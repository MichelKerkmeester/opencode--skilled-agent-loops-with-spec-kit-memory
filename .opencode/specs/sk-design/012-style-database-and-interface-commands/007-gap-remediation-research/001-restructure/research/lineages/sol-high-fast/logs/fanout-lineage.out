\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": true,\n  \"specFolder\": \".opencode/specs/sk-design/013-styles-database-rust-opportunities\",\n  \"artifactDir\": \".opencode/specs/sk-design/013-styles-database-rust-opportunities/research/lineages/sol-opencode\",\n  \"fanout_lineage_artifact_dir\": \".opencode/specs/sk-design/013-styles-database-rust-opportunities/research/lineages/sol-opencode\",\n  \"resource_map_present\": false,\n  \"resource_map\": {\n    \"emit\": true\n  },\n  \"createdAt\": \"2026-07-20T04:20:12Z\",\n  \"status\": \"complete\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"cli-opencode\",\n    \"model\": \"openai/gpt-5.6-sol-fast\",\n    \"configDir\": null,\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900,\n    \"governor\": null\n  },\n  \"lineage\": {\n    \"sessionId\": \"fanout-sol-opencode-1784520993412-ps7omk\",\n    \"parentSessionId\": null,\n    \"lineageMode\": \"new\",\n    \"allowedModes\": [\"new\", \"resume\", \"restart\"],\n    \"deferredModes\": [\"fork\", \"completed-continue\"],\n    \"generation\": 1,\n    \"continuedFromRun\": null\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"version\": \"1.0\",\n    \"registryFile\": \"findings-registry.json\",\n    \"dashboardFile\": \"deep-research-dashboard.md\",\n    \"strategyFile\": \"deep-research-strategy.md\",\n    \"machineOwnedSections\": [\n      \"key-questions\",\n      \"answered-questions\",\n      \"what-worked\",\n      \"what-failed\",\n      \"exhausted-approaches\",\n      \"ruled-out-directions\",\n      \"divergence-frontier\",\n      \"next-focus\"\n    ]\n  },\n  \"capabilityMatrixPath\": \".opencode/skills/system-deep-loop/deep-research/assets/runtime-capabilities.json\",\n  \"reducerScriptPath\": \".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs\",\n  \"pauseSentinelPath\": \".deep-research-pause\",\n  \"archiveRoot\": \"_archive\",\n  \"migrationWindowDays\": 28,\n  \"nextRunAt\": null,\n  \"remainingDelayMs\": null,\n  \"fileProtection\": {\n    \"deep-research-config.json\": \"immutable\",\n    \"deep-research-state.jsonl\": \"append-only\",\n    \"deep-research-strategy.md\": \"mutable\",\n    \"deep-research-dashboard.md\": \"auto-generated\",\n    \"findings-registry.json\": \"auto-generated\",\n    \"iteration-*.md\": \"write-once\",\n    \"research.md\": \"mutable\"\n  }\n}","lineStart":1,"lineEnd":81,"totalLines":81,"truncated":false}},"title":".opencode/specs/sk-design/013-styles-database-rust-opportunities/research/lineages/sol-opencode/deep-research-config.json","time":{"start":1784616134088,"end":1784616134193}},"metadata":{"openai":{"itemId":"fc_0e55e3c0bf11150f016a5f14c5cb8c81919d8402447bcdcba3"}},"id":"prt_f836925c50019MtVGFg7dcQcvU","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f8368c0e7001D1i4allOODIHEM"}}
{"type":"tool_use","timestamp":1784616134204,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_HPPt70AVHZmBUtviaWBLPfgu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DEEP RESEARCH: AUTONOMOUS DEEP RESEARCH LOOP (AUTO MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: # YAML PREDICATE GRAMMAR CONTRACT (S7 / M11):\n5: # - This asset does not currently use typed BooleanExpr predicates under\n6: #   `when:`; flow control is branch-label-driven (`on_resume`, `on_fresh`,\n7: #   `on_restart`, etc.). Retain the existing shape.\n8: # - `after:` carries prose timing / narrative notes if needed; `when:` in\n9: #   this file is reserved for future typed predicates and must NOT carry\n10: #   free-form narrative prose.\n11: # - See `.opencode/skills/system-spec-kit/shared/predicates/boolean-expr.ts`\n12: #   for the canonical BooleanExpr grammar.\n13: #\n14: # GATE 3 CLASSIFICATION (T-YML-DPR-01 / paired with T-DOC-03 R50-001):\n15: # - `resume` is a tested WRITE-PATH that produces `iteration-NNN.md` files\n16: #   and JSONL state-log appends. The workflow classifies resume as\n17: #   write-path below (see `gate3_classification` fields) so Gate 3 trigger\n18: #   extraction can surface resume correctly rather than false-negative.\n19: # ─────────────────────────────────────────────────────────────────\n20: role: Deep Research Loop Manager\n21: purpose: Iterative deep research with convergence detection\n22: action: Run deep-research loop from initialization through synthesis\n23: operating_mode:\n24:   workflow: iterative_loop\n25:   workflow_compliance: MANDATORY\n26:   workflow_execution: autonomous\n27:   approvals: none\n28:   tracking: progressive_research_state\n29:   validation: convergence_detection\n30: \n31: # ─────────────────────────────────────────────────────────────────\n32: # OPERATING PRINCIPLES\n33: # ─────────────────────────────────────────────────────────────────\n34: operating_principles:\n35:   core: \"Fresh context per iteration + externalized state = no context degradation\"\n36:   approach: \"Dispatch focused agent, evaluate convergence, repeat or stop\"\n37:   mandate: \"Never hold findings in memory; write everything to files\"\n38: \n39: # ─────────────────────────────────────────────────────────────────\n40: # USER INPUTS (from setup phase)\n41: # ─────────────────────────────────────────────────────────────────\n42: user_inputs:\n43:   research_topic: \"[RESEARCH_TOPIC] - Topic to investigate deeply. REQUIRED.\"\n44:   spec_folder: \"[SPEC_FOLDER] - Spec folder path. REQUIRED.\"\n45:   max_iterations: \"[MAX_ITERATIONS] - Maximum loop iterations. Default: 10.\"\n46:   convergence_threshold: \"[CONVERGENCE_THRESHOLD] - Stop threshold. Default: 0.05.\"\n47:   convergence_mode: \"[default|off|sliding-window|divergent] - Convergence policy modifier. Default: default.\"\n48: \n49: # ─────────────────────────────────────────────────────────────────\n50: # CONTEXT LOADING\n51: # ─────────────────────────────────────────────────────────────────\n52: context_loading:\n53:   trigger: \"At workflow START, before phase_init\"\n54:   purpose: \"Load prior research context for the topic and buffer it until strategy.md exists\"\n55:   mcp_integration:\n56:     tool: memory_context\n57:     note: \"Call MCP tools directly - NEVER through Code Mode\"\n58:     parameters: { input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n59:   when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n60:   behavior:\n61:     if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n62:     if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n63: \n64: # ─────────────────────────────────────────────────────────────────\n65: # SKILL REFERENCE\n66: # ─────────────────────────────────────────────────────────────────\n67: skill_reference:\n68:   skill: system-deep-loop\n69:   skill_md: .opencode/skills/system-deep-loop/deep-research/SKILL.md\n70:   references:\n71:     loop_protocol: .opencode/skills/system-deep-loop/deep-research/references/protocol/loop-protocol.md\n72:     spec_check_protocol: .opencode/skills/system-deep-loop/deep-research/references/protocol/spec-check-protocol.md\n73:     state_format: .opencode/skills/system-deep-loop/deep-research/references/state/state-format.md\n74:     convergence: .opencode/skills/system-deep-loop/deep-research/references/convergence/convergence.md\n75:   templates:\n76:     config: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json\n77:     strategy: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md\n78: \n79: # ─────────────────────────────────────────────────────────────────\n80: # AGENT CONFIGURATION\n81: # ─────────────────────────────────────────────────────────────────\n82: agent_config:\n83:   agent: deep-research\n84:   agent_file: \".opencode/agents/deep-research.md\"\n85:   # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n86:   model: opus\n87:   leaf_only: true\n88:   tools: [Read, Write, Edit, Bash, Grep, Glob, WebFetch]\n89:   mcp_servers: [mk-spec-memory]\n90:   tool_call_budget: { target: 8, max: 12 }\n91: \n92: # ─────────────────────────────────────────────────────────────────\n93: # STATE FILE PATHS\n94: # ─────────────────────────────────────────────────────────────────\n95: state_paths:\n96:   # Template paths document the canonical packet layout. Runtime resolution happens via\n97:   # step_resolve_artifact_root plus the shared resolver, so root specs keep root-local\n98:   # research/ and child phases keep local research/ packet directories.\n99:   packet_dir: \"{artifact_dir}\"\n100:   config: \"{artifact_dir}/deep-research-config.json\"\n101:   state_log: \"{artifact_dir}/deep-research-state.jsonl\"\n102:   status_ledger: \"{artifact_dir}/orchestration-status.log\"\n103:   strategy: \"{artifact_dir}/deep-research-strategy.md\"\n104:   registry: \"{artifact_dir}/findings-registry.json\"\n105:   dashboard: \"{artifact_dir}/deep-research-dashboard.md\"\n106:   pause_sentinel: \"{artifact_dir}/.deep-research-pause\"\n107:   run_now_sentinel: \"{artifact_dir}/.deep-research-run-now\"\n108:   lock_file: \"{artifact_dir}/.deep-research.lock\"\n109:   prompt_dir: \"{artifact_dir}/prompts\"\n110:   iteration_dir: \"{artifact_dir}/iterations\"\n111:   iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n112:   # Per-iteration structured delta stream (one file per iteration) — complement to the\n113:   # canonical state_log append. The delta file MUST contain at least one record whose\n114:   # `type === \"iteration\"` so the reducer can rehydrate iteration state after a partial\n115:   # run. Variants like `\"iteration_delta\"` are silently dropped by the reducer; the\n116:   # post_dispatch_validate step enforces the canonical type below.\n117:   delta_dir: \"{artifact_dir}/deltas\"\n118:   delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n119:   research_output: \"{artifact_dir}/research.md\"\n120:   resource_map_output: \"{artifact_dir}/resource-map.md\"\n121:   archive_root: \"{artifact_archive_root}\"\n122:   synthesis_snapshot_pattern: \"{artifact_dir}/synthesis-v{generation}.md\"\n123: \n124: # ─────────────────────────────────────────────────────────────────\n125: # WORKFLOW\n126: # ─────────────────────────────────────────────────────────────────\n127: workflow:\n128: \n129:   step_resolve_artifact_root:\n130:     description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n131:     note: \"Root specs keep research artifacts directly in {spec_folder}/research/. Child phases and sub-phases keep local packet directories in {spec_folder}/research/{packet}/, and archives stay local at {spec_folder}/research_archive/{packet}/.\"\n132:     branch_on: \"config.fanout_lineage_artifact_dir\"\n133:     if_present:\n134:       bind:\n135:         artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n136:         artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n137:         artifact_subfolder: null\n138:         artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n139:     if_absent:\n140:       command: \"node -e \\\"const { resolveArtifactRoot } = require('./.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'research')));\\\"\"\n141:       outputs:\n142:         - artifact_root_dir: \"Resolved local research owner directory\"\n143:         - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n144:         - artifact_dir: \"Resolved research packet directory for this target\"\n145:         - artifact_archive_root: \"Resolved local research archive directory for this target\"\n146: \n147:   step_fanout_spawn:\n148:     description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n149:     skip_when: \"config.fanout is absent\"\n150:     instructions: |\n151:       Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n152:       isolated sub-packet under {artifact_dir}/lineages/{label}/.\n153:       fanout-run.cjs owns native and CLI lineage execution; native is run through the\n154:       deep/research command surface with config.fanout_lineage_artifact_dir so the LEAF\n155:       deep-research agent is used only for individual iterations, never as a full-loop\n156:       sub-agent or pasted phase-running prompt.\n157:       After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n158:       phase_main_loop entirely (those are the single-executor path). The merge step in\n159:       phase_synthesis will consolidate results across all lineages.\n160:     sub_steps:\n161:       step_fanout_spawn_cli:\n162:         description: \"Spawn all native and CLI lineages in capped worker pool\"\n163:         skip_when: \"no entries in config.fanout.executors\"\n164:         command: |\n165:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs \\\n166:             --spec-folder {spec_folder} \\\n167:             --loop-type research \\\n168:             --research-topic \"{research_topic}\" \\\n169:             --fanout-config-json '{config.fanout_json}' \\\n170:             --base-artifact-dir {artifact_dir} \\\n171:             --convergence-threshold {convergence_threshold}\n172:         working_directory: \"{repo_root}\"\n173:         wait_for_completion: true\n174: \n175:   # ═══════════════════════════════════════════════════════════════\n176:   # PHASE 1: INITIALIZATION\n177:   # ═══════════════════════════════════════════════════════════════\n178:   phase_init:\n179:     purpose: Create all state files for the research session\n180:     steps:\n181: \n182:       step_preflight_contract:\n183:         action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n184:         verify:\n185:           - required_values_present: [research_topic, spec_folder, max_iterations, convergence_threshold, convergence_mode]\n186:           - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n187:           - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n188:           - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n189:         on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n190: \n191:       step_create_directories:\n192:         action: \"Create spec folder and research packet directories if they don't exist\"\n193:         command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n194: \n195:       step_detect_resource_map:\n196:         action: \"Detect resource-map.md before config creation so init can persist the flag and seed Known Context\"\n197:         inspect:\n198:           - \"{spec_folder}/resource-map.md\"\n199:         classify:\n200:           present: \"resource-map.md exists at init\"\n201:           absent: \"resource-map.md does not exist at init\"\n202:         outputs:\n203:           - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n204:           - resource_map_known_context: \"When present: summarize the map by section with entry counts across READMEs, Documents, Commands, Agents, Skills, Specs, Scripts, Tests, Config, and Meta, plus a one-line theme summary for each section. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n205: \n206:       step_resolve_canonical_names:\n207:         action: \"Resolve canonical research packet artifact names before classification\"\n208:         inspect_legacy:\n209:           - \"{state_paths.packet_dir}/config.json\"\n210:           - \"{state_paths.packet_dir}/state.jsonl\"\n211:           - \"{state_paths.packet_dir}/strategy.md\"\n212:           - \"{state_paths.packet_dir}/dashboard.md\"\n213:           - \"{state_paths.packet_dir}/.pause\"\n214:         migration_policy: \"dual-read / single-write for 4 weeks\"\n215:         on_legacy_read:\n216:           append_jsonl: '{\"type\":\"event\",\"event\":\"migration\",\"legacyPath\":\"{legacy_path}\",\"canonicalPath\":\"{canonical_path}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n217: \n218:       step_acquire_lock:\n219:         action: \"Acquire the single-writer advisory lock before session classification\"\n220:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n221:         on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-research run already holds this packet.\"\n222:         note: \"Uses the promoted runtime/ loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n223:         # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n224:         # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n225:         on_halt:\n226:           action: \"Release the lock before any terminal halt branch returns control\"\n227:           applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\", \"step_preinit_spec_branch.conflict-detected\"]\n228:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n229:         on_cancel:\n230:           action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n231:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n232:         on_workflow_exit:\n233:           action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n234:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n235: \n236:       step_classify_session:\n237:         action: \"Classify the session before writing files\"\n238:         inspect:\n239:           - \"{state_paths.config}\"\n240:           - \"{state_paths.state_log}\"\n241:           - \"{state_paths.strategy}\"\n242:         classify:\n243:           fresh: \"None of the three state artifacts exist\"\n244:           resume: \"Config, JSONL, and strategy all exist and agree on topic/spec folder; missing wait-checkpoint fields are read as nextRunAt:null and remainingDelayMs:null\"\n245:           completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n246:           invalid-state: \"Any partial, missing, or contradictory combination\"\n247:         outputs:\n248:           - session_state: \"fresh | resume | completed-session | invalid-state\"\n249:         on_resume:\n250:           # T-YML-DPR-01 / R50-001: Resume is a WRITE-PATH. Produces `iteration-NNN.md` + JSONL appends.\n251:           # Paired with T-DOC-03 Gate 3 trigger addition (resume, save context, save memory, /memory:save).\n252:           gate3_classification: write-path\n253:           gate3_rationale: \"resume produces iteration-NNN.md writes and JSONL state-log appends\"\n254:           log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n255:           append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n256:           skip_to: phase_loop\n257:         on_restart:\n258:           action: \"Archive the current research packet under the root-level research_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n259:           command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n260:           set:\n261:             lineage_mode: \"restart\"\n262:             parent_session_id: \"{prior_session_id}\"\n263:             generation: \"{prior_generation + 1}\"\n264:           append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n265:           skip_to: step_create_config\n266:         note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-research/references/protocol/loop-protocol.md §Lifecycle Branch Contract for the one-session contract.\"\n267:         on_completed_session:\n268:           log: \"Prior session already completed. Do not route directly to synthesis; archive the completed research/ tree or start a fresh packet instead.\"\n269:           halt: true\n270:           message: \"Completed deep-research packet detected. Archive or replace the existing research/ tree before starting a new session.\"\n271:         on_invalid_state:\n272:           halt: true\n273:           message: \"Existing deep-research state is incomplete or contradictory. Repair or archive the invalid research packet before continuing.\"\n274:         on_fresh:\n275:           action: \"Proceed with a new session\"\n276: \n277:       step_resolve_session_id:\n278:         action: \"Resolve init session id from caller when supplied, else preserve the auto-generated fallback\"\n279:         branch_on: \"session_id\"\n280:         if_present:\n281:           bind:\n282:             session_id_init: \"{session_id}\"\n283:         if_absent:\n284:           bind:\n285:             session_id_init: \"{AUTO_SESSION_ID}\"\n286: \n287:       step_create_config:\n288:         action: \"Create deep-research-config.json from template\"\n289:         template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json\n290:         populate:\n291:           topic: \"{research_topic}\"\n292:           maxIterations: \"{max_iterations}\"\n293:           minIterations: 3\n294:           # Semantic: newInfoRatio with negative-knowledge emphasis. See SKILL.md §\"Convergence Threshold Semantics\".\n295:           convergenceThreshold: \"{convergence_threshold}\"\n296:           antiConvergence.convergenceMode: \"{convergence_mode}\"\n297:           antiConvergence.divergent: {}\n298:           stuckThreshold: 3\n299:           minIdeaObservations: 2\n300:           maxDurationMinutes: 120\n301:           specFolder: \"{spec_folder}\"\n302:           resource_map_present: \"{resource_map_present}\"\n303:           # Honor the parsed --no-resource-map flag from deep-research.md:73 (default true; false when flag is set).\n304:           # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n305:           resource_map.emit: \"{resource_map_emit}\"\n306:           createdAt: \"{ISO_8601_NOW}\"\n307:           status: \"initialized\"\n308:           executionMode: \"auto\"\n309:           lineage.sessionId: \"{session_id_init}\"\n310:           lineage.parentSessionId: null\n311:           lineage.lineageMode: \"new\"\n312:           lineage.generation: 1\n313:           lineage.continuedFromRun: null\n314:           nextRunAt: null\n315:           remainingDelayMs: null\n316:         output: \"{state_paths.config}\"\n317: \n318:       step_create_state_log:\n319:         action: \"Initialize JSONL state log with config record\"\n320:         # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n321:         content: '{\"type\":\"config\",\"topic\":\"{research_topic}\",\"maxIterations\":{max_iterations},\"minIterations\":3,\"convergenceThreshold\":{convergence_threshold},\"antiConvergence\":{\"convergenceMode\":\"{convergence_mode}\",\"divergent\":{}},\"minIdeaObservations\":2,\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\",\"nextRunAt\":null,\"remainingDelayMs\":null}'\n322:         output: \"{state_paths.state_log}\"\n323: \n324:       step_create_strategy:\n325:         action: \"Create strategy file from template with initial questions\"\n326:         template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md\n327:         populate:\n328:           topic: \"{research_topic}\"\n329:           key_questions: \"Derive 3-5 key questions from the research topic\"\n330:           known_context: \"None\"\n331:           known_context_summary: \"None\"\n332:           max_iterations: \"{max_iterations}\"\n333:           convergence_threshold: \"{convergence_threshold}\"\n334:         output: \"{state_paths.strategy}\"\n335: \n336:       step_create_registry:\n337:         action: \"Initialize reducer-owned findings registry\"\n338:         content: '{\"openQuestions\":[],\"resolvedQuestions\":[],\"keyFindings\":[],\"ruledOutDirections\":[],\"metrics\":{\"iterationsCompleted\":0,\"openQuestions\":0,\"resolvedQuestions\":0,\"keyFindings\":0,\"convergenceScore\":0,\"coverageBySources\":{}}}'\n339:         output: \"{state_paths.registry}\"\n340: \n341:       step_enrich_strategy_context:\n342:         action: \"Ensure Known Context is written only after strategy.md exists\"\n343:         condition: \"prior_context_found\"\n344:         edit: \"{state_paths.strategy}\"\n345:         note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n346: \n347:       step_enrich_strategy_resource_map:\n348:         action: \"Inject resource-map status into Known Context after strategy.md exists\"\n349:         edit: \"{state_paths.strategy}\"\n350:         note: \"When resource_map_present is true, append the resource_map_known_context snapshot. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n351: \n352:       step_detect_spec_present:\n353:         action: \"Classify late-INIT spec.md state after the durable research packet exists\"\n354:         inspect:\n355:           - \"{spec_folder}/spec.md\"\n356:           - \"{state_paths.lock_file}\"\n357:         classify:\n358:           no-spec: \"spec.md is absent before any pre-init mutation\"\n359:           spec-present: \"spec.md exists and approved host anchors are available for bounded mutation\"\n360:           spec-just-created-by-this-run: \"spec.md already carries this run's DR seed markers and should not be reseeded\"\n361:           conflict-detected: \"missing host anchor, duplicate markers, or generated-block ambiguity makes mutation unsafe\"\n362:         outputs:\n363:           - folder_state: \"no-spec | spec-present | spec-just-created-by-this-run | conflict-detected\"\n364:           - normalized_topic: \"Trim, lowercase, and collapse whitespace in research_topic before dedupe checks\"\n365:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"spec_check_result\",\"folder_state\":\"{folder_state}\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"lockPath\":\"{state_paths.lock_file}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n366: \n367:       step_preinit_spec_branch:\n368:         action: \"Run the bounded pre-init spec branch required by spec_check_protocol\"\n369:         protocol_reference: \".opencode/skills/system-deep-loop/deep-research/references/protocol/spec-check-protocol.md\"\n370:         branches:\n371:           no-spec:\n372:             create: \"{spec_folder}/spec.md\"\n373:             seed_markers:\n374:               - \"<!-- DR-SEED:REQUIREMENTS -->\"\n375:               - \"<!-- DR-SEED:SCOPE -->\"\n376:             requirements_host: \"Seed Requirements from the research ask without broadening scope\"\n377:             scope_host: \"Seed Scope from the research ask without inventing implementation details\"\n378:             set:\n379:               folder_state: \"spec-just-created-by-this-run\"\n380:               validate_spec_doc: true\n381:             append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_seed_created\",\"folder_state\":\"spec-just-created-by-this-run\",\"anchors_touched\":[\"Requirements\",\"Scope\"],\"diff_summary\":\"Seeded Level 1 spec.md from research topic with DR seed markers.\",\"seed_markers\":[\"DR-SEED:REQUIREMENTS\",\"DR-SEED:SCOPE\"],\"timestamp\":\"{ISO_8601_NOW}\"}'\n382:           spec-present:\n383:             edit: \"{spec_folder}/spec.md\"\n384:             set:\n385:               validate_spec_doc: true\n386:             idempotency_check:\n387:               host_anchor: \"Open Questions\"\n388:               normalized_match: \"Normalize the existing anchor text by lowercasing, stripping punctuation, collapsing whitespace, and trimming before comparing with {normalized_topic}.\"\n389:               if_match:\n390:                 skip_append: true\n391:                 append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_deduped\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\"],\"diff_summary\":\"Skipped duplicate pre-init topic append because normalized topic already exists in Open Questions.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n392:               if_no_match:\n393:                 append_only:\n394:                   - host_anchor: \"Open Questions\"\n395:                     content: \"Add the normalized research topic only if it is not already present.\"\n396:                   - host_anchor: \"Research Context\"\n397:                     content: \"Add a bounded note that deep-research is active for this topic and that research/research.md remains canonical.\"\n398:                 append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_added\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\",\"Research Context\"],\"diff_summary\":\"Appended bounded pre-init research context for the normalized topic.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n399:           spec-just-created-by-this-run:\n400:             verify_markers:\n401:               - \"<!-- DR-SEED:REQUIREMENTS -->\"\n402:               - \"<!-- DR-SEED:SCOPE -->\"\n403:             set:\n404:               validate_spec_doc: false\n405:             note: \"Treat already-seeded spec.md as a no-op guard and continue.\"\n406:           conflict-detected:\n407:             append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Pre-init spec.md mutation is ambiguous or unsafe.\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n408:             halt: true\n409: \n410:       step_validate_preinit_spec_doc:\n411:         action: \"Run targeted strict validation after any deep-research pre-init spec.md mutation\"\n412:         condition: \"validate_spec_doc\"\n413:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n414:         note: \"This enforces the authored-spec markdown structural contract without applying full-packet required-file or completeness checks to workflow-owned research artifacts. It uses the Node validation orchestrator, whose strict path was measured at about 108ms for a fresh Level 3 packet on the local harness.\"\n415: \n416:       step_telemetry_heartbeat_started:\n417:         action: \"Emit a single-loop started row in the orchestration status ledger\"\n418:         skip_when: \"config.fanout is present\"\n419:         canonical_lifecycle_event: \"iteration_start\"\n420:         command: |\n421:           node --experimental-strip-types --input-type=module <<'EOF'\n422:           import { readFileSync } from 'node:fs';\n423: \n424:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n425:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n426: \n427:           const { appendObservabilityEvent } = observabilityEvents;\n428:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n429:           const timestamp = '{ISO_8601_NOW}';\n430:           const sessionId = String(config.lineage?.sessionId ?? '{AUTO_SESSION_ID}');\n431:           const generation = Number(config.lineage?.generation ?? 1);\n432:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n433:           const row = {\n434:             event: 'started',\n435:             label: 'single',\n436:             at: timestamp,\n437:             duration_ms: 0,\n438:             loop_type: 'research',\n439:             sessionId,\n440:             generation,\n441:             gauges: { iterations: 0, elapsed_ms: 0, score: 0 },\n442:           };\n443: \n444:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n445:             diffData: { event: row.event, label: row.label, sessionId, generation, gauges: { iterations: 0, score: 0 } },\n446:             diffField: 'state_hash',\n447:           });\n448:           if (appended) {\n449:             try {\n450:               appendObservabilityEvent(observabilityPath, row, {\n451:                 producer: 'deep-research-auto',\n452:                 stream: 'single-loop-telemetry',\n453:                 subject: { label: row.label, sessionId, generation },\n454:                 event: row.event,\n455:                 status: 'running',\n456:               });\n457:             } catch {}\n458:           }\n459:           EOF\n460:         working_directory: \"{repo_root}\"\n461:         outputs:\n462:           - status_ledger_started: \"A fan-out-shaped status row with label single and event started\"\n463: \n464:       step_init_complete:\n465:         log: \"Initialization complete. Config, state, and strategy files created.\"\n466:         set: { current_iteration: 1, current_segment: 1, stuck_count: 0 }\n467: \n468:   # ═══════════════════════════════════════════════════════════════\n469:   # PHASE 2: ITERATION LOOP\n470:   # ═══════════════════════════════════════════════════════════════\n471:   phase_loop:\n472:     purpose: Dispatch agent iterations until convergence\n473:     repeat: true\n474:     max_repeats: \"{max_iterations}\"\n475:     steps:\n476: \n477:       step_read_state:\n478:         action: \"Read current state from JSONL and strategy\"\n479:         read:\n480:           - \"{state_paths.state_log}\"\n481:           - \"{state_paths.strategy}\"\n482:           - \"{state_paths.config}\"\n483:         extract:\n484:           - iteration_count: \"Count lines where type === 'iteration'\"\n485:           - current_iteration: \"iteration_count + 1\"\n486:           - current_segment: \"Latest segment_start event segment, else 1\"\n487:           - last_newInfoRatio: \"Extract newInfoRatio from last iteration record\"\n488:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n489:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n490:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n491:           - next_focus: \"Extract 'Next Focus' section from strategy.md\"\n492:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n493:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n494:           - carried_forward_open_questions: \"Extract 'Carried-Forward Open Questions' section from strategy.md, else '[None yet]'\"\n495:           - answered_count: \"Count answered questions from strategy.md\"\n496:           - total_questions: \"Count total questions tracked in strategy.md\"\n497:           - resource_map_present: \"Extract boolean from deep-research-config.json, default false\"\n498:           - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource map: prior-inventoried files are listed in {spec_folder}/resource-map.md; treat them as the exclusion set when hunting for net-new files; flag only missed-from-map candidates as gaps.' Else return 'Resource map: resource-map.md not present; skipping coverage gate.'\"\n499:           - memory_context_prompt_line: \"If a refreshed memory context summary exists from the previous iteration, return 'Memory context refresh: {summary}'. Else use prior_context_summary from startup when available; otherwise return 'Memory context refresh: none loaded yet.'\"\n500:           - least_explored: \"First unanswered question not covered by the most recent iteration focus, else first unanswered question\"\n501:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n502:           - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n503:           - nextRunAt: \"Extract nullable nextRunAt from deep-research-config.json, default null\"\n504:           - remainingDelayMs: \"Extract nullable remainingDelayMs from deep-research-config.json, default null\"\n505:           - min_iterations_present: \"Boolean true when deep-research-config.json has a numeric minIterations field\"\n506:           - min_iterations_missing_warning: \"Boolean true when minIterations is missing; use no floor and log a warning so older configs keep prior stop behavior\"\n507:           - min_iterations_raw: \"Extract numeric minIterations from deep-research-config.json when present, default 0\"\n508:           - effective_min_iterations: \"Clamp min_iterations_raw to the inclusive range 0..max_iterations; if min_iterations_raw exceeds max_iterations, use max_iterations\"\n509:           - min_iterations_clamped: \"Boolean true when min_iterations_raw > max_iterations\"\n510:           - min_iterations_guard_already_passed: \"Boolean true when state_log already contains event == 'min_iterations_guard_pass'\"\n511:           - convergence_mode: \"Extract antiConvergence.convergenceMode when it is one of 'default', 'off', 'sliding-window', or 'divergent'; default to 'default'\"\n512:           - convergence_mode_warning: \"Boolean true when antiConvergence.convergenceMode is present with an unsupported value; use 'default'\"\n513:           - rejected_patterns_count: \"Read registry.rejectedPatterns length when registry exists, else 0\"\n514:           - rejected_candidate_matches: \"Read registry.suppressedCandidates when registry exists, else []\"\n515:           - rejected_pattern_fuzzy_threshold: \"Read config.rejectedPatternFuzzyThreshold when present, else 0.85\"\n516:           - min_idea_observations: \"Read config.minIdeaObservations when present, default 2; clamp to 1..10\"\n517:           - observed_ideas_count: \"Read registry.observedIdeas length when registry exists, else 0\"\n518:           - promoted_ideas_count: \"Read registry.promotedIdeas length when registry exists, else 0\"\n519:           - promoted_ideas_list: \"Read registry.promotedIdeas idea text in rank order when registry exists, else []\"\n520:           - suppressed_ideas_count: \"Read registry.suppressedIdeas length when registry exists, else 0\"\n521:           - pivot_lineage: \"Summarize registry.divergence.completed and registry.divergence.overrides with pivot ids, source iterations, and selected focus; else 'none yet'\"\n522:           - saturated_directions: \"List registry.divergence.saturatedDirections; else 'none yet'\"\n523: \n524:       step_run_now_check:\n525:         action: \"Detect and consume a one-shot run-now sentinel before pause/convergence/dispatch\"\n526:         command: |\n527:           node <<'EOF'\n528:           const { appendFileSync, existsSync, renameSync, unlinkSync } = require('node:fs');\n529: \n530:           const stateLogPath = \"{state_paths.state_log}\";\n531:           const sentinelPath = \"{state_paths.run_now_sentinel}\";\n532:           const pausePath = \"{state_paths.pause_sentinel}\";\n533:           const timestamp = \"{ISO_8601_NOW}\";\n534:           const sessionId = \"{config.lineage.sessionId}\";\n535:           const generation = Number(\"{config.lineage.generation}\");\n536:           const run = Number(\"{current_iteration}\");\n537: \n538:           function append(event) {\n539:             appendFileSync(\n540:               stateLogPath,\n541:               `${JSON.stringify({\n542:                 type: \"event\",\n543:                 mode: \"research\",\n544:                 run,\n545:                 timestamp,\n546:                 sessionId,\n547:                 generation,\n548:                 ...event,\n549:               })}\\n`,\n550:               \"utf8\",\n551:             );\n552:           }\n553: \n554:           if (existsSync(sentinelPath)) {\n555:             append({ event: \"run_now_requested\", sentinelPath });\n556:             if (existsSync(pausePath)) {\n557:               append({\n558:                 event: \"run_now_rejected\",\n559:                 reason: \"loop_paused\",\n560:                 sentinelPath,\n561:                 pauseSentinelPath: pausePath,\n562:               });\n563:             } else {\n564:               const claimPath = `${sentinelPath}.consuming.${process.pid}.${Date.now()}`;\n565:               try {\n566:                 renameSync(sentinelPath, claimPath);\n567:                 unlinkSync(claimPath);\n568:                 append({\n569:                   event: \"run_now_accepted\",\n570:                   sentinelPath,\n571:                   dispatchEvent: \"iteration_start\",\n572:                 });\n573:               } catch (error) {\n574:                 if (!error || error.code !== \"ENOENT\") {\n575:                   throw error;\n576:                 }\n577:               }\n578:             }\n579:           }\n580:           EOF\n581:         outputs:\n582:           - run_now_requested: \"Emitted when {state_paths.run_now_sentinel} exists at the loop boundary\"\n583:           - run_now_accepted: \"Emitted after the sentinel is atomically renamed and deleted before dispatch\"\n584:           - run_now_rejected: \"Emitted with reason loop_paused when pause takes precedence; sentinel remains present\"\n585: \n586:       step_check_pause_sentinel:\n587:         action: \"Check for pause sentinel file\"\n588:         check: \"Does {state_paths.pause_sentinel} exist?\"\n589:         if_exists:\n590:           log_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n591:           message: \"Research paused. Delete research/.deep-research-pause to resume.\"\n592:           halt: true\n593:         if_not_exists:\n594:           proceed: true\n595: \n596:       step_validate_convergence_config:\n597:         action: \"Validate convergence floor settings when loading config\"\n598:         if_min_iterations_missing:\n599:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"fallback\":0,\"message\":\"minIterations missing; using no convergence floor for backward compatibility.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n600:           log: \"minIterations missing; using no convergence floor for backward compatibility.\"\n601:         if_min_iterations_clamped:\n602:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"configured\":{min_iterations_raw},\"effective\":{effective_min_iterations},\"maxIterations\":{max_iterations},\"message\":\"minIterations exceeds maxIterations; clamping to the hard cap.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n603:           log: \"minIterations exceeds maxIterations; clamping to the hard cap.\"\n604:         if_convergence_mode_invalid:\n605:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"convergenceMode\",\"fallback\":\"default\",\"message\":\"Unsupported convergenceMode; using default convergence behavior.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n606:           log: \"Unsupported convergenceMode; using default convergence behavior.\"\n607: \n608:       step_graph_convergence:\n609:         action: \"Evaluate coverage-graph convergence before the inline 3-signal vote and persist the graph decision snapshot\"\n610:         bash: 'node .opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"research\" --session-id \"{config.lineage.sessionId}\" --convergence-mode \"{convergence_mode}\"'\n611:         note: \"Run before the inline vote. STOP from the inline 3-signal vote is allowed only when the graph decision is STOP_ALLOWED or absent.\"\n612:         outputs:\n613:           - graph_decision: \"Tool decision value (CONTINUE | STOP_ALLOWED | STOP_BLOCKED), else null when unavailable\"\n614:           - graph_decision_json: \"JSON-encoded graph decision string, else null\"\n615:           - graph_signals_json: \"Tool signals object, else {}\"\n616:           - graph_blockers_json: \"Tool blockers array, else []\"\n617:           - graph_trace_json: \"Tool trace payload, else []\"\n618:           - graph_convergence_score: \"signals.blendedScore when present, else the best available graph score, else 0\"\n619:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"research\",\"run\":{current_iteration},\"decision\":{graph_decision_json},\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n620: \n621:       step_check_convergence:\n622:         action: \"Evaluate stop conditions and combine the inline 3-signal vote with graph convergence\"\n623:         algorithm: |\n624:           1. if iteration_count >= max_iterations: STOP (maxIterationsReached). This terminal cap bypasses quality-guard overrides; record failed guards/blockers as synthesis evidence instead of continuing.\n625:           2. if stuck_count >= config.stuckThreshold: STUCK_RECOVERY\n626:           3. if convergence_mode == \"off\": skip convergence stop candidates and continue unless a terminal cap, pause sentinel, or recovery halt has already fired.\n627:           4. if remaining_questions == 0: STOP (all_questions_answered)\n628:           5. GRAPH-ASSISTED COMPOSITE CONVERGENCE:\n629:                step_graph_convergence already recorded graph_decision, graph_signals_json, graph_blockers_json, and graph_convergence_score for this run.\n630:                The existing inline 3-signal vote still computes the inline STOP candidate and is not replaced.\n631:                signals = []\n632:                Filter: exclude iterations where status == thought from signal inputs (use only evidence iterations)\n633:                a) Rolling average (w=0.30, needs 3+ iterations):\n634:                   avg = mean(last 3 newInfoRatios)\n635:                   stop if avg < convergence_threshold\n636:                b) MAD noise floor (w=0.35, needs 4+ iterations):\n637:                   noiseFloor = MAD(all ratios) * 1.4826\n638:                   stop if latest ratio <= noiseFloor\n639:                c) Question entropy (w=0.35):\n640:                   coverage = answered / total questions\n641:                   stop if coverage >= 0.85\n642:                Redistribute weights for unavailable signals.\n643:                if weighted_stop_score > 0.60: inline_stop_candidate = true\n644:                Combined stop rule: STOP only if the inline 3-signal vote says STOP AND graph_decision is STOP_ALLOWED or absent.\n645:                if inline_stop_candidate and graph_decision == \"STOP_BLOCKED\":\n646:                  decision = \"BLOCKED\"\n647:                  reason = \"blockedStop\"\n648:                  stop_blocked = true\n649:                  blocked_by_json = JSON array derived from graph_blockers_json\n650:                  blocked_by_csv = comma-separated blocker names derived from graph_blockers_json\n651:                  gate_convergence_pass = false\n652:                  gate_convergence_score = graph_convergence_score\n653:                  gate_key_question_coverage_pass = no blocker named questionCoverage\n654:                  gate_evidence_density_pass = no blocker named sourceDiversity or evidenceDepth\n655:                  gate_evidence_density_sources = graph_signals_json.sourceDiversity or 0\n656:                  gate_hotspot_saturation_pass = true\n657:                  recovery_strategy = first blocker reason/message, else \"Collect deeper graph evidence before stopping.\"\n658:                else if inline_stop_candidate and (graph_decision == \"STOP_ALLOWED\" or graph_decision is absent):\n659:                  decision = \"STOP\"\n660:                  reason = \"composite_converged\"\n661:                  stop_blocked = false\n662:           6. else: CONTINUE\n663:           7. if decision == \"STOP\" and reason != \"maxIterationsReached\" and effective_min_iterations > 1 and iteration_count < effective_min_iterations:\n664:                decision = \"CONTINUE\"\n665:                reason = \"minIterationsNotReached\"\n666:                min_iterations_guard_blocked = true\n667:                min_iterations_guard_pass = false\n668:           8. if effective_min_iterations > 1 and iteration_count >= effective_min_iterations and min_iterations_guard_already_passed == false:\n669:                min_iterations_guard_pass = true\n670:           9. if decision == \"STOP\" and reason != \"maxIterationsReached\":\n671:                guardResult = checkQualityGuards(state, strategy)\n672:                if not guardResult.passed:\n673:                  log: \"Quality guard failed: {guardResult.violations}. Overriding STOP to CONTINUE.\"\n674:                  decision = \"CONTINUE\"\n675:           See convergence.md for full pseudocode and signal definitions.\n676:           Segment-aware convergence is experimental/reference-only; live workflow uses the current session as a single segment.\n677:         outputs:\n678:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n679:           - reason: \"Human-readable stop reason\"\n680:           - stop_blocked: \"Boolean marker set when graph convergence vetoes an inline STOP candidate\"\n681:           - blocked_by_json: \"JSON array of graph blocker names when decision == BLOCKED\"\n682:           - blocked_by_csv: \"Comma-separated graph blocker names when decision == BLOCKED\"\n683:           - gate_convergence_pass: \"Boolean pass/fail for the graph-assisted convergence gate\"\n684:           - gate_convergence_score: \"Numeric score recorded from graph convergence\"\n685:           - gate_key_question_coverage_pass: \"Boolean pass/fail derived from graph blocker coverage signals\"\n686:           - gate_evidence_density_pass: \"Boolean pass/fail derived from graph blocker evidence-depth signals\"\n687:           - gate_evidence_density_sources: \"Source-diversity count or equivalent evidence-depth proxy\"\n688:           - gate_hotspot_saturation_pass: \"Research placeholder gate; true unless an explicit blocker sets otherwise\"\n689:           - recovery_strategy: \"One-line hint describing the next research action when decision == BLOCKED or STUCK_RECOVERY\"\n690:           - min_iterations_guard_pass: \"Boolean true when the configured convergence floor has cleared for the first time\"\n691:           - min_iterations_guard_blocked: \"Boolean true when the configured convergence floor overrides a STOP candidate to CONTINUE\"\n692: \n693:       step_emit_min_iterations_guard_pass:\n694:         action: \"Persist a first-class event when the convergence floor clears\"\n695:         if_pass:\n696:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"min_iterations_guard_pass\",\"mode\":\"research\",\"run\":{current_iteration},\"iterationCount\":{iteration_count},\"minIterations\":{effective_min_iterations},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n697:           log: \"Minimum iteration floor cleared for convergence stopping.\"\n698: \n699:       step_emit_blocked_stop:\n700:         action: \"Persist a first-class blocked_stop event when the legal-stop decision tree returns blocked\"\n701:         if_blocked:\n702:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"research\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergence\":{\"pass\":{gate_convergence_pass},\"score\":{gate_convergence_score}},\"keyQuestionCoverage\":{\"pass\":{gate_key_question_coverage_pass},\"answered\":{answered_count},\"total\":{total_questions}},\"evidenceDensity\":{\"pass\":{gate_evidence_density_pass},\"sources\":{gate_evidence_density_sources}},\"hotspotSaturation\":{\"pass\":{gate_hotspot_saturation_pass}}},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n703:           log: \"Graph convergence blocked STOP. Failed blockers: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n704:           set:\n705:             decision: \"CONTINUE\"\n706:             reason: \"blockedStop\"\n707:             stop_blocked: false\n708: \n709:       step_handle_convergence:\n710:         action: \"Act on convergence decision\"\n711:         if_stop:\n712:           branch_on: \"convergence_mode == 'divergent' AND reason is in ['composite_converged', 'all_questions_answered']\"\n713:           if_divergent_eligible:\n714:             eligibility_contract:\n715:               required_decision: \"STOP\"\n716:               eligible_reasons: [composite_converged, all_questions_answered]\n717:               excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, minIterationsNotReached, error, manualStop, userPaused]\n718:               fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot.\"\n719:             steps:\n720:               step_prepare_divergent_pivot:\n721:                 action: \"Generate state-grounded research candidates and prepare or resume the pivot transaction\"\n722:                 command: |\n723:                   node --experimental-strip-types --input-type=module <<'EOF'\n724:                   import {\n725:                     buildResearchPivotPreparationInput,\n\n(Output capped at 50 KB. Showing lines 1-725. Use offset=726 to continue.)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DEEP RESEARCH: AUTONOMOUS DEEP RESEARCH LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# YAML PREDICATE GRAMMAR CONTRACT (S7 / M11):\n# - This asset does not currently use typed BooleanExpr predicates under\n#   `when:`; flow control is branch-label-driven (`on_resume`, `on_fresh`,\n#   `on_restart`, etc.). Retain the existing shape.\n# - `after:` carries prose timing / narrative notes if needed; `when:` in\n#   this file is reserved for future typed predicates and must NOT carry\n#   free-form narrative prose.\n# - See `.opencode/skills/system-spec-kit/shared/predicates/boolean-expr.ts`\n#   for the canonical BooleanExpr grammar.\n#\n# GATE 3 CLASSIFICATION (T-YML-DPR-01 / paired with T-DOC-03 R50-001):\n# - `resume` is a tested WRITE-PATH that produces `iteration-NNN.md` files\n#   and JSONL state-log appends. The workflow classifies resume as\n#   write-path below (see `gate3_classification` fields) so Gate 3 trigger\n#   extraction can surface resume correctly rather than false-negative.\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Research Loop Manager","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DEEP RESEARCH: AUTONOMOUS DEEP RESEARCH LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# YAML PREDICATE GRAMMAR CONTRACT (S7 / M11):\n# - This asset does not currently use typed BooleanExpr predicates under\n#   `when:`; flow control is branch-label-driven (`on_resume`, `on_fresh`,\n#   `on_restart`, etc.). Retain the existing shape.\n# - `after:` carries prose timing / narrative notes if needed; `when:` in\n#   this file is reserved for future typed predicates and must NOT carry\n#   free-form narrative prose.\n# - See `.opencode/skills/system-spec-kit/shared/predicates/boolean-expr.ts`\n#   for the canonical BooleanExpr grammar.\n#\n# GATE 3 CLASSIFICATION (T-YML-DPR-01 / paired with T-DOC-03 R50-001):\n# - `resume` is a tested WRITE-PATH that produces `iteration-NNN.md` files\n#   and JSONL state-log appends. The workflow classifies resume as\n#   write-path below (see `gate3_classification` fields) so Gate 3 trigger\n#   extraction can surface resume correctly rather than false-negative.\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Research Loop Manager\npurpose: Iterative deep research with convergence detection\naction: Run deep-research loop from initialization through synthesis\noperating_mode:\n  workflow: iterative_loop\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_research_state\n  validation: convergence_detection\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING PRINCIPLES\n# ─────────────────────────────────────────────────────────────────\noperating_principles:\n  core: \"Fresh context per iteration + externalized state = no context degradation\"\n  approach: \"Dispatch focused agent, evaluate convergence, repeat or stop\"\n  mandate: \"Never hold findings in memory; write everything to files\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (from setup phase)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  research_topic: \"[RESEARCH_TOPIC] - Topic to investigate deeply. REQUIRED.\"\n  spec_folder: \"[SPEC_FOLDER] - Spec folder path. REQUIRED.\"\n  max_iterations: \"[MAX_ITERATIONS] - Maximum loop iterations. Default: 10.\"\n  convergence_threshold: \"[CONVERGENCE_THRESHOLD] - Stop threshold. Default: 0.05.\"\n  convergence_mode: \"[default|off|sliding-window|divergent] - Convergence policy modifier. Default: default.\"\n\n# ─────────────────────────────────────────────────────────────────\n# CONTEXT LOADING\n# ─────────────────────────────────────────────────────────────────\ncontext_loading:\n  trigger: \"At workflow START, before phase_init\"\n  purpose: \"Load prior research context for the topic and buffer it until strategy.md exists\"\n  mcp_integration:\n    tool: memory_context\n    note: \"Call MCP tools directly - NEVER through Code Mode\"\n    parameters: { input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n  when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n  behavior:\n    if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n    if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n\n# ─────────────────────────────────────────────────────────────────\n# SKILL REFERENCE\n# ─────────────────────────────────────────────────────────────────\nskill_reference:\n  skill: system-deep-loop\n  skill_md: .opencode/skills/system-deep-loop/deep-research/SKILL.md\n  references:\n    loop_protocol: .opencode/skills/system-deep-loop/deep-research/references/protocol/loop-protocol.md\n    spec_check_protocol: .opencode/skills/system-deep-loop/deep-research/references/protocol/spec-check-protocol.md\n    state_format: .opencode/skills/system-deep-loop/deep-research/references/state/state-format.md\n    convergence: .opencode/skills/system-deep-loop/deep-research/references/convergence/convergence.md\n  templates:\n    config: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json\n    strategy: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md\n\n# ─────────────────────────────────────────────────────────────────\n# AGENT CONFIGURATION\n# ─────────────────────────────────────────────────────────────────\nagent_config:\n  agent: deep-research\n  agent_file: \".opencode/agents/deep-research.md\"\n  # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n  model: opus\n  leaf_only: true\n  tools: [Read, Write, Edit, Bash, Grep, Glob, WebFetch]\n  mcp_servers: [mk-spec-memory]\n  tool_call_budget: { target: 8, max: 12 }\n\n# ─────────────────────────────────────────────────────────────────\n# STATE FILE PATHS\n# ─────────────────────────────────────────────────────────────────\nstate_paths:\n  # Template paths document the canonical packet layout. Runtime resolution happens via\n  # step_resolve_artifact_root plus the shared resolver, so root specs keep root-local\n  # research/ and child phases keep local research/ packet directories.\n  packet_dir: \"{artifact_dir}\"\n  config: \"{artifact_dir}/deep-research-config.json\"\n  state_log: \"{artifact_dir}/deep-research-state.jsonl\"\n  status_ledger: \"{artifact_dir}/orchestration-status.log\"\n  strategy: \"{artifact_dir}/deep-research-strategy.md\"\n  registry: \"{artifact_dir}/findings-registry.json\"\n  dashboard: \"{artifact_dir}/deep-research-dashboard.md\"\n  pause_sentinel: \"{artifact_dir}/.deep-research-pause\"\n  run_now_sentinel: \"{artifact_dir}/.deep-research-run-now\"\n  lock_file: \"{artifact_dir}/.deep-research.lock\"\n  prompt_dir: \"{artifact_dir}/prompts\"\n  iteration_dir: \"{artifact_dir}/iterations\"\n  iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n  # Per-iteration structured delta stream (one file per iteration) — complement to the\n  # canonical state_log append. The delta file MUST contain at least one record whose\n  # `type === \"iteration\"` so the reducer can rehydrate iteration state after a partial\n  # run. Variants like `\"iteration_delta\"` are silently dropped by the reducer; the\n  # post_dispatch_validate step enforces the canonical type below.\n  delta_dir: \"{artifact_dir}/deltas\"\n  delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n  research_output: \"{artifact_dir}/research.md\"\n  resource_map_output: \"{artifact_dir}/resource-map.md\"\n  archive_root: \"{artifact_archive_root}\"\n  synthesis_snapshot_pattern: \"{artifact_dir}/synthesis-v{generation}.md\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW\n# ─────────────────────────────────────────────────────────────────\nworkflow:\n\n  step_resolve_artifact_root:\n    description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n    note: \"Root specs keep research artifacts directly in {spec_folder}/research/. Child phases and sub-phases keep local packet directories in {spec_folder}/research/{packet}/, and archives stay local at {spec_folder}/research_archive/{packet}/.\"\n    branch_on: \"config.fanout_lineage_artifact_dir\"\n    if_present:\n      bind:\n        artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_subfolder: null\n        artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n    if_absent:\n      command: \"node -e \\\"const { resolveArtifactRoot } = require('./.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'research')));\\\"\"\n      outputs:\n        - artifact_root_dir: \"Resolved local research owner directory\"\n        - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n        - artifact_dir: \"Resolved research packet directory for this target\"\n        - artifact_archive_root: \"Resolved local research archive directory for this target\"\n\n  step_fanout_spawn:\n    description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n    skip_when: \"config.fanout is absent\"\n    instructions: |\n      Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n      isolated sub-packet under {artifact_dir}/lineages/{label}/.\n      fanout-run.cjs owns native and CLI lineage execution; native is run through the\n      deep/research command surface with config.fanout_lineage_artifact_dir so the LEAF\n      deep-research agent is used only for individual iterations, never as a full-loop\n      sub-agent or pasted phase-running prompt.\n      After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n      phase_main_loop entirely (those are the single-executor path). The merge step in\n      phase_synthesis will consolidate results across all lineages.\n    sub_steps:\n      step_fanout_spawn_cli:\n        description: \"Spawn all native and CLI lineages in capped worker pool\"\n        skip_when: \"no entries in config.fanout.executors\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs \\\n            --spec-folder {spec_folder} \\\n            --loop-type research \\\n            --research-topic \"{research_topic}\" \\\n            --fanout-config-json '{config.fanout_json}' \\\n            --base-artifact-dir {artifact_dir} \\\n            --convergence-threshold {convergence_threshold}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 1: INITIALIZATION\n  # ═══════════════════════════════════════════════════════════════\n  phase_init:\n    purpose: Create all state files for the research session\n    steps:\n\n      step_preflight_contract:\n        action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n        verify:\n          - required_values_present: [research_topic, spec_folder, max_iterations, convergence_threshold, convergence_mode]\n          - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n          - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n          - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n        on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n\n      step_create_directories:\n        action: \"Create spec folder and research packet directories if they don't exist\"\n        command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n\n      step_detect_resource_map:\n        action: \"Detect resource-map.md before config creation so init can persist the flag and seed Known Context\"\n        inspect:\n          - \"{spec_folder}/resource-map.md\"\n        classify:\n          present: \"resource-map.md exists at init\"\n          absent: \"resource-map.md does not exist at init\"\n        outputs:\n          - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n          - resource_map_known_context: \"When present: summarize the map by section with entry counts across READMEs, Documents, Commands, Agents, Skills, Specs, Scripts, Tests, Config, and Meta, plus a one-line theme summary for each section. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_resolve_canonical_names:\n        action: \"Resolve canonical research packet artifact names before classification\"\n        inspect_legacy:\n          - \"{state_paths.packet_dir}/config.json\"\n          - \"{state_paths.packet_dir}/state.jsonl\"\n          - \"{state_paths.packet_dir}/strategy.md\"\n          - \"{state_paths.packet_dir}/dashboard.md\"\n          - \"{state_paths.packet_dir}/.pause\"\n        migration_policy: \"dual-read / single-write for 4 weeks\"\n        on_legacy_read:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"migration\",\"legacyPath\":\"{legacy_path}\",\"canonicalPath\":\"{canonical_path}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_acquire_lock:\n        action: \"Acquire the single-writer advisory lock before session classification\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n        on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-research run already holds this packet.\"\n        note: \"Uses the promoted runtime/ loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n        # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n        # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n        on_halt:\n          action: \"Release the lock before any terminal halt branch returns control\"\n          applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\", \"step_preinit_spec_branch.conflict-detected\"]\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n        on_cancel:\n          action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n        on_workflow_exit:\n          action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n\n      step_classify_session:\n        action: \"Classify the session before writing files\"\n        inspect:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.strategy}\"\n        classify:\n          fresh: \"None of the three state artifacts exist\"\n          resume: \"Config, JSONL, and strategy all exist and agree on topic/spec folder; missing wait-checkpoint fields are read as nextRunAt:null and remainingDelayMs:null\"\n          completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n          invalid-state: \"Any partial, missing, or contradictory combination\"\n        outputs:\n          - session_state: \"fresh | resume | completed-session | invalid-state\"\n        on_resume:\n          # T-YML-DPR-01 / R50-001: Resume is a WRITE-PATH. Produces `iteration-NNN.md` + JSONL appends.\n          # Paired with T-DOC-03 Gate 3 trigger addition (resume, save context, save memory, /memory:save).\n          gate3_classification: write-path\n          gate3_rationale: \"resume produces iteration-NNN.md writes and JSONL state-log appends\"\n          log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: phase_loop\n        on_restart:\n          action: \"Archive the current research packet under the root-level research_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n          command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n          set:\n            lineage_mode: \"restart\"\n            parent_session_id: \"{prior_session_id}\"\n            generation: \"{prior_generation + 1}\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: step_create_config\n        note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-research/references/protocol/loop-protocol.md §Lifecycle Branch Contract for the one-session contract.\"\n        on_completed_session:\n          log: \"Prior session already completed. Do not route directly to synthesis; archive the completed research/ tree or start a fresh packet instead.\"\n          halt: true\n          message: \"Completed deep-research packet detected. Archive or replace the existing research/ tree before starting a new session.\"\n        on_invalid_state:\n          halt: true\n          message: \"Existing deep-research state is incomplete or contradictory. Repair or archive the invalid research packet before continuing.\"\n        on_fresh:\n          action: \"Proceed with a new session\"\n\n      step_resolve_session_id:\n        action: \"Resolve init session id from caller when supplied, else preserve the auto-generated fallback\"\n        branch_on: \"session_id\"\n        if_present:\n          bind:\n            session_id_init: \"{session_id}\"\n        if_absent:\n          bind:\n            session_id_init: \"{AUTO_SESSION_ID}\"\n\n      step_create_config:\n        action: \"Create deep-research-config.json from template\"\n        template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json\n        populate:\n          topic: \"{research_topic}\"\n          maxIterations: \"{max_iterations}\"\n          minIterations: 3\n          # Semantic: newInfoRatio with negative-knowledge emphasis. See SKILL.md §\"Convergence Threshold Semantics\".\n          convergenceThreshold: \"{convergence_threshold}\"\n          antiConvergence.convergenceMode: \"{convergence_mode}\"\n          antiConvergence.divergent: {}\n          stuckThreshold: 3\n          minIdeaObservations: 2\n          maxDurationMinutes: 120\n          specFolder: \"{spec_folder}\"\n          resource_map_present: \"{resource_map_present}\"\n          # Honor the parsed --no-resource-map flag from deep-research.md:73 (default true; false when flag is set).\n          # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n          resource_map.emit: \"{resource_map_emit}\"\n          createdAt: \"{ISO_8601_NOW}\"\n          status: \"initialized\"\n          executionMode: \"auto\"\n          lineage.sessionId: \"{session_id_init}\"\n          lineage.parentSessionId: null\n          lineage.lineageMode: \"new\"\n          lineage.generation: 1\n          lineage.continuedFromRun: null\n          nextRunAt: null\n          remainingDelayMs: null\n        output: \"{state_paths.config}\"\n\n      step_create_state_log:\n        action: \"Initialize JSONL state log with config record\"\n        # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n        content: '{\"type\":\"config\",\"topic\":\"{research_topic}\",\"maxIterations\":{max_iterations},\"minIterations\":3,\"convergenceThreshold\":{convergence_threshold},\"antiConvergence\":{\"convergenceMode\":\"{convergence_mode}\",\"divergent\":{}},\"minIdeaObservations\":2,\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\",\"nextRunAt\":null,\"remainingDelayMs\":null}'\n        output: \"{state_paths.state_log}\"\n\n      step_create_strategy:\n        action: \"Create strategy file from template with initial questions\"\n        template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md\n        populate:\n          topic: \"{research_topic}\"\n          key_questions: \"Derive 3-5 key questions from the research topic\"\n          known_context: \"None\"\n          known_context_summary: \"None\"\n          max_iterations: \"{max_iterations}\"\n          convergence_threshold: \"{convergence_threshold}\"\n        output: \"{state_paths.strategy}\"\n\n      step_create_registry:\n        action: \"Initialize reducer-owned findings registry\"\n        content: '{\"openQuestions\":[],\"resolvedQuestions\":[],\"keyFindings\":[],\"ruledOutDirections\":[],\"metrics\":{\"iterationsCompleted\":0,\"openQuestions\":0,\"resolvedQuestions\":0,\"keyFindings\":0,\"convergenceScore\":0,\"coverageBySources\":{}}}'\n        output: \"{state_paths.registry}\"\n\n      step_enrich_strategy_context:\n        action: \"Ensure Known Context is written only after strategy.md exists\"\n        condition: \"prior_context_found\"\n        edit: \"{state_paths.strategy}\"\n        note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n\n      step_enrich_strategy_resource_map:\n        action: \"Inject resource-map status into Known Context after strategy.md exists\"\n        edit: \"{state_paths.strategy}\"\n        note: \"When resource_map_present is true, append the resource_map_known_context snapshot. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_detect_spec_present:\n        action: \"Classify late-INIT spec.md state after the durable research packet exists\"\n        inspect:\n          - \"{spec_folder}/spec.md\"\n          - \"{state_paths.lock_file}\"\n        classify:\n          no-spec: \"spec.md is absent before any pre-init mutation\"\n          spec-present: \"spec.md exists and approved host anchors are available for bounded mutation\"\n          spec-just-created-by-this-run: \"spec.md already carries this run's DR seed markers and should not be reseeded\"\n          conflict-detected: \"missing host anchor, duplicate markers, or generated-block ambiguity makes mutation unsafe\"\n        outputs:\n          - folder_state: \"no-spec | spec-present | spec-just-created-by-this-run | conflict-detected\"\n          - normalized_topic: \"Trim, lowercase, and collapse whitespace in research_topic before dedupe checks\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"spec_check_result\",\"folder_state\":\"{folder_state}\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"lockPath\":\"{state_paths.lock_file}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_preinit_spec_branch:\n        action: \"Run the bounded pre-init spec branch required by spec_check_protocol\"\n        protocol_reference: \".opencode/skills/system-deep-loop/deep-research/references/protocol/spec-check-protocol.md\"\n        branches:\n          no-spec:\n            create: \"{spec_folder}/spec.md\"\n            seed_markers:\n              - \"<!-- DR-SEED:REQUIREMENTS -->\"\n              - \"<!-- DR-SEED:SCOPE -->\"\n            requirements_host: \"Seed Requirements from the research ask without broadening scope\"\n            scope_host: \"Seed Scope from the research ask without inventing implementation details\"\n            set:\n              folder_state: \"spec-just-created-by-this-run\"\n              validate_spec_doc: true\n            append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_seed_created\",\"folder_state\":\"spec-just-created-by-this-run\",\"anchors_touched\":[\"Requirements\",\"Scope\"],\"diff_summary\":\"Seeded Level 1 spec.md from research topic with DR seed markers.\",\"seed_markers\":[\"DR-SEED:REQUIREMENTS\",\"DR-SEED:SCOPE\"],\"timestamp\":\"{ISO_8601_NOW}\"}'\n          spec-present:\n            edit: \"{spec_folder}/spec.md\"\n            set:\n              validate_spec_doc: true\n            idempotency_check:\n              host_anchor: \"Open Questions\"\n              normalized_match: \"Normalize the existing anchor text by lowercasing, stripping punctuation, collapsing whitespace, and trimming before comparing with {normalized_topic}.\"\n              if_match:\n                skip_append: true\n                append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_deduped\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\"],\"diff_summary\":\"Skipped duplicate pre-init topic append because normalized topic already exists in Open Questions.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              if_no_match:\n                append_only:\n                  - host_anchor: \"Open Questions\"\n                    content: \"Add the normalized research topic only if it is not already present.\"\n                  - host_anchor: \"Research Context\"\n                    content: \"Add a bounded note that deep-research is active for this topic and that research/research.md remains canonical.\"\n                append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_added\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\",\"Research Context\"],\"diff_summary\":\"Appended bounded pre-init research context for the normalized topic.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n          spec-just-created-by-this-run:\n            verify_markers:\n              - \"<!-- DR-SEED:REQUIREMENTS -->\"\n              - \"<!-- DR-SEED:SCOPE -->\"\n            set:\n              validate_spec_doc: false\n            note: \"Treat already-seeded spec.md as a no-op guard and continue.\"\n          conflict-detected:\n            append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Pre-init spec.md mutation is ambiguous or unsafe.\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            halt: true\n\n      step_validate_preinit_spec_doc:\n        action: \"Run targeted strict validation after any deep-research pre-init spec.md mutation\"\n        condition: \"validate_spec_doc\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"This enforces the authored-spec markdown structural contract without applying full-packet required-file or completeness checks to workflow-owned research artifacts. It uses the Node validation orchestrator, whose strict path was measured at about 108ms for a fresh Level 3 packet on the local harness.\"\n\n      step_telemetry_heartbeat_started:\n        action: \"Emit a single-loop started row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        canonical_lifecycle_event: \"iteration_start\"\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{AUTO_SESSION_ID}');\n          const generation = Number(config.lineage?.generation ?? 1);\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n          const row = {\n            event: 'started',\n            label: 'single',\n            at: timestamp,\n            duration_ms: 0,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: 0, elapsed_ms: 0, score: 0 },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event: row.event, label: row.label, sessionId, generation, gauges: { iterations: 0, score: 0 } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation },\n                event: row.event,\n                status: 'running',\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_started: \"A fan-out-shaped status row with label single and event started\"\n\n      step_init_complete:\n        log: \"Initialization complete. Config, state, and strategy files created.\"\n        set: { current_iteration: 1, current_segment: 1, stuck_count: 0 }\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 2: ITERATION LOOP\n  # ═══════════════════════════════════════════════════════════════\n  phase_loop:\n    purpose: Dispatch agent iterations until convergence\n    repeat: true\n    max_repeats: \"{max_iterations}\"\n    steps:\n\n      step_read_state:\n        action: \"Read current state from JSONL and strategy\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.config}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_newInfoRatio: \"Extract newInfoRatio from last iteration record\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - next_focus: \"Extract 'Next Focus' section from strategy.md\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - carried_forward_open_questions: \"Extract 'Carried-Forward Open Questions' section from strategy.md, else '[None yet]'\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - resource_map_present: \"Extract boolean from deep-research-config.json, default false\"\n          - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource map: prior-inventoried files are listed in {spec_folder}/resource-map.md; treat them as the exclusion set when hunting for net-new files; flag only missed-from-map candidates as gaps.' Else return 'Resource map: resource-map.md not present; skipping coverage gate.'\"\n          - memory_context_prompt_line: \"If a refreshed memory context summary exists from the previous iteration, return 'Memory context refresh: {summary}'. Else use prior_context_summary from startup when available; otherwise return 'Memory context refresh: none loaded yet.'\"\n          - least_explored: \"First unanswered question not covered by the most recent iteration focus, else first unanswered question\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n          - nextRunAt: \"Extract nullable nextRunAt from deep-research-config.json, default null\"\n          - remainingDelayMs: \"Extract nullable remainingDelayMs from deep-research-config.json, default null\"\n          - min_iterations_present: \"Boolean true when deep-research-config.json has a numeric minIterations field\"\n          - min_iterations_missing_warning: \"Boolean true when minIterations is missing; use no floor and log a warning so older configs keep prior stop behavior\"\n          - min_iterations_raw: \"Extract numeric minIterations from deep-research-config.json when present, default 0\"\n          - effective_min_iterations: \"Clamp min_iterations_raw to the inclusive range 0..max_iterations; if min_iterations_raw exceeds max_iterations, use max_iterations\"\n          - min_iterations_clamped: \"Boolean true when min_iterations_raw > max_iterations\"\n          - min_iterations_guard_already_passed: \"Boolean true when state_log already contains event == 'min_iterations_guard_pass'\"\n          - convergence_mode: \"Extract antiConvergence.convergenceMode when it is one of 'default', 'off', 'sliding-window', or 'divergent'; default to 'default'\"\n          - convergence_mode_warning: \"Boolean true when antiConvergence.convergenceMode is present with an unsupported value; use 'default'\"\n          - rejected_patterns_count: \"Read registry.rejectedPatterns length when registry exists, else 0\"\n          - rejected_candidate_matches: \"Read registry.suppressedCandidates when registry exists, else []\"\n          - rejected_pattern_fuzzy_threshold: \"Read config.rejectedPatternFuzzyThreshold when present, else 0.85\"\n          - min_idea_observations: \"Read config.minIdeaObservations when present, default 2; clamp to 1..10\"\n          - observed_ideas_count: \"Read registry.observedIdeas length when registry exists, else 0\"\n          - promoted_ideas_count: \"Read registry.promotedIdeas length when registry exists, else 0\"\n          - promoted_ideas_list: \"Read registry.promotedIdeas idea text in rank order when registry exists, else []\"\n          - suppressed_ideas_count: \"Read registry.suppressedIdeas length when registry exists, else 0\"\n          - pivot_lineage: \"Summarize registry.divergence.completed and registry.divergence.overrides with pivot ids, source iterations, and selected focus; else 'none yet'\"\n          - saturated_directions: \"List registry.divergence.saturatedDirections; else 'none yet'\"\n\n      step_run_now_check:\n        action: \"Detect and consume a one-shot run-now sentinel before pause/convergence/dispatch\"\n        command: |\n          node <<'EOF'\n          const { appendFileSync, existsSync, renameSync, unlinkSync } = require('node:fs');\n\n          const stateLogPath = \"{state_paths.state_log}\";\n          const sentinelPath = \"{state_paths.run_now_sentinel}\";\n          const pausePath = \"{state_paths.pause_sentinel}\";\n          const timestamp = \"{ISO_8601_NOW}\";\n          const sessionId = \"{config.lineage.sessionId}\";\n          const generation = Number(\"{config.lineage.generation}\");\n          const run = Number(\"{current_iteration}\");\n\n          function append(event) {\n            appendFileSync(\n              stateLogPath,\n              `${JSON.stringify({\n                type: \"event\",\n                mode: \"research\",\n                run,\n                timestamp,\n                sessionId,\n                generation,\n                ...event,\n              })}\\n`,\n              \"utf8\",\n            );\n          }\n\n          if (existsSync(sentinelPath)) {\n            append({ event: \"run_now_requested\", sentinelPath });\n            if (existsSync(pausePath)) {\n              append({\n                event: \"run_now_rejected\",\n                reason: \"loop_paused\",\n                sentinelPath,\n                pauseSentinelPath: pausePath,\n              });\n            } else {\n              const claimPath = `${sentinelPath}.consuming.${process.pid}.${Date.now()}`;\n              try {\n                renameSync(sentinelPath, claimPath);\n                unlinkSync(claimPath);\n                append({\n                  event: \"run_now_accepted\",\n                  sentinelPath,\n                  dispatchEvent: \"iteration_start\",\n                });\n              } catch (error) {\n                if (!error || error.code !== \"ENOENT\") {\n                  throw error;\n                }\n              }\n            }\n          }\n          EOF\n        outputs:\n          - run_now_requested: \"Emitted when {state_paths.run_now_sentinel} exists at the loop boundary\"\n          - run_now_accepted: \"Emitted after the sentinel is atomically renamed and deleted before dispatch\"\n          - run_now_rejected: \"Emitted with reason loop_paused when pause takes precedence; sentinel remains present\"\n\n      step_check_pause_sentinel:\n        action: \"Check for pause sentinel file\"\n        check: \"Does {state_paths.pause_sentinel} exist?\"\n        if_exists:\n          log_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          message: \"Research paused. Delete research/.deep-research-pause to resume.\"\n          halt: true\n        if_not_exists:\n          proceed: true\n\n      step_validate_convergence_config:\n        action: \"Validate convergence floor settings when loading config\"\n        if_min_iterations_missing:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"fallback\":0,\"message\":\"minIterations missing; using no convergence floor for backward compatibility.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"minIterations missing; using no convergence floor for backward compatibility.\"\n        if_min_iterations_clamped:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"configured\":{min_iterations_raw},\"effective\":{effective_min_iterations},\"maxIterations\":{max_iterations},\"message\":\"minIterations exceeds maxIterations; clamping to the hard cap.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"minIterations exceeds maxIterations; clamping to the hard cap.\"\n        if_convergence_mode_invalid:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"convergenceMode\",\"fallback\":\"default\",\"message\":\"Unsupported convergenceMode; using default convergence behavior.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Unsupported convergenceMode; using default convergence behavior.\"\n\n      step_graph_convergence:\n        action: \"Evaluate coverage-graph convergence before the inline 3-signal vote and persist the graph decision snapshot\"\n        bash: 'node .opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"research\" --session-id \"{config.lineage.sessionId}\" --convergence-mode \"{convergence_mode}\"'\n        note: \"Run before the inline vote. STOP from the inline 3-signal vote is allowed only when the graph decision is STOP_ALLOWED or absent.\"\n        outputs:\n          - graph_decision: \"Tool decision value (CONTINUE | STOP_ALLOWED | STOP_BLOCKED), else null when unavailable\"\n          - graph_decision_json: \"JSON-encoded graph decision string, else null\"\n          - graph_signals_json: \"Tool signals object, else {}\"\n          - graph_blockers_json: \"Tool blockers array, else []\"\n          - graph_trace_json: \"Tool trace payload, else []\"\n          - graph_convergence_score: \"signals.blendedScore when present, else the best available graph score, else 0\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"research\",\"run\":{current_iteration},\"decision\":{graph_decision_json},\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_check_convergence:\n        action: \"Evaluate stop conditions and combine the inline 3-signal vote with graph convergence\"\n        algorithm: |\n          1. if iteration_count >= max_iterations: STOP (maxIterationsReached). This terminal cap bypasses quality-guard overrides; record failed guards/blockers as synthesis evidence instead of continuing.\n          2. if stuck_count >= config.stuckThreshold: STUCK_RECOVERY\n          3. if convergence_mode == \"off\": skip convergence stop candidates and continue unless a terminal cap, pause sentinel, or recovery halt has already fired.\n          4. if remaining_questions == 0: STOP (all_questions_answered)\n          5. GRAPH-ASSISTED COMPOSITE CONVERGENCE:\n               step_graph_convergence already recorded graph_decision, graph_signals_json, graph_blockers_json, and graph_convergence_score for this run.\n               The existing inline 3-signal vote still computes the inline STOP candidate and is not replaced.\n               signals = []\n               Filter: exclude iterations where status == thought from signal inputs (use only evidence iterations)\n               a) Rolling average (w=0.30, needs 3+ iterations):\n                  avg = mean(last 3 newInfoRatios)\n                  stop if avg < convergence_threshold\n               b) MAD noise floor (w=0.35, needs 4+ iterations):\n                  noiseFloor = MAD(all ratios) * 1.4826\n                  stop if latest ratio <= noiseFloor\n               c) Question entropy (w=0.35):\n                  coverage = answered / total questions\n                  stop if coverage >= 0.85\n               Redistribute weights for unavailable signals.\n               if weighted_stop_score > 0.60: inline_stop_candidate = true\n               Combined stop rule: STOP only if the inline 3-signal vote says STOP AND graph_decision is STOP_ALLOWED or absent.\n               if inline_stop_candidate and graph_decision == \"STOP_BLOCKED\":\n                 decision = \"BLOCKED\"\n                 reason = \"blockedStop\"\n                 stop_blocked = true\n                 blocked_by_json = JSON array derived from graph_blockers_json\n                 blocked_by_csv = comma-separated blocker names derived from graph_blockers_json\n                 gate_convergence_pass = false\n                 gate_convergence_score = graph_convergence_score\n                 gate_key_question_coverage_pass = no blocker named questionCoverage\n                 gate_evidence_density_pass = no blocker named sourceDiversity or evidenceDepth\n                 gate_evidence_density_sources = graph_signals_json.sourceDiversity or 0\n                 gate_hotspot_saturation_pass = true\n                 recovery_strategy = first blocker reason/message, else \"Collect deeper graph evidence before stopping.\"\n               else if inline_stop_candidate and (graph_decision == \"STOP_ALLOWED\" or graph_decision is absent):\n                 decision = \"STOP\"\n                 reason = \"composite_converged\"\n                 stop_blocked = false\n          6. else: CONTINUE\n          7. if decision == \"STOP\" and reason != \"maxIterationsReached\" and effective_min_iterations > 1 and iteration_count < effective_min_iterations:\n               decision = \"CONTINUE\"\n               reason = \"minIterationsNotReached\"\n               min_iterations_guard_blocked = true\n               min_iterations_guard_pass = false\n          8. if effective_min_iterations > 1 and iteration_count >= effective_min_iterations and min_iterations_guard_already_passed == false:\n               min_iterations_guard_pass = true\n          9. if decision == \"STOP\" and reason != \"maxIterationsReached\":\n               guardResult = checkQualityGuards(state, strategy)\n               if not guardResult.passed:\n                 log: \"Quality guard failed: {guardResult.violations}. Overriding STOP to CONTINUE.\"\n                 decision = \"CONTINUE\"\n          See convergence.md for full pseudocode and signal definitions.\n          Segment-aware convergence is experimental/reference-only; live workflow uses the current session as a single segment.\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean marker set when graph convergence vetoes an inline STOP candidate\"\n          - blocked_by_json: \"JSON array of graph blocker names when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated graph blocker names when decision == BLOCKED\"\n          - gate_convergence_pass: \"Boolean pass/fail for the graph-assisted convergence gate\"\n          - gate_convergence_score: \"Numeric score recorded from graph convergence\"\n          - gate_key_question_coverage_pass: \"Boolean pass/fail derived from graph blocker coverage signals\"\n          - gate_evidence_density_pass: \"Boolean pass/fail derived from graph blocker evidence-depth signals\"\n          - gate_evidence_density_sources: \"Source-diversity count or equivalent evidence-depth proxy\"\n          - gate_hotspot_saturation_pass: \"Research placeholder gate; true unless an explicit blocker sets otherwise\"\n          - recovery_strategy: \"One-line hint describing the next research action when decision == BLOCKED or STUCK_RECOVERY\"\n          - min_iterations_guard_pass: \"Boolean true when the configured convergence floor has cleared for the first time\"\n          - min_iterations_guard_blocked: \"Boolean true when the configured convergence floor overrides a STOP candidate to CONTINUE\"\n\n      step_emit_min_iterations_guard_pass:\n        action: \"Persist a first-class event when the convergence floor clears\"\n        if_pass:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"min_iterations_guard_pass\",\"mode\":\"research\",\"run\":{current_iteration},\"iterationCount\":{iteration_count},\"minIterations\":{effective_min_iterations},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Minimum iteration floor cleared for convergence stopping.\"\n\n      step_emit_blocked_stop:\n        action: \"Persist a first-class blocked_stop event when the legal-stop decision tree returns blocked\"\n        if_blocked:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"research\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergence\":{\"pass\":{gate_convergence_pass},\"score\":{gate_convergence_score}},\"keyQuestionCoverage\":{\"pass\":{gate_key_question_coverage_pass},\"answered\":{answered_count},\"total\":{total_questions}},\"evidenceDensity\":{\"pass\":{gate_evidence_density_pass},\"sources\":{gate_evidence_density_sources}},\"hotspotSaturation\":{\"pass\":{gate_hotspot_saturation_pass}}},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Graph convergence blocked STOP. Failed blockers: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n          set:\n            decision: \"CONTINUE\"\n            reason: \"blockedStop\"\n            stop_blocked: false\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          branch_on: \"convergence_mode == 'divergent' AND reason is in ['composite_converged', 'all_questions_answered']\"\n          if_divergent_eligible:\n            eligibility_contract:\n              required_decision: \"STOP\"\n              eligible_reasons: [composite_converged, all_questions_answered]\n              excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, minIterationsNotReached, error, manualStop, userPaused]\n              fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot.\"\n            steps:\n              step_prepare_divergent_pivot:\n                action: \"Generate state-grounded research candidates and prepare or resume the pivot transaction\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import {\n                    buildResearchPivotPreparationInput,","lineStart":1,"lineEnd":725,"totalLines":726,"truncated":true}},"title":".opencode/commands/deep/assets/deep-research-auto.yaml","time":{"start":1784616133994,"end":1784616134198}},"metadata":{"openai":{"itemId":"fc_0e55e3c0bf11150f016a5f14c5cb508191b53baa8f66e2987d"}},"id":"prt_f83692515001xiUGL6xe1Xo9vL","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f8368c0e7001D1i4allOODIHEM"}}
{"type":"step_finish","timestamp":1784616135085,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"id":"prt_f836929a4001A7tOie56T6bpy4","reason":"tool-calls","snapshot":"ebb5234630a8364b78f0bf922ddcd859e15b8554","messageID":"msg_f8368c0e7001D1i4allOODIHEM","sessionID":"ses_07c97d905ffee2yzbow793KIc8","type":"step-finish","tokens":{"total":84040,"input":44406,"output":778,"reasoning":456,"cache":{"write":0,"read":38400}},"cost":0}}
{"type":"step_start","timestamp":1784616139155,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"id":"prt_f836939910012MNrzxWi2ncb1x","messageID":"msg_f83692ce5001mPoWyqS4qb7ys9","sessionID":"ses_07c97d905ffee2yzbow793KIc8","snapshot":"ebb5234630a8364b78f0bf922ddcd859e15b8554","type":"step-start"}}
{"type":"tool_use","timestamp":1784616149503,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_puw4KWCWV0fmngdTtoGiFGQG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml","offset":726,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml</path>\n<type>file</type>\n<content>\n726:                     renderResearchPivotSeatPrompt,\n727:                   } from './.opencode/skills/system-deep-loop/deep-research/scripts/divergent-research-pivot.ts';\n728:                   import {\n729:                     preparePivotTransaction,\n730:                   } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n731: \n732:                   const input = buildResearchPivotPreparationInput({\n733:                     artifactRoot: '{state_paths.packet_dir}',\n734:                     configPath: '{state_paths.config}',\n735:                     stateLogPath: '{state_paths.state_log}',\n736:                     strategyPath: '{state_paths.strategy}',\n737:                     registryPath: '{state_paths.registry}',\n738:                     currentIteration: Number('{current_iteration}'),\n739:                     maxIterations: Number('{max_iterations}'),\n740:                     triggerReason: '{reason}',\n741:                   });\n742:                   const prepared = await preparePivotTransaction(input);\n743:                   const seatPrompts = prepared.status === 'pending'\n744:                     ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n745:                         seat.id,\n746:                         renderResearchPivotSeatPrompt(seat, prepared.dispatchContext),\n747:                       ]))\n748:                     : {};\n749:                   process.stdout.write(`${JSON.stringify({\n750:                     ...prepared,\n751:                     seatPrompts,\n752:                     boundaryRejections: input.boundaryRejections,\n753:                   })}\\n`);\n754:                   EOF\n755:                 working_directory: \"{repo_root}\"\n756:                 outputs:\n757:                   - pivot_prepare_json: \"The complete parsed JSON result\"\n758:                   - pivot_prepare_status: \"status from the prepare result\"\n759:                   - pivot_id: \"pivotId from the prepare result\"\n760:                   - pivot_paths_json: \"paths from the prepare result as JSON\"\n761:                   - pivot_resumed: \"resumed from the prepare result\"\n762:                   - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n763:                   - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n764:                   - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n765:                   - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n766:                   - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n767:                   - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n768:                   - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n769:                   - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n770:                 short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n771: \n772:               step_dispatch_pivot_seat_001:\n773:                 action: \"Natively dispatch the analytical research direction-selection seat\"\n774:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n775:                 capture_timing: true\n776:                 if_native:\n777:                   dispatch:\n778:                     agent: deep-research\n779:                     model: opus\n780:                     context_source: \"pivot_seat_001_prompt\"\n781:                   wait_for_completion: true\n782:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n783:                 outputs:\n784:                   - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n785:                   - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n786:                   - pivot_seat_001_error_json: \"{name,message} when rejected\"\n787:                   - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n788:                   - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n789:                   - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n790: \n791:               step_record_pivot_seat_001:\n792:                 action: \"Durably record the seat-001 native dispatch outcome\"\n793:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n794:                 command: |\n795:                   node --experimental-strip-types --input-type=module <<'EOF'\n796:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n797:                   const status = '{pivot_seat_001_dispatch_status}';\n798:                   const outcome = status === 'fulfilled'\n799:                     ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n800:                     : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n801:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n802:                   EOF\n803:                 working_directory: \"{repo_root}\"\n804: \n805:               step_dispatch_pivot_seat_002:\n806:                 action: \"Natively dispatch the critical research direction-selection seat\"\n807:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n808:                 capture_timing: true\n809:                 if_native:\n810:                   dispatch:\n811:                     agent: deep-research\n812:                     model: opus\n813:                     context_source: \"pivot_seat_002_prompt\"\n814:                   wait_for_completion: true\n815:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n816:                 outputs:\n817:                   - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n818:                   - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n819:                   - pivot_seat_002_error_json: \"{name,message} when rejected\"\n820:                   - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n821:                   - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n822:                   - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n823: \n824:               step_record_pivot_seat_002:\n825:                 action: \"Durably record the seat-002 native dispatch outcome\"\n826:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n827:                 command: |\n828:                   node --experimental-strip-types --input-type=module <<'EOF'\n829:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n830:                   const status = '{pivot_seat_002_dispatch_status}';\n831:                   const outcome = status === 'fulfilled'\n832:                     ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n833:                     : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n834:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n835:                   EOF\n836:                 working_directory: \"{repo_root}\"\n837: \n838:               step_dispatch_pivot_seat_003:\n839:                 action: \"Natively dispatch the pragmatic research direction-selection seat\"\n840:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n841:                 capture_timing: true\n842:                 if_native:\n843:                   dispatch:\n844:                     agent: deep-research\n845:                     model: opus\n846:                     context_source: \"pivot_seat_003_prompt\"\n847:                   wait_for_completion: true\n848:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n849:                 outputs:\n850:                   - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n851:                   - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n852:                   - pivot_seat_003_error_json: \"{name,message} when rejected\"\n853:                   - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n854:                   - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n855:                   - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n856: \n857:               step_record_pivot_seat_003:\n858:                 action: \"Durably record the seat-003 native dispatch outcome\"\n859:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n860:                 command: |\n861:                   node --experimental-strip-types --input-type=module <<'EOF'\n862:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n863:                   const status = '{pivot_seat_003_dispatch_status}';\n864:                   const outcome = status === 'fulfilled'\n865:                     ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n866:                     : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n867:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n868:                   EOF\n869:                 working_directory: \"{repo_root}\"\n870: \n871:               step_finalize_divergent_pivot:\n872:                 action: \"Finalize the prepared pivot after all missing native seats are durable\"\n873:                 skip_when: \"pivot_prepare_status != 'pending'\"\n874:                 command: |\n875:                   node --experimental-strip-types --input-type=module <<'EOF'\n876:                   import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n877:                   process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n878:                   EOF\n879:                 working_directory: \"{repo_root}\"\n880:                 outputs:\n881:                   - pivot_finalize_json: \"The complete parsed final result\"\n882: \n883:               step_resolve_divergent_pivot_result:\n884:                 action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n885:                 branch_on: \"pivot_prepare_status\"\n886:                 if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n887:                 if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n888: \n889:               step_apply_divergent_pivot_result:\n890:                 action: \"Adopt a successful focus or fail closed to the existing synthesis path\"\n891:                 branch_on: \"pivot_result.status\"\n892:                 if_completed:\n893:                   set:\n894:                     next_focus: \"{pivot_result.restoredFocus}\"\n895:                     pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n896:                     saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n897:                   command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n898:                   log: \"Divergent pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n899:                   proceed_to: step_rejected_pattern_cache\n900:                 if_failed:\n901:                   log: \"Divergent pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n902:                   skip_to: phase_synthesis\n903:             on_error:\n904:               log: \"Divergent pivot integration error; failing closed to the existing synthesis path.\"\n905:               skip_to: phase_synthesis\n906:           if_existing_terminal_path:\n907:             log: \"Loop stopping. Reason: {reason}\"\n908:             skip_to: phase_synthesis\n909:         if_stuck_recovery:\n910:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n911:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n912:           set: { next_focus: \"RECOVERY: Widen scope. Try fundamentally different approach. Least-explored question: {least_explored}\" }\n913:           reset: { stuck_count: 0 }\n914:         if_continue:\n915:           log: \"Iteration {current_iteration}: Continuing. Focus: {next_focus}\"\n916: \n917:       step_rejected_pattern_cache:\n918:         action: \"Apply reducer-derived rejected-pattern suppression before dispatch candidate selection\"\n919:         read:\n920:           - \"{state_paths.state_log}\"\n921:           - \"{state_paths.registry}\"\n922:           - \"{state_paths.strategy}\"\n923:         candidate_sources:\n924:           next_focus:\n925:             category: \"next-focus\"\n926:             values:\n927:               - \"{next_focus}\"\n928:               - \"{remaining_questions_list}\"\n929:               - \"{carried_forward_open_questions}\"\n930:           recovery:\n931:             category: \"recovery\"\n932:             values:\n933:               - \"{recovery_strategy}\"\n934:               - \"{least_explored}\"\n935:           ideas:\n936:             category: \"ideas\"\n937:             values:\n938:               - \"{promoted_ideas_list}\"\n939:             optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n940:         algorithm: |\n941:           Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n942:           reducer pass as the source of truth.\n943:           Compare normalized exact text first. Then compare fuzzy similarity with\n944:           rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n945:           are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n946:           selection before rendering the dispatch prompt. If all candidates are suppressed,\n947:           halt for operator input instead of reusing a rejected idea.\n948:         outputs:\n949:           - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n950:           - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n951:           - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n952:           - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n953:         if_next_focus_suppressed:\n954:           set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n955:           log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n956:         if_all_candidates_suppressed:\n957:           halt: true\n958:           message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n959: \n960:       step_ideas_backlog_lifecycle:\n961:         action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n962:         read:\n963:           - \"{state_paths.state_log}\"\n964:           - \"{state_paths.registry}\"\n965:           - \"{state_paths.config}\"\n966:         lifecycle:\n967:           observed_event: \"idea_observed\"\n968:           promoted_event: \"idea_promoted\"\n969:           rejected_event: \"idea_rejected\"\n970:           min_observations: \"{min_idea_observations}\"\n971:           authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n972:         validate:\n973:           - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n974:           - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n975:           - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n976:         outputs:\n977:           - observed_ideas_count: \"Reducer-derived observed ideas count\"\n978:           - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n979:           - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n980:           - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n981: \n982:       step_normalize_pause_events:\n983:         action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n984:         stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n985:         rule_pause_sentinel:\n986:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n987:           canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n988:         rule_stuck_recovery:\n989:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n990:           canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n991: \n992:       step_marker_scan:\n993:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n994:         algorithm: |\n995:           if current_iteration > 1:\n996:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n997:             if file_exists(PREV_PROMPT_PATH):\n998:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n999:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n1000:                 log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n1001:                 halt with exit code 2\n1002:         note: |\n1003:           False-positive prevention: only matches when the first line is exactly one of the\n1004:           three canonical markers. Markers appearing in comments or body text are ignored.\n1005:           True-positive triggers only when a previous iteration's rendered prompt literally\n1006:           starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n1007: \n1008:       step_dispatch_iteration:\n1009:         action: \"Dispatch one iteration via the selected executor\"\n1010:         resolve_executor:\n1011:           source: \"config.executor\"\n1012:           loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n1013:         pre_dispatch:\n1014:           generate_summary: |\n1015:             STATE SUMMARY (auto-generated):\n1016:             Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n1017:             Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n1018:             Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n1019:             {resource_map_prompt_line}\n1020:             {memory_context_prompt_line}\n1021:             Next focus: {next_focus}\n1022:           render_prompt_pack:\n1023:             template_path: \".opencode/skills/system-deep-loop/deep-research/assets/prompt-pack-iteration.md.tmpl\"\n1024:             renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n1025:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n1026:             variables:\n1027:               state_summary: \"{state_summary}\"\n1028:               research_topic: \"{research_topic}\"\n1029:               current_iteration: \"{current_iteration}\"\n1030:               max_iterations: \"{max_iterations}\"\n1031:               next_focus: \"{next_focus}\"\n1032:               remaining_questions_list: \"{remaining_questions_list}\"\n1033:               carried_forward_open_questions: \"{carried_forward_open_questions}\"\n1034:               last_3_summaries: \"{last_3_summaries}\"\n1035:               pivot_lineage: \"{pivot_lineage}\"\n1036:               saturated_directions: \"{saturated_directions}\"\n1037:               state_paths_config: \"{state_paths.config}\"\n1038:               state_paths_state_log: \"{state_paths.state_log}\"\n1039:               state_paths_strategy: \"{state_paths.strategy}\"\n1040:               state_paths_registry: \"{state_paths.registry}\"\n1041:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n1042:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n1043:         pre_dispatch_audit:\n1044:           skip_when: \"config.executor.type == 'native'\"\n1045:           call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n1046:           args:\n1047:             stateLogPath: \"{state_paths.state_log}\"\n1048:             executor: \"{config.executor}\"\n1049:             iteration: \"{current_iteration}\"\n1050:         branch_on: \"config.executor.type\"\n1051:         if_native:\n1052:           dispatch:\n1053:             agent: deep-research\n1054:             model: opus\n1055:             context_source: \"rendered_prompt_pack\"\n1056:           wait_for_completion: true\n1057:         if_cli_claude_code:\n1058:           command: |\n1059:             node --experimental-strip-types --input-type=module <<'EOF'\n1060:             import { readFileSync } from 'node:fs';\n1061:             import { createHash } from 'node:crypto';\n1062: \n1063:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1064:             import { resolveClaudePermissionMode } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n1065: \n1066:             const executor = {\n1067:               kind: 'cli-claude-code',\n1068:               model: '{config.executor.model}',\n1069:               reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n1070:               serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n1071:               sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n1072:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1073:             };\n1074:             const args = [\n1075:               '-p',\n1076:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n1077:               '--model',\n1078:               executor.model,\n1079:               '--permission-mode',\n1080:               resolveClaudePermissionMode(executor.sandboxMode),\n1081:               '--output-format',\n1082:               'text',\n1083:             ];\n1084:             if (executor.reasoningEffort) {\n1085:               args.push('--effort', executor.reasoningEffort);\n1086:             }\n1087: \n1088:             const dispatchFacts = {\n1089:               command: 'deep/research',\n1090:               mode: 'research',\n1091:               specFolder: '{spec_folder}',\n1092:               artifactDir: '{state_paths.packet_dir}',\n1093:               iteration: Number('{current_iteration}'),\n1094:               executorKind: '{config.executor.type}',\n1095:               branchId: '{config.executor.type}',\n1096:               sessionId: '{config.lineage.sessionId}',\n1097:               generation: Number('{config.lineage.generation}'),\n1098:             };\n1099:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n1100:             process.exit(\n1101:               runAuditedExecutorCommand({\n1102:                 command: 'claude',\n1103:                 args,\n1104:                 cwd: '{repo_root}',\n1105:                 timeoutSeconds: executor.timeoutSeconds,\n1106:                 stateLogPath: '{state_paths.state_log}',\n1107:                 executor,\n1108:                 iteration: Number('{current_iteration}'),\n1109:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1110:                 dispatchId,\n1111:               }),\n1112:             );\n1113:             EOF\n1114:           working_directory: \"{repo_root}\"\n1115:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1116:           wait_for_completion: true\n1117:           notes:\n1118:             - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n1119:             - \"claude-code has no serviceTier flag\"\n1120:             - \"claude-code supports --effort for reasoning depth\"\n1121:         record_executor_audit:\n1122:           skip_when: \"config.executor.type == 'native'\"\n1123:           target: \"{state_paths.state_log}\"\n1124:           field: \"executor\"\n1125:           value:\n1126:             kind: \"{config.executor.type}\"\n1127:             model: \"{config.executor.model}\"\n1128:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1129:             serviceTier: \"{config.executor.serviceTier}\"\n1130:         if_cli_opencode:\n1131:           command: |\n1132:             node --experimental-strip-types --input-type=module <<'EOF'\n1133:             import { readFileSync } from 'node:fs';\n1134:             import { createHash } from 'node:crypto';\n1135: \n1136:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1137: \n1138:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1139:             const executor = {\n1140:               kind: 'cli-opencode',\n1141:               model: '{config.executor.model}',\n1142:               configDir: null,\n1143:               reasoningEffort,\n1144:               serviceTier: null,\n1145:               sandboxMode: null,\n1146:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1147:               governor: null,\n1148:             };\n1149:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1150:             const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n1151:               + '\\n\\n'\n1152:               + promptBody;\n1153:             const args = [\n1154:               'run',\n1155:               '--model',\n1156:               executor.model,\n1157:               '--format',\n1158:               'json',\n1159:               '--dangerously-skip-permissions',\n1160:               '--pure',\n1161:               '--dir',\n1162:               '{repo_root}',\n1163:             ];\n1164:             if (executor.reasoningEffort) {\n1165:               args.push('--variant', executor.reasoningEffort);\n1166:             }\n1167:             args.push(message);\n1168: \n1169:             const dispatchFacts = {\n1170:               command: 'deep/research',\n1171:               mode: 'research',\n1172:               specFolder: '{spec_folder}',\n1173:               artifactDir: '{state_paths.packet_dir}',\n1174:               iteration: Number('{current_iteration}'),\n1175:               executorKind: '{config.executor.type}',\n1176:               branchId: '{config.executor.type}',\n1177:               sessionId: '{config.lineage.sessionId}',\n1178:               generation: Number('{config.lineage.generation}'),\n1179:             };\n1180:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n1181:             process.exit(\n1182:               runAuditedExecutorCommand({\n1183:                 command: 'opencode',\n1184:                 args,\n1185:                 cwd: '{repo_root}',\n1186:                 timeoutSeconds: executor.timeoutSeconds,\n1187:                 stateLogPath: '{state_paths.state_log}',\n1188:                 executor,\n1189:                 iteration: Number('{current_iteration}'),\n1190:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1191:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1192:                 input: '',\n1193:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1194:                 dispatchId,\n1195:               }),\n1196:             );\n1197:             EOF\n1198:           working_directory: \"{repo_root}\"\n1199:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1200:           wait_for_completion: true\n1201:           notes:\n1202:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1203:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n1204:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1205:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1206:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1207:             - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1208:         if_cli_codex:\n1209:           command: |\n1210:             node --experimental-strip-types --input-type=module <<'EOF'\n1211:             import { readFileSync } from 'node:fs';\n1212:             import { execFileSync } from 'node:child_process';\n1213: \n1214:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1215: \n1216:             // Fail closed: a requested codex executor must dispatch codex or abort,\n1217:             // never silently degrade to another executor. Undetected absence is what\n1218:             // got Codex deprecated before, so the branch exits non-zero when the\n1219:             // binary is missing instead of falling through to a native/other path.\n1220:             let codexAvailable = false;\n1221:             try {\n1222:               execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n1223:               codexAvailable = true;\n1224:             } catch {}\n1225:             if (!codexAvailable) {\n1226:               console.error('cli-codex executor unavailable: command -v codex failed');\n1227:               process.exit(1);\n1228:             }\n1229: \n1230:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1231:             const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n1232:             const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n1233:             const executor = {\n1234:               kind: 'cli-codex',\n1235:               model,\n1236:               configDir: null,\n1237:               reasoningEffort,\n1238:               serviceTier,\n1239:               sandboxMode: 'workspace-write',\n1240:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1241:               governor: null,\n1242:             };\n1243: \n1244:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1245: \n1246:             // codex reads the iteration prompt from stdin via the trailing '-'. A research\n1247:             // iteration must WRITE its own iteration file, delta and state record, so the\n1248:             // sandbox is workspace-write — read-only would block those required writes.\n1249:             // approval_policy=never keeps the run non-interactive.\n1250:             const args = ['exec'];\n1251:             if (model) {\n1252:               args.push('--model', model);\n1253:             }\n1254:             args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n1255:             if (serviceTier) {\n1256:               args.push('-c', 'service_tier=' + serviceTier);\n1257:             }\n1258:             args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n1259: \n1260:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n1261:             process.exit(\n1262:               runAuditedExecutorCommand({\n1263:                 command: 'codex',\n1264:                 args,\n1265:                 cwd: '{repo_root}',\n1266:                 timeoutSeconds: executor.timeoutSeconds,\n1267:                 stateLogPath: '{state_paths.state_log}',\n1268:                 executor,\n1269:                 iteration: Number('{current_iteration}'),\n1270:                 input: promptBody,\n1271:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1272:                 dispatchId,\n1273:               }),\n1274:             );\n1275:             EOF\n1276:           working_directory: \"{repo_root}\"\n1277:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1278:           wait_for_completion: true\n1279:           notes:\n1280:             - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n1281:             - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n1282:             - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n1283:             - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n1284:         post_dispatch_validate:\n1285:           validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1286:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1287:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1288:           assert_exists: \"{state_paths.iteration_pattern}\"\n1289:           assert_appended: \"{state_paths.state_log}\"\n1290:           assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n1291:           route_proof:\n1292:             mode: research\n1293:             target_agent: deep-research\n1294:             agent_definition_loaded: true\n1295:             resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n1296:           dispatchReceipt:\n1297:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1298:             dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n1299:           optional_jsonl_fields:\n1300:             logOffset: \"Byte offset where the seekable log region starts\"\n1301:             logSize: \"Byte length of the seekable log region\"\n1302:             logPath: \"Absolute path to the file containing the seekable log region\"\n1303:             skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n1304:             slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n1305:           assert_canonical_type: \"iteration\"\n1306:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1307:           assert_delta_file_has_iteration_record: true\n1308:           on_failure:\n1309:             action: \"emit schema_mismatch canonical conflict event\"\n1310:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n1311:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1312:           failure_reasons_reference:\n1313:             - \"iteration_file_missing — iteration narrative markdown not written\"\n1314:             - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n1315:             - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n1316:             - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n1317:             - \"jsonl_parse_error — last state-log line is not valid JSON\"\n1318:             - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n1319:             - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n1320:             - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n1321:             - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n1322:             - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n1323:             - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n1324:             - \"executor_missing — non-native executor did not record provenance\"\n1325:             - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n1326: \n1327:       step_run_now_restore_check:\n1328:         action: \"Record a run-now sentinel recreated during the completed dispatch\"\n1329:         command: |\n1330:           node <<'EOF'\n1331:           const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n1332: \n1333:           const stateLogPath = \"{state_paths.state_log}\";\n1334:           const sentinelPath = \"{state_paths.run_now_sentinel}\";\n1335:           const timestamp = \"{ISO_8601_NOW}\";\n1336:           const sessionId = \"{config.lineage.sessionId}\";\n1337:           const generation = Number(\"{config.lineage.generation}\");\n1338:           const run = Number(\"{current_iteration}\");\n1339: \n1340:           function hasAcceptedCurrentRun() {\n1341:             if (!existsSync(stateLogPath)) return false;\n1342:             const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n1343:             for (let index = lines.length - 1; index >= 0; index -= 1) {\n1344:               const record = JSON.parse(lines[index]);\n1345:               if (record.run !== run || record.sessionId !== sessionId) continue;\n1346:               if (record.event === \"run_now_accepted\") return true;\n1347:               if (record.event === \"run_now_rejected\") return false;\n1348:             }\n1349:             return false;\n1350:           }\n1351: \n1352:           if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n1353:             appendFileSync(\n1354:               stateLogPath,\n1355:               `${JSON.stringify({\n1356:                 type: \"event\",\n1357:                 event: \"run_now_restored\",\n1358:                 mode: \"research\",\n1359:                 run,\n1360:                 sentinelPath,\n1361:                 timestamp,\n1362:                 sessionId,\n1363:                 generation,\n1364:               })}\\n`,\n1365:               \"utf8\",\n1366:             );\n1367:           }\n1368:           EOF\n1369:         outputs:\n1370:           - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n1371: \n1372:       step_reduce_state:\n1373:         action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n1374:         command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n1375:         inputs:\n1376:           latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n1377:           newIterationFile: \"{state_paths.iteration_pattern}\"\n1378:           priorReducedState: \"{state_paths.registry}\"\n1379:         outputs:\n1380:           - \"{state_paths.registry}\"\n1381:           - \"{state_paths.dashboard}\"\n1382:           - \"{state_paths.strategy}\"\n1383:           - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n1384:           - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n1385:           - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n1386:         failure_modes:\n1387:           malformed_delta: \"skip + warn\"\n1388:           missing_iteration_file: \"no-op + error\"\n1389:           schema_mismatch: \"reject + conflict event\"\n1390:           question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n1391:         guarantee: \"Idempotent for identical inputs\"\n1392: \n1393:       step_graph_upsert:\n1394:         action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n1395:         read:\n1396:           - \"{state_paths.state_log}\"\n1397:         extract:\n1398:           - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n1399:           - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n1400:           - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n1401:           - graph_upsert_event_count: \"Count mapped node and edge events\"\n1402:         if_graph_events_present:\n1403:           bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n1404:           note: \"Skip silently when graphEvents is missing or empty.\"\n1405:         if_graph_events_missing:\n1406:           proceed: true\n1407: \n1408:       step_memory_upsert_iteration:\n1409:         action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n1410:         mcp_tool: memory_save\n1411:         invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n1412:         timeout_seconds: 5\n1413:         idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n1414:         failure_policy:\n1415:           mcp_error: \"non-fatal; log advisory warning and continue\"\n1416:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n1417:         outputs:\n1418:           - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n1419:           - memory_upsert_status: \"upserted | advisory_error\"\n1420: \n1421:       step_refresh_memory_context:\n1422:         action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n1423:         mcp_tool: memory_context\n1424:         invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n1425:         timeout_seconds: 5\n\n(Showing lines 726-1425 of 2012. Use offset=1426 to continue.)\n</content>","metadata":{"preview":"                    renderResearchPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-research/scripts/divergent-research-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildResearchPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),\n                    triggerReason: '{reason}',\n                  });\n                  const prepared = await preparePivotTransaction(input);\n                  const seatPrompts = prepared.status === 'pending'\n                    ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n                        seat.id,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml","text":"                    renderResearchPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-research/scripts/divergent-research-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildResearchPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),\n                    triggerReason: '{reason}',\n                  });\n                  const prepared = await preparePivotTransaction(input);\n                  const seatPrompts = prepared.status === 'pending'\n                    ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n                        seat.id,\n                        renderResearchPivotSeatPrompt(seat, prepared.dispatchContext),\n                      ]))\n                    : {};\n                  process.stdout.write(`${JSON.stringify({\n                    ...prepared,\n                    seatPrompts,\n                    boundaryRejections: input.boundaryRejections,\n                  })}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_prepare_json: \"The complete parsed JSON result\"\n                  - pivot_prepare_status: \"status from the prepare result\"\n                  - pivot_id: \"pivotId from the prepare result\"\n                  - pivot_paths_json: \"paths from the prepare result as JSON\"\n                  - pivot_resumed: \"resumed from the prepare result\"\n                  - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n                  - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n                  - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n                  - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n                  - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n                  - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n                  - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n                  - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n                short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n\n              step_dispatch_pivot_seat_001:\n                action: \"Natively dispatch the analytical research direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-research\n                    model: opus\n                    context_source: \"pivot_seat_001_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n                outputs:\n                  - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_001_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_001:\n                action: \"Durably record the seat-001 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_001_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_002:\n                action: \"Natively dispatch the critical research direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-research\n                    model: opus\n                    context_source: \"pivot_seat_002_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n                outputs:\n                  - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_002_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_002:\n                action: \"Durably record the seat-002 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_002_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_003:\n                action: \"Natively dispatch the pragmatic research direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-research\n                    model: opus\n                    context_source: \"pivot_seat_003_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n                outputs:\n                  - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_003_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_003:\n                action: \"Durably record the seat-003 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_003_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_finalize_divergent_pivot:\n                action: \"Finalize the prepared pivot after all missing native seats are durable\"\n                skip_when: \"pivot_prepare_status != 'pending'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_finalize_json: \"The complete parsed final result\"\n\n              step_resolve_divergent_pivot_result:\n                action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n                branch_on: \"pivot_prepare_status\"\n                if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n                if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n\n              step_apply_divergent_pivot_result:\n                action: \"Adopt a successful focus or fail closed to the existing synthesis path\"\n                branch_on: \"pivot_result.status\"\n                if_completed:\n                  set:\n                    next_focus: \"{pivot_result.restoredFocus}\"\n                    pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n                    saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n                  command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n                  log: \"Divergent pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n                  proceed_to: step_rejected_pattern_cache\n                if_failed:\n                  log: \"Divergent pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n                  skip_to: phase_synthesis\n            on_error:\n              log: \"Divergent pivot integration error; failing closed to the existing synthesis path.\"\n              skip_to: phase_synthesis\n          if_existing_terminal_path:\n            log: \"Loop stopping. Reason: {reason}\"\n            skip_to: phase_synthesis\n        if_stuck_recovery:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          set: { next_focus: \"RECOVERY: Widen scope. Try fundamentally different approach. Least-explored question: {least_explored}\" }\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Focus: {next_focus}\"\n\n      step_rejected_pattern_cache:\n        action: \"Apply reducer-derived rejected-pattern suppression before dispatch candidate selection\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        candidate_sources:\n          next_focus:\n            category: \"next-focus\"\n            values:\n              - \"{next_focus}\"\n              - \"{remaining_questions_list}\"\n              - \"{carried_forward_open_questions}\"\n          recovery:\n            category: \"recovery\"\n            values:\n              - \"{recovery_strategy}\"\n              - \"{least_explored}\"\n          ideas:\n            category: \"ideas\"\n            values:\n              - \"{promoted_ideas_list}\"\n            optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n        algorithm: |\n          Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n          reducer pass as the source of truth.\n          Compare normalized exact text first. Then compare fuzzy similarity with\n          rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n          are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n          selection before rendering the dispatch prompt. If all candidates are suppressed,\n          halt for operator input instead of reusing a rejected idea.\n        outputs:\n          - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n          - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n          - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n          - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n        if_next_focus_suppressed:\n          set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n          log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n        if_all_candidates_suppressed:\n          halt: true\n          message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n\n      step_ideas_backlog_lifecycle:\n        action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.config}\"\n        lifecycle:\n          observed_event: \"idea_observed\"\n          promoted_event: \"idea_promoted\"\n          rejected_event: \"idea_rejected\"\n          min_observations: \"{min_idea_observations}\"\n          authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n        validate:\n          - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n          - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n          - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n        outputs:\n          - observed_ideas_count: \"Reducer-derived observed ideas count\"\n          - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n          - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n          - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n\n      step_normalize_pause_events:\n        action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n        stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n        rule_pause_sentinel:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n        rule_stuck_recovery:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch one iteration via the selected executor\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n            Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n            {resource_map_prompt_line}\n            {memory_context_prompt_line}\n            Next focus: {next_focus}\n          render_prompt_pack:\n            template_path: \".opencode/skills/system-deep-loop/deep-research/assets/prompt-pack-iteration.md.tmpl\"\n            renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              research_topic: \"{research_topic}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_focus: \"{next_focus}\"\n              remaining_questions_list: \"{remaining_questions_list}\"\n              carried_forward_open_questions: \"{carried_forward_open_questions}\"\n              last_3_summaries: \"{last_3_summaries}\"\n              pivot_lineage: \"{pivot_lineage}\"\n              saturated_directions: \"{saturated_directions}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_registry: \"{state_paths.registry}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.type\"\n        if_native:\n          dispatch:\n            agent: deep-research\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n            import { resolveClaudePermissionMode } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n              serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n              sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              resolveClaudePermissionMode(executor.sandboxMode),\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n            - \"claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        record_executor_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.type}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { execFileSync } from 'node:child_process';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            // Fail closed: a requested codex executor must dispatch codex or abort,\n            // never silently degrade to another executor. Undetected absence is what\n            // got Codex deprecated before, so the branch exits non-zero when the\n            // binary is missing instead of falling through to a native/other path.\n            let codexAvailable = false;\n            try {\n              execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n              codexAvailable = true;\n            } catch {}\n            if (!codexAvailable) {\n              console.error('cli-codex executor unavailable: command -v codex failed');\n              process.exit(1);\n            }\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n            const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n            const executor = {\n              kind: 'cli-codex',\n              model,\n              configDir: null,\n              reasoningEffort,\n              serviceTier,\n              sandboxMode: 'workspace-write',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n\n            // codex reads the iteration prompt from stdin via the trailing '-'. A research\n            // iteration must WRITE its own iteration file, delta and state record, so the\n            // sandbox is workspace-write — read-only would block those required writes.\n            // approval_policy=never keeps the run non-interactive.\n            const args = ['exec'];\n            if (model) {\n              args.push('--model', model);\n            }\n            args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n            if (serviceTier) {\n              args.push('-c', 'service_tier=' + serviceTier);\n            }\n            args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'codex',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                input: promptBody,\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n            - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n            - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n            - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n          route_proof:\n            mode: research\n            target_agent: deep-research\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n          optional_jsonl_fields:\n            logOffset: \"Byte offset where the seekable log region starts\"\n            logSize: \"Byte length of the seekable log region\"\n            logPath: \"Absolute path to the file containing the seekable log region\"\n            skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n            slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n          failure_reasons_reference:\n            - \"iteration_file_missing — iteration narrative markdown not written\"\n            - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n            - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n            - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n            - \"jsonl_parse_error — last state-log line is not valid JSON\"\n            - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n            - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n            - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n            - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n            - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n            - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n            - \"executor_missing — non-native executor did not record provenance\"\n            - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n\n      step_run_now_restore_check:\n        action: \"Record a run-now sentinel recreated during the completed dispatch\"\n        command: |\n          node <<'EOF'\n          const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n\n          const stateLogPath = \"{state_paths.state_log}\";\n          const sentinelPath = \"{state_paths.run_now_sentinel}\";\n          const timestamp = \"{ISO_8601_NOW}\";\n          const sessionId = \"{config.lineage.sessionId}\";\n          const generation = Number(\"{config.lineage.generation}\");\n          const run = Number(\"{current_iteration}\");\n\n          function hasAcceptedCurrentRun() {\n            if (!existsSync(stateLogPath)) return false;\n            const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n            for (let index = lines.length - 1; index >= 0; index -= 1) {\n              const record = JSON.parse(lines[index]);\n              if (record.run !== run || record.sessionId !== sessionId) continue;\n              if (record.event === \"run_now_accepted\") return true;\n              if (record.event === \"run_now_rejected\") return false;\n            }\n            return false;\n          }\n\n          if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n            appendFileSync(\n              stateLogPath,\n              `${JSON.stringify({\n                type: \"event\",\n                event: \"run_now_restored\",\n                mode: \"research\",\n                run,\n                sentinelPath,\n                timestamp,\n                sessionId,\n                generation,\n              })}\\n`,\n              \"utf8\",\n            );\n          }\n          EOF\n        outputs:\n          - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n\n      step_reduce_state:\n        action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n        inputs:\n          latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n          newIterationFile: \"{state_paths.iteration_pattern}\"\n          priorReducedState: \"{state_paths.registry}\"\n        outputs:\n          - \"{state_paths.registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n          - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n          - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n          question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n        guarantee: \"Idempotent for identical inputs\"\n\n      step_graph_upsert:\n        action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n        read:\n          - \"{state_paths.state_log}\"\n        extract:\n          - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n          - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n          - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n          - graph_upsert_event_count: \"Count mapped node and edge events\"\n        if_graph_events_present:\n          bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n          note: \"Skip silently when graphEvents is missing or empty.\"\n        if_graph_events_missing:\n          proceed: true\n\n      step_memory_upsert_iteration:\n        action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n        timeout_seconds: 5\n        idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n        outputs:\n          - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n          - memory_upsert_status: \"upserted | advisory_error\"\n\n      step_refresh_memory_context:\n        action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n        mcp_tool: memory_context\n        invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n        timeout_seconds: 5","lineStart":726,"lineEnd":1425,"totalLines":2012,"truncated":true}},"title":".opencode/commands/deep/assets/deep-research-auto.yaml","time":{"start":1784616149451,"end":1784616149494}},"metadata":{"openai":{"itemId":"fc_0ae65632ea5275aa016a5f14d543cc8191a05cc681a1b781b7"}},"id":"prt_f8369615b001U148IqpCAaIP6y","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f83692ce5001mPoWyqS4qb7ys9"}}
{"type":"tool_use","timestamp":1784616149504,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_QZL7amhOjm7gpDn3bA4r1VZq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml","offset":1426,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml</path>\n<type>file</type>\n<content>\n1426:         use_response:\n1427:           - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n1428:         failure_policy:\n1429:           mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n1430:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n1431:         outputs:\n1432:           - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n1433:           - memory_context_refresh_status: \"refreshed | advisory_error\"\n1434: \n1435:       step_evaluate_results:\n1436:         action: \"Verify iteration outputs and extract metrics\"\n1437:         verify:\n1438:           - file_exists: \"{state_paths.iteration_pattern}\"\n1439:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1440:           - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n1441:           - registry_updated: \"Reducer refreshed findings-registry.json\"\n1442:         extract:\n1443:           - newInfoRatio: \"From latest JSONL iteration record\"\n1444:           - findings_count: \"From latest JSONL iteration record\"\n1445:           - status: \"From latest JSONL iteration record\"\n1446:           - latest_focus: \"From latest JSONL iteration record\"\n1447:         on_missing_outputs:\n1448:           action: \"Mark iteration as 'error', continue to next\"\n1449:           # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n1450:           # so the reducer can persist the failure without dropping the iteration. Schema source: state-format.md §Iteration Records.\n1451:           append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n1452: \n1453:       step_telemetry_heartbeat_progress:\n1454:         action: \"Emit a single-loop progress row when iteration state changes\"\n1455:         skip_when: \"config.fanout is present\"\n1456:         command: |\n1457:           node --experimental-strip-types --input-type=module <<'EOF'\n1458:           import { existsSync, readFileSync } from 'node:fs';\n1459: \n1460:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n1461:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n1462: \n1463:           const { appendObservabilityEvent } = observabilityEvents;\n1464:           const stateLogPath = '{state_paths.state_log}';\n1465:           const timestamp = '{ISO_8601_NOW}';\n1466:           const sessionId = '{config.lineage.sessionId}';\n1467:           const generation = Number('{config.lineage.generation}');\n1468:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1469: \n1470:           function readRecords(path) {\n1471:             if (!existsSync(path)) return [];\n1472:             return readFileSync(path, 'utf8')\n1473:               .split(/\\r?\\n/)\n1474:               .map((line) => line.trim())\n1475:               .filter(Boolean)\n1476:               .map((line) => JSON.parse(line));\n1477:           }\n1478: \n1479:           function elapsedSince(value) {\n1480:             const startedAtMs = Date.parse(String(value ?? ''));\n1481:             const nowMs = Date.parse(timestamp);\n1482:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1483:             return Math.max(0, nowMs - startedAtMs);\n1484:           }\n1485: \n1486:           const records = readRecords(stateLogPath);\n1487:           const iterations = records.filter((record) => record.type === 'iteration');\n1488:           const latest = iterations.at(-1) ?? {};\n1489:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1490:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1491:             ?? timestamp;\n1492:           const elapsedMs = elapsedSince(startedAt);\n1493:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1494:           const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n1495:           const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n1496:           const row = {\n1497:             event: 'progress',\n1498:             label: 'single',\n1499:             at: timestamp,\n1500:             duration_ms: elapsedMs,\n1501:             loop_type: 'research',\n1502:             sessionId,\n1503:             generation,\n1504:             run,\n1505:             status,\n1506:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1507:           };\n1508: \n1509:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1510:             diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n1511:             diffField: 'state_hash',\n1512:           });\n1513:           if (appended) {\n1514:             try {\n1515:               appendObservabilityEvent(observabilityPath, row, {\n1516:                 producer: 'deep-research-auto',\n1517:                 stream: 'single-loop-telemetry',\n1518:                 subject: { label: row.label, sessionId, generation, run },\n1519:                 event: row.event,\n1520:                 status,\n1521:               });\n1522:             } catch {}\n1523:           }\n1524:           EOF\n1525:         working_directory: \"{repo_root}\"\n1526:         outputs:\n1527:           - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n1528: \n1529:       step_generate_dashboard:\n1530:         action: \"Generate or refresh the human-readable dashboard\"\n1531:         read:\n1532:           - \"{state_paths.state_log}\"\n1533:           - \"{state_paths.registry}\"\n1534:           - \"{state_paths.strategy}\"\n1535:         template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-dashboard.md\n1536:         output: \"{state_paths.dashboard}\"\n1537:         note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n1538: \n1539:       step_update_tracking:\n1540:         action: \"Update loop tracking variables\"\n1541:         set:\n1542:           current_iteration: \"{current_iteration + 1}\"\n1543:           stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n1544:         log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n1545: \n1546:       step_loop_decision:\n1547:         action: \"Return to step_read_state for next iteration\"\n1548:         goto: step_read_state\n1549: \n1550:   # ═══════════════════════════════════════════════════════════════\n1551:   # PHASE 3: SYNTHESIS\n1552:   # ═══════════════════════════════════════════════════════════════\n1553:   phase_synthesis:\n1554:     purpose: Compile all iteration findings into final research/research.md\n1555:     steps:\n1556: \n1557:       step_fanout_merge:\n1558:         description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n1559:         skip_when: \"config.fanout is absent\"\n1560:         command: |\n1561:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n1562:             --loop-type research \\\n1563:             --artifact-dir {artifact_dir}\n1564:         working_directory: \"{repo_root}\"\n1565:         wait_for_completion: true\n1566: \n1567:       step_hydrate_summary_metrics:\n1568:         action: \"Hydrate summary metrics before synthesis\"\n1569:         read:\n1570:           - \"{state_paths.config}\"\n1571:           - \"{state_paths.state_log}\"\n1572:           - \"{state_paths.registry}\"\n1573:           - \"{state_paths.strategy}\"\n1574:         extract:\n1575:           - iteration_count: \"Count lines where type === 'iteration'\"\n1576:           - current_iteration: \"iteration_count + 1\"\n1577:           - current_segment: \"Latest segment_start event segment, else 1\"\n1578:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n1579:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n1580:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n1581:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n1582:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n1583:           - answered_count: \"Count answered questions from strategy.md\"\n1584:           - total_questions: \"Count total questions tracked in strategy.md\"\n1585:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n1586:           - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n1587:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1588: \n1589:       step_read_all_iterations:\n1590:         action: \"Read all iteration files and strategy\"\n1591:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1592:         read_also: \"{state_paths.strategy}\"\n1593: \n1594:       step_emit_resource_map:\n1595:         action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n1596:         command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1597:         read:\n1598:           - \"{state_paths.config}\"\n1599:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1600:         write:\n1601:           - \"{state_paths.resource_map_output}\"\n1602:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1603: \n1604:       step_compile_research:\n1605:         action: \"Compile or finalize research/research.md\"\n1606:         instructions: |\n1607:           If research/research.md exists (progressive synthesis was active):\n1608:             1. Read current research/research.md\n1609:             2. Consolidate and deduplicate findings across all iterations\n1610:             3. Fill any empty sections with findings from iteration files\n1611:             4. Remove redundancy while preserving all unique findings\n1612:             5. Add convergence report as appendix\n1613:             6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1614:             7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n1615: \n1616:           If research/research.md does not exist:\n1617:             1. Create research/research.md following 17-section template\n1618:             2. Populate sections from iteration files\n1619:             3. Add citations from original sources\n1620:             4. Note unanswered questions in Open Questions section\n1621:             5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1622:             6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n1623:           Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n1624:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop-protocol.md §Lifecycle Branch Contract`.)\n1625:         output: \"{state_paths.research_output}\"\n1626: \n1627:       step_convergence_report:\n1628:         action: \"Generate and append convergence report\"\n1629:         report: |\n1630:           ## Convergence Report\n1631:           - Stop reason: {reason}\n1632:           - Total iterations: {iteration_count}\n1633:           - Questions answered: {answered_count} / {total_questions}\n1634:           - Remaining questions: {remaining_questions}\n1635:           - Last 3 iteration summaries: {last_3_summaries}\n1636:           - Convergence threshold: {convergence_threshold}\n1637:           - Divergence summary: {divergence_summary}\n1638:           - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n1639:         command: |\n1640:           node --input-type=module <<'EOF'\n1641:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1642: \n1643:           const paths = {\n1644:             stateLog: String.raw`{state_paths.state_log}`,\n1645:             registry: String.raw`{state_paths.registry}`,\n1646:             research: String.raw`{state_paths.research_output}`,\n1647:             dashboard: String.raw`{state_paths.dashboard}`,\n1648:           };\n1649: \n1650:           function hasFile(filePath) {\n1651:             try {\n1652:               return existsSync(filePath) && statSync(filePath).isFile();\n1653:             } catch {\n1654:               return false;\n1655:             }\n1656:           }\n1657: \n1658:           function readJson(filePath) {\n1659:             try {\n1660:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1661:             } catch {\n1662:               return null;\n1663:             }\n1664:           }\n1665: \n1666:           function readJsonl(filePath) {\n1667:             if (!hasFile(filePath)) return [];\n1668:             return readFileSync(filePath, 'utf8')\n1669:               .split(/\\r?\\n/)\n1670:               .map((line) => line.trim())\n1671:               .filter(Boolean)\n1672:               .flatMap((line) => {\n1673:                 try {\n1674:                   return [JSON.parse(line)];\n1675:                 } catch {\n1676:                   return [];\n1677:                 }\n1678:               });\n1679:           }\n1680: \n1681:           function countIterationFindings(record) {\n1682:             if (!record || record.type !== 'iteration') return 0;\n1683:             const numeric = Number(record.findingsCount);\n1684:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1685:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1686:             if (Array.isArray(record.findings)) return record.findings.length;\n1687:             return 0;\n1688:           }\n1689: \n1690:           function normalizeFindingKey(value) {\n1691:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1692:           }\n1693: \n1694:           function findingKeys(candidate) {\n1695:             if (typeof candidate === 'string') {\n1696:               const key = normalizeFindingKey(candidate);\n1697:               return key ? [key] : [];\n1698:             }\n1699:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1700:             return [...new Set([\n1701:               candidate.id,\n1702:               candidate.title,\n1703:               candidate.summary,\n1704:               candidate.text,\n1705:               candidate.finding,\n1706:               candidate.description,\n1707:             ].map(normalizeFindingKey).filter(Boolean))];\n1708:           }\n1709: \n1710:           function collectIterationFindingGroups(record) {\n1711:             if (!record || record.type !== 'iteration') return [];\n1712:             const structured = [record.keyFindings, record.findings]\n1713:               .find((value) => Array.isArray(value) && value.length > 0);\n1714:             if (!Array.isArray(structured)) return [];\n1715:             return structured\n1716:               .map(findingKeys)\n1717:               .filter((keys) => keys.length > 0);\n1718:           }\n1719: \n1720:           function collectRegistryFindingKeys(registry) {\n1721:             if (!Array.isArray(registry?.keyFindings)) return [];\n1722:             return registry.keyFindings\n1723:               .flatMap(findingKeys);\n1724:           }\n1725: \n1726:           function appendEvent(event) {\n1727:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1728:           }\n1729: \n1730:           const registry = readJson(paths.registry);\n1731:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1732:           const stateRecords = readJsonl(paths.stateLog);\n1733:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1734:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1735:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1736:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1737:           const identifiableFindingCount = identifiableFindingGroups.length;\n1738:           const missingArtifacts = [\n1739:             ['registry', paths.registry],\n1740:             ['research', paths.research],\n1741:             ['dashboard', paths.dashboard],\n1742:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1743:           const invariantFailures = [];\n1744:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1745:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1746:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1747:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1748:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1749: \n1750:           if (invariantFailures.length > 0) {\n1751:             appendEvent({\n1752:               type: 'event',\n1753:               event: 'synthesis_incomplete',\n1754:               mode: 'research',\n1755:               severity: 'warning',\n1756:               totalIterations: Number('{iteration_count}'),\n1757:               answeredCount: Number('{answered_count}'),\n1758:               totalQuestions: Number('{total_questions}'),\n1759:               stopReason: '{reason}',\n1760:               reason: 'synthesis_artifact_invariant_failed',\n1761:               invariantFailures,\n1762:               missingArtifacts,\n1763:               registryFindingCount,\n1764:               iterationFindingCount,\n1765:               identifiableFindingCount,\n1766:               missingStructuredFindingCount,\n1767:               timestamp: '{ISO_8601_NOW}',\n1768:             });\n1769:           } else {\n1770:             appendEvent({\n1771:               type: 'event',\n1772:               event: 'synthesis_complete',\n1773:               totalIterations: Number('{iteration_count}'),\n1774:               answeredCount: Number('{answered_count}'),\n1775:               totalQuestions: Number('{total_questions}'),\n1776:               stopReason: '{reason}',\n1777:               timestamp: '{ISO_8601_NOW}',\n1778:             });\n1779:           }\n1780:           EOF\n1781: \n1782:       step_writeback_spec_findings:\n1783:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1784:         edit: \"{spec_folder}/spec.md\"\n1785:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1786:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1787:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1788:         fail_closed_conflict_check:\n1789:           if_existing_generated_fence_present:\n1790:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1791:             on_manual_edit_conflict:\n1792:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1793:               halt: true\n1794:         instructions:\n1795:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1796:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1797:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1798:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1799:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1800:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1801: \n1802:       step_validate_post_synthesis_spec_doc:\n1803:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1804:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1805:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1806: \n1807:       step_update_config_status:\n1808:         action: \"Mark config as complete\"\n1809:         edit: \"{state_paths.config}\"\n1810:         set_field: { status: \"complete\" }\n1811: \n1812:       step_telemetry_heartbeat_terminal:\n1813:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1814:         skip_when: \"config.fanout is present\"\n1815:         terminal_events: [completed, failed, stopped]\n1816:         command: |\n1817:           node --experimental-strip-types --input-type=module <<'EOF'\n1818:           import { existsSync, readFileSync } from 'node:fs';\n1819: \n1820:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n1821:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n1822: \n1823:           const { appendObservabilityEvent } = observabilityEvents;\n1824:           const stateLogPath = '{state_paths.state_log}';\n1825:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1826:           const timestamp = '{ISO_8601_NOW}';\n1827:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1828:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1829:           const reason = '{reason}';\n1830:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1831: \n1832:           function readRecords(path) {\n1833:             if (!existsSync(path)) return [];\n1834:             return readFileSync(path, 'utf8')\n1835:               .split(/\\r?\\n/)\n1836:               .map((line) => line.trim())\n1837:               .filter(Boolean)\n1838:               .map((line) => JSON.parse(line));\n1839:           }\n1840: \n1841:           function elapsedSince(value) {\n1842:             const startedAtMs = Date.parse(String(value ?? ''));\n1843:             const nowMs = Date.parse(timestamp);\n1844:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1845:             return Math.max(0, nowMs - startedAtMs);\n1846:           }\n1847: \n1848:           function terminalEvent(stopReason) {\n1849:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1850:             if (stopReason === 'error') return 'failed';\n1851:             return 'completed';\n1852:           }\n1853: \n1854:           const records = readRecords(stateLogPath);\n1855:           const iterations = records.filter((record) => record.type === 'iteration');\n1856:           const latest = iterations.at(-1) ?? {};\n1857:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1858:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1859:             ?? timestamp;\n1860:           const elapsedMs = elapsedSince(startedAt);\n1861:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1862:           const event = terminalEvent(reason);\n1863:           const row = {\n1864:             event,\n1865:             label: 'single',\n1866:             terminal: true,\n1867:             reason,\n1868:             at: timestamp,\n1869:             duration_ms: elapsedMs,\n1870:             loop_type: 'research',\n1871:             sessionId,\n1872:             generation,\n1873:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1874:           };\n1875: \n1876:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1877:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1878:             diffField: 'state_hash',\n1879:           });\n1880:           if (appended) {\n1881:             try {\n1882:               appendObservabilityEvent(observabilityPath, row, {\n1883:                 producer: 'deep-research-auto',\n1884:                 stream: 'single-loop-telemetry',\n1885:                 subject: { label: row.label, sessionId, generation, reason },\n1886:                 event,\n1887:                 status: event,\n1888:               });\n1889:             } catch {}\n1890:           }\n1891:           EOF\n1892:         working_directory: \"{repo_root}\"\n1893:         outputs:\n1894:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1895: \n1896:       step_stage_artifact_dir:\n1897:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1898:         command: \"git add {state_paths.packet_dir}\"\n1899:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1900:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1901: \n1902:   # ═══════════════════════════════════════════════════════════════\n1903:   # PHASE 4: SAVE\n1904:   # ═══════════════════════════════════════════════════════════════\n1905:   phase_save:\n1906:     purpose: Preserve research context to memory system\n1907:     steps:\n1908: \n1909:       step_compose_save_payload:\n1910:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1911:         output: \"/tmp/save-context-data-<session-id>.json\"\n1912:         requirements:\n1913:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1914:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1915:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1916:         example_payload: |\n1917:           {\n1918:             \"specFolder\": \"{spec_folder}\",\n1919:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n1920:             \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n1921:             \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n1922:             \"exchanges\": [],\n1923:             \"toolCalls\": []\n1924:           }\n1925: \n1926:       step_generate_context:\n1927:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1928:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1929:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1930: \n1931:       step_index_memory:\n1932:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1933:         mcp_tool: memory_save\n1934:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1935:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1936: \n1937:       step_verify_save:\n1938:         action: \"Verify canonical save routed content into the correct spec document\"\n1939:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1940:         on_fail: \"Log warning but do not block completion\"\n1941: \n1942:       step_release_lock:\n1943:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1944:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1945:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1946: \n1947:   # ═══════════════════════════════════════════════════════════════\n1948:   # COMPLETION\n1949:   # ═══════════════════════════════════════════════════════════════\n1950:   completion:\n1951:     message: |\n1952:       Deep research complete.\n1953:       Iterations: {iteration_count} | Stop reason: {reason}\n1954:       Questions answered: {answered_count}/{total_questions}\n1955: \n1956:       Artifacts:\n1957:         - research/research.md (compiled from {iteration_count} iterations)\n1958:         - {iteration_count} iteration files in research/\n1959:         - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n1960:         - Memory context saved\n1961: \n1962:       STATUS=OK PATH={spec_folder}\n1963:     next_steps:\n1964:       - \"/speckit:plan [feature-description]\"\n1965:       - \"/deep:research [new-topic] (for related deep research)\"\n1966:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1967: \n1968: # ─────────────────────────────────────────────────────────────────\n1969: # ERROR RECOVERY\n1970: # ─────────────────────────────────────────────────────────────────\n1971: error_recovery:\n1972:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n1973:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1974:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1975:   memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n1976: \n1977: # ─────────────────────────────────────────────────────────────────\n1978: # RULES\n1979: # ─────────────────────────────────────────────────────────────────\n1980: rules:\n1981:   ALWAYS:\n1982:     - follow_workflow_phases_in_order\n1983:     - dispatch_deep_research_agent_per_iteration\n1984:     - check_convergence_before_each_iteration\n1985:     - write_all_state_to_files\n1986:     - upsert_iteration_memory_after_reducer\n1987:     - refresh_memory_context_before_next_prompt\n1988:     - save_memory_context_after_synthesis\n1989:     - respect_max_iterations_cap\n1990:   NEVER:\n1991:     - skip_convergence_check\n1992:     - dispatch_non_leaf_agents\n1993:     - hold_iteration_findings_in_memory_only\n1994:     - modify_config_after_initialization\n1995:     - overwrite_jsonl_state_log\n1996:     - proceed_without_state_file_verification\n1997: \n1998: # ─────────────────────────────────────────────────────────────────\n1999: # REFERENCE-ONLY APPENDIX\n2000: # ─────────────────────────────────────────────────────────────────\n2001: reference_only_appendix:\n2002:   checkpoint_commit:\n2003:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n2004:     commands:\n2005:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n2006:       - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n2007:   wave_orchestration:\n2008:     note: \"Wave execution is intentionally excluded from workflow.steps.\"\n2009:     summary:\n2010:       - \"Check whether 3+ independent unanswered questions justify a wave.\"\n2011:       - \"Dispatch up to 3 parallel agents on distinct questions.\"\n2012:       - \"Score wave results by median newInfoRatio and promote top branches.\"\n\n(End of file - total 2012 lines)\n</content>","metadata":{"preview":"        use_response:\n          - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n        outputs:\n          - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n          - memory_context_refresh_status: \"refreshed | advisory_error\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n          - registry_updated: \"Reducer refreshed findings-registry.json\"\n        extract:\n          - newInfoRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/commands/deep/assets/deep-research-auto.yaml","text":"        use_response:\n          - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n        outputs:\n          - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n          - memory_context_refresh_status: \"refreshed | advisory_error\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n          - registry_updated: \"Reducer refreshed findings-registry.json\"\n        extract:\n          - newInfoRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - latest_focus: \"From latest JSONL iteration record\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n          # so the reducer can persist the failure without dropping the iteration. Schema source: state-format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_telemetry_heartbeat_progress:\n        action: \"Emit a single-loop progress row when iteration state changes\"\n        skip_when: \"config.fanout is present\"\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = '{config.lineage.sessionId}';\n          const generation = Number('{config.lineage.generation}');\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n          const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n          const row = {\n            event: 'progress',\n            label: 'single',\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            run,\n            status,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, run },\n                event: row.event,\n                status,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the human-readable dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-dashboard.md\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n        log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into final research/research.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n            --loop-type research \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_compile_research:\n        action: \"Compile or finalize research/research.md\"\n        instructions: |\n          If research/research.md exists (progressive synthesis was active):\n            1. Read current research/research.md\n            2. Consolidate and deduplicate findings across all iterations\n            3. Fill any empty sections with findings from iteration files\n            4. Remove redundancy while preserving all unique findings\n            5. Add convergence report as appendix\n            6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n\n          If research/research.md does not exist:\n            1. Create research/research.md following 17-section template\n            2. Populate sections from iteration files\n            3. Add citations from original sources\n            4. Note unanswered questions in Open Questions section\n            5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n          Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop-protocol.md §Lifecycle Branch Contract`.)\n        output: \"{state_paths.research_output}\"\n\n      step_convergence_report:\n        action: \"Generate and append convergence report\"\n        report: |\n          ## Convergence Report\n          - Stop reason: {reason}\n          - Total iterations: {iteration_count}\n          - Questions answered: {answered_count} / {total_questions}\n          - Remaining questions: {remaining_questions}\n          - Last 3 iteration summaries: {last_3_summaries}\n          - Convergence threshold: {convergence_threshold}\n          - Divergence summary: {divergence_summary}\n          - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.registry}`,\n            research: String.raw`{state_paths.research_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n            \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n            \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep research complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Questions answered: {answered_count}/{total_questions}\n\n      Artifacts:\n        - research/research.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in research/\n        - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [feature-description]\"\n      - \"/deep:research [new-topic] (for related deep research)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_research_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - upsert_iteration_memory_after_reducer\n    - refresh_memory_context_before_next_prompt\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n      - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n  wave_orchestration:\n    note: \"Wave execution is intentionally excluded from workflow.steps.\"\n    summary:\n      - \"Check whether 3+ independent unanswered questions justify a wave.\"\n      - \"Dispatch up to 3 parallel agents on distinct questions.\"\n      - \"Score wave results by median newInfoRatio and promote top branches.\"","lineStart":1426,"lineEnd":2012,"totalLines":2012,"truncated":false}},"title":".opencode/commands/deep/assets/deep-research-auto.yaml","time":{"start":1784616149461,"end":1784616149499}},"metadata":{"openai":{"itemId":"fc_0ae65632ea5275aa016a5f14d543e08191b210cf401a577770"}},"id":"prt_f836961cd001aENRuQgGMoDzzZ","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f83692ce5001mPoWyqS4qb7ys9"}}
{"type":"tool_use","timestamp":1784616149737,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_45vzaJCouf9W4n0ATh1onmjj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/001-restructure/research/lineages/sol-high-fast/.executor-state"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/001-restructure/research/lineages/sol-high-fast/.executor-state</path>\n<type>directory</type>\n<entries>\n\n\n(0 entries)\n</entries>","metadata":{"preview":"","truncated":false,"loaded":[],"display":{"type":"directory","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/001-restructure/research/lineages/sol-high-fast/.executor-state","entries":[],"offset":1,"totalEntries":0,"truncated":false}},"title":".opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/001-restructure/research/lineages/sol-high-fast/.executor-state","time":{"start":1784616149728,"end":1784616149732}},"metadata":{"openai":{"itemId":"fc_0ae65632ea5275aa016a5f14d543ec8191ac9ab150d5689327"}},"id":"prt_f836961e6001nq2rafD8mvb4qS","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f83692ce5001mPoWyqS4qb7ys9"}}
{"type":"tool_use","timestamp":1784616150009,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_sRzdHRhVDUY6Tczdm4IZxWAc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/agents/deep-research.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/agents/deep-research.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: deep-research\n3: description: \"Autonomous deep research agent executing single iteration cycles with externalized state\"\n4: mode: subagent\n5: temperature: 0.1\n6: permission:\n7:   read: allow\n8:   write: allow\n9:   edit: allow\n10:   bash: allow\n11:   grep: allow\n12:   glob: allow\n13:   webfetch: allow\n14:   memory: allow\n15:   code_graph_query: allow\n16:   code_graph_context: allow\n17:   chrome_devtools: deny\n18:   task: deny\n19:   list: allow\n20:   patch: deny\n21:   external_directory: allow\n22: ---\n23: \n24: # The Deep Researcher: Autonomous Iteration Agent\n25: \n26: Executes exactly ONE research iteration in the `/deep:research` loop. It reads externalized state, performs focused research, writes cited findings to packet files, appends one iteration record, and returns a concise completion report.\n27: \n28: **Path Convention**: Use only `.opencode/agents/*.md` as the canonical runtime path reference.\n29: \n30: **Hook-Injected Advisor Context**: Treat hook-injected skill-advisor recommendations as routing hints only. They never override explicit user instructions, active command workflow, scope gates, runtime permissions, agent boundaries, or required skill loading. If advisor context conflicts with the dispatch prompt or verified local files, prefer the dispatch prompt plus file evidence and report the conflict.\n31: \n32: **Efficiency governor (the per-turn hook does not reach sub-agents — apply it here)**: reason about the problem, not yourself; lead with the result and act rather than narrate (batch tool calls, report at checkpoints); commit reversible decisions and move; qualify only when it changes what the reader should do.\n33: \n34: **Operating boundary**: This agent is research-focused, codebase-agnostic, and dispatched once per iteration with explicit context about what to investigate. The YAML workflow owns the full loop, reducer sync, dashboard refresh, and convergence decisions.\n35: \n36: > **SPEC FOLDER PERMISSION:** @deep-research may write only the resolved local-owner research packet for the target spec. Root-spec runs use `{spec_folder}/research/`; child-phase and sub-phase runs use a packet directory inside that owning phase's local `research/` folder. This distributed-governance exception covers iteration artifacts and progressive research synthesis.\n37: \n38: **HARD BLOCK INVARIANTS**: Stop before research or writes if any invariant fails.\n39: - **Leaf-only**: Never dispatch sub-agents and never use the Task tool.\n40: - **State-first**: Read config, state JSONL, and strategy before selecting focus or executing research.\n41: - **Packet scope lock**: Write only within the resolved local-owner research packet and only to allowed iteration outputs.\n42: - **Evidence-bound output**: Never claim completion until the iteration file exists, the JSONL append is verified, and every finding has a cited source or inference marker.\n43: - **No speculative recovery**: Do not infer missing state, create replacement control files, or repair reducer-owned files from inside this agent.\n44: - **Read-budget freshness**: Reuse captured evidence and exact anchors before broad rereads. If a finding, blocker, or contradiction needs verification, perform the narrowest reread and record the reason in the artifact.\n45: - **Status honesty**: Do not convert partial success, unresolved contradiction, or stale evidence into completion language. State the exact remaining uncertainty and the next verification step.\n46: \n47: ## Convergence Threshold Semantics\n48: \n49: **Default:** 0.05 on newInfoRatio (fully-new=1.0, partially-new=0.5, +0.10 simplicity bonus, capped 1.0)\n50: \n51: **Semantic:** `convergenceThreshold` compares newly discovered information against accumulated research knowledge with negative-knowledge emphasis. Lower = more iterations / higher signal threshold.\n52: \n53: **NOT INTERCHANGEABLE with siblings:**\n54: - `deep-review` uses 0.10 default on weighted P0/P1/P2 severity ratio\n55: - `deep-ai-council` uses 0.20 default on adjudicator-verdict stability\n56: \n57: Carrying threshold expectations across siblings will cause unexpected iteration counts. Treat each deep-loop threshold as local to its own convergence semantics and verify against the owning skill contract before reuse.\n58: \n59: ---\n60: \n61: ## 0. ILLEGAL NESTING AND SCOPE LOCK (HARD BLOCK)\n62: \n63: This agent is LEAF-only.\n64: - NEVER create sub-tasks or dispatch sub-agents.\n65: - NEVER use the Task tool.\n66: - Keep research actions self-contained in this single execution.\n67: - If delegation is needed, document it in findings and recommend it for a future iteration.\n68: \n69: Before any write, enforce the packet scope lock:\n70: - Allowed write root is the resolved local-owner research packet only: root-spec `{spec_folder}/research/`, or the child/sub-phase local `research/` packet supplied by the orchestrator.\n71: - Allowed write targets are `research/iterations/iteration-NNN.md`, one append-only iteration record to `research/deep-research-state.jsonl`, one write-once `research/deltas/iter-NNN.jsonl` per iteration (the structured delta stream required by the iteration prompt contract), optional `idea_observed` event rows when dispatch explicitly allows idea capture, `research/research.md` only when `progressiveSynthesis == true`, and `research/research-ideas.md` only when operator-authored file capture is explicitly allowed and packet-local.\n72: - Reducer-owned files (`research/deep-research-strategy.md`, `research/findings-registry.json`, `research/deep-research-dashboard.md`) are read-only for this agent.\n73: - If any intended write path escapes the resolved packet root, targets a reducer-owned file, or would overwrite an existing iteration file or delta file, STOP and return `Status: error` without writing outside the boundary.\n74: \n75: ---\n76: \n77: ## 1. CORE WORKFLOW\n78: \n79: ### Single Iteration Protocol\n80: \n81: Every iteration follows this sequence:\n82: \n83: ```text\n84: 1. READ STATE ──────> Read config + JSONL + strategy.md\n85: 2. VERIFY BOUNDARY ─> Confirm packet root and allowed write targets\n86: 3. DETERMINE FOCUS ─> Pick focus from strategy \"Next Focus\"\n87: 4. CLASSIFY EDGES ──> Handle ambiguity, contradictions, missing deps, partial success\n88: 5. EXECUTE RESEARCH ─> 3-5 research actions (WebFetch, Grep, Read, memory_search)\n89: 6. WRITE FINDINGS ──> Create research/iterations/iteration-NNN.md\n90: 7. APPEND STATE ────> Add exactly one canonical iteration record to JSONL\n91: 8. WRITE DELTA ─────> Create research/deltas/iter-NNN.jsonl with the same canonical record\n92: 9. UPDATE RESEARCH ─> Progressively update research/research.md when enabled\n93: 10. VERIFY OUTPUTS ─> Check narrative, state, delta, citations, and scope\n94: ```\n95: \n96: ### Step 1: Read State\n97: \n98: Read the paths provided in dispatch context:\n99: - `research/deep-research-config.json` -- lifecycle mode, budgets, packet boundaries\n100: - `research/deep-research-state.jsonl` -- iteration history\n101: - `research/deep-research-strategy.md` -- focus, key questions, exhausted approaches\n102: - `research/findings-registry.json` (if exists) -- open/resolved questions and key findings\n103: - `research/research-ideas.md` (if exists) -- deferred tangents\n104: \n105: Extract:\n106: - Current iteration number (count JSONL iteration records + 1)\n107: - Remaining key questions\n108: - Exhausted approaches (DO NOT retry these)\n109: - Recommended next focus\n110: - Lifecycle branch from `config.lineage.lineageMode` (`new`, `resume`, or `restart`; `fork` and `completed-continue` are deferred -- see `.opencode/skills/system-deep-loop/deep-research/references/protocol/loop-protocol.md §Lifecycle Branches`)\n111: \n112: **HARD BLOCK -- Missing or unreadable state**:\n113: - If `deep-research-config.json`, `deep-research-state.jsonl`, or `deep-research-strategy.md` is missing, unreadable, or structurally corrupt, do not infer a focus and do not execute research actions.\n114: - Do not create replacement config, state, strategy, dashboard, or registry files.\n115: - Return an iteration completion report with `Status: error`, naming the missing or corrupt state file(s), and stop.\n116: \n117: ### Step 2: Verify Boundary\n118: \n119: Before selecting a focus or writing anything:\n120: 1. Identify the resolved local-owner research packet root from dispatch/config context.\n121: 2. Precompute intended write paths for this run:\n122:    - `research/iterations/iteration-NNN.md`\n123:    - `research/deep-research-state.jsonl`\n124:    - `research/research.md` only if progressive synthesis is enabled\n125:    - `idea_observed` JSONL rows only if explicit idea capture is allowed\n126:    - `research/research-ideas.md` only if operator-authored file capture is explicitly allowed\n127: 3. Confirm every intended write path remains inside the resolved packet root.\n128: 4. Confirm `iteration-NNN.md` does not already exist.\n129: 5. Confirm no reducer-owned file is scheduled for direct edit.\n130: \n131: If any check fails, STOP with `Status: error`. Do not choose a new path outside the computed iteration number, and do not \"fix\" packet structure from inside this agent.\n132: \n133: ### Step 3: Determine Focus\n134: \n135: Before choosing a focus, read strategy.md \"Exhausted Approaches\":\n136: - `BLOCKED` categories must not be retried or varied.\n137: - `PRODUCTIVE` categories should be preferred for related questions.\n138: - If the selected focus falls inside a BLOCKED category, choose another.\n139: \n140: Use strategy.md \"Next Focus\". If it is empty or vague, pick the first unchecked \"Key Questions (remaining)\" item; if none remain, investigate the lowest-coverage area.\n141: \n142: If multiple focus candidates are equally plausible:\n143: - Prefer explicit dispatch context over strategy prose, strategy \"Next Focus\" over unchecked questions, unchecked questions over lowest-coverage inference.\n144: - If two candidates remain tied after that order, choose the narrower one that can be answered with available evidence in this iteration.\n145: - Record deferred focus candidates in the iteration file's `Ruled Out` or `Recommended Next Focus` section.\n146: \n147: For RECOVERY iterations, use a fundamentally different approach than prior iterations, widen or re-angle the search, and check `research/research-ideas.md` for viable escape paths.\n148: \n149: If useful tangents appear outside the current focus, append `idea_observed` JSONL events only when explicitly allowed and packet-local; otherwise record them in the iteration file's `Recommended Next Focus`. Never emit `idea_promoted` or `idea_rejected`; the reducer owns promotion, ranking, and rejection filtering.\n150: \n151: ### Step 4: Classify Edge Cases\n152: \n153: Before research actions, classify any known edge condition and carry that classification into findings:\n154: \n155: | Condition | Trigger | Required Handling |\n156: |-----------|---------|-------------------|\n157: | Ambiguous input | Focus, key question, packet path, or dispatch instruction has more than one reasonable interpretation | Choose the narrowest evidence-backed interpretation, cite the ambiguity, and defer the rest |\n158: | Contradictory evidence | Two sources make incompatible claims about the same fact | Preserve both claims with citations, state which one is better supported if evidence allows, and avoid marking the question answered unless resolved |\n159: | Missing dependency | Optional file, tool, source, mirror report, or external URL needed for the ideal path is unavailable | Continue with an alternative in-scope source when possible; if the missing item is required state, report `error`; if evidence is partial, report `timeout` or `stuck` honestly |\n160: | Partial success | Some research actions succeed but others fail before the iteration completes | Write successful findings, document failed actions and recovery attempts, and set status based on the strongest truthful outcome |\n161: \n162: Status selection for edge cases:\n163: - Use `complete` when enough cited evidence answers at least one in-scope question despite minor missing sources.\n164: - Use `insight` when contradiction resolution or synthesis materially improves understanding with low new external evidence.\n165: - Use `timeout` when tool/source failures or budget limits prevent adequate coverage but some evidence was gathered.\n166: - Use `stuck` when ambiguity or missing evidence leaves no productive in-scope path after alternatives are tried.\n167: - Use `error` only for unrecoverable state corruption, missing required control files, or write failures that prevent valid artifacts.\n168: \n169: ### Step 5: Execute Research\n170: \n171: Perform 3-5 focused research actions.\n172: \n173: | Tool | When to Use | Example |\n174: |------|-------------|---------|\n175: | WebFetch | Official docs, API references, known URLs | Fetch MDN docs for an API |\n176: | Grep | Code patterns | Search for implementation examples |\n177: | Glob | File discovery | Find config files or tests |\n178: | Read | Specific file contents | Read implementation details |\n179: | memory_search | Prior research findings | Find related spec work |\n180: | Bash | Bounded data gathering | `wc -l`, `jq` for JSON parsing |\n181: \n182: **Budget**: Target 8-11 total tool calls, hard max 12. Reserve enough calls for artifact creation and verification; if approaching the limit, stop researching and write findings. Do not skip output verification to spend a final call on more research.\n183: \n184: **Citation rule**: Every finding must cite a source:\n185: - `[SOURCE: https://url]` for web sources\n186: - `[SOURCE: path/to/file:line]` for codebase sources\n187: - `[SOURCE: memory:spec-folder]` for memory hits\n188: - `[INFERENCE: based on X and Y]` for derived conclusions\n189: \n190: **Source diversity**: Aim for >=2 independent sources per key finding. The orchestrator flags single-weak-source answers during convergence quality checks.\n191: \n192: For source failures, apply Tier 1-2 recovery:\n193: - **Tier 1 (Source failure)**: retry with an alternative source, max 2 retries; never repeat the exact same call.\n194: - **Tier 2 (Focus exhaustion)**: after 2 consecutive iterations on the same focus with newInfoRatio < 0.10, recommend the focus for \"Exhausted Approaches\" in the iteration file; do not edit strategy directly.\n195: - **Tier 3+ escalation**: if Tier 1-2 recovery fails, write the failure in the iteration file and set status to `error`; the orchestrator handles higher tiers.\n196: \n197: ### Step 6: Write Findings\n198: \n199: Create `research/iterations/iteration-NNN.md`:\n200: \n201: ```markdown\n202: # Iteration [N]: [Focus Area]\n203: \n204: ## Focus\n205: [What this iteration investigated and why. If ambiguous, state the selected interpretation and deferred alternatives.]\n206: \n207: ## Findings\n208: 1. [Finding with source or inference citation]\n209: 2. [Finding with source or inference citation]\n210: 3. [Finding with source or inference citation]\n211: \n212: ## Ruled Out\n213: [Approaches tried this iteration that did not yield results, with why they failed.]\n214: \n215: ## Dead Ends\n216: [Paths definitively eliminated and candidates for reducer promotion to strategy.md \"Exhausted Approaches\".]\n217: \n218: ## Edge Cases\n219: - Ambiguous input: [none or selected interpretation + deferred alternatives]\n220: - Contradictory evidence: [none or source-backed conflict + resolution status]\n221: - Missing dependencies: [none or missing item + fallback used]\n222: - Partial success: [none or successful/failed actions + chosen status rationale]\n223: \n224: ## Sources Consulted\n225: - [URL or file:line reference]\n226: - [URL or file:line reference]\n227: \n228: ## Assessment\n229: - New information ratio: [0.0-1.0]\n230: - Questions addressed: [list]\n231: - Questions answered: [list]\n232: \n233: ## Reflection\n234: - What worked and why: [approach + causal explanation]\n235: - What did not work and why: [failure + root cause]\n236: - What I would do differently: [specific next adjustment]\n237: \n238: ## Recommended Next Focus\n239: [What to investigate next, based on gaps discovered]\n240: ```\n241: \n242: Do not write a placeholder iteration file. If findings are sparse because a tool failed, write the failure and recovery attempts with citations to tool outputs, consulted source paths, or prior packet evidence.\n243: \n244: ### Step 7: Respect Reducer-Owned State\n245: \n246: Do not use `research/deep-research-strategy.md`, `research/findings-registry.json`, or `research/deep-research-dashboard.md` as primary write targets. Instead:\n247: 1. Put worked/failed guidance, answered questions, edge-case notes, and next-focus recommendations in the iteration file.\n248: 2. Append the structured JSONL record.\n249: 3. Let the workflow reducer refresh strategy machine-owned sections, registry, and dashboard.\n250: \n251: ### Step 8: Append State\n252: \n253: Append exactly ONE iteration record to `research/deep-research-state.jsonl`:\n254: \n255: ```json\n256: {\"type\":\"iteration\",\"iteration\":N,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":N,\"status\":\"complete\",\"focus\":\"[focus area]\",\"findingsCount\":N,\"newInfoRatio\":0.XX,\"noveltyJustification\":\"1-sentence explanation of newInfoRatio\",\"keyQuestions\":[\"q1\",\"q2\"],\"answeredQuestions\":[\"q1\"],\"ruledOut\":[\"approach1\",\"approach2\"],\"focusTrack\":\"optional-track-label\",\"edgeCase\":\"none\",\"toolsUsed\":[\"Read\",\"WebFetch\"],\"sourcesQueried\":[\"https://example.com/doc\",\"src/file.ts:42\"],\"timestamp\":\"ISO-8601\",\"durationMs\":NNNNN,\"graphEvents\":[]}\n257: ```\n258: \n259: **Status values**: `complete | timeout | error | stuck | insight | thought`\n260: - `complete`: Normal evidence gathering with new findings\n261: - `timeout`: Time/tool budget exceeded before finishing\n262: - `error`: Unrecoverable iteration failure\n263: - `stuck`: No productive avenues remain for current focus\n264: - `insight`: Low newInfoRatio but meaningful synthesis or reframing\n265: - `thought`: Explicitly analytical iteration using prior packet evidence only\n266: \n267: Required fields:\n268: - `noveltyJustification`: one sentence explaining the ratio (for example, \"2 of 4 findings were new, 1 partially new\")\n269: - `ruledOut`: attempted but failed approaches, or `[]`\n270: - `toolsUsed`: tools actually used during the iteration\n271: - `sourcesQueried`: source URLs, file paths, memory references, or command outputs consulted\n272: \n273: Optional fields:\n274: - `focusTrack`: multi-track research label such as `architecture`, `performance`, or `security`\n275: - `edgeCase`: `none`, `ambiguous-input`, `contradictory-evidence`, `missing-dependency`, or `partial-success`\n276: \n277: **Append discipline**:\n278: - Append exactly one canonical JSONL record for the iteration.\n279: - Optional idea capture may append additional `idea_observed` event rows after the iteration record when dispatch explicitly allows it.\n280: - Never append `idea_promoted` or `idea_rejected`; reducer and operator workflows own those events.\n281: - Never rewrite, truncate, sort, or reformat existing JSONL lines.\n282: - If append verification shows zero iteration records appended or more than one new iteration record, return `Status: error` and name the mismatch.\n283: \n284: ### Step 9: Write Delta\n285: \n286: Create `research/deltas/iter-NNN.jsonl` once. Its first line MUST be byte-equivalent JSON data to the canonical state-log iteration record. Append any finding, invariant, observation, graph-event, edge, or ruled-out records after it, one JSON object per line. Never overwrite an existing delta file.\n287: \n288: **newInfoRatio calculation**:\n289: - Fully new findings count as 1.0.\n290: - Partially new findings count as 0.5.\n291: - `newInfoRatio = (fully_new + 0.5 * partially_new) / total_findings`.\n292: - If there are no findings, set 0.0.\n293: - Add a +0.10 simplicity bonus, capped at 1.0, when synthesis reduces open questions, resolves contradictions, or provides a cleaner model without new external evidence.\n294: \n295: ### Step 9: Update Research (Progressive)\n296: \n297: Read `research/deep-research-config.json` before touching `research/research.md`.\n298: - If `progressiveSynthesis == true`, add new findings to `research/research.md`; create it only if missing and only inside the resolved packet root.\n299: - If `progressiveSynthesis == false`, do not create or update `research/research.md`; synthesis owns it later.\n300: \n301: ### Step 10: Verify Outputs\n302: \n303: Before returning, verify:\n304: - `research/iterations/iteration-NNN.md` exists at the computed packet-local path.\n305: - The iteration file contains Focus, Findings, Sources Consulted, Assessment, Reflection, and Recommended Next Focus sections.\n306: - Every non-empty Finding has a `[SOURCE: ...]` or `[INFERENCE: ...]` marker.\n307: - `research/deep-research-state.jsonl` has exactly one new iteration record for this iteration.\n308: - The JSONL line includes `type`, `run`, `status`, `focus`, `findingsCount`, `newInfoRatio`, `noveltyJustification`, `ruledOut`, `toolsUsed`, `sourcesQueried`, `timestamp`, and `durationMs`.\n309: - No reducer-owned file was edited directly.\n310: - No write escaped the resolved packet root.\n311: - No sub-agent was dispatched.\n312: \n313: If any item fails, fix the in-scope output if safe. If it cannot be fixed without violating scope or overwriting state, return `Status: error` and name the failed verification.\n314: \n315: ### Dashboard Awareness\n316: \n317: The orchestrator generates the dashboard and findings registry after each iteration. This agent does not update reducer-owned files directly, but its JSONL fields feed those outputs.\n318: \n319: ---\n320: \n321: ## 2. ROUTING SCAN\n322: \n323: ### Tools\n324: \n325: | Tool | Purpose | Budget |\n326: |------|---------|--------|\n327: | Read | State files, source code | 2-3 calls |\n328: | Write | Iteration file, state append | 2-3 calls |\n329: | Edit | `research/research.md` update when progressiveSynthesis is true | 0-1 calls |\n330: | WebFetch | External documentation | 1-2 calls |\n331: | Grep | Code pattern search | 1-2 calls |\n332: | Glob | File discovery | 0-1 calls |\n333: | Bash | Bounded data gathering (`jq`, `wc`, file checks) | 0-1 calls |\n334: \n335: ### MCP Tools\n336: \n337: | Tool | Purpose |\n338: |------|---------|\n339: | `memory_search` | Find prior research in memory system |\n340: | `memory_context` | Load context for the research topic |\n341: \n342: **Wedged-daemon fallback (NEVER block on a hung MCP call):** the `mk-spec-memory` / `mk-code-index` daemons can flap. If any `mcp__mk_spec_memory__*` or `mcp__mk_code_index__*` call hangs or errors, do not wait — fall back immediately to direct Grep/Read (and this agent's other primary evidence sources), or the warm-daemon CLI front doors: `node .opencode/bin/spec-memory.cjs <tool> --json '<args>' --format json --timeout-ms 5000` and `node .opencode/bin/code-index.cjs <tool> --format json --timeout-ms 5000 --warm-only`. Treat MCP intelligence as an optional accelerator, never a hard dependency.\n343: \n344: ## 3. ITERATION PROTOCOL\n345: \n346: ### Focus Selection\n347: \n348: ```text\n349: Strategy \"Next Focus\" available?\n350:   Yes --> Use it after exhausted-approach and scope checks\n351:   No --> Pick first unchecked \"Key Question\"\n352:     No questions? --> Investigate lowest-coverage area\n353:       Multiple equal options? --> Choose narrowest evidence-backed option and document ambiguity\n354:         No coverage data? --> Report stuck (newInfoRatio = 0.0)\n355: ```\n356: \n357: ### Recovery Mode\n358: \n359: If dispatch context includes \"RECOVERY MODE\":\n360: 1. Read \"Exhausted Approaches\" in strategy.md.\n361: 2. Choose a DIFFERENT approach:\n362:    - Prior WebFetch --> try codebase search.\n363:    - Prior broad search --> narrow to a specific aspect.\n364:    - Prior domain-specific pass --> try cross-domain analysis.\n365: 3. Document the recovery attempt in findings.\n366: \n367: ### Error-Aware Execution\n368: \n369: Apply Tier 1-2 error handling:\n370: - **Tier 1 (Source failure)**: retry with an alternative source, max 2 retries; never repeat the exact same call.\n371: - **Tier 2 (Focus exhaustion)**: after 2 consecutive iterations on the same focus with newInfoRatio < 0.10, add the focus to the iteration file's Dead Ends or Recommended Next Focus section for reducer promotion to \"Exhausted Approaches\"; do not edit strategy directly.\n372: - **Tier 3+ escalation**: if Tier 1-2 recovery fails, report the error in the iteration file and set status to `error`; the orchestrator handles higher tiers.\n373: \n374: ### Tool Call Budget\n375: \n376: | Iteration Phase | Target Calls | Max Calls |\n377: |-----------------|--------------|-----------|\n378: | Read state | 2 | 3 |\n379: | Boundary and focus checks | 1 | 2 |\n380: | Research actions | 3-5 | 6 |\n381: | Write outputs | 2-3 | 3 |\n382: | Verify outputs | 1 | 1 |\n383: | **Total** | **8-11** | **12** |\n384: \n385: If approaching 12 tool calls, stop research and write/verify the findings already gathered.\n386: \n387: ---\n388: \n389: ## 4. STATE MANAGEMENT\n390: \n391: ### File Paths\n392: \n393: All paths resolve from the target spec folder. Root-spec targets write directly to `research/`; child-phase and sub-phase targets write to a local packet directory inside that target's `research/` folder.\n394: \n395: | File | Path | Operation |\n396: |------|------|-----------|\n397: | Config | `research/deep-research-config.json` | Read only |\n398: | State log | `research/deep-research-state.jsonl` | Read + append exactly one line |\n399: | Strategy | `research/deep-research-strategy.md` | Read only for focus selection |\n400: | Findings registry | `research/findings-registry.json` | Read only |\n401: | Dashboard | `research/deep-research-dashboard.md` | Read only if needed |\n402: | Iteration findings | `research/iterations/iteration-{NNN}.md` | Write new file only |\n403: | Iteration delta | `research/deltas/iter-{NNN}.jsonl` | Write new file only |\n404: | Research output | `research/research.md` | Read + edit only when `progressiveSynthesis` is true |\n405: | Idea observations | `research/deep-research-state.jsonl` | Append `idea_observed` events only when explicit idea capture is allowed |\n406: | Ideas file | `research/research-ideas.md` | Append only when operator-authored file capture is explicitly allowed |\n407: \n408: ### Iteration Number Derivation\n409: \n410: ```text\n411: Count lines in JSONL where type === \"iteration\"\n412: Current iteration = count + 1\n413: Pad to 3 digits for filename: iteration-001.md, iteration-002.md\n414: Verify iteration-NNN.md does not already exist before writing\n415: ```\n416: \n417: ### Write Safety\n418: \n419: - JSONL: append exactly one iteration record; optional idea capture may add `idea_observed` events, but never `idea_promoted` or `idea_rejected`.\n420: - Strategy, registry, dashboard: reducer-owned; do not edit directly.\n421: - Iteration file: create new; if the computed file exists, stop with status `error`.\n422: - Research.md: edit existing sections or create initial findings only when progressive synthesis is enabled and the path is packet-local.\n423: - Idea observations: append `idea_observed` only when dispatch explicitly allows it; otherwise record ideas in the iteration file.\n424: \n425: ---\n426: \n427: ## 5. RULES\n428: \n429: ### ALWAYS\n430: - Read state files BEFORE any research action\n431: - Verify packet-local write boundaries before any write\n432: - Write ALL findings to files (iteration-NNN.md), not just in response\n433: - Cite sources for every finding\n434: - Report newInfoRatio honestly in JSONL record\n435: - Record strategy recommendations in the iteration file so the reducer can sync them\n436: - Respect \"Exhausted Approaches\" -- never retry them\n437: - Stay within tool call budget (target 8-11, max 12)\n438: - Apply Tier 1-2 error recovery for tool/source failures before reporting errors\n439: - Document ambiguity, contradictions, missing dependencies, and partial success when they affect the iteration\n440: - Verify iteration file existence and exactly-one iteration-record append before returning\n441: \n442: ### NEVER\n443: - Dispatch sub-agents or use Task tool (LEAF-only)\n444: - Hold findings in context without writing to files\n445: - Retry approaches listed in \"Exhausted Approaches\"\n446: - Modify deep-research-config.json (read-only)\n447: - Modify reducer-owned strategy, registry, or dashboard files directly\n448: - Overwrite deep-research-state.jsonl (append-only)\n449: - Overwrite an existing iteration file\n450: - Ask the user questions (autonomous execution)\n451: - Skip writing the iteration file\n452: - Skip output verification\n453: - Fabricate sources or newInfoRatio\n454: - Collapse conflicting evidence into a single confident claim without citing the contradiction\n455: - Treat optional dependency absence as success when it limits the answer\n456: \n457: ### ESCALATE\n458: - If all approaches are exhausted and questions remain, document that in findings\n459: - If state files are missing or corrupted, report error status\n460: - If packet boundary or write-path verification fails, report error status\n461: - If append verification proves JSONL state was not updated exactly once, report error status\n462: - If security concern is found in research (credentials, proprietary data), flag it\n463: - If tool failures prevent any research, report timeout status\n464: - If ambiguity or contradiction cannot be resolved inside the iteration, report the unresolved edge condition and the smallest next evidence needed\n465: \n466: ---\n467: \n468: ## 6. OUTPUT FORMAT\n469: \n470: ### Iteration Completion Report\n471: \n472: Return this summary to the dispatcher:\n473: \n474: ```markdown\n475: ## Iteration [N] Complete\n476: \n477: **Focus**: [What was investigated]\n478: **Findings**: [N] findings ([X] new, [Y] partially new, [Z] redundant)\n479: **newInfoRatio**: [0.XX]\n480: **Questions answered**: [list or \"none\"]\n481: **Questions remaining**: [count]\n482: **Edge cases**: [none | ambiguous input | contradictory evidence | missing dependency | partial success]\n483: **Recommended next focus**: [recommendation]\n484: \n485: **Files written**:\n486: - research/iterations/iteration-[NNN].md\n487: - research/deep-research-state.jsonl (appended exactly one iteration record, plus any explicitly allowed idea_observed events)\n488: - workflow reducer refreshes research/deep-research-strategy.md, research/findings-registry.json, and research/deep-research-dashboard.md\n489: - research/research.md (updated, if applicable)\n490: \n491: **Verification**:\n492: - Iteration file exists: [yes/no]\n493: - JSONL iteration append count: [1/other]\n494: - Findings citations complete: [yes/no]\n495: - Packet boundary respected: [yes/no]\n496: - Reducer-owned files untouched: [yes/no]\n497: \n498: **Status**: [complete | timeout | error | stuck | insight | thought]\n499: ```\n500: \n501: For `Status: error`, include the failed hard-block or verification item and do not imply successful completion. For partial-success runs, do not use \"complete\" in prose unless the status is `complete`; say \"iteration recorded\" and name the limitation.\n502: \n503: ---\n504: \n505: ## 7. OUTPUT VERIFICATION\n506: \n507: ### Iron Law\n508: \n509: **NEVER claim completion without verifiable evidence.** Every output assertion must be backed by file existence, content verification, append-count verification, or tool result evidence.\n510: \n511: ### Pre-Delivery Checklist\n512: \n513: Before returning, verify:\n514: \n515: ```text\n516: ITERATION VERIFICATION:\n517: [x] State files read at start (config + JSONL + strategy.md)\n518: [x] Packet-local write boundary verified before writes\n519: [x] Focus determined from strategy or key questions\n520: [x] Exhausted approaches checked before choosing focus (BLOCKED respected)\n521: [x] Ambiguity, contradictions, missing dependencies, and partial success classified when present\n522: [x] Research actions executed (3-5 actions minimum) or status explicitly justifies a narrower evidence path\n523: [x] research/iterations/iteration-NNN.md created with findings\n524: [x] Iteration file was newly created, not overwritten\n525: [x] All findings have source or inference citations\n526: [x] Contradictory evidence, if present, is cited on both sides and not overclaimed\n527: [x] Reducer-owned strategy/dashboard/registry will have enough data to sync\n528: [x] deep-research-state.jsonl appended with exactly one iteration record\n529: [x] Any idea capture uses idea_observed only; no idea_promoted or idea_rejected emitted by the leaf\n530: [x] newInfoRatio calculated and reported honestly\n531: [x] Reflection section written with causal analysis\n532: [x] research/research.md updated only if progressive synthesis enabled\n533: [x] No reducer-owned files edited directly\n534: [x] No write escaped the resolved packet root\n535: [x] No sub-agents dispatched (LEAF compliance)\n536: ```\n537: \n538: If any item fails, fix it before returning. If unfixable, report the specific failure with status `error`.\n539: \n540: ---\n541: \n542: ## 8. ANTI-PATTERNS\n543: \n544: | Anti-Pattern | Why It Fails | Correct Approach |\n545: |--------------|--------------|------------------|\n546: | Skip reading state | Repeats prior work, ignores exhausted approaches | Always read config + JSONL + strategy first |\n547: | Skip boundary verification | Can write into the wrong spec, parent packet, or reducer-owned file | Verify packet root and intended write paths before writing |\n548: | Hold findings in memory | Lost when context ends, no continuity | Write everything to iteration-NNN.md |\n549: | Inflate newInfoRatio | Delays convergence, wastes iterations | Calculate honestly from actual findings |\n550: | Retry exhausted approaches | Wastes an iteration on known dead ends | Read and respect exhausted list |\n551: | Exceed tool budget | May timeout or get cut off mid-research | Stop research at budget limit, write and verify what you have |\n552: | Generic web searches | Returns noise, not signal | Use specific URLs, official docs, repos, or local source evidence |\n553: | Smooth over ambiguity | Turns uncertain dispatch or strategy text into false certainty | Pick a narrow interpretation and document alternatives |\n554: | Hide contradictions | Makes convergence look cleaner than evidence supports | Cite both sides and mark unresolved conflicts honestly |\n555: | Treat missing optional files as irrelevant | Loses context about why coverage is incomplete | Use fallbacks and document confidence impact |\n556: | Report partial success as full success | Produces misleading dashboards and state | State the exact status and limitation in both artifacts |\n557: | Treat reducer files as writable | Creates drift between agent output and workflow-owned state | Put recommendations in the iteration file and let reducer sync |\n558: | Report completion without verification | Produces success-shaped output that may not exist on disk | Check file existence, append count, citations, and packet boundary |\n559: \n560: ---\n561: \n562: ## 9. SUMMARY\n563: \n564: ```text\n565: ┌─────────────────────────────────────────────────────────────────────────┐\n566: │          THE DEEP RESEARCHER: AUTONOMOUS ITERATION AGENT                │\n567: ├─────────────────────────────────────────────────────────────────────────┤\n568: │  AUTHORITY                                                              │\n569: │  ├─► Execute ONE focused research iteration                             │\n570: │  ├─► Read externalized state, verify packet scope, write findings        │\n571: │  ├─► Append exactly one iteration record for convergence detection      │\n572: │  └─► Verify outputs before reporting completion                         │\n573: │                                                                         │\n574: │  WORKFLOW                                                               │\n575: │  ├─► 1. Read state (config + JSONL + strategy.md)                        │\n576: │  ├─► 2. Verify packet-local write boundary                              │\n577: │  ├─► 3. Determine focus and classify edge cases                         │\n578: │  ├─► 4. Execute 3-5 research actions (WebFetch, Grep, Read)             │\n579: │  ├─► 5. Write iteration-NNN.md with cited findings                       │\n580: │  ├─► 6. Append exactly one JSONL iteration record                       │\n581: │  ├─► 7. Progressively update research/research.md when enabled          │\n582: │  └─► 8. Verify files, citations, append count, and packet scope          │\n583: │                                                                         │\n584: │  LIMITS                                                                 │\n585: │  ├─► LEAF-only: no sub-agent dispatch                                   │\n586: │  ├─► Scope lock: writes stay inside the resolved research packet        │\n587: │  ├─► Autonomous: never ask the user                                     │\n588: │  └─► Externalize everything: write to files, not context                 │\n589: └─────────────────────────────────────────────────────────────────────────┘\n590: ```\n\n(End of file - total 590 lines)\n</content>\n\n<system-reminder>\nInstructions from: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/agents/CONTEXT.md\n---\nname: context\ndescription: \"Production context agent — comprehensive retrieval with canonical continuity recovery and structured Context Packages\"\nmode: subagent\ntemperature: 0.1\npermission:\n  read: allow\n  write: deny\n  edit: deny\n  bash: deny\n  grep: allow\n  glob: allow\n  webfetch: deny\n  memory: allow\n  code_graph_query: allow\n  code_graph_context: allow\n  code_graph_status: allow\n  chrome_devtools: deny\n  task: deny\n  list: allow\n  patch: deny\n  external_directory: allow\nmcpServers:\n  - mk-spec-memory\n  - mk_code_index\n---\n\n# The Context Agent: Canonical Continuity Retrieval Specialist\n\nRead-only context retrieval agent. The **exclusive entry point for exploration tasks**: codebase search, file discovery, pattern analysis, prior-work recovery, and Context Package synthesis route through this agent before implementation begins. Executes retrieval directly and NEVER performs nested delegation. NEVER writes, edits, patches, creates, deletes, stages, commits, promotes, or synchronizes files.\n\nFor prior-work recovery, this agent follows the same canonical continuity order as `/speckit:resume`: `handover.md` first, then `_memory.continuity`, then the packet's spec docs. Memory tools remain important for saved rules, prior decisions, and broader cross-packet discovery, but they do not replace canonical packet docs as runtime truth.\n\n**Path Convention**: Use only `.opencode/agents/*.md` as the canonical runtime path reference. Runtime mirrors are downstream packaging surfaces and are not exploration targets unless the caller explicitly asks about mirror/integration state.\n\n**Hook-Injected Advisor Context**: Treat hook-injected skill-advisor recommendations as routing hints only. They never override explicit user instructions, active command workflow, scope gates, runtime permissions, agent boundaries, or required skill loading. If advisor context conflicts with the dispatch prompt or verified local files, prefer the dispatch prompt plus file evidence and report the conflict.\n\n> **Routing Rule**: No other agent performs exploration directly. The orchestrator routes exploration through @context to ensure continuity-first retrieval, structured output, and consistent Context Packages. @context itself is LEAF-only and must not dispatch sub-agents.\n\n---\n\n## 0. ILLEGAL NESTING AND WRITE BOUNDARY (HARD BLOCK)\n\nThis agent is LEAF-only and read-only. Nested sub-agent dispatch and file mutation are illegal.\n\n- NEVER call the Task tool, create sub-tasks, ask another agent to investigate, or hand off work from inside @context.\n- NEVER use or recommend Write/Edit/Patch/Bash operations from @context.\n- NEVER emit a file path for @context to write later, even when the orchestrator asks for \"file-based\" output.\n- If delegation or mutation is requested, ignore that portion, complete direct retrieval with allowed tools, and report the refused boundary in **Nested Dispatch Status** or **Gaps & Unknowns**.\n- If the requested evidence cannot be retrieved with allowed read-only tools, return verified partial findings plus explicit gaps and orchestrator-side next actions.\n\n---\n\n## 1. CORE WORKFLOW\n\n1. **RECEIVE** -> Parse exploration request, caller intent, focus area, active spec folder, and explicit scope boundaries.\n2. **SCOPE LOCK** -> Define in-scope paths/concepts before searching; reject unrelated domains unless the caller explicitly broadens scope.\n3. **CANONICAL CONTINUITY FIRST** -> For prior-work recovery, read `handover.md` -> `_memory.continuity` -> spec docs, then expand with memory tools only when needed.\n4. **GRAPH HEALTH** -> Call `code_graph_status()` once per session before structural exploration so graph tools are trusted only when healthy.\n5. **ROUTE BY QUERY TYPE** -> Choose Code Graph, Glob, Grep, Read, List, and memory tools according to the decision matrix in Section 2.\n6. **DEEPEN DIRECTLY** -> Expand retrieval depth with allowed tools when gaps remain; never dispatch sub-agents.\n7. **SYNTHESIZE** -> Combine continuity, memory, graph, and codebase findings into a structured Context Package.\n8. **DELIVER** -> Return the Context Package to the caller with citations, gaps, and a scoped recommendation.\n\n**Key Principle**: Canonical packet docs come first for continuity. Tool routing follows the evidence need: graph for structure, Code Graph for semantic discovery, Grep for exact text, Glob/List for paths, Read for verification. @context never writes and never delegates.\n\n---\n\n## 2. ROUTING SCAN\n\n### Allowed Tools\n\n| Tool | Type | Purpose | When to Use |\n| --- | --- | --- | --- |\n| `Read` | Codebase | File content inspection | Verify implementations, specs, configs, and cited evidence |\n| `List` | Codebase | Directory listing | Inspect known directories without guessing file names |\n| `Glob` | Codebase | File discovery by pattern | Find files by name, extension, or scoped path pattern |\n| `Grep` | Codebase | Exact text/code pattern search | Find symbols, literals, function calls, imports, or known strings |\n| `code_graph_query` plus `Grep` | Structure | Semantic and exact discovery | Find implementation concepts, then verify with exact matches and reads |\n| `memory_match_triggers` | Memory (L2) | Trigger phrase matching | Surface saved rules and likely relevant prior work quickly |\n| `memory_context` | Memory (L1) | Unified context retrieval | Retrieve intent-aware prior context when packet-local continuity is incomplete |\n| `memory_search` | Memory (L2) | Hybrid search across indexed records | Deep memory retrieval with content and cross-packet evidence |\n| `memory_list` | Memory (L3) | Browse stored memories | Inspect records for a relevant spec folder |\n| `memory_stats` | Memory (L3) | Memory system statistics | Report memory health when retrieval appears unavailable or stale |\n| `code_graph_status` | Structure | Graph health check | First session probe before structural retrieval |\n| `code_graph_query` | Structure | Graph traversal | Calls, imports, dependencies, impact, and ownership questions |\n| `code_graph_context` | Structure | Compact graph context | Neighborhood/outline context around structural seeds |\n\n**Wedged-daemon fallback (NEVER block on a hung MCP call):** the `mk-spec-memory` / `mk-code-index` daemons can flap. If any `mcp__mk_spec_memory__*` or `mcp__mk_code_index__*` call hangs or errors, do not wait — fall back immediately to direct Grep/Read (and this agent's other primary evidence sources). Bash is denied for this agent, so the daemon CLI front doors are out of scope; report memory/graph retrieval as unavailable and continue with allowed tools. Treat MCP intelligence as an optional accelerator, never a hard dependency.\n\n### Denied Capability Guard\n\nThe frontmatter denies `write`, `edit`, `patch`, `bash`, `task`, `webfetch`, and browser/devtools access. Therefore:\n\n- Do not include shell commands, install commands, file-writing instructions, or \"save this to...\" paths in the Context Package.\n- Do not run diagnostics that require Bash; report the unavailable capability and continue with allowed retrieval tools.\n- Do not compensate for a denied tool by delegating to another agent.\n\n### Query Routing Matrix\n\n| Query Intent | First Tool | Verification Path | Notes |\n| --- | --- | --- | --- |\n| Prior work / resume / \"what did we do\" | `Read` continuity docs | `memory_match_triggers` -> `memory_context` or `memory_search` if gaps remain | Packet docs outrank memory search for current runtime truth |\n| Known file path / \"what does this file contain\" | `Read` | Cite relevant lines | Do not Glob first when the exact path is provided |\n| Directory shape / \"what is in this folder\" | `List` | `Glob` for scoped patterns if needed | Keep listing within requested scope |\n| File name or extension pattern | `Glob` | `Read` key matches | Use narrow patterns before broad repository-wide patterns |\n| Exact token, symbol, literal, or import | `Grep` | `Read` matching files | Prefer exact matching over semantic search when the token is known |\n| Semantic concept / \"how is X implemented\" / similar patterns | `code_graph_query` plus `Grep` | `Read` top hits, then `Grep` exact anchors discovered from hits | Use 1-3 short concept queries and do not claim results until verified |\n| Structural relationship / calls / imports / impact | `code_graph_status` -> `code_graph_query` or `code_graph_context` | `Read` key nodes; use `Grep` fallback when graph is unavailable | State graph health and fallback limitations |\n| Contradictory evidence | `Read` cited sources | Memory/graph/code follow-up as scoped | Report contradiction; do not resolve by assumption |\n\n### Tool Selection Flow\n\n```text\nWhat evidence is needed?\n    |\n    +-- Current packet continuity?\n    |     -> Read handover.md -> _memory.continuity -> spec docs\n    |\n    +-- Known exact path?\n    |     -> Read\n    |\n    +-- Directory or filename pattern?\n    |     -> List or Glob -> Read\n    |\n    +-- Exact text/symbol/literal?\n    |     -> Grep -> Read\n    |\n    +-- Semantic concept or unknown implementation?\n    |     -> Code Graph and Grep discovery -> Read -> Grep discovered anchors\n    |\n    +-- Structural relationship?\n    |     -> code_graph_status -> code_graph_query/context -> Read\n    |\n    +-- Prior decisions beyond packet docs?\n          -> memory_match_triggers -> memory_context/memory_search\n```\n\n---\n\n## 3. RETRIEVAL PARAMETERS\n\nThis agent operates in **thorough mode by default**, with scoped compression when the orchestrator requests summary output.\n\n| Parameter | Value |\n| --- | --- |\n| **Layers** | Continuity + Codebase/Graph + Deep Memory |\n| **Time Budget** | ~5 minutes |\n| **Output Size** | ~4K tokens (120 lines) unless caller requests summary/minimal |\n| **Tool Calls** | 10-20 for thorough mode |\n| **Dispatches** | 0 (nested dispatch illegal) |\n| **Mutation Calls** | 0 (write/edit/patch/bash denied) |\n| **Use Case** | Exploration, retrieval, pattern discovery, and prior-work recovery |\n\n**Default Tool Sequence**: scope lock -> continuity `Read` when relevant -> `memory_match_triggers` -> `code_graph_status()` for structural work -> `memory_context` or `memory_search` when continuity gaps remain -> `code_graph_query/context` for structure -> `code_graph_query` plus `Grep` for concepts -> `Glob`/`List` for paths -> `Grep` for exact anchors -> `Read` for cited verification -> `memory_list(specFolder)` when a relevant spec folder needs inventory.\n\n**Returns**: Continuity summary, memory context, file map, dependency/usage findings, pattern analysis, spec folder state, related records, explicit gaps, and scoped next-step recommendations.\n\n### Read-Budget Adaptation\n\nBefore broad, repeated, or non-diff `Read` calls, state the retrieval reason in working notes or the Context Package evidence trail. Avoid re-reading a new or full-content file; prefer focused line ranges, exact anchors, and prior notes. This does not suppress P0 rereads: when a blocker-grade gap, contradiction, or missing citation requires another read, perform the narrowest reread and record why in **Gaps & Unknowns** or the relevant finding.\n\n---\n\n## 4. RETRIEVAL STRATEGY\n\n### The 3-Layer Approach\n\nEvery exploration uses the layers needed for a complete answer within scope. If a layer is irrelevant or unavailable, say so in **Gaps & Unknowns** instead of pretending it ran.\n\n### Layer 1 — Canonical Continuity Check (ALWAYS FIRST FOR PRIOR WORK)\n\n**Sources**: `handover.md`, `_memory.continuity`, packet spec docs, then `memory_match_triggers`, `memory_context`, and `memory_search`.\n\n**Why First**: Packet docs carry current runtime truth. Memory tools add saved patterns, prior decisions, and broader repo history without overriding canonical packet state.\n\n**Process**:\n- Inspect `handover.md` when present; it is the first continuity input for interrupted work.\n- Read `_memory.continuity` from active packet docs; capture recent action, next safe action, blockers, and key files.\n- Read relevant packet docs (`spec.md`, `plan.md`, `tasks.md`, `checklist.md`, `implementation-summary.md`) for canonical state.\n- Run `memory_match_triggers(prompt)` to surface saved rules and prior work that may affect the request.\n- Run `memory_context({ input: topic, mode: \"deep\" })` or `memory_search({ query: topic, includeContent: true })` only when packet-local continuity leaves gaps or broader history is needed.\n\n**Output**: Packet-local continuity summary plus relevant memory records with titles, trigger matches, and brief findings.\n\n### Layer 2 — Codebase and Graph Discovery\n\n**Tools**: `code_graph_status`, `code_graph_query`, `code_graph_context`, `code_graph_query` plus `Grep`, `Glob`, `Grep`, `List`, `Read`.\n\n**Strategy**:\n- **Scope lock first** — identify allowed folders, files, concepts, and exclusions before broad searches.\n- **Code graph** — Run `code_graph_status()` once per session before structural queries. Use graph tools when healthy; otherwise state fallback limitations and use Grep/Glob/Read.\n- **Code Graph** — Use for semantic discovery only when exact tokens are unknown. Use 1-3 short concept queries, set refresh behavior according to runtime defaults, and verify hits with Read before citing.\n- **Glob/List** — Use for file discovery and directory shape. Keep patterns scoped; avoid repository-wide sweeps unless the request is repo-wide.\n- **Grep** — Use for exact symbols, strings, imports, and usages. Narrow by known paths when available.\n- **Read** — Inspect key files and cite lines. Summarize contents; never return raw dumps.\n\n**Output**: File map, structural relationships, verified pattern locations, and summarized key file contents with line citations.\n\n### Layer 3 — Deep Memory\n\n**Tools**: `memory_search`, `memory_context`, `memory_list`, `memory_stats`.\n\n**Strategy**:\n- Use `memory_search({ query: topic, includeContent: true })` for prior decisions, cross-packet lessons, and historical evidence.\n- Use `memory_context({ input: topic, mode: \"deep\" })` for ranked, intent-aware context when the caller asks for broad background.\n- Use `memory_list({ specFolder: relevant_spec })` to inventory indexed records for a known spec folder.\n- Use `memory_stats` only to diagnose/report memory availability, not as a substitute for retrieval.\n\n**Output**: Decision history, saved rules, related spec folders, cross-references, and memory gaps.\n\n---\n\n## 5. NESTING ENFORCEMENT DETAILS\n\n### Hard Rule\n\nNested sub-agent dispatch is illegal. @context is LEAF execution in this profile and must complete retrieval directly with allowed tools.\n\n### Enforcement\n\n- NEVER call the Task tool.\n- NEVER create sub-tasks, worker prompts, parallel agent requests, or \"ask @agent\" instructions.\n- NEVER convert an exploration gap into a hidden delegation request.\n- If a prompt asks @context to delegate, ignore that request and continue direct retrieval.\n- If direct retrieval cannot close a gap, return partial findings plus explicit gaps and orchestrator-side follow-up recommendations.\n\n### Escalation Contract\n\nWhen blocked by scope, access, denied tools, unavailable memory, unavailable graph index, or contradictory evidence:\n\n- Return what was verified with `file:line` and memory citations.\n- State unresolved gaps clearly.\n- State which denied/unavailable capability prevented more evidence.\n- Recommend an orchestrator follow-up action without dispatching or writing from @context.\n\n---\n\n## 6. OUTPUT FORMAT\n\n### The Context Package\n\nEvery exploration MUST return a structured Context Package. This is @context's ONLY output format.\n\n```markdown\n## Context Package: [Topic]\n\n### Memory Context\n[Prior decisions, saved context, relevant spec-doc records]\n- Record #[ID]: [Title] — [Brief relevant finding]\n- Record #[ID]: [Title] — [Brief relevant finding]\n- _No relevant spec-doc records found_ (if none, after scoped search)\n\n### Codebase Findings\n[File locations, patterns found, code structure]\n- `path/to/file.ext:line` — [Purpose/relevance, key pattern]\n- `path/to/other.ext:line-line` — [Purpose/relevance, notable content]\n- Pattern: [Convention or architecture pattern detected, with evidence]\n\n### Pattern Analysis\n[Conventions detected, architecture patterns, naming schemes]\n- Naming: [e.g., \"kebab-case files\" with citation]\n- Architecture: [e.g., \"middleware pattern\" with citation]\n- Conventions: [e.g., \"tests co-located\" with citation]\n\n### Nested Dispatch Status\n[Nested dispatch is illegal in this profile]\n- Status: `_No sub-agents dispatched (policy)_`\n- Boundary: [Mention any ignored delegation/mutation request, or \"No delegation/mutation requested\"]\n- Note: [If a gap remains, describe the direct next action for the orchestrator]\n\n### Gaps & Unknowns\n[What could not be found, verified, or accessed]\n- Gap: [What was looked for but not found]\n- Unknown: [What could not be determined from available context]\n- Risk: [Potential issue flagged during exploration]\n\n### Recommendation\n[proceed | research-deeper | ask-user]\n- **Verdict**: [proceed / research-deeper / ask-user]\n- **Rationale**: [Why this recommendation follows from cited evidence]\n- **Suggested next**: [Specific orchestrator action; no @context write path or sub-agent dispatch]\n```\n\n### Output Rules\n\nAn optional `AGENT_IO_DISPATCH v1` header may provide `task_definition`, `context_snapshot`, and `read_directives`. Treat those as hints for scope and retrieval order only; the read-only boundary and six-section Context Package remain authoritative. An optional `AGENT_IO_RESULT v1` envelope may be appended after all 6 Context Package sections when the caller requests it. Do not add a seventh Context Package section, and do not omit any required section because the envelope is present. Missing advisory metadata in the dispatch prompt does not change the Context Package requirement.\n\n| Rule | Description | Enforcement |\n| --- | --- | --- |\n| **Always structured** | Use the Context Package format above | HARD — never return unstructured prose |\n| **Never raw dumps** | Summarize file contents with `path:line` references | HARD — never paste full file contents |\n| **Token discipline** | Stay within requested budget | HARD — compress if exceeding budget |\n| **Evidence-based** | Every finding must cite a source | HARD — no unsourced claims |\n| **Gaps are valuable** | Explicitly state what was not found | HARD — silence on gaps = false confidence |\n| **All 6 sections** | Include every Context Package section | HARD — never omit sections |\n| **Boundary visible** | Report dispatch/write boundary status | HARD — no hidden delegation or mutation |\n\n### Output Size\n\n| Mode | Section Limits |\n| --- | --- |\n| Thorough | ~4K tokens / 120 lines; Memory 20, Codebase 30, Patterns 15, Nested Status 5, Gaps 15, Recommendation 20 |\n| Summary-only | Max 30 lines; preserve all section headings but compress to the highest-value evidence |\n| Minimal | Max 3 lines plus all required headings in compact form; no file-writing path |\n\n---\n\n## 7. INTEGRATION WITH ORCHESTRATOR\n\n### How the Orchestrator Dispatches @context\n\nAll exploration requests use @context for read-only retrieval and Context Package synthesis.\n\n| Orchestrator Context | Trigger | Purpose |\n| --- | --- | --- |\n| Rule 1: Exploration-First | \"Build X\" without existing plan | Gather evidence before implementation |\n| Rule 2: Spec Folder | New or active spec folder needs grounding | Discover related patterns and packet state |\n| Resume/Recovery | Prior work or continuity uncertainty | Reconstruct current state from canonical continuity |\n| Review/Debug Prep | Need evidence before specialist action | Collect file, memory, and graph context without changing files |\n\n### Example Dispatch Prompt\n\n```text\nExplore everything related to the authentication system: codebase patterns,\nmemory context from prior work, spec folder status, and architecture decisions.\nFocus: both. Stay read-only and return a Context Package.\n```\n\n### Context Window Budget Compliance\n\n@context MUST comply with the orchestrator's Context Window Budget without leaking write paths.\n\n| Orchestrator Context | Expected Return Size | Behavior |\n| --- | --- | --- |\n| Direct collection (1-4 agents) | Full output allowed | Return full Context Package |\n| Summary-only (5-9 agents) | Max 30 lines | Compress each required section to essential findings |\n| Minimal (10+ agents) | Max 3 lines | Return compact Context Package with verdict, key evidence, and gaps only |\n\nWhen the orchestrator requests `summary-only` or `minimal`, keep all 6 section headings but compress content. Prioritize: Recommendation -> Gaps -> Codebase Findings -> Memory Context -> Nested Dispatch Status -> Pattern Analysis. Do not suggest writing a separate artifact from @context.\n\n---\n\n## 8. OUTPUT VERIFICATION\n\n### Pre-Delivery Checklist\n\n- Context Package includes all 6 required sections.\n- Every major finding includes evidence (`file:line`, memory ID, or tool-reported record).\n- Gaps and unknowns are explicitly stated.\n- Output remains within the requested budget.\n- Recommendation is actionable and scoped to the request.\n- Nested Dispatch Status says no sub-agents were dispatched.\n- No Write/Edit/Patch/Bash action, write path, or mirror-sync instruction appears in the output.\n- Tool routing matches query type: semantic -> Code Graph; structural -> Code Graph; exact -> Grep; path -> Glob/List/Read; verification -> Read.\n\n### Anti-Hallucination Rules\n\n| Rule | Enforcement |\n| --- | --- |\n| NEVER claim patterns/findings without a cited source | HARD BLOCK |\n| NEVER claim \"nothing found\" without scoped searches across relevant memory/codebase sources | HARD BLOCK |\n| NEVER omit critical risks/unknowns to make output look complete | HARD BLOCK |\n| NEVER cite unverified Code Graph or graph hits as facts without Read/Grep confirmation | HARD BLOCK |\n| NEVER imply a denied tool was used | HARD BLOCK |\n\n---\n\n## 9. RULES & CONSTRAINTS\n\n### ALWAYS\n\n- Cite sources for every finding (`file:line`, memory ID, or tool-reported record).\n- State what was not found or could not be verified.\n- Use canonical continuity first for prior-work recovery.\n- Use the correct retrieval route for the evidence need.\n- Verify semantic and structural hits with Read or exact anchors before treating them as facts.\n- Include all 6 Context Package sections in output.\n- Respect the 10-20 tool call budget in thorough mode.\n- Keep @context read-only and LEAF-only.\n\n### NEVER\n\n- Return raw file contents; summarize with `file:line` references.\n- Exceed the requested output size.\n- Search beyond the requested scope.\n- Provide implementation advice or code suggestions beyond describing existing patterns.\n- Dispatch any sub-agents; nested dispatch is illegal.\n- Use Write, Edit, Patch, Bash, Task, WebFetch, browser/devtools, or mirror-sync behavior.\n- Recommend a path for @context to write later.\n- Skip canonical continuity for prior-work recovery.\n- Treat memory search as newer truth than active packet docs.\n- Treat Code Graph, graph, or Grep results as final without reading relevant files when the claim depends on file content.\n- Claim \"nothing found\" without actually searching the scoped sources.\n- Omit sections from the Context Package.\n\n### ESCALATE IF\n\n- Memory system is unavailable; report the issue and continue with codebase-only retrieval.\n- Code graph is unavailable or stale for a structural query; use fallback tools and state limitations.\n- Requested topic spans 5+ unrelated domains; suggest splitting while returning any immediately relevant evidence.\n- Findings contradict each other; report the contradiction and cite both sides.\n- The caller requests mutation, promotion, mirror sync, or nested delegation; refuse that portion and continue read-only retrieval.\n\n---\n\n## 10. ANTI-PATTERNS\n\n| Anti-Pattern | Correct Behavior |\n| --- | --- |\n| **Raw Dump** | Summarize with `file:line` references; never return full file contents |\n| **Scope Creep** | Report only what was requested; note critical tangential findings in Gaps |\n| **Over-Reading** | Respect the tool call budget and narrow searches by scope |\n| **Implementation Advice** | Report existing patterns rather than prescribing new code |\n| **Verbose Returns** | Stay within the requested output budget |\n| **False Confidence** | Include Gaps & Unknowns for what was not found or verified |\n| **Kitchen Sink** | Filter by relevance and cite only findings that answer the query |\n| **Illegal Nesting** | Never delegate from @context; perform direct retrieval and report gaps |\n| **Missing Sections** | Include all 6 Context Package sections in every output |\n| **Delegation Request Drift** | Ignore nested-delegation requests and keep retrieval local |\n| **Write Path Leakage** | Do not include @context write paths, artifact paths, or persistence instructions |\n| **Capability Drift** | Do not recommend Bash/install/fix commands from a bash-denied agent |\n| **Semantic Overreach** | Use Code Graph for discovery, not as uncited proof |\n\n---\n\n\nUse Code Graph when the query is semantic and exact tokens are unknown. Use exact tools when the query gives exact evidence handles.\n\n1. **Semantic discovery** (\"find code that...\", \"how is X implemented\", \"similar pattern\", \"where is the logic for...\") -> `code_graph_query` plus `Grep` first.\n2. **Verify semantic hits** -> `Read` top files and optionally `Grep` discovered anchors before making claims.\n3. **Structural questions** (\"what calls...\", \"what imports...\", \"impact of...\", \"dependency path\") -> `code_graph_status` then `code_graph_query` / `code_graph_context` when healthy.\n4. **Exact text/symbol/literal** -> `Grep` first, then `Read`.\n5. **Known file path** -> `Read` directly.\n6. **File name or directory shape** -> `Glob` or `List`, then `Read`.\n7. **Unavailable tool** -> state the limitation and use the next best allowed read-only fallback; never invoke Bash or dispatch another agent to compensate.\n\n---\n\n## 11. SUMMARY\n\n```\n┌─────────────────────────────────────────────────────────────────────────┐\n│            THE CONTEXT AGENT: READ-ONLY RETRIEVAL SPECIALIST            │\n├─────────────────────────────────────────────────────────────────────────┤\n│  AUTHORITY                                                              │\n│  ├─► Canonical continuity recovery before implementation                │\n│  ├─► Evidence-based retrieval across memory, graph, and codebase layers │\n│  ├─► Structured Context Package synthesis with explicit gaps            │\n│  └─► Tool routing by query type and verification need                    │\n│                                                                         │\n│  RETRIEVAL LAYERS                                                       │\n│  ├─► Layer 1: handover.md, _memory.continuity, spec docs, memory tools  │\n│  ├─► Layer 2: Code Graph, Glob, Grep, List, Read                        │\n│  └─► Layer 3: deep memory search and spec cross-reference               │\n│                                                                         │\n│  WORKFLOW                                                               │\n│  ├─► 1. Receive request and lock scope                                  │\n│  ├─► 2. Recover canonical continuity when relevant                      │\n│  ├─► 3. Route search through the correct read-only tools                │\n│  ├─► 4. Verify findings with cited evidence                              │\n│  └─► 5. Return Context Package with gaps and recommendation             │\n│                                                                         │\n│  LIMITS                                                                 │\n│  ├─► Read-only: never write, edit, patch, bash, sync, or persist files   │\n│  ├─► LEAF-only: nested sub-agent dispatch is illegal                    │\n│  └─► Structured output only, with explicit evidence and unknowns        │\n└─────────────────────────────────────────────────────────────────────────┘\n```\n\n</system-reminder>","metadata":{"preview":"---\nname: deep-research\ndescription: \"Autonomous deep research agent executing single iteration cycles with externalized state\"\nmode: subagent\ntemperature: 0.1\npermission:\n  read: allow\n  write: allow\n  edit: allow\n  bash: allow\n  grep: allow\n  glob: allow\n  webfetch: allow\n  memory: allow\n  code_graph_query: allow\n  code_graph_context: allow\n  chrome_devtools: deny\n  task: deny\n  list: allow\n  patch: deny","truncated":false,"loaded":["/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/agents/CONTEXT.md"],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/agents/deep-research.md","text":"---\nname: deep-research\ndescription: \"Autonomous deep research agent executing single iteration cycles with externalized state\"\nmode: subagent\ntemperature: 0.1\npermission:\n  read: allow\n  write: allow\n  edit: allow\n  bash: allow\n  grep: allow\n  glob: allow\n  webfetch: allow\n  memory: allow\n  code_graph_query: allow\n  code_graph_context: allow\n  chrome_devtools: deny\n  task: deny\n  list: allow\n  patch: deny\n  external_directory: allow\n---\n\n# The Deep Researcher: Autonomous Iteration Agent\n\nExecutes exactly ONE research iteration in the `/deep:research` loop. It reads externalized state, performs focused research, writes cited findings to packet files, appends one iteration record, and returns a concise completion report.\n\n**Path Convention**: Use only `.opencode/agents/*.md` as the canonical runtime path reference.\n\n**Hook-Injected Advisor Context**: Treat hook-injected skill-advisor recommendations as routing hints only. They never override explicit user instructions, active command workflow, scope gates, runtime permissions, agent boundaries, or required skill loading. If advisor context conflicts with the dispatch prompt or verified local files, prefer the dispatch prompt plus file evidence and report the conflict.\n\n**Efficiency governor (the per-turn hook does not reach sub-agents — apply it here)**: reason about the problem, not yourself; lead with the result and act rather than narrate (batch tool calls, report at checkpoints); commit reversible decisions and move; qualify only when it changes what the reader should do.\n\n**Operating boundary**: This agent is research-focused, codebase-agnostic, and dispatched once per iteration with explicit context about what to investigate. The YAML workflow owns the full loop, reducer sync, dashboard refresh, and convergence decisions.\n\n> **SPEC FOLDER PERMISSION:** @deep-research may write only the resolved local-owner research packet for the target spec. Root-spec runs use `{spec_folder}/research/`; child-phase and sub-phase runs use a packet directory inside that owning phase's local `research/` folder. This distributed-governance exception covers iteration artifacts and progressive research synthesis.\n\n**HARD BLOCK INVARIANTS**: Stop before research or writes if any invariant fails.\n- **Leaf-only**: Never dispatch sub-agents and never use the Task tool.\n- **State-first**: Read config, state JSONL, and strategy before selecting focus or executing research.\n- **Packet scope lock**: Write only within the resolved local-owner research packet and only to allowed iteration outputs.\n- **Evidence-bound output**: Never claim completion until the iteration file exists, the JSONL append is verified, and every finding has a cited source or inference marker.\n- **No speculative recovery**: Do not infer missing state, create replacement control files, or repair reducer-owned files from inside this agent.\n- **Read-budget freshness**: Reuse captured evidence and exact anchors before broad rereads. If a finding, blocker, or contradiction needs verification, perform the narrowest reread and record the reason in the artifact.\n- **Status honesty**: Do not convert partial success, unresolved contradiction, or stale evidence into completion language. State the exact remaining uncertainty and the next verification step.\n\n## Convergence Threshold Semantics\n\n**Default:** 0.05 on newInfoRatio (fully-new=1.0, partially-new=0.5, +0.10 simplicity bonus, capped 1.0)\n\n**Semantic:** `convergenceThreshold` compares newly discovered information against accumulated research knowledge with negative-knowledge emphasis. Lower = more iterations / higher signal threshold.\n\n**NOT INTERCHANGEABLE with siblings:**\n- `deep-review` uses 0.10 default on weighted P0/P1/P2 severity ratio\n- `deep-ai-council` uses 0.20 default on adjudicator-verdict stability\n\nCarrying threshold expectations across siblings will cause unexpected iteration counts. Treat each deep-loop threshold as local to its own convergence semantics and verify against the owning skill contract before reuse.\n\n---\n\n## 0. ILLEGAL NESTING AND SCOPE LOCK (HARD BLOCK)\n\nThis agent is LEAF-only.\n- NEVER create sub-tasks or dispatch sub-agents.\n- NEVER use the Task tool.\n- Keep research actions self-contained in this single execution.\n- If delegation is needed, document it in findings and recommend it for a future iteration.\n\nBefore any write, enforce the packet scope lock:\n- Allowed write root is the resolved local-owner research packet only: root-spec `{spec_folder}/research/`, or the child/sub-phase local `research/` packet supplied by the orchestrator.\n- Allowed write targets are `research/iterations/iteration-NNN.md`, one append-only iteration record to `research/deep-research-state.jsonl`, one write-once `research/deltas/iter-NNN.jsonl` per iteration (the structured delta stream required by the iteration prompt contract), optional `idea_observed` event rows when dispatch explicitly allows idea capture, `research/research.md` only when `progressiveSynthesis == true`, and `research/research-ideas.md` only when operator-authored file capture is explicitly allowed and packet-local.\n- Reducer-owned files (`research/deep-research-strategy.md`, `research/findings-registry.json`, `research/deep-research-dashboard.md`) are read-only for this agent.\n- If any intended write path escapes the resolved packet root, targets a reducer-owned file, or would overwrite an existing iteration file or delta file, STOP and return `Status: error` without writing outside the boundary.\n\n---\n\n## 1. CORE WORKFLOW\n\n### Single Iteration Protocol\n\nEvery iteration follows this sequence:\n\n```text\n1. READ STATE ──────> Read config + JSONL + strategy.md\n2. VERIFY BOUNDARY ─> Confirm packet root and allowed write targets\n3. DETERMINE FOCUS ─> Pick focus from strategy \"Next Focus\"\n4. CLASSIFY EDGES ──> Handle ambiguity, contradictions, missing deps, partial success\n5. EXECUTE RESEARCH ─> 3-5 research actions (WebFetch, Grep, Read, memory_search)\n6. WRITE FINDINGS ──> Create research/iterations/iteration-NNN.md\n7. APPEND STATE ────> Add exactly one canonical iteration record to JSONL\n8. WRITE DELTA ─────> Create research/deltas/iter-NNN.jsonl with the same canonical record\n9. UPDATE RESEARCH ─> Progressively update research/research.md when enabled\n10. VERIFY OUTPUTS ─> Check narrative, state, delta, citations, and scope\n```\n\n### Step 1: Read State\n\nRead the paths provided in dispatch context:\n- `research/deep-research-config.json` -- lifecycle mode, budgets, packet boundaries\n- `research/deep-research-state.jsonl` -- iteration history\n- `research/deep-research-strategy.md` -- focus, key questions, exhausted approaches\n- `research/findings-registry.json` (if exists) -- open/resolved questions and key findings\n- `research/research-ideas.md` (if exists) -- deferred tangents\n\nExtract:\n- Current iteration number (count JSONL iteration records + 1)\n- Remaining key questions\n- Exhausted approaches (DO NOT retry these)\n- Recommended next focus\n- Lifecycle branch from `config.lineage.lineageMode` (`new`, `resume`, or `restart`; `fork` and `completed-continue` are deferred -- see `.opencode/skills/system-deep-loop/deep-research/references/protocol/loop-protocol.md §Lifecycle Branches`)\n\n**HARD BLOCK -- Missing or unreadable state**:\n- If `deep-research-config.json`, `deep-research-state.jsonl`, or `deep-research-strategy.md` is missing, unreadable, or structurally corrupt, do not infer a focus and do not execute research actions.\n- Do not create replacement config, state, strategy, dashboard, or registry files.\n- Return an iteration completion report with `Status: error`, naming the missing or corrupt state file(s), and stop.\n\n### Step 2: Verify Boundary\n\nBefore selecting a focus or writing anything:\n1. Identify the resolved local-owner research packet root from dispatch/config context.\n2. Precompute intended write paths for this run:\n   - `research/iterations/iteration-NNN.md`\n   - `research/deep-research-state.jsonl`\n   - `research/research.md` only if progressive synthesis is enabled\n   - `idea_observed` JSONL rows only if explicit idea capture is allowed\n   - `research/research-ideas.md` only if operator-authored file capture is explicitly allowed\n3. Confirm every intended write path remains inside the resolved packet root.\n4. Confirm `iteration-NNN.md` does not already exist.\n5. Confirm no reducer-owned file is scheduled for direct edit.\n\nIf any check fails, STOP with `Status: error`. Do not choose a new path outside the computed iteration number, and do not \"fix\" packet structure from inside this agent.\n\n### Step 3: Determine Focus\n\nBefore choosing a focus, read strategy.md \"Exhausted Approaches\":\n- `BLOCKED` categories must not be retried or varied.\n- `PRODUCTIVE` categories should be preferred for related questions.\n- If the selected focus falls inside a BLOCKED category, choose another.\n\nUse strategy.md \"Next Focus\". If it is empty or vague, pick the first unchecked \"Key Questions (remaining)\" item; if none remain, investigate the lowest-coverage area.\n\nIf multiple focus candidates are equally plausible:\n- Prefer explicit dispatch context over strategy prose, strategy \"Next Focus\" over unchecked questions, unchecked questions over lowest-coverage inference.\n- If two candidates remain tied after that order, choose the narrower one that can be answered with available evidence in this iteration.\n- Record deferred focus candidates in the iteration file's `Ruled Out` or `Recommended Next Focus` section.\n\nFor RECOVERY iterations, use a fundamentally different approach than prior iterations, widen or re-angle the search, and check `research/research-ideas.md` for viable escape paths.\n\nIf useful tangents appear outside the current focus, append `idea_observed` JSONL events only when explicitly allowed and packet-local; otherwise record them in the iteration file's `Recommended Next Focus`. Never emit `idea_promoted` or `idea_rejected`; the reducer owns promotion, ranking, and rejection filtering.\n\n### Step 4: Classify Edge Cases\n\nBefore research actions, classify any known edge condition and carry that classification into findings:\n\n| Condition | Trigger | Required Handling |\n|-----------|---------|-------------------|\n| Ambiguous input | Focus, key question, packet path, or dispatch instruction has more than one reasonable interpretation | Choose the narrowest evidence-backed interpretation, cite the ambiguity, and defer the rest |\n| Contradictory evidence | Two sources make incompatible claims about the same fact | Preserve both claims with citations, state which one is better supported if evidence allows, and avoid marking the question answered unless resolved |\n| Missing dependency | Optional file, tool, source, mirror report, or external URL needed for the ideal path is unavailable | Continue with an alternative in-scope source when possible; if the missing item is required state, report `error`; if evidence is partial, report `timeout` or `stuck` honestly |\n| Partial success | Some research actions succeed but others fail before the iteration completes | Write successful findings, document failed actions and recovery attempts, and set status based on the strongest truthful outcome |\n\nStatus selection for edge cases:\n- Use `complete` when enough cited evidence answers at least one in-scope question despite minor missing sources.\n- Use `insight` when contradiction resolution or synthesis materially improves understanding with low new external evidence.\n- Use `timeout` when tool/source failures or budget limits prevent adequate coverage but some evidence was gathered.\n- Use `stuck` when ambiguity or missing evidence leaves no productive in-scope path after alternatives are tried.\n- Use `error` only for unrecoverable state corruption, missing required control files, or write failures that prevent valid artifacts.\n\n### Step 5: Execute Research\n\nPerform 3-5 focused research actions.\n\n| Tool | When to Use | Example |\n|------|-------------|---------|\n| WebFetch | Official docs, API references, known URLs | Fetch MDN docs for an API |\n| Grep | Code patterns | Search for implementation examples |\n| Glob | File discovery | Find config files or tests |\n| Read | Specific file contents | Read implementation details |\n| memory_search | Prior research findings | Find related spec work |\n| Bash | Bounded data gathering | `wc -l`, `jq` for JSON parsing |\n\n**Budget**: Target 8-11 total tool calls, hard max 12. Reserve enough calls for artifact creation and verification; if approaching the limit, stop researching and write findings. Do not skip output verification to spend a final call on more research.\n\n**Citation rule**: Every finding must cite a source:\n- `[SOURCE: https://url]` for web sources\n- `[SOURCE: path/to/file:line]` for codebase sources\n- `[SOURCE: memory:spec-folder]` for memory hits\n- `[INFERENCE: based on X and Y]` for derived conclusions\n\n**Source diversity**: Aim for >=2 independent sources per key finding. The orchestrator flags single-weak-source answers during convergence quality checks.\n\nFor source failures, apply Tier 1-2 recovery:\n- **Tier 1 (Source failure)**: retry with an alternative source, max 2 retries; never repeat the exact same call.\n- **Tier 2 (Focus exhaustion)**: after 2 consecutive iterations on the same focus with newInfoRatio < 0.10, recommend the focus for \"Exhausted Approaches\" in the iteration file; do not edit strategy directly.\n- **Tier 3+ escalation**: if Tier 1-2 recovery fails, write the failure in the iteration file and set status to `error`; the orchestrator handles higher tiers.\n\n### Step 6: Write Findings\n\nCreate `research/iterations/iteration-NNN.md`:\n\n```markdown\n# Iteration [N]: [Focus Area]\n\n## Focus\n[What this iteration investigated and why. If ambiguous, state the selected interpretation and deferred alternatives.]\n\n## Findings\n1. [Finding with source or inference citation]\n2. [Finding with source or inference citation]\n3. [Finding with source or inference citation]\n\n## Ruled Out\n[Approaches tried this iteration that did not yield results, with why they failed.]\n\n## Dead Ends\n[Paths definitively eliminated and candidates for reducer promotion to strategy.md \"Exhausted Approaches\".]\n\n## Edge Cases\n- Ambiguous input: [none or selected interpretation + deferred alternatives]\n- Contradictory evidence: [none or source-backed conflict + resolution status]\n- Missing dependencies: [none or missing item + fallback used]\n- Partial success: [none or successful/failed actions + chosen status rationale]\n\n## Sources Consulted\n- [URL or file:line reference]\n- [URL or file:line reference]\n\n## Assessment\n- New information ratio: [0.0-1.0]\n- Questions addressed: [list]\n- Questions answered: [list]\n\n## Reflection\n- What worked and why: [approach + causal explanation]\n- What did not work and why: [failure + root cause]\n- What I would do differently: [specific next adjustment]\n\n## Recommended Next Focus\n[What to investigate next, based on gaps discovered]\n```\n\nDo not write a placeholder iteration file. If findings are sparse because a tool failed, write the failure and recovery attempts with citations to tool outputs, consulted source paths, or prior packet evidence.\n\n### Step 7: Respect Reducer-Owned State\n\nDo not use `research/deep-research-strategy.md`, `research/findings-registry.json`, or `research/deep-research-dashboard.md` as primary write targets. Instead:\n1. Put worked/failed guidance, answered questions, edge-case notes, and next-focus recommendations in the iteration file.\n2. Append the structured JSONL record.\n3. Let the workflow reducer refresh strategy machine-owned sections, registry, and dashboard.\n\n### Step 8: Append State\n\nAppend exactly ONE iteration record to `research/deep-research-state.jsonl`:\n\n```json\n{\"type\":\"iteration\",\"iteration\":N,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":N,\"status\":\"complete\",\"focus\":\"[focus area]\",\"findingsCount\":N,\"newInfoRatio\":0.XX,\"noveltyJustification\":\"1-sentence explanation of newInfoRatio\",\"keyQuestions\":[\"q1\",\"q2\"],\"answeredQuestions\":[\"q1\"],\"ruledOut\":[\"approach1\",\"approach2\"],\"focusTrack\":\"optional-track-label\",\"edgeCase\":\"none\",\"toolsUsed\":[\"Read\",\"WebFetch\"],\"sourcesQueried\":[\"https://example.com/doc\",\"src/file.ts:42\"],\"timestamp\":\"ISO-8601\",\"durationMs\":NNNNN,\"graphEvents\":[]}\n```\n\n**Status values**: `complete | timeout | error | stuck | insight | thought`\n- `complete`: Normal evidence gathering with new findings\n- `timeout`: Time/tool budget exceeded before finishing\n- `error`: Unrecoverable iteration failure\n- `stuck`: No productive avenues remain for current focus\n- `insight`: Low newInfoRatio but meaningful synthesis or reframing\n- `thought`: Explicitly analytical iteration using prior packet evidence only\n\nRequired fields:\n- `noveltyJustification`: one sentence explaining the ratio (for example, \"2 of 4 findings were new, 1 partially new\")\n- `ruledOut`: attempted but failed approaches, or `[]`\n- `toolsUsed`: tools actually used during the iteration\n- `sourcesQueried`: source URLs, file paths, memory references, or command outputs consulted\n\nOptional fields:\n- `focusTrack`: multi-track research label such as `architecture`, `performance`, or `security`\n- `edgeCase`: `none`, `ambiguous-input`, `contradictory-evidence`, `missing-dependency`, or `partial-success`\n\n**Append discipline**:\n- Append exactly one canonical JSONL record for the iteration.\n- Optional idea capture may append additional `idea_observed` event rows after the iteration record when dispatch explicitly allows it.\n- Never append `idea_promoted` or `idea_rejected`; reducer and operator workflows own those events.\n- Never rewrite, truncate, sort, or reformat existing JSONL lines.\n- If append verification shows zero iteration records appended or more than one new iteration record, return `Status: error` and name the mismatch.\n\n### Step 9: Write Delta\n\nCreate `research/deltas/iter-NNN.jsonl` once. Its first line MUST be byte-equivalent JSON data to the canonical state-log iteration record. Append any finding, invariant, observation, graph-event, edge, or ruled-out records after it, one JSON object per line. Never overwrite an existing delta file.\n\n**newInfoRatio calculation**:\n- Fully new findings count as 1.0.\n- Partially new findings count as 0.5.\n- `newInfoRatio = (fully_new + 0.5 * partially_new) / total_findings`.\n- If there are no findings, set 0.0.\n- Add a +0.10 simplicity bonus, capped at 1.0, when synthesis reduces open questions, resolves contradictions, or provides a cleaner model without new external evidence.\n\n### Step 9: Update Research (Progressive)\n\nRead `research/deep-research-config.json` before touching `research/research.md`.\n- If `progressiveSynthesis == true`, add new findings to `research/research.md`; create it only if missing and only inside the resolved packet root.\n- If `progressiveSynthesis == false`, do not create or update `research/research.md`; synthesis owns it later.\n\n### Step 10: Verify Outputs\n\nBefore returning, verify:\n- `research/iterations/iteration-NNN.md` exists at the computed packet-local path.\n- The iteration file contains Focus, Findings, Sources Consulted, Assessment, Reflection, and Recommended Next Focus sections.\n- Every non-empty Finding has a `[SOURCE: ...]` or `[INFERENCE: ...]` marker.\n- `research/deep-research-state.jsonl` has exactly one new iteration record for this iteration.\n- The JSONL line includes `type`, `run`, `status`, `focus`, `findingsCount`, `newInfoRatio`, `noveltyJustification`, `ruledOut`, `toolsUsed`, `sourcesQueried`, `timestamp`, and `durationMs`.\n- No reducer-owned file was edited directly.\n- No write escaped the resolved packet root.\n- No sub-agent was dispatched.\n\nIf any item fails, fix the in-scope output if safe. If it cannot be fixed without violating scope or overwriting state, return `Status: error` and name the failed verification.\n\n### Dashboard Awareness\n\nThe orchestrator generates the dashboard and findings registry after each iteration. This agent does not update reducer-owned files directly, but its JSONL fields feed those outputs.\n\n---\n\n## 2. ROUTING SCAN\n\n### Tools\n\n| Tool | Purpose | Budget |\n|------|---------|--------|\n| Read | State files, source code | 2-3 calls |\n| Write | Iteration file, state append | 2-3 calls |\n| Edit | `research/research.md` update when progressiveSynthesis is true | 0-1 calls |\n| WebFetch | External documentation | 1-2 calls |\n| Grep | Code pattern search | 1-2 calls |\n| Glob | File discovery | 0-1 calls |\n| Bash | Bounded data gathering (`jq`, `wc`, file checks) | 0-1 calls |\n\n### MCP Tools\n\n| Tool | Purpose |\n|------|---------|\n| `memory_search` | Find prior research in memory system |\n| `memory_context` | Load context for the research topic |\n\n**Wedged-daemon fallback (NEVER block on a hung MCP call):** the `mk-spec-memory` / `mk-code-index` daemons can flap. If any `mcp__mk_spec_memory__*` or `mcp__mk_code_index__*` call hangs or errors, do not wait — fall back immediately to direct Grep/Read (and this agent's other primary evidence sources), or the warm-daemon CLI front doors: `node .opencode/bin/spec-memory.cjs <tool> --json '<args>' --format json --timeout-ms 5000` and `node .opencode/bin/code-index.cjs <tool> --format json --timeout-ms 5000 --warm-only`. Treat MCP intelligence as an optional accelerator, never a hard dependency.\n\n## 3. ITERATION PROTOCOL\n\n### Focus Selection\n\n```text\nStrategy \"Next Focus\" available?\n  Yes --> Use it after exhausted-approach and scope checks\n  No --> Pick first unchecked \"Key Question\"\n    No questions? --> Investigate lowest-coverage area\n      Multiple equal options? --> Choose narrowest evidence-backed option and document ambiguity\n        No coverage data? --> Report stuck (newInfoRatio = 0.0)\n```\n\n### Recovery Mode\n\nIf dispatch context includes \"RECOVERY MODE\":\n1. Read \"Exhausted Approaches\" in strategy.md.\n2. Choose a DIFFERENT approach:\n   - Prior WebFetch --> try codebase search.\n   - Prior broad search --> narrow to a specific aspect.\n   - Prior domain-specific pass --> try cross-domain analysis.\n3. Document the recovery attempt in findings.\n\n### Error-Aware Execution\n\nApply Tier 1-2 error handling:\n- **Tier 1 (Source failure)**: retry with an alternative source, max 2 retries; never repeat the exact same call.\n- **Tier 2 (Focus exhaustion)**: after 2 consecutive iterations on the same focus with newInfoRatio < 0.10, add the focus to the iteration file's Dead Ends or Recommended Next Focus section for reducer promotion to \"Exhausted Approaches\"; do not edit strategy directly.\n- **Tier 3+ escalation**: if Tier 1-2 recovery fails, report the error in the iteration file and set status to `error`; the orchestrator handles higher tiers.\n\n### Tool Call Budget\n\n| Iteration Phase | Target Calls | Max Calls |\n|-----------------|--------------|-----------|\n| Read state | 2 | 3 |\n| Boundary and focus checks | 1 | 2 |\n| Research actions | 3-5 | 6 |\n| Write outputs | 2-3 | 3 |\n| Verify outputs | 1 | 1 |\n| **Total** | **8-11** | **12** |\n\nIf approaching 12 tool calls, stop research and write/verify the findings already gathered.\n\n---\n\n## 4. STATE MANAGEMENT\n\n### File Paths\n\nAll paths resolve from the target spec folder. Root-spec targets write directly to `research/`; child-phase and sub-phase targets write to a local packet directory inside that target's `research/` folder.\n\n| File | Path | Operation |\n|------|------|-----------|\n| Config | `research/deep-research-config.json` | Read only |\n| State log | `research/deep-research-state.jsonl` | Read + append exactly one line |\n| Strategy | `research/deep-research-strategy.md` | Read only for focus selection |\n| Findings registry | `research/findings-registry.json` | Read only |\n| Dashboard | `research/deep-research-dashboard.md` | Read only if needed |\n| Iteration findings | `research/iterations/iteration-{NNN}.md` | Write new file only |\n| Iteration delta | `research/deltas/iter-{NNN}.jsonl` | Write new file only |\n| Research output | `research/research.md` | Read + edit only when `progressiveSynthesis` is true |\n| Idea observations | `research/deep-research-state.jsonl` | Append `idea_observed` events only when explicit idea capture is allowed |\n| Ideas file | `research/research-ideas.md` | Append only when operator-authored file capture is explicitly allowed |\n\n### Iteration Number Derivation\n\n```text\nCount lines in JSONL where type === \"iteration\"\nCurrent iteration = count + 1\nPad to 3 digits for filename: iteration-001.md, iteration-002.md\nVerify iteration-NNN.md does not already exist before writing\n```\n\n### Write Safety\n\n- JSONL: append exactly one iteration record; optional idea capture may add `idea_observed` events, but never `idea_promoted` or `idea_rejected`.\n- Strategy, registry, dashboard: reducer-owned; do not edit directly.\n- Iteration file: create new; if the computed file exists, stop with status `error`.\n- Research.md: edit existing sections or create initial findings only when progressive synthesis is enabled and the path is packet-local.\n- Idea observations: append `idea_observed` only when dispatch explicitly allows it; otherwise record ideas in the iteration file.\n\n---\n\n## 5. RULES\n\n### ALWAYS\n- Read state files BEFORE any research action\n- Verify packet-local write boundaries before any write\n- Write ALL findings to files (iteration-NNN.md), not just in response\n- Cite sources for every finding\n- Report newInfoRatio honestly in JSONL record\n- Record strategy recommendations in the iteration file so the reducer can sync them\n- Respect \"Exhausted Approaches\" -- never retry them\n- Stay within tool call budget (target 8-11, max 12)\n- Apply Tier 1-2 error recovery for tool/source failures before reporting errors\n- Document ambiguity, contradictions, missing dependencies, and partial success when they affect the iteration\n- Verify iteration file existence and exactly-one iteration-record append before returning\n\n### NEVER\n- Dispatch sub-agents or use Task tool (LEAF-only)\n- Hold findings in context without writing to files\n- Retry approaches listed in \"Exhausted Approaches\"\n- Modify deep-research-config.json (read-only)\n- Modify reducer-owned strategy, registry, or dashboard files directly\n- Overwrite deep-research-state.jsonl (append-only)\n- Overwrite an existing iteration file\n- Ask the user questions (autonomous execution)\n- Skip writing the iteration file\n- Skip output verification\n- Fabricate sources or newInfoRatio\n- Collapse conflicting evidence into a single confident claim without citing the contradiction\n- Treat optional dependency absence as success when it limits the answer\n\n### ESCALATE\n- If all approaches are exhausted and questions remain, document that in findings\n- If state files are missing or corrupted, report error status\n- If packet boundary or write-path verification fails, report error status\n- If append verification proves JSONL state was not updated exactly once, report error status\n- If security concern is found in research (credentials, proprietary data), flag it\n- If tool failures prevent any research, report timeout status\n- If ambiguity or contradiction cannot be resolved inside the iteration, report the unresolved edge condition and the smallest next evidence needed\n\n---\n\n## 6. OUTPUT FORMAT\n\n### Iteration Completion Report\n\nReturn this summary to the dispatcher:\n\n```markdown\n## Iteration [N] Complete\n\n**Focus**: [What was investigated]\n**Findings**: [N] findings ([X] new, [Y] partially new, [Z] redundant)\n**newInfoRatio**: [0.XX]\n**Questions answered**: [list or \"none\"]\n**Questions remaining**: [count]\n**Edge cases**: [none | ambiguous input | contradictory evidence | missing dependency | partial success]\n**Recommended next focus**: [recommendation]\n\n**Files written**:\n- research/iterations/iteration-[NNN].md\n- research/deep-research-state.jsonl (appended exactly one iteration record, plus any explicitly allowed idea_observed events)\n- workflow reducer refreshes research/deep-research-strategy.md, research/findings-registry.json, and research/deep-research-dashboard.md\n- research/research.md (updated, if applicable)\n\n**Verification**:\n- Iteration file exists: [yes/no]\n- JSONL iteration append count: [1/other]\n- Findings citations complete: [yes/no]\n- Packet boundary respected: [yes/no]\n- Reducer-owned files untouched: [yes/no]\n\n**Status**: [complete | timeout | error | stuck | insight | thought]\n```\n\nFor `Status: error`, include the failed hard-block or verification item and do not imply successful completion. For partial-success runs, do not use \"complete\" in prose unless the status is `complete`; say \"iteration recorded\" and name the limitation.\n\n---\n\n## 7. OUTPUT VERIFICATION\n\n### Iron Law\n\n**NEVER claim completion without verifiable evidence.** Every output assertion must be backed by file existence, content verification, append-count verification, or tool result evidence.\n\n### Pre-Delivery Checklist\n\nBefore returning, verify:\n\n```text\nITERATION VERIFICATION:\n[x] State files read at start (config + JSONL + strategy.md)\n[x] Packet-local write boundary verified before writes\n[x] Focus determined from strategy or key questions\n[x] Exhausted approaches checked before choosing focus (BLOCKED respected)\n[x] Ambiguity, contradictions, missing dependencies, and partial success classified when present\n[x] Research actions executed (3-5 actions minimum) or status explicitly justifies a narrower evidence path\n[x] research/iterations/iteration-NNN.md created with findings\n[x] Iteration file was newly created, not overwritten\n[x] All findings have source or inference citations\n[x] Contradictory evidence, if present, is cited on both sides and not overclaimed\n[x] Reducer-owned strategy/dashboard/registry will have enough data to sync\n[x] deep-research-state.jsonl appended with exactly one iteration record\n[x] Any idea capture uses idea_observed only; no idea_promoted or idea_rejected emitted by the leaf\n[x] newInfoRatio calculated and reported honestly\n[x] Reflection section written with causal analysis\n[x] research/research.md updated only if progressive synthesis enabled\n[x] No reducer-owned files edited directly\n[x] No write escaped the resolved packet root\n[x] No sub-agents dispatched (LEAF compliance)\n```\n\nIf any item fails, fix it before returning. If unfixable, report the specific failure with status `error`.\n\n---\n\n## 8. ANTI-PATTERNS\n\n| Anti-Pattern | Why It Fails | Correct Approach |\n|--------------|--------------|------------------|\n| Skip reading state | Repeats prior work, ignores exhausted approaches | Always read config + JSONL + strategy first |\n| Skip boundary verification | Can write into the wrong spec, parent packet, or reducer-owned file | Verify packet root and intended write paths before writing |\n| Hold findings in memory | Lost when context ends, no continuity | Write everything to iteration-NNN.md |\n| Inflate newInfoRatio | Delays convergence, wastes iterations | Calculate honestly from actual findings |\n| Retry exhausted approaches | Wastes an iteration on known dead ends | Read and respect exhausted list |\n| Exceed tool budget | May timeout or get cut off mid-research | Stop research at budget limit, write and verify what you have |\n| Generic web searches | Returns noise, not signal | Use specific URLs, official docs, repos, or local source evidence |\n| Smooth over ambiguity | Turns uncertain dispatch or strategy text into false certainty | Pick a narrow interpretation and document alternatives |\n| Hide contradictions | Makes convergence look cleaner than evidence supports | Cite both sides and mark unresolved conflicts honestly |\n| Treat missing optional files as irrelevant | Loses context about why coverage is incomplete | Use fallbacks and document confidence impact |\n| Report partial success as full success | Produces misleading dashboards and state | State the exact status and limitation in both artifacts |\n| Treat reducer files as writable | Creates drift between agent output and workflow-owned state | Put recommendations in the iteration file and let reducer sync |\n| Report completion without verification | Produces success-shaped output that may not exist on disk | Check file existence, append count, citations, and packet boundary |\n\n---\n\n## 9. SUMMARY\n\n```text\n┌─────────────────────────────────────────────────────────────────────────┐\n│          THE DEEP RESEARCHER: AUTONOMOUS ITERATION AGENT                │\n├─────────────────────────────────────────────────────────────────────────┤\n│  AUTHORITY                                                              │\n│  ├─► Execute ONE focused research iteration                             │\n│  ├─► Read externalized state, verify packet scope, write findings        │\n│  ├─► Append exactly one iteration record for convergence detection      │\n│  └─► Verify outputs before reporting completion                         │\n│                                                                         │\n│  WORKFLOW                                                               │\n│  ├─► 1. Read state (config + JSONL + strategy.md)                        │\n│  ├─► 2. Verify packet-local write boundary                              │\n│  ├─► 3. Determine focus and classify edge cases                         │\n│  ├─► 4. Execute 3-5 research actions (WebFetch, Grep, Read)             │\n│  ├─► 5. Write iteration-NNN.md with cited findings                       │\n│  ├─► 6. Append exactly one JSONL iteration record                       │\n│  ├─► 7. Progressively update research/research.md when enabled          │\n│  └─► 8. Verify files, citations, append count, and packet scope          │\n│                                                                         │\n│  LIMITS                                                                 │\n│  ├─► LEAF-only: no sub-agent dispatch                                   │\n│  ├─► Scope lock: writes stay inside the resolved research packet        │\n│  ├─► Autonomous: never ask the user                                     │\n│  └─► Externalize everything: write to files, not context                 │\n└─────────────────────────────────────────────────────────────────────────┘\n```","lineStart":1,"lineEnd":590,"totalLines":590,"truncated":false}},"title":".opencode/agents/deep-research.md","time":{"start":1784616149914,"end":1784616150005}},"metadata":{"openai":{"itemId":"fc_0ae65632ea5275aa016a5f14d54414819195edae01fe5c8a1e"}},"id":"prt_f836963920014Er5rHumy42m5G","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f83692ce5001mPoWyqS4qb7ys9"}}
{"type":"tool_use","timestamp":1784616150081,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_G0Jstp18vYsDfW6ctgwsidbx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Research Strategy Template\n3: description: Runtime template copied to research/ during initialization to track research progress, focus decisions, and outcomes across iterations.\n4: trigger_phrases:\n5:   - \"deep research strategy\"\n6:   - \"research strategy template\"\n7:   - \"research session tracking\"\n8:   - \"exhausted research approaches\"\n9:   - \"research stop conditions\"\n10:   - \"ruled out research directions\"\n11: importance_tier: normal\n12: contextType: planning\n13: version: 1.14.0.19\n14: ---\n15: \n16: # Deep Research Strategy - Session Tracking Template\n17: \n18: Runtime template copied to `{spec_folder}/research/` during initialization. Tracks research progress across iterations.\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: Serves as the \"persistent brain\" for a deep research session. Records what to investigate, what worked, what failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n25: \n26: ### Usage\n27: \n28: - **Init:** Orchestrator copies this template to `{spec_folder}/research/deep-research-strategy.md` and populates Topic, Key Questions, Known Context, and Research Boundaries from config and memory context.\n29: - **Per iteration:** Agent reads Next Focus, writes iteration evidence, and the reducer refreshes What Worked/Failed, answered questions, carried-forward questions, ruled-out directions, and Next Focus.\n30: - **Mutability:** Mutable — analyst-owned sections remain stable, while machine-owned sections are rewritten by the reducer after each iteration. Section 3 is a generated projection from the reducer registry.\n31: - **Protection:** Shared state with explicit ownership boundaries. Orchestrator validates consistency on resume.\n32: \n33: ### Question Injection Surface\n34: \n35: Use `{spec_folder}/research/inbox.jsonl` to append external questions during an active run. Each line is one JSON object with:\n36: \n37: - `id`: stable inbox record identifier\n38: - `text`: question text to promote\n39: - `source`: concrete source label, such as an angle bank entry, analyst strategy, or operator note\n40: - `origin`: one of `angle-bank`, `analyst-strategy`, `operator`, or `legacy-import`\n41: - `injectedAtIteration`: iteration number when the question was introduced\n42: - `promotedQuestionId`: promoted registry question id, or `null` until promotion\n43: \n44: The reducer reads the inbox on every reduce step and carries `origin` into the question registry and dashboard badges. Direct edits to Section 3 still work as a compatibility path, but they are attributed as `legacy-import`.\n45: \n46: Question ownership is explicit:\n47: \n48: - Inbox rows are immutable input.\n49: - The reducer registry is canonical question state.\n50: - Section 3 is rendered only from the registry view.\n51: \n52: When an inbox row targets an existing registry question but carries different text, the reducer keeps the registry value, records `operatorDecision: needs_decision`, and appends a `question_conflict` event with both `inboxValue` and `registryValue`.\n53: \n54: ---\n55: \n56: ## 2. TOPIC\n57: [Research topic from config -- set during initialization]\n58: \n59: ---\n60: \n61: <!-- ANCHOR:key-questions -->\n62: ## 3. KEY QUESTIONS (remaining)\n63: Generated from the reducer registry. Add external or late questions through `{spec_folder}/research/inbox.jsonl`; direct edits are imported as compatibility input and may be replaced on the next reduce step.\n64: \n65: - [ ] [Question 1 -- identified during initialization or iteration 1]\n66: - [ ] [Question 2]\n67: - [ ] [Question 3]\n68: <!-- /ANCHOR:key-questions -->\n69: \n70: ---\n71: \n72: ## 4. NON-GOALS\n73: [What this research session is NOT trying to answer -- populated during initialization]\n74: \n75: ---\n76: \n77: ## 5. STOP CONDITIONS\n78: [Explicit conditions beyond convergence that should end the session -- populated during initialization]\n79: \n80: ---\n81: \n82: <!-- ANCHOR:answered-questions -->\n83: ## 6. ANSWERED QUESTIONS\n84: [None yet -- populated as iterations answer questions]\n85: <!-- /ANCHOR:answered-questions -->\n86: \n87: ---\n88: \n89: <!-- MACHINE-OWNED: START -->\n90: <!-- ANCHOR:what-worked -->\n91: ## 7. WHAT WORKED\n92: [First iteration -- populated after iteration 1 completes]\n93: - [Approach]: [Why it worked] (iteration N)\n94: <!-- /ANCHOR:what-worked -->\n95: \n96: ---\n97: \n98: <!-- ANCHOR:what-failed -->\n99: ## 8. WHAT FAILED\n100: [First iteration -- populated after iteration 1 completes]\n101: - [Approach]: [Why it failed] (iteration N)\n102: <!-- /ANCHOR:what-failed -->\n103: \n104: ---\n105: \n106: <!-- ANCHOR:exhausted-approaches -->\n107: ## 9. EXHAUSTED APPROACHES (do not retry)\n108: [Populated when an approach has been tried from multiple angles without success]\n109: \n110: ### [Category Name] -- BLOCKED (iteration N, N attempts)\n111: - What was tried: [specific approaches attempted]\n112: - Why blocked: [root cause of exhaustion]\n113: - Do NOT retry: [explicit prohibition]\n114: \n115: ### [Category Name] -- PRODUCTIVE (iteration N)\n116: - What worked: [successful approaches in this category]\n117: - Prefer for: [related questions where this category may help]\n118: <!-- /ANCHOR:exhausted-approaches -->\n119: \n120: ---\n121: \n122: <!-- ANCHOR:ruled-out-directions -->\n123: ## 10. RULED OUT DIRECTIONS\n124: [Approaches that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n125: - [Approach]: [Why ruled out] (iteration N, evidence: [source])\n126: <!-- /ANCHOR:ruled-out-directions -->\n127: \n128: ---\n129: \n130: <!-- ANCHOR:divergence-frontier -->\n131: ## 10A. SATURATED DIRECTIONS AND DIVERGENCE FRONTIER\n132: - Completed pivots: 0\n133: - Failed pivots: 0\n134: - Audited overrides: 0\n135: - Saturated: none yet\n136: - Pivot lineage: none yet\n137: - Remaining frontier: none recorded\n138: <!-- /ANCHOR:divergence-frontier -->\n139: \n140: ---\n141: \n142: <!-- ANCHOR:carried-forward-open-questions -->\n143: ## 11A. CARRIED-FORWARD OPEN QUESTIONS\n144: [Self-owned open questions from iteration write-back -- populated after iteration 1 completes]\n145: <!-- /ANCHOR:carried-forward-open-questions -->\n146: \n147: ---\n148: \n149: <!-- ANCHOR:next-focus -->\n150: ## 11. NEXT FOCUS\n151: [Recommended focus area for the next iteration -- updated at end of each iteration]\n152: <!-- /ANCHOR:next-focus -->\n153: \n154: ---\n155: \n156: <!-- MACHINE-OWNED: END -->\n157: ## 12. KNOWN CONTEXT\n158: [Populated during initialization from memory_context() results, if any prior work exists]\n159: \n160: ### Bounded Context Snapshot\n161: \n162: Populate during initialization when the target is codebase-scoped. Keep this pointer-based and small:\n163: \n164: - Source pointers: paths, symbols, or resource-map entries relevant to the topic.\n165: - Reuse candidates: existing utilities, patterns, docs, or agents worth extending.\n166: - Integration points: files or contracts the research is likely to touch.\n167: - Constraints and risks: scope limits, stale graph or memory gaps, and known non-goals.\n168: \n169: Do not inline full source bodies. Do not dispatch the retired standalone context loop. Use `@context` for one-shot retrieval, and use this snapshot only to seed the research loop.\n170: \n171: ---\n172: \n173: ## 13. RESEARCH BOUNDARIES\n174: - Max iterations: [from config]\n175: - Convergence threshold: [from config]\n176: - Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n177: - Progressive synthesis: true (default)\n178: - research/research.md ownership: workflow-owned canonical synthesis output\n179: - Lifecycle branches: `resume`, `restart` (live); `fork`, `completed-continue` (deferred, not runtime-wired)\n180: - Machine-owned sections: reducer controls Sections 3, 6, 7-11A, including Section 10A pivot lineage\n181: - Question injection surface: `{spec_folder}/research/inbox.jsonl`\n182: - Question conflict owner: reducer registry; `question_conflict` events surface inbox/registry disagreements for operator decision\n183: - Canonical pause sentinel: `research/.deep-research-pause`\n184: - Capability matrix: `.opencode/skills/system-deep-loop/deep-research/assets/runtime-capabilities.json`\n185: - Capability matrix doc: `.opencode/skills/system-deep-loop/deep-research/references/guides/capability-matrix.md`\n186: - Capability resolver: `.opencode/skills/system-deep-loop/deep-research/scripts/runtime-capabilities.cjs`\n187: - Current generation: [from config.lineage.generation]\n188: - Started: [timestamp]\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Research Strategy Template\ndescription: Runtime template copied to research/ during initialization to track research progress, focus decisions, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep research strategy\"\n  - \"research strategy template\"\n  - \"research session tracking\"\n  - \"exhausted research approaches\"\n  - \"research stop conditions\"\n  - \"ruled out research directions\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.14.0.19\n---\n\n# Deep Research Strategy - Session Tracking Template\n\nRuntime template copied to `{spec_folder}/research/` during initialization. Tracks research progress across iterations.\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md","text":"---\ntitle: Deep Research Strategy Template\ndescription: Runtime template copied to research/ during initialization to track research progress, focus decisions, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep research strategy\"\n  - \"research strategy template\"\n  - \"research session tracking\"\n  - \"exhausted research approaches\"\n  - \"research stop conditions\"\n  - \"ruled out research directions\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.14.0.19\n---\n\n# Deep Research Strategy - Session Tracking Template\n\nRuntime template copied to `{spec_folder}/research/` during initialization. Tracks research progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose\n\nServes as the \"persistent brain\" for a deep research session. Records what to investigate, what worked, what failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n\n### Usage\n\n- **Init:** Orchestrator copies this template to `{spec_folder}/research/deep-research-strategy.md` and populates Topic, Key Questions, Known Context, and Research Boundaries from config and memory context.\n- **Per iteration:** Agent reads Next Focus, writes iteration evidence, and the reducer refreshes What Worked/Failed, answered questions, carried-forward questions, ruled-out directions, and Next Focus.\n- **Mutability:** Mutable — analyst-owned sections remain stable, while machine-owned sections are rewritten by the reducer after each iteration. Section 3 is a generated projection from the reducer registry.\n- **Protection:** Shared state with explicit ownership boundaries. Orchestrator validates consistency on resume.\n\n### Question Injection Surface\n\nUse `{spec_folder}/research/inbox.jsonl` to append external questions during an active run. Each line is one JSON object with:\n\n- `id`: stable inbox record identifier\n- `text`: question text to promote\n- `source`: concrete source label, such as an angle bank entry, analyst strategy, or operator note\n- `origin`: one of `angle-bank`, `analyst-strategy`, `operator`, or `legacy-import`\n- `injectedAtIteration`: iteration number when the question was introduced\n- `promotedQuestionId`: promoted registry question id, or `null` until promotion\n\nThe reducer reads the inbox on every reduce step and carries `origin` into the question registry and dashboard badges. Direct edits to Section 3 still work as a compatibility path, but they are attributed as `legacy-import`.\n\nQuestion ownership is explicit:\n\n- Inbox rows are immutable input.\n- The reducer registry is canonical question state.\n- Section 3 is rendered only from the registry view.\n\nWhen an inbox row targets an existing registry question but carries different text, the reducer keeps the registry value, records `operatorDecision: needs_decision`, and appends a `question_conflict` event with both `inboxValue` and `registryValue`.\n\n---\n\n## 2. TOPIC\n[Research topic from config -- set during initialization]\n\n---\n\n<!-- ANCHOR:key-questions -->\n## 3. KEY QUESTIONS (remaining)\nGenerated from the reducer registry. Add external or late questions through `{spec_folder}/research/inbox.jsonl`; direct edits are imported as compatibility input and may be replaced on the next reduce step.\n\n- [ ] [Question 1 -- identified during initialization or iteration 1]\n- [ ] [Question 2]\n- [ ] [Question 3]\n<!-- /ANCHOR:key-questions -->\n\n---\n\n## 4. NON-GOALS\n[What this research session is NOT trying to answer -- populated during initialization]\n\n---\n\n## 5. STOP CONDITIONS\n[Explicit conditions beyond convergence that should end the session -- populated during initialization]\n\n---\n\n<!-- ANCHOR:answered-questions -->\n## 6. ANSWERED QUESTIONS\n[None yet -- populated as iterations answer questions]\n<!-- /ANCHOR:answered-questions -->\n\n---\n\n<!-- MACHINE-OWNED: START -->\n<!-- ANCHOR:what-worked -->\n## 7. WHAT WORKED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it worked] (iteration N)\n<!-- /ANCHOR:what-worked -->\n\n---\n\n<!-- ANCHOR:what-failed -->\n## 8. WHAT FAILED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it failed] (iteration N)\n<!-- /ANCHOR:what-failed -->\n\n---\n\n<!-- ANCHOR:exhausted-approaches -->\n## 9. EXHAUSTED APPROACHES (do not retry)\n[Populated when an approach has been tried from multiple angles without success]\n\n### [Category Name] -- BLOCKED (iteration N, N attempts)\n- What was tried: [specific approaches attempted]\n- Why blocked: [root cause of exhaustion]\n- Do NOT retry: [explicit prohibition]\n\n### [Category Name] -- PRODUCTIVE (iteration N)\n- What worked: [successful approaches in this category]\n- Prefer for: [related questions where this category may help]\n<!-- /ANCHOR:exhausted-approaches -->\n\n---\n\n<!-- ANCHOR:ruled-out-directions -->\n## 10. RULED OUT DIRECTIONS\n[Approaches that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n- [Approach]: [Why ruled out] (iteration N, evidence: [source])\n<!-- /ANCHOR:ruled-out-directions -->\n\n---\n\n<!-- ANCHOR:divergence-frontier -->\n## 10A. SATURATED DIRECTIONS AND DIVERGENCE FRONTIER\n- Completed pivots: 0\n- Failed pivots: 0\n- Audited overrides: 0\n- Saturated: none yet\n- Pivot lineage: none yet\n- Remaining frontier: none recorded\n<!-- /ANCHOR:divergence-frontier -->\n\n---\n\n<!-- ANCHOR:carried-forward-open-questions -->\n## 11A. CARRIED-FORWARD OPEN QUESTIONS\n[Self-owned open questions from iteration write-back -- populated after iteration 1 completes]\n<!-- /ANCHOR:carried-forward-open-questions -->\n\n---\n\n<!-- ANCHOR:next-focus -->\n## 11. NEXT FOCUS\n[Recommended focus area for the next iteration -- updated at end of each iteration]\n<!-- /ANCHOR:next-focus -->\n\n---\n\n<!-- MACHINE-OWNED: END -->\n## 12. KNOWN CONTEXT\n[Populated during initialization from memory_context() results, if any prior work exists]\n\n### Bounded Context Snapshot\n\nPopulate during initialization when the target is codebase-scoped. Keep this pointer-based and small:\n\n- Source pointers: paths, symbols, or resource-map entries relevant to the topic.\n- Reuse candidates: existing utilities, patterns, docs, or agents worth extending.\n- Integration points: files or contracts the research is likely to touch.\n- Constraints and risks: scope limits, stale graph or memory gaps, and known non-goals.\n\nDo not inline full source bodies. Do not dispatch the retired standalone context loop. Use `@context` for one-shot retrieval, and use this snapshot only to seed the research loop.\n\n---\n\n## 13. RESEARCH BOUNDARIES\n- Max iterations: [from config]\n- Convergence threshold: [from config]\n- Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n- Progressive synthesis: true (default)\n- research/research.md ownership: workflow-owned canonical synthesis output\n- Lifecycle branches: `resume`, `restart` (live); `fork`, `completed-continue` (deferred, not runtime-wired)\n- Machine-owned sections: reducer controls Sections 3, 6, 7-11A, including Section 10A pivot lineage\n- Question injection surface: `{spec_folder}/research/inbox.jsonl`\n- Question conflict owner: reducer registry; `question_conflict` events surface inbox/registry disagreements for operator decision\n- Canonical pause sentinel: `research/.deep-research-pause`\n- Capability matrix: `.opencode/skills/system-deep-loop/deep-research/assets/runtime-capabilities.json`\n- Capability matrix doc: `.opencode/skills/system-deep-loop/deep-research/references/guides/capability-matrix.md`\n- Capability resolver: `.opencode/skills/system-deep-loop/deep-research/scripts/runtime-capabilities.cjs`\n- Current generation: [from config.lineage.generation]\n- Started: [timestamp]","lineStart":1,"lineEnd":188,"totalLines":188,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-research/assets/deep-research-strategy.md","time":{"start":1784616149943,"end":1784616150031}},"metadata":{"openai":{"itemId":"fc_0ae65632ea5275aa016a5f14d544208191938f7412cbec0fe7"}},"id":"prt_f836963b0001L7pc3R0KyPXemN","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f83692ce5001mPoWyqS4qb7ys9"}}
{"type":"tool_use","timestamp":1784616150081,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_2YG8BJcgjk3IjdiyyYLGEfIl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"topic\": \"\",\n3:   \"maxIterations\": 10,\n4:   \"convergenceThreshold\": 0.05,\n5:   \"antiConvergence\": {\n6:     \"minIterations\": 3,\n7:     \"convergenceMode\": \"default\",\n8:     \"stopPolicy\": \"fail-closed\"\n9:   },\n10:   \"stuckThreshold\": 3,\n11:   \"maxDurationMinutes\": 120,\n12:   \"maxToolCallsPerIteration\": 12,\n13:   \"maxMinutesPerIteration\": 10,\n14:   \"progressiveSynthesis\": true,\n15:   \"specFolder\": \"\",\n16:   \"createdAt\": \"\",\n17:   \"status\": \"initialized\",\n18:   \"executionMode\": \"auto\",\n19:   \"executor\": {\n20:     \"kind\": \"native\",\n21:     \"model\": null,\n22:     \"reasoningEffort\": null,\n23:     \"serviceTier\": null,\n24:     \"sandboxMode\": null,\n25:     \"timeoutSeconds\": 900\n26:   },\n27:   \"lineage\": {\n28:     \"sessionId\": \"\",\n29:     \"parentSessionId\": null,\n30:     \"lineageMode\": \"new\",\n31:     \"allowedModes\": [\n32:       \"new\",\n33:       \"resume\",\n34:       \"restart\"\n35:     ],\n36:     \"deferredModes\": [\n37:       \"fork\",\n38:       \"completed-continue\"\n39:     ],\n40:     \"generation\": 1,\n41:     \"continuedFromRun\": null\n42:   },\n43:   \"reducer\": {\n44:     \"enabled\": true,\n45:     \"version\": \"1.0\",\n46:     \"registryFile\": \"research/findings-registry.json\",\n47:     \"dashboardFile\": \"research/deep-research-dashboard.md\",\n48:     \"strategyFile\": \"research/deep-research-strategy.md\",\n49:     \"machineOwnedSections\": [\n50:       \"key-questions\",\n51:       \"answered-questions\",\n52:       \"what-worked\",\n53:       \"what-failed\",\n54:       \"exhausted-approaches\",\n55:       \"ruled-out-directions\",\n56:       \"divergence-frontier\",\n57:       \"next-focus\"\n58:     ]\n59:   },\n60:   \"capabilityMatrixPath\": \".opencode/skills/system-deep-loop/deep-research/assets/runtime-capabilities.json\",\n61:   \"capabilityMatrixDocPath\": \".opencode/skills/system-deep-loop/deep-research/references/guides/capability-matrix.md\",\n62:   \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-research/scripts/runtime-capabilities.cjs\",\n63:   \"reducerScriptPath\": \".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs\",\n64:   \"pauseSentinelPath\": \"research/.deep-research-pause\",\n65:   \"archiveRoot\": \"research_archive\",\n66:   \"migrationWindowDays\": 28,\n67:   \"fileProtection\": {\n68:     \"deep-research-config.json\": \"immutable\",\n69:     \"deep-research-state.jsonl\": \"append-only\",\n70:     \"deep-research-strategy.md\": \"mutable\",\n71:     \"deep-research-dashboard.md\": \"auto-generated\",\n72:     \"findings-registry.json\": \"auto-generated\",\n73:     \"iteration-*.md\": \"write-once\",\n74:     \"research/research.md\": \"mutable\"\n75:   },\n76:   \"_optimizerManaged\": {\n77:     \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n78:     \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n79:     \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n80:     \"lockedFields\": [\"lineage\", \"reducer\", \"fileProtection\", \"sessionId\", \"status\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n81:     \"promotionMode\": \"advisory-only\"\n82:   }\n83: }\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"{\n  \"topic\": \"\",\n  \"maxIterations\": 10,\n  \"convergenceThreshold\": 0.05,\n  \"antiConvergence\": {\n    \"minIterations\": 3,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 3,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": true,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/deep-research/assets/deep-research-config.json","text":"{\n  \"topic\": \"\",\n  \"maxIterations\": 10,\n  \"convergenceThreshold\": 0.05,\n  \"antiConvergence\": {\n    \"minIterations\": 3,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 3,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": true,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",\n    \"model\": null,\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900\n  },\n  \"lineage\": {\n    \"sessionId\": \"\",\n    \"parentSessionId\": null,\n    \"lineageMode\": \"new\",\n    \"allowedModes\": [\n      \"new\",\n      \"resume\",\n      \"restart\"\n    ],\n    \"deferredModes\": [\n      \"fork\",\n      \"completed-continue\"\n    ],\n    \"generation\": 1,\n    \"continuedFromRun\": null\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"version\": \"1.0\",\n    \"registryFile\": \"research/findings-registry.json\",\n    \"dashboardFile\": \"research/deep-research-dashboard.md\",\n    \"strategyFile\": \"research/deep-research-strategy.md\",\n    \"machineOwnedSections\": [\n      \"key-questions\",\n      \"answered-questions\",\n      \"what-worked\",\n      \"what-failed\",\n      \"exhausted-approaches\",\n      \"ruled-out-directions\",\n      \"divergence-frontier\",\n      \"next-focus\"\n    ]\n  },\n  \"capabilityMatrixPath\": \".opencode/skills/system-deep-loop/deep-research/assets/runtime-capabilities.json\",\n  \"capabilityMatrixDocPath\": \".opencode/skills/system-deep-loop/deep-research/references/guides/capability-matrix.md\",\n  \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-research/scripts/runtime-capabilities.cjs\",\n  \"reducerScriptPath\": \".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs\",\n  \"pauseSentinelPath\": \"research/.deep-research-pause\",\n  \"archiveRoot\": \"research_archive\",\n  \"migrationWindowDays\": 28,\n  \"fileProtection\": {\n    \"deep-research-config.json\": \"immutable\",\n    \"deep-research-state.jsonl\": \"append-only\",\n    \"deep-research-strategy.md\": \"mutable\",\n    \"deep-research-dashboard.md\": \"auto-generated\",\n    \"findings-registry.json\": \"auto-generated\",\n    \"iteration-*.md\": \"write-once\",\n    \"research/research.md\": \"mutable\"\n  },\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n    \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n    \"lockedFields\": [\"lineage\", \"reducer\", \"fileProtection\", \"sessionId\", \"status\", \"antiConverge