.opencode/skills/system-skill-advisor/references/graph/skill_graph_query_cookbook.md:272:  "skills": [
.opencode/skills/system-skill-advisor/references/graph/skill_graph_query_cookbook.md:273:    { "skillId": "system-spec-kit", "inDegree": 18, "outDegree": 6, "total": 24 },
