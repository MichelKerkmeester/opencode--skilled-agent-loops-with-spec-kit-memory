\n\n  Line 551:         if (deleteResult.failedIds.length > 0) {\n\n  Line 552:           throw new Error(`Failed to delete old chunk rows: ${deleteResult.failedIds.join(', ')}`);\n\n  Line 555:         for (const oldChildId of deleteResult.deletedIds) {\n\n  Line 557:             recordHistory(oldChildId, 'DELETE', filePath ?? null, null, 'mcp:chunking_reindex', parsed.specFolder);\n\n  Line 572:             if (vectorIndex.deleteMemory(cid)) {\n\n  Line 574:                 recordHistory(cid, 'DELETE', null, null, 'mcp:chunking_rollback', parsed.specFolder);\n\n  Line 585:       toolCache.invalidateOnWrite('chunked-save-rollback', { filePath });\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"path\\.resolve|realpath|relative\\(|\\.\\.\\/|filePath|specFolder|confirm|delete|rmSync|unlink|mkdir|writeFile|readFile","time":{"start":1781763953682,"end":1781763953696}},"metadata":{"openai":{"itemId":"fc_022e98e88d144d9c016a338f70f3d48191892182fd1a7a5240"}},"id":"prt_ed96853e50014XeMXtsoKnYdyj","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed9681bd0001ktPiEwOFIhF6BP"}}
