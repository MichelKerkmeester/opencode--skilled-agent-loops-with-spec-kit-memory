e native routes to system-spec-kit\",\n      \"approvedAt\": \"2026-06-13\"\n    },\n    {\n      \"id\": \"rr-iter2-034\",\n      \"corpus\": \"labeled\",\n      \"promptHash\": \"sha256:bd885aa14cb0efe12135a0005a7a8fbd4cb452edcf3d299227f832eb9c51d58c\",\n      \"gold\": \"system-spec-kit\",\n      \"localTop\": \"mcp-chrome-devtools\",\n      \"nativeTop\": \"sk-prompt\",\n      \"reason\": \"baseline divergence captured 2026-06-13: local/native lexical-mis-route disagreement (local=mcp-chrome-devtools, native=sk-prompt)\",\n      \"approvedAt\": \"2026-06-13\"\n    },\n    {\n      \"id\": \"rr-iter2-039\",\n      \"corpus\": \"labeled\",\n      \"promptHash\": \"sha256:29bc5a2dd483d42d2a0cda2ed84edca66906cdc259c3c9834b1aaca924a04547\",\n      \"gold\": \"system-spec-kit\",\n      \"localTop\": \"none\",\n      \"nativeTop\": \"sk-doc\",\n      \"reason\": \"baseline divergence captured 2026-06-13: local abstains at strict thresholds where native routes to sk-doc\",\n      \"approvedAt\": \"2026-06-13\"\n    },\n    {\n      \"id\": \"rr-iter2-040\",\n      \"corpus\": \"labeled\",\n      \"promptHash\": \"sha256:040bfab6a71918dd8a60c0cf4b88c9f68b8b12c62039efd4997d1e0f8af929b1\",\n      \"gold\": \"none\",\n      \"localTop\": \"system-spec-kit\",\n      \"nativeTop\": \"none\",","lineStart":1,"lineEnd":220,"totalLines":755,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/tests/parity/fixtures/local-native-approved-divergences.json","time":{"start":1783486704041,"end":1783486704047}},"metadata":{"openai":{"itemId":"fc_0475c0f7f817f0fc016a4dd8eff38081919fe83f9eedbec6ba"}},"id":"prt_f40176987001Uc1UTXSmawpXwz","sessionID":"ses_0bfeb66caffeUBiiEjockj4kt1","messageID":"msg_f401754c3001Oob96pLYClQptj"}}
