gs', 'fanout-lineage.out'),\n1413:       'utf8',\n1414:     );\n1415:     return { stdout, baseDir };\n1416:   }\n1417: \n1418:   it('omits --variant from opencode argv when reasoningEffort is unset', async () => {\n1419:     const { stdout } = await runOpencodeEcho({ label: 'no-variant' }, 'research');\n1420:     const argvLine = stdout.split('\\n').find((l) => l.startsWith('ARGV:')) ?? '';\n1421:     expect(argvLine).not.toContain('--variant');\n1422:   });\n1423: \n1424:   it('includes --variant in opencode argv when reasoningEffort is set', async () => {\n1425:     const { stdout } = await runOpencodeEcho({ label: 'with-variant', reasoningEffort: 'high' }, 'research');\n1426:     const argvLine = stdout.split('\\n').find((l) => l.startsWith('ARGV:')) ?? '';\n1427:     expect(argvLine).toContain('--variant high');\n1428:   });\n1429: \n1430:   it('adds config.maxIterations to the prompt when lineage.iterations is set (A3)', async () => {\n1431:     const { stdout } = await runOpencodeEcho({ label: 'capped', iterations: 4 }, 'research');\n1432:     expect(stdout).toContain('config.maxIterations: 4');\n1433:     expect(stdout).toContain('whichever comes first');\n1434:   });\n1435: \n1436:   it('omits config.maxIterations from the prompt when iterations is null (A3)', async () => {\n1437:     const { stdout } = await runOpencodeEcho({ label: 'uncapped' }, 'research');\n1438:     expect(stdout).not.toContain('config.maxIterations');\n1439:     expect(stdout).toContain('(to legal convergence)');\n1440:   });\n1441: });\n1442: \n1443: describe('fanout-run.cjs — recursion-guard dispatch stack (SPECKIT_CLI_DISPATCH_STACK)', () => {\n1444:   /**\n1445:    * Write a stub that echoes the dispatch-stack env var (and the per-replica\n1446:    * state-dir env) so the test can assert the spawned seat's environment.\n1447:    */\n1448:   function writeStackEchoStub(binDir: string, name: string): string {\n1449:     const stubPath = join(binDir, name);\n1450:     writeFileSync(\n1451:       stubPath,\n1452:       '#!/bin/sh\\necho \"DISPATCH_STACK=$SPECKIT_CLI_DISPATCH_STACK\"\\n'\n1453:         + 'echo \"STATE_DIR=$SPECKIT_OPENCODE_STATE_DIR\"\\n'\n1454:         + `echo \"LINEAGE_ID=$SPECKIT_FANOUT_LINEAGE_ID\"\\n${writeFanoutArtifactsShell()}\\nexit 0\\n`,\n1455:       { mode: 0o755 },\n1456:     );\n1457:     return stubPath;\n1458:   }\n1459: \n1460:   async function runOpencodeSeat(\n1461:     parentStack: string | undefined,\n1462:   ): Promise<string> {\n1463:     const binDir = makeTempDir('fanout-run-stack-bin-');\n1464:     writeStackEchoStub(binDir, 'opencode');\n1465:     const baseDir = makeTempDir('fanout-run-stack-base-');\n1466: \n1467:     const fanoutConfig = JSON.stringify({\n1468:       executors: [{ label: 'seat-a', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n1469:       concurrency: 1,\n1470:     });\n1471: \n1472:     const hermetic = useHermeticEnv(`stack-${parentStack ?? 'empty'}`);\n1473:     const env = envWithBin(hermetic, binDir);\n1474:     if (parentStack === undefined) {\n1475:       delete env['SPECKIT_CLI_DISPATCH_STACK'];\n1476:     } else {\n1477:       env['SPECKIT_CLI_DISPATCH_STACK'] = parentStack;\n1478:     }\n1479: \n1480:     await spawnCjs(\n\n(Showing lines 1376-1480 of 1597. Use offset=1481 to continue.)\n</content>","metadata":{"preview":"describe('fanout-run.cjs — buildLineageCommand / buildLoopPrompt via echo stub', () => {\n  async function runOpencodeEcho(\n    lineage: Record<string, unknown>,\n    loopType: 'research' | 'review',\n  ): Promise<{ stdout: string; baseDir: string }> {\n    const binDir = makeTempDir('fanout-run-echo-bin-');\n    writeEchoStubBinary(binDir, 'opencode');\n    const baseDir = makeTempDir('fanout-run-echo-base-');\n\n    const fanoutConfig = JSON.stringify({\n      executors: [{ ...lineage, kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n      concurrency: 1,\n    });\n\n    const hermetic = useHermeticEnv(`echo-${String(lineage['label'] ?? 'lineage')}`);\n    await spawnCjs(\n      fanoutRunScript,\n      [\n        '--spec-folder',\n        'specs/test-fanout-run-echo',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fanout-run.vitest.ts","text":"describe('fanout-run.cjs — buildLineageCommand / buildLoopPrompt via echo stub', () => {\n  async function runOpencodeEcho(\n    lineage: Record<string, unknown>,\n    loopType: 'research' | 'review',\n  ): Promise<{ stdout: string; baseDir: string }> {\n    const binDir = makeTempDir('fanout-run-echo-bin-');\n    writeEchoStubBinary(binDir, 'opencode');\n    const baseDir = makeTempDir('fanout-run-echo-base-');\n\n    const fanoutConfig = JSON.stringify({\n      executors: [{ ...lineage, kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n      concurrency: 1,\n    });\n\n    const hermetic = useHermeticEnv(`echo-${String(lineage['label'] ?? 'lineage')}`);\n    await spawnCjs(\n      fanoutRunScript,\n      [\n        '--spec-folder',\n        'specs/test-fanout-run-echo',\n        '--loop-type',\n        loopType,\n        '--fanout-config-json',\n        fanoutConfig,\n        '--base-artifact-dir',\n        baseDir,\n      ],\n      {\n        cwd: hermetic.tmpDir,\n        env: envWithBin(hermetic, binDir),\n        timeoutMs: 15_000,\n      },\n    );\n\n    const label = String(lineage['label']);\n    const stdout = readFileSync(\n      join(baseDir, 'lineages', label, 'logs', 'fanout-lineage.out'),\n      'utf8',\n    );\n    return { stdout, baseDir };\n  }\n\n  it('omits --variant from opencode argv when reasoningEffort is unset', async () => {\n    const { stdout } = await runOpencodeEcho({ label: 'no-variant' }, 'research');\n    const argvLine = stdout.split('\\n').find((l) => l.startsWith('ARGV:')) ?? '';\n    expect(argvLine).not.toContain('--variant');\n  });\n\n  it('includes --variant in opencode argv when reasoningEffort is set', async () => {\n    const { stdout } = await runOpencodeEcho({ label: 'with-variant', reasoningEffort: 'high' }, 'research');\n    const argvLine = stdout.split('\\n').find((l) => l.startsWith('ARGV:')) ?? '';\n    expect(argvLine).toContain('--variant high');\n  });\n\n  it('adds config.maxIterations to the prompt when lineage.iterations is set (A3)', async () => {\n    const { stdout } = await runOpencodeEcho({ label: 'capped', iterations: 4 }, 'research');\n    expect(stdout).toContain('config.maxIterations: 4');\n    expect(stdout).toContain('whichever comes first');\n  });\n\n  it('omits config.maxIterations from the prompt when iterations is null (A3)', async () => {\n    const { stdout } = await runOpencodeEcho({ label: 'uncapped' }, 'research');\n    expect(stdout).not.toContain('config.maxIterations');\n    expect(stdout).toContain('(to legal convergence)');\n  });\n});\n\ndescribe('fanout-run.cjs — recursion-guard dispatch stack (SPECKIT_CLI_DISPATCH_STACK)', () => {\n  /**\n   * Write a stub that echoes the dispatch-stack env var (and the per-replica\n   * state-dir env) so the test can assert the spawned seat's environment.\n   */\n  function writeStackEchoStub(binDir: string, name: string): string {\n    const stubPath = join(binDir, name);\n    writeFileSync(\n      stubPath,\n      '#!/bin/sh\\necho \"DISPATCH_STACK=$SPECKIT_CLI_DISPATCH_STACK\"\\n'\n        + 'echo \"STATE_DIR=$SPECKIT_OPENCODE_STATE_DIR\"\\n'\n        + `echo \"LINEAGE_ID=$SPECKIT_FANOUT_LINEAGE_ID\"\\n${writeFanoutArtifactsShell()}\\nexit 0\\n`,\n      { mode: 0o755 },\n    );\n    return stubPath;\n  }\n\n  async function runOpencodeSeat(\n    parentStack: string | undefined,\n  ): Promise<string> {\n    const binDir = makeTempDir('fanout-run-stack-bin-');\n    writeStackEchoStub(binDir, 'opencode');\n    const baseDir = makeTempDir('fanout-run-stack-base-');\n\n    const fanoutConfig = JSON.stringify({\n      executors: [{ label: 'seat-a', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n      concurrency: 1,\n    });\n\n    const hermetic = useHermeticEnv(`stack-${parentStack ?? 'empty'}`);\n    const env = envWithBin(hermetic, binDir);\n    if (parentStack === undefined) {\n      delete env['SPECKIT_CLI_DISPATCH_STACK'];\n    } else {\n      env['SPECKIT_CLI_DISPATCH_STACK'] = parentStack;\n    }\n\n    await spawnCjs(","lineStart":1376,"lineEnd":1480,"totalLines":1597,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/tests/unit/fanout-run.vitest.ts","time":{"start":1782884703066,"end":1782884703081}},"metadata":{"openai":{"itemId":"fc_0999bdee91159103016a44a95eea908191a1ba02a9c2375210"}},"id":"prt_f1c359b13001abqeUjeK3Yxdl0","sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","messageID":"msg_f1c35493c001k96bwSqL69O5dP"}}
