{"type":"tool_use","timestamp":1780741923612,"sessionID":"ses_16384c52effeHJzY2mg4EmA5Ud","part":{"type":"tool","tool":"read","callID":"call_2d8030c656c8438a8c2aabed","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","limit":100,"offset":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n700: };\n701: \n702: // ───────────────────────────────────────────────────────────────\n703: // 3. AGGREGATED DEFINITIONS\n704: \n705: // ───────────────────────────────────────────────────────────────\n706: /**\n707:  * Canonical ordered list of MCP tool registrations exposed by this server.\n708:  */\n709: export const TOOL_DEFINITIONS: ToolDefinition[] = [\n710:   // L1: Orchestration\n711:   memoryContext,\n712:   sessionResume,\n713:   sessionBootstrap,\n714:   // L2: Core\n715:   memorySearch,\n716:   memoryQuickSearch,\n717:   memoryMatchTriggers,\n718:   memorySave,\n719:   // L3: Discovery\n720:   memoryList,\n721:   memoryStats,\n722:   memoryHealth,\n723:   sessionHealth,\n724:   // L4: Mutation\n725:   memoryDelete,\n726:   memoryUpdate,\n727:   memoryValidate,\n728:   memoryBulkDelete,\n729:   memoryRetentionSweep,\n730:   memoryEmbeddingReconcile,\n731:   // L5: Lifecycle\n732:   checkpointCreate,\n733:   checkpointList,\n734:   checkpointRestore,\n735:   checkpointDelete,\n736:   // L6: Analysis\n737:   taskPreflight,\n738:   taskPostflight,\n739:   memoryDriftWhy,\n740:   memoryCausalLink,\n741:   memoryCausalStats,\n742:   memoryCausalUnlink,\n743:   evalRunAblation,\n744:   evalReportingDashboard,\n745:   // L7: Maintenance\n746:   memoryIndexScan,\n747:   memoryGetLearningHistory,\n748:   memoryIngestStart,\n749:   memoryIngestStatus,\n750:   memoryIngestCancel,\n751:   embedderList,\n752:   embedderSet,\n753:   embedderStatus,\n754:   // L8: Code Graph schemas live in system-code-graph\n755:   // L8: Skill Graph schemas live in system-skill-advisor\n756: ];\n\n(End of file - total 756 lines)\n</content>","metadata":{"preview":"};\n\n// ───────────────────────────────────────────────────────────────\n// 3. AGGREGATED DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Canonical ordered list of MCP tool registrations exposed by this server.\n */\nexport const TOOL_DEFINITIONS: ToolDefinition[] = [\n  // L1: Orchestration\n  memoryContext,\n  sessionResume,\n  sessionBootstrap,\n  // L2: Core\n  memorySearch,\n  memoryQuickSearch,\n  memoryMatchTriggers,\n  memorySave,\n  // L3: Discovery","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","text":"};\n\n// ───────────────────────────────────────────────────────────────\n// 3. AGGREGATED DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Canonical ordered list of MCP tool registrations exposed by this server.\n */\nexport const TOOL_DEFINITIONS: ToolDefinition[] = [\n  // L1: Orchestration\n  memoryContext,\n  sessionResume,\n  sessionBootstrap,\n  // L2: Core\n  memorySearch,\n  memoryQuickSearch,\n  memoryMatchTriggers,\n  memorySave,\n  // L3: Discovery\n  memoryList,\n  memoryStats,\n  memoryHealth,\n  sessionHealth,\n  // L4: Mutation\n  memoryDelete,\n  memoryUpdate,\n  memoryValidate,\n  memoryBulkDelete,\n  memoryRetentionSweep,\n  memoryEmbeddingReconcile,\n  // L5: Lifecycle\n  checkpointCreate,\n  checkpointList,\n  checkpointRestore,\n  checkpointDelete,\n  // L6: Analysis\n  taskPreflight,\n  taskPostflight,\n  memoryDriftWhy,\n  memoryCausalLink,\n  memoryCausalStats,\n  memoryCausalUnlink,\n  evalRunAblation,\n  evalReportingDashboard,\n  // L7: Maintenance\n  memoryIndexScan,\n  memoryGetLearningHistory,\n  memoryIngestStart,\n  memoryIngestStatus,\n  memoryIngestCancel,\n  embedderList,\n  embedderSet,\n  embedderStatus,\n  // L8: Code Graph schemas live in system-code-graph\n  // L8: Skill Graph schemas live in system-skill-advisor\n];","lineStart":700,"lineEnd":756,"totalLines":756,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1780741923603,"end":1780741923610}},"id":"prt_e9c7d6310001PHIEh5tKEgnZ1A","sessionID":"ses_16384c52effeHJzY2mg4EmA5Ud","messageID":"msg_e9c7d597d001JJl3PI2ewxImum"}}
{"type":"tool_use","timestamp":1780741924300,"sessionID":"ses_16384c52effeHJzY2mg4EmA5Ud","part":{"type":"tool","tool":"read","callID":"call_36060850e7004407bd035b26","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","limit":100,"offset":680},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts</path>\n<type>file</type>\n<content>\n680: \n681: export function getToolSchema(toolName: string): ToolInputSchema | null {\n682:   return TOOL_SCHEMAS[toolName] ?? null;\n683: }\n684: \n685: export function validateToolArgs(toolName: string, rawInput: Record<string, unknown>): ToolInput {\n686:   const schema = getToolSchema(toolName);\n687:   if (!schema) {\n688:     throw new ToolSchemaValidationError(toolName, `Unknown tool: \"${toolName}\". No schema registered.`, {\n689:       tool: toolName,\n690:       issues: ['unknown_tool'],\n691:       unknownParameters: [],\n692:       expectedParameters: [],\n693:     });\n694:   }\n695: \n696:   try {\n697:     return schema.parse(rawInput);\n698:   } catch (error: unknown) {\n699:     if (error instanceof ZodError) {\n700:       const formatted = formatZodError(toolName, error);\n701:       // Log rejected params for audit trail (MCP uses stderr)\n702:       console.error(`[schema-validation] ${toolName}: ${formatted.message}`);\n703:       throw formatted;\n704:     }\n705:     throw new Error('Schema validation encountered an unexpected error');\n706:   }\n707: }\n\n(End of file - total 707 lines)\n</content>","metadata":{"preview":"\nexport function getToolSchema(toolName: string): ToolInputSchema | null {\n  return TOOL_SCHEMAS[toolName] ?? null;\n}\n\nexport function validateToolArgs(toolName: string, rawInput: Record<string, unknown>): ToolInput {\n  const schema = getToolSchema(toolName);\n  if (!schema) {\n    throw new ToolSchemaValidationError(toolName, `Unknown tool: \"${toolName}\". No schema registered.`, {\n      tool: toolName,\n      issues: ['unknown_tool'],\n      unknownParameters: [],\n      expectedParameters: [],\n    });\n  }\n\n  try {\n    return schema.parse(rawInput);\n  } catch (error: unknown) {\n    if (error instanceof ZodError) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","text":"\nexport function getToolSchema(toolName: string): ToolInputSchema | null {\n  return TOOL_SCHEMAS[toolName] ?? null;\n}\n\nexport function validateToolArgs(toolName: string, rawInput: Record<string, unknown>): ToolInput {\n  const schema = getToolSchema(toolName);\n  if (!schema) {\n    throw new ToolSchemaValidationError(toolName, `Unknown tool: \"${toolName}\". No schema registered.`, {\n      tool: toolName,\n      issues: ['unknown_tool'],\n      unknownParameters: [],\n      expectedParameters: [],\n    });\n  }\n\n  try {\n    return schema.parse(rawInput);\n  } catch (error: unknown) {\n    if (error instanceof ZodError) {\n      const formatted = formatZodError(toolName, error);\n      // Log rejected params for audit trail (MCP uses stderr)\n      console.error(`[schema-validation] ${toolName}: ${formatted.message}`);\n      throw formatted;\n    }\n    throw new Error('Schema validation encountered an unexpected error');\n  }\n}","lineStart":680,"lineEnd":707,"totalLines":707,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","time":{"start":1780741924294,"end":1780741924298}},"id":"prt_e9c7d65c3001mLicwTMisSkYf7","sessionID":"ses_16384c52effeHJzY2mg4EmA5Ud","messageID":"msg_e9c7d597d001JJl3PI2ewxImum"}}
