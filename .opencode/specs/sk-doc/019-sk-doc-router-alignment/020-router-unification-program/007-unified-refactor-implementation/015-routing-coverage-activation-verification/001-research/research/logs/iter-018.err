   532	        ? stageM[1]
   533	        : 'routing';
   534	      const expectedRankBelowSkillIds = parseFrontmatterList(block, [
   535	        'rankBelowSkillIds',
   536	        'rank_below_skill_ids',
   537	        'expected_rank_below_skill_ids',
   538	      ]);
   539	      const expectedLeafResources = parseLeafResourceGold(block);
   540	      const fullInventoryIntent = parseFrontmatterBool(block, 'full_inventory_intent');
