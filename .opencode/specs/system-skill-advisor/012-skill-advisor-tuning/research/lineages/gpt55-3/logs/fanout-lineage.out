ode/code-webflow/assets/patterns/wait_patterns.js\",\n      \".opencode/skills/sk-code/code-webflow/references/implementation/implementation_workflows.md\",\n      \".opencode/skills/sk-code/code-opencode/references/shared/universal_patterns.md\",\n      \".opencode/skills/sk-code/code-opencode/assets/scripts/verify_alignment_drift.py\",\n      \".opencode/skills/sk-code/code-webflow/SKILL.md\",\n      \".opencode/skills/sk-code/code-opencode/SKILL.md\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"sk-code\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/sk-code/SKILL.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"motion_dev\",\n        \"kind\": \"reference\",\n        \"path\": \".opencode/skills/sk-code/code-webflow/references/animation/quick_start.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"code_surface_detection\",\n        \"kind\": \"reference\",\n        \"path\": \".opencode/skills/sk-code/shared/references/stack_detection.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"verify_alignment_drift\",\n        \"kind\": \"script\",\n        \"path\": \".opencode/skills/sk-code/code-opencode/assets/scripts/verify_alignment_drift.py\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"sk-code is the single public code skill that routes a request through mode-registry.json to two workflow modes (quality, code-review) or bundles one of two read-only surface evidence packets (code-webflow, code-opencode) over a shared surface-detection router. Each surface carries the shared implement/debug/verify workflow doctrine plus its stack knowledge; code-webflow also carries the Motion.dev animation overlay. The shared router centralizes WEBFLOW, OPENCODE, and MOTION_DEV identity and precedence so the advisor sees exactly one code identity.\",\n    \"created_at\": \"2026-04-30T08:30:00Z\",\n    \"last_updated_at\": \"20