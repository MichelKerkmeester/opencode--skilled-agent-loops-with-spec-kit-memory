-store.js';\nimport { startFileWatcher, type FSWatcher } from './lib/ops/file-watcher.js';\nimport { getCanonicalPathKey } from './lib/utils/canonical-path.js';\nimport { runBatchLearning } from './lib/feedback/batch-learning.js';\nimport { getSessionSnapshot } from './lib/session/session-snapshot.js';\nimport { resumeReindexJobs } from './lib/embedders/reindex.js';\nimport { ensureActiveEmbedder } from './lib/embedders/schema.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  error?: string;\n  [key: string]: unknown;\n}\n\ninterface PendingRecoveryResult {\n  found: number;\n  processed: number;\n  recovered: number;\n  failed: number;\n  results: unknown[];\n}\n\ninterface ApiKeyValidation {\n  valid: boolean;\n  provider?: string;\n  error?: string;\n  errorCode?: string;\n  warning?: string;\n  actions?: string[];\n  networkError?: boolean;\n}\n\ninterface AutoSurfaceResult {\n  constitutional: unknown[];\n  triggered: unknown[];\n  codeGraphStatus?: {\n    status: 'ok' | 'error';\n    data?: Record<string, unknown>;\n    error?: string;\n  };\n  sessionPrimed?: boolean;\n  primedTool?: string;\n  /** Structured Prime Package for non-hook CLI auto-priming */\n  primePackage?: {\n    specFolder: string | null;\n    currentTask: string | null;\n    codeGraphStatus: 'fresh' | 'stale' | 'empty';\n    recommendedCalls: string[];\n  };\n  surfaced_at?: string;\n  latencyMs?: number;\n}\n\ninterface ToolCallResponse {\n  content: Array<{ type: string; text: string }>;\n  isError?: boolean;\n  structuredContent?: unknown;\n  [key: string]: unknown;\n}\n\ninterface DynamicMemoryStats {\n  totalMemories: number;\n  specFolderCount: number;\n  activeCount: number;\n  staleCount: number;\n}\n\ntype AfterToolCallback = (tool: string, callId: string, result: unknown) => Promise<void>;\ntype BootFtsIntegrityHealth = 'unknown' | 'skipped' | 'ok' | 'corrupt' | 'repaired';\n\nconst afterToolCallbacks: Array<AfterToolCallback> = [];\n\n/** Timeout (ms) for API key validation during startup. */\nconst API_KEY_VALIDATION_TIMEOUT_MS = 5_000;\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\nconst FTS_CORRUPTION_RUNBOOK =\n  '.opencode/specs/system-spec-kit/026-graph-and-context-optimization/004-code-graph/012-empty-graph-first-time-auto-scan/bug-report-memory-db-corruption.md';\n\nconst GRAPH_ENRICHMENT_TIMEOUT_MS = 250;\nconst GRAPH_ENRICHMENT_OUTLINE_LIMIT = 6;\nconst GRAPH_ENRICHMENT_NEIGHBOR_LIMIT = 6;\nconst GRAPH_ENRICHMENT_SYMBOL_LIMIT = 4;\nconst GRAPH_CONTEXT_EXCLUDED_TOOLS = new Set<string>([\n  ...MEMORY_AWARE_TOOLS,\n  // Code-graph MCP tools route through standalone mk-code-index\n]);\n\nconst MEMORY_RUNTIME_TOOL_NAMES = new Set<string>([\n  'memory_context',\n  'memory_search',\n  'memory_quick_search',\n  'memory_match_triggers',\n  'memory_save',\n  'memory_list',\n  'memory_stats',\n  'memory_delete',\n  'memory_update',\n  'memory_validate',\n  'memory_bulk_delete',\n  'memory_retention_sweep',\n  'memory_embedding_reconcile',\n  'memory_index_scan',\n  'memory_index_scan_status',\n  'memory_index_scan_cancel',\n  'memory_ingest_start',","lineStart":1,"lineEnd":260,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781763091734,"end":1781763091738}},"metadata":{"openai":{"itemId":"fc_009ec8241b1c17e7016a338c1398a081918a250cd1f558a849"}},"id":"prt_ed95b2cd5001tCI2Y4iQg6SBd0","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95aff680016dLp35yAqGqnDO"}}
{"type":"tool_use","timestamp":1781763091749,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_o9DFRvPoXLllZPELVN7PTGva","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC Socket Server (multi-client launcher bridge)\n3: // ───────────────────────────────────────────────────────────────\n4: // Thin re-export of the canonical bridge logic. The bind/reclaim/serve\n5: // behaviour (including the race-safe stale-socket fence and the dir\n6: // ownership/mode hardening) is shared across every daemon launcher so\n7: // the security contract cannot drift between services. Per-service\n8: // socket/db PATHS remain owned by each package's own resolution code.\n9: \n10: export {\n11:   canUnlinkExistingSocket,\n12:   getIpcBridgeStats,\n13:   parseMaxClients,\n14:   resolveIpcSocketPath,\n15:   startIpcSocketServer,\n16: } from '@spec-kit/shared/ipc/socket-server.js';\n17: \n18: export type {\n19:   IpcBridgeStats,\n20:   IpcSocketServerHandle,\n21:   IpcSocketServerOptions,\n22: } from '@spec-kit/shared/ipc/socket-server.js';\n\n(End of file - total 22 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Thin re-export of the canonical bridge logic. The bind/reclaim/serve\n// behaviour (including the race-safe stale-socket fence and the dir\n// ownership/mode hardening) is shared across every daemon launcher so\n// the security contract cannot drift between services. Per-service\n// socket/db PATHS remain owned by each package's own resolution code.\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n} from '@spec-kit/shared/ipc/socket-server.js';\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Thin re-export of the canonical bridge logic. The bind/reclaim/serve\n// behaviour (including the race-safe stale-socket fence and the dir\n// ownership/mode hardening) is shared across every daemon launcher so\n// the security contract cannot drift between services. Per-service\n// socket/db PATHS remain owned by each package's own resolution code.\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n} from '@spec-kit/shared/ipc/socket-server.js';\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,\n  IpcSocketServerOptions,\n} from '@spec-kit/shared/ipc/socket-server.js';","lineStart":1,"lineEnd":22,"totalLines":22,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts","time":{"start":1781763091746,"end":1781763091748}},"metadata":{"openai":{"itemId":"fc_009ec8241b1c17e7016a338c1398b4819190a1bbbfb56e379f"}},"id":"prt_ed95b2d1b001045D8JGtKhLkOq","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95aff680016dLp35yAqGqnDO"}}
{"type":"tool_use","timestamp":1781763091772,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_dSg4VPDSYnzGl20TWwoLoBkC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","offset":720,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts</path>\n<type>file</type>\n<content>\n720: \n721:   return previous[right.length];\n722: }\n723: \n724: function closestCommand(command: string): string | undefined {\n725:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n726:   targets.set('completion', 'completion');\n727:   for (const tool of TOOL_DEFINITIONS) {\n728:     for (const alias of commandAliases(tool.name)) {\n729:       targets.set(alias, tool.name);\n730:     }\n731:   }\n732: \n733:   let best: { readonly command: string; readonly distance: number } | null = null;\n734:   for (const [alias, canonical] of targets) {\n735:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n736:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n737:       best = { command: canonical, distance };\n738:     }\n739:   }\n740: \n741:   if (!best) return undefined;\n742:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n743:   return best.distance <= threshold ? best.command : undefined;\n744: }\n745: \n746: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n747:   const match = message.match(/^Unknown command: (.+)$/);\n748:   if (!match) return null;\n749:   return {\n750:     hint: 'Try `list-tools` to see available commands.',\n751:     suggestion: closestCommand(match[1]),\n752:   };\n753: }\n754: \n755: function socketPathTooLong(socketPath: string): boolean {\n756:   if (socketPath.startsWith('tcp://')) return false;\n757:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n758: }\n759: \n760: // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n761: // (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n762: // mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n763: // a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n764: // symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\n765: function assertSocketPerimeter(socketDir: string): void {\n766:   const dirLink = lstatSync(socketDir);\n767:   if (dirLink.isSymbolicLink()) {\n768:     throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n769:   }\n770:   const dirStat = statSync(socketDir);\n771:   const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n772:   if (uid !== null && dirStat.uid !== uid) {\n773:     throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n774:   }\n775:   if ((dirStat.mode & 0o022) !== 0) {\n776:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n777:   }\n778:   const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n779:   let nodeLink;\n780:   try {\n781:     nodeLink = lstatSync(socketPath);\n782:   } catch (error: unknown) {\n783:     const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n784:     if (code === 'ENOENT') return;\n785:     throw error;\n786:   }\n787:   if (nodeLink.isSymbolicLink()) {\n788:     throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n789:   }\n790:   if (uid !== null && nodeLink.uid !== uid) {\n791:     throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n792:   }\n793: }\n794: \n795: function ensureSocketEnvironment(): void {\n796:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n797:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n798:   }\n799:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n800:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n801:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n802:   assertSocketPerimeter(socketDir);\n803: }\n804: \n805: function sleep(ms: number): Promise<void> {\n806:   return new Promise((resolve) => setTimeout(resolve, ms));\n807: }\n808: \n809: function spawnLauncher(paths: RepoPaths): void {\n810:   const child = spawn(process.execPath, [paths.launcherPath], {\n811:     cwd: paths.repoRoot,\n812:     env: process.env,\n813:     detached: true,\n814:     stdio: 'ignore',\n815:   });\n816:   child.unref();\n817: }\n818: \n819: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n820:   const deadline = Date.now() + timeoutMs;\n821:   let lastReason = 'not probed';\n822: \n823:   while (Date.now() <= deadline) {\n824:     const remaining = Math.max(1, deadline - Date.now());\n825:     const probe = await bridge.probeDaemon(socketPath, {\n826:       timeoutMs: Math.min(remaining, 5000),\n827:       deepProbe: true,\n828:     });\n829:     if (probe.status === 'alive') return;\n830:     lastReason = probe.reason ?? probe.status;\n831:     await sleep(100);\n832:   }\n833: \n834:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n835: }\n836: \n837: class JsonRpcSocketClient {\n838:   private nextId = 1;\n839:   private readonly decoder = new StringDecoder('utf8');\n840: \n841:   private constructor(\n842:     private readonly socket: net.Socket,\n843:   ) {}\n844: \n845:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n846:     return new Promise((resolve, reject) => {\n847:       let socket: net.Socket;\n848:       let settled = false;\n849:       const finish = (error?: Error): void => {\n850:         if (settled) return;\n851:         settled = true;\n852:         clearTimeout(timer);\n853:         socket.off?.('connect', onConnect);\n854:         socket.off?.('error', onError);\n855:         if (error) {\n856:           socket.destroy?.();\n857:           reject(error);\n858:           return;\n859:         }\n860:         resolve(new JsonRpcSocketClient(socket));\n861:       };\n862:       const onConnect = (): void => finish();\n863:       const onError = (error: Error): void => finish(error);\n864:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n865:       timer.unref?.();\n866: \n867:       try {\n868:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n869:         socket = typeof connectionOptions === 'string'\n870:           ? net.createConnection(connectionOptions)\n871:           : net.createConnection(connectionOptions);\n872:       } catch (error: unknown) {\n873:         clearTimeout(timer);\n874:         reject(error instanceof Error ? error : new Error(String(error)));\n875:         return;\n876:       }\n877:       socket.once('connect', onConnect);\n878:       socket.once('error', onError);\n879:     });\n880:   }\n881: \n882:   notify(method: string, params?: unknown): void {\n883:     const frame = params === undefined\n884:       ? { jsonrpc: '2.0', method }\n885:       : { jsonrpc: '2.0', method, params };\n886:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n887:   }\n888: \n889:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n890:     const id = this.nextId++;\n891:     const request = { jsonrpc: '2.0', id, method, params };\n892:     return new Promise((resolve, reject) => {\n893:       let buffer = '';\n894:       let settled = false;\n895: \n896:       const cleanup = (): void => {\n897:         clearTimeout(timer);\n898:         this.socket.off('data', onData);\n899:         this.socket.off('error', onError);\n900:         this.socket.off('close', onClose);\n901:       };\n902:       const finish = (error: unknown, value?: unknown): void => {\n903:         if (settled) return;\n904:         settled = true;\n905:         cleanup();\n906:         if (error) {\n907:           reject(error);\n908:           return;\n909:         }\n910:         resolve(value);\n911:       };\n912:       const onData = (chunk: Buffer | string): void => {\n913:         buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n914:         let newlineIndex = buffer.indexOf('\\n');\n915:         while (newlineIndex !== -1) {\n916:           const line = buffer.slice(0, newlineIndex).trim();\n917:           buffer = buffer.slice(newlineIndex + 1);\n918:           newlineIndex = buffer.indexOf('\\n');\n919:           if (!line) continue;\n920:           let parsed: JsonRpcResponse;\n921:           try {\n922:             parsed = JSON.parse(line) as JsonRpcResponse;\n923:           } catch {\n924:             continue;\n925:           }\n926:           if (parsed.id !== id) continue;\n927:           if (parsed.error) {\n928:             finish(new JsonRpcError(parsed.error));\n929:             return;\n930:           }\n931:           finish(null, parsed.result);\n932:           return;\n933:         }\n934:       };\n935:       const onError = (error: Error): void => finish(error);\n936:       const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n937:       const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n938:       timer.unref?.();\n939: \n940:       this.socket.on('data', onData);\n941:       this.socket.once('error', onError);\n942:       this.socket.once('close', onClose);\n943:       this.socket.write(`${JSON.stringify(request)}\\n`);\n944:     });\n945:   }\n946: \n947:   close(): void {\n948:     this.socket.end();\n949:     this.socket.destroy();\n950:   }\n951: }\n952: \n953: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n954:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n955:   if (initialProbe.status === 'alive') return;\n956:   if (warmOnly) {\n957:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n958:   }\n959:   spawnLauncher(paths);\n960:   await waitForDaemon(socketPath, bridge, timeoutMs);\n961: }\n962: \n963: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n964:   ensureSocketEnvironment();\n965:   const paths = findRepoPaths();\n966:   const bridge = loadBridge(paths);\n967:   const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n968:   if (socketPathTooLong(socketPath)) {\n969:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n970:   }\n971: \n972:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n973: \n974:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n975:   try {\n976:     const initialize = await client.request('initialize', {\n977:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n978:       capabilities: {},\n979:       clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n980:     }, timeoutMs) as InitializeResult;\n981:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n982:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n983:     }\n984:     client.notify('notifications/initialized');\n985:     return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n986:   } finally {\n987:     client.close();\n988:   }\n989: }\n990: \n991: export async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n992:   try {\n993:     const parsed = parseCliArgs(argv);\n994:     if (parsed.help) {\n995:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n996:       return EXIT_SUCCESS;\n997:     }\n998:     if (parsed.version) {\n999:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n1000:       return EXIT_SUCCESS;\n1001:     }\n1002:     if (parsed.command === 'list-tools') {\n1003:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n1004:       return EXIT_SUCCESS;\n1005:     }\n1006:     if (parsed.command === 'completion') {\n1007:       if (!parsed.completionShell) {\n1008:         throw new CliUsageError('completion requires a shell: bash or zsh');\n1009:       }\n1010:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n1011:       return EXIT_SUCCESS;\n1012:     }\n1013: \n1014:     const validated = validateCommand(parsed);\n1015:     if (!validated) {\n1016:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n1017:     }\n1018:     const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n1019:     const { payload, isError } = extractToolPayload(validated.tool.name, result);\n1020:     await writeLine(io.stdout, renderPayload(payload, parsed.format));\n1021:     return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n1022:   } catch (error: unknown) {\n1023:     const exitCode = exitCodeForError(error);\n1024:     const message = error instanceof Error ? error.message : String(error);\n1025:     const unknownCommand = unknownCommandContext(message);\n1026:     const payload = {\n1027:       status: 'error',\n1028:       error: message,\n1029:       exitCode,\n1030:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n1031:       ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n1032:     };\n1033:     const format = (() => {\n1034:       try {\n1035:         return parseCliArgs(argv).format;\n1036:       } catch {\n1037:         return 'text' as OutputFormat;\n1038:       }\n1039:     })();\n1040:     if (format === 'json' || format === 'jsonl') {\n1041:       await writeLine(io.stderr, renderJson(payload, format));\n1042:     } else {\n1043:       await writeLine(io.stderr, [\n1044:         `ERROR: ${message}`,\n1045:         unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n1046:         unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n1047:       ].filter((line): line is string => Boolean(line)).join('\\n'));\n1048:     }\n1049:     return exitCode;\n1050:   }\n1051: }\n1052: \n1053: function isCliEntrypoint(): boolean {\n1054:   const invoked = process.argv[1];\n1055:   if (!invoked) return false;\n1056:   return path.resolve(invoked) === path.resolve(currentModulePath());\n1057: }\n1058: \n1059: export const __testing = {\n1060:   DEFAULT_SOCKET_DIR,\n1061:   EXIT_PROTOCOL,\n1062:   EXIT_RETRYABLE,\n1063:   EXIT_RUNTIME,\n1064:   EXIT_USAGE,\n1065:   commandMap,\n1066:   commandAliases,\n1067:   assertSocketPerimeter,\n1068:   ensureSocketEnvironment,\n1069:   exitCodeForError,\n1070:   findRepoPaths,\n1071:   isErrorPayload,\n1072:   closestCommand,\n1073:   renderCompletion,\n1074:   renderToolList,\n1075:   resolvePropertyName,\n1076: };\n1077: \n1078: if (isCliEntrypoint()) {\n1079:   // Natural exit via process.exitCode: a hard process.exit() drops any\n1080:   // stdout bytes still queued behind the kernel pipe buffer, truncating\n1081:   // large payloads. Pending pipe writes keep the event loop alive until\n1082:   // they flush; all sockets and timers are closed or unref'd by here.\n1083:   process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n1084: }\n\n(End of file - total 1084 lines)\n</content>","metadata":{"preview":"\n  return previous[right.length];\n}\n\nfunction closestCommand(command: string): string | undefined {\n  const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n  targets.set('completion', 'completion');\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      targets.set(alias, tool.name);\n    }\n  }\n\n  let best: { readonly command: string; readonly distance: number } | null = null;\n  for (const [alias, canonical] of targets) {\n    const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n    if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n      best = { command: canonical, distance };\n    }\n  }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"\n  return previous[right.length];\n}\n\nfunction closestCommand(command: string): string | undefined {\n  const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n  targets.set('completion', 'completion');\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      targets.set(alias, tool.name);\n    }\n  }\n\n  let best: { readonly command: string; readonly distance: number } | null = null;\n  for (const [alias, canonical] of targets) {\n    const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n    if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n      best = { command: canonical, distance };\n    }\n  }\n\n  if (!best) return undefined;\n  const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n  return best.distance <= threshold ? best.command : undefined;\n}\n\nfunction unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n  const match = message.match(/^Unknown command: (.+)$/);\n  if (!match) return null;\n  return {\n    hint: 'Try `list-tools` to see available commands.',\n    suggestion: closestCommand(match[1]),\n  };\n}\n\nfunction socketPathTooLong(socketPath: string): boolean {\n  if (socketPath.startsWith('tcp://')) return false;\n  return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n}\n\n// `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n// (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n// mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n// a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n// symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\nfunction assertSocketPerimeter(socketDir: string): void {\n  const dirLink = lstatSync(socketDir);\n  if (dirLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n  }\n  const dirStat = statSync(socketDir);\n  const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n  if (uid !== null && dirStat.uid !== uid) {\n    throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n  }\n  if ((dirStat.mode & 0o022) !== 0) {\n    throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n  }\n  const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n  let nodeLink;\n  try {\n    nodeLink = lstatSync(socketPath);\n  } catch (error: unknown) {\n    const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n    if (code === 'ENOENT') return;\n    throw error;\n  }\n  if (nodeLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n  }\n  if (uid !== null && nodeLink.uid !== uid) {\n    throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n  }\n}\n\nfunction ensureSocketEnvironment(): void {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (!socketDir || socketDir.startsWith('tcp://')) return;\n  mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  assertSocketPerimeter(socketDir);\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction spawnLauncher(paths: RepoPaths): void {\n  const child = spawn(process.execPath, [paths.launcherPath], {\n    cwd: paths.repoRoot,\n    env: process.env,\n    detached: true,\n    stdio: 'ignore',\n  });\n  child.unref();\n}\n\nasync function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  let lastReason = 'not probed';\n\n  while (Date.now() <= deadline) {\n    const remaining = Math.max(1, deadline - Date.now());\n    const probe = await bridge.probeDaemon(socketPath, {\n      timeoutMs: Math.min(remaining, 5000),\n      deepProbe: true,\n    });\n    if (probe.status === 'alive') return;\n    lastReason = probe.reason ?? probe.status;\n    await sleep(100);\n  }\n\n  throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n}\n\nclass JsonRpcSocketClient {\n  private nextId = 1;\n  private readonly decoder = new StringDecoder('utf8');\n\n  private constructor(\n    private readonly socket: net.Socket,\n  ) {}\n\n  static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n    return new Promise((resolve, reject) => {\n      let socket: net.Socket;\n      let settled = false;\n      const finish = (error?: Error): void => {\n        if (settled) return;\n        settled = true;\n        clearTimeout(timer);\n        socket.off?.('connect', onConnect);\n        socket.off?.('error', onError);\n        if (error) {\n          socket.destroy?.();\n          reject(error);\n          return;\n        }\n        resolve(new JsonRpcSocketClient(socket));\n      };\n      const onConnect = (): void => finish();\n      const onError = (error: Error): void => finish(error);\n      const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n      timer.unref?.();\n\n      try {\n        const connectionOptions = bridge.toConnectionOptions(socketPath);\n        socket = typeof connectionOptions === 'string'\n          ? net.createConnection(connectionOptions)\n          : net.createConnection(connectionOptions);\n      } catch (error: unknown) {\n        clearTimeout(timer);\n        reject(error instanceof Error ? error : new Error(String(error)));\n        return;\n      }\n      socket.once('connect', onConnect);\n      socket.once('error', onError);\n    });\n  }\n\n  notify(method: string, params?: unknown): void {\n    const frame = params === undefined\n      ? { jsonrpc: '2.0', method }\n      : { jsonrpc: '2.0', method, params };\n    this.socket.write(`${JSON.stringify(frame)}\\n`);\n  }\n\n  request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n    const id = this.nextId++;\n    const request = { jsonrpc: '2.0', id, method, params };\n    return new Promise((resolve, reject) => {\n      let buffer = '';\n      let settled = false;\n\n      const cleanup = (): void => {\n        clearTimeout(timer);\n        this.socket.off('data', onData);\n        this.socket.off('error', onError);\n        this.socket.off('close', onClose);\n      };\n      const finish = (error: unknown, value?: unknown): void => {\n        if (settled) return;\n        settled = true;\n        cleanup();\n        if (error) {\n          reject(error);\n          return;\n        }\n        resolve(value);\n      };\n      const onData = (chunk: Buffer | string): void => {\n        buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n        let newlineIndex = buffer.indexOf('\\n');\n        while (newlineIndex !== -1) {\n          const line = buffer.slice(0, newlineIndex).trim();\n          buffer = buffer.slice(newlineIndex + 1);\n          newlineIndex = buffer.indexOf('\\n');\n          if (!line) continue;\n          let parsed: JsonRpcResponse;\n          try {\n            parsed = JSON.parse(line) as JsonRpcResponse;\n          } catch {\n            continue;\n          }\n          if (parsed.id !== id) continue;\n          if (parsed.error) {\n            finish(new JsonRpcError(parsed.error));\n            return;\n          }\n          finish(null, parsed.result);\n          return;\n        }\n      };\n      const onError = (error: Error): void => finish(error);\n      const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n      const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n      timer.unref?.();\n\n      this.socket.on('data', onData);\n      this.socket.once('error', onError);\n      this.socket.once('close', onClose);\n      this.socket.write(`${JSON.stringify(request)}\\n`);\n    });\n  }\n\n  close(): void {\n    this.socket.end();\n    this.socket.destroy();\n  }\n}\n\nasync function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n  const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n  if (initialProbe.status === 'alive') return;\n  if (warmOnly) {\n    throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n  }\n  spawnLauncher(paths);\n  await waitForDaemon(socketPath, bridge, timeoutMs);\n}\n\nasync function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n  ensureSocketEnvironment();\n  const paths = findRepoPaths();\n  const bridge = loadBridge(paths);\n  const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n  if (socketPathTooLong(socketPath)) {\n    throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n  }\n\n  await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n\n  const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n  try {\n    const initialize = await client.request('initialize', {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n    }, timeoutMs) as InitializeResult;\n    if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n      throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n    }\n    client.notify('notifications/initialized');\n    return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n  } finally {\n    client.close();\n  }\n}\n\nexport async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n  try {\n    const parsed = parseCliArgs(argv);\n    if (parsed.help) {\n      await writeLine(io.stdout, usageText(parsed.command || undefined));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.version) {\n      await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'list-tools') {\n      await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'completion') {\n      if (!parsed.completionShell) {\n        throw new CliUsageError('completion requires a shell: bash or zsh');\n      }\n      await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n      return EXIT_SUCCESS;\n    }\n\n    const validated = validateCommand(parsed);\n    if (!validated) {\n      throw new CliUsageError(`Unknown command: ${parsed.command}`);\n    }\n    const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n    const { payload, isError } = extractToolPayload(validated.tool.name, result);\n    await writeLine(io.stdout, renderPayload(payload, parsed.format));\n    return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n  } catch (error: unknown) {\n    const exitCode = exitCodeForError(error);\n    const message = error instanceof Error ? error.message : String(error);\n    const unknownCommand = unknownCommandContext(message);\n    const payload = {\n      status: 'error',\n      error: message,\n      exitCode,\n      ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n      ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n    };\n    const format = (() => {\n      try {\n        return parseCliArgs(argv).format;\n      } catch {\n        return 'text' as OutputFormat;\n      }\n    })();\n    if (format === 'json' || format === 'jsonl') {\n      await writeLine(io.stderr, renderJson(payload, format));\n    } else {\n      await writeLine(io.stderr, [\n        `ERROR: ${message}`,\n        unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n        unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n      ].filter((line): line is string => Boolean(line)).join('\\n'));\n    }\n    return exitCode;\n  }\n}\n\nfunction isCliEntrypoint(): boolean {\n  const invoked = process.argv[1];\n  if (!invoked) return false;\n  return path.resolve(invoked) === path.resolve(currentModulePath());\n}\n\nexport const __testing = {\n  DEFAULT_SOCKET_DIR,\n  EXIT_PROTOCOL,\n  EXIT_RETRYABLE,\n  EXIT_RUNTIME,\n  EXIT_USAGE,\n  commandMap,\n  commandAliases,\n  assertSocketPerimeter,\n  ensureSocketEnvironment,\n  exitCodeForError,\n  findRepoPaths,\n  isErrorPayload,\n  closestCommand,\n  renderCompletion,\n  renderToolList,\n  resolvePropertyName,\n};\n\nif (isCliEntrypoint()) {\n  // Natural exit via process.exitCode: a hard process.exit() drops any\n  // stdout bytes still queued behind the kernel pipe buffer, truncating\n  // large payloads. Pending pipe writes keep the event loop alive until\n  // they flush; all sockets and timers are closed or unref'd by here.\n  process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n}","lineStart":720,"lineEnd":1084,"totalLines":1084,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781763091767,"end":1781763091770}},"metadata":{"openai":{"itemId":"fc_009ec8241b1c17e7016a338c1398bc81918b494fabb91b8159"}},"id":"prt_ed95b2d27001RV2jTPXRIWPmJE","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95aff680016dLp35yAqGqnDO"}}
{"type":"tool_use","timestamp":1781763091863,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_8I1nA0SZAjVtSg9pgLlF4WBR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","offset":1,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // --------------------------------------------------------------------------\n3: // COMPONENT: Spec Memory CLI Shim\n4: // PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n5: // --------------------------------------------------------------------------\n6: 'use strict';\n7: \n8: const fs = require('fs');\n9: const path = require('path');\n10: const crypto = require('crypto');\n11: const { spawnSync } = require('child_process');\n12: \n13: const opencodeDir = path.resolve(__dirname, '..');\n14: const mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\n15: const cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\n16: const sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\n17: const defaultSocketDir = '/tmp/mk-spec-memory';\n18: const socketFileName = 'daemon-ipc.sock';\n19: const allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n20: \n21: function fail(message) {\n22:   process.stderr.write(`${message}\\n`);\n23:   process.exit(69);\n24: }\n25: \n26: // Recursively collects the CLI's compiled-source surface (entry, local schema\n27: // imports, tsconfig) so new files under candidate directories are watched\n28: // without editing this list. Must stay in lock-step with\n29: // scripts/finalize-dist.mjs, which writes the matching hash at build time.\n30: function sourceCandidates() {\n31:   const candidates = [\n32:     path.join(mcpServerDir, 'spec-memory-cli.ts'),\n33:     path.join(mcpServerDir, 'tool-schemas.ts'),\n34:     path.join(mcpServerDir, 'tsconfig.json'),\n35:     path.join(mcpServerDir, 'schemas'),\n36:   ];\n37:   const files = [];\n38: \n39:   const visit = (candidate) => {\n40:     if (!fs.existsSync(candidate)) return;\n41:     const stat = fs.statSync(candidate);\n42:     if (stat.isDirectory()) {\n43:       for (const entry of fs.readdirSync(candidate)) {\n44:         visit(path.join(candidate, entry));\n45:       }\n46:       return;\n47:     }\n48:     if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n49:       files.push(candidate);\n50:     }\n51:   };\n52: \n53:   for (const candidate of candidates) visit(candidate);\n54:   return files;\n55: }\n56: \n57: function hashSourceFiles(existingSources) {\n58:   const hash = crypto.createHash('sha256');\n59:   for (const filePath of [...existingSources].sort()) {\n60:     hash.update(path.relative(mcpServerDir, filePath));\n61:     hash.update('\\0');\n62:     hash.update(fs.readFileSync(filePath));\n63:     hash.update('\\0');\n64:   }\n65:   return hash.digest('hex');\n66: }\n67: \n68: function readStoredSourceHash() {\n69:   try {\n70:     const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n71:     return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n72:   } catch {\n73:     return null;\n74:   }\n75: }\n76: \n77: function writeStoredSourceHash(sourceHash) {\n78:   try {\n79:     fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n80:     fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n81:   } catch {\n82:     // Freshness metadata is an optimization; stale detection remains conservative.\n83:   }\n84: }\n85: \n86: function ensureFreshDist() {\n87:   if (!fs.existsSync(cliDist)) {\n88:     fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n89:   }\n90:   if (allowStale) return;\n91:   const existingSources = sourceCandidates();\n92:   if (existingSources.length === 0) return;\n93:   const currentSourceHash = hashSourceFiles(existingSources);\n94:   if (readStoredSourceHash() === currentSourceHash) return;\n95:   const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n96:   const distMtime = fs.statSync(cliDist).mtimeMs;\n97:   if (newestSourceMtime > distMtime) {\n98:     fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n99:   }\n100:   writeStoredSourceHash(currentSourceHash);\n101: }\n102: \n103: function ensureSocketDir() {\n104:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n105:     process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n106:   }\n107:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n108:   if (socketDir.startsWith('tcp://')) return;\n109:   fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n110:   const socketPath = path.join(path.resolve(socketDir), socketFileName);\n111:   if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n112:     fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n113:   }\n114: }\n115: \n116: ensureSocketDir();\n117: ensureFreshDist();\n118: \n119: const result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n120:   cwd: path.dirname(opencodeDir),\n121:   env: process.env,\n122:   stdio: 'inherit',\n123: });\n124: \n125: if (result.error) {\n126:   process.stderr.write(`${result.error.message}\\n`);\n127:   process.exit(75);\n128: }\n129: \n130: process.exit(result.status ?? 1);\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","text":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n\nfunction fail(message) {\n  process.stderr.write(`${message}\\n`);\n  process.exit(69);\n}\n\n// Recursively collects the CLI's compiled-source surface (entry, local schema\n// imports, tsconfig) so new files under candidate directories are watched\n// without editing this list. Must stay in lock-step with\n// scripts/finalize-dist.mjs, which writes the matching hash at build time.\nfunction sourceCandidates() {\n  const candidates = [\n    path.join(mcpServerDir, 'spec-memory-cli.ts'),\n    path.join(mcpServerDir, 'tool-schemas.ts'),\n    path.join(mcpServerDir, 'tsconfig.json'),\n    path.join(mcpServerDir, 'schemas'),\n  ];\n  const files = [];\n\n  const visit = (candidate) => {\n    if (!fs.existsSync(candidate)) return;\n    const stat = fs.statSync(candidate);\n    if (stat.isDirectory()) {\n      for (const entry of fs.readdirSync(candidate)) {\n        visit(path.join(candidate, entry));\n      }\n      return;\n    }\n    if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n      files.push(candidate);\n    }\n  };\n\n  for (const candidate of candidates) visit(candidate);\n  return files;\n}\n\nfunction hashSourceFiles(existingSources) {\n  const hash = crypto.createHash('sha256');\n  for (const filePath of [...existingSources].sort()) {\n    hash.update(path.relative(mcpServerDir, filePath));\n    hash.update('\\0');\n    hash.update(fs.readFileSync(filePath));\n    hash.update('\\0');\n  }\n  return hash.digest('hex');\n}\n\nfunction readStoredSourceHash() {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n    return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction writeStoredSourceHash(sourceHash) {\n  try {\n    fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n    fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n  } catch {\n    // Freshness metadata is an optimization; stale detection remains conservative.\n  }\n}\n\nfunction ensureFreshDist() {\n  if (!fs.existsSync(cliDist)) {\n    fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n  }\n  if (allowStale) return;\n  const existingSources = sourceCandidates();\n  if (existingSources.length === 0) return;\n  const currentSourceHash = hashSourceFiles(existingSources);\n  if (readStoredSourceHash() === currentSourceHash) return;\n  const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n  const distMtime = fs.statSync(cliDist).mtimeMs;\n  if (newestSourceMtime > distMtime) {\n    fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n  }\n  writeStoredSourceHash(currentSourceHash);\n}\n\nfunction ensureSocketDir() {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (socketDir.startsWith('tcp://')) return;\n  fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  const socketPath = path.join(path.resolve(socketDir), socketFileName);\n  if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n    fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n  }\n}\n\nensureSocketDir();\nensureFreshDist();\n\nconst result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n  cwd: path.dirname(opencodeDir),\n  env: process.env,\n  stdio: 'inherit',\n});\n\nif (result.error) {\n  process.stderr.write(`${result.error.message}\\n`);\n  process.exit(75);\n}\n\nprocess.exit(result.status ?? 1);","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/bin/spec-memory.cjs","time":{"start":1781763091860,"end":1781763091862}},"metadata":{"openai":{"itemId":"fc_009ec8241b1c17e7016a338c1398c08191b030f10648383b5e"}},"id":"prt_ed95b2d37001PSvXOefe0k7MSt","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95aff680016dLp35yAqGqnDO"}}
{"type":"tool_use","timestamp":1781763091877,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_iiSk20dpRWONtIW7k7cIotlh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1,"limit":460},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   readMaintenanceMarker,\n37:   shouldAdoptDespiteProbe,\n38:   releaseRespawnLockFile,\n39:   sampleProcessTreeRssMb,\n40:   shouldAbortRelaunchOnFire,\n41:   shouldSkipLaunch,\n42:   signalProcess,\n43:   superviseChildExit,\n44:   waitForPidExit,\n45: } = mss;\n46: \n47: const root = path.resolve(__dirname, '..', '..');\n48: const opencodeDir = path.join(root, '.opencode');\n49: \n50: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n51: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n52: // Minimal parser — no external dependency.\n53: function loadEnvFile(filePath) {\n54:   if (!fs.existsSync(filePath)) return 0;\n55:   let count = 0;\n56:   const raw = fs.readFileSync(filePath, 'utf8');\n57:   for (const line of raw.split('\\n')) {\n58:     const trimmed = line.trim();\n59:     if (!trimmed || trimmed.startsWith('#')) continue;\n60:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n61:     if (!m) continue;\n62:     const key = m[1];\n63:     let val = m[2];\n64:     // Strip matching outer quotes (single or double)\n65:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n66:       val = val.slice(1, -1);\n67:     }\n68:     if (!(key in process.env)) {\n69:       process.env[key] = val;\n70:       count++;\n71:     }\n72:   }\n73:   return count;\n74: }\n75: \n76: function isStrictModeDisabled(value) {\n77:   if (value === undefined || value === null) return false;\n78:   const v = String(value).trim().toLowerCase();\n79:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n80: }\n81: \n82: let skillsDir = path.join(opencodeDir, 'skills');\n83: let legacySkillDir = path.join(opencodeDir, 'skill');\n84: let kitDir = path.join(skillsDir, 'system-spec-kit');\n85: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n86: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n87: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n88: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n89: let stateFile = path.join(dbDir, PID_FILE_NAME);\n90: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n91: \n92: const rel = (p) => path.relative(root, p) || '.';\n93: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n94: const now = () => new Date().toISOString();\n95: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n96: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n97: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n98: let childProcess = null;\n99: let ownerLeasePid = null;\n100: let leaseStartedAt = null;\n101: let launcherShutdownInProgress = false;\n102: let rssBreachSelfExitInProgress = false;\n103: let rssWatchdogTimer = null;\n104: let crashLoopGuard = null;\n105: let supervisorRelaunchTimer = null;\n106: // The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n107: // launcher's parent. When the host disposes its session the launcher is orphaned and its\n108: // ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n109: // path can tell \"owning runtime went away\" apart from a genuine daemon crash.\n110: const LAUNCHER_INITIAL_PPID = process.ppid;\n111: let ownerLeaseHeartbeatTimer = null;\n112: let ownerLeaseRequired = true;\n113: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n114: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n115: // orphaned sidecar after the child has already exited.\n116: let lastKnownDescendantPids = [];\n117: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n118: const durableWriteWarnings = new Set();\n119: // Daemon exit code meaning \"another live process holds the database\n120: // single-writer lock\". Never counts toward the crash loop: the right move is\n121: // bridging to the live owner (or a bounded retry while a maintenance script\n122: // finishes), not relaunching a doomed second writer. Mirrored in\n123: // mcp_server context-server (EXIT_DB_LOCK_HELD).\n124: const EXIT_DB_LOCK_HELD = 86;\n125: const DB_LOCK_HELD_MAX_RETRIES = 3;\n126: let dbLockHeldRetries = 0;\n127: \n128: function log(message) {\n129:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n130:   persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n131: }\n132: \n133: function isDurableWriteUnavailable(error) {\n134:   const code = error && typeof error === 'object' ? error.code : undefined;\n135:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n136: }\n137: \n138: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n139:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n140:   const key = `${operation}:${targetPath}:${code}`;\n141:   if (durableWriteWarnings.has(key)) return;\n142:   durableWriteWarnings.add(key);\n143:   const detail = error instanceof Error ? error.message : String(error ?? code);\n144:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n145: }\n146: \n147: // Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n148: // ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n149: // durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n150: // launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n151: // grow without bound.\n152: function launcherLogIsEnabled(env = process.env) {\n153:   return env.SPECKIT_LAUNCHER_LOG !== '0';\n154: }\n155: function launcherLogMaxBytes(env = process.env) {\n156:   return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n157: }\n158: function resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n159:   const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n160:   return typeof override === 'string' && override.trim()\n161:     ? override.trim()\n162:     : path.join(baseDir, '.mk-spec-memory-launcher.log');\n163: }\n164: function shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n165:   return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n166: }\n167: function persistLauncherLogLine(line) {\n168:   if (!launcherLogIsEnabled()) return;\n169:   let target;\n170:   try {\n171:     target = resolveLauncherLogPath();\n172:     try {\n173:       const { size } = fs.statSync(target);\n174:       if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n175:         try {\n176:           // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n177:           // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n178:           // suffix still rotates instead of renaming the file onto itself and growing without bound.\n179:           const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n180:           fs.renameSync(target, rotated);\n181:         } catch {\n182:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n183:         }\n184:       }\n185:     } catch (statErr) {\n186:       if (statErr.code !== 'ENOENT') throw statErr;\n187:     }\n188:     fs.appendFileSync(target, line, { mode: 0o600 });\n189:   } catch (error) {\n190:     if (target && isDurableWriteUnavailable(error)) {\n191:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n192:       return;\n193:     }\n194:     // Logging must never break the launcher.\n195:   }\n196: }\n197: \n198: // Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n199: // When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n200: // (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n201: // not tear the shared backend out from under other sessions. A fresh session that finds the released\n202: // daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n203: // it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n204: // writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n205: // killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n206: // sweeper bounds any leak.\n207: function daemonReelectionEnabled(env = process.env) {\n208:   return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n209: }\n210: function contextServerSpawnIo(reelectionEnabled) {\n211:   return reelectionEnabled\n212:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n213:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n214: }\n215: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n216:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n217: }\n218: \n219: function cleanupTmpFile(tmpPath) {\n220:   try {\n221:     fs.unlinkSync(tmpPath);\n222:   } catch (error) {\n223:     if (error.code !== 'ENOENT') {\n224:       // Best-effort cleanup only; the original durable-write failure is more useful.\n225:     }\n226:   }\n227: }\n228: \n229: function writeAtomicJsonFile(targetPath, payload, operation) {\n230:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n231:   const tmp = `${currentPath}.tmp.${process.pid}`;\n232:   try {\n233:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n234:     fs.renameSync(tmp, currentPath);\n235:     return true;\n236:   } catch (error) {\n237:     cleanupTmpFile(tmp);\n238:     if (isDurableWriteUnavailable(error)) {\n239:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n240:       return false;\n241:     }\n242:     throw error;\n243:   }\n244: }\n245: \n246: function loadProjectEnvFiles() {\n247:   for (const fname of ['.env.local', '.env']) {\n248:     const p = path.join(root, fname);\n249:     if (fs.existsSync(p)) {\n250:       const n = loadEnvFile(p);\n251:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n252:     }\n253:   }\n254: }\n255: \n256: function parsePositiveInteger(value, fallback) {\n257:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n258:   const parsed = Number.parseInt(String(value).trim(), 10);\n259:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n260: }\n261: \n262: function loadBridgeModule() {\n263:   try {\n264:     return require('./lib/launcher-ipc-bridge.cjs');\n265:   } catch (error) {\n266:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n267:     return {\n268:       async maybeBridgeLeaseHolder({ leaseResult }) {\n269:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n270:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n271:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n272:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n273:         return { action: 'report', reason: 'bridge-module-missing' };\n274:       },\n275:     };\n276:   }\n277: }\n278: \n279: function resolveSessionProxySocketPath() {\n280:   const { getIpcSocketPath } = loadBridgeModule();\n281:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n282: }\n283: \n284: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n285: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n286: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n287: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n288: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n289: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n290: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n291: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n292:   const createProxy = options.createProxy ?? createSessionProxy;\n293:   const sessionProxy = createProxy({\n294:     socketPath,\n295:     stdin: options.stdin ?? process.stdin,\n296:     stdout: options.stdout ?? process.stdout,\n297:     log,\n298:   });\n299:   return sessionProxy.start();\n300: }\n301: \n302: function refreshPaths() {\n303:   skillsDir = path.join(opencodeDir, 'skills');\n304:   legacySkillDir = path.join(opencodeDir, 'skill');\n305:   kitDir = path.join(skillsDir, 'system-spec-kit');\n306:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n307:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n308:   stateFile = path.join(dbDir, PID_FILE_NAME);\n309:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n310: }\n311: \n312: function exists(p) {\n313:   return fs.existsSync(p);\n314: }\n315: \n316: function writeState(payload) {\n317:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n318:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n319: }\n320: \n321: function resolvedDbDir() {\n322:   return canonicalizePath(dbDir);\n323: }\n324: \n325: // Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n326: // daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n327: // resolved against cwd, else the default DB dir) so both sides agree on the path\n328: // even under a test fake-root that sets SPEC_KIT_DB_DIR.\n329: function maintenanceMarkerDir() {\n330:   const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n331:   if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n332:   return resolvedDbDir();\n333: }\n334: \n335: function leasePath() {\n336:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n337: }\n338: \n339: function ownerLeasePath() {\n340:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n341: }\n342: \n343: function legacyLeasePaths() {\n344:   return [\n345:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n346:   ].map(canonicalizePath);\n347: }\n348: \n349: function readLeaseFile(filePath = leasePath()) {\n350:   try {\n351:     const raw = fs.readFileSync(filePath, 'utf8');\n352:     const parsed = JSON.parse(raw);\n353:     if (typeof parsed.pid === 'number') return parsed;\n354:   } catch {\n355:     // Missing or corrupt lease files are treated as no active lease.\n356:   }\n357:   return null;\n358: }\n359: \n360: function readOwnerLeaseFile(filePath = ownerLeasePath()) {\n361:   try {\n362:     const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n363:     if (\n364:       Number.isInteger(parsed.ownerPid) &&\n365:       Number.isInteger(parsed.ppid) &&\n366:       typeof parsed.executablePath === 'string' &&\n367:       typeof parsed.startedAtIso === 'string' &&\n368:       typeof parsed.lastHeartbeatIso === 'string' &&\n369:       Number.isInteger(parsed.ttlMs) &&\n370:       typeof parsed.canonicalDbDir === 'string'\n371:     ) {\n372:       return parsed;\n373:     }\n374:   } catch {\n375:     // Missing or corrupt owner leases are treated as no active owner.\n376:   }\n377:   return null;\n378: }\n379: \n380: function writeOwnerLeaseFile(lease) {\n381:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n382:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n383:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n384:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n385:   // after power loss and break ownership detection.\n386:   let fd;\n387:   try {\n388:     fd = fs.openSync(tmp, 'wx', 0o600);\n389:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n390:     fs.fsyncSync(fd);\n391:   } finally {\n392:     if (typeof fd === 'number') fs.closeSync(fd);\n393:   }\n394:   fs.renameSync(tmp, currentLeasePath);\n395: }\n396: \n397: function writeOwnerLeaseFileExclusive(lease) {\n398:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n399:   let fd;\n400:   try {\n401:     fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n402:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n403:     fs.fsyncSync(fd);\n404:     return true;\n405:   } catch (error) {\n406:     if (error.code === 'EEXIST') return false;\n407:     throw error;\n408:   } finally {\n409:     if (typeof fd === 'number') fs.closeSync(fd);\n410:   }\n411: }\n412: \n413: function buildOwnerLease(ownerPid = process.pid) {\n414:   return {\n415:     ownerPid,\n416:     ppid: process.ppid,\n417:     executablePath: process.execPath,\n418:     startedAtIso: new Date().toISOString(),\n419:     lastHeartbeatIso: new Date().toISOString(),\n420:     ttlMs: 60000,\n421:     canonicalDbDir: resolvedDbDir(),\n422:   };\n423: }\n424: \n425: function readParentPid(pid) {\n426:   if (!Number.isInteger(pid) || pid <= 0) return null;\n427:   if (process.platform === 'linux') {\n428:     try {\n429:       const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n430:       const match = status.match(/^PPid:\\s+(\\d+)$/m);\n431:       return match ? Number.parseInt(match[1], 10) : null;\n432:     } catch {\n433:       return null;\n434:     }\n435:   }\n436:   const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n437:     encoding: 'utf8',\n438:     stdio: ['ignore', 'pipe', 'ignore'],\n439:   });\n440:   if (result.status !== 0 || !result.stdout) return null;\n441:   const parsed = Number.parseInt(result.stdout.trim(), 10);\n442:   return Number.isInteger(parsed) ? parsed : null;\n443: }\n444: \n445: function classifyOwnerLease(lease) {\n446:   const liveness = processLiveness(lease.ownerPid);\n447:   if (liveness === 'dead') return 'stale-pid';\n448:   if (liveness === 'unknown-eperm') return 'unknown-eperm';\n449: \n450:   const actualPpid = readParentPid(lease.ownerPid);\n451:   if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n452:     return 'ppid-1-orphan';\n453:   }\n454: \n455:   const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n456:   const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n457:   if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n458:     return 'stale-heartbeat-reclaim';\n459:   }\n460: \n\n(Showing lines 1-460 of 1882. Use offset=461 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;\nlet crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\n// The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n// launcher's parent. When the host disposes its session the launcher is orphaned and its\n// ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n// path can tell \"owning runtime went away\" apart from a genuine daemon crash.\nconst LAUNCHER_INITIAL_PPID = process.ppid;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n// Daemon exit code meaning \"another live process holds the database\n// single-writer lock\". Never counts toward the crash loop: the right move is\n// bridging to the live owner (or a bounded retry while a maintenance script\n// finishes), not relaunching a doomed second writer. Mirrored in\n// mcp_server context-server (EXIT_DB_LOCK_HELD).\nconst EXIT_DB_LOCK_HELD = 86;\nconst DB_LOCK_HELD_MAX_RETRIES = 3;\nlet dbLockHeldRetries = 0;\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n  persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\n// Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n// ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n// durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n// launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n// grow without bound.\nfunction launcherLogIsEnabled(env = process.env) {\n  return env.SPECKIT_LAUNCHER_LOG !== '0';\n}\nfunction launcherLogMaxBytes(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n}\nfunction resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n  const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n  return typeof override === 'string' && override.trim()\n    ? override.trim()\n    : path.join(baseDir, '.mk-spec-memory-launcher.log');\n}\nfunction shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n  return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n}\nfunction persistLauncherLogLine(line) {\n  if (!launcherLogIsEnabled()) return;\n  let target;\n  try {\n    target = resolveLauncherLogPath();\n    try {\n      const { size } = fs.statSync(target);\n      if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n        try {\n          // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n          // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n          // suffix still rotates instead of renaming the file onto itself and growing without bound.\n          const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n// (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n// not tear the shared backend out from under other sessions. A fresh session that finds the released\n// daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n// it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n// writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n// killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n// sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-spec-kit');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n  canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\n// Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n// daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n// resolved against cwd, else the default DB dir) so both sides agree on the path\n// even under a test fake-root that sets SPEC_KIT_DB_DIR.\nfunction maintenanceMarkerDir() {\n  const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n  return resolvedDbDir();\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n\nfunction readOwnerLeaseFile(filePath = ownerLeasePath()) {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    if (\n      Number.isInteger(parsed.ownerPid) &&\n      Number.isInteger(parsed.ppid) &&\n      typeof parsed.executablePath === 'string' &&\n      typeof parsed.startedAtIso === 'string' &&\n      typeof parsed.lastHeartbeatIso === 'string' &&\n      Number.isInteger(parsed.ttlMs) &&\n      typeof parsed.canonicalDbDir === 'string'\n    ) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt owner leases are treated as no active owner.\n  }\n  return null;\n}\n\nfunction writeOwnerLeaseFile(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n  // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n  // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n  // after power loss and break ownership detection.\n  let fd;\n  try {\n    fd = fs.openSync(tmp, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction writeOwnerLeaseFileExclusive(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  let fd;\n  try {\n    fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n    return true;\n  } catch (error) {\n    if (error.code === 'EEXIST') return false;\n    throw error;\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n}\n\nfunction buildOwnerLease(ownerPid = process.pid) {\n  return {\n    ownerPid,\n    ppid: process.ppid,\n    executablePath: process.execPath,\n    startedAtIso: new Date().toISOString(),\n    lastHeartbeatIso: new Date().toISOString(),\n    ttlMs: 60000,\n    canonicalDbDir: resolvedDbDir(),\n  };\n}\n\nfunction readParentPid(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return null;\n  if (process.platform === 'linux') {\n    try {\n      const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n      const match = status.match(/^PPid:\\s+(\\d+)$/m);\n      return match ? Number.parseInt(match[1], 10) : null;\n    } catch {\n      return null;\n    }\n  }\n  const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'ignore'],\n  });\n  if (result.status !== 0 || !result.stdout) return null;\n  const parsed = Number.parseInt(result.stdout.trim(), 10);\n  return Number.isInteger(parsed) ? parsed : null;\n}\n\nfunction classifyOwnerLease(lease) {\n  const liveness = processLiveness(lease.ownerPid);\n  if (liveness === 'dead') return 'stale-pid';\n  if (liveness === 'unknown-eperm') return 'unknown-eperm';\n\n  const actualPpid = readParentPid(lease.ownerPid);\n  if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n    return 'ppid-1-orphan';\n  }\n\n  const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n  const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n  if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n    return 'stale-heartbeat-reclaim';\n  }\n","lineStart":1,"lineEnd":460,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781763091872,"end":1781763091876}},"metadata":{"openai":{"itemId":"fc_009ec8241b1c17e7016a338c1398c8819196663edb30dbd965"}},"id":"prt_ed95b2d9a001y5fgTxwrA258ly","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95aff680016dLp35yAqGqnDO"}}
