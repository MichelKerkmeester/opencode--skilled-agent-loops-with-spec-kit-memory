{"type":"tool_use","timestamp":1783437217905,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_f5kAD6FAFGRaUCqWtiRu1EAi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Ambiguity\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorScoredRecommendation } from './types.js';\n6: \n7: export const AMBIGUITY_MARGIN = 0.05;\n8: export const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n9: \n10: // Compute ambiguity from ranking `score` so the cluster aligns\n11: // with the score-based fusion ranking (top-two-by-confidence may not match\n12: // top-two-by-score).\n13: //\n14: // Also compute on `confidence` and union the two\n15: // clusters. Score-margin keeps ranking alignment; confidence-margin restores\n16: // the documented \"0.05 confidence window\" and catches\n17: // cross-domain prompts where confidence is near-tied (user-visible signal)\n18: // even when score gaps just exceed the score margin. A candidate is in the\n19: // ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n20: // \"outside both margins\" is required to be unambiguously ranked.\n21: \n22: function ambiguousCluster(\n23:   recommendations: readonly AdvisorScoredRecommendation[],\n24: ): AdvisorScoredRecommendation[] {\n25:   const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);\n26:   const [top] = passing;\n27:   if (!top) return [];\n28:   return passing.filter((recommendation) => {\n29:     const scoreGap = Math.abs(top.score - recommendation.score);\n30:     const confidenceGap = Math.abs(top.confidence - recommendation.confidence);\n31:     return (\n32:       scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON\n33:       || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON\n34:     );\n35:   });\n36: }\n37: \n38: export function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {\n39:   // Name preserved for back-compat with existing call sites; semantics are\n40:   // now \"is the passing top a member of an ambiguity cluster of size >= 2\".\n41:   return ambiguousCluster(recommendations).length >= 2;\n42: }\n43: \n44: export function applyAmbiguity(\n45:   recommendations: readonly AdvisorScoredRecommendation[],\n46: ): AdvisorScoredRecommendation[] {\n47:   const cluster = ambiguousCluster(recommendations);\n48:   if (cluster.length < 2) return [...recommendations];\n49:   const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));\n50:   return recommendations.map((recommendation) => (\n51:     ambiguousSet.has(recommendation.skill)\n52:       ? {\n53:         ...recommendation,\n54:         ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),\n55:       }\n56:       : recommendation\n57:   ));\n58: }\n\n(End of file - total 58 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Ambiguity\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorScoredRecommendation } from './types.js';\n\nexport const AMBIGUITY_MARGIN = 0.05;\nexport const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n\n// Compute ambiguity from ranking `score` so the cluster aligns\n// with the score-based fusion ranking (top-two-by-confidence may not match\n// top-two-by-score).\n//\n// Also compute on `confidence` and union the two\n// clusters. Score-margin keeps ranking alignment; confidence-margin restores\n// the documented \"0.05 confidence window\" and catches\n// cross-domain prompts where confidence is near-tied (user-visible signal)\n// even when score gaps just exceed the score margin. A candidate is in the\n// ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n// \"outside both margins\" is required to be unambiguously ranked.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Ambiguity\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorScoredRecommendation } from './types.js';\n\nexport const AMBIGUITY_MARGIN = 0.05;\nexport const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n\n// Compute ambiguity from ranking `score` so the cluster aligns\n// with the score-based fusion ranking (top-two-by-confidence may not match\n// top-two-by-score).\n//\n// Also compute on `confidence` and union the two\n// clusters. Score-margin keeps ranking alignment; confidence-margin restores\n// the documented \"0.05 confidence window\" and catches\n// cross-domain prompts where confidence is near-tied (user-visible signal)\n// even when score gaps just exceed the score margin. A candidate is in the\n// ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n// \"outside both margins\" is required to be unambiguously ranked.\n\nfunction ambiguousCluster(\n  recommendations: readonly AdvisorScoredRecommendation[],\n): AdvisorScoredRecommendation[] {\n  const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);\n  const [top] = passing;\n  if (!top) return [];\n  return passing.filter((recommendation) => {\n    const scoreGap = Math.abs(top.score - recommendation.score);\n    const confidenceGap = Math.abs(top.confidence - recommendation.confidence);\n    return (\n      scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON\n      || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON\n    );\n  });\n}\n\nexport function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {\n  // Name preserved for back-compat with existing call sites; semantics are\n  // now \"is the passing top a member of an ambiguity cluster of size >= 2\".\n  return ambiguousCluster(recommendations).length >= 2;\n}\n\nexport function applyAmbiguity(\n  recommendations: readonly AdvisorScoredRecommendation[],\n): AdvisorScoredRecommendation[] {\n  const cluster = ambiguousCluster(recommendations);\n  if (cluster.length < 2) return [...recommendations];\n  const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));\n  return recommendations.map((recommendation) => (\n    ambiguousSet.has(recommendation.skill)\n      ? {\n        ...recommendation,\n        ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),\n      }\n      : recommendation\n  ));\n}","lineStart":1,"lineEnd":58,"totalLines":58,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","time":{"start":1783437217867,"end":1783437217903}},"metadata":{"openai":{"itemId":"fc_0ca241608142d171016a4d17a149f48191aabbab12a6707652"}},"id":"prt_f3d245048001BOxxt6lq0TKUGD","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d241de0001RqM8ozNmqoEouG"}}
{"type":"tool_use","timestamp":1783437217919,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_i5qellaiPVGkHO5tPkGjoRUt","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Derived Generated Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: // Pull the age-haircut policy from the scorer-local seam\n6: // instead of reaching into the lifecycle subsystem directly. The lifecycle\n7: // implementation stays the source of truth; the seam keeps the scorer's\n8: // dependency direction inward.\n9: import { applyAgeHaircutToLane } from '../age-policy.js';\n10: import type { NormalizedAffordance } from '../../affordance-normalizer.js';\n11: import type { AdvisorProjection, LaneMatch } from '../types.js';\n12: import { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n13: \n14: function affordancesForSkill(\n15:   affordances: readonly NormalizedAffordance[],\n16:   skillId: string,\n17: ): NormalizedAffordance[] {\n18:   return affordances.filter((affordance) => affordance.skillId === skillId);\n19: }\n20: \n21: // Doc-level harvest contribution is bounded twice: only the strongest\n22: // few docs count (so doc-heavy skills cannot outscore lean skills on\n23: // volume alone) and the summed contribution is capped below the level a\n24: // skill's own curated triggers can reach.\n25: const DOC_TOP_N = 3;\n26: const DOC_PHRASE_FACTOR = 0.5;\n27: const DOC_CONTRIBUTION_CAP = 0.45;\n28: \n29: interface DocMatch {\n30:   readonly docPath: string;\n31:   readonly score: number;\n32: }\n33: \n34: function scoreDocTriggers(\n35:   lower: string,\n36:   skill: AdvisorProjection['skills'][number],\n37: ): DocMatch[] {\n38:   const matches: DocMatch[] = [];\n39:   for (const doc of skill.docTriggers ?? []) {\n40:     let best = 0;\n41:     for (const phrase of doc.phrases) {\n42:       if (!matchesPhraseBoundary(lower, phrase)) continue;\n43:       best = Math.max(best, phraseSpecificity(phrase));\n44:     }\n45:     if (best <= 0) continue;\n46:     matches.push({ docPath: doc.docPath, score: best * doc.tierWeight });\n47:   }\n48:   return matches.sort((left, right) => right.score - left.score).slice(0, DOC_TOP_N);\n49: }\n50: \n51: export function scoreDerivedLane(\n52:   prompt: string,\n53:   projection: AdvisorProjection,\n54:   now: Date = new Date(),\n55:   affordances: readonly NormalizedAffordance[] = [],\n56: ): LaneMatch[] {\n57:   const lower = prompt.toLowerCase();\n58:   const tokens = tokenize(prompt);\n59:   const matches: LaneMatch[] = [];\n60: \n61:   for (const skill of projection.skills) {\n62:     const phrases = [...skill.derivedTriggers, ...skill.derivedKeywords];\n63:     const skillAffordances = affordancesForSkill(affordances, skill.id);\n64:     const affordancePhrases = skillAffordances.flatMap((affordance) => [...affordance.derivedTriggers]);\n65:     const docMatches = scoreDocTriggers(lower, skill);\n66:     if (phrases.length === 0 && affordancePhrases.length === 0 && docMatches.length === 0) continue;\n67:     const evidence: string[] = docMatches.map((doc) => `doc:${doc.docPath}`);\n68:     let score = Math.min(\n69:       docMatches.reduce((total, doc) => total + doc.score, 0) * DOC_PHRASE_FACTOR,\n70:       DOC_CONTRIBUTION_CAP,\n71:     );\n72:     for (const phrase of phrases) {\n73:       if (!matchesPhraseBoundary(lower, phrase)) continue;\n74:       score += phraseSpecificity(phrase) * 0.7;\n75:       evidence.push(`derived:${phrase}`);\n76:     }\n77:     for (const affordance of skillAffordances) {\n78:       let matched = false;\n79:       for (const phrase of affordance.derivedTriggers) {\n80:         if (!matchesPhraseBoundary(lower, phrase)) continue;\n81:         matched = true;\n82:         score += phraseSpecificity(phrase) * 0.45;\n83:       }\n84:       if (matched) evidence.push(affordance.evidenceLabel);\n85:     }\n86:     score += scoreTokenOverlap(tokens, phrases) * 0.45;\n87:     score += scoreTokenOverlap(tokens, affordancePhrases) * 0.25;\n88:     // Decay by the skill's own derived-content age — derivedGeneratedAt is the\n89:     // author/sync time of the derived block (author-time, not refreshed by\n90:     // rebuild; see SkillProjection.derivedGeneratedAt). The projection.generatedAt\n91:     // fallback is a last-resort, timestamp-less value (near-now on every run, so\n92:     // it exempts the skill from the haircut), used ONLY when a skill has no\n93:     // derived.generated_at — it is not a runtime freshness signal.\n94:     const adjusted = applyAgeHaircutToLane(\n95:       { trustLane: 'derived_generated', score: Math.min(score, 1) },\n96:       {\n97:         generatedAt: skill.derivedGeneratedAt ?? projection.generatedAt,\n98:         now,\n99:         lifecycleStatus: skill.lifecycleStatus,\n100:       },\n101:     );\n102:     if (adjusted.score <= 0.05) continue;\n103:     matches.push({\n104:       skillId: skill.id,\n105:       lane: 'derived_generated',\n106:       score: Number((adjusted.score * (skill.derivedDemotion ?? 1)).toFixed(6)),\n107:       evidence: evidence.slice(0, 6),\n108:     });\n109:   }\n110: \n111:   return matches;\n112: }\n\n(End of file - total 112 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Generated Lane\n// ───────────────────────────────────────────────────────────────\n\n// Pull the age-haircut policy from the scorer-local seam\n// instead of reaching into the lifecycle subsystem directly. The lifecycle\n// implementation stays the source of truth; the seam keeps the scorer's\n// dependency direction inward.\nimport { applyAgeHaircutToLane } from '../age-policy.js';\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n\nfunction affordancesForSkill(\n  affordances: readonly NormalizedAffordance[],\n  skillId: string,\n): NormalizedAffordance[] {\n  return affordances.filter((affordance) => affordance.skillId === skillId);\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Generated Lane\n// ───────────────────────────────────────────────────────────────\n\n// Pull the age-haircut policy from the scorer-local seam\n// instead of reaching into the lifecycle subsystem directly. The lifecycle\n// implementation stays the source of truth; the seam keeps the scorer's\n// dependency direction inward.\nimport { applyAgeHaircutToLane } from '../age-policy.js';\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n\nfunction affordancesForSkill(\n  affordances: readonly NormalizedAffordance[],\n  skillId: string,\n): NormalizedAffordance[] {\n  return affordances.filter((affordance) => affordance.skillId === skillId);\n}\n\n// Doc-level harvest contribution is bounded twice: only the strongest\n// few docs count (so doc-heavy skills cannot outscore lean skills on\n// volume alone) and the summed contribution is capped below the level a\n// skill's own curated triggers can reach.\nconst DOC_TOP_N = 3;\nconst DOC_PHRASE_FACTOR = 0.5;\nconst DOC_CONTRIBUTION_CAP = 0.45;\n\ninterface DocMatch {\n  readonly docPath: string;\n  readonly score: number;\n}\n\nfunction scoreDocTriggers(\n  lower: string,\n  skill: AdvisorProjection['skills'][number],\n): DocMatch[] {\n  const matches: DocMatch[] = [];\n  for (const doc of skill.docTriggers ?? []) {\n    let best = 0;\n    for (const phrase of doc.phrases) {\n      if (!matchesPhraseBoundary(lower, phrase)) continue;\n      best = Math.max(best, phraseSpecificity(phrase));\n    }\n    if (best <= 0) continue;\n    matches.push({ docPath: doc.docPath, score: best * doc.tierWeight });\n  }\n  return matches.sort((left, right) => right.score - left.score).slice(0, DOC_TOP_N);\n}\n\nexport function scoreDerivedLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  now: Date = new Date(),\n  affordances: readonly NormalizedAffordance[] = [],\n): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = tokenize(prompt);\n  const matches: LaneMatch[] = [];\n\n  for (const skill of projection.skills) {\n    const phrases = [...skill.derivedTriggers, ...skill.derivedKeywords];\n    const skillAffordances = affordancesForSkill(affordances, skill.id);\n    const affordancePhrases = skillAffordances.flatMap((affordance) => [...affordance.derivedTriggers]);\n    const docMatches = scoreDocTriggers(lower, skill);\n    if (phrases.length === 0 && affordancePhrases.length === 0 && docMatches.length === 0) continue;\n    const evidence: string[] = docMatches.map((doc) => `doc:${doc.docPath}`);\n    let score = Math.min(\n      docMatches.reduce((total, doc) => total + doc.score, 0) * DOC_PHRASE_FACTOR,\n      DOC_CONTRIBUTION_CAP,\n    );\n    for (const phrase of phrases) {\n      if (!matchesPhraseBoundary(lower, phrase)) continue;\n      score += phraseSpecificity(phrase) * 0.7;\n      evidence.push(`derived:${phrase}`);\n    }\n    for (const affordance of skillAffordances) {\n      let matched = false;\n      for (const phrase of affordance.derivedTriggers) {\n        if (!matchesPhraseBoundary(lower, phrase)) continue;\n        matched = true;\n        score += phraseSpecificity(phrase) * 0.45;\n      }\n      if (matched) evidence.push(affordance.evidenceLabel);\n    }\n    score += scoreTokenOverlap(tokens, phrases) * 0.45;\n    score += scoreTokenOverlap(tokens, affordancePhrases) * 0.25;\n    // Decay by the skill's own derived-content age — derivedGeneratedAt is the\n    // author/sync time of the derived block (author-time, not refreshed by\n    // rebuild; see SkillProjection.derivedGeneratedAt). The projection.generatedAt\n    // fallback is a last-resort, timestamp-less value (near-now on every run, so\n    // it exempts the skill from the haircut), used ONLY when a skill has no\n    // derived.generated_at — it is not a runtime freshness signal.\n    const adjusted = applyAgeHaircutToLane(\n      { trustLane: 'derived_generated', score: Math.min(score, 1) },\n      {\n        generatedAt: skill.derivedGeneratedAt ?? projection.generatedAt,\n        now,\n        lifecycleStatus: skill.lifecycleStatus,\n      },\n    );\n    if (adjusted.score <= 0.05) continue;\n    matches.push({\n      skillId: skill.id,\n      lane: 'derived_generated',\n      score: Number((adjusted.score * (skill.derivedDemotion ?? 1)).toFixed(6)),\n      evidence: evidence.slice(0, 6),\n    });\n  }\n\n  return matches;\n}","lineStart":1,"lineEnd":112,"totalLines":112,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","time":{"start":1783437217870,"end":1783437217915}},"metadata":{"openai":{"itemId":"fc_0ca241608142d171016a4d17a149fc81919df79caeb4ba17d4"}},"id":"prt_f3d24504c0013R8WWEyCwQSqmy","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d241de0001RqM8ozNmqoEouG"}}
{"type":"tool_use","timestamp":1783437217919,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_mzu3aRvk0q40RxFfL6Vvrabv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Semantic Shadow Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { getAdapter } from '../../embedders/registry.js';\n6: import { getActiveEmbedder } from '../../embedders/schema.js';\n7: import { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\n8: import { scoreTokenOverlap, tokenize } from '../text.js';\n9: import type { AdvisorProjection, LaneMatch } from '../types.js';\n10: \n11: const COSINE_THRESHOLD = 0.2;\n12: \n13: let activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n14: \n15: export interface SemanticShadowRuntimeHealth {\n16:   readonly checkedAt: string;\n17:   readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n18:   readonly dimMismatch: boolean;\n19:   readonly disabledReason: string | null;\n20:   readonly lastPromptEmbeddingAt: string | null;\n21: }\n22: \n23: let runtimeHealth: SemanticShadowRuntimeHealth = {\n24:   checkedAt: new Date(0).toISOString(),\n25:   activeEmbedder: null,\n26:   dimMismatch: false,\n27:   disabledReason: null,\n28:   lastPromptEmbeddingAt: null,\n29: };\n30: \n31: function setRuntimeHealth(update: Partial<SemanticShadowRuntimeHealth>): void {\n32:   runtimeHealth = {\n33:     ...runtimeHealth,\n34:     ...update,\n35:     checkedAt: new Date().toISOString(),\n36:   };\n37: }\n38: \n39: export function getSemanticShadowRuntimeHealth(): SemanticShadowRuntimeHealth {\n40:   return runtimeHealth;\n41: }\n42: \n43: function toFloat32Array(vector: Float32Array | readonly number[]): Float32Array {\n44:   return vector instanceof Float32Array ? vector : Float32Array.from(vector);\n45: }\n46: \n47: function cosineSimilarity(left: Float32Array, right: Float32Array): number {\n48:   const length = Math.min(left.length, right.length);\n49:   if (length === 0) {\n50:     return 0;\n51:   }\n52: \n53:   let dot = 0;\n54:   let leftNorm = 0;\n55:   let rightNorm = 0;\n56:   for (let index = 0; index < length; index++) {\n57:     const leftValue = left[index];\n58:     const rightValue = right[index];\n59:     dot += leftValue * rightValue;\n60:     leftNorm += leftValue * leftValue;\n61:     rightNorm += rightValue * rightValue;\n62:   }\n63: \n64:   if (leftNorm === 0 || rightNorm === 0) {\n65:     return 0;\n66:   }\n67: \n68:   return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n69: }\n70: \n71: function fixtureVector(text: string): Float32Array {\n72:   const normalized = text.toLowerCase().split(/\\W+/).filter(Boolean);\n73:   const vector = new Float32Array(32);\n74:   for (const token of normalized) {\n75:     let hash = 0;\n76:     for (let index = 0; index < token.length; index++) {\n77:       hash = ((hash << 5) - hash + token.charCodeAt(index)) | 0;\n78:     }\n79:     vector[Math.abs(hash) % vector.length] += 1;\n80:   }\n81:   return vector;\n82: }\n83: \n84: export function setSemanticShadowPromptEmbedding(prompt: string, vector: Float32Array | readonly number[] | null | undefined): void {\n85:   activePromptEmbedding = vector ? { prompt, vector: toFloat32Array(vector) } : null;\n86: }\n87: \n88: export function clearSemanticShadowPromptEmbedding(): void {\n89:   activePromptEmbedding = null;\n90: }\n91: \n92: export async function withSemanticShadowPromptEmbedding<T>(prompt: string, run: () => T): Promise<T> {\n93:   if (process.env.VITEST === 'true') {\n94:     return run();\n95:   }\n96: \n97:   try {\n98:     // Read-only access: recommend calls must never open the daemon-owned\n99:     // database read-write (dual-writer hazard) or create it when absent.\n100:     const database = getDbReadOnly();\n101:     if (!database) {\n102:       setRuntimeHealth({\n103:         activeEmbedder: null,\n104:         dimMismatch: false,\n105:         disabledReason: 'database_absent',\n106:       });\n107:       throw new Error('skill graph database is absent; shadow scoring disabled');\n108:     }\n109:     const active = getActiveEmbedder(database);\n110:     const adapter = getAdapter(active.name);\n111:     if (!adapter) {\n112:       setRuntimeHealth({\n113:         activeEmbedder: { name: active.name, dim: active.dim, adapterDim: null },\n114:         dimMismatch: false,\n115:         disabledReason: 'adapter_unavailable',\n116:       });\n117:       throw new Error(`active embedder is not registered: ${active.name}`);\n118:     }\n119:     if (adapter.dim !== active.dim) {\n120:       setRuntimeHealth({\n121:         activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n122:         dimMismatch: true,\n123:         disabledReason: 'dim_mismatch',\n124:       });\n125:       throw new Error(`active embedder dimension mismatch: ${active.name} reports ${adapter.dim}, pointer expects ${active.dim}`);\n126:     }\n127: \n128:     const [vector] = await adapter.embed([prompt], { inputType: 'query' });\n129:     setSemanticShadowPromptEmbedding(prompt, vector ?? null);\n130:     setRuntimeHealth({\n131:       activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n132:       dimMismatch: false,\n133:       disabledReason: vector ? null : 'prompt_embedding_empty',\n134:       lastPromptEmbeddingAt: vector ? new Date().toISOString() : runtimeHealth.lastPromptEmbeddingAt,\n135:     });\n136:   } catch (error: unknown) {\n137:     setSemanticShadowPromptEmbedding(prompt, null);\n138:     const message = error instanceof Error ? error.message : String(error);\n139:     if (!runtimeHealth.disabledReason) {\n140:       setRuntimeHealth({ disabledReason: 'prompt_embedding_failed' });\n141:     }\n142:     console.warn(`[semantic-shadow] Prompt embedding failed; cosine lane disabled for this call (${message})`);\n143:   }\n144: \n145:   try {\n146:     return run();\n147:   } finally {\n148:     clearSemanticShadowPromptEmbedding();\n149:   }\n150: }\n151: \n152: export const _semanticShadowTest = {\n153:   cosineSimilarity,\n154:   fixtureVector,\n155: };\n156: \n157: export function scoreSemanticShadowExactSubset(\n158:   prompt: string,\n159:   projection: AdvisorProjection,\n160:   skillIds: readonly string[],\n161: ): LaneMatch[] {\n162:   if (projection.embeddingStaleness?.stale) {\n163:     setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n164:     return [];\n165:   }\n166: \n167:   const orderedSkillIds = [...new Set(skillIds)];\n168:   if (orderedSkillIds.length === 0) return [];\n169: \n170:   const promptVector = activePromptEmbedding?.prompt === prompt\n171:     ? activePromptEmbedding.vector\n172:     : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n173:   if (!promptVector) {\n174:     return [];\n175:   }\n176: \n177:   const requested = new Set(orderedSkillIds);\n178:   const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n179:     ? new Map(projection.skills\n180:         .filter((skill) => requested.has(skill.id))\n181:         .map((skill) => [skill.id, fixtureVector([\n182:           skill.name,\n183:           skill.description,\n184:           ...skill.domains,\n185:           ...skill.intentSignals,\n186:           ...skill.derivedTriggers,\n187:         ].join(' '))]))\n188:     : new Map<string, Float32Array>();\n189: \n190:   let cachedVectors = new Map<string, Float32Array>();\n191:   if (projection.source !== 'fixture' && process.env.VITEST !== 'true') {\n192:     try {\n193:       cachedVectors = new Map(\n194:         loadSkillEmbeddings(orderedSkillIds)\n195:           .map((row) => [row.skillId, row.embedding]),\n196:       );\n197:     } catch (error: unknown) {\n198:       const message = error instanceof Error ? error.message : String(error);\n199:       setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n200:       console.warn(`[semantic-shadow] Exact skill embedding load failed; rerank disabled (${message})`);\n201:       return [];\n202:     }\n203:   }\n204: \n205:   return orderedSkillIds\n206:     .map((skillId): LaneMatch | null => {\n207:       const skillVector = cachedVectors.get(skillId) ?? fixtureVectors.get(skillId);\n208:       if (!skillVector) {\n209:         return null;\n210:       }\n211:       const score = cosineSimilarity(promptVector, skillVector);\n212:       const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n213:       return {\n214:         skillId,\n215:         lane: 'semantic_shadow' as const,\n216:         score: roundedScore,\n217:         evidence: [`cosine-exact:${score.toFixed(4)}`],\n218:         shadowOnly: false,\n219:       };\n220:     })\n221:     .filter((match): match is LaneMatch => match !== null);\n222: }\n223: \n224: export function scoreSemanticShadowLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n225:   if (projection.embeddingStaleness?.stale) {\n226:     setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n227:     return [];\n228:   }\n229: \n230:   if (!activePromptEmbedding && process.env.VITEST === 'true') {\n231:     const tokens = tokenize(prompt);\n232:     return projection.skills\n233:       .map((skill) => ({\n234:         skillId: skill.id,\n235:         lane: 'semantic_shadow' as const,\n236:         score: Math.min(scoreTokenOverlap(tokens, [\n237:           skill.name,\n238:           skill.description,\n239:           ...skill.domains,\n240:           ...skill.intentSignals,\n241:           ...skill.derivedTriggers,\n242:         ]) * 0.8, 1),\n243:         evidence: ['shadow:test-fallback'],\n244:         shadowOnly: false,\n245:       }))\n246:       .filter((match) => match.score > 0.08);\n247:   }\n248: \n249:   const promptVector = activePromptEmbedding?.prompt === prompt\n250:     ? activePromptEmbedding.vector\n251:     : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n252:   if (!promptVector) {\n253:     return [];\n254:   }\n255: \n256:   const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n257:     ? new Map(projection.skills.map((skill) => [skill.id, fixtureVector([\n258:         skill.name,\n259:         skill.description,\n260:         ...skill.domains,\n\n(Showing lines 1-260 of 311. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport { getAdapter } from '../../embedders/registry.js';\nimport { getActiveEmbedder } from '../../embedders/schema.js';\nimport { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\nimport { scoreTokenOverlap, tokenize } from '../text.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nconst COSINE_THRESHOLD = 0.2;\n\nlet activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n\nexport interface SemanticShadowRuntimeHealth {\n  readonly checkedAt: string;\n  readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n  readonly dimMismatch: boolean;\n  readonly disabledReason: string | null;\n  readonly lastPromptEmbeddingAt: string | null;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport { getAdapter } from '../../embedders/registry.js';\nimport { getActiveEmbedder } from '../../embedders/schema.js';\nimport { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\nimport { scoreTokenOverlap, tokenize } from '../text.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nconst COSINE_THRESHOLD = 0.2;\n\nlet activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n\nexport interface SemanticShadowRuntimeHealth {\n  readonly checkedAt: string;\n  readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n  readonly dimMismatch: boolean;\n  readonly disabledReason: string | null;\n  readonly lastPromptEmbeddingAt: string | null;\n}\n\nlet runtimeHealth: SemanticShadowRuntimeHealth = {\n  checkedAt: new Date(0).toISOString(),\n  activeEmbedder: null,\n  dimMismatch: false,\n  disabledReason: null,\n  lastPromptEmbeddingAt: null,\n};\n\nfunction setRuntimeHealth(update: Partial<SemanticShadowRuntimeHealth>): void {\n  runtimeHealth = {\n    ...runtimeHealth,\n    ...update,\n    checkedAt: new Date().toISOString(),\n  };\n}\n\nexport function getSemanticShadowRuntimeHealth(): SemanticShadowRuntimeHealth {\n  return runtimeHealth;\n}\n\nfunction toFloat32Array(vector: Float32Array | readonly number[]): Float32Array {\n  return vector instanceof Float32Array ? vector : Float32Array.from(vector);\n}\n\nfunction cosineSimilarity(left: Float32Array, right: Float32Array): number {\n  const length = Math.min(left.length, right.length);\n  if (length === 0) {\n    return 0;\n  }\n\n  let dot = 0;\n  let leftNorm = 0;\n  let rightNorm = 0;\n  for (let index = 0; index < length; index++) {\n    const leftValue = left[index];\n    const rightValue = right[index];\n    dot += leftValue * rightValue;\n    leftNorm += leftValue * leftValue;\n    rightNorm += rightValue * rightValue;\n  }\n\n  if (leftNorm === 0 || rightNorm === 0) {\n    return 0;\n  }\n\n  return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n}\n\nfunction fixtureVector(text: string): Float32Array {\n  const normalized = text.toLowerCase().split(/\\W+/).filter(Boolean);\n  const vector = new Float32Array(32);\n  for (const token of normalized) {\n    let hash = 0;\n    for (let index = 0; index < token.length; index++) {\n      hash = ((hash << 5) - hash + token.charCodeAt(index)) | 0;\n    }\n    vector[Math.abs(hash) % vector.length] += 1;\n  }\n  return vector;\n}\n\nexport function setSemanticShadowPromptEmbedding(prompt: string, vector: Float32Array | readonly number[] | null | undefined): void {\n  activePromptEmbedding = vector ? { prompt, vector: toFloat32Array(vector) } : null;\n}\n\nexport function clearSemanticShadowPromptEmbedding(): void {\n  activePromptEmbedding = null;\n}\n\nexport async function withSemanticShadowPromptEmbedding<T>(prompt: string, run: () => T): Promise<T> {\n  if (process.env.VITEST === 'true') {\n    return run();\n  }\n\n  try {\n    // Read-only access: recommend calls must never open the daemon-owned\n    // database read-write (dual-writer hazard) or create it when absent.\n    const database = getDbReadOnly();\n    if (!database) {\n      setRuntimeHealth({\n        activeEmbedder: null,\n        dimMismatch: false,\n        disabledReason: 'database_absent',\n      });\n      throw new Error('skill graph database is absent; shadow scoring disabled');\n    }\n    const active = getActiveEmbedder(database);\n    const adapter = getAdapter(active.name);\n    if (!adapter) {\n      setRuntimeHealth({\n        activeEmbedder: { name: active.name, dim: active.dim, adapterDim: null },\n        dimMismatch: false,\n        disabledReason: 'adapter_unavailable',\n      });\n      throw new Error(`active embedder is not registered: ${active.name}`);\n    }\n    if (adapter.dim !== active.dim) {\n      setRuntimeHealth({\n        activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n        dimMismatch: true,\n        disabledReason: 'dim_mismatch',\n      });\n      throw new Error(`active embedder dimension mismatch: ${active.name} reports ${adapter.dim}, pointer expects ${active.dim}`);\n    }\n\n    const [vector] = await adapter.embed([prompt], { inputType: 'query' });\n    setSemanticShadowPromptEmbedding(prompt, vector ?? null);\n    setRuntimeHealth({\n      activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n      dimMismatch: false,\n      disabledReason: vector ? null : 'prompt_embedding_empty',\n      lastPromptEmbeddingAt: vector ? new Date().toISOString() : runtimeHealth.lastPromptEmbeddingAt,\n    });\n  } catch (error: unknown) {\n    setSemanticShadowPromptEmbedding(prompt, null);\n    const message = error instanceof Error ? error.message : String(error);\n    if (!runtimeHealth.disabledReason) {\n      setRuntimeHealth({ disabledReason: 'prompt_embedding_failed' });\n    }\n    console.warn(`[semantic-shadow] Prompt embedding failed; cosine lane disabled for this call (${message})`);\n  }\n\n  try {\n    return run();\n  } finally {\n    clearSemanticShadowPromptEmbedding();\n  }\n}\n\nexport const _semanticShadowTest = {\n  cosineSimilarity,\n  fixtureVector,\n};\n\nexport function scoreSemanticShadowExactSubset(\n  prompt: string,\n  projection: AdvisorProjection,\n  skillIds: readonly string[],\n): LaneMatch[] {\n  if (projection.embeddingStaleness?.stale) {\n    setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n    return [];\n  }\n\n  const orderedSkillIds = [...new Set(skillIds)];\n  if (orderedSkillIds.length === 0) return [];\n\n  const promptVector = activePromptEmbedding?.prompt === prompt\n    ? activePromptEmbedding.vector\n    : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n  if (!promptVector) {\n    return [];\n  }\n\n  const requested = new Set(orderedSkillIds);\n  const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n    ? new Map(projection.skills\n        .filter((skill) => requested.has(skill.id))\n        .map((skill) => [skill.id, fixtureVector([\n          skill.name,\n          skill.description,\n          ...skill.domains,\n          ...skill.intentSignals,\n          ...skill.derivedTriggers,\n        ].join(' '))]))\n    : new Map<string, Float32Array>();\n\n  let cachedVectors = new Map<string, Float32Array>();\n  if (projection.source !== 'fixture' && process.env.VITEST !== 'true') {\n    try {\n      cachedVectors = new Map(\n        loadSkillEmbeddings(orderedSkillIds)\n          .map((row) => [row.skillId, row.embedding]),\n      );\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n      console.warn(`[semantic-shadow] Exact skill embedding load failed; rerank disabled (${message})`);\n      return [];\n    }\n  }\n\n  return orderedSkillIds\n    .map((skillId): LaneMatch | null => {\n      const skillVector = cachedVectors.get(skillId) ?? fixtureVectors.get(skillId);\n      if (!skillVector) {\n        return null;\n      }\n      const score = cosineSimilarity(promptVector, skillVector);\n      const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n      return {\n        skillId,\n        lane: 'semantic_shadow' as const,\n        score: roundedScore,\n        evidence: [`cosine-exact:${score.toFixed(4)}`],\n        shadowOnly: false,\n      };\n    })\n    .filter((match): match is LaneMatch => match !== null);\n}\n\nexport function scoreSemanticShadowLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n  if (projection.embeddingStaleness?.stale) {\n    setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n    return [];\n  }\n\n  if (!activePromptEmbedding && process.env.VITEST === 'true') {\n    const tokens = tokenize(prompt);\n    return projection.skills\n      .map((skill) => ({\n        skillId: skill.id,\n        lane: 'semantic_shadow' as const,\n        score: Math.min(scoreTokenOverlap(tokens, [\n          skill.name,\n          skill.description,\n          ...skill.domains,\n          ...skill.intentSignals,\n          ...skill.derivedTriggers,\n        ]) * 0.8, 1),\n        evidence: ['shadow:test-fallback'],\n        shadowOnly: false,\n      }))\n      .filter((match) => match.score > 0.08);\n  }\n\n  const promptVector = activePromptEmbedding?.prompt === prompt\n    ? activePromptEmbedding.vector\n    : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n  if (!promptVector) {\n    return [];\n  }\n\n  const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n    ? new Map(projection.skills.map((skill) => [skill.id, fixtureVector([\n        skill.name,\n        skill.description,\n        ...skill.domains,","lineStart":1,"lineEnd":260,"totalLines":311,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","time":{"start":1783437217873,"end":1783437217917}},"metadata":{"openai":{"itemId":"fc_0ca241608142d171016a4d17a14a04819197a272872e8d19fc"}},"id":"prt_f3d24504f001iKvvKZKogA1wl8","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d241de0001RqM8ozNmqoEouG"}}
