{"type":"tool_use","timestamp":1781129304604,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_OsrAb3rg8naEtQofvHP3dZxV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: advisor_recommend Handler\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { realpathSync } from 'node:fs';\n6: import { resolve } from 'node:path';\n7: \n8: import { advisorPromptCache } from '../lib/prompt-cache.js';\n9: import {\n10:   resolveAdvisorThresholdConfig,\n11: } from '../lib/skill-advisor-brief.js';\n12: import { scoreAdvisorPrompt } from '../lib/scorer/fusion.js';\n13: import { withSemanticShadowPromptEmbedding } from '../lib/scorer/lanes/semantic-shadow.js';\n14: import { DEFAULT_SHADOW_SCORER_LANE_WEIGHTS } from '../lib/scorer/lane-registry.js';\n15: import { sanitizeSkillLabel } from '../lib/render.js';\n16: import { recordShadowDelta } from '../lib/shadow/shadow-sink.js';\n17: import { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';\n18: import {\n19:   AdvisorRecommendInputSchema,\n20:   AdvisorRecommendOutputSchema,\n21:   type AdvisorRecommendInput,\n22:   type AdvisorRecommendOutput,\n23: } from '../schemas/advisor-tool-schemas.js';\n24: import { readAdvisorStatus } from './advisor-status.js';\n25: \n26: type HandlerResponse = { content: Array<{ type: string; text: string }> };\n27: type AdvisorStatus = ReturnType<typeof readAdvisorStatus>;\n28: type ScoredRecommendation = ReturnType<typeof scoreAdvisorPrompt>['recommendations'][number];\n29: type PublicRecommendationStatus = NonNullable<AdvisorRecommendOutput['recommendations'][number]['status']>;\n30: type PublicThresholds = AdvisorRecommendOutput['effectiveThresholds'];\n31: type ShadowRecommendation = NonNullable<AdvisorRecommendOutput['_shadow']>['recommendations'][number];\n32: \n33: function findWorkspaceRoot(start = process.cwd()): string {\n34:   return findAdvisorWorkspaceRoot(start, { maxDepth: 12 });\n35: }\n36: \n37: // Canonicalize a caller-supplied workspaceRoot via realpath.\n38: // The schema-level allowlist refinement runs against the same canonical\n39: // form, so a caller passing /tmp/symlink-to-repo gets the real path\n40: // post-symlink before downstream code uses it.\n41: function canonicalizeWorkspaceRoot(input: string): string {\n42:   const resolved = resolve(input);\n43:   try {\n44:     return realpathSync.native(resolved);\n45:   } catch {\n46:     return resolved;\n47:   }\n48: }\n49: \n50: function cacheSourceSignature(status: AdvisorStatus): string {\n51:   return `${status.freshness}:${status.generation}:${status.lastGenerationBump ?? 'never'}`;\n52: }\n53: \n54: function recommendationLabels(output: AdvisorRecommendOutput): string[] {\n55:   return output.recommendations.map((recommendation) => recommendation.skillId);\n56: }\n57: \n58: function unavailableTrustState(reason: string): AdvisorRecommendOutput['trustState'] {\n59:   return {\n60:     state: 'unavailable',\n61:     reason,\n62:     generation: 0,\n63:     checkedAt: new Date().toISOString(),\n64:     lastLiveAt: null,\n65:   };\n66: }\n67: \n68: function publicThresholds(args: {\n69:   confidenceThreshold?: number;\n70:   uncertaintyThreshold?: number;\n71: }): PublicThresholds {\n72:   const resolved = resolveAdvisorThresholdConfig(args);\n73:   return {\n74:     confidenceThreshold: resolved.confidenceThreshold,\n75:     uncertaintyThreshold: resolved.uncertaintyThreshold,\n76:     confidenceOnly: resolved.confidenceOnly,\n77:   };\n78: }\n79: \n80: function emptyOutput(args: {\n81:   workspaceRoot: string;\n82:   effectiveThresholds: AdvisorRecommendOutput['effectiveThresholds'];\n83:   freshness: AdvisorRecommendOutput['freshness'];\n84:   trustState: AdvisorRecommendOutput['trustState'];\n85:   warnings?: readonly string[];\n86:   abstainReasons?: readonly string[];\n87: }): AdvisorRecommendOutput {\n88:   return AdvisorRecommendOutputSchema.parse({\n89:     workspaceRoot: args.workspaceRoot,\n90:     effectiveThresholds: args.effectiveThresholds,\n91:     recommendations: [],\n92:     ambiguous: false,\n93:     freshness: args.freshness,\n94:     trustState: args.trustState,\n95:     generatedAt: new Date().toISOString(),\n96:     cache: {\n97:       hit: false,\n98:       sourceSignaturePresent: false,\n99:     },\n100:     ...(args.warnings && args.warnings.length > 0 ? { warnings: [...args.warnings] } : {}),\n101:     ...(args.abstainReasons && args.abstainReasons.length > 0 ? { abstainReasons: [...args.abstainReasons] } : {}),\n102:   });\n103: }\n104: \n105: function disabledOutput(\n106:   workspaceRoot: string,\n107:   effectiveThresholds: PublicThresholds,\n108: ): AdvisorRecommendOutput {\n109:   return emptyOutput({\n110:     workspaceRoot,\n111:     effectiveThresholds,\n112:     freshness: 'unavailable',\n113:     trustState: unavailableTrustState('ADVISOR_DISABLED'),\n114:     warnings: ['ADVISOR_DISABLED'],\n115:     abstainReasons: ['Skill advisor disabled by SPECKIT_SKILL_ADVISOR_HOOK_DISABLED.'],\n116:   });\n117: }\n118: \n119: function absentOutput(\n120:   status: AdvisorStatus,\n121:   workspaceRoot: string,\n122:   effectiveThresholds: AdvisorRecommendOutput['effectiveThresholds'],\n123: ): AdvisorRecommendOutput {\n124:   return emptyOutput({\n125:     workspaceRoot,\n126:     effectiveThresholds,\n127:     freshness: 'absent',\n128:     trustState: status.trustState,\n129:     warnings: [status.trustState.reason ?? 'ADVISOR_FRESHNESS_ABSENT'],\n130:     abstainReasons: ['Skill advisor freshness is absent; returning fail-open empty recommendations.'],\n131:   });\n132: }\n133: \n134: function unavailableOutput(\n135:   status: AdvisorStatus,\n136:   workspaceRoot: string,\n137:   effectiveThresholds: AdvisorRecommendOutput['effectiveThresholds'],\n138: ): AdvisorRecommendOutput {\n139:   return emptyOutput({\n140:     workspaceRoot,\n141:     effectiveThresholds,\n142:     freshness: 'unavailable',\n143:     trustState: {\n144:       ...status.trustState,\n145:       state: 'unavailable',\n146:       reason: 'advisor_unavailable',\n147:     },\n148:     warnings: ['advisor_unavailable', ...(status.errors ?? [])],\n149:     abstainReasons: ['Skill advisor freshness is unavailable; returning fail-open empty recommendations.'],\n150:   });\n151: }\n152: \n153: function safeMany(values: readonly string[] | undefined): string[] {\n154:   return (values ?? [])\n155:     .map((value) => sanitizeSkillLabel(value))\n156:     .filter((value): value is string => Boolean(value));\n157: }\n158: \n159: function evidenceFeature(value: string): string {\n160:   const prefix = value.split(':', 1)[0];\n161:   switch (prefix) {\n162:     case 'phrase':\n163:       return 'phrase_match';\n164:     case 'token':\n165:       return 'token_match';\n166:     case 'hint':\n167:       return 'category_hint';\n168:     case 'derived':\n169:       return 'derived_skill_signal';\n170:     case 'cosine':\n171:       return 'semantic_similarity';\n172:     default:\n173:       if (value.includes('disambiguation')) return 'disambiguation_rule';\n174:       if (value.includes('surface')) return 'surface_signal';\n175:       if (value.includes('intent')) return 'intent_signal';\n176:       if (value.includes('loop')) return 'workflow_signal';\n177:       return 'scorer_signal';\n178:   }\n179: }\n180: \n181: function publicWhyRecommended(recommendation: ScoredRecommendation) {\n182:   const positiveLanes = recommendation.laneContributions\n183:     .filter((lane) => lane.rawScore > 0 || lane.weightedScore > 0)\n184:     .sort((left, right) => right.weightedScore - left.weightedScore)\n185:     .slice(0, 4);\n186:   const matchedSkillFeatures = positiveLanes.flatMap((lane) => (\n187:     Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))).map((feature) => ({\n188:       lane: lane.lane,\n189:       feature,\n190:     }))\n191:   ));\n192:   const dominant = recommendation.dominantLane;\n193:   return {\n194:     reason: dominant\n195:       ? `Recommended from ranker signals: ${dominant} contributed the strongest live score.`\n196:       : 'Recommended from ranker signals without a single dominant live lane.',\n197:     dominantLane: dominant,\n198:     topLanes: positiveLanes.map((lane) => ({\n199:       lane: lane.lane,\n200:       rawScore: lane.rawScore,\n201:       weightedScore: lane.weightedScore,\n202:       weight: lane.weight,\n203:       shadowOnly: lane.shadowOnly,\n204:       evidenceTypes: Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))),\n205:       evidenceCount: lane.evidence.length,\n206:     })),\n207:     matchedSkillFeatures,\n208:   };\n209: }\n210: \n211: function publicRecommendation(recommendation: ScoredRecommendation, includeAttribution: boolean) {\n212:   const skillId = sanitizeSkillLabel(recommendation.skill);\n213:   if (!skillId) return null;\n214:   const redirectFrom = safeMany(recommendation.redirectFrom);\n215:   const redirectTo = sanitizeSkillLabel(recommendation.redirectTo ?? '');\n216:   const sanitizedStatus = sanitizeSkillLabel(recommendation.lifecycleStatus);\n217:   const status: PublicRecommendationStatus | undefined = sanitizedStatus === 'active'\n218:     || sanitizedStatus === 'deprecated'\n219:     || sanitizedStatus === 'archived'\n220:     || sanitizedStatus === 'future'\n221:     ? sanitizedStatus as PublicRecommendationStatus\n222:     : undefined;\n223:   return {\n224:     skillId,\n225:     score: recommendation.score,\n226:     confidence: recommendation.confidence,\n227:     uncertainty: recommendation.uncertainty,\n228:     dominantLane: recommendation.dominantLane,\n229:     ...(includeAttribution ? {\n230:       laneBreakdown: recommendation.laneContributions.map((lane) => ({\n231:         lane: lane.lane,\n232:         rawScore: lane.rawScore,\n233:         weightedScore: lane.weightedScore,\n234:         weight: lane.weight,\n235:         shadowOnly: lane.shadowOnly,\n236:       })),\n237:       why_recommended: publicWhyRecommended(recommendation),\n238:     } : {}),\n239:     ...(redirectFrom.length > 0 ? { redirectFrom } : {}),\n240:     ...(redirectTo ? { redirectTo } : {}),\n241:     ...(status ? { status } : {}),\n242:   };\n243: }\n244: \n245: function publicShadowRecommendations(recommendations: readonly ScoredRecommendation[], topK: number): ShadowRecommendation[] {\n246:   const shadowRecommendations: ShadowRecommendation[] = [];\n247:   for (const recommendation of recommendations) {\n248:     const skillId = sanitizeSkillLabel(recommendation.skill);\n249:     if (!skillId) continue;\n250:     const shadowContributions = recommendation.laneContributions.map((lane) => ({\n251:       lane: lane.lane,\n252:       weightedScore: lane.rawScore * DEFAULT_SHADOW_SCORER_LANE_WEIGHTS[lane.lane],\n253:     }));\n254:     const shadowScore = roundScore(shadowContributions.reduce((total, lane) => total + lane.weightedScore, 0));\n255:     const dominant = shadowContributions\n256:       .filter((lane) => lane.weightedScore > 0)\n257:       .sort((left, right) => right.weightedScore - left.weightedScore)[0]?.lane ?? null;\n258:     shadowRecommendations.push({\n259:         skillId,\n260:         liveScore: recommendation.score,\n261:         shadowScore,\n262:         delta: roundScore(shadowScore - recommendation.score),\n263:         dominantShadowLane: dominant,\n264:     });\n265:   }\n266:   return shadowRecommendations\n267:     .sort((left, right) => right.shadowScore - left.shadowScore || left.skillId.localeCompare(right.skillId))\n268:     .slice(0, topK);\n269: }\n270: \n271: function roundScore(value: number): number {\n272:   return Math.round(value * 1_000_000) / 1_000_000;\n273: }\n274: \n275: async function computeRecommendationOutput(input: AdvisorRecommendInput): Promise<AdvisorRecommendOutput> {\n276:   // Canonicalize via realpath after the schema allowlist check.\n277:   const workspaceRoot = input.workspaceRoot\n278:     ? canonicalizeWorkspaceRoot(input.workspaceRoot)\n279:     : findWorkspaceRoot();\n280:   const effectiveThresholds = publicThresholds({\n281:     confidenceThreshold: input.options?.confidenceThreshold,\n282:     uncertaintyThreshold: input.options?.uncertaintyThreshold,\n283:   });\n284:   const status = readAdvisorStatus({ workspaceRoot });\n285:   if (status.freshness === 'unavailable') {\n286:     return unavailableOutput(status, workspaceRoot, effectiveThresholds);\n287:   }\n288:   if (status.freshness === 'absent') {\n289:     return absentOutput(status, workspaceRoot, effectiveThresholds);\n290:   }\n291:   const sourceSignature = cacheSourceSignature(status);\n292:   advisorPromptCache.invalidateSourceSignatureChange(sourceSignature);\n293:   const key = advisorPromptCache.makeKey({\n294:     canonicalPrompt: input.prompt.trim(),\n295:     sourceSignature,\n296:     workspaceRoot,\n297:     runtime: 'mcp',\n298:     maxTokens: input.options?.topK,\n299:     thresholdConfig: {\n300:       confidenceThreshold: input.options?.confidenceThreshold,\n301:       uncertaintyThreshold: input.options?.uncertaintyThreshold,\n302:       includeAttribution: input.options?.includeAttribution,\n303:       includeAbstainReasons: input.options?.includeAbstainReasons,\n304:     },\n305:   });\n306:   const cached = advisorPromptCache.get(key);\n307:   if (cached) {\n308:     const cachedOutput = cached.value as AdvisorRecommendOutput;\n309:     return AdvisorRecommendOutputSchema.parse({\n310:       ...cachedOutput,\n311:       workspaceRoot,\n312:       effectiveThresholds,\n313:       cache: {\n314:         ...cachedOutput.cache,\n315:         hit: true,\n316:       },\n317:     });\n318:   }\n319: \n320:   const topK = input.options?.topK ?? 3;\n321:   const result = await withSemanticShadowPromptEmbedding(input.prompt, () => scoreAdvisorPrompt(input.prompt, {\n322:     workspaceRoot,\n323:     confidenceThreshold: input.options?.confidenceThreshold,\n324:     uncertaintyThreshold: input.options?.uncertaintyThreshold,\n325:   }));\n326:   const recommendations = result.recommendations\n327:     .map((recommendation) => publicRecommendation(recommendation, Boolean(input.options?.includeAttribution)))\n328:     .filter((recommendation): recommendation is NonNullable<typeof recommendation> => Boolean(recommendation))\n329:     .slice(0, topK);\n330:   const output: AdvisorRecommendOutput = {\n331:     workspaceRoot,\n332:     effectiveThresholds,\n333:     recommendations,\n334:     ambiguous: result.ambiguous,\n335:     freshness: status.freshness,\n336:     trustState: status.trustState,\n337:     generatedAt: new Date().toISOString(),\n338:     cache: {\n339:       hit: false,\n340:       sourceSignaturePresent: status.generation > 0 || status.lastGenerationBump !== null,\n341:     },\n342:     _shadow: {\n343:       model: 'advisor-shadow-learned-weights-v1',\n344:       liveWeightsFrozen: true,\n345:       recommendations: publicShadowRecommendations(result.recommendations, topK),\n346:     },\n347:     ...(status.freshness === 'stale' ? { warnings: [status.trustState.reason ?? 'STALE_ADVISOR_FRESHNESS'] } : {}),\n348:     ...(input.options?.includeAbstainReasons && result.unknown\n349:       ? { abstainReasons: ['No recommendation passed confidence and uncertainty thresholds.'] }\n350:       : {}),\n351:   };\n352:   const parsed = AdvisorRecommendOutputSchema.parse(output);\n353:   for (const shadow of parsed._shadow?.recommendations ?? []) {\n354:     recordShadowDelta({\n355:       prompt: input.prompt,\n356:       recommendation: shadow.skillId,\n357:       liveScore: shadow.liveScore,\n358:       shadowScore: shadow.shadowScore,\n359:       delta: shadow.delta,\n360:       dominantLane: shadow.dominantShadowLane,\n361:       timestamp: parsed.generatedAt,\n362:     });\n363:   }\n364:   advisorPromptCache.set({\n365:     key,\n366:     sourceSignature,\n367:     value: parsed,\n368:     skillLabels: recommendationLabels(parsed),\n369:   });\n370:   return parsed;\n371: }\n372: \n373: export async function handleAdvisorRecommend(args: unknown): Promise<HandlerResponse> {\n374:   const input = AdvisorRecommendInputSchema.parse(args);\n375:   // Canonicalize via realpath after the schema allowlist check.\n376:   const workspaceRoot = input.workspaceRoot\n377:     ? canonicalizeWorkspaceRoot(input.workspaceRoot)\n378:     : findWorkspaceRoot();\n379:   const effectiveThresholds = publicThresholds({\n380:     confidenceThreshold: input.options?.confidenceThreshold,\n381:     uncertaintyThreshold: input.options?.uncertaintyThreshold,\n382:   });\n383:   const data = process.env.SPECKIT_SKILL_ADVISOR_HOOK_DISABLED === '1'\n384:     ? disabledOutput(workspaceRoot, effectiveThresholds)\n385:     : await computeRecommendationOutput(input);\n386:   return {\n387:     content: [{\n388:       type: 'text',\n389:       text: JSON.stringify({ status: 'ok', data }, null, 2),\n390:     }],\n391:   };\n392: }\n393: \n394: export const handle_advisor_recommend = handleAdvisorRecommend;\n\n(End of file - total 394 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: advisor_recommend Handler\n// ───────────────────────────────────────────────────────────────\n\nimport { realpathSync } from 'node:fs';\nimport { resolve } from 'node:path';\n\nimport { advisorPromptCache } from '../lib/prompt-cache.js';\nimport {\n  resolveAdvisorThresholdConfig,\n} from '../lib/skill-advisor-brief.js';\nimport { scoreAdvisorPrompt } from '../lib/scorer/fusion.js';\nimport { withSemanticShadowPromptEmbedding } from '../lib/scorer/lanes/semantic-shadow.js';\nimport { DEFAULT_SHADOW_SCORER_LANE_WEIGHTS } from '../lib/scorer/lane-registry.js';\nimport { sanitizeSkillLabel } from '../lib/render.js';\nimport { recordShadowDelta } from '../lib/shadow/shadow-sink.js';\nimport { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';\nimport {\n  AdvisorRecommendInputSchema,\n  AdvisorRecommendOutputSchema,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: advisor_recommend Handler\n// ───────────────────────────────────────────────────────────────\n\nimport { realpathSync } from 'node:fs';\nimport { resolve } from 'node:path';\n\nimport { advisorPromptCache } from '../lib/prompt-cache.js';\nimport {\n  resolveAdvisorThresholdConfig,\n} from '../lib/skill-advisor-brief.js';\nimport { scoreAdvisorPrompt } from '../lib/scorer/fusion.js';\nimport { withSemanticShadowPromptEmbedding } from '../lib/scorer/lanes/semantic-shadow.js';\nimport { DEFAULT_SHADOW_SCORER_LANE_WEIGHTS } from '../lib/scorer/lane-registry.js';\nimport { sanitizeSkillLabel } from '../lib/render.js';\nimport { recordShadowDelta } from '../lib/shadow/shadow-sink.js';\nimport { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';\nimport {\n  AdvisorRecommendInputSchema,\n  AdvisorRecommendOutputSchema,\n  type AdvisorRecommendInput,\n  type AdvisorRecommendOutput,\n} from '../schemas/advisor-tool-schemas.js';\nimport { readAdvisorStatus } from './advisor-status.js';\n\ntype HandlerResponse = { content: Array<{ type: string; text: string }> };\ntype AdvisorStatus = ReturnType<typeof readAdvisorStatus>;\ntype ScoredRecommendation = ReturnType<typeof scoreAdvisorPrompt>['recommendations'][number];\ntype PublicRecommendationStatus = NonNullable<AdvisorRecommendOutput['recommendations'][number]['status']>;\ntype PublicThresholds = AdvisorRecommendOutput['effectiveThresholds'];\ntype ShadowRecommendation = NonNullable<AdvisorRecommendOutput['_shadow']>['recommendations'][number];\n\nfunction findWorkspaceRoot(start = process.cwd()): string {\n  return findAdvisorWorkspaceRoot(start, { maxDepth: 12 });\n}\n\n// Canonicalize a caller-supplied workspaceRoot via realpath.\n// The schema-level allowlist refinement runs against the same canonical\n// form, so a caller passing /tmp/symlink-to-repo gets the real path\n// post-symlink before downstream code uses it.\nfunction canonicalizeWorkspaceRoot(input: string): string {\n  const resolved = resolve(input);\n  try {\n    return realpathSync.native(resolved);\n  } catch {\n    return resolved;\n  }\n}\n\nfunction cacheSourceSignature(status: AdvisorStatus): string {\n  return `${status.freshness}:${status.generation}:${status.lastGenerationBump ?? 'never'}`;\n}\n\nfunction recommendationLabels(output: AdvisorRecommendOutput): string[] {\n  return output.recommendations.map((recommendation) => recommendation.skillId);\n}\n\nfunction unavailableTrustState(reason: string): AdvisorRecommendOutput['trustState'] {\n  return {\n    state: 'unavailable',\n    reason,\n    generation: 0,\n    checkedAt: new Date().toISOString(),\n    lastLiveAt: null,\n  };\n}\n\nfunction publicThresholds(args: {\n  confidenceThreshold?: number;\n  uncertaintyThreshold?: number;\n}): PublicThresholds {\n  const resolved = resolveAdvisorThresholdConfig(args);\n  return {\n    confidenceThreshold: resolved.confidenceThreshold,\n    uncertaintyThreshold: resolved.uncertaintyThreshold,\n    confidenceOnly: resolved.confidenceOnly,\n  };\n}\n\nfunction emptyOutput(args: {\n  workspaceRoot: string;\n  effectiveThresholds: AdvisorRecommendOutput['effectiveThresholds'];\n  freshness: AdvisorRecommendOutput['freshness'];\n  trustState: AdvisorRecommendOutput['trustState'];\n  warnings?: readonly string[];\n  abstainReasons?: readonly string[];\n}): AdvisorRecommendOutput {\n  return AdvisorRecommendOutputSchema.parse({\n    workspaceRoot: args.workspaceRoot,\n    effectiveThresholds: args.effectiveThresholds,\n    recommendations: [],\n    ambiguous: false,\n    freshness: args.freshness,\n    trustState: args.trustState,\n    generatedAt: new Date().toISOString(),\n    cache: {\n      hit: false,\n      sourceSignaturePresent: false,\n    },\n    ...(args.warnings && args.warnings.length > 0 ? { warnings: [...args.warnings] } : {}),\n    ...(args.abstainReasons && args.abstainReasons.length > 0 ? { abstainReasons: [...args.abstainReasons] } : {}),\n  });\n}\n\nfunction disabledOutput(\n  workspaceRoot: string,\n  effectiveThresholds: PublicThresholds,\n): AdvisorRecommendOutput {\n  return emptyOutput({\n    workspaceRoot,\n    effectiveThresholds,\n    freshness: 'unavailable',\n    trustState: unavailableTrustState('ADVISOR_DISABLED'),\n    warnings: ['ADVISOR_DISABLED'],\n    abstainReasons: ['Skill advisor disabled by SPECKIT_SKILL_ADVISOR_HOOK_DISABLED.'],\n  });\n}\n\nfunction absentOutput(\n  status: AdvisorStatus,\n  workspaceRoot: string,\n  effectiveThresholds: AdvisorRecommendOutput['effectiveThresholds'],\n): AdvisorRecommendOutput {\n  return emptyOutput({\n    workspaceRoot,\n    effectiveThresholds,\n    freshness: 'absent',\n    trustState: status.trustState,\n    warnings: [status.trustState.reason ?? 'ADVISOR_FRESHNESS_ABSENT'],\n    abstainReasons: ['Skill advisor freshness is absent; returning fail-open empty recommendations.'],\n  });\n}\n\nfunction unavailableOutput(\n  status: AdvisorStatus,\n  workspaceRoot: string,\n  effectiveThresholds: AdvisorRecommendOutput['effectiveThresholds'],\n): AdvisorRecommendOutput {\n  return emptyOutput({\n    workspaceRoot,\n    effectiveThresholds,\n    freshness: 'unavailable',\n    trustState: {\n      ...status.trustState,\n      state: 'unavailable',\n      reason: 'advisor_unavailable',\n    },\n    warnings: ['advisor_unavailable', ...(status.errors ?? [])],\n    abstainReasons: ['Skill advisor freshness is unavailable; returning fail-open empty recommendations.'],\n  });\n}\n\nfunction safeMany(values: readonly string[] | undefined): string[] {\n  return (values ?? [])\n    .map((value) => sanitizeSkillLabel(value))\n    .filter((value): value is string => Boolean(value));\n}\n\nfunction evidenceFeature(value: string): string {\n  const prefix = value.split(':', 1)[0];\n  switch (prefix) {\n    case 'phrase':\n      return 'phrase_match';\n    case 'token':\n      return 'token_match';\n    case 'hint':\n      return 'category_hint';\n    case 'derived':\n      return 'derived_skill_signal';\n    case 'cosine':\n      return 'semantic_similarity';\n    default:\n      if (value.includes('disambiguation')) return 'disambiguation_rule';\n      if (value.includes('surface')) return 'surface_signal';\n      if (value.includes('intent')) return 'intent_signal';\n      if (value.includes('loop')) return 'workflow_signal';\n      return 'scorer_signal';\n  }\n}\n\nfunction publicWhyRecommended(recommendation: ScoredRecommendation) {\n  const positiveLanes = recommendation.laneContributions\n    .filter((lane) => lane.rawScore > 0 || lane.weightedScore > 0)\n    .sort((left, right) => right.weightedScore - left.weightedScore)\n    .slice(0, 4);\n  const matchedSkillFeatures = positiveLanes.flatMap((lane) => (\n    Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))).map((feature) => ({\n      lane: lane.lane,\n      feature,\n    }))\n  ));\n  const dominant = recommendation.dominantLane;\n  return {\n    reason: dominant\n      ? `Recommended from ranker signals: ${dominant} contributed the strongest live score.`\n      : 'Recommended from ranker signals without a single dominant live lane.',\n    dominantLane: dominant,\n    topLanes: positiveLanes.map((lane) => ({\n      lane: lane.lane,\n      rawScore: lane.rawScore,\n      weightedScore: lane.weightedScore,\n      weight: lane.weight,\n      shadowOnly: lane.shadowOnly,\n      evidenceTypes: Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))),\n      evidenceCount: lane.evidence.length,\n    })),\n    matchedSkillFeatures,\n  };\n}\n\nfunction publicRecommendation(recommendation: ScoredRecommendation, includeAttribution: boolean) {\n  const skillId = sanitizeSkillLabel(recommendation.skill);\n  if (!skillId) return null;\n  const redirectFrom = safeMany(recommendation.redirectFrom);\n  const redirectTo = sanitizeSkillLabel(recommendation.redirectTo ?? '');\n  const sanitizedStatus = sanitizeSkillLabel(recommendation.lifecycleStatus);\n  const status: PublicRecommendationStatus | undefined = sanitizedStatus === 'active'\n    || sanitizedStatus === 'deprecated'\n    || sanitizedStatus === 'archived'\n    || sanitizedStatus === 'future'\n    ? sanitizedStatus as PublicRecommendationStatus\n    : undefined;\n  return {\n    skillId,\n    score: recommendation.score,\n    confidence: recommendation.confidence,\n    uncertainty: recommendation.uncertainty,\n    dominantLane: recommendation.dominantLane,\n    ...(includeAttribution ? {\n      laneBreakdown: recommendation.laneContributions.map((lane) => ({\n        lane: lane.lane,\n        rawScore: lane.rawScore,\n        weightedScore: lane.weightedScore,\n        weight: lane.weight,\n        shadowOnly: lane.shadowOnly,\n      })),\n      why_recommended: publicWhyRecommended(recommendation),\n    } : {}),\n    ...(redirectFrom.length > 0 ? { redirectFrom } : {}),\n    ...(redirectTo ? { redirectTo } : {}),\n    ...(status ? { status } : {}),\n  };\n}\n\nfunction publicShadowRecommendations(recommendations: readonly ScoredRecommendation[], topK: number): ShadowRecommendation[] {\n  const shadowRecommendations: ShadowRecommendation[] = [];\n  for (const recommendation of recommendations) {\n    const skillId = sanitizeSkillLabel(recommendation.skill);\n    if (!skillId) continue;\n    const shadowContributions = recommendation.laneContributions.map((lane) => ({\n      lane: lane.lane,\n      weightedScore: lane.rawScore * DEFAULT_SHADOW_SCORER_LANE_WEIGHTS[lane.lane],\n    }));\n    const shadowScore = roundScore(shadowContributions.reduce((total, lane) => total + lane.weightedScore, 0));\n    const dominant = shadowContributions\n      .filter((lane) => lane.weightedScore > 0)\n      .sort((left, right) => right.weightedScore - left.weightedScore)[0]?.lane ?? null;\n    shadowRecommendations.push({\n        skillId,\n        liveScore: recommendation.score,\n        shadowScore,\n        delta: roundScore(shadowScore - recommendation.score),\n        dominantShadowLane: dominant,\n    });\n  }\n  return shadowRecommendations\n    .sort((left, right) => right.shadowScore - left.shadowScore || left.skillId.localeCompare(right.skillId))\n    .slice(0, topK);\n}\n\nfunction roundScore(value: number): number {\n  return Math.round(value * 1_000_000) / 1_000_000;\n}\n\nasync function computeRecommendationOutput(input: AdvisorRecommendInput): Promise<AdvisorRecommendOutput> {\n  // Canonicalize via realpath after the schema allowlist check.\n  const workspaceRoot = input.workspaceRoot\n    ? canonicalizeWorkspaceRoot(input.workspaceRoot)\n    : findWorkspaceRoot();\n  const effectiveThresholds = publicThresholds({\n    confidenceThreshold: input.options?.confidenceThreshold,\n    uncertaintyThreshold: input.options?.uncertaintyThreshold,\n  });\n  const status = readAdvisorStatus({ workspaceRoot });\n  if (status.freshness === 'unavailable') {\n    return unavailableOutput(status, workspaceRoot, effectiveThresholds);\n  }\n  if (status.freshness === 'absent') {\n    return absentOutput(status, workspaceRoot, effectiveThresholds);\n  }\n  const sourceSignature = cacheSourceSignature(status);\n  advisorPromptCache.invalidateSourceSignatureChange(sourceSignature);\n  const key = advisorPromptCache.makeKey({\n    canonicalPrompt: input.prompt.trim(),\n    sourceSignature,\n    workspaceRoot,\n    runtime: 'mcp',\n    maxTokens: input.options?.topK,\n    thresholdConfig: {\n      confidenceThreshold: input.options?.confidenceThreshold,\n      uncertaintyThreshold: input.options?.uncertaintyThreshold,\n      includeAttribution: input.options?.includeAttribution,\n      includeAbstainReasons: input.options?.includeAbstainReasons,\n    },\n  });\n  const cached = advisorPromptCache.get(key);\n  if (cached) {\n    const cachedOutput = cached.value as AdvisorRecommendOutput;\n    return AdvisorRecommendOutputSchema.parse({\n      ...cachedOutput,\n      workspaceRoot,\n      effectiveThresholds,\n      cache: {\n        ...cachedOutput.cache,\n        hit: true,\n      },\n    });\n  }\n\n  const topK = input.options?.topK ?? 3;\n  const result = await withSemanticShadowPromptEmbedding(input.prompt, () => scoreAdvisorPrompt(input.prompt, {\n    workspaceRoot,\n    confidenceThreshold: input.options?.confidenceThreshold,\n    uncertaintyThreshold: input.options?.uncertaintyThreshold,\n  }));\n  const recommendations = result.recommendations\n    .map((recommendation) => publicRecommendation(recommendation, Boolean(input.options?.includeAttribution)))\n    .filter((recommendation): recommendation is NonNullable<typeof recommendation> => Boolean(recommendation))\n    .slice(0, topK);\n  const output: AdvisorRecommendOutput = {\n    workspaceRoot,\n    effectiveThresholds,\n    recommendations,\n    ambiguous: result.ambiguous,\n    freshness: status.freshness,\n    trustState: status.trustState,\n    generatedAt: new Date().toISOString(),\n    cache: {\n      hit: false,\n      sourceSignaturePresent: status.generation > 0 || status.lastGenerationBump !== null,\n    },\n    _shadow: {\n      model: 'advisor-shadow-learned-weights-v1',\n      liveWeightsFrozen: true,\n      recommendations: publicShadowRecommendations(result.recommendations, topK),\n    },\n    ...(status.freshness === 'stale' ? { warnings: [status.trustState.reason ?? 'STALE_ADVISOR_FRESHNESS'] } : {}),\n    ...(input.options?.includeAbstainReasons && result.unknown\n      ? { abstainReasons: ['No recommendation passed confidence and uncertainty thresholds.'] }\n      : {}),\n  };\n  const parsed = AdvisorRecommendOutputSchema.parse(output);\n  for (const shadow of parsed._shadow?.recommendations ?? []) {\n    recordShadowDelta({\n      prompt: input.prompt,\n      recommendation: shadow.skillId,\n      liveScore: shadow.liveScore,\n      shadowScore: shadow.shadowScore,\n      delta: shadow.delta,\n      dominantLane: shadow.dominantShadowLane,\n      timestamp: parsed.generatedAt,\n    });\n  }\n  advisorPromptCache.set({\n    key,\n    sourceSignature,\n    value: parsed,\n    skillLabels: recommendationLabels(parsed),\n  });\n  return parsed;\n}\n\nexport async function handleAdvisorRecommend(args: unknown): Promise<HandlerResponse> {\n  const input = AdvisorRecommendInputSchema.parse(args);\n  // Canonicalize via realpath after the schema allowlist check.\n  const workspaceRoot = input.workspaceRoot\n    ? canonicalizeWorkspaceRoot(input.workspaceRoot)\n    : findWorkspaceRoot();\n  const effectiveThresholds = publicThresholds({\n    confidenceThreshold: input.options?.confidenceThreshold,\n    uncertaintyThreshold: input.options?.uncertaintyThreshold,\n  });\n  const data = process.env.SPECKIT_SKILL_ADVISOR_HOOK_DISABLED === '1'\n    ? disabledOutput(workspaceRoot, effectiveThresholds)\n    : await computeRecommendationOutput(input);\n  return {\n    content: [{\n      type: 'text',\n      text: JSON.stringify({ status: 'ok', data }, null, 2),\n    }],\n  };\n}\n\nexport const handle_advisor_recommend = handleAdvisorRecommend;","lineStart":1,"lineEnd":394,"totalLines":394,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts","time":{"start":1781129304593,"end":1781129304598}},"metadata":{"openai":{"itemId":"fc_03a7269519c32c84016a29e05882188191b33d5dcb3ab10b76"}},"id":"prt_eb39459d900123miZKH1hx1anq","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3942f76001MikAc8rxVzXCKv"}}
{"type":"tool_use","timestamp":1781129304630,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_7E5gkHwTt7xtA2aTecstztu3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor MCP Tool Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { z } from 'zod';\n6: import { existsSync, realpathSync } from 'node:fs';\n7: import { resolve } from 'node:path';\n8: import { tmpdir } from 'node:os';\n9: import { SCORER_LANE_IDS } from '../lib/scorer/lane-registry.js';\n10: \n11: export const AdvisorFreshnessSchema = z.enum(['live', 'stale', 'absent', 'unavailable']);\n12: export const AdvisorLaneSchema = z.enum(SCORER_LANE_IDS);\n13: \n14: // Bound caller-supplied workspaceRoot inputs to a small\n15: // allowlist (repo root + os.tmpdir()) so handlers cannot be coerced into\n16: // resolving paths outside the workspace. resolve() canonicalizes the input\n17: // path; realpathSync follows symlinks; the prefix check rejects anything\n18: // that escapes the allowlist after canonicalization.\n19: //\n20: // Repo root is detected by walking up from process.cwd() looking for the\n21: // .opencode/skill sentinel — same shape as findAdvisorWorkspaceRoot but\n22: // inlined here to avoid a circular import between schemas/ and lib/.\n23: function detectRepoRoot(): string {\n24:   // Use the same SKILL.md sentinel that\n25:   // findAdvisorWorkspaceRoot uses in advisor-validate.ts so the schema\n26:   // and the handler agree on which directory is the workspace root.\n27:   // A bare `.opencode/skill` sentinel can match nested mock directories\n28:   // created by other workflows (e.g. mcp_server/.opencode/skill).\n29:   const sentinel = '.opencode/skills/system-spec-kit/SKILL.md';\n30:   let current = resolve(process.cwd());\n31:   for (let index = 0; index < 14; index += 1) {\n32:     if (existsSync(resolve(current, sentinel))) return current;\n33:     const parent = resolve(current, '..');\n34:     if (parent === current) break;\n35:     current = parent;\n36:   }\n37:   return resolve(process.cwd());\n38: }\n39: \n40: function canonicalize(input: string): string {\n41:   const resolved = resolve(input);\n42:   try {\n43:     return realpathSync.native(resolved);\n44:   } catch {\n45:     // Path may not exist yet (test fixtures created lazily,\n46:     // tmpdir mkdtemp paths probed before mkdir). Walk up and realpath the\n47:     // first existing ancestor, then re-join the unresolved tail. This\n48:     // resolves macOS-style symlinks like /tmp → /private/tmp even when\n49:     // the leaf doesn't exist.\n50:     let probe = resolved;\n51:     let tail = '';\n52:     for (let depth = 0; depth < 32; depth += 1) {\n53:       const parent = resolve(probe, '..');\n54:       if (parent === probe) break;\n55:       try {\n56:         const realParent = realpathSync.native(parent);\n57:         return tail\n58:           ? resolve(realParent, probe.slice(parent.length + 1) + tail)\n59:           : resolve(realParent, probe.slice(parent.length + 1));\n60:       } catch {\n61:         // Parent doesn't exist either — keep walking up.\n62:         const segment = probe.slice(parent.length + 1);\n63:         tail = tail ? `${segment}/${tail}` : segment;\n64:         probe = parent;\n65:       }\n66:     }\n67:     return resolved;\n68:   }\n69: }\n70: \n71: const ALLOWED_WORKSPACE_PREFIXES: readonly string[] = (() => {\n72:   const prefixes: string[] = [];\n73:   prefixes.push(canonicalize(detectRepoRoot()));\n74:   prefixes.push(canonicalize(tmpdir()));\n75:   // Include the canonicalized /tmp prefix as well. On macOS\n76:   // os.tmpdir() returns the per-user temp dir under /var/folders/...; the\n77:   // /tmp symlink resolves to /private/tmp. Test fixtures and tools that\n78:   // hardcode /tmp/foo paths need both forms in the allowlist.\n79:   prefixes.push(canonicalize('/tmp'));\n80:   // Accept additional explicit allowlist via env (CI / test runners).\n81:   const envExtras = process.env.SPECKIT_ADVISOR_WORKSPACE_ALLOWLIST;\n82:   if (envExtras) {\n83:     for (const extra of envExtras.split(':')) {\n84:       const trimmed = extra.trim();\n85:       if (trimmed) prefixes.push(canonicalize(trimmed));\n86:     }\n87:   }\n88:   return Array.from(new Set(prefixes));\n89: })();\n90: \n91: /**\n92:  * Validate that a caller-supplied workspaceRoot resolves under\n93:  * the repo root, os.tmpdir(), or an explicit allowlist entry after\n94:  * realpath canonicalization.\n95:  *\n96:  * Exported so handlers can re-canonicalize at call time and reuse the\n97:  * same bounding logic the schema applies at parse time.\n98:  */\n99: export function isAllowedWorkspaceRoot(input: string): boolean {\n100:   if (!input || typeof input !== 'string') return false;\n101:   const canonical = canonicalize(input);\n102:   return ALLOWED_WORKSPACE_PREFIXES.some(\n103:     (prefix) => canonical === prefix || canonical.startsWith(`${prefix}/`),\n104:   );\n105: }\n106: \n107: const BoundedWorkspaceRootSchema = z\n108:   .string()\n109:   .min(1)\n110:   .refine(isAllowedWorkspaceRoot, {\n111:     message:\n112:       'workspaceRoot must resolve under the repo root, os.tmpdir(), or an explicit SPECKIT_ADVISOR_WORKSPACE_ALLOWLIST entry',\n113:   });\n114: \n115: const laneBreakdownSchema = z.object({\n116:   lane: AdvisorLaneSchema,\n117:   rawScore: z.number().min(0),\n118:   weightedScore: z.number().min(0),\n119:   weight: z.number().min(0),\n120:   shadowOnly: z.boolean(),\n121: }).strict();\n122: \n123: const whyRecommendedLaneSchema = laneBreakdownSchema.extend({\n124:   evidenceTypes: z.array(z.string().min(1)),\n125:   evidenceCount: z.number().int().nonnegative(),\n126: }).strict();\n127: \n128: const whyRecommendedSchema = z.object({\n129:   reason: z.string().min(1),\n130:   dominantLane: AdvisorLaneSchema.nullable(),\n131:   topLanes: z.array(whyRecommendedLaneSchema),\n132:   matchedSkillFeatures: z.array(z.object({\n133:     lane: AdvisorLaneSchema,\n134:     feature: z.string().min(1),\n135:   }).strict()),\n136: }).strict();\n137: \n138: const semanticLaneHealthSchema = z.object({\n139:   activeEmbedder: z.object({\n140:     name: z.string().min(1),\n141:     dim: z.number().int().nonnegative(),\n142:     adapterDim: z.number().int().positive().nullable(),\n143:   }).strict().nullable(),\n144:   vectorCoverage: z.object({\n145:     embedded: z.number().int().nonnegative(),\n146:     total: z.number().int().nonnegative(),\n147:     ratio: z.number().min(0).max(1),\n148:   }).strict(),\n149:   dimMismatch: z.boolean(),\n150:   lastRefresh: z.string().nullable(),\n151:   disabledReason: z.string().nullable(),\n152:   laneEnabled: z.boolean(),\n153:   checkedAt: z.string().datetime(),\n154: }).strict();\n155: \n156: // NOTE (DEFER decision):\n157: // `AdvisorScoringOptions.affordances` (see `lib/scorer/types.ts:94`) is a\n158: // COMPILE-TIME-ONLY internal seam used by the scorer fusion path. Affordance\n159: // evidence is sourced from compiled skill graph metadata via\n160: // `skill_graph_compiler.py` (which emits sanitized `derived.affordances[]`\n161: // nodes), not from public MCP input. Exposing `affordances` through this\n162: // request schema would re-introduce the prompt-stuffing surface that\n163: // `affordance-normalizer.ts` specifically defends against (URLs, emails,\n164: // instruction-shaped strings, free-form `description` fields). The public\n165: // `advisor_recommend` tool intentionally does NOT accept `affordances`.\n166: // Internal callers that need request-local affordance scoring should invoke\n167: // `scoreAdvisorPrompt` directly with `AdvisorScoringOptions.affordances`.\n168: export const AdvisorRecommendInputSchema = z.object({\n169:   // workspaceRoot must resolve under the allowed prefix set.\n170:   workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n171:   prompt: z.string().min(1).max(10_000),\n172:   options: z.object({\n173:     topK: z.number().int().min(1).max(10).optional(),\n174:     includeAttribution: z.boolean().optional(),\n175:     includeAbstainReasons: z.boolean().optional(),\n176:     confidenceThreshold: z.number().min(0).max(1).optional(),\n177:     uncertaintyThreshold: z.number().min(0).max(1).optional(),\n178:   }).strict().optional(),\n179: }).strict();\n180: \n181: export const AdvisorRecommendationSchema = z.object({\n182:   skillId: z.string().min(1),\n183:   score: z.number().min(0),\n184:   confidence: z.number().min(0).max(1),\n185:   uncertainty: z.number().min(0).max(1),\n186:   dominantLane: AdvisorLaneSchema.nullable(),\n187:   laneBreakdown: z.array(laneBreakdownSchema).optional(),\n188:   why_recommended: whyRecommendedSchema.optional(),\n189:   redirectFrom: z.array(z.string().min(1)).optional(),\n190:   redirectTo: z.string().min(1).optional(),\n191:   status: z.enum(['active', 'deprecated', 'archived', 'future']).optional(),\n192: }).strict();\n193: \n194: export const AdvisorRecommendOutputSchema = z.object({\n195:   workspaceRoot: z.string().min(1),\n196:   effectiveThresholds: z.object({\n197:     confidenceThreshold: z.number().min(0).max(1),\n198:     uncertaintyThreshold: z.number().min(0).max(1),\n199:     confidenceOnly: z.boolean(),\n200:   }).strict(),\n201:   recommendations: z.array(AdvisorRecommendationSchema),\n202:   ambiguous: z.boolean().optional(),\n203:   freshness: AdvisorFreshnessSchema,\n204:   trustState: z.object({\n205:     state: AdvisorFreshnessSchema,\n206:     reason: z.string().nullable(),\n207:     generation: z.number().int().nonnegative(),\n208:     checkedAt: z.string().datetime(),\n209:     lastLiveAt: z.string().datetime().nullable(),\n210:   }).strict(),\n211:   generatedAt: z.string().datetime(),\n212:   cache: z.object({\n213:     hit: z.boolean(),\n214:     sourceSignaturePresent: z.boolean(),\n215:   }).strict(),\n216:   warnings: z.array(z.string()).optional(),\n217:   abstainReasons: z.array(z.string()).optional(),\n218:   _shadow: z.object({\n219:     model: z.literal('advisor-shadow-learned-weights-v1'),\n220:     liveWeightsFrozen: z.boolean(),\n221:     recommendations: z.array(z.object({\n222:       skillId: z.string().min(1),\n223:       liveScore: z.number().min(0),\n224:       shadowScore: z.number().min(0),\n225:       delta: z.number(),\n226:       dominantShadowLane: AdvisorLaneSchema.nullable(),\n227:     }).strict()),\n228:   }).strict().optional(),\n229: }).strict();\n230: \n231: export const AdvisorStatusInputSchema = z.object({\n232:   // Bound workspaceRoot to allowed prefix set.\n233:   workspaceRoot: BoundedWorkspaceRootSchema,\n234:   maxMetadataFiles: z.number().int().positive().max(10_000).optional(),\n235:   includeSemanticHealth: z.boolean().optional(),\n236:   debug: z.boolean().optional(),\n237: }).strict();\n238: \n239: export const AdvisorStatusOutputSchema = z.object({\n240:   freshness: AdvisorFreshnessSchema,\n241:   generation: z.number().int().nonnegative(),\n242:   trustState: z.object({\n243:     state: AdvisorFreshnessSchema,\n244:     reason: z.string().nullable(),\n245:     generation: z.number().int().nonnegative(),\n246:     checkedAt: z.string().datetime(),\n247:     lastLiveAt: z.string().datetime().nullable(),\n248:   }).strict(),\n249:   lastGenerationBump: z.string().datetime().nullable(),\n250:   lastScanAt: z.string().datetime().nullable(),\n251:   skillCount: z.number().int().nonnegative(),\n252:   laneWeights: z.record(AdvisorLaneSchema, z.number().min(0)),\n253:   semanticLaneHealth: semanticLaneHealthSchema.optional(),\n254:   daemonPid: z.number().int().positive().optional(),\n255:   errors: z.array(z.string()).optional(),\n256: }).strict();\n257: \n258: export const AdvisorRebuildInputSchema = z.object({\n259:   force: z.boolean().optional(),\n260:   // Bound workspaceRoot to allowed prefix set.\n261:   workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n262: }).strict();\n263: \n264: export const AdvisorRebuildOutputSchema = z.object({\n265:   rebuilt: z.boolean(),\n266:   skipped: z.boolean(),\n267:   reason: z.enum(['status-live', 'stale', 'absent', 'unavailable', 'force']),\n268:   freshnessBefore: AdvisorFreshnessSchema,\n269:   freshnessAfter: AdvisorFreshnessSchema,\n270:   generationBefore: z.number().int().nonnegative(),\n271:   generationAfter: z.number().int().nonnegative(),\n272:   skillCount: z.number().int().nonnegative(),\n273:   summary: z.record(z.string(), z.unknown()).nullable(),\n274:   diagnostics: z.array(z.string()),\n275: }).strict();\n276: \n277: export const AdvisorValidateInputSchema = z.object({\n278:   confirmHeavyRun: z.literal(true),\n279:   // Bound workspaceRoot to allowed prefix set.\n280:   workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n281:   skillSlug: z.string().min(1).nullable().optional(),\n282:   outcomeEvents: z.array(z.object({\n283:     runtime: z.enum(['claude', 'copilot', 'codex']),\n284:     outcome: z.enum(['accepted', 'corrected', 'ignored']),\n285:     skillId: z.string().min(1),\n286:     correctedSkillId: z.string().min(1).optional(),\n287:     timestamp: z.string().datetime().optional(),\n288:   }).strict()).optional(),\n289: }).strict();\n290: \n291: const validationSliceSchema = z.object({\n292:   percentage: z.number().min(0).max(1),\n293:   passed: z.boolean(),\n294:   threshold: z.number().min(0).max(1).optional(),\n295:   count: z.object({\n296:     passed: z.number().int().nonnegative(),\n297:     total: z.number().int().nonnegative(),\n298:   }).strict(),\n299: }).strict();\n300: \n301: const advisorValidateAggregateValidationSchema = z.object({\n302:   fullCorpusTop1: z.number().min(0).max(1),\n303:   holdoutTop1: z.number().min(0).max(1),\n304:   perSkillTop1: z.number().min(0).max(1),\n305:   unknownCountTargetMax: z.number().int().nonnegative(),\n306: }).strict().describe('Release-gate thresholds for full corpus, holdout, per-skill accuracy, and UNKNOWN counts.');\n307: \n308: const advisorValidateRuntimeRoutingSchema = z.object({\n309:   confidenceThreshold: z.number().min(0).max(1),\n310:   uncertaintyThreshold: z.number().min(0).max(1),\n311:   confidenceOnly: z.boolean(),\n312: }).strict().describe('Live runtime routing thresholds surfaced by advisor_validate so manual checks can compare runtime semantics with release gates.');\n313: \n314: const advisorValidateTelemetryDiagnosticsSchema = z.object({\n315:   recordsPath: z.string().min(1),\n316:   recordsRetained: z.number().int().nonnegative(),\n317:   rollingCacheHitRate: z.number().min(0).max(1),\n318:   rollingP95Ms: z.number().min(0),\n319:   rollingFailOpenRate: z.number().min(0).max(1),\n320: }).strict().describe('Prompt-safe rolling diagnostics from retained advisor hook telemetry records.');\n321: \n322: const advisorValidateTelemetryScopeSchema = z.object({\n323:   kind: z.enum(['workspace', 'skill']),\n324:   skillSlug: z.string().min(1).nullable(),\n325: }).strict().describe('Whether recorded outcome totals are workspace-wide or scoped to the selected skillSlug.');\n326: \n327: const advisorValidateOutcomeTotalsSchema = z.object({\n328:   accepted: z.number().int().nonnegative(),\n329:   corrected: z.number().int().nonnegative(),\n330:   ignored: z.number().int().nonnegative(),\n331: }).strict().describe('Recorded outcome totals retained for the active workspace or skill scope.');\n332: \n333: const advisorValidateTelemetryOutcomesSchema = z.object({\n334:   recordsPath: z.string().min(1),\n335:   recordedThisRun: z.number().int().nonnegative(),\n336:   scope: advisorValidateTelemetryScopeSchema,\n337:   totals: advisorValidateOutcomeTotalsSchema,\n338: }).strict().describe('Outcome recording summary, including injected event count and retained accepted/corrected/ignored totals.');\n339: \n340: export const AdvisorValidateOutputSchema = z.object({\n341:   workspaceRoot: z.string().min(1),\n342:   skillSlug: z.string().nullable(),\n343:   thresholdSemantics: z.object({\n344:     aggregateValidation: advisorValidateAggregateValidationSchema,\n345:     runtimeRouting: advisorValidateRuntimeRoutingSchema,\n346:   }).strict().describe('Public threshold contract for advisor_validate, covering release-gate scoring and runtime-routing semantics.'),\n347:   overallAccuracy: z.number().min(0).max(1),\n348:   perSkill: z.array(z.object({\n349:     skillId: z.string().min(1),\n350:     status: z.enum(['pass', 'fail', 'skipped']),\n351:     matched: z.number().int().nonnegative(),\n352:     total: z.number().int().nonnegative(),\n353:   }).strict()),\n354:   slices: z.object({\n355:     corpus: z.object({\n356:       full_corpus_top1: validationSliceSchema,\n357:       unknown_count: z.object({\n358:         value: z.number().int().nonnegative(),\n359:         targetMax: z.number().int().nonnegative(),\n360:         passed: z.boolean(),\n361:       }).strict(),\n362:       gold_none_false_fire_count: z.object({\n363:         value: z.number().int().nonnegative(),\n364:         baselineDelta: z.number().int(),\n365:       }).strict(),\n366:     }).strict(),\n367:     holdout: z.object({\n368:       holdout_top1: validationSliceSchema,\n369:     }).strict(),\n370:     parity: z.object({\n371:       explicit_skill_top1_regression: z.object({\n372:         passed: z.boolean(),\n373:         regressions: z.array(z.string()),\n374:       }).strict(),\n375:       ambiguity_slice_stable: z.object({\n376:         passed: z.boolean(),\n377:         top2Within005: z.boolean(),\n378:       }).strict(),\n379:       derived_lane_attribution_complete: z.boolean(),\n380:     }).strict(),\n381:     safety: z.object({\n382:       adversarial_stuffing_blocked: z.object({\n383:         passed: z.boolean(),\n384:         fixtureCount: z.number().int().nonnegative(),\n385:       }).strict(),\n386:     }).strict(),\n387:     latency: z.object({\n388:       regression_suite_status: z.object({\n389:         p0PassRate: z.number().min(0).max(1),\n390:         failedCount: z.number().int().nonnegative(),\n391:         commandBridgeFalsePositiveRate: z.number().min(0).max(1),\n392:         cacheHitP95Ms: z.number().min(0),\n393:         uncachedP95Ms: z.number().min(0),\n394:       }).strict(),\n395:     }).strict(),\n396:   }).strict(),\n397:   telemetry: z.object({\n398:     diagnostics: advisorValidateTelemetryDiagnosticsSchema,\n399:     outcomes: advisorValidateTelemetryOutcomesSchema,\n400:   }).strict().describe('Prompt-safe telemetry diagnostics and recorded outcome summaries exposed for operator validation.'),\n401:   generatedAt: z.string().datetime(),\n402: }).strict();\n403: \n404: export type AdvisorFreshness = z.infer<typeof AdvisorFreshnessSchema>;\n405: export type AdvisorRecommendInput = z.infer<typeof AdvisorRecommendInputSchema>;\n406: export type AdvisorRecommendOutput = z.infer<typeof AdvisorRecommendOutputSchema>;\n407: export type AdvisorRebuildInput = z.infer<typeof AdvisorRebuildInputSchema>;\n408: export type AdvisorRebuildOutput = z.infer<typeof AdvisorRebuildOutputSchema>;\n409: export type AdvisorStatusInput = z.infer<typeof AdvisorStatusInputSchema>;\n410: export type AdvisorStatusOutput = z.infer<typeof AdvisorStatusOutputSchema>;\n411: export type AdvisorValidateInput = z.infer<typeof AdvisorValidateInputSchema>;\n412: export type AdvisorValidateOutput = z.infer<typeof AdvisorValidateOutputSchema>;\n413: \n414: export const AdvisorToolInputSchemas = {\n415:   advisor_recommend: AdvisorRecommendInputSchema,\n416:   advisor_rebuild: AdvisorRebuildInputSchema,\n417:   advisor_status: AdvisorStatusInputSchema,\n418:   advisor_validate: AdvisorValidateInputSchema,\n419: } as const;\n\n(End of file - total 419 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor MCP Tool Schemas\n// ───────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\nimport { existsSync, realpathSync } from 'node:fs';\nimport { resolve } from 'node:path';\nimport { tmpdir } from 'node:os';\nimport { SCORER_LANE_IDS } from '../lib/scorer/lane-registry.js';\n\nexport const AdvisorFreshnessSchema = z.enum(['live', 'stale', 'absent', 'unavailable']);\nexport const AdvisorLaneSchema = z.enum(SCORER_LANE_IDS);\n\n// Bound caller-supplied workspaceRoot inputs to a small\n// allowlist (repo root + os.tmpdir()) so handlers cannot be coerced into\n// resolving paths outside the workspace. resolve() canonicalizes the input\n// path; realpathSync follows symlinks; the prefix check rejects anything\n// that escapes the allowlist after canonicalization.\n//\n// Repo root is detected by walking up from process.cwd() looking for the","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor MCP Tool Schemas\n// ───────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\nimport { existsSync, realpathSync } from 'node:fs';\nimport { resolve } from 'node:path';\nimport { tmpdir } from 'node:os';\nimport { SCORER_LANE_IDS } from '../lib/scorer/lane-registry.js';\n\nexport const AdvisorFreshnessSchema = z.enum(['live', 'stale', 'absent', 'unavailable']);\nexport const AdvisorLaneSchema = z.enum(SCORER_LANE_IDS);\n\n// Bound caller-supplied workspaceRoot inputs to a small\n// allowlist (repo root + os.tmpdir()) so handlers cannot be coerced into\n// resolving paths outside the workspace. resolve() canonicalizes the input\n// path; realpathSync follows symlinks; the prefix check rejects anything\n// that escapes the allowlist after canonicalization.\n//\n// Repo root is detected by walking up from process.cwd() looking for the\n// .opencode/skill sentinel — same shape as findAdvisorWorkspaceRoot but\n// inlined here to avoid a circular import between schemas/ and lib/.\nfunction detectRepoRoot(): string {\n  // Use the same SKILL.md sentinel that\n  // findAdvisorWorkspaceRoot uses in advisor-validate.ts so the schema\n  // and the handler agree on which directory is the workspace root.\n  // A bare `.opencode/skill` sentinel can match nested mock directories\n  // created by other workflows (e.g. mcp_server/.opencode/skill).\n  const sentinel = '.opencode/skills/system-spec-kit/SKILL.md';\n  let current = resolve(process.cwd());\n  for (let index = 0; index < 14; index += 1) {\n    if (existsSync(resolve(current, sentinel))) return current;\n    const parent = resolve(current, '..');\n    if (parent === current) break;\n    current = parent;\n  }\n  return resolve(process.cwd());\n}\n\nfunction canonicalize(input: string): string {\n  const resolved = resolve(input);\n  try {\n    return realpathSync.native(resolved);\n  } catch {\n    // Path may not exist yet (test fixtures created lazily,\n    // tmpdir mkdtemp paths probed before mkdir). Walk up and realpath the\n    // first existing ancestor, then re-join the unresolved tail. This\n    // resolves macOS-style symlinks like /tmp → /private/tmp even when\n    // the leaf doesn't exist.\n    let probe = resolved;\n    let tail = '';\n    for (let depth = 0; depth < 32; depth += 1) {\n      const parent = resolve(probe, '..');\n      if (parent === probe) break;\n      try {\n        const realParent = realpathSync.native(parent);\n        return tail\n          ? resolve(realParent, probe.slice(parent.length + 1) + tail)\n          : resolve(realParent, probe.slice(parent.length + 1));\n      } catch {\n        // Parent doesn't exist either — keep walking up.\n        const segment = probe.slice(parent.length + 1);\n        tail = tail ? `${segment}/${tail}` : segment;\n        probe = parent;\n      }\n    }\n    return resolved;\n  }\n}\n\nconst ALLOWED_WORKSPACE_PREFIXES: readonly string[] = (() => {\n  const prefixes: string[] = [];\n  prefixes.push(canonicalize(detectRepoRoot()));\n  prefixes.push(canonicalize(tmpdir()));\n  // Include the canonicalized /tmp prefix as well. On macOS\n  // os.tmpdir() returns the per-user temp dir under /var/folders/...; the\n  // /tmp symlink resolves to /private/tmp. Test fixtures and tools that\n  // hardcode /tmp/foo paths need both forms in the allowlist.\n  prefixes.push(canonicalize('/tmp'));\n  // Accept additional explicit allowlist via env (CI / test runners).\n  const envExtras = process.env.SPECKIT_ADVISOR_WORKSPACE_ALLOWLIST;\n  if (envExtras) {\n    for (const extra of envExtras.split(':')) {\n      const trimmed = extra.trim();\n      if (trimmed) prefixes.push(canonicalize(trimmed));\n    }\n  }\n  return Array.from(new Set(prefixes));\n})();\n\n/**\n * Validate that a caller-supplied workspaceRoot resolves under\n * the repo root, os.tmpdir(), or an explicit allowlist entry after\n * realpath canonicalization.\n *\n * Exported so handlers can re-canonicalize at call time and reuse the\n * same bounding logic the schema applies at parse time.\n */\nexport function isAllowedWorkspaceRoot(input: string): boolean {\n  if (!input || typeof input !== 'string') return false;\n  const canonical = canonicalize(input);\n  return ALLOWED_WORKSPACE_PREFIXES.some(\n    (prefix) => canonical === prefix || canonical.startsWith(`${prefix}/`),\n  );\n}\n\nconst BoundedWorkspaceRootSchema = z\n  .string()\n  .min(1)\n  .refine(isAllowedWorkspaceRoot, {\n    message:\n      'workspaceRoot must resolve under the repo root, os.tmpdir(), or an explicit SPECKIT_ADVISOR_WORKSPACE_ALLOWLIST entry',\n  });\n\nconst laneBreakdownSchema = z.object({\n  lane: AdvisorLaneSchema,\n  rawScore: z.number().min(0),\n  weightedScore: z.number().min(0),\n  weight: z.number().min(0),\n  shadowOnly: z.boolean(),\n}).strict();\n\nconst whyRecommendedLaneSchema = laneBreakdownSchema.extend({\n  evidenceTypes: z.array(z.string().min(1)),\n  evidenceCount: z.number().int().nonnegative(),\n}).strict();\n\nconst whyRecommendedSchema = z.object({\n  reason: z.string().min(1),\n  dominantLane: AdvisorLaneSchema.nullable(),\n  topLanes: z.array(whyRecommendedLaneSchema),\n  matchedSkillFeatures: z.array(z.object({\n    lane: AdvisorLaneSchema,\n    feature: z.string().min(1),\n  }).strict()),\n}).strict();\n\nconst semanticLaneHealthSchema = z.object({\n  activeEmbedder: z.object({\n    name: z.string().min(1),\n    dim: z.number().int().nonnegative(),\n    adapterDim: z.number().int().positive().nullable(),\n  }).strict().nullable(),\n  vectorCoverage: z.object({\n    embedded: z.number().int().nonnegative(),\n    total: z.number().int().nonnegative(),\n    ratio: z.number().min(0).max(1),\n  }).strict(),\n  dimMismatch: z.boolean(),\n  lastRefresh: z.string().nullable(),\n  disabledReason: z.string().nullable(),\n  laneEnabled: z.boolean(),\n  checkedAt: z.string().datetime(),\n}).strict();\n\n// NOTE (DEFER decision):\n// `AdvisorScoringOptions.affordances` (see `lib/scorer/types.ts:94`) is a\n// COMPILE-TIME-ONLY internal seam used by the scorer fusion path. Affordance\n// evidence is sourced from compiled skill graph metadata via\n// `skill_graph_compiler.py` (which emits sanitized `derived.affordances[]`\n// nodes), not from public MCP input. Exposing `affordances` through this\n// request schema would re-introduce the prompt-stuffing surface that\n// `affordance-normalizer.ts` specifically defends against (URLs, emails,\n// instruction-shaped strings, free-form `description` fields). The public\n// `advisor_recommend` tool intentionally does NOT accept `affordances`.\n// Internal callers that need request-local affordance scoring should invoke\n// `scoreAdvisorPrompt` directly with `AdvisorScoringOptions.affordances`.\nexport const AdvisorRecommendInputSchema = z.object({\n  // workspaceRoot must resolve under the allowed prefix set.\n  workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n  prompt: z.string().min(1).max(10_000),\n  options: z.object({\n    topK: z.number().int().min(1).max(10).optional(),\n    includeAttribution: z.boolean().optional(),\n    includeAbstainReasons: z.boolean().optional(),\n    confidenceThreshold: z.number().min(0).max(1).optional(),\n    uncertaintyThreshold: z.number().min(0).max(1).optional(),\n  }).strict().optional(),\n}).strict();\n\nexport const AdvisorRecommendationSchema = z.object({\n  skillId: z.string().min(1),\n  score: z.number().min(0),\n  confidence: z.number().min(0).max(1),\n  uncertainty: z.number().min(0).max(1),\n  dominantLane: AdvisorLaneSchema.nullable(),\n  laneBreakdown: z.array(laneBreakdownSchema).optional(),\n  why_recommended: whyRecommendedSchema.optional(),\n  redirectFrom: z.array(z.string().min(1)).optional(),\n  redirectTo: z.string().min(1).optional(),\n  status: z.enum(['active', 'deprecated', 'archived', 'future']).optional(),\n}).strict();\n\nexport const AdvisorRecommendOutputSchema = z.object({\n  workspaceRoot: z.string().min(1),\n  effectiveThresholds: z.object({\n    confidenceThreshold: z.number().min(0).max(1),\n    uncertaintyThreshold: z.number().min(0).max(1),\n    confidenceOnly: z.boolean(),\n  }).strict(),\n  recommendations: z.array(AdvisorRecommendationSchema),\n  ambiguous: z.boolean().optional(),\n  freshness: AdvisorFreshnessSchema,\n  trustState: z.object({\n    state: AdvisorFreshnessSchema,\n    reason: z.string().nullable(),\n    generation: z.number().int().nonnegative(),\n    checkedAt: z.string().datetime(),\n    lastLiveAt: z.string().datetime().nullable(),\n  }).strict(),\n  generatedAt: z.string().datetime(),\n  cache: z.object({\n    hit: z.boolean(),\n    sourceSignaturePresent: z.boolean(),\n  }).strict(),\n  warnings: z.array(z.string()).optional(),\n  abstainReasons: z.array(z.string()).optional(),\n  _shadow: z.object({\n    model: z.literal('advisor-shadow-learned-weights-v1'),\n    liveWeightsFrozen: z.boolean(),\n    recommendations: z.array(z.object({\n      skillId: z.string().min(1),\n      liveScore: z.number().min(0),\n      shadowScore: z.number().min(0),\n      delta: z.number(),\n      dominantShadowLane: AdvisorLaneSchema.nullable(),\n    }).strict()),\n  }).strict().optional(),\n}).strict();\n\nexport const AdvisorStatusInputSchema = z.object({\n  // Bound workspaceRoot to allowed prefix set.\n  workspaceRoot: BoundedWorkspaceRootSchema,\n  maxMetadataFiles: z.number().int().positive().max(10_000).optional(),\n  includeSemanticHealth: z.boolean().optional(),\n  debug: z.boolean().optional(),\n}).strict();\n\nexport const AdvisorStatusOutputSchema = z.object({\n  freshness: AdvisorFreshnessSchema,\n  generation: z.number().int().nonnegative(),\n  trustState: z.object({\n    state: AdvisorFreshnessSchema,\n    reason: z.string().nullable(),\n    generation: z.number().int().nonnegative(),\n    checkedAt: z.string().datetime(),\n    lastLiveAt: z.string().datetime().nullable(),\n  }).strict(),\n  lastGenerationBump: z.string().datetime().nullable(),\n  lastScanAt: z.string().datetime().nullable(),\n  skillCount: z.number().int().nonnegative(),\n  laneWeights: z.record(AdvisorLaneSchema, z.number().min(0)),\n  semanticLaneHealth: semanticLaneHealthSchema.optional(),\n  daemonPid: z.number().int().positive().optional(),\n  errors: z.array(z.string()).optional(),\n}).strict();\n\nexport const AdvisorRebuildInputSchema = z.object({\n  force: z.boolean().optional(),\n  // Bound workspaceRoot to allowed prefix set.\n  workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n}).strict();\n\nexport const AdvisorRebuildOutputSchema = z.object({\n  rebuilt: z.boolean(),\n  skipped: z.boolean(),\n  reason: z.enum(['status-live', 'stale', 'absent', 'unavailable', 'force']),\n  freshnessBefore: AdvisorFreshnessSchema,\n  freshnessAfter: AdvisorFreshnessSchema,\n  generationBefore: z.number().int().nonnegative(),\n  generationAfter: z.number().int().nonnegative(),\n  skillCount: z.number().int().nonnegative(),\n  summary: z.record(z.string(), z.unknown()).nullable(),\n  diagnostics: z.array(z.string()),\n}).strict();\n\nexport const AdvisorValidateInputSchema = z.object({\n  confirmHeavyRun: z.literal(true),\n  // Bound workspaceRoot to allowed prefix set.\n  workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n  skillSlug: z.string().min(1).nullable().optional(),\n  outcomeEvents: z.array(z.object({\n    runtime: z.enum(['claude', 'copilot', 'codex']),\n    outcome: z.enum(['accepted', 'corrected', 'ignored']),\n    skillId: z.string().min(1),\n    correctedSkillId: z.string().min(1).optional(),\n    timestamp: z.string().datetime().optional(),\n  }).strict()).optional(),\n}).strict();\n\nconst validationSliceSchema = z.object({\n  percentage: z.number().min(0).max(1),\n  passed: z.boolean(),\n  threshold: z.number().min(0).max(1).optional(),\n  count: z.object({\n    passed: z.number().int().nonnegative(),\n    total: z.number().int().nonnegative(),\n  }).strict(),\n}).strict();\n\nconst advisorValidateAggregateValidationSchema = z.object({\n  fullCorpusTop1: z.number().min(0).max(1),\n  holdoutTop1: z.number().min(0).max(1),\n  perSkillTop1: z.number().min(0).max(1),\n  unknownCountTargetMax: z.number().int().nonnegative(),\n}).strict().describe('Release-gate thresholds for full corpus, holdout, per-skill accuracy, and UNKNOWN counts.');\n\nconst advisorValidateRuntimeRoutingSchema = z.object({\n  confidenceThreshold: z.number().min(0).max(1),\n  uncertaintyThreshold: z.number().min(0).max(1),\n  confidenceOnly: z.boolean(),\n}).strict().describe('Live runtime routing thresholds surfaced by advisor_validate so manual checks can compare runtime semantics with release gates.');\n\nconst advisorValidateTelemetryDiagnosticsSchema = z.object({\n  recordsPath: z.string().min(1),\n  recordsRetained: z.number().int().nonnegative(),\n  rollingCacheHitRate: z.number().min(0).max(1),\n  rollingP95Ms: z.number().min(0),\n  rollingFailOpenRate: z.number().min(0).max(1),\n}).strict().describe('Prompt-safe rolling diagnostics from retained advisor hook telemetry records.');\n\nconst advisorValidateTelemetryScopeSchema = z.object({\n  kind: z.enum(['workspace', 'skill']),\n  skillSlug: z.string().min(1).nullable(),\n}).strict().describe('Whether recorded outcome totals are workspace-wide or scoped to the selected skillSlug.');\n\nconst advisorValidateOutcomeTotalsSchema = z.object({\n  accepted: z.number().int().nonnegative(),\n  corrected: z.number().int().nonnegative(),\n  ignored: z.number().int().nonnegative(),\n}).strict().describe('Recorded outcome totals retained for the active workspace or skill scope.');\n\nconst advisorValidateTelemetryOutcomesSchema = z.object({\n  recordsPath: z.string().min(1),\n  recordedThisRun: z.number().int().nonnegative(),\n  scope: advisorValidateTelemetryScopeSchema,\n  totals: advisorValidateOutcomeTotalsSchema,\n}).strict().describe('Outcome recording summary, including injected event count and retained accepted/corrected/ignored totals.');\n\nexport const AdvisorValidateOutputSchema = z.object({\n  workspaceRoot: z.string().min(1),\n  skillSlug: z.string().nullable(),\n  thresholdSemantics: z.object({\n    aggregateValidation: advisorValidateAggregateValidationSchema,\n    runtimeRouting: advisorValidateRuntimeRoutingSchema,\n  }).strict().describe('Public threshold contract for advisor_validate, covering release-gate scoring and runtime-routing semantics.'),\n  overallAccuracy: z.number().min(0).max(1),\n  perSkill: z.array(z.object({\n    skillId: z.string().min(1),\n    status: z.enum(['pass', 'fail', 'skipped']),\n    matched: z.number().int().nonnegative(),\n    total: z.number().int().nonnegative(),\n  }).strict()),\n  slices: z.object({\n    corpus: z.object({\n      full_corpus_top1: validationSliceSchema,\n      unknown_count: z.object({\n        value: z.number().int().nonnegative(),\n        targetMax: z.number().int().nonnegative(),\n        passed: z.boolean(),\n      }).strict(),\n      gold_none_false_fire_count: z.object({\n        value: z.number().int().nonnegative(),\n        baselineDelta: z.number().int(),\n      }).strict(),\n    }).strict(),\n    holdout: z.object({\n      holdout_top1: validationSliceSchema,\n    }).strict(),\n    parity: z.object({\n      explicit_skill_top1_regression: z.object({\n        passed: z.boolean(),\n        regressions: z.array(z.string()),\n      }).strict(),\n      ambiguity_slice_stable: z.object({\n        passed: z.boolean(),\n        top2Within005: z.boolean(),\n      }).strict(),\n      derived_lane_attribution_complete: z.boolean(),\n    }).strict(),\n    safety: z.object({\n      adversarial_stuffing_blocked: z.object({\n        passed: z.boolean(),\n        fixtureCount: z.number().int().nonnegative(),\n      }).strict(),\n    }).strict(),\n    latency: z.object({\n      regression_suite_status: z.object({\n        p0PassRate: z.number().min(0).max(1),\n        failedCount: z.number().int().nonnegative(),\n        commandBridgeFalsePositiveRate: z.number().min(0).max(1),\n        cacheHitP95Ms: z.number().min(0),\n        uncachedP95Ms: z.number().min(0),\n      }).strict(),\n    }).strict(),\n  }).strict(),\n  telemetry: z.object({\n    diagnostics: advisorValidateTelemetryDiagnosticsSchema,\n    outcomes: advisorValidateTelemetryOutcomesSchema,\n  }).strict().describe('Prompt-safe telemetry diagnostics and recorded outcome summaries exposed for operator validation.'),\n  generatedAt: z.string().datetime(),\n}).strict();\n\nexport type AdvisorFreshness = z.infer<typeof AdvisorFreshnessSchema>;\nexport type AdvisorRecommendInput = z.infer<typeof AdvisorRecommendInputSchema>;\nexport type AdvisorRecommendOutput = z.infer<typeof AdvisorRecommendOutputSchema>;\nexport type AdvisorRebuildInput = z.infer<typeof AdvisorRebuildInputSchema>;\nexport type AdvisorRebuildOutput = z.infer<typeof AdvisorRebuildOutputSchema>;\nexport type AdvisorStatusInput = z.infer<typeof AdvisorStatusInputSchema>;\nexport type AdvisorStatusOutput = z.infer<typeof AdvisorStatusOutputSchema>;\nexport type AdvisorValidateInput = z.infer<typeof AdvisorValidateInputSchema>;\nexport type AdvisorValidateOutput = z.infer<typeof AdvisorValidateOutputSchema>;\n\nexport const AdvisorToolInputSchemas = {\n  advisor_recommend: AdvisorRecommendInputSchema,\n  advisor_rebuild: AdvisorRebuildInputSchema,\n  advisor_status: AdvisorStatusInputSchema,\n  advisor_validate: AdvisorValidateInputSchema,\n} as const;","lineStart":1,"lineEnd":419,"totalLines":419,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts","time":{"start":1781129304626,"end":1781129304630}},"metadata":{"openai":{"itemId":"fc_03a7269519c32c84016a29e05882388191b54e1796be420f4a"}},"id":"prt_eb3945a130017UXDAb1uVAioaY","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3942f76001MikAc8rxVzXCKv"}}
{"type":"tool_use","timestamp":1781129304646,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_JzhOqpNYckGxcWeL6H4rFDzX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Packed BM25F Lexical Shadow Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorProjection, SkillProjection } from '../types.js';\n6: import { tokenize } from '../text.js';\n7: \n8: export const ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID = 'bm25_lexical_shadow' as const;\n9: \n10: const BM25_K1 = 1.2;\n11: const BM25_B = 0.75;\n12: const DEFAULT_LIMIT = 20;\n13: \n14: const BM25F_FIELD_NAMES = [\n15:   'name',\n16:   'keywords',\n17:   'domains',\n18:   'intentSignals',\n19:   'derivedTriggers',\n20:   'description',\n21: ] as const;\n22: \n23: export type AdvisorBm25FieldName = typeof BM25F_FIELD_NAMES[number];\n24: export type AdvisorBm25FieldWeights = Record<AdvisorBm25FieldName, number>;\n25: \n26: export const ADVISOR_BM25_FIELD_WEIGHTS: AdvisorBm25FieldWeights = {\n27:   name: 4.0,\n28:   keywords: 3.0,\n29:   domains: 2.2,\n30:   intentSignals: 2.4,\n31:   derivedTriggers: 1.8,\n32:   description: 1.0,\n33: };\n34: \n35: export interface AdvisorBm25SearchOptions {\n36:   readonly fieldWeights?: Partial<AdvisorBm25FieldWeights>;\n37:   readonly limit?: number;\n38: }\n39: \n40: export interface AdvisorBm25Match {\n41:   readonly skillId: string;\n42:   readonly lane: typeof ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID;\n43:   readonly score: number;\n44:   readonly rawScore: number;\n45:   readonly evidence: readonly string[];\n46:   readonly shadowOnly: true;\n47: }\n48: \n49: export interface AdvisorBm25FootprintStats {\n50:   readonly documentCount: number;\n51:   readonly termCount: number;\n52:   readonly postingCount: number;\n53:   readonly typedArrayBytes: number;\n54:   readonly mutablePostingCount: number;\n55: }\n56: \n57: interface FieldTermFrequency {\n58:   total: number;\n59:   fields: Record<AdvisorBm25FieldName, number>;\n60: }\n61: \n62: interface PackedSkillDocument {\n63:   numericId: number;\n64:   skillId: string;\n65:   length: number;\n66:   terms: readonly string[];\n67: }\n68: \n69: interface PackedPostingMutable {\n70:   docIds: number[];\n71:   totalTfs: number[];\n72:   nameTfs: number[];\n73:   keywordTfs: number[];\n74:   domainTfs: number[];\n75:   intentSignalTfs: number[];\n76:   derivedTriggerTfs: number[];\n77:   descriptionTfs: number[];\n78: }\n79: \n80: interface PackedPostingList {\n81:   docIds: Uint32Array;\n82:   totalTfs: Uint32Array;\n83:   nameTfs: Uint32Array;\n84:   keywordTfs: Uint32Array;\n85:   domainTfs: Uint32Array;\n86:   intentSignalTfs: Uint32Array;\n87:   derivedTriggerTfs: Uint32Array;\n88:   descriptionTfs: Uint32Array;\n89: }\n90: \n91: function emptyFieldFrequency(): FieldTermFrequency {\n92:   return {\n93:     total: 0,\n94:     fields: {\n95:       name: 0,\n96:       keywords: 0,\n97:       domains: 0,\n98:       intentSignals: 0,\n99:       derivedTriggers: 0,\n100:       description: 0,\n101:     },\n102:   };\n103: }\n104: \n105: function resolveFieldWeights(overrides: Partial<AdvisorBm25FieldWeights> = {}): AdvisorBm25FieldWeights {\n106:   return {\n107:     name: overrides.name ?? ADVISOR_BM25_FIELD_WEIGHTS.name,\n108:     keywords: overrides.keywords ?? ADVISOR_BM25_FIELD_WEIGHTS.keywords,\n109:     domains: overrides.domains ?? ADVISOR_BM25_FIELD_WEIGHTS.domains,\n110:     intentSignals: overrides.intentSignals ?? ADVISOR_BM25_FIELD_WEIGHTS.intentSignals,\n111:     derivedTriggers: overrides.derivedTriggers ?? ADVISOR_BM25_FIELD_WEIGHTS.derivedTriggers,\n112:     description: overrides.description ?? ADVISOR_BM25_FIELD_WEIGHTS.description,\n113:   };\n114: }\n115: \n116: function skillFields(skill: SkillProjection): Record<AdvisorBm25FieldName, readonly string[]> {\n117:   return {\n118:     name: [skill.id.replace(/-/g, ' '), skill.name],\n119:     keywords: skill.keywords,\n120:     domains: skill.domains,\n121:     intentSignals: skill.intentSignals,\n122:     derivedTriggers: skill.derivedTriggers,\n123:     description: [skill.description],\n124:   };\n125: }\n126: \n127: function fieldTermFrequencies(skill: SkillProjection): Map<string, FieldTermFrequency> {\n128:   const frequencies = new Map<string, FieldTermFrequency>();\n129:   for (const fieldName of BM25F_FIELD_NAMES) {\n130:     for (const value of skillFields(skill)[fieldName]) {\n131:       for (const token of tokenize(value)) {\n132:         let frequency = frequencies.get(token);\n133:         if (!frequency) {\n134:           frequency = emptyFieldFrequency();\n135:           frequencies.set(token, frequency);\n136:         }\n137:         frequency.total += 1;\n138:         frequency.fields[fieldName] += 1;\n139:       }\n140:     }\n141:   }\n142:   return frequencies;\n143: }\n144: \n145: function weightedFrequency(\n146:   postings: PackedPostingList,\n147:   index: number,\n148:   weights: AdvisorBm25FieldWeights,\n149: ): number {\n150:   return postings.nameTfs[index] * weights.name\n151:     + postings.keywordTfs[index] * weights.keywords\n152:     + postings.domainTfs[index] * weights.domains\n153:     + postings.intentSignalTfs[index] * weights.intentSignals\n154:     + postings.derivedTriggerTfs[index] * weights.derivedTriggers\n155:     + postings.descriptionTfs[index] * weights.description;\n156: }\n157: \n158: function topWeightedFields(\n159:   postings: PackedPostingList,\n160:   index: number,\n161:   weights: AdvisorBm25FieldWeights,\n162: ): AdvisorBm25FieldName[] {\n163:   return [\n164:     { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n165:     { field: 'keywords' as const, value: postings.keywordTfs[index] * weights.keywords },\n166:     { field: 'domains' as const, value: postings.domainTfs[index] * weights.domains },\n167:     { field: 'intentSignals' as const, value: postings.intentSignalTfs[index] * weights.intentSignals },\n168:     { field: 'derivedTriggers' as const, value: postings.derivedTriggerTfs[index] * weights.derivedTriggers },\n169:     { field: 'description' as const, value: postings.descriptionTfs[index] * weights.description },\n170:   ]\n171:     .filter((entry) => entry.value > 0)\n172:     .sort((left, right) => right.value - left.value)\n173:     .map((entry) => entry.field)\n174:     .slice(0, 3);\n175: }\n176: \n177: export class AdvisorPackedBm25Index {\n178:   private readonly skillIds: string[] = [];\n179:   private readonly skillNumbersById = new Map<string, number>();\n180:   private readonly documents = new Map<string, PackedSkillDocument>();\n181:   private readonly documentFreq = new Map<string, number>();\n182:   private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n183:   private readonly packedPostings = new Map<string, PackedPostingList>();\n184:   private totalDocumentLength = 0;\n185: \n186:   constructor(skills: readonly SkillProjection[] = []) {\n187:     for (const skill of skills) {\n188:       this.addSkill(skill);\n189:     }\n190:     this.finalize();\n191:   }\n192: \n193:   addSkill(skill: SkillProjection): void {\n194:     const frequencies = fieldTermFrequencies(skill);\n195:     const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n196:     if (length === 0) return;\n197: \n198:     const numericId = this.nextNumericId(skill.id);\n199:     const terms = [...frequencies.keys()].sort();\n200:     this.documents.set(skill.id, { numericId, skillId: skill.id, length, terms });\n201:     this.totalDocumentLength += length;\n202: \n203:     for (const term of terms) {\n204:       const frequency = frequencies.get(term);\n205:       if (!frequency) continue;\n206:       this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n207:       const postings = this.ensureMutablePostings(term);\n208:       postings.docIds.push(numericId);\n209:       postings.totalTfs.push(frequency.total);\n210:       postings.nameTfs.push(frequency.fields.name);\n211:       postings.keywordTfs.push(frequency.fields.keywords);\n212:       postings.domainTfs.push(frequency.fields.domains);\n213:       postings.intentSignalTfs.push(frequency.fields.intentSignals);\n214:       postings.derivedTriggerTfs.push(frequency.fields.derivedTriggers);\n215:       postings.descriptionTfs.push(frequency.fields.description);\n216:     }\n217:   }\n218: \n219:   finalize(): void {\n220:     for (const [term, postings] of this.mutablePostings.entries()) {\n221:       const order = postings.docIds.map((docId, index) => ({ docId, index }))\n222:         .sort((left, right) => left.docId - right.docId);\n223:       this.packedPostings.set(term, {\n224:         docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n225:         totalTfs: Uint32Array.from(order.map((entry) => postings.totalTfs[entry.index])),\n226:         nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n227:         keywordTfs: Uint32Array.from(order.map((entry) => postings.keywordTfs[entry.index])),\n228:         domainTfs: Uint32Array.from(order.map((entry) => postings.domainTfs[entry.index])),\n229:         intentSignalTfs: Uint32Array.from(order.map((entry) => postings.intentSignalTfs[entry.index])),\n230:         derivedTriggerTfs: Uint32Array.from(order.map((entry) => postings.derivedTriggerTfs[entry.index])),\n231:         descriptionTfs: Uint32Array.from(order.map((entry) => postings.descriptionTfs[entry.index])),\n232:       });\n233:     }\n234:     this.mutablePostings.clear();\n235:   }\n236: \n237:   search(prompt: string, options: AdvisorBm25SearchOptions = {}): AdvisorBm25Match[] {\n238:     const queryTerms = [...new Set(tokenize(prompt))];\n239:     if (queryTerms.length === 0 || this.documents.size === 0) return [];\n240: \n241:     const weights = resolveFieldWeights(options.fieldWeights);\n242:     const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n243:     const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n244: \n245:     for (const term of queryTerms) {\n246:       const postings = this.packedPostings.get(term);\n247:       if (!postings) continue;\n248:       const idf = this.idf(term);\n249:       for (let i = 0; i < postings.docIds.length; i += 1) {\n250:         const numericId = postings.docIds[i];\n251:         const skillId = this.skillIds[numericId];\n252:         const doc = skillId ? this.documents.get(skillId) : undefined;\n253:         if (!doc) continue;\n254:         const weightedTf = weightedFrequency(postings, i, weights);\n255:         if (weightedTf <= 0) continue;\n256: \n257:         const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n258:           / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (doc.length / averageLength))));\n259:         const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n260:         existing.rawScore += termScore;\n261:         if (existing.evidence.length < 6) {\n262:           existing.evidence.push(`bm25:${term}`);\n263:           for (const field of topWeightedFields(postings, i, weights)) {\n264:             if (existing.evidence.length >= 6) break;\n265:             existing.evidence.push(`field:${field}`);\n266:           }\n267:         }\n268:         scores.set(numericId, existing);\n269:       }\n270:     }\n271: \n272:     return [...scores.entries()]\n273:       .map(([numericId, result]) => ({\n274:         skillId: this.skillIds[numericId],\n275:         lane: ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID,\n276:         rawScore: Number(result.rawScore.toFixed(6)),\n277:         score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n278:         evidence: result.evidence,\n279:         shadowOnly: true,\n280:       } satisfies AdvisorBm25Match))\n281:       .filter((match) => typeof match.skillId === 'string' && match.score > 0)\n282:       .sort((left, right) => right.score - left.score || left.skillId.localeCompare(right.skillId))\n283:       .slice(0, options.limit ?? DEFAULT_LIMIT);\n284:   }\n285: \n286:   getFootprintStats(): AdvisorBm25FootprintStats {\n287:     let postingCount = 0;\n288:     let typedArrayBytes = 0;\n289:     for (const postings of this.packedPostings.values()) {\n290:       postingCount += postings.docIds.length;\n291:       typedArrayBytes += postings.docIds.byteLength\n292:         + postings.totalTfs.byteLength\n293:         + postings.nameTfs.byteLength\n294:         + postings.keywordTfs.byteLength\n295:         + postings.domainTfs.byteLength\n296:         + postings.intentSignalTfs.byteLength\n297:         + postings.derivedTriggerTfs.byteLength\n298:         + postings.descriptionTfs.byteLength;\n299:     }\n300:     return {\n301:       documentCount: this.documents.size,\n302:       termCount: this.packedPostings.size,\n303:       postingCount,\n304:       typedArrayBytes,\n305:       mutablePostingCount: this.mutablePostings.size,\n306:     };\n307:   }\n308: \n309:   private nextNumericId(skillId: string): number {\n310:     const existing = this.skillNumbersById.get(skillId);\n311:     if (existing !== undefined) return existing;\n312:     const numericId = this.skillIds.length;\n313:     this.skillIds.push(skillId);\n314:     this.skillNumbersById.set(skillId, numericId);\n315:     return numericId;\n316:   }\n317: \n318:   private ensureMutablePostings(term: string): PackedPostingMutable {\n319:     const existing = this.mutablePostings.get(term);\n320:     if (existing) return existing;\n321:     const postings: PackedPostingMutable = {\n322:       docIds: [],\n323:       totalTfs: [],\n324:       nameTfs: [],\n325:       keywordTfs: [],\n326:       domainTfs: [],\n327:       intentSignalTfs: [],\n328:       derivedTriggerTfs: [],\n329:       descriptionTfs: [],\n330:     };\n331:     this.mutablePostings.set(term, postings);\n332:     return postings;\n333:   }\n334: \n335:   private idf(term: string): number {\n336:     const docFreq = this.documentFreq.get(term) ?? 0;\n337:     return Math.log(1 + (this.documents.size - docFreq + 0.5) / (docFreq + 0.5));\n338:   }\n339: }\n340: \n341: export function buildAdvisorBm25Index(projection: AdvisorProjection): AdvisorPackedBm25Index {\n342:   return new AdvisorPackedBm25Index(projection.skills);\n343: }\n344: \n345: export function scoreBm25LexicalShadowLane(\n346:   prompt: string,\n347:   projection: AdvisorProjection,\n348:   options: AdvisorBm25SearchOptions = {},\n349: ): AdvisorBm25Match[] {\n350:   return buildAdvisorBm25Index(projection).search(prompt, options);\n351: }\n\n(End of file - total 351 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Packed BM25F Lexical Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, SkillProjection } from '../types.js';\nimport { tokenize } from '../text.js';\n\nexport const ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID = 'bm25_lexical_shadow' as const;\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 20;\n\nconst BM25F_FIELD_NAMES = [\n  'name',\n  'keywords',\n  'domains',\n  'intentSignals',\n  'derivedTriggers',\n  'description',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Packed BM25F Lexical Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, SkillProjection } from '../types.js';\nimport { tokenize } from '../text.js';\n\nexport const ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID = 'bm25_lexical_shadow' as const;\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 20;\n\nconst BM25F_FIELD_NAMES = [\n  'name',\n  'keywords',\n  'domains',\n  'intentSignals',\n  'derivedTriggers',\n  'description',\n] as const;\n\nexport type AdvisorBm25FieldName = typeof BM25F_FIELD_NAMES[number];\nexport type AdvisorBm25FieldWeights = Record<AdvisorBm25FieldName, number>;\n\nexport const ADVISOR_BM25_FIELD_WEIGHTS: AdvisorBm25FieldWeights = {\n  name: 4.0,\n  keywords: 3.0,\n  domains: 2.2,\n  intentSignals: 2.4,\n  derivedTriggers: 1.8,\n  description: 1.0,\n};\n\nexport interface AdvisorBm25SearchOptions {\n  readonly fieldWeights?: Partial<AdvisorBm25FieldWeights>;\n  readonly limit?: number;\n}\n\nexport interface AdvisorBm25Match {\n  readonly skillId: string;\n  readonly lane: typeof ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID;\n  readonly score: number;\n  readonly rawScore: number;\n  readonly evidence: readonly string[];\n  readonly shadowOnly: true;\n}\n\nexport interface AdvisorBm25FootprintStats {\n  readonly documentCount: number;\n  readonly termCount: number;\n  readonly postingCount: number;\n  readonly typedArrayBytes: number;\n  readonly mutablePostingCount: number;\n}\n\ninterface FieldTermFrequency {\n  total: number;\n  fields: Record<AdvisorBm25FieldName, number>;\n}\n\ninterface PackedSkillDocument {\n  numericId: number;\n  skillId: string;\n  length: number;\n  terms: readonly string[];\n}\n\ninterface PackedPostingMutable {\n  docIds: number[];\n  totalTfs: number[];\n  nameTfs: number[];\n  keywordTfs: number[];\n  domainTfs: number[];\n  intentSignalTfs: number[];\n  derivedTriggerTfs: number[];\n  descriptionTfs: number[];\n}\n\ninterface PackedPostingList {\n  docIds: Uint32Array;\n  totalTfs: Uint32Array;\n  nameTfs: Uint32Array;\n  keywordTfs: Uint32Array;\n  domainTfs: Uint32Array;\n  intentSignalTfs: Uint32Array;\n  derivedTriggerTfs: Uint32Array;\n  descriptionTfs: Uint32Array;\n}\n\nfunction emptyFieldFrequency(): FieldTermFrequency {\n  return {\n    total: 0,\n    fields: {\n      name: 0,\n      keywords: 0,\n      domains: 0,\n      intentSignals: 0,\n      derivedTriggers: 0,\n      description: 0,\n    },\n  };\n}\n\nfunction resolveFieldWeights(overrides: Partial<AdvisorBm25FieldWeights> = {}): AdvisorBm25FieldWeights {\n  return {\n    name: overrides.name ?? ADVISOR_BM25_FIELD_WEIGHTS.name,\n    keywords: overrides.keywords ?? ADVISOR_BM25_FIELD_WEIGHTS.keywords,\n    domains: overrides.domains ?? ADVISOR_BM25_FIELD_WEIGHTS.domains,\n    intentSignals: overrides.intentSignals ?? ADVISOR_BM25_FIELD_WEIGHTS.intentSignals,\n    derivedTriggers: overrides.derivedTriggers ?? ADVISOR_BM25_FIELD_WEIGHTS.derivedTriggers,\n    description: overrides.description ?? ADVISOR_BM25_FIELD_WEIGHTS.description,\n  };\n}\n\nfunction skillFields(skill: SkillProjection): Record<AdvisorBm25FieldName, readonly string[]> {\n  return {\n    name: [skill.id.replace(/-/g, ' '), skill.name],\n    keywords: skill.keywords,\n    domains: skill.domains,\n    intentSignals: skill.intentSignals,\n    derivedTriggers: skill.derivedTriggers,\n    description: [skill.description],\n  };\n}\n\nfunction fieldTermFrequencies(skill: SkillProjection): Map<string, FieldTermFrequency> {\n  const frequencies = new Map<string, FieldTermFrequency>();\n  for (const fieldName of BM25F_FIELD_NAMES) {\n    for (const value of skillFields(skill)[fieldName]) {\n      for (const token of tokenize(value)) {\n        let frequency = frequencies.get(token);\n        if (!frequency) {\n          frequency = emptyFieldFrequency();\n          frequencies.set(token, frequency);\n        }\n        frequency.total += 1;\n        frequency.fields[fieldName] += 1;\n      }\n    }\n  }\n  return frequencies;\n}\n\nfunction weightedFrequency(\n  postings: PackedPostingList,\n  index: number,\n  weights: AdvisorBm25FieldWeights,\n): number {\n  return postings.nameTfs[index] * weights.name\n    + postings.keywordTfs[index] * weights.keywords\n    + postings.domainTfs[index] * weights.domains\n    + postings.intentSignalTfs[index] * weights.intentSignals\n    + postings.derivedTriggerTfs[index] * weights.derivedTriggers\n    + postings.descriptionTfs[index] * weights.description;\n}\n\nfunction topWeightedFields(\n  postings: PackedPostingList,\n  index: number,\n  weights: AdvisorBm25FieldWeights,\n): AdvisorBm25FieldName[] {\n  return [\n    { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n    { field: 'keywords' as const, value: postings.keywordTfs[index] * weights.keywords },\n    { field: 'domains' as const, value: postings.domainTfs[index] * weights.domains },\n    { field: 'intentSignals' as const, value: postings.intentSignalTfs[index] * weights.intentSignals },\n    { field: 'derivedTriggers' as const, value: postings.derivedTriggerTfs[index] * weights.derivedTriggers },\n    { field: 'description' as const, value: postings.descriptionTfs[index] * weights.description },\n  ]\n    .filter((entry) => entry.value > 0)\n    .sort((left, right) => right.value - left.value)\n    .map((entry) => entry.field)\n    .slice(0, 3);\n}\n\nexport class AdvisorPackedBm25Index {\n  private readonly skillIds: string[] = [];\n  private readonly skillNumbersById = new Map<string, number>();\n  private readonly documents = new Map<string, PackedSkillDocument>();\n  private readonly documentFreq = new Map<string, number>();\n  private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n  private readonly packedPostings = new Map<string, PackedPostingList>();\n  private totalDocumentLength = 0;\n\n  constructor(skills: readonly SkillProjection[] = []) {\n    for (const skill of skills) {\n      this.addSkill(skill);\n    }\n    this.finalize();\n  }\n\n  addSkill(skill: SkillProjection): void {\n    const frequencies = fieldTermFrequencies(skill);\n    const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n    if (length === 0) return;\n\n    const numericId = this.nextNumericId(skill.id);\n    const terms = [...frequencies.keys()].sort();\n    this.documents.set(skill.id, { numericId, skillId: skill.id, length, terms });\n    this.totalDocumentLength += length;\n\n    for (const term of terms) {\n      const frequency = frequencies.get(term);\n      if (!frequency) continue;\n      this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n      const postings = this.ensureMutablePostings(term);\n      postings.docIds.push(numericId);\n      postings.totalTfs.push(frequency.total);\n      postings.nameTfs.push(frequency.fields.name);\n      postings.keywordTfs.push(frequency.fields.keywords);\n      postings.domainTfs.push(frequency.fields.domains);\n      postings.intentSignalTfs.push(frequency.fields.intentSignals);\n      postings.derivedTriggerTfs.push(frequency.fields.derivedTriggers);\n      postings.descriptionTfs.push(frequency.fields.description);\n    }\n  }\n\n  finalize(): void {\n    for (const [term, postings] of this.mutablePostings.entries()) {\n      const order = postings.docIds.map((docId, index) => ({ docId, index }))\n        .sort((left, right) => left.docId - right.docId);\n      this.packedPostings.set(term, {\n        docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n        totalTfs: Uint32Array.from(order.map((entry) => postings.totalTfs[entry.index])),\n        nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n        keywordTfs: Uint32Array.from(order.map((entry) => postings.keywordTfs[entry.index])),\n        domainTfs: Uint32Array.from(order.map((entry) => postings.domainTfs[entry.index])),\n        intentSignalTfs: Uint32Array.from(order.map((entry) => postings.intentSignalTfs[entry.index])),\n        derivedTriggerTfs: Uint32Array.from(order.map((entry) => postings.derivedTriggerTfs[entry.index])),\n        descriptionTfs: Uint32Array.from(order.map((entry) => postings.descriptionTfs[entry.index])),\n      });\n    }\n    this.mutablePostings.clear();\n  }\n\n  search(prompt: string, options: AdvisorBm25SearchOptions = {}): AdvisorBm25Match[] {\n    const queryTerms = [...new Set(tokenize(prompt))];\n    if (queryTerms.length === 0 || this.documents.size === 0) return [];\n\n    const weights = resolveFieldWeights(options.fieldWeights);\n    const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n    const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n\n    for (const term of queryTerms) {\n      const postings = this.packedPostings.get(term);\n      if (!postings) continue;\n      const idf = this.idf(term);\n      for (let i = 0; i < postings.docIds.length; i += 1) {\n        const numericId = postings.docIds[i];\n        const skillId = this.skillIds[numericId];\n        const doc = skillId ? this.documents.get(skillId) : undefined;\n        if (!doc) continue;\n        const weightedTf = weightedFrequency(postings, i, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n          / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (doc.length / averageLength))));\n        const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n        existing.rawScore += termScore;\n        if (existing.evidence.length < 6) {\n          existing.evidence.push(`bm25:${term}`);\n          for (const field of topWeightedFields(postings, i, weights)) {\n            if (existing.evidence.length >= 6) break;\n            existing.evidence.push(`field:${field}`);\n          }\n        }\n        scores.set(numericId, existing);\n      }\n    }\n\n    return [...scores.entries()]\n      .map(([numericId, result]) => ({\n        skillId: this.skillIds[numericId],\n        lane: ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID,\n        rawScore: Number(result.rawScore.toFixed(6)),\n        score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n        evidence: result.evidence,\n        shadowOnly: true,\n      } satisfies AdvisorBm25Match))\n      .filter((match) => typeof match.skillId === 'string' && match.score > 0)\n      .sort((left, right) => right.score - left.score || left.skillId.localeCompare(right.skillId))\n      .slice(0, options.limit ?? DEFAULT_LIMIT);\n  }\n\n  getFootprintStats(): AdvisorBm25FootprintStats {\n    let postingCount = 0;\n    let typedArrayBytes = 0;\n    for (const postings of this.packedPostings.values()) {\n      postingCount += postings.docIds.length;\n      typedArrayBytes += postings.docIds.byteLength\n        + postings.totalTfs.byteLength\n        + postings.nameTfs.byteLength\n        + postings.keywordTfs.byteLength\n        + postings.domainTfs.byteLength\n        + postings.intentSignalTfs.byteLength\n        + postings.derivedTriggerTfs.byteLength\n        + postings.descriptionTfs.byteLength;\n    }\n    return {\n      documentCount: this.documents.size,\n      termCount: this.packedPostings.size,\n      postingCount,\n      typedArrayBytes,\n      mutablePostingCount: this.mutablePostings.size,\n    };\n  }\n\n  private nextNumericId(skillId: string): number {\n    const existing = this.skillNumbersById.get(skillId);\n    if (existing !== undefined) return existing;\n    const numericId = this.skillIds.length;\n    this.skillIds.push(skillId);\n    this.skillNumbersById.set(skillId, numericId);\n    return numericId;\n  }\n\n  private ensureMutablePostings(term: string): PackedPostingMutable {\n    const existing = this.mutablePostings.get(term);\n    if (existing) return existing;\n    const postings: PackedPostingMutable = {\n      docIds: [],\n      totalTfs: [],\n      nameTfs: [],\n      keywordTfs: [],\n      domainTfs: [],\n      intentSignalTfs: [],\n      derivedTriggerTfs: [],\n      descriptionTfs: [],\n    };\n    this.mutablePostings.set(term, postings);\n    return postings;\n  }\n\n  private idf(term: string): number {\n    const docFreq = this.documentFreq.get(term) ?? 0;\n    return Math.log(1 + (this.documents.size - docFreq + 0.5) / (docFreq + 0.5));\n  }\n}\n\nexport function buildAdvisorBm25Index(projection: AdvisorProjection): AdvisorPackedBm25Index {\n  return new AdvisorPackedBm25Index(projection.skills);\n}\n\nexport function scoreBm25LexicalShadowLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  options: AdvisorBm25SearchOptions = {},\n): AdvisorBm25Match[] {\n  return buildAdvisorBm25Index(projection).search(prompt, options);\n}","lineStart":1,"lineEnd":351,"totalLines":351,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts","time":{"start":1781129304640,"end":1781129304645}},"metadata":{"openai":{"itemId":"fc_03a7269519c32c84016a29e05882448191a9f591924213d774"}},"id":"prt_eb3945a33001RfNK33Xb34EzLk","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3942f76001MikAc8rxVzXCKv"}}
{"type":"tool_use","timestamp":1781129304769,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_Z8xEU7AAWjGKv6C82UNZfx4X","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","offset":1,"limit":1700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Feedback Calibration Reducer\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { createHash } from 'node:crypto';\n6: import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n7: import { tmpdir } from 'node:os';\n8: import { dirname, join, resolve } from 'node:path';\n9: \n10: import type { AdvisorHookOutcomeRecord } from '../metrics.js';\n11: import { isLiveScorerLane } from './lane-registry.js';\n12: import type { ScorerLane } from './types.js';\n13: import {\n14:   SCORER_LANES,\n15:   buildReadOnlyScorerCalibrationProposal,\n16:   type ReadOnlyScorerCalibrationProposal,\n17:   type ScorerCalibrationThresholds,\n18: } from './weights-config.js';\n19: \n20: const TRUE_VALUES = new Set(['true', '1', 'yes', 'on', 'enabled']);\n21: const DEFAULT_MIN_SAMPLES = 8;\n22: const DEFAULT_MAX_SKILL_SHARE = 0.6;\n23: const MAX_WEIGHT_DELTA = 0.03;\n24: const MAX_THRESHOLD_DELTA = 0.05;\n25: const MAX_RECORDS = 50;\n26: const RECORD_ROOT = join(tmpdir(), 'speckit-skill-advisor-calibration');\n27: \n28: export type AdvisorFeedbackCalibrationLaneStatus = 'candidate' | 'excluded';\n29: \n30: export interface AdvisorFeedbackCalibrationLaneSignal {\n31:   readonly lane: ScorerLane;\n32:   readonly status: AdvisorFeedbackCalibrationLaneStatus;\n33:   readonly sampleCount: number;\n34:   readonly accepted: number;\n35:   readonly corrected: number;\n36:   readonly ignored: number;\n37:   readonly proposedDelta: number;\n38:   readonly reason: string;\n39: }\n40: \n41: export interface AdvisorFeedbackCalibrationReport {\n42:   readonly model: 'advisor-feedback-calibration-shadow-v1';\n43:   readonly generatedAt: string;\n44:   readonly scope: {\n45:     readonly kind: 'workspace' | 'skill';\n46:     readonly skillSlug: string | null;\n47:   };\n48:   readonly sample: {\n49:     readonly total: number;\n50:     readonly accepted: number;\n51:     readonly corrected: number;\n52:     readonly ignored: number;\n53:     readonly distinctSkills: number;\n54:     readonly maxSkillShare: number;\n55:   };\n56:   readonly laneSignals: readonly AdvisorFeedbackCalibrationLaneSignal[];\n57:   readonly thresholdSignals: {\n58:     readonly confidenceThresholdDelta: number;\n59:     readonly uncertaintyThresholdDelta: number;\n60:     readonly reason: string;\n61:   };\n62:   readonly proposal: ReadOnlyScorerCalibrationProposal;\n63:   readonly guardrails: {\n64:     readonly defaultOff: true;\n65:     readonly shadowOnly: true;\n66:     readonly liveWeightsFrozen: true;\n67:     readonly autoPromotion: false;\n68:     readonly heldOutValidationRequired: true;\n69:     readonly noLaneAttributionFallback: boolean;\n70:   };\n71: }\n72: \n73: export interface AdvisorFeedbackCalibrationOptions {\n74:   readonly generatedAt?: string;\n75:   readonly skillSlug?: string | null;\n76:   readonly currentThresholds: ScorerCalibrationThresholds;\n77:   readonly minSamples?: number;\n78:   readonly maxSkillShare?: number;\n79:   readonly laneAttributionBySkill?: Readonly<Record<string, ScorerLane>>;\n80: }\n81: \n82: function round4(value: number): number {\n83:   return Number(value.toFixed(4));\n84: }\n85: \n86: function clamp(value: number, maxAbs: number): number {\n87:   return Math.max(-maxAbs, Math.min(maxAbs, value));\n88: }\n89: \n90: function workspaceHash(workspaceRoot: string): string {\n91:   return createHash('sha256')\n92:     .update(resolve(workspaceRoot))\n93:     .digest('hex')\n94:     .slice(0, 16);\n95: }\n96: \n97: function countOutcomes(records: readonly AdvisorHookOutcomeRecord[]): {\n98:   accepted: number;\n99:   corrected: number;\n100:   ignored: number;\n101: } {\n102:   return {\n103:     accepted: records.filter((record) => record.outcome === 'accepted').length,\n104:     corrected: records.filter((record) => record.outcome === 'corrected').length,\n105:     ignored: records.filter((record) => record.outcome === 'ignored').length,\n106:   };\n107: }\n108: \n109: function maxSkillShare(records: readonly AdvisorHookOutcomeRecord[]): number {\n110:   if (records.length === 0) return 0;\n111:   const counts = new Map<string, number>();\n112:   for (const record of records) {\n113:     counts.set(record.skillLabel, (counts.get(record.skillLabel) ?? 0) + 1);\n114:   }\n115:   return Math.max(...counts.values()) / records.length;\n116: }\n117: \n118: function distinctSkillCount(records: readonly AdvisorHookOutcomeRecord[]): number {\n119:   return new Set(records.map((record) => record.skillLabel)).size;\n120: }\n121: \n122: function signalReason(args: {\n123:   readonly sampleCount: number;\n124:   readonly minSamples: number;\n125:   readonly concentrated: boolean;\n126:   readonly attributed: boolean;\n127: }): string {\n128:   if (args.sampleCount < args.minSamples) return 'low_sample_excluded';\n129:   if (args.concentrated) return 'sample_concentration_excluded';\n130:   if (!args.attributed) return 'no_lane_attribution_excluded';\n131:   return 'supported_shadow_candidate';\n132: }\n133: \n134: function laneRecords(\n135:   lane: ScorerLane,\n136:   records: readonly AdvisorHookOutcomeRecord[],\n137:   laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n138: ): AdvisorHookOutcomeRecord[] {\n139:   return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n140: }\n141: \n142: export function isAdvisorFeedbackCalibrationEnabled(\n143:   env: Record<string, string | undefined> = process.env,\n144: ): boolean {\n145:   const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n146:   return raw !== undefined && TRUE_VALUES.has(raw);\n147: }\n148: \n149: export function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {\n150:   return process.env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_PATH\n151:     ?? join(RECORD_ROOT, `${workspaceHash(workspaceRoot)}-feedback-calibration.jsonl`);\n152: }\n153: \n154: export function reduceAdvisorFeedbackCalibration(\n155:   records: readonly AdvisorHookOutcomeRecord[],\n156:   options: AdvisorFeedbackCalibrationOptions,\n157: ): AdvisorFeedbackCalibrationReport {\n158:   const minSamples = options.minSamples ?? DEFAULT_MIN_SAMPLES;\n159:   const maxShare = options.maxSkillShare ?? DEFAULT_MAX_SKILL_SHARE;\n160:   const totals = countOutcomes(records);\n161:   const skillShare = round4(maxSkillShare(records));\n162:   const concentrated = records.length > 0 && skillShare > maxShare;\n163:   const laneAttributionBySkill = options.laneAttributionBySkill ?? {};\n164:   const hasAttribution = Object.keys(laneAttributionBySkill).length > 0;\n165:   const weightDeltas: Partial<Record<ScorerLane, number>> = {};\n166: \n167:   const laneSignals = SCORER_LANES.map((lane): AdvisorFeedbackCalibrationLaneSignal => {\n168:     const attributedRecords = laneRecords(lane, records, laneAttributionBySkill);\n169:     const laneTotals = hasAttribution ? countOutcomes(attributedRecords) : totals;\n170:     const sampleCount = hasAttribution ? attributedRecords.length : records.length;\n171:     const reason = signalReason({ sampleCount, minSamples, concentrated, attributed: hasAttribution });\n172:     const status: AdvisorFeedbackCalibrationLaneStatus = reason === 'supported_shadow_candidate' ? 'candidate' : 'excluded';\n173:     const correctionPressure = sampleCount > 0 ? laneTotals.corrected / sampleCount : 0;\n174:     const acceptancePressure = sampleCount > 0 ? laneTotals.accepted / sampleCount : 0;\n175:     const proposedDelta = status === 'candidate' && isLiveScorerLane(lane)\n176:       ? round4(clamp((acceptancePressure - correctionPressure) * MAX_WEIGHT_DELTA, MAX_WEIGHT_DELTA))\n177:       : 0;\n178:     if (proposedDelta !== 0) weightDeltas[lane] = proposedDelta;\n179:     return {\n180:       lane,\n181:       status,\n182:       sampleCount,\n183:       accepted: laneTotals.accepted,\n184:       corrected: laneTotals.corrected,\n185:       ignored: laneTotals.ignored,\n186:       proposedDelta,\n187:       reason,\n188:     };\n189:   });\n190: \n191:   const correctionRate = records.length > 0 ? totals.corrected / records.length : 0;\n192:   const ignoredRate = records.length > 0 ? totals.ignored / records.length : 0;\n193:   const thresholdSignals = records.length < minSamples || concentrated\n194:     ? {\n195:       confidenceThresholdDelta: 0,\n196:       uncertaintyThresholdDelta: 0,\n197:       reason: records.length < minSamples ? 'low_sample_excluded' : 'sample_concentration_excluded',\n198:     }\n199:     : {\n200:       confidenceThresholdDelta: round4(clamp(correctionRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n201:       uncertaintyThresholdDelta: round4(clamp(-ignoredRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n202:       reason: 'supported_shadow_candidate',\n203:     };\n204: \n205:   return {\n206:     model: 'advisor-feedback-calibration-shadow-v1',\n207:     generatedAt: options.generatedAt ?? new Date().toISOString(),\n208:     scope: {\n209:       kind: options.skillSlug === null || options.skillSlug === undefined ? 'workspace' : 'skill',\n210:       skillSlug: options.skillSlug ?? null,\n211:     },\n212:     sample: {\n213:       total: records.length,\n214:       accepted: totals.accepted,\n215:       corrected: totals.corrected,\n216:       ignored: totals.ignored,\n217:       distinctSkills: distinctSkillCount(records),\n218:       maxSkillShare: skillShare,\n219:     },\n220:     laneSignals,\n221:     thresholdSignals,\n222:     proposal: buildReadOnlyScorerCalibrationProposal({\n223:       proposedWeightDeltas: weightDeltas,\n224:       currentThresholds: options.currentThresholds,\n225:       proposedThresholdDeltas: {\n226:         confidenceThreshold: thresholdSignals.confidenceThresholdDelta,\n227:         uncertaintyThreshold: thresholdSignals.uncertaintyThresholdDelta,\n228:       },\n229:     }),\n230:     guardrails: {\n231:       defaultOff: true,\n232:       shadowOnly: true,\n233:       liveWeightsFrozen: true,\n234:       autoPromotion: false,\n235:       heldOutValidationRequired: true,\n236:       noLaneAttributionFallback: !hasAttribution,\n237:     },\n238:   };\n239: }\n240: \n241: export function persistAdvisorFeedbackCalibrationRecord(\n242:   workspaceRoot: string,\n243:   report: AdvisorFeedbackCalibrationReport,\n244: ): string {\n245:   const path = advisorFeedbackCalibrationRecordsPath(workspaceRoot);\n246:   mkdirSync(dirname(path), { recursive: true });\n247:   const existing = existsSync(path)\n248:     ? readFileSync(path, 'utf8').split('\\n').map((line) => line.trim()).filter(Boolean)\n249:     : [];\n250:   existing.push(JSON.stringify(report));\n251:   writeFileSync(path, `${existing.slice(-MAX_RECORDS).join('\\n')}\\n`, 'utf8');\n252:   return path;\n253: }\n254: \n255: export function recordAdvisorFeedbackCalibrationIfEnabled(input: {\n256:   readonly workspaceRoot: string;\n257:   readonly records: readonly AdvisorHookOutcomeRecord[];\n258:   readonly options: AdvisorFeedbackCalibrationOptions;\n259:   readonly env?: Record<string, string | undefined>;\n260: }): AdvisorFeedbackCalibrationReport | null {\n261:   if (!isAdvisorFeedbackCalibrationEnabled(input.env)) return null;\n262:   const report = reduceAdvisorFeedbackCalibration(input.records, input.options);\n263:   persistAdvisorFeedbackCalibrationRecord(input.workspaceRoot, report);\n264:   return report;\n265: }\n\n(End of file - total 265 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Feedback Calibration Reducer\n// ───────────────────────────────────────────────────────────────\n\nimport { createHash } from 'node:crypto';\nimport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\n\nimport type { AdvisorHookOutcomeRecord } from '../metrics.js';\nimport { isLiveScorerLane } from './lane-registry.js';\nimport type { ScorerLane } from './types.js';\nimport {\n  SCORER_LANES,\n  buildReadOnlyScorerCalibrationProposal,\n  type ReadOnlyScorerCalibrationProposal,\n  type ScorerCalibrationThresholds,\n} from './weights-config.js';\n\nconst TRUE_VALUES = new Set(['true', '1', 'yes', 'on', 'enabled']);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Feedback Calibration Reducer\n// ───────────────────────────────────────────────────────────────\n\nimport { createHash } from 'node:crypto';\nimport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\n\nimport type { AdvisorHookOutcomeRecord } from '../metrics.js';\nimport { isLiveScorerLane } from './lane-registry.js';\nimport type { ScorerLane } from './types.js';\nimport {\n  SCORER_LANES,\n  buildReadOnlyScorerCalibrationProposal,\n  type ReadOnlyScorerCalibrationProposal,\n  type ScorerCalibrationThresholds,\n} from './weights-config.js';\n\nconst TRUE_VALUES = new Set(['true', '1', 'yes', 'on', 'enabled']);\nconst DEFAULT_MIN_SAMPLES = 8;\nconst DEFAULT_MAX_SKILL_SHARE = 0.6;\nconst MAX_WEIGHT_DELTA = 0.03;\nconst MAX_THRESHOLD_DELTA = 0.05;\nconst MAX_RECORDS = 50;\nconst RECORD_ROOT = join(tmpdir(), 'speckit-skill-advisor-calibration');\n\nexport type AdvisorFeedbackCalibrationLaneStatus = 'candidate' | 'excluded';\n\nexport interface AdvisorFeedbackCalibrationLaneSignal {\n  readonly lane: ScorerLane;\n  readonly status: AdvisorFeedbackCalibrationLaneStatus;\n  readonly sampleCount: number;\n  readonly accepted: number;\n  readonly corrected: number;\n  readonly ignored: number;\n  readonly proposedDelta: number;\n  readonly reason: string;\n}\n\nexport interface AdvisorFeedbackCalibrationReport {\n  readonly model: 'advisor-feedback-calibration-shadow-v1';\n  readonly generatedAt: string;\n  readonly scope: {\n    readonly kind: 'workspace' | 'skill';\n    readonly skillSlug: string | null;\n  };\n  readonly sample: {\n    readonly total: number;\n    readonly accepted: number;\n    readonly corrected: number;\n    readonly ignored: number;\n    readonly distinctSkills: number;\n    readonly maxSkillShare: number;\n  };\n  readonly laneSignals: readonly AdvisorFeedbackCalibrationLaneSignal[];\n  readonly thresholdSignals: {\n    readonly confidenceThresholdDelta: number;\n    readonly uncertaintyThresholdDelta: number;\n    readonly reason: string;\n  };\n  readonly proposal: ReadOnlyScorerCalibrationProposal;\n  readonly guardrails: {\n    readonly defaultOff: true;\n    readonly shadowOnly: true;\n    readonly liveWeightsFrozen: true;\n    readonly autoPromotion: false;\n    readonly heldOutValidationRequired: true;\n    readonly noLaneAttributionFallback: boolean;\n  };\n}\n\nexport interface AdvisorFeedbackCalibrationOptions {\n  readonly generatedAt?: string;\n  readonly skillSlug?: string | null;\n  readonly currentThresholds: ScorerCalibrationThresholds;\n  readonly minSamples?: number;\n  readonly maxSkillShare?: number;\n  readonly laneAttributionBySkill?: Readonly<Record<string, ScorerLane>>;\n}\n\nfunction round4(value: number): number {\n  return Number(value.toFixed(4));\n}\n\nfunction clamp(value: number, maxAbs: number): number {\n  return Math.max(-maxAbs, Math.min(maxAbs, value));\n}\n\nfunction workspaceHash(workspaceRoot: string): string {\n  return createHash('sha256')\n    .update(resolve(workspaceRoot))\n    .digest('hex')\n    .slice(0, 16);\n}\n\nfunction countOutcomes(records: readonly AdvisorHookOutcomeRecord[]): {\n  accepted: number;\n  corrected: number;\n  ignored: number;\n} {\n  return {\n    accepted: records.filter((record) => record.outcome === 'accepted').length,\n    corrected: records.filter((record) => record.outcome === 'corrected').length,\n    ignored: records.filter((record) => record.outcome === 'ignored').length,\n  };\n}\n\nfunction maxSkillShare(records: readonly AdvisorHookOutcomeRecord[]): number {\n  if (records.length === 0) return 0;\n  const counts = new Map<string, number>();\n  for (const record of records) {\n    counts.set(record.skillLabel, (counts.get(record.skillLabel) ?? 0) + 1);\n  }\n  return Math.max(...counts.values()) / records.length;\n}\n\nfunction distinctSkillCount(records: readonly AdvisorHookOutcomeRecord[]): number {\n  return new Set(records.map((record) => record.skillLabel)).size;\n}\n\nfunction signalReason(args: {\n  readonly sampleCount: number;\n  readonly minSamples: number;\n  readonly concentrated: boolean;\n  readonly attributed: boolean;\n}): string {\n  if (args.sampleCount < args.minSamples) return 'low_sample_excluded';\n  if (args.concentrated) return 'sample_concentration_excluded';\n  if (!args.attributed) return 'no_lane_attribution_excluded';\n  return 'supported_shadow_candidate';\n}\n\nfunction laneRecords(\n  lane: ScorerLane,\n  records: readonly AdvisorHookOutcomeRecord[],\n  laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n): AdvisorHookOutcomeRecord[] {\n  return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n}\n\nexport function isAdvisorFeedbackCalibrationEnabled(\n  env: Record<string, string | undefined> = process.env,\n): boolean {\n  const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n  return raw !== undefined && TRUE_VALUES.has(raw);\n}\n\nexport function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {\n  return process.env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_PATH\n    ?? join(RECORD_ROOT, `${workspaceHash(workspaceRoot)}-feedback-calibration.jsonl`);\n}\n\nexport function reduceAdvisorFeedbackCalibration(\n  records: readonly AdvisorHookOutcomeRecord[],\n  options: AdvisorFeedbackCalibrationOptions,\n): AdvisorFeedbackCalibrationReport {\n  const minSamples = options.minSamples ?? DEFAULT_MIN_SAMPLES;\n  const maxShare = options.maxSkillShare ?? DEFAULT_MAX_SKILL_SHARE;\n  const totals = countOutcomes(records);\n  const skillShare = round4(maxSkillShare(records));\n  const concentrated = records.length > 0 && skillShare > maxShare;\n  const laneAttributionBySkill = options.laneAttributionBySkill ?? {};\n  const hasAttribution = Object.keys(laneAttributionBySkill).length > 0;\n  const weightDeltas: Partial<Record<ScorerLane, number>> = {};\n\n  const laneSignals = SCORER_LANES.map((lane): AdvisorFeedbackCalibrationLaneSignal => {\n    const attributedRecords = laneRecords(lane, records, laneAttributionBySkill);\n    const laneTotals = hasAttribution ? countOutcomes(attributedRecords) : totals;\n    const sampleCount = hasAttribution ? attributedRecords.length : records.length;\n    const reason = signalReason({ sampleCount, minSamples, concentrated, attributed: hasAttribution });\n    const status: AdvisorFeedbackCalibrationLaneStatus = reason === 'supported_shadow_candidate' ? 'candidate' : 'excluded';\n    const correctionPressure = sampleCount > 0 ? laneTotals.corrected / sampleCount : 0;\n    const acceptancePressure = sampleCount > 0 ? laneTotals.accepted / sampleCount : 0;\n    const proposedDelta = status === 'candidate' && isLiveScorerLane(lane)\n      ? round4(clamp((acceptancePressure - correctionPressure) * MAX_WEIGHT_DELTA, MAX_WEIGHT_DELTA))\n      : 0;\n    if (proposedDelta !== 0) weightDeltas[lane] = proposedDelta;\n    return {\n      lane,\n      status,\n      sampleCount,\n      accepted: laneTotals.accepted,\n      corrected: laneTotals.corrected,\n      ignored: laneTotals.ignored,\n      proposedDelta,\n      reason,\n    };\n  });\n\n  const correctionRate = records.length > 0 ? totals.corrected / records.length : 0;\n  const ignoredRate = records.length > 0 ? totals.ignored / records.length : 0;\n  const thresholdSignals = records.length < minSamples || concentrated\n    ? {\n      confidenceThresholdDelta: 0,\n      uncertaintyThresholdDelta: 0,\n      reason: records.length < minSamples ? 'low_sample_excluded' : 'sample_concentration_excluded',\n    }\n    : {\n      confidenceThresholdDelta: round4(clamp(correctionRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n      uncertaintyThresholdDelta: round4(clamp(-ignoredRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n      reason: 'supported_shadow_candidate',\n    };\n\n  return {\n    model: 'advisor-feedback-calibration-shadow-v1',\n    generatedAt: options.generatedAt ?? new Date().toISOString(),\n    scope: {\n      kind: options.skillSlug === null || options.skillSlug === undefined ? 'workspace' : 'skill',\n      skillSlug: options.skillSlug ?? null,\n    },\n    sample: {\n      total: records.length,\n      accepted: totals.accepted,\n      corrected: totals.corrected,\n      ignored: totals.ignored,\n      distinctSkills: distinctSkillCount(records),\n      maxSkillShare: skillShare,\n    },\n    laneSignals,\n    thresholdSignals,\n    proposal: buildReadOnlyScorerCalibrationProposal({\n      proposedWeightDeltas: weightDeltas,\n      currentThresholds: options.currentThresholds,\n      proposedThresholdDeltas: {\n        confidenceThreshold: thresholdSignals.confidenceThresholdDelta,\n        uncertaintyThreshold: thresholdSignals.uncertaintyThresholdDelta,\n      },\n    }),\n    guardrails: {\n      defaultOff: true,\n      shadowOnly: true,\n      liveWeightsFrozen: true,\n      autoPromotion: false,\n      heldOutValidationRequired: true,\n      noLaneAttributionFallback: !hasAttribution,\n    },\n  };\n}\n\nexport function persistAdvisorFeedbackCalibrationRecord(\n  workspaceRoot: string,\n  report: AdvisorFeedbackCalibrationReport,\n): string {\n  const path = advisorFeedbackCalibrationRecordsPath(workspaceRoot);\n  mkdirSync(dirname(path), { recursive: true });\n  const existing = existsSync(path)\n    ? readFileSync(path, 'utf8').split('\\n').map((line) => line.trim()).filter(Boolean)\n    : [];\n  existing.push(JSON.stringify(report));\n  writeFileSync(path, `${existing.slice(-MAX_RECORDS).join('\\n')}\\n`, 'utf8');\n  return path;\n}\n\nexport function recordAdvisorFeedbackCalibrationIfEnabled(input: {\n  readonly workspaceRoot: string;\n  readonly records: readonly AdvisorHookOutcomeRecord[];\n  readonly options: AdvisorFeedbackCalibrationOptions;\n  readonly env?: Record<string, string | undefined>;\n}): AdvisorFeedbackCalibrationReport | null {\n  if (!isAdvisorFeedbackCalibrationEnabled(input.env)) return null;\n  const report = reduceAdvisorFeedbackCalibration(input.records, input.options);\n  persistAdvisorFeedbackCalibrationRecord(input.workspaceRoot, report);\n  return report;\n}","lineStart":1,"lineEnd":265,"totalLines":265,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","time":{"start":1781129304758,"end":1781129304767}},"metadata":{"openai":{"itemId":"fc_03a7269519c32c84016a29e058824c8191bcaff5d5f6c1873a"}},"id":"prt_eb3945a5d0013d4swHDbuL5QJQ","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3942f76001MikAc8rxVzXCKv"}}
{"type":"tool_use","timestamp":1781129304769,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_2K8JbI68a9wqvDnRbU4iNOlQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Cross-Skill Edges Apply Patch\n3: // ───────────────────────────────────────────────────────────────\n4: // Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n5: \n6: import { readFile, writeFile } from 'node:fs/promises';\n7: import { basename, resolve, sep } from 'node:path';\n8: import type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n9: \n10: // ───────────────────────────────────────────────────────────────\n11: // 1. APPLY EDGE\n12: // ───────────────────────────────────────────────────────────────\n13: \n14: const PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n15: \n16: function deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n17:   return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n18: }\n19: \n20: function readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {\n21:   const value = edge.source_kind;\n22:   if (value === 'automated' || value === 'manual' || value === 'trusted') {\n23:     return value;\n24:   }\n25:   return null;\n26: }\n27: \n28: function buildAutomatedReason(candidate: InboundEnhanceCandidate): string {\n29:   return candidate.rules.map(r => `${r.rule}:${r.contribution.toFixed(2)}`).join(' + ');\n30: }\n31: \n32: /**\n33:  * Validate that the source path is a graph-metadata.json file under the trusted skills root.\n34:  * Prevents path traversal in apply mode.\n35:  */\n36: function isPathWithin(candidatePath: string, trustedRoot: string): boolean {\n37:   const resolvedCandidate = resolve(candidatePath);\n38:   const resolvedRoot = resolve(trustedRoot);\n39:   const rootWithSep = resolvedRoot.endsWith(sep) ? resolvedRoot : resolvedRoot + sep;\n40:   return resolvedCandidate.startsWith(rootWithSep) && basename(resolvedCandidate) === 'graph-metadata.json';\n41: }\n42: \n43: /**\n44:  * Apply an enhance edge to the source skill's graph-metadata.json.\n45:  * Idempotent for automated writes and protects manually maintained provenance.\n46:  *\n47:  * @param candidate - The candidate to apply\n48:  * @param skillsRoot - Optional trusted workspace root. When provided, candidate.sourcePath\n49:  *                    MUST resolve under this root and have basename 'graph-metadata.json'.\n50:  * This guards against path traversal in apply mode.\n51:  */\n52: export async function applyEnhanceEdge(\n53:   candidate: InboundEnhanceCandidate,\n54:   skillsRoot?: string,\n55:   writeIntent: EdgeWriteIntent = 'automated',\n56: ): Promise<{ applied: boolean; reason: string }> {\n57:   if (!candidate.applyable) {\n58:     return { applied: false, reason: `not applyable: ${candidate.blockers.join('; ')}` };\n59:   }\n60: \n61:   if (skillsRoot && !isPathWithin(candidate.sourcePath, skillsRoot)) {\n62:     return {\n63:       applied: false,\n64:       reason: `path-boundary violation: ${candidate.sourcePath} not under ${skillsRoot}`,\n65:     };\n66:   }\n67: \n68:   try {\n69:     const raw = await readFile(candidate.sourcePath, 'utf-8');\n70:     const parsed = JSON.parse(raw);\n71: \n72:     if (!parsed.edges) {\n73:       parsed.edges = {};\n74:     }\n75:     if (!parsed.edges.enhances) {\n76:       parsed.edges.enhances = [];\n77:     }\n78: \n79:     const enhances: Array<Record<string, unknown>> = parsed.edges.enhances;\n80:     const sourceKind = deriveSourceKind(writeIntent);\n81:     const existingEdge = enhances.find(e => e.target === candidate.targetSkillId);\n82: \n83:     if (existingEdge && writeIntent === 'automated') {\n84:       const existingSourceKind = readSourceKind(existingEdge);\n85:       if (existingSourceKind && PROTECTED_SOURCE_KINDS.has(existingSourceKind)) {\n86:         return { applied: false, reason: 'edge already exists: manual provenance protected' };\n87:       }\n88:       return { applied: false, reason: 'edge already exists' };\n89:     }\n90: \n91:     if (existingEdge) {\n92:       existingEdge.weight = candidate.weight;\n93:       existingEdge.context = candidate.context;\n94:       existingEdge.source_kind = sourceKind;\n95:       await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n96:       return { applied: true, reason: 'edge updated by trusted maintainer' };\n97:     }\n98: \n99:     const newEdge = {\n100:       target: candidate.targetSkillId,\n101:       weight: candidate.weight,\n102:       context: candidate.context,\n103:       source_kind: sourceKind,\n104:     };\n105: \n106:     if (writeIntent === 'automated') {\n107:       Object.assign(newEdge, {\n108:         auto_added_at: new Date().toISOString(),\n109:         auto_added_reason: buildAutomatedReason(candidate),\n110:       });\n111:     }\n112: \n113:     enhances.push(newEdge);\n114:     parsed.edges.enhances = enhances;\n115: \n116:     await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n117:     return { applied: true, reason: `edge added with ${sourceKind} provenance` };\n118:   } catch (error) {\n119:     const message = error instanceof Error ? error.message : String(error);\n120:     return { applied: false, reason: `failed to apply edge: ${message}` };\n121:   }\n122: }\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Cross-Skill Edges Apply Patch\n// ───────────────────────────────────────────────────────────────\n// Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n\nimport { readFile, writeFile } from 'node:fs/promises';\nimport { basename, resolve, sep } from 'node:path';\nimport type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. APPLY EDGE\n// ───────────────────────────────────────────────────────────────\n\nconst PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n\nfunction deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n  return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n}\n\nfunction readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Cross-Skill Edges Apply Patch\n// ───────────────────────────────────────────────────────────────\n// Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n\nimport { readFile, writeFile } from 'node:fs/promises';\nimport { basename, resolve, sep } from 'node:path';\nimport type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. APPLY EDGE\n// ───────────────────────────────────────────────────────────────\n\nconst PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n\nfunction deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n  return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n}\n\nfunction readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {\n  const value = edge.source_kind;\n  if (value === 'automated' || value === 'manual' || value === 'trusted') {\n    return value;\n  }\n  return null;\n}\n\nfunction buildAutomatedReason(candidate: InboundEnhanceCandidate): string {\n  return candidate.rules.map(r => `${r.rule}:${r.contribution.toFixed(2)}`).join(' + ');\n}\n\n/**\n * Validate that the source path is a graph-metadata.json file under the trusted skills root.\n * Prevents path traversal in apply mode.\n */\nfunction isPathWithin(candidatePath: string, trustedRoot: string): boolean {\n  const resolvedCandidate = resolve(candidatePath);\n  const resolvedRoot = resolve(trustedRoot);\n  const rootWithSep = resolvedRoot.endsWith(sep) ? resolvedRoot : resolvedRoot + sep;\n  return resolvedCandidate.startsWith(rootWithSep) && basename(resolvedCandidate) === 'graph-metadata.json';\n}\n\n/**\n * Apply an enhance edge to the source skill's graph-metadata.json.\n * Idempotent for automated writes and protects manually maintained provenance.\n *\n * @param candidate - The candidate to apply\n * @param skillsRoot - Optional trusted workspace root. When provided, candidate.sourcePath\n *                    MUST resolve under this root and have basename 'graph-metadata.json'.\n * This guards against path traversal in apply mode.\n */\nexport async function applyEnhanceEdge(\n  candidate: InboundEnhanceCandidate,\n  skillsRoot?: string,\n  writeIntent: EdgeWriteIntent = 'automated',\n): Promise<{ applied: boolean; reason: string }> {\n  if (!candidate.applyable) {\n    return { applied: false, reason: `not applyable: ${candidate.blockers.join('; ')}` };\n  }\n\n  if (skillsRoot && !isPathWithin(candidate.sourcePath, skillsRoot)) {\n    return {\n      applied: false,\n      reason: `path-boundary violation: ${candidate.sourcePath} not under ${skillsRoot}`,\n    };\n  }\n\n  try {\n    const raw = await readFile(candidate.sourcePath, 'utf-8');\n    const parsed = JSON.parse(raw);\n\n    if (!parsed.edges) {\n      parsed.edges = {};\n    }\n    if (!parsed.edges.enhances) {\n      parsed.edges.enhances = [];\n    }\n\n    const enhances: Array<Record<string, unknown>> = parsed.edges.enhances;\n    const sourceKind = deriveSourceKind(writeIntent);\n    const existingEdge = enhances.find(e => e.target === candidate.targetSkillId);\n\n    if (existingEdge && writeIntent === 'automated') {\n      const existingSourceKind = readSourceKind(existingEdge);\n      if (existingSourceKind && PROTECTED_SOURCE_KINDS.has(existingSourceKind)) {\n        return { applied: false, reason: 'edge already exists: manual provenance protected' };\n      }\n      return { applied: false, reason: 'edge already exists' };\n    }\n\n    if (existingEdge) {\n      existingEdge.weight = candidate.weight;\n      existingEdge.context = candidate.context;\n      existingEdge.source_kind = sourceKind;\n      await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n      return { applied: true, reason: 'edge updated by trusted maintainer' };\n    }\n\n    const newEdge = {\n      target: candidate.targetSkillId,\n      weight: candidate.weight,\n      context: candidate.context,\n      source_kind: sourceKind,\n    };\n\n    if (writeIntent === 'automated') {\n      Object.assign(newEdge, {\n        auto_added_at: new Date().toISOString(),\n        auto_added_reason: buildAutomatedReason(candidate),\n      });\n    }\n\n    enhances.push(newEdge);\n    parsed.edges.enhances = enhances;\n\n    await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n    return { applied: true, reason: `edge added with ${sourceKind} provenance` };\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    return { applied: false, reason: `failed to apply edge: ${message}` };\n  }\n}","lineStart":1,"lineEnd":122,"totalLines":122,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","time":{"start":1781129304762,"end":1781129304768}},"metadata":{"openai":{"itemId":"fc_03a7269519c32c84016a29e058825c81919700c11a95ebbde1"}},"id":"prt_eb3945ab8001LN261Sbw0fXQpb","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3942f76001MikAc8rxVzXCKv"}}
{"type":"tool_use","timestamp":1781129304773,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_X8kkRwOYtuyCRnRK99rKdVhD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/bfs-traversal.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/bfs-traversal.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Skill Graph BFS Traversal\n3: // -------------------------------------------------------------------\n4: \n5: export const MAX_SKILL_GRAPH_TRAVERSAL_DEPTH = 8;\n6: \n7: /** Edge-plus-node relation yielded by a skill graph adjacency reader. */\n8: export interface SkillGraphTraversalRelation<TNode, TEdge> {\n9:   readonly nodeId: string;\n10:   readonly node: TNode;\n11:   readonly edge: TEdge;\n12: }\n13: \n14: /** Queue state surfaced to traversal callbacks. */\n15: export interface SkillGraphTraversalState<TEdge> {\n16:   readonly nodeIds: readonly string[];\n17:   readonly edges: readonly TEdge[];\n18:   readonly depth: number;\n19: }\n20: \n21: /** Matched path returned by early-stop traversals. */\n22: export interface SkillGraphTraversalMatch<TEdge> {\n23:   readonly nodeIds: readonly string[];\n24:   readonly edges: readonly TEdge[];\n25: }\n26: \n27: /** Options for hop-capped advisor skill graph traversal. */\n28: export interface SkillGraphBfsOptions<TNode, TEdge> {\n29:   readonly rootId: string;\n30:   readonly maxDepth: number;\n31:   readonly readRelations: (nodeId: string) => readonly SkillGraphTraversalRelation<TNode, TEdge>[];\n32:   readonly onRelation?: (\n33:     relation: SkillGraphTraversalRelation<TNode, TEdge>,\n34:     state: SkillGraphTraversalState<TEdge>,\n35:   ) => void;\n36:   readonly shouldStop?: (\n37:     relation: SkillGraphTraversalRelation<TNode, TEdge>,\n38:     nextState: SkillGraphTraversalState<TEdge>,\n39:   ) => boolean;\n40: }\n41: \n42: /** Result metadata for advisor skill graph BFS callers. */\n43: export interface SkillGraphBfsResult<TEdge> {\n44:   readonly match: SkillGraphTraversalMatch<TEdge> | null;\n45:   readonly visited: ReadonlySet<string>;\n46:   readonly truncated: boolean;\n47: }\n48: \n49: /** Clamp traversal depth to the advisor's bounded traversal policy. */\n50: export function clampSkillGraphTraversalDepth(depth: number, fallback: number = 1): number {\n51:   return Number.isFinite(depth)\n52:     ? Math.max(0, Math.min(Math.trunc(depth), MAX_SKILL_GRAPH_TRAVERSAL_DEPTH))\n53:     : fallback;\n54: }\n55: \n56: /** Run breadth-first traversal with shared visited and depth-cap semantics. */\n57: export function runSkillGraphBfs<TNode, TEdge>(\n58:   options: SkillGraphBfsOptions<TNode, TEdge>,\n59: ): SkillGraphBfsResult<TEdge> {\n60:   const maxDepth = clampSkillGraphTraversalDepth(options.maxDepth, 0);\n61:   const visited = new Set<string>([options.rootId]);\n62:   const queue: SkillGraphTraversalState<TEdge>[] = [{\n63:     nodeIds: [options.rootId],\n64:     edges: [],\n65:     depth: 0,\n66:   }];\n67:   let truncated = false;\n68: \n69:   for (let queueIndex = 0; queueIndex < queue.length; queueIndex += 1) {\n70:     const current = queue[queueIndex];\n71:     if (!current) {\n72:       continue;\n73:     }\n74:     if (current.depth >= maxDepth) {\n75:       truncated = true;\n76:       continue;\n77:     }\n78: \n79:     const currentId = current.nodeIds[current.nodeIds.length - 1];\n80:     if (!currentId) {\n81:       continue;\n82:     }\n83: \n84:     for (const relation of options.readRelations(currentId)) {\n85:       options.onRelation?.(relation, current);\n86:       if (visited.has(relation.nodeId)) {\n87:         continue;\n88:       }\n89: \n90:       const nextState: SkillGraphTraversalState<TEdge> = {\n91:         nodeIds: [...current.nodeIds, relation.nodeId],\n92:         edges: [...current.edges, relation.edge],\n93:         depth: current.depth + 1,\n94:       };\n95:       if (options.shouldStop?.(relation, nextState)) {\n96:         return { match: nextState, visited, truncated };\n97:       }\n98: \n99:       visited.add(relation.nodeId);\n100:       queue.push(nextState);\n101:     }\n102:   }\n103: \n104:   return { match: null, visited, truncated };\n105: }\n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Skill Graph BFS Traversal\n// -------------------------------------------------------------------\n\nexport const MAX_SKILL_GRAPH_TRAVERSAL_DEPTH = 8;\n\n/** Edge-plus-node relation yielded by a skill graph adjacency reader. */\nexport interface SkillGraphTraversalRelation<TNode, TEdge> {\n  readonly nodeId: string;\n  readonly node: TNode;\n  readonly edge: TEdge;\n}\n\n/** Queue state surfaced to traversal callbacks. */\nexport interface SkillGraphTraversalState<TEdge> {\n  readonly nodeIds: readonly string[];\n  readonly edges: readonly TEdge[];\n  readonly depth: number;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/bfs-traversal.ts","text":"// -------------------------------------------------------------------\n// MODULE: Skill Graph BFS Traversal\n// -------------------------------------------------------------------\n\nexport const MAX_SKILL_GRAPH_TRAVERSAL_DEPTH = 8;\n\n/** Edge-plus-node relation yielded by a skill graph adjacency reader. */\nexport interface SkillGraphTraversalRelation<TNode, TEdge> {\n  readonly nodeId: string;\n  readonly node: TNode;\n  readonly edge: TEdge;\n}\n\n/** Queue state surfaced to traversal callbacks. */\nexport interface SkillGraphTraversalState<TEdge> {\n  readonly nodeIds: readonly string[];\n  readonly edges: readonly TEdge[];\n  readonly depth: number;\n}\n\n/** Matched path returned by early-stop traversals. */\nexport interface SkillGraphTraversalMatch<TEdge> {\n  readonly nodeIds: readonly string[];\n  readonly edges: readonly TEdge[];\n}\n\n/** Options for hop-capped advisor skill graph traversal. */\nexport interface SkillGraphBfsOptions<TNode, TEdge> {\n  readonly rootId: string;\n  readonly maxDepth: number;\n  readonly readRelations: (nodeId: string) => readonly SkillGraphTraversalRelation<TNode, TEdge>[];\n  readonly onRelation?: (\n    relation: SkillGraphTraversalRelation<TNode, TEdge>,\n    state: SkillGraphTraversalState<TEdge>,\n  ) => void;\n  readonly shouldStop?: (\n    relation: SkillGraphTraversalRelation<TNode, TEdge>,\n    nextState: SkillGraphTraversalState<TEdge>,\n  ) => boolean;\n}\n\n/** Result metadata for advisor skill graph BFS callers. */\nexport interface SkillGraphBfsResult<TEdge> {\n  readonly match: SkillGraphTraversalMatch<TEdge> | null;\n  readonly visited: ReadonlySet<string>;\n  readonly truncated: boolean;\n}\n\n/** Clamp traversal depth to the advisor's bounded traversal policy. */\nexport function clampSkillGraphTraversalDepth(depth: number, fallback: number = 1): number {\n  return Number.isFinite(depth)\n    ? Math.max(0, Math.min(Math.trunc(depth), MAX_SKILL_GRAPH_TRAVERSAL_DEPTH))\n    : fallback;\n}\n\n/** Run breadth-first traversal with shared visited and depth-cap semantics. */\nexport function runSkillGraphBfs<TNode, TEdge>(\n  options: SkillGraphBfsOptions<TNode, TEdge>,\n): SkillGraphBfsResult<TEdge> {\n  const maxDepth = clampSkillGraphTraversalDepth(options.maxDepth, 0);\n  const visited = new Set<string>([options.rootId]);\n  const queue: SkillGraphTraversalState<TEdge>[] = [{\n    nodeIds: [options.rootId],\n    edges: [],\n    depth: 0,\n  }];\n  let truncated = false;\n\n  for (let queueIndex = 0; queueIndex < queue.length; queueIndex += 1) {\n    const current = queue[queueIndex];\n    if (!current) {\n      continue;\n    }\n    if (current.depth >= maxDepth) {\n      truncated = true;\n      continue;\n    }\n\n    const currentId = current.nodeIds[current.nodeIds.length - 1];\n    if (!currentId) {\n      continue;\n    }\n\n    for (const relation of options.readRelations(currentId)) {\n      options.onRelation?.(relation, current);\n      if (visited.has(relation.nodeId)) {\n        continue;\n      }\n\n      const nextState: SkillGraphTraversalState<TEdge> = {\n        nodeIds: [...current.nodeIds, relation.nodeId],\n        edges: [...current.edges, relation.edge],\n        depth: current.depth + 1,\n      };\n      if (options.shouldStop?.(relation, nextState)) {\n        return { match: nextState, visited, truncated };\n      }\n\n      visited.add(relation.nodeId);\n      queue.push(nextState);\n    }\n  }\n\n  return { match: null, visited, truncated };\n}","lineStart":1,"lineEnd":105,"totalLines":105,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/bfs-traversal.ts","time":{"start":1781129304765,"end":1781129304772}},"metadata":{"openai":{"itemId":"fc_03a7269519c32c84016a29e05882a481918fcf9cd40cee8775"}},"id":"prt_eb3945abb001tvr2uY8fBdHJqG","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3942f76001MikAc8rxVzXCKv"}}
{"type":"step_finish","timestamp":1781129305049,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"id":"prt_eb3945bd7001gnQQQY7Hhs19mC","reason":"tool-calls","snapshot":"28d70b8e76efcbf0241e9f3730d7dd9b7c51fc2e","messageID":"msg_eb3942f76001MikAc8rxVzXCKv","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","type":"step-finish","tokens":{"total":182248,"input":2100,"output":393,"reasoning":43,"cache":{"write":0,"read":179712}},"cost":0}}
{"type":"step_start","timestamp":1781129307642,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"id":"prt_eb39465f9001BH6BRqi7tap4IK","messageID":"msg_eb3945caf001r2qWEQVRh3E137","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","snapshot":"28d70b8e76efcbf0241e9f3730d7dd9b7c51fc2e","type":"step-start"}}
{"type":"tool_use","timestamp":1781129312506,"sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","part":{"type":"tool","tool":"read","callID":"call_GjlpkOlZPMrGTvFB5CVjzjkk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Skill Graph Queries\n3: // ───────────────────────────────────────────────────────────────\n4: // Query helpers for the SQLite-backed skill graph.\n5: // Uses prepared statements and mirrors the structural graph query patterns.\n6: \n7: import type Database from 'better-sqlite3';\n8: import {\n9:   getDb,\n10:   rowToSkillEdge,\n11:   rowToSkillNode,\n12:   type SkillEdge,\n13:   type SkillFamily,\n14:   type SkillNode,\n15: } from './skill-graph-db.js';\n16: import {\n17:   clampSkillGraphTraversalDepth,\n18:   MAX_SKILL_GRAPH_TRAVERSAL_DEPTH,\n19:   runSkillGraphBfs,\n20:   type SkillGraphTraversalRelation,\n21: } from './bfs-traversal.js';\n22: \n23: // ───────────────────────────────────────────────────────────────\n24: // 1. TYPES\n25: // ───────────────────────────────────────────────────────────────\n26: \n27: export interface SkillGraphRelation {\n28:   node: SkillNode;\n29:   edge: SkillEdge;\n30:   direction: 'inbound' | 'outbound';\n31: }\n32: \n33: export interface SkillGraphPath {\n34:   nodes: SkillNode[];\n35:   edges: SkillEdge[];\n36: }\n37: \n38: export interface SkillGraphHub {\n39:   node: SkillNode;\n40:   inboundCount: number;\n41: }\n42: \n43: export interface SkillGraphSubgraph {\n44:   nodes: SkillNode[];\n45:   edges: SkillEdge[];\n46: }\n47: \n48: interface PreparedStatements {\n49:   nodeById: Database.Statement;\n50:   dependsOn: Database.Statement;\n51:   dependents: Database.Statement;\n52:   enhances: Database.Statement;\n53:   enhancedBy: Database.Statement;\n54:   familyMembers: Database.Statement;\n55:   conflictsOutgoing: Database.Statement;\n56:   conflictsIncoming: Database.Statement;\n57:   outgoingAny: Database.Statement;\n58:   incomingAny: Database.Statement;\n59:   hubSkills: Database.Statement;\n60:   orphans: Database.Statement;\n61: }\n62: \n63: interface RelationRow {\n64:   edge_id: number;\n65:   edge_source_id: string;\n66:   edge_target_id: string;\n67:   edge_type: SkillEdge['edgeType'];\n68:   edge_weight: number;\n69:   edge_context: string;\n70:   node_id: string;\n71:   node_family: SkillNode['family'];\n72:   node_category: string;\n73:   node_schema_version: 1 | 2;\n74:   node_domains: string | null;\n75:   node_intent_signals: string | null;\n76:   node_derived: string | null;\n77:   node_source_path: string;\n78:   node_content_hash: string;\n79:   node_indexed_at: string | null;\n80: }\n81: \n82: const preparedStatementCache = new WeakMap<Database.Database, PreparedStatements>();\n83: \n84: // ───────────────────────────────────────────────────────────────\n85: // 2. PREPARED STATEMENTS\n86: // ───────────────────────────────────────────────────────────────\n87: \n88: function getPreparedStatements(database: Database.Database = getDb()): PreparedStatements {\n89:   const cached = preparedStatementCache.get(database);\n90:   if (cached) {\n91:     return cached;\n92:   }\n93: \n94:   const selectRelationColumns = `\n95:     e.id AS edge_id,\n96:     e.source_id AS edge_source_id,\n97:     e.target_id AS edge_target_id,\n98:     e.edge_type AS edge_type,\n99:     e.weight AS edge_weight,\n100:     e.context AS edge_context,\n101:     n.id AS node_id,\n102:     n.family AS node_family,\n103:     n.category AS node_category,\n104:     n.schema_version AS node_schema_version,\n105:     n.domains AS node_domains,\n106:     n.intent_signals AS node_intent_signals,\n107:     n.derived AS node_derived,\n108:     n.source_path AS node_source_path,\n109:     n.content_hash AS node_content_hash,\n110:     n.indexed_at AS node_indexed_at\n111:   `;\n112: \n113:   const statements: PreparedStatements = {\n114:     nodeById: database.prepare('SELECT * FROM skill_nodes WHERE id = ?'),\n115:     dependsOn: database.prepare(`\n116:       SELECT ${selectRelationColumns}\n117:       FROM skill_edges e\n118:       INNER JOIN skill_nodes n ON n.id = e.target_id\n119:       WHERE e.source_id = ? AND e.edge_type = 'depends_on'\n120:       ORDER BY e.weight DESC, n.id ASC\n121:     `),\n122:     dependents: database.prepare(`\n123:       SELECT ${selectRelationColumns}\n124:       FROM skill_edges e\n125:       INNER JOIN skill_nodes n ON n.id = e.source_id\n126:       WHERE e.target_id = ? AND e.edge_type = 'depends_on'\n127:       ORDER BY e.weight DESC, n.id ASC\n128:     `),\n129:     enhances: database.prepare(`\n130:       SELECT ${selectRelationColumns}\n131:       FROM skill_edges e\n132:       INNER JOIN skill_nodes n ON n.id = e.target_id\n133:       WHERE e.source_id = ? AND e.edge_type = 'enhances'\n134:       ORDER BY e.weight DESC, n.id ASC\n135:     `),\n136:     enhancedBy: database.prepare(`\n137:       SELECT ${selectRelationColumns}\n138:       FROM skill_edges e\n139:       INNER JOIN skill_nodes n ON n.id = e.source_id\n140:       WHERE e.target_id = ? AND e.edge_type = 'enhances'\n141:       ORDER BY e.weight DESC, n.id ASC\n142:     `),\n143:     familyMembers: database.prepare(`\n144:       SELECT *\n145:       FROM skill_nodes\n146:       WHERE family = ?\n147:       ORDER BY id ASC\n148:     `),\n149:     conflictsOutgoing: database.prepare(`\n150:       SELECT ${selectRelationColumns}\n151:       FROM skill_edges e\n152:       INNER JOIN skill_nodes n ON n.id = e.target_id\n153:       WHERE e.source_id = ? AND e.edge_type = 'conflicts_with'\n154:       ORDER BY e.weight DESC, n.id ASC\n155:     `),\n156:     conflictsIncoming: database.prepare(`\n157:       SELECT ${selectRelationColumns}\n158:       FROM skill_edges e\n159:       INNER JOIN skill_nodes n ON n.id = e.source_id\n160:       WHERE e.target_id = ? AND e.edge_type = 'conflicts_with'\n161:       ORDER BY e.weight DESC, n.id ASC\n162:     `),\n163:     outgoingAny: database.prepare(`\n164:       SELECT ${selectRelationColumns}\n165:       FROM skill_edges e\n166:       INNER JOIN skill_nodes n ON n.id = e.target_id\n167:       WHERE e.source_id = ?\n168:       ORDER BY e.weight DESC, n.id ASC\n169:     `),\n170:     incomingAny: database.prepare(`\n171:       SELECT ${selectRelationColumns}\n172:       FROM skill_edges e\n173:       INNER JOIN skill_nodes n ON n.id = e.source_id\n174:       WHERE e.target_id = ?\n175:       ORDER BY e.weight DESC, n.id ASC\n176:     `),\n177:     hubSkills: database.prepare(`\n178:       SELECT\n179:         n.*,\n180:         COUNT(e.id) AS inbound_count\n181:       FROM skill_nodes n\n182:       INNER JOIN skill_edges e ON e.target_id = n.id\n183:       GROUP BY n.id\n184:       HAVING COUNT(e.id) >= ?\n185:       ORDER BY inbound_count DESC, n.id ASC\n186:     `),\n187:     orphans: database.prepare(`\n188:       SELECT n.*\n189:       FROM skill_nodes n\n190:       LEFT JOIN skill_edges outgoing ON outgoing.source_id = n.id\n191:       LEFT JOIN skill_edges incoming ON incoming.target_id = n.id\n192:       WHERE outgoing.id IS NULL AND incoming.id IS NULL\n193:       ORDER BY n.id ASC\n194:     `),\n195:   };\n196: \n197:   preparedStatementCache.set(database, statements);\n198:   return statements;\n199: }\n200: \n201: // ───────────────────────────────────────────────────────────────\n202: // 3. HELPERS\n203: // ───────────────────────────────────────────────────────────────\n204: \n205: function relationRowToResult(row: RelationRow, direction: 'inbound' | 'outbound'): SkillGraphRelation {\n206:   return {\n207:     direction,\n208:     edge: rowToSkillEdge({\n209:       id: row.edge_id,\n210:       source_id: row.edge_source_id,\n211:       target_id: row.edge_target_id,\n212:       edge_type: row.edge_type,\n213:       weight: row.edge_weight,\n214:       context: row.edge_context,\n215:     }),\n216:     node: rowToSkillNode({\n217:       id: row.node_id,\n218:       family: row.node_family,\n219:       category: row.node_category,\n220:       schema_version: row.node_schema_version,\n221:       domains: row.node_domains,\n222:       intent_signals: row.node_intent_signals,\n223:       derived: row.node_derived,\n224:       source_path: row.node_source_path,\n225:       content_hash: row.node_content_hash,\n226:       indexed_at: row.node_indexed_at,\n227:     }),\n228:   };\n229: }\n230: \n231: function getNodeById(skillId: string, database: Database.Database = getDb()): SkillNode | null {\n232:   const row = getPreparedStatements(database).nodeById.get(skillId) as Record<string, unknown> | undefined;\n233:   return row ? rowToSkillNode(row) : null;\n234: }\n235: \n236: function dedupeRelations(relations: SkillGraphRelation[]): SkillGraphRelation[] {\n237:   const deduped = new Map<string, SkillGraphRelation>();\n238:   for (const relation of relations) {\n239:     const key = relation.edge.id !== undefined\n240:       ? String(relation.edge.id)\n241:       : `${relation.edge.sourceId}:${relation.edge.edgeType}:${relation.edge.targetId}`;\n242:     if (!deduped.has(key)) {\n243:       deduped.set(key, relation);\n244:     }\n245:   }\n246:   return [...deduped.values()];\n247: }\n248: \n249: function edgeKey(edge: SkillEdge): string {\n250:   return edge.id !== undefined\n251:     ? String(edge.id)\n252:     : `${edge.sourceId}:${edge.edgeType}:${edge.targetId}`;\n253: }\n254: \n255: function relationToTraversalRelation(\n256:   relation: SkillGraphRelation,\n257: ): SkillGraphTraversalRelation<SkillNode, SkillEdge> {\n258:   return {\n259:     nodeId: relation.node.id,\n260:     node: relation.node,\n261:     edge: relation.edge,\n262:   };\n263: }\n264: \n265: // ───────────────────────────────────────────────────────────────\n266: // 4. QUERIES\n267: // ───────────────────────────────────────────────────────────────\n268: \n269: /** Get the skills a given skill depends on. */\n270: export function dependsOn(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n271:   const rows = getPreparedStatements(database).dependsOn.all(skillId) as RelationRow[];\n272:   return rows.map((row) => relationRowToResult(row, 'outbound'));\n273: }\n274: \n275: /** Get the skills that depend on a given skill. */\n276: export function dependents(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n277:   const rows = getPreparedStatements(database).dependents.all(skillId) as RelationRow[];\n278:   return rows.map((row) => relationRowToResult(row, 'inbound'));\n279: }\n280: \n281: /** Get the skills enhanced by a given skill. */\n282: export function enhances(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n283:   const rows = getPreparedStatements(database).enhances.all(skillId) as RelationRow[];\n284:   return rows.map((row) => relationRowToResult(row, 'outbound'));\n285: }\n286: \n287: /** Get the skills that enhance a given skill. */\n288: export function enhancedBy(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n289:   const rows = getPreparedStatements(database).enhancedBy.all(skillId) as RelationRow[];\n290:   return rows.map((row) => relationRowToResult(row, 'inbound'));\n291: }\n292: \n293: /** Get all skill nodes for a given family. */\n294: export function familyMembers(family: SkillFamily, database: Database.Database = getDb()): SkillNode[] {\n295:   const rows = getPreparedStatements(database).familyMembers.all(family) as Record<string, unknown>[];\n296:   return rows.map(rowToSkillNode);\n297: }\n298: \n299: /** Get all conflict relationships for a given skill, regardless of direction. */\n300: export function conflicts(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n301:   const statements = getPreparedStatements(database);\n302:   const outgoingRows = statements.conflictsOutgoing.all(skillId) as RelationRow[];\n303:   const incomingRows = statements.conflictsIncoming.all(skillId) as RelationRow[];\n304: \n305:   return dedupeRelations([\n306:     ...outgoingRows.map((row) => relationRowToResult(row, 'outbound')),\n307:     ...incomingRows.map((row) => relationRowToResult(row, 'inbound')),\n308:   ]);\n309: }\n310: \n311: /** Find the shortest outbound relationship path between two skills. */\n312: export function transitivePath(\n313:   fromSkillId: string,\n314:   toSkillId: string,\n315:   database: Database.Database = getDb(),\n316: ): SkillGraphPath | null {\n317:   const startNode = getNodeById(fromSkillId, database);\n318:   const targetNode = getNodeById(toSkillId, database);\n319:   if (!startNode || !targetNode) {\n320:     return null;\n321:   }\n322: \n323:   if (fromSkillId === toSkillId) {\n324:     return { nodes: [startNode], edges: [] };\n325:   }\n326: \n327:   const statements = getPreparedStatements(database);\n328:   const nodeCache = new Map<string, SkillNode>([\n329:     [startNode.id, startNode],\n330:     [targetNode.id, targetNode],\n331:   ]);\n332:   const traversal = runSkillGraphBfs({\n333:     rootId: fromSkillId,\n334:     maxDepth: MAX_SKILL_GRAPH_TRAVERSAL_DEPTH,\n335:     readRelations: (currentId) => {\n336:       const rows = statements.outgoingAny.all(currentId) as RelationRow[];\n337:       return rows.map((row) => relationToTraversalRelation(relationRowToResult(row, 'outbound')));\n338:     },\n339:     onRelation: (relation) => {\n340:       nodeCache.set(relation.nodeId, relation.node);\n341:     },\n342:     shouldStop: (relation) => relation.nodeId === toSkillId,\n343:   });\n344: \n345:   if (traversal.match) {\n346:     return {\n347:       nodes: traversal.match.nodeIds.map((nodeId) => nodeCache.get(nodeId) ?? getNodeById(nodeId, database)).filter(\n348:         (node): node is SkillNode => node !== null,\n349:       ),\n350:       edges: [...traversal.match.edges],\n351:     };\n352:   }\n353: \n354:   return null;\n355: }\n356: \n357: /** Get skills with at least the requested inbound edge count. */\n358: export function hubSkills(minInbound: number = 1, database: Database.Database = getDb()): SkillGraphHub[] {\n359:   const safeMinInbound = Number.isFinite(minInbound) ? Math.max(1, Math.trunc(minInbound)) : 1;\n360:   const rows = getPreparedStatements(database).hubSkills.all(safeMinInbound) as Array<Record<string, unknown> & {\n361:     inbound_count: number;\n362:   }>;\n363: \n364:   return rows.map((row) => ({\n365:     node: rowToSkillNode(row),\n366:     inboundCount: row.inbound_count,\n367:   }));\n368: }\n369: \n370: /** Get skills that have no inbound or outbound edges. */\n371: export function orphans(database: Database.Database = getDb()): SkillNode[] {\n372:   const rows = getPreparedStatements(database).orphans.all() as Record<string, unknown>[];\n373:   return rows.map(rowToSkillNode);\n374: }\n375: \n376: /** Get an N-hop neighborhood around a skill, traversing inbound and outbound relationships. */\n377: export function subgraph(\n378:   skillId: string,\n379:   depth: number = 1,\n380:   database: Database.Database = getDb(),\n381: ): SkillGraphSubgraph {\n382:   const root = getNodeById(skillId, database);\n383:   if (!root) {\n384:     return { nodes: [], edges: [] };\n385:   }\n386: \n387:   const safeDepth = clampSkillGraphTraversalDepth(depth, 1);\n388:   const statements = getPreparedStatements(database);\n389:   const nodes = new Map<string, SkillNode>([[root.id, root]]);\n390:   const edges = new Map<string, SkillEdge>();\n391: \n392:   runSkillGraphBfs({\n393:     rootId: root.id,\n394:     maxDepth: safeDepth,\n395:     readRelations: (currentId) => {\n396:       const outgoingRows = statements.outgoingAny.all(currentId) as RelationRow[];\n397:       const incomingRows = statements.incomingAny.all(currentId) as RelationRow[];\n398:       return [\n399:         ...outgoingRows.map((row) => relationToTraversalRelation(relationRowToResult(row, 'outbound'))),\n400:         ...incomingRows.map((row) => relationToTraversalRelation(relationRowToResult(row, 'inbound'))),\n401:       ];\n402:     },\n403:     onRelation: (relation) => {\n404:       nodes.set(relation.nodeId, relation.node);\n405:       edges.set(edgeKey(relation.edge), relation.edge);\n406:     },\n407:   });\n408: \n409:   return {\n410:     nodes: [...nodes.values()].sort((left, right) => left.id.localeCompare(right.id)),\n411:     edges: [...edges.values()].sort((left, right) => {\n412:       const sourceOrder = left.sourceId.localeCompare(right.sourceId);\n413:       if (sourceOrder !== 0) return sourceOrder;\n414:       const typeOrder = left.edgeType.localeCompare(right.edgeType);\n415:       if (typeOrder !== 0) return typeOrder;\n416:       return left.targetId.localeCompare(right.targetId);\n417:     }),\n418:   };\n419: }\n\n(End of file - total 419 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Skill Graph Queries\n// ───────────────────────────────────────────────────────────────\n// Query helpers for the SQLite-backed skill graph.\n// Uses prepared statements and mirrors the structural graph query patterns.\n\nimport type Database from 'better-sqlite3';\nimport {\n  getDb,\n  rowToSkillEdge,\n  rowToSkillNode,\n  type SkillEdge,\n  type SkillFamily,\n  type SkillNode,\n} from './skill-graph-db.js';\nimport {\n  clampSkillGraphTraversalDepth,\n  MAX_SKILL_GRAPH_TRAVERSAL_DEPTH,\n  runSkillGraphBfs,\n  type SkillGraphTraversalRelation,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Skill Graph Queries\n// ───────────────────────────────────────────────────────────────\n// Query helpers for the SQLite-backed skill graph.\n// Uses prepared statements and mirrors the structural graph query patterns.\n\nimport type Database from 'better-sqlite3';\nimport {\n  getDb,\n  rowToSkillEdge,\n  rowToSkillNode,\n  type SkillEdge,\n  type SkillFamily,\n  type SkillNode,\n} from './skill-graph-db.js';\nimport {\n  clampSkillGraphTraversalDepth,\n  MAX_SKILL_GRAPH_TRAVERSAL_DEPTH,\n  runSkillGraphBfs,\n  type SkillGraphTraversalRelation,\n} from './bfs-traversal.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\nexport interface SkillGraphRelation {\n  node: SkillNode;\n  edge: SkillEdge;\n  direction: 'inbound' | 'outbound';\n}\n\nexport interface SkillGraphPath {\n  nodes: SkillNode[];\n  edges: SkillEdge[];\n}\n\nexport interface SkillGraphHub {\n  node: SkillNode;\n  inboundCount: number;\n}\n\nexport interface SkillGraphSubgraph {\n  nodes: SkillNode[];\n  edges: SkillEdge[];\n}\n\ninterface PreparedStatements {\n  nodeById: Database.Statement;\n  dependsOn: Database.Statement;\n  dependents: Database.Statement;\n  enhances: Database.Statement;\n  enhancedBy: Database.Statement;\n  familyMembers: Database.Statement;\n  conflictsOutgoing: Database.Statement;\n  conflictsIncoming: Database.Statement;\n  outgoingAny: Database.Statement;\n  incomingAny: Database.Statement;\n  hubSkills: Database.Statement;\n  orphans: Database.Statement;\n}\n\ninterface RelationRow {\n  edge_id: number;\n  edge_source_id: string;\n  edge_target_id: string;\n  edge_type: SkillEdge['edgeType'];\n  edge_weight: number;\n  edge_context: string;\n  node_id: string;\n  node_family: SkillNode['family'];\n  node_category: string;\n  node_schema_version: 1 | 2;\n  node_domains: string | null;\n  node_intent_signals: string | null;\n  node_derived: string | null;\n  node_source_path: string;\n  node_content_hash: string;\n  node_indexed_at: string | null;\n}\n\nconst preparedStatementCache = new WeakMap<Database.Database, PreparedStatements>();\n\n// ───────────────────────────────────────────────────────────────\n// 2. PREPARED STATEMENTS\n// ───────────────────────────────────────────────────────────────\n\nfunction getPreparedStatements(database: Database.Database = getDb()): PreparedStatements {\n  const cached = preparedStatementCache.get(database);\n  if (cached) {\n    return cached;\n  }\n\n  const selectRelationColumns = `\n    e.id AS edge_id,\n    e.source_id AS edge_source_id,\n    e.target_id AS edge_target_id,\n    e.edge_type AS edge_type,\n    e.weight AS edge_weight,\n    e.context AS edge_context,\n    n.id AS node_id,\n    n.family AS node_family,\n    n.category AS node_category,\n    n.schema_version AS node_schema_version,\n    n.domains AS node_domains,\n    n.intent_signals AS node_intent_signals,\n    n.derived AS node_derived,\n    n.source_path AS node_source_path,\n    n.content_hash AS node_content_hash,\n    n.indexed_at AS node_indexed_at\n  `;\n\n  const statements: PreparedStatements = {\n    nodeById: database.prepare('SELECT * FROM skill_nodes WHERE id = ?'),\n    dependsOn: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.target_id\n      WHERE e.source_id = ? AND e.edge_type = 'depends_on'\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    dependents: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.source_id\n      WHERE e.target_id = ? AND e.edge_type = 'depends_on'\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    enhances: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.target_id\n      WHERE e.source_id = ? AND e.edge_type = 'enhances'\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    enhancedBy: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.source_id\n      WHERE e.target_id = ? AND e.edge_type = 'enhances'\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    familyMembers: database.prepare(`\n      SELECT *\n      FROM skill_nodes\n      WHERE family = ?\n      ORDER BY id ASC\n    `),\n    conflictsOutgoing: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.target_id\n      WHERE e.source_id = ? AND e.edge_type = 'conflicts_with'\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    conflictsIncoming: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.source_id\n      WHERE e.target_id = ? AND e.edge_type = 'conflicts_with'\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    outgoingAny: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.target_id\n      WHERE e.source_id = ?\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    incomingAny: database.prepare(`\n      SELECT ${selectRelationColumns}\n      FROM skill_edges e\n      INNER JOIN skill_nodes n ON n.id = e.source_id\n      WHERE e.target_id = ?\n      ORDER BY e.weight DESC, n.id ASC\n    `),\n    hubSkills: database.prepare(`\n      SELECT\n        n.*,\n        COUNT(e.id) AS inbound_count\n      FROM skill_nodes n\n      INNER JOIN skill_edges e ON e.target_id = n.id\n      GROUP BY n.id\n      HAVING COUNT(e.id) >= ?\n      ORDER BY inbound_count DESC, n.id ASC\n    `),\n    orphans: database.prepare(`\n      SELECT n.*\n      FROM skill_nodes n\n      LEFT JOIN skill_edges outgoing ON outgoing.source_id = n.id\n      LEFT JOIN skill_edges incoming ON incoming.target_id = n.id\n      WHERE outgoing.id IS NULL AND incoming.id IS NULL\n      ORDER BY n.id ASC\n    `),\n  };\n\n  preparedStatementCache.set(database, statements);\n  return statements;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ───────────────────────────────────────────────────────────────\n\nfunction relationRowToResult(row: RelationRow, direction: 'inbound' | 'outbound'): SkillGraphRelation {\n  return {\n    direction,\n    edge: rowToSkillEdge({\n      id: row.edge_id,\n      source_id: row.edge_source_id,\n      target_id: row.edge_target_id,\n      edge_type: row.edge_type,\n      weight: row.edge_weight,\n      context: row.edge_context,\n    }),\n    node: rowToSkillNode({\n      id: row.node_id,\n      family: row.node_family,\n      category: row.node_category,\n      schema_version: row.node_schema_version,\n      domains: row.node_domains,\n      intent_signals: row.node_intent_signals,\n      derived: row.node_derived,\n      source_path: row.node_source_path,\n      content_hash: row.node_content_hash,\n      indexed_at: row.node_indexed_at,\n    }),\n  };\n}\n\nfunction getNodeById(skillId: string, database: Database.Database = getDb()): SkillNode | null {\n  const row = getPreparedStatements(database).nodeById.get(skillId) as Record<string, unknown> | undefined;\n  return row ? rowToSkillNode(row) : null;\n}\n\nfunction dedupeRelations(relations: SkillGraphRelation[]): SkillGraphRelation[] {\n  const deduped = new Map<string, SkillGraphRelation>();\n  for (const relation of relations) {\n    const key = relation.edge.id !== undefined\n      ? String(relation.edge.id)\n      : `${relation.edge.sourceId}:${relation.edge.edgeType}:${relation.edge.targetId}`;\n    if (!deduped.has(key)) {\n      deduped.set(key, relation);\n    }\n  }\n  return [...deduped.values()];\n}\n\nfunction edgeKey(edge: SkillEdge): string {\n  return edge.id !== undefined\n    ? String(edge.id)\n    : `${edge.sourceId}:${edge.edgeType}:${edge.targetId}`;\n}\n\nfunction relationToTraversalRelation(\n  relation: SkillGraphRelation,\n): SkillGraphTraversalRelation<SkillNode, SkillEdge> {\n  return {\n    nodeId: relation.node.id,\n    node: relation.node,\n    edge: relation.edge,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. QUERIES\n// ───────────────────────────────────────────────────────────────\n\n/** Get the skills a given skill depends on. */\nexport function dependsOn(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n  const rows = getPreparedStatements(database).dependsOn.all(skillId) as RelationRow[];\n  return rows.map((row) => relationRowToResult(row, 'outbound'));\n}\n\n/** Get the skills that depend on a given skill. */\nexport function dependents(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n  const rows = getPreparedStatements(database).dependents.all(skillId) as RelationRow[];\n  return rows.map((row) => relationRowToResult(row, 'inbound'));\n}\n\n/** Get the skills enhanced by a given skill. */\nexport function enhances(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n  const rows = getPreparedStatements(database).enhances.all(skillId) as RelationRow[];\n  return rows.map((row) => relationRowToResult(row, 'outbound'));\n}\n\n/** Get the skills that enhance a given skill. */\nexport function enhancedBy(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n  const rows = getPreparedStatements(database).enhancedBy.all(skillId) as RelationRow[];\n  return rows.map((row) => relationRowToResult(row, 'inbound'));\n}\n\n/** Get all skill nodes for a given family. */\nexport function familyMembers(family: SkillFamily, database: Database.Database = getDb()): SkillNode[] {\n  const rows = getPreparedStatements(database).familyMembers.all(family) as Record<string, unknown>[];\n  return rows.map(rowToSkillNode);\n}\n\n/** Get all conflict relationships for a given skill, regardless of direction. */\nexport function conflicts(skillId: string, database: Database.Database = getDb()): SkillGraphRelation[] {\n  const statements = getPreparedStatements(database);\n  const outgoingRows = statements.conflictsOutgoing.all(skillId) as RelationRow[];\n  const incomingRows = statements.conflictsIncoming.all(skillId) as RelationRow[];\n\n  return dedupeRelations([\n    ...outgoingRows.map((row) => relationRowToResult(row, 'outbound')),\n    ...incomingRows.map((row) => relationRowToResult(row, 'inbound')),\n  ]);\n}\n\n/** Find the shortest outbound relationship path between two skills. */\nexport function transitivePath(\n  fromSkillId: string,\n  toSkillId: string,\n  database: Database.Database = getDb(),\n): SkillGraphPath | null {\n  const startNode = getNodeById(fromSkillId, database);\n  const targetNode = getNodeById(toSkillId, database);\n  if (!startNode || !targetNode) {\n    return null;\n  }\n\n  if (fromSkillId === toSkillId) {\n    return { nodes: [startNode], edges: [] };\n  }\n\n  const statements = getPreparedStatements(database);\n  const nodeCache = new Map<string, SkillNode>([\n    [startNode.id, startNode],\n    [targetNode.id, targetNode],\n  ]);\n  const traversal = runSkillGraphBfs({\n    rootId: fromSkillId,\n    maxDepth: MAX_SKILL_GRAPH_TRAVERSAL_DEPTH,\n    readRelations: (currentId) => {\n      const rows = statements.outgoingAny.all(currentId) as RelationRow[];\n      return rows.map((row) => relationToTraversalRelation(relationRowToResult(row, 'outbound')));\n    },\n    onRelation: (relation) => {\n      nodeCache.set(relation.nodeId, relation.node);\n    },\n    shouldStop: (relation) => relation.nodeId === toSkillId,\n  });\n\n  if (traversal.match) {\n    return {\n      nodes: traversal.match.nodeIds.map((nodeId) => nodeCache.get(nodeId) ?? getNodeById(nodeId, database)).filter(\n        (node): node is SkillNode => node !== null,\n      ),\n      edges: [...traversal.match.edges],\n    };\n  }\n\n  return null;\n}\n\n/** Get skills with at least the requested inbound edge count. */\nexport function hubSkills(minInbound: number = 1, database: Database.Database = getDb()): SkillGraphHub[] {\n  const safeMinInbound = Number.isFinite(minInbound) ? Math.max(1, Math.trunc(minInbound)) : 1;\n  const rows = getPreparedStatements(database).hubSkills.all(safeMinInbound) as Array<Record<string, unknown> & {\n    inbound_count: number;\n  }>;\n\n  return rows.map((row) => ({\n    node: rowToSkillNode(row),\n    inboundCount: row.inbound_count,\n  }));\n}\n\n/** Get skills that have no inbound or outbound edges. */\nexport function orphans(database: Database.Database = getDb()): SkillNode[] {\n  const rows = getPreparedStatements(database).orphans.all() as Record<string, unknown>[];\n  return rows.map(rowToSkillNode);\n}\n\n/** Get an N-hop neighborhood around a skill, traversing inbound and outbound relationships. */\nexport function subgraph(\n  skillId: string,\n  depth: number = 1,\n  database: Database.Database = getDb(),\n): SkillGraphSubgraph {\n  const root = getNodeById(skillId, database);\n  if (!root) {\n    return { nodes: [], edges: [] };\n  }\n\n  const safeDepth = clampSkillGraphTraversalDepth(depth, 1);\n  const statements = getPreparedStatements(database);\n  const nodes = new Map<string, SkillNode>([[root.id, root]]);\n  const edges = new Map<string, SkillEdge>();\n\n  runSkillGraphBfs({\n    rootId: root.id,\n    maxDepth: safeDepth,\n    readRelations: (currentId) => {\n      const outgoingRows = statements.outgoingAny.all(currentId) as RelationRow[];\n      const incomingRows = statements.incomingAny.all(currentId) as RelationRow[];\n      return [\n        ...outgoingRows.map((row) => relationToTraversalRelation(relationRowToResult(row, 'outbound'))),\n        ...incomingRows.map((row) => relationToTraversalRelation(relationRowToResult(row, 'inbound'))),\n      ];\n    },\n    onRelation: (relation) => {\n      nodes.set(relation.nodeId, relation.node);\n      edges.set(edgeKey(relation.edge), relation.edge);\n    },\n  });\n\n  return {\n    nodes: [...nodes.values()].sort((left, right) => left.id.localeCompare(right.id)),\n    edges: [...edges.values()].sort((left, right) => {\n      const sourceOrder = left.sourceId.localeCompare(right.sourceId);\n      if (sourceOrder !== 0) return sourceOrder;\n      const typeOrder = left.edgeType.localeCompare(right.edgeType);\n      if (typeOrder !== 0) return typeOrder;\n      return left.targetId.localeCompare(right.targetId);\n    }),\n  };\n}","lineStart":1,"lineEnd":419,"totalLines":419,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts","time":{"start":1781129312497,"end":1781129312504}},"metadata":{"openai":{"itemId":"fc_017f7718dd41b889016a29e05f26088191ba34db33351bc3ad"}},"id":"prt_eb39473b6001aU3UL71HzorKUl","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb3945caf001r2qWEQVRh3E137"}}
