9:       {\n90:         \"name\": \"tasks.md\",\n91:         \"kind\": \"doc\",\n92:         \"path\": \"tasks.md\",\n93:         \"source\": \"derived\"\n94:       },\n95:       {\n96:         \"name\": \"implementation-summary.md\",\n97:         \"kind\": \"doc\",\n98:         \"path\": \"implementation-summary.md\",\n99:         \"source\": \"derived\"\n100:       },\n101:       {\n102:         \"name\": \"canonical-fingerprint.ts\",\n103:         \"kind\": \"code\",\n104:         \"path\": \"mcp_server/lib/storage/canonical-fingerprint.ts\",\n105:         \"source\": \"derived\"\n106:       },\n107:       {\n108:         \"name\": \"deploy-mcp.sh\",\n109:         \"kind\": \"script\",\n110:         \"path\": \"scripts/deploy-mcp.sh\",\n111:         \"source\": \"derived\"\n112:       },\n113:       {\n114:         \"name\": \"Feature Specification\",\n115:         \"kind\": \"proper_noun\",\n116:         \"path\": \"spec.md\",\n117:         \"source\": \"derived\"\n118:       },\n119:       {\n120:         \"name\": \"Packed In\",\n121:         \"kind\": \"proper_noun\",\n122:         \"path\": \"spec.md\",\n123:         \"source\": \"derived\"\n124:       },\n125:       {\n126:         \"name\": \"Field Weights\",\n127:         \"kind\": \"proper_noun\",\n128:         \"path\": \"spec.md\",\n129:         \"source\": \"derived\"\n130:       },\n131:       {\n132:         \"name\": \"Parent Spec\",\n133:         \"kind\": \"proper_noun\",\n134:         \"path\": \"spec.md\",\n135:         \"source\": \"derived\"\n136:       },\n137:       {\n138:         \"name\": \"Parent Packet\",\n139:         \"kind\": \"proper_noun\",\n140:         \"path\": \"spec.md\",\n141:         \"source\": \"derived\"\n142:       },\n143:       {\n144:         \"name\": \"Problem Statement The\",\n145:         \"kind\": \"proper_noun\",\n146:         \"path\": \"spec.md\",\n147:         \"source\": \"derived\"\n148:       },\n149:       {\n150:         \"name\": \"Implementation Plan\",\n151:         \"kind\": \"proper_noun\",\n152:         \"path\": \"plan.md\",\n153:         \"source\": \"derived\"\n154:       },\n155:       {\n156:         \"name\": \"Technical Context\",\n157:         \"kind\": \"proper_noun\",\n158:         \"path\": \"plan.md\",\n159:         \"source\": \"derived\"\n160:       },\n161:       {\n162:         \"name\": \"Spec Kit Memory\",\n163:         \"kind\": \"proper_noun\",\n164:         \"path\": \"plan.md\",\n165:         \"source\": \"derived\"\n166:       },\n167:       {\n168:         \"name\": \"Overview Implement\",\n169:         \"kind\": \"proper_noun\",\n170:         \"path\": \"plan.md\",\n171:         \"source\": \"derived\"\n172:       },\n173:       {\n174:         \"name\": \"Task Format\",\n175:         \"kind\": \"proper_noun\",\n176:         \"path\": \"tasks.md\",\n177:         \"source\": \"derived\"\n178:       },\n179:       {\n180:         \"name\": \"Task Notation\",\n181:         \"kind\": \"proper_noun\",\n182:         \"path\": \"tasks.md\",\n183:         \"source\": \"derived\"\n184:       },\n185:       {\n186:         \"name\": \"Completion Criteria\",\n187:         \"kind\": \"proper_noun\",\n188:         \"path\": \"tasks.md\",\n189:         \"source\": \"derived\"\n190:       },\n191:       {\n192:         \"name\": \"measured\",\n193:         \"kind\": \"key_phrase\",\n194:         \"path\": \"tasks.md\",\n195:         \"source\": \"derived\"\n196:       }\n197:     ],\n198:     \"causal_summary\": \"The in-memory BM25 fallback channel has two latent defects at the measured corpus (10,245 docs, 69.2 MB indexed text). First, the legacy engine stores full token arrays per document (bm25-index.ts:197-207), an estimated 300-600 MB of heap if it ever warms the full corpus - a standing RAM hazard for the daemon whenever memory_fts is absent. Second, it flattens title/content/triggers/path into one field (bm25-index.ts:151-172), silently losing the title-x10 weighting that the FTS5 channel applies via bm25(memory_fts,10,5,2,1) - the engine slot packed-inmemory is reserved but unimplemented (bm25-index.ts:53,487-493) and BM25_FIELD_WEIGHTS is exported but unused there (:73-78). Source evidence: z_future/sqlite-to-turso 004 - gap-alternatives.md section 3.\",\n199:     \"created_at\": \"2026-06-10T17:48:33Z\",\n200:     \"last_save_at\": \"2026-06-10T19:22:14.995Z\",\n201:     \"save_lineage\": \"graph_only\",\n202:     \"last_accessed_at\": null,\n203:     \"source_docs\": [\n204:       \"spec.md\",\n205:       \"plan.md\",\n206:       \"tasks.md\",\n207:       \"implementation-summary.md\"\n208:     ],\n209:     \"last_active_child_id\": null,\n210:     \"last_active_at\": null\n211:   }\n212: }\n\n(End of file - total 212 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/014-packed-bm25-field-weights\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/014-packed-bm25-field-weights\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"packed bm25\",\n      \"in-memory bm25 engine\",\n      \"bm25f field weights\",\n      \"lexical fallback channel\",\n      \"014-packed-bm25-field-weights plan\",\n      \"014-packed-bm25-field-weights tasks\",\n      \"014-packed-bm25-field-weights summary\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/014-packed-bm25-field-weights/graph-metadata.json","text":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/014-packed-bm25-field-weights\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/014-packed-bm25-field-weights\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"packed bm25\",\n      \"in-memory bm25 engine\",\n      \"bm25f field weights\",\n      \"lexical fallback channel\",\n      \"014-packed-bm25-field-weights plan\",\n      \"014-packed-bm25-field-weights tasks\",\n      \"014-packed-bm25-field-weights summary\"\n    ],\n    \"key_topics\": [\n      \"packed\",\n      \"bm25\",\n      \"in-memory\",\n      \"engine\",\n      \"bm25f\",\n      \"field\",\n      \"weights\",\n      \"lexical\",\n      \"fallback\",\n      \"channel\",\n      \"014-packed-bm25-field-weights\",\n      \"plan\"\n    ],\n    \"importance_tier\": \"normal\",\n    \"status\": \"shipped\",\n    \"key_files\": [\n      \".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts\",\n      \".opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts\",\n      \".opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts\",\n      \".opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts\",\n      \"spec.md\",\n      \"plan.md\",\n      \"tasks.md\",\n      \"implementation-summary.md\",\n      \"mcp_server/lib/storage/canonical-fingerprint.ts\",\n      \"scripts/deploy-mcp.sh\",\n      \"mcp_server/lib/search/bm25-index.ts\",\n      \"mcp_server/lib/eval/bm25-baseline.ts\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"bm25-index.ts\",\n        \"kind\": \"code\",\n        \"path\": \".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"bm25-baseline.ts\",\n        \"kind\": \"code\",\n        \"path\": \".opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"bm25-packed-fixture.ts\",\n        \"kind\": \"code\",\n        \"path\": \".opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"bm25-packed-inmemory.vitest.ts\",\n        \"kind\": \"test\",\n        \"path\": \".opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"spec.md\",\n        \"kind\": \"doc\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"plan.md\",\n        \"kind\": \"doc\",\n        \"path\": \"plan.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"tasks.md\",\n        \"kind\": \"doc\",\n        \"path\": \"tasks.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"implementation-summary.md\",\n        \"kind\": \"doc\",\n        \"path\": \"implementation-summary.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"canonical-fingerprint.ts\",\n        \"kind\": \"code\",\n        \"path\": \"mcp_server/lib/storage/canonical-fingerprint.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"deploy-mcp.sh\",\n        \"kind\": \"script\",\n        \"path\": \"scripts/deploy-mcp.sh\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Feature Specification\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Packed In\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Field Weights\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Parent Spec\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Parent Packet\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Problem Statement The\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Implementation Plan\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"plan.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Technical Context\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"plan.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Spec Kit Memory\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"plan.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Overview Implement\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"plan.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Task Format\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"tasks.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Task Notation\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"tasks.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Completion Criteria\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"tasks.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"measured\",\n        \"kind\": \"key_phrase\",\n        \"path\": \"tasks.md\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"The in-memory BM25 fallback channel has two latent defects at the measured corpus (10,245 docs, 69.2 MB indexed text). First, the legacy engine stores full token arrays per document (bm25-index.ts:197-207), an estimated 300-600 MB of heap if it ever warms the full corpus - a standing RAM hazard for the daemon whenever memory_fts is absent. Second, it flattens title/content/triggers/path into one field (bm25-index.ts:151-172), silently losing the title-x10 weighting that the FTS5 channel applies via bm25(memory_fts,10,5,2,1) - the engine slot packed-inmemory is reserved but unimplemented (bm25-index.ts:53,487-493) and BM25_FIELD_WEIGHTS is exported but unused there (:73-78). Source evidence: z_future/sqlite-to-turso 004 - gap-alternatives.md section 3.\",\n    \"created_at\": \"2026-06-10T17:48:33Z\",\n    \"last_save_at\": \"2026-06-10T19:22:14.995Z\",\n    \"save_lineage\": \"graph_only\",\n    \"last_accessed_at\": null,\n    \"source_docs\": [\n      \"spec.md\",\n      \"plan.md\",\n      \"tasks.md\",\n      \"implementation-summary.md\"\n    ],\n    \"last_active_child_id\": null,\n    \"last_active_at\": null\n  }\n}","lineStart":1,"lineEnd":212,"totalLines":212,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/014-packed-bm25-field-weights/graph-metadata.json","time":{"start":1781151904163,"end":1781151904168}},"metadata":{"openai":{"itemId":"fc_054d49bd1d417cb3016a2a38a00888819194ea5ea7c786827c"}},"id":"prt_eb4ed319e001a0vyOTAH3dQlqu","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed07c2001uKsHtl9IPqzsPe"}}
{"type":"step_finish","timestamp":1781151904544,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"id":"prt_eb4ed331e00176Rfw6hoeYfgZB","reason":"tool-calls","snapshot":"d099332a90a08a3dac28e7f95b5ef70267b29ccb","messageID":"msg_eb4ed07c2001uKsHtl9IPqzsPe","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","type":"step-finish","tokens":{"total":85194,"input":1263,"output":429,"reasoning":46,"cache":{"write":0,"read":83456}},"cost":0}}
{"type":"step_start","timestamp":1781151906169,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"id":"prt_eb4ed3978001ZZ2vJRl2G07s9O","messageID":"msg_eb4ed3406001QSvMXtyij9Xo5H","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","snapshot":"d099332a90a08a3dac28e7f95b5ef70267b29ccb","type":"step-start"}}
{"type":"text","timestamp":1781151913685,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"id":"prt_eb4ed45ec001f8dTKisUTkIWIH","messageID":"msg_eb4ed3406001QSvMXtyij9Xo5H","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","type":"text","text":"Phase init inputs are clear: this is a Level 1 shipped spec for the packed BM25 fallback, with four implementation/test files named by the summary. I’m reviewing those files read-only, then will synthesize iteration artifacts into the lineage directory.","time":{"start":1781151909356,"end":1781151913684},"metadata":{"openai":{"itemId":"msg_0e1f5eb53c6bb8d3016a2a38a55b9481919c32a008c0db4910","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781151913740,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"type":"tool","tool":"read","callID":"call_mqDUEIcGvNsKL3LPstAHIVMf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25 Index\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: import { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\n6: import {\n7:   normalizeLexicalQueryTokens,\n8:   sanitizeFTS5Query,\n9:   sanitizeQueryTokens,\n10:   simpleStem,\n11:   STOP_WORDS,\n12:   tokenize,\n13: } from './lexical-normalizer.js';\n14: import type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\n15: import { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n16: \n17: // ───────────────────────────────────────────────────────────────\n18: // 1. INTERFACES\n19: \n20: // ───────────────────────────────────────────────────────────────\n21: interface BM25SearchResult {\n22:   id: string;\n23:   /**\n24:    * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n25:    * Higher = better lexical match. Not directly comparable to vector similarity\n26:    * scores; use min-max normalization or RRF when combining with other methods.\n27:    */\n28:   score: number;\n29: }\n30: \n31: interface BM25Stats {\n32:   documentCount: number;\n33:   termCount: number;\n34:   avgDocLength: number;\n35: }\n36: \n37: interface BM25DocumentSource {\n38:   title?: string | null;\n39:   content_text?: string | null;\n40:   trigger_phrases?: string | string[] | null;\n41:   file_path?: string | null;\n42: }\n43: \n44: /* ───────────────────────────────────────────────────────────────\n45:    1B. CONSTANTS & FEATURE FLAG\n46:    ──────────────────────────────────────────────────────────────── */\n47: \n48: const DEFAULT_K1 = 1.2;\n49: const DEFAULT_B = 0.75;\n50: const BM25_WARMUP_BATCH_SIZE = 250;\n51: const BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n52: const BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\n53: const BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\n54: type Bm25Engine = typeof BM25_ENGINE_VALUES[number];\n55: type InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\n56: type BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n57: \n58: const BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\n59: const BM25_ENGINE_LOGGED = new Set<string>();\n60: \n61: /**\n62:  * Field weight multipliers for weighted BM25 scoring.\n63:  * When indexing a document composed of multiple fields, multiply\n64:  * each field's token scores by the appropriate weight before\n65:  * accumulating the total document score.\n66:  *\n67:  * These weights are shared by the FTS5 path and the packed in-memory\n68:  * fallback so both lexical lanes preserve the same field-priority intent.\n69:  *\n70:  * title:           10.0 — exact title matches are the strongest signal\n71:  * trigger_phrases:  5.0 — curated keywords next most important\n72:  * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n73:  * body:             1.0 — baseline weight for full body / content_text\n74:  */\n75: const BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n76: \n77: const BM25_FIELD_WEIGHTS: Record<string, number> = {\n78:   title: BM25_FTS5_WEIGHTS[0],\n79:   trigger_phrases: BM25_FTS5_WEIGHTS[1],\n80:   content_generic: BM25_FTS5_WEIGHTS[2],\n81:   body: BM25_FTS5_WEIGHTS[3],\n82: };\n83: \n84: type BM25FieldWeights = Record<BM25FieldName, number>;\n85: \n86: interface BM25DocumentFields {\n87:   title?: string | null;\n88:   trigger_phrases?: string | string[] | null;\n89:   content_generic?: string | null;\n90:   body?: string | null;\n91: }\n92: \n93: interface BM25SearchOptions {\n94:   fieldWeights?: Partial<BM25FieldWeights>;\n95: }\n96: \n97: interface LegacyDocumentRecord {\n98:   tokens: string[];\n99:   termFreq: Map<string, number>;\n100: }\n101: \n102: interface PackedTermFrequency {\n103:   total: number;\n104:   fields: Record<BM25FieldName, number>;\n105: }\n106: \n107: interface PackedDocumentRecord {\n108:   numericId: number;\n109:   id: string;\n110:   length: number;\n111:   terms: string[];\n112: }\n113: \n114: interface PackedPostingMutable {\n115:   docIds: number[];\n116:   totalTfs: number[];\n117:   titleTfs: number[];\n118:   triggerTfs: number[];\n119:   pathTfs: number[];\n120:   bodyTfs: number[];\n121: }\n122: \n123: interface PackedPostingList {\n124:   docIds: Uint32Array;\n125:   totalTfs: Uint32Array;\n126:   titleTfs: Uint32Array;\n127:   triggerTfs: Uint32Array;\n128:   pathTfs: Uint32Array;\n129:   bodyTfs: Uint32Array;\n130: }\n131: \n132: /**\n133:  * Check whether the in-memory BM25 index is enabled.\n134:  *\n135:  * @returns `true` when BM25 indexing/search is enabled for the current process.\n136:  * @example\n137:  * ```ts\n138:  * if (isBm25Enabled()) {\n139:  *   getIndex();\n140:  * }\n141:  * ```\n142:  */\n143: function isBm25Enabled(): boolean {\n144:   const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n145:   if (!value) return true; // enabled by default\n146:   if (BM25_DISABLED_VALUES.has(value)) return false;\n147:   return BM25_ENABLED_VALUES.has(value);\n148: }\n149: \n150: // ───────────────────────────────────────────────────────────────\n151: // 2. HELPERS\n152: \n153: // ───────────────────────────────────────────────────────────────\n154: /**\n155:  * Count token frequency occurrences for BM25 scoring.\n156:  *\n157:  * @param tokens - Normalized tokens produced by {@link tokenize}.\n158:  * @returns A frequency map keyed by token text.\n159:  * @example\n160:  * ```ts\n161:  * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n162:  * // 2\n163:  * ```\n164:  */\n165: function getTermFrequencies(tokens: string[]): Map<string, number> {\n166:   const freq = new Map<string, number>();\n167:   for (const token of tokens) {\n168:     freq.set(token, (freq.get(token) || 0) + 1);\n169:   }\n170:   return freq;\n171: }\n172: \n173: function visitBm25Tokens(text: string, visitor: (token: string) => void): void {\n174:   if (!text || typeof text !== 'string') return;\n175: \n176:   let token = '';\n177:   const flush = () => {\n178:     if (token.length >= 2 && !STOP_WORDS.has(token)) {\n179:       visitor(simpleStem(token));\n180:     }\n181:     token = '';\n182:   };\n183: \n184:   for (let i = 0; i < text.length; i += 1) {\n185:     const code = text.charCodeAt(i);\n186:     if (code >= 65 && code <= 90) {\n187:       token += String.fromCharCode(code + 32);\n188:     } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n189:       token += text[i];\n190:     } else if (token.length > 0) {\n191:       flush();\n192:     }\n193:   }\n194: \n195:   if (token.length > 0) {\n196:     flush();\n197:   }\n198: }\n199: \n200: function normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n201:   if (Array.isArray(triggerPhrases)) {\n202:     return triggerPhrases\n203:       .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n204:       .join(' ');\n205:   }\n206: \n207:   if (typeof triggerPhrases !== 'string') {\n208:     return '';\n209:   }\n210: \n211:   const trimmed = triggerPhrases.trim();\n212:   if (!trimmed) {\n213:     return '';\n214:   }\n215: \n216:   try {\n217:     const parsed = JSON.parse(trimmed) as unknown;\n218:     if (Array.isArray(parsed)) {\n219:       return parsed\n220:         .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n221:         .join(' ');\n222:     }\n223:   } catch {\n224:     // Fall back to raw string when the database value is not JSON.\n225:   }\n226: \n227:   return trimmed;\n228: }\n229: \n230: function defaultPackedTermFrequency(): PackedTermFrequency {\n231:   return {\n232:     total: 0,\n233:     fields: {\n234:       title: 0,\n235:       trigger_phrases: 0,\n236:       content_generic: 0,\n237:       body: 0,\n238:     },\n239:   };\n240: }\n241: \n242: function resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n243:   return {\n244:     title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n245:     trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n246:     content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n247:     body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n248:   };\n249: }\n250: \n251: function emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n252:   const key = `${engine}:${reason}`;\n253:   if (BM25_ENGINE_LOGGED.has(key)) {\n254:     return;\n255:   }\n256:   BM25_ENGINE_LOGGED.add(key);\n257:   console.info(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n258: }\n259: \n260: function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n261:   const configured = resolveBm25Engine();\n262:   if (configured === 'legacy-inmemory') {\n263:     emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n264:     return 'legacy-inmemory';\n265:   }\n266: \n267:   if (configured === 'sqlite') {\n268:     emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n269:     return 'packed-inmemory';\n270:   }\n271: \n272:   if (configured === 'packed-inmemory') {\n273:     emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n274:     return 'packed-inmemory';\n275:   }\n276: \n277:   emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n278:   return 'packed-inmemory';\n279: }\n280: \n281: function buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n282:   return {\n283:     title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n284:     body: typeof row.content_text === 'string' && row.content_text.trim()\n285:       ? normalizeContentForBM25(row.content_text)\n286:       : '',\n287:     trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n288:     content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n289:   };\n290: }\n291: \n292: function buildBm25DocumentText(row: BM25DocumentSource): string {\n293:   const textParts: string[] = [];\n294: \n295:   if (typeof row.title === 'string' && row.title.trim()) {\n296:     textParts.push(row.title.trim());\n297:   }\n298: \n299:   if (typeof row.content_text === 'string' && row.content_text.trim()) {\n300:     textParts.push(normalizeContentForBM25(row.content_text));\n301:   }\n302: \n303:   const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n304:   if (triggerPhrases) {\n305:     textParts.push(triggerPhrases);\n306:   }\n307: \n308:   if (typeof row.file_path === 'string' && row.file_path.trim()) {\n309:     textParts.push(row.file_path.trim());\n310:   }\n311: \n312:   return textParts.join(' ').trim();\n313: }\n314: \n315: // ───────────────────────────────────────────────────────────────\n316: // 3. BM25 INDEX CLASS\n317: \n318: // ───────────────────────────────────────────────────────────────\n319: class BM25Index {\n320:   private k1: number;\n321:   private b: number;\n322:   private engine: InMemoryBm25Engine;\n323:   private documents: Map<string, LegacyDocumentRecord>;\n324:   private packedDocuments: Map<string, PackedDocumentRecord>;\n325:   private packedDocIds: string[];\n326:   private packedDocNumbersById: Map<string, number>;\n327:   private packedMutablePostings: Map<string, PackedPostingMutable>;\n328:   private packedPostings: Map<string, PackedPostingList>;\n329:   private packedDirtyTerms: Set<string>;\n330:   private documentFreq: Map<string, number>;\n331:   private totalDocLength: number;\n332:   private warmupHandle: ReturnType<typeof setTimeout> | null;\n333:   private warmupGeneration: number;\n334: \n335:   constructor(\n336:     k1: number = DEFAULT_K1,\n337:     b: number = DEFAULT_B,\n338:     engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n339:   ) {\n340:     this.k1 = k1;\n341:     this.b = b;\n342:     this.engine = engine;\n343:     this.documents = new Map();\n344:     this.packedDocuments = new Map();\n345:     this.packedDocIds = [];\n346:     this.packedDocNumbersById = new Map();\n347:     this.packedMutablePostings = new Map();\n348:     this.packedPostings = new Map();\n349:     this.packedDirtyTerms = new Set();\n350:     this.documentFreq = new Map();\n351:     this.totalDocLength = 0;\n352:     this.warmupHandle = null;\n353:     this.warmupGeneration = 0;\n354:   }\n355: \n356:   addDocument(id: string, text: string): void {\n357:     if (this.engine === 'packed-inmemory') {\n358:       this.addDocumentFields(id, { body: text });\n359:       return;\n360:     }\n361: \n362:     const tokens = tokenize(text);\n363:     const termFreq = getTermFrequencies(tokens);\n364: \n365:     if (this.documents.has(id)) {\n366:       this.removeDocument(id);\n367:     }\n368: \n369:     this.documents.set(id, { tokens, termFreq });\n370:     this.totalDocLength += tokens.length;\n371: \n372:     // Update document frequency\n373:     for (const term of termFreq.keys()) {\n374:       this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n375:     }\n376:   }\n377: \n378:   addDocumentFields(id: string, fields: BM25DocumentFields): void {\n379:     if (this.engine === 'legacy-inmemory') {\n380:       this.addDocument(id, this.joinDocumentFields(fields));\n381:       return;\n382:     }\n383: \n384:     if (this.packedDocuments.has(id)) {\n385:       this.removeDocument(id);\n386:     }\n387: \n388:     const termFreq = this.getPackedTermFrequencies(fields);\n389:     const length = Array.from(termFreq.values()).reduce((sum, freq) => sum + freq.total, 0);\n390:     if (length === 0) {\n391:       return;\n392:     }\n393: \n394:     const numericId = this.getPackedNumericId(id);\n395:     this.packedDocuments.set(id, { numericId, id, length, terms: Array.from(termFreq.keys()) });\n396:     this.totalDocLength += length;\n397: \n398:     for (const [term, frequency] of termFreq) {\n399:       const postings = this.ensurePackedMutablePostings(term);\n400:       this.setPackedMutablePosting(postings, numericId, frequency);\n401:       this.packedDirtyTerms.add(term);\n402:       this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n403:     }\n404:   }\n405: \n406:   removeDocument(id: string): boolean {\n407:     if (this.engine === 'packed-inmemory') {\n408:       return this.removePackedDocument(id);\n409:     }\n410: \n411:     const doc = this.documents.get(id);\n412:     if (!doc) return false;\n413: \n414:     this.totalDocLength -= doc.tokens.length;\n415: \n416:     for (const term of doc.termFreq.keys()) {\n417:       const count = this.documentFreq.get(term) || 0;\n418:       if (count <= 1) {\n419:         this.documentFreq.delete(term);\n420:       } else {\n421:         this.documentFreq.set(term, count - 1);\n422:       }\n423:     }\n424: \n425:     this.documents.delete(id);\n426:     return true;\n427:   }\n428: \n429:   calculateIdf(term: string): number {\n430:     const n = this.getDocumentCount();\n431:     const df = this.documentFreq.get(term) || 0;\n432:     if (df === 0 || n === 0) return 0;\n433:     return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n434:   }\n435: \n436:   calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n437:     if (this.engine === 'packed-inmemory') {\n438:       return this.calculatePackedScore(queryTokens, docId, options);\n439:     }\n440: \n441:     const doc = this.documents.get(docId);\n442:     if (!doc) return 0;\n443: \n444:     const avgDl = this.getAverageDocumentLength();\n445:     const dl = doc.tokens.length;\n446: \n447:     let score = 0;\n448:     for (const term of queryTokens) {\n449:       const tf = doc.termFreq.get(term) || 0;\n450:       if (tf === 0) continue;\n451: \n452:       const idf = this.calculateIdf(term);\n453:       const numerator = tf * (this.k1 + 1);\n454:       const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n455:       score += idf * (numerator / denominator);\n456:     }\n457: \n458:     return score;\n459:   }\n460: \n461:   search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n462:     const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n463:     if (queryTokens.length === 0) return [];\n464: \n465:     if (this.engine === 'packed-inmemory') {\n466:       return this.searchPacked(queryTokens, limit, options);\n467:     }\n468: \n469:     const results: BM25SearchResult[] = [];\n470: \n471:     for (const [id] of this.documents) {\n472:       const score = this.calculateScore(queryTokens, id);\n473:       if (score > 0) {\n474:         results.push({ id, score });\n475:       }\n476:     }\n477: \n478:     return results\n479:       .sort((a, b) => b.score - a.score)\n480:       .slice(0, limit);\n481:   }\n482: \n483:   getStats(): BM25Stats {\n484:     return {\n485:       documentCount: this.getDocumentCount(),\n486:       termCount: this.documentFreq.size,\n487:       avgDocLength: this.getAverageDocumentLength(),\n488:     };\n489:   }\n490: \n491:   clear(): void {\n492:     this.cancelWarmup();\n493:     this.documents.clear();\n494:     this.packedDocuments.clear();\n495:     this.packedDocIds = [];\n496:     this.packedDocNumbersById.clear();\n497:     this.packedMutablePostings.clear();\n498:     this.packedPostings.clear();\n499:     this.packedDirtyTerms.clear();\n500:     this.documentFreq.clear();\n501:     this.totalDocLength = 0;\n502:   }\n503: \n504:   addDocuments(docs: Array<{ id: string; text: string }>): void {\n505:     for (const doc of docs) {\n506:       this.addDocument(doc.id, doc.text);\n507:     }\n508:   }\n509: \n510:   finalizePackedPostings(): void {\n511:     if (this.engine === 'legacy-inmemory') {\n512:       return;\n513:     }\n514: \n515:     for (const term of Array.from(this.packedDirtyTerms)) {\n516:       this.getPackedPosting(term);\n517:     }\n518:     this.packedMutablePostings.clear();\n519:   }\n520: \n521:   /**\n522:    * Incrementally synchronize changed rows from the database into the in-memory index.\n523:    */\n524:   syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n525:     const normalizedIds = Array.from(\n526:       new Set(\n527:         rowIds\n528:           .map((rowId) => Number(rowId))\n529:           .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n530:       )\n531:     );\n532: \n533:     if (normalizedIds.length === 0) {\n534:       return 0;\n535:     }\n536: \n537:     try {\n538:       const placeholders = normalizedIds.map(() => '?').join(', ');\n539:       const rows = (database.prepare(\n540:         `SELECT id, title, content_text, trigger_phrases, file_path\n541:          FROM memory_index\n542:          WHERE id IN (${placeholders})`\n543:       ) as Database.Statement).all(...normalizedIds) as Array<{\n544:         id: number;\n545:         title: string | null;\n546:         content_text: string | null;\n547:         trigger_phrases: string | null;\n548:         file_path: string | null;\n549:       }>;\n550: \n551:       const activeRowMap = new Map<number, typeof rows[number]>();\n552:       for (const row of rows) {\n553:         activeRowMap.set(row.id, row);\n554:       }\n555: \n556:       for (const rowId of normalizedIds) {\n557:         const row = activeRowMap.get(rowId);\n558:         if (!row) {\n559:           this.removeDocument(String(rowId));\n560:           continue;\n561:         }\n562: \n563:         const fields = buildBm25DocumentFields(row);\n564:         if (this.joinDocumentFields(fields).trim()) {\n565:           this.addDocumentFields(String(row.id), fields);\n566:         } else {\n567:           this.removeDocument(String(row.id));\n568:         }\n569:       }\n570: \n571:       return normalizedIds.length;\n572:     } catch (error: unknown) {\n573:       const msg = error instanceof Error ? error.message : String(error);\n574:       console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n575:       return 0;\n576:     }\n577:   }\n578: \n579:   /**\n580:    * Defer full startup warmup into batched row-ID syncs so process\n581:    * initialization is not blocked by a monolithic in-memory rebuild.\n582:    */\n583:   rebuildFromDatabase(database: Database.Database): number {\n584:     this.clear();\n585: \n586:     try {\n587:       const rows = (database.prepare(\n588:         `SELECT id\n589:          FROM memory_index\n590:          ORDER BY id`\n591:       ) as Database.Statement).all() as Array<{ id: number }>;\n592: \n593:       const pendingIds = rows.map((row) => row.id);\n594:       if (pendingIds.length === 0) {\n595:         return 0;\n596:       }\n597: \n598:       const warmupGeneration = ++this.warmupGeneration;\n599:       const processBatch = () => {\n600:         if (warmupGeneration !== this.warmupGeneration) {\n601:           return;\n602:         }\n603: \n604:         const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n605:         if (batchIds.length === 0) {\n606:           this.finalizePackedPostings();\n607:           this.warmupHandle = null;\n608:           return;\n609:         }\n610: \n611:         this.syncChangedRows(database, batchIds);\n612: \n613:         if (pendingIds.length > 0) {\n614:           this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n615:         } else {\n616:           this.warmupHandle = null;\n617:         }\n618:       };\n619: \n620:       this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n621:       return pendingIds.length;\n622:     } catch (error: unknown) {\n623:       const msg = error instanceof Error ? error.message : String(error);\n624:       console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n625:       return 0;\n626:     }\n627:   }\n628: \n629:   cancelWarmup(): void {\n630:     this.warmupGeneration += 1;\n631:     if (this.warmupHandle) {\n632:       clearRegisteredTimer(this.warmupHandle);\n633:       this.warmupHandle = null;\n634:     }\n635:   }\n636: \n637:   private getDocumentCount(): number {\n638:     return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n639:   }\n640: \n641:   private getAverageDocumentLength(): number {\n642:     const documentCount = this.getDocumentCount();\n643:     return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n644:   }\n645: \n646:   private joinDocumentFields(fields: BM25DocumentFields): string {\n647:     const parts: string[] = [];\n648:     for (const fieldName of BM25_FIELD_NAMES) {\n649:       const value = fields[fieldName];\n650:       if (Array.isArray(value)) {\n651:         parts.push(value.join(' '));\n652:       } else if (typeof value === 'string' && value.trim()) {\n653:         parts.push(value.trim());\n654:       }\n655:     }\n656:     return parts.join(' ').trim();\n657:   }\n658: \n659:   private getPackedNumericId(id: string): number {\n660:     const existing = this.packedDocNumbersById.get(id);\n661:     if (existing !== undefined) {\n662:       return existing;\n663:     }\n664: \n665:     const numericId = this.packedDocIds.length;\n666:     this.packedDocIds.push(id);\n667:     this.packedDocNumbersById.set(id, numericId);\n668:     return numericId;\n669:   }\n670: \n671:   private getPackedTermFrequencies(fields: BM25DocumentFields): Map<string, PackedTermFrequency> {\n672:     const termFreq = new Map<string, PackedTermFrequency>();\n673: \n674:     for (const fieldName of BM25_FIELD_NAMES) {\n675:       const rawValue = fields[fieldName];\n676:       const text = Array.isArray(rawValue) ? rawValue.join(' ') : (rawValue ?? '');\n677:       visitBm25Tokens(text, (token) => {\n678:         let frequency = termFreq.get(token);\n679:         if (!frequency) {\n680:           frequency = defaultPackedTermFrequency();\n681:           termFreq.set(token, frequency);\n682:         }\n683:         frequency.total += 1;\n684:         frequency.fields[fieldName] += 1;\n685:       });\n686:     }\n687: \n688:     return termFreq;\n689:   }\n690: \n691:   private removePackedDocument(id: string): boolean {\n692:     const doc = this.packedDocuments.get(id);\n693:     if (!doc) return false;\n694: \n695:     this.totalDocLength -= doc.length;\n696: \n697:     for (const term of doc.terms) {\n698:       const postings = this.ensurePackedMutablePostings(term);\n699:       this.deletePackedMutablePosting(postings, doc.numericId);\n700:       this.packedDirtyTerms.add(term);\n701: \n702:       const count = this.documentFreq.get(term) || 0;\n703:       if (count <= 1) {\n704:         this.documentFreq.delete(term);\n705:         this.packedMutablePostings.delete(term);\n706:         this.packedPostings.delete(term);\n707:       } else {\n708:         this.documentFreq.set(term, count - 1);\n709:       }\n710:     }\n711: \n712:     this.packedDocuments.delete(id);\n713:     return true;\n714:   }\n715: \n716:   private getPackedPosting(term: string): PackedPostingList | undefined {\n717:     if (!this.packedDirtyTerms.has(term)) {\n718:       return this.packedPostings.get(term);\n719:     }\n720: \n721:     const mutable = this.packedMutablePostings.get(term);\n722:     if (!mutable || mutable.docIds.length === 0) {\n723:       this.packedDirtyTerms.delete(term);\n724:       this.packedPostings.delete(term);\n725:       return undefined;\n726:     }\n727: \n728:     this.sortPackedMutablePosting(mutable);\n729: \n730:     const packed: PackedPostingList = {\n731:       docIds: Uint32Array.from(mutable.docIds),\n732:       totalTfs: Uint32Array.from(mutable.totalTfs),\n733:       titleTfs: Uint32Array.from(mutable.titleTfs),\n734:       triggerTfs: Uint32Array.from(mutable.triggerTfs),\n735:       pathTfs: Uint32Array.from(mutable.pathTfs),\n736:       bodyTfs: Uint32Array.from(mutable.bodyTfs),\n737:     };\n738:     this.packedPostings.set(term, packed);\n739:     this.packedDirtyTerms.delete(term);\n740:     return packed;\n741:   }\n742: \n743:   private ensurePackedMutablePostings(term: string): PackedPostingMutable {\n744:     const existing = this.packedMutablePostings.get(term);\n745:     if (existing) {\n746:       return existing;\n747:     }\n748: \n749:     const hydrated: PackedPostingMutable = {\n750:       docIds: [],\n751:       totalTfs: [],\n752:       titleTfs: [],\n753:       triggerTfs: [],\n754:       pathTfs: [],\n755:       bodyTfs: [],\n756:     };\n757:     const packed = this.packedPostings.get(term);\n758:     if (packed) {\n759:       for (let i = 0; i < packed.docIds.length; i += 1) {\n760:         hydrated.docIds.push(packed.docIds[i]);\n761:         hydrated.totalTfs.push(packed.totalTfs[i]);\n762:         hydrated.titleTfs.push(packed.titleTfs[i]);\n763:         hydrated.triggerTfs.push(packed.triggerTfs[i]);\n764:         hydrated.pathTfs.push(packed.pathTfs[i]);\n765:         hydrated.bodyTfs.push(packed.bodyTfs[i]);\n766:       }\n767:     }\n768: \n769:     this.packedMutablePostings.set(term, hydrated);\n770:     return hydrated;\n771:   }\n772: \n773:   private setPackedMutablePosting(\n774:     postings: PackedPostingMutable,\n775:     numericId: number,\n776:     frequency: PackedTermFrequency\n777:   ): void {\n778:     const existingIndex = postings.docIds.indexOf(numericId);\n779:     if (existingIndex >= 0) {\n780:       postings.totalTfs[existingIndex] = frequency.total;\n781:       postings.titleTfs[existingIndex] = frequency.fields.title;\n782:       postings.triggerTfs[existingIndex] = frequency.fields.trigger_phrases;\n783:       postings.pathTfs[existingIndex] = frequency.fields.content_generic;\n784:       postings.bodyTfs[existingIndex] = frequency.fields.body;\n785:       return;\n786:     }\n787: \n788:     postings.docIds.push(numericId);\n789:     postings.totalTfs.push(frequency.total);\n790:     postings.titleTfs.push(frequency.fields.title);\n791:     postings.triggerTfs.push(frequency.fields.trigger_phrases);\n792:     postings.pathTfs.push(frequency.fields.content_generic);\n793:     postings.bodyTfs.push(frequency.fields.body);\n794:   }\n795: \n796:   private deletePackedMutablePosting(postings: PackedPostingMutable, numericId: number): void {\n797:     const index = postings.docIds.indexOf(numericId);\n798:     if (index < 0) {\n799:       return;\n800:     }\n801:     postings.docIds.splice(index, 1);\n802:     postings.totalTfs.splice(index, 1);\n803:     postings.titleTfs.splice(index, 1);\n804:     postings.triggerTfs.splice(index, 1);\n805:     postings.pathTfs.splice(index, 1);\n806:     postings.bodyTfs.splice(index, 1);\n807:   }\n808: \n809:   private sortPackedMutablePosting(postings: PackedPostingMutable): void {\n810:     const order = postings.docIds.map((docId, index) => ({ docId, index }));\n811:     order.sort((a, b) => a.docId - b.docId);\n812: \n813:     postings.docIds = order.map((entry) => entry.docId);\n814:     postings.totalTfs = order.map((entry) => postings.totalTfs[entry.index]);\n815:     postings.titleTfs = order.map((entry) => postings.titleTfs[entry.index]);\n816:     postings.triggerTfs = order.map((entry) => postings.triggerTfs[entry.index]);\n817:     postings.pathTfs = order.map((entry) => postings.pathTfs[entry.index]);\n818:     postings.bodyTfs = order.map((entry) => postings.bodyTfs[entry.index]);\n819:   }\n820: \n821:   private calculatePackedScore(\n822:     queryTokens: string[],\n823:     docId: string,\n824:     options: BM25SearchOptions\n825:   ): number {\n826:     const doc = this.packedDocuments.get(docId);\n827:     if (!doc) return 0;\n828: \n829:     const weights = resolveBm25FieldWeights(options.fieldWeights);\n830:     const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n831:     let score = 0;\n832: \n833:     for (const term of queryTokens) {\n834:       const postings = this.getPackedPosting(term);\n835:       if (!postings) continue;\n836:       const postingIndex = this.findPackedPostingIndex(postings, doc.numericId);\n837:       if (postingIndex < 0) continue;\n838: \n839:       const weightedTf = this.calculateWeightedPostingFrequency(postings, postingIndex, weights);\n840:       if (weightedTf <= 0) continue;\n841: \n842:       const idf = this.calculateIdf(term);\n843:       score += this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n844:     }\n845: \n846:     return score;\n847:   }\n848: \n849:   private searchPacked(\n850:     queryTokens: string[],\n851:     limit: number,\n852:     options: BM25SearchOptions\n853:   ): BM25SearchResult[] {\n854:     const weights = resolveBm25FieldWeights(options.fieldWeights);\n855:     const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n856:     const scores = new Map<number, number>();\n857: \n858:     for (const term of queryTokens) {\n859:       const postings = this.getPackedPosting(term);\n860:       if (!postings) continue;\n861: \n862:       const idf = this.calculateIdf(term);\n863:       for (let i = 0; i < postings.docIds.length; i += 1) {\n864:         const numericId = postings.docIds[i];\n865:         const id = this.packedDocIds[numericId];\n866:         if (!id) continue;\n867:         const doc = this.packedDocuments.get(id);\n868:         if (!doc) continue;\n869: \n870:         const weightedTf = this.calculateWeightedPostingFrequency(postings, i, weights);\n871:         if (weightedTf <= 0) continue;\n872: \n873:         const termScore = this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n874:         scores.set(numericId, (scores.get(numericId) || 0) + termScore);\n875:       }\n876:     }\n877: \n878:     return Array.from(scores.entries())\n879:       .map(([numericId, score]) => ({ id: this.packedDocIds[numericId], score }))\n880:       .filter((result): result is BM25SearchResult => typeof result.id === 'string' && result.score > 0)\n881:       .sort((a, b) => b.score - a.score)\n882:       .slice(0, limit);\n883:   }\n884: \n885:   private calculateWeightedPostingFrequency(\n886:     postings: PackedPostingList,\n887:     index: number,\n888:     weights: BM25FieldWeights\n889:   ): number {\n890:     return (\n891:       postings.titleTfs[index] * weights.title +\n892:       postings.triggerTfs[index] * weights.trigger_phrases +\n893:       postings.pathTfs[index] * weights.content_generic +\n894:       postings.bodyTfs[index] * weights.body\n895:     );\n896:   }\n897: \n898:   private findPackedPostingIndex(postings: PackedPostingList, numericId: number): number {\n899:     let low = 0;\n900:     let high = postings.docIds.length - 1;\n901:     while (low <= high) {\n902:       const mid = Math.floor((low + high) / 2);\n903:       const value = postings.docIds[mid];\n904:       if (value === numericId) return mid;\n905:       if (value < numericId) {\n906:         low = mid + 1;\n907:       } else {\n908:         high = mid - 1;\n909:       }\n910:     }\n911:     return -1;\n912:   }\n913: \n914:   private calculateBm25TermScore(tf: number, dl: number, avgDl: number, idf: number): number {\n915:     const numerator = tf * (this.k1 + 1);\n916:     const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / avgDl));\n917:     return idf * (numerator / denominator);\n918:   }\n919: }\n920: \n921: // ───────────────────────────────────────────────────────────────\n922: // 4. SINGLETON\n923: \n924: // ───────────────────────────────────────────────────────────────\n925: let indexInstance: BM25Index | null = null;\n926: \n927: /**\n928:  * Retrieve the shared in-memory BM25 index singleton.\n929:  *\n930:  * @returns The process-wide {@link BM25Index} instance.\n931:  * @example\n932:  * ```ts\n933:  * const index = getIndex();\n934:  * index.addDocument('123', 'memory search');\n935:  * ```\n936:  */\n937: function getIndex(): BM25Index {\n938:   if (!indexInstance) {\n939:     indexInstance = new BM25Index();\n940:   }\n941:   return indexInstance;\n942: }\n943: \n944: /**\n945:  * Reset the shared BM25 index singleton.\n946:  *\n947:  * @returns Nothing.\n948:  * @example\n949:  * ```ts\n950:  * resetIndex();\n951:  * ```\n952:  */\n953: function resetIndex(): void {\n954:   indexInstance?.cancelWarmup();\n955:   indexInstance = null;\n956: }\n957: \n958: // ───────────────────────────────────────────────────────────────\n959: // 5. LEXICAL ENGINE ROUTING\n960: \n961: // ───────────────────────────────────────────────────────────────\n962: function resolveBm25Engine(): Bm25Engine {\n963:   const value = process.env.SPECKIT_BM25_ENGINE?.trim().toLowerCase();\n964:   if (!value) {\n965:     return 'auto';\n966:   }\n967: \n968:   if ((BM25_ENGINE_VALUES as readonly string[]).includes(value)) {\n969:     return value as Bm25Engine;\n970:   }\n971: \n972:   console.warn(`[bm25-index] Unsupported SPECKIT_BM25_ENGINE=${value}; falling back to auto`);\n973:   return 'auto';\n974: }\n975: \n976: function isMemoryFtsAvailable(database: Database.Database | null | undefined): boolean {\n977:   if (!database) {\n978:     return false;\n979:   }\n980: \n981:   try {\n982:     const result = (database.prepare(\n983:       `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n984:     ) as Database.Statement).get() as { name: string } | undefined;\n985:     return !!result;\n986:   } catch {\n987:     return false;\n988:   }\n989: }\n990: \n991: function shouldWarmInMemoryBm25(database: Database.Database | null | undefined): boolean {\n992:   if (!isBm25Enabled()) {\n993:     return false;\n994:   }\n995: \n996:   const engine = resolveBm25Engine();\n997:   emitBm25EngineSelection(engine, 'warmup routing');\n998:   if (engine === 'sqlite') {\n999:     if (!isMemoryFtsAvailable(database)) {\n1000:       throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table; JS BM25 warmup is disabled in sqlite mode');\n1001:     }\n1002:     return false;\n1003:   }\n1004: \n1005:   if (engine === 'auto') {\n1006:     return !isMemoryFtsAvailable(database);\n1007:   }\n1008: \n1009:   if (engine === 'packed-inmemory') {\n1010:     return true;\n1011:   }\n1012: \n1013:   return true;\n1014: }\n1015: \n1016: function shouldUseSqliteLexicalEngine(database: Database.Database | null | undefined): boolean {\n1017:   const engine = resolveBm25Engine();\n1018:   emitBm25EngineSelection(engine, 'lexical routing');\n1019:   if (engine === 'sqlite') {\n1020:     if (!isMemoryFtsAvailable(database)) {\n1021:       throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table for lexical BM25 search');\n1022:     }\n1023:     return true;\n1024:   }\n1025: \n1026:   if (engine === 'auto') {\n1027:     return isMemoryFtsAvailable(database);\n1028:   }\n1029: \n1030:   return false;\n1031: }\n1032: \n1033: function getBm25EngineStatus(database: Database.Database | null | undefined = null): {\n1034:   lexical_engine: Bm25Engine;\n1035:   fts5_available: boolean;\n1036:   warms_in_memory_bm25: boolean;\n1037:   bm25_enabled: boolean;\n1038: } {\n1039:   const lexical_engine = resolveBm25Engine();\n1040:   const fts5_available = isMemoryFtsAvailable(database);\n1041:   let warms_in_memory_bm25 = false;\n1042: \n1043:   try {\n1044:     warms_in_memory_bm25 = shouldWarmInMemoryBm25(database);\n1045:   } catch {\n1046:     warms_in_memory_bm25 = false;\n1047:   }\n1048: \n1049:   return {\n1050:     lexical_engine,\n1051:     fts5_available,\n1052:     warms_in_memory_bm25,\n1053:     bm25_enabled: isBm25Enabled(),\n1054:   };\n1055: }\n1056: \n1057: // ───────────────────────────────────────────────────────────────\n1058: // 6. EXPORTS\n1059: \n1060: // ───────────────────────────────────────────────────────────────\n1061: export {\n1062:   BM25Index,\n1063:   getIndex,\n1064:   resetIndex,\n1065:   tokenize,\n1066:   simpleStem,\n1067:   getTermFrequencies,\n1068:   isBm25Enabled,\n1069:   resolveBm25Engine,\n1070:   isMemoryFtsAvailable,\n1071:   shouldWarmInMemoryBm25,\n1072:   shouldUseSqliteLexicalEngine,\n1073:   getBm25EngineStatus,\n1074:   sanitizeQueryTokens,\n1075:   sanitizeFTS5Query,\n1076:   normalizeLexicalQueryTokens,\n1077:   buildBm25DocumentText,\n1078:   buildBm25DocumentFields,\n1079:   DEFAULT_K1,\n1080:   DEFAULT_B,\n1081:   BM25_FTS5_WEIGHTS,\n1082:   BM25_FIELD_WEIGHTS,\n1083: };\n1084: \n1085: export type {\n1086:   BM25SearchResult,\n1087:   BM25Stats,\n1088:   BM25DocumentSource,\n1089:   BM25DocumentFields,\n1090:   BM25FieldWeights,\n1091:   BM25SearchOptions,\n1092:   Bm25Engine,\n1093:   InMemoryBm25Engine,\n1094:   NormalizedLexicalQueryTokens,\n1095: };\n\n(End of file - total 1095 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface BM25SearchResult {\n  id: string;\n  /**\n   * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n   * Higher = better lexical match. Not directly comparable to vector similarity\n   * scores; use min-max normalization or RRF when combining with other methods.\n   */\n  score: number;\n}\n\ninterface BM25Stats {\n  documentCount: number;\n  termCount: number;\n  avgDocLength: number;\n}\n\ninterface BM25DocumentSource {\n  title?: string | null;\n  content_text?: string | null;\n  trigger_phrases?: string | string[] | null;\n  file_path?: string | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1B. CONSTANTS & FEATURE FLAG\n   ──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_K1 = 1.2;\nconst DEFAULT_B = 0.75;\nconst BM25_WARMUP_BATCH_SIZE = 250;\nconst BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\nconst BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\nconst BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\ntype Bm25Engine = typeof BM25_ENGINE_VALUES[number];\ntype InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\ntype BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n\nconst BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\nconst BM25_ENGINE_LOGGED = new Set<string>();\n\n/**\n * Field weight multipliers for weighted BM25 scoring.\n * When indexing a document composed of multiple fields, multiply\n * each field's token scores by the appropriate weight before\n * accumulating the total document score.\n *\n * These weights are shared by the FTS5 path and the packed in-memory\n * fallback so both lexical lanes preserve the same field-priority intent.\n *\n * title:           10.0 — exact title matches are the strongest signal\n * trigger_phrases:  5.0 — curated keywords next most important\n * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n * body:             1.0 — baseline weight for full body / content_text\n */\nconst BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n\nconst BM25_FIELD_WEIGHTS: Record<string, number> = {\n  title: BM25_FTS5_WEIGHTS[0],\n  trigger_phrases: BM25_FTS5_WEIGHTS[1],\n  content_generic: BM25_FTS5_WEIGHTS[2],\n  body: BM25_FTS5_WEIGHTS[3],\n};\n\ntype BM25FieldWeights = Record<BM25FieldName, number>;\n\ninterface BM25DocumentFields {\n  title?: string | null;\n  trigger_phrases?: string | string[] | null;\n  content_generic?: string | null;\n  body?: string | null;\n}\n\ninterface BM25SearchOptions {\n  fieldWeights?: Partial<BM25FieldWeights>;\n}\n\ninterface LegacyDocumentRecord {\n  tokens: string[];\n  termFreq: Map<string, number>;\n}\n\ninterface PackedTermFrequency {\n  total: number;\n  fields: Record<BM25FieldName, number>;\n}\n\ninterface PackedDocumentRecord {\n  numericId: number;\n  id: string;\n  length: number;\n  terms: string[];\n}\n\ninterface PackedPostingMutable {\n  docIds: number[];\n  totalTfs: number[];\n  titleTfs: number[];\n  triggerTfs: number[];\n  pathTfs: number[];\n  bodyTfs: number[];\n}\n\ninterface PackedPostingList {\n  docIds: Uint32Array;\n  totalTfs: Uint32Array;\n  titleTfs: Uint32Array;\n  triggerTfs: Uint32Array;\n  pathTfs: Uint32Array;\n  bodyTfs: Uint32Array;\n}\n\n/**\n * Check whether the in-memory BM25 index is enabled.\n *\n * @returns `true` when BM25 indexing/search is enabled for the current process.\n * @example\n * ```ts\n * if (isBm25Enabled()) {\n *   getIndex();\n * }\n * ```\n */\nfunction isBm25Enabled(): boolean {\n  const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n  if (!value) return true; // enabled by default\n  if (BM25_DISABLED_VALUES.has(value)) return false;\n  return BM25_ENABLED_VALUES.has(value);\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. HELPERS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Count token frequency occurrences for BM25 scoring.\n *\n * @param tokens - Normalized tokens produced by {@link tokenize}.\n * @returns A frequency map keyed by token text.\n * @example\n * ```ts\n * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n * // 2\n * ```\n */\nfunction getTermFrequencies(tokens: string[]): Map<string, number> {\n  const freq = new Map<string, number>();\n  for (const token of tokens) {\n    freq.set(token, (freq.get(token) || 0) + 1);\n  }\n  return freq;\n}\n\nfunction visitBm25Tokens(text: string, visitor: (token: string) => void): void {\n  if (!text || typeof text !== 'string') return;\n\n  let token = '';\n  const flush = () => {\n    if (token.length >= 2 && !STOP_WORDS.has(token)) {\n      visitor(simpleStem(token));\n    }\n    token = '';\n  };\n\n  for (let i = 0; i < text.length; i += 1) {\n    const code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      token += String.fromCharCode(code + 32);\n    } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n      token += text[i];\n    } else if (token.length > 0) {\n      flush();\n    }\n  }\n\n  if (token.length > 0) {\n    flush();\n  }\n}\n\nfunction normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n  if (Array.isArray(triggerPhrases)) {\n    return triggerPhrases\n      .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n      .join(' ');\n  }\n\n  if (typeof triggerPhrases !== 'string') {\n    return '';\n  }\n\n  const trimmed = triggerPhrases.trim();\n  if (!trimmed) {\n    return '';\n  }\n\n  try {\n    const parsed = JSON.parse(trimmed) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed\n        .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n        .join(' ');\n    }\n  } catch {\n    // Fall back to raw string when the database value is not JSON.\n  }\n\n  return trimmed;\n}\n\nfunction defaultPackedTermFrequency(): PackedTermFrequency {\n  return {\n    total: 0,\n    fields: {\n      title: 0,\n      trigger_phrases: 0,\n      content_generic: 0,\n      body: 0,\n    },\n  };\n}\n\nfunction resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n  return {\n    title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n    trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n    content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n    body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n  };\n}\n\nfunction emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n  const key = `${engine}:${reason}`;\n  if (BM25_ENGINE_LOGGED.has(key)) {\n    return;\n  }\n  BM25_ENGINE_LOGGED.add(key);\n  console.info(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n}\n\nfunction resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n  const configured = resolveBm25Engine();\n  if (configured === 'legacy-inmemory') {\n    emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n    return 'legacy-inmemory';\n  }\n\n  if (configured === 'sqlite') {\n    emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n    return 'packed-inmemory';\n  }\n\n  if (configured === 'packed-inmemory') {\n    emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n    return 'packed-inmemory';\n  }\n\n  emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n  return 'packed-inmemory';\n}\n\nfunction buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n  return {\n    title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n    body: typeof row.content_text === 'string' && row.content_text.trim()\n      ? normalizeContentForBM25(row.content_text)\n      : '',\n    trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n    content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n  };\n}\n\nfunction buildBm25DocumentText(row: BM25DocumentSource): string {\n  const textParts: string[] = [];\n\n  if (typeof row.title === 'string' && row.title.trim()) {\n    textParts.push(row.title.trim());\n  }\n\n  if (typeof row.content_text === 'string' && row.content_text.trim()) {\n    textParts.push(normalizeContentForBM25(row.content_text));\n  }\n\n  const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n  if (triggerPhrases) {\n    textParts.push(triggerPhrases);\n  }\n\n  if (typeof row.file_path === 'string' && row.file_path.trim()) {\n    textParts.push(row.file_path.trim());\n  }\n\n  return textParts.join(' ').trim();\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. BM25 INDEX CLASS\n\n// ───────────────────────────────────────────────────────────────\nclass BM25Index {\n  private k1: number;\n  private b: number;\n  private engine: InMemoryBm25Engine;\n  private documents: Map<string, LegacyDocumentRecord>;\n  private packedDocuments: Map<string, PackedDocumentRecord>;\n  private packedDocIds: string[];\n  private packedDocNumbersById: Map<string, number>;\n  private packedMutablePostings: Map<string, PackedPostingMutable>;\n  private packedPostings: Map<string, PackedPostingList>;\n  private packedDirtyTerms: Set<string>;\n  private documentFreq: Map<string, number>;\n  private totalDocLength: number;\n  private warmupHandle: ReturnType<typeof setTimeout> | null;\n  private warmupGeneration: number;\n\n  constructor(\n    k1: number = DEFAULT_K1,\n    b: number = DEFAULT_B,\n    engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n  ) {\n    this.k1 = k1;\n    this.b = b;\n    this.engine = engine;\n    this.documents = new Map();\n    this.packedDocuments = new Map();\n    this.packedDocIds = [];\n    this.packedDocNumbersById = new Map();\n    this.packedMutablePostings = new Map();\n    this.packedPostings = new Map();\n    this.packedDirtyTerms = new Set();\n    this.documentFreq = new Map();\n    this.totalDocLength = 0;\n    this.warmupHandle = null;\n    this.warmupGeneration = 0;\n  }\n\n  addDocument(id: string, text: string): void {\n    if (this.engine === 'packed-inmemory') {\n      this.addDocumentFields(id, { body: text });\n      return;\n    }\n\n    const tokens = tokenize(text);\n    const termFreq = getTermFrequencies(tokens);\n\n    if (this.documents.has(id)) {\n      this.removeDocument(id);\n    }\n\n    this.documents.set(id, { tokens, termFreq });\n    this.totalDocLength += tokens.length;\n\n    // Update document frequency\n    for (const term of termFreq.keys()) {\n      this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n    }\n  }\n\n  addDocumentFields(id: string, fields: BM25DocumentFields): void {\n    if (this.engine === 'legacy-inmemory') {\n      this.addDocument(id, this.joinDocumentFields(fields));\n      return;\n    }\n\n    if (this.packedDocuments.has(id)) {\n      this.removeDocument(id);\n    }\n\n    const termFreq = this.getPackedTermFrequencies(fields);\n    const length = Array.from(termFreq.values()).reduce((sum, freq) => sum + freq.total, 0);\n    if (length === 0) {\n      return;\n    }\n\n    const numericId = this.getPackedNumericId(id);\n    this.packedDocuments.set(id, { numericId, id, length, terms: Array.from(termFreq.keys()) });\n    this.totalDocLength += length;\n\n    for (const [term, frequency] of termFreq) {\n      const postings = this.ensurePackedMutablePostings(term);\n      this.setPackedMutablePosting(postings, numericId, frequency);\n      this.packedDirtyTerms.add(term);\n      this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n    }\n  }\n\n  removeDocument(id: string): boolean {\n    if (this.engine === 'packed-inmemory') {\n      return this.removePackedDocument(id);\n    }\n\n    const doc = this.documents.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.tokens.length;\n\n    for (const term of doc.termFreq.keys()) {\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.documents.delete(id);\n    return true;\n  }\n\n  calculateIdf(term: string): number {\n    const n = this.getDocumentCount();\n    const df = this.documentFreq.get(term) || 0;\n    if (df === 0 || n === 0) return 0;\n    return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n  }\n\n  calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n    if (this.engine === 'packed-inmemory') {\n      return this.calculatePackedScore(queryTokens, docId, options);\n    }\n\n    const doc = this.documents.get(docId);\n    if (!doc) return 0;\n\n    const avgDl = this.getAverageDocumentLength();\n    const dl = doc.tokens.length;\n\n    let score = 0;\n    for (const term of queryTokens) {\n      const tf = doc.termFreq.get(term) || 0;\n      if (tf === 0) continue;\n\n      const idf = this.calculateIdf(term);\n      const numerator = tf * (this.k1 + 1);\n      const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n      score += idf * (numerator / denominator);\n    }\n\n    return score;\n  }\n\n  search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n    const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n    if (queryTokens.length === 0) return [];\n\n    if (this.engine === 'packed-inmemory') {\n      return this.searchPacked(queryTokens, limit, options);\n    }\n\n    const results: BM25SearchResult[] = [];\n\n    for (const [id] of this.documents) {\n      const score = this.calculateScore(queryTokens, id);\n      if (score > 0) {\n        results.push({ id, score });\n      }\n    }\n\n    return results\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  getStats(): BM25Stats {\n    return {\n      documentCount: this.getDocumentCount(),\n      termCount: this.documentFreq.size,\n      avgDocLength: this.getAverageDocumentLength(),\n    };\n  }\n\n  clear(): void {\n    this.cancelWarmup();\n    this.documents.clear();\n    this.packedDocuments.clear();\n    this.packedDocIds = [];\n    this.packedDocNumbersById.clear();\n    this.packedMutablePostings.clear();\n    this.packedPostings.clear();\n    this.packedDirtyTerms.clear();\n    this.documentFreq.clear();\n    this.totalDocLength = 0;\n  }\n\n  addDocuments(docs: Array<{ id: string; text: string }>): void {\n    for (const doc of docs) {\n      this.addDocument(doc.id, doc.text);\n    }\n  }\n\n  finalizePackedPostings(): void {\n    if (this.engine === 'legacy-inmemory') {\n      return;\n    }\n\n    for (const term of Array.from(this.packedDirtyTerms)) {\n      this.getPackedPosting(term);\n    }\n    this.packedMutablePostings.clear();\n  }\n\n  /**\n   * Incrementally synchronize changed rows from the database into the in-memory index.\n   */\n  syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n    const normalizedIds = Array.from(\n      new Set(\n        rowIds\n          .map((rowId) => Number(rowId))\n          .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n      )\n    );\n\n    if (normalizedIds.length === 0) {\n      return 0;\n    }\n\n    try {\n      const placeholders = normalizedIds.map(() => '?').join(', ');\n      const rows = (database.prepare(\n        `SELECT id, title, content_text, trigger_phrases, file_path\n         FROM memory_index\n         WHERE id IN (${placeholders})`\n      ) as Database.Statement).all(...normalizedIds) as Array<{\n        id: number;\n        title: string | null;\n        content_text: string | null;\n        trigger_phrases: string | null;\n        file_path: string | null;\n      }>;\n\n      const activeRowMap = new Map<number, typeof rows[number]>();\n      for (const row of rows) {\n        activeRowMap.set(row.id, row);\n      }\n\n      for (const rowId of normalizedIds) {\n        const row = activeRowMap.get(rowId);\n        if (!row) {\n          this.removeDocument(String(rowId));\n          continue;\n        }\n\n        const fields = buildBm25DocumentFields(row);\n        if (this.joinDocumentFields(fields).trim()) {\n          this.addDocumentFields(String(row.id), fields);\n        } else {\n          this.removeDocument(String(row.id));\n        }\n      }\n\n      return normalizedIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n      return 0;\n    }\n  }\n\n  /**\n   * Defer full startup warmup into batched row-ID syncs so process\n   * initialization is not blocked by a monolithic in-memory rebuild.\n   */\n  rebuildFromDatabase(database: Database.Database): number {\n    this.clear();\n\n    try {\n      const rows = (database.prepare(\n        `SELECT id\n         FROM memory_index\n         ORDER BY id`\n      ) as Database.Statement).all() as Array<{ id: number }>;\n\n      const pendingIds = rows.map((row) => row.id);\n      if (pendingIds.length === 0) {\n        return 0;\n      }\n\n      const warmupGeneration = ++this.warmupGeneration;\n      const processBatch = () => {\n        if (warmupGeneration !== this.warmupGeneration) {\n          return;\n        }\n\n        const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n        if (batchIds.length === 0) {\n          this.finalizePackedPostings();\n          this.warmupHandle = null;\n          return;\n        }\n\n        this.syncChangedRows(database, batchIds);\n\n        if (pendingIds.length > 0) {\n          this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n        } else {\n          this.warmupHandle = null;\n        }\n      };\n\n      this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n      return pendingIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n      return 0;\n    }\n  }\n\n  cancelWarmup(): void {\n    this.warmupGeneration += 1;\n    if (this.warmupHandle) {\n      clearRegisteredTimer(this.warmupHandle);\n      this.warmupHandle = null;\n    }\n  }\n\n  private getDocumentCount(): number {\n    return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n  }\n\n  private getAverageDocumentLength(): number {\n    const documentCount = this.getDocumentCount();\n    return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n  }\n\n  private joinDocumentFields(fields: BM25DocumentFields): string {\n    const parts: string[] = [];\n    for (const fieldName of BM25_FIELD_NAMES) {\n      const value = fields[fieldName];\n      if (Array.isArray(value)) {\n        parts.push(value.join(' '));\n      } else if (typeof value === 'string' && value.trim()) {\n        parts.push(value.trim());\n      }\n    }\n    return parts.join(' ').trim();\n  }\n\n  private getPackedNumericId(id: string): number {\n    const existing = this.packedDocNumbersById.get(id);\n    if (existing !== undefined) {\n      return existing;\n    }\n\n    const numericId = this.packedDocIds.length;\n    this.packedDocIds.push(id);\n    this.packedDocNumbersById.set(id, numericId);\n    return numericId;\n  }\n\n  private getPackedTermFrequencies(fields: BM25DocumentFields): Map<string, PackedTermFrequency> {\n    const termFreq = new Map<string, PackedTermFrequency>();\n\n    for (const fieldName of BM25_FIELD_NAMES) {\n      const rawValue = fields[fieldName];\n      const text = Array.isArray(rawValue) ? rawValue.join(' ') : (rawValue ?? '');\n      visitBm25Tokens(text, (token) => {\n        let frequency = termFreq.get(token);\n        if (!frequency) {\n          frequency = defaultPackedTermFrequency();\n          termFreq.set(token, frequency);\n        }\n        frequency.total += 1;\n        frequency.fields[fieldName] += 1;\n      });\n    }\n\n    return termFreq;\n  }\n\n  private removePackedDocument(id: string): boolean {\n    const doc = this.packedDocuments.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.length;\n\n    for (const term of doc.terms) {\n      const postings = this.ensurePackedMutablePostings(term);\n      this.deletePackedMutablePosting(postings, doc.numericId);\n      this.packedDirtyTerms.add(term);\n\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n        this.packedMutablePostings.delete(term);\n        this.packedPostings.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.packedDocuments.delete(id);\n    return true;\n  }\n\n  private getPackedPosting(term: string): PackedPostingList | undefined {\n    if (!this.packedDirtyTerms.has(term)) {\n      return this.packedPostings.get(term);\n    }\n\n    const mutable = this.packedMutablePostings.get(term);\n    if (!mutable || mutable.docIds.length === 0) {\n      this.packedDirtyTerms.delete(term);\n      this.packedPostings.delete(term);\n      return undefined;\n    }\n\n    this.sortPackedMutablePosting(mutable);\n\n    const packed: PackedPostingList = {\n      docIds: Uint32Array.from(mutable.docIds),\n      totalTfs: Uint32Array.from(mutable.totalTfs),\n      titleTfs: Uint32Array.from(mutable.titleTfs),\n      triggerTfs: Uint32Array.from(mutable.triggerTfs),\n      pathTfs: Uint32Array.from(mutable.pathTfs),\n      bodyTfs: Uint32Array.from(mutable.bodyTfs),\n    };\n    this.packedPostings.set(term, packed);\n    this.packedDirtyTerms.delete(term);\n    return packed;\n  }\n\n  private ensurePackedMutablePostings(term: string): PackedPostingMutable {\n    const existing = this.packedMutablePostings.get(term);\n    if (existing) {\n      return existing;\n    }\n\n    const hydrated: PackedPostingMutable = {\n      docIds: [],\n      totalTfs: [],\n      titleTfs: [],\n      triggerTfs: [],\n      pathTfs: [],\n      bodyTfs: [],\n    };\n    const packed = this.packedPostings.get(term);\n    if (packed) {\n      for (let i = 0; i < packed.docIds.length; i += 1) {\n        hydrated.docIds.push(packed.docIds[i]);\n        hydrated.totalTfs.push(packed.totalTfs[i]);\n        hydrated.titleTfs.push(packed.titleTfs[i]);\n        hydrated.triggerTfs.push(packed.triggerTfs[i]);\n        hydrated.pathTfs.push(packed.pathTfs[i]);\n        hydrated.bodyTfs.push(packed.bodyTfs[i]);\n      }\n    }\n\n    this.packedMutablePostings.set(term, hydrated);\n    return hydrated;\n  }\n\n  private setPackedMutablePosting(\n    postings: PackedPostingMutable,\n    numericId: number,\n    frequency: PackedTermFrequency\n  ): void {\n    const existingIndex = postings.docIds.indexOf(numericId);\n    if (existingIndex >= 0) {\n      postings.totalTfs[existingIndex] = frequency.total;\n      postings.titleTfs[existingIndex] = frequency.fields.title;\n      postings.triggerTfs[existingIndex] = frequency.fields.trigger_phrases;\n      postings.pathTfs[existingIndex] = frequency.fields.content_generic;\n      postings.bodyTfs[existingIndex] = frequency.fields.body;\n      return;\n    }\n\n    postings.docIds.push(numericId);\n    postings.totalTfs.push(frequency.total);\n    postings.titleTfs.push(frequency.fields.title);\n    postings.triggerTfs.push(frequency.fields.trigger_phrases);\n    postings.pathTfs.push(frequency.fields.content_generic);\n    postings.bodyTfs.push(frequency.fields.body);\n  }\n\n  private deletePackedMutablePosting(postings: PackedPostingMutable, numericId: number): void {\n    const index = postings.docIds.indexOf(numericId);\n    if (index < 0) {\n      return;\n    }\n    postings.docIds.splice(index, 1);\n    postings.totalTfs.splice(index, 1);\n    postings.titleTfs.splice(index, 1);\n    postings.triggerTfs.splice(index, 1);\n    postings.pathTfs.splice(index, 1);\n    postings.bodyTfs.splice(index, 1);\n  }\n\n  private sortPackedMutablePosting(postings: PackedPostingMutable): void {\n    const order = postings.docIds.map((docId, index) => ({ docId, index }));\n    order.sort((a, b) => a.docId - b.docId);\n\n    postings.docIds = order.map((entry) => entry.docId);\n    postings.totalTfs = order.map((entry) => postings.totalTfs[entry.index]);\n    postings.titleTfs = order.map((entry) => postings.titleTfs[entry.index]);\n    postings.triggerTfs = order.map((entry) => postings.triggerTfs[entry.index]);\n    postings.pathTfs = order.map((entry) => postings.pathTfs[entry.index]);\n    postings.bodyTfs = order.map((entry) => postings.bodyTfs[entry.index]);\n  }\n\n  private calculatePackedScore(\n    queryTokens: string[],\n    docId: string,\n    options: BM25SearchOptions\n  ): number {\n    const doc = this.packedDocuments.get(docId);\n    if (!doc) return 0;\n\n    const weights = resolveBm25FieldWeights(options.fieldWeights);\n    const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n    let score = 0;\n\n    for (const term of queryTokens) {\n      const postings = this.getPackedPosting(term);\n      if (!postings) continue;\n      const postingIndex = this.findPackedPostingIndex(postings, doc.numericId);\n      if (postingIndex < 0) continue;\n\n      const weightedTf = this.calculateWeightedPostingFrequency(postings, postingIndex, weights);\n      if (weightedTf <= 0) continue;\n\n      const idf = this.calculateIdf(term);\n      score += this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n    }\n\n    return score;\n  }\n\n  private searchPacked(\n    queryTokens: string[],\n    limit: number,\n    options: BM25SearchOptions\n  ): BM25SearchResult[] {\n    const weights = resolveBm25FieldWeights(options.fieldWeights);\n    const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n    const scores = new Map<number, number>();\n\n    for (const term of queryTokens) {\n      const postings = this.getPackedPosting(term);\n      if (!postings) continue;\n\n      const idf = this.calculateIdf(term);\n      for (let i = 0; i < postings.docIds.length; i += 1) {\n        const numericId = postings.docIds[i];\n        const id = this.packedDocIds[numericId];\n        if (!id) continue;\n        const doc = this.packedDocuments.get(id);\n        if (!doc) continue;\n\n        const weightedTf = this.calculateWeightedPostingFrequency(postings, i, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n        scores.set(numericId, (scores.get(numericId) || 0) + termScore);\n      }\n    }\n\n    return Array.from(scores.entries())\n      .map(([numericId, score]) => ({ id: this.packedDocIds[numericId], score }))\n      .filter((result): result is BM25SearchResult => typeof result.id === 'string' && result.score > 0)\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  private calculateWeightedPostingFrequency(\n    postings: PackedPostingList,\n    index: number,\n    weights: BM25FieldWeights\n  ): number {\n    return (\n      postings.titleTfs[index] * weights.title +\n      postings.triggerTfs[index] * weights.trigger_phrases +\n      postings.pathTfs[index] * weights.content_generic +\n      postings.bodyTfs[index] * weights.body\n    );\n  }\n\n  private findPackedPostingIndex(postings: PackedPostingList, numericId: number): number {\n    let low = 0;\n    let high = postings.docIds.length - 1;\n    while (low <= high) {\n      const mid = Math.floor((low + high) / 2);\n      const value = postings.docIds[mid];\n      if (value === numericId) return mid;\n      if (value < numericId) {\n        low = mid + 1;\n      } else {\n        high = mid - 1;\n      }\n    }\n    return -1;\n  }\n\n  private calculateBm25TermScore(tf: number, dl: number, avgDl: number, idf: number): number {\n    const numerator = tf * (this.k1 + 1);\n    const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / avgDl));\n    return idf * (numerator / denominator);\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. SINGLETON\n\n// ───────────────────────────────────────────────────────────────\nlet indexInstance: BM25Index | null = null;\n\n/**\n * Retrieve the shared in-memory BM25 index singleton.\n *\n * @returns The process-wide {@link BM25Index} instance.\n * @example\n * ```ts\n * const index = getIndex();\n * index.addDocument('123', 'memory search');\n * ```\n */\nfunction getIndex(): BM25Index {\n  if (!indexInstance) {\n    indexInstance = new BM25Index();\n  }\n  return indexInstance;\n}\n\n/**\n * Reset the shared BM25 index singleton.\n *\n * @returns Nothing.\n * @example\n * ```ts\n * resetIndex();\n * ```\n */\nfunction resetIndex(): void {\n  indexInstance?.cancelWarmup();\n  indexInstance = null;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 5. LEXICAL ENGINE ROUTING\n\n// ───────────────────────────────────────────────────────────────\nfunction resolveBm25Engine(): Bm25Engine {\n  const value = process.env.SPECKIT_BM25_ENGINE?.trim().toLowerCase();\n  if (!value) {\n    return 'auto';\n  }\n\n  if ((BM25_ENGINE_VALUES as readonly string[]).includes(value)) {\n    return value as Bm25Engine;\n  }\n\n  console.warn(`[bm25-index] Unsupported SPECKIT_BM25_ENGINE=${value}; falling back to auto`);\n  return 'auto';\n}\n\nfunction isMemoryFtsAvailable(database: Database.Database | null | undefined): boolean {\n  if (!database) {\n    return false;\n  }\n\n  try {\n    const result = (database.prepare(\n      `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n    ) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch {\n    return false;\n  }\n}\n\nfunction shouldWarmInMemoryBm25(database: Database.Database | null | undefined): boolean {\n  if (!isBm25Enabled()) {\n    return false;\n  }\n\n  const engine = resolveBm25Engine();\n  emitBm25EngineSelection(engine, 'warmup routing');\n  if (engine === 'sqlite') {\n    if (!isMemoryFtsAvailable(database)) {\n      throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table; JS BM25 warmup is disabled in sqlite mode');\n    }\n    return false;\n  }\n\n  if (engine === 'auto') {\n    return !isMemoryFtsAvailable(database);\n  }\n\n  if (engine === 'packed-inmemory') {\n    return true;\n  }\n\n  return true;\n}\n\nfunction shouldUseSqliteLexicalEngine(database: Database.Database | null | undefined): boolean {\n  const engine = resolveBm25Engine();\n  emitBm25EngineSelection(engine, 'lexical routing');\n  if (engine === 'sqlite') {\n    if (!isMemoryFtsAvailable(database)) {\n      throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table for lexical BM25 search');\n    }\n    return true;\n  }\n\n  if (engine === 'auto') {\n    return isMemoryFtsAvailable(database);\n  }\n\n  return false;\n}\n\nfunction getBm25EngineStatus(database: Database.Database | null | undefined = null): {\n  lexical_engine: Bm25Engine;\n  fts5_available: boolean;\n  warms_in_memory_bm25: boolean;\n  bm25_enabled: boolean;\n} {\n  const lexical_engine = resolveBm25Engine();\n  const fts5_available = isMemoryFtsAvailable(database);\n  let warms_in_memory_bm25 = false;\n\n  try {\n    warms_in_memory_bm25 = shouldWarmInMemoryBm25(database);\n  } catch {\n    warms_in_memory_bm25 = false;\n  }\n\n  return {\n    lexical_engine,\n    fts5_available,\n    warms_in_memory_bm25,\n    bm25_enabled: isBm25Enabled(),\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 6. EXPORTS\n\n// ───────────────────────────────────────────────────────────────\nexport {\n  BM25Index,\n  getIndex,\n  resetIndex,\n  tokenize,\n  simpleStem,\n  getTermFrequencies,\n  isBm25Enabled,\n  resolveBm25Engine,\n  isMemoryFtsAvailable,\n  shouldWarmInMemoryBm25,\n  shouldUseSqliteLexicalEngine,\n  getBm25EngineStatus,\n  sanitizeQueryTokens,\n  sanitizeFTS5Query,\n  normalizeLexicalQueryTokens,\n  buildBm25DocumentText,\n  buildBm25DocumentFields,\n  DEFAULT_K1,\n  DEFAULT_B,\n  BM25_FTS5_WEIGHTS,\n  BM25_FIELD_WEIGHTS,\n};\n\nexport type {\n  BM25SearchResult,\n  BM25Stats,\n  BM25DocumentSource,\n  BM25DocumentFields,\n  BM25FieldWeights,\n  BM25SearchOptions,\n  Bm25Engine,\n  InMemoryBm25Engine,\n  NormalizedLexicalQueryTokens,\n};","lineStart":1,"lineEnd":1095,"totalLines":1095,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781151913726,"end":1781151913738}},"metadata":{"openai":{"itemId":"fc_0e1f5eb53c6bb8d3016a2a38a9aa8481918aa0901356c9b94e"}},"id":"prt_eb4ed56d8001xUB6j81nsrvlUT","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed3406001QSvMXtyij9Xo5H"}}
{"type":"tool_use","timestamp":1781151913742,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"type":"tool","tool":"read","callID":"call_5BDW6RaHZoMMkq5Dz7cySPpo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25-Only Baseline Runner\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // Runs the ground truth query set through the BM25/FTS5-only\n6: // Search path (disabling vector, graph, and trigger channels)\n7: // And computes baseline metrics. Records results in eval DB.\n8: //\n9: // The baseline measurement establishes the \"floor\" — what simple\n10: // Keyword search achieves without any semantic, graph, or trigger\n11: // Augmentation.\n12: //\n13: // Design notes:\n14: //   - The search function is injected as a dependency so tests\n15: // Can use mocks without a live DB.\n16: //   - The contingency decision matrix turns the measured MRR@5\n17: // Into an actionable gate: PAUSE / RATIONALIZE / PROCEED.\n18: //   - recordBaselineMetrics() is a pure DB write — no network I/O.\n19: import type Database from 'better-sqlite3';\n20: \n21: import {\n22:   computeMRR,\n23:   computeNDCG,\n24:   computeRecall,\n25:   computeHitRate,\n26:   type EvalResult,\n27:   type GroundTruthEntry,\n28: } from './eval-metrics.js';\n29: import {\n30:   GROUND_TRUTH_QUERIES,\n31:   GROUND_TRUTH_RELEVANCES,\n32:   type GroundTruthQuery,\n33: } from './ground-truth-data.js';\n34: \n35: /* ───────────────────────────────────────────────────────────────\n36:    1. PUBLIC TYPES\n37: ──────────────────────────────────────────────────────────────── */\n38: \n39: /** Configuration options for the BM25 baseline runner. */\n40: export interface BM25BaselineConfig {\n41:   /** Maximum number of queries to run. Defaults to all 110. */\n42:   queryLimit?: number;\n43:   /** Top-K cutoff for NDCG and Recall metrics. MRR always uses k=5 for contingency compatibility. */\n44:   k?: number;\n45:   /** Exclude hard-negative queries from the run. Default: false. */\n46:   skipHardNegatives?: boolean;\n47: }\n48: \n49: /** Metrics produced by a single BM25 baseline run. */\n50: export interface BM25BaselineMetrics {\n51:   mrr5: number;\n52:   /** NDCG at configured K (default 10). Named ndcg10 for backwards compatibility. */\n53:   ndcg10: number;\n54:   /** Recall at configured K (default 20). Named recall20 for backwards compatibility. */\n55:   recall20: number;\n56:   hitRate1: number;\n57: }\n58: \n59: /** Full result returned by runBM25Baseline(). */\n60: export interface BM25BaselineResult {\n61:   metrics: BM25BaselineMetrics;\n62:   queryCount: number;\n63:   timestamp: string;\n64:   contingencyDecision: ContingencyDecision;\n65:   /** Per-query MRR@5 values for bootstrap CI computation. */\n66:   perQueryMRR?: number[];\n67:   /** Bootstrap 95% CI for MRR@5 (computed if perQueryMRR available). */\n68:   bootstrapCI?: BootstrapCIResult;\n69: }\n70: \n71: /** Decision produced by evaluateContingency() or evaluateContingencyRelative(). */\n72: export interface ContingencyDecision {\n73:   /** The MRR@5 value used to derive the decision. */\n74:   bm25MRR: number;\n75:   /** Human-readable threshold band: '>=0.8' | '0.5-0.8' | '<0.5'. */\n76:   threshold: string;\n77:   /** Gate action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED'. */\n78:   action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED';\n79:   /** Plain-language interpretation for humans reading the exit gate report. */\n80:   interpretation: string;\n81:   /** Comparison mode: 'absolute' (the rollout) or 'relative' (the original rollout+). */\n82:   mode?: 'absolute' | 'relative';\n83:   /** Hybrid MRR@5 used as reference (relative mode only). */\n84:   hybridMRR?: number;\n85:   /** BM25/hybrid ratio (relative mode only). */\n86:   ratio?: number;\n87: }\n88: \n89: /**\n90:  * A single search result as returned by the injected BM25 search function.\n91:  * Mirrors the shape used in hybrid-search.ts so callers can reuse the same\n92:  * function reference.\n93:  */\n94: export interface BM25SearchResult {\n95:   /** Memory ID (numeric). */\n96:   id: number;\n97:   /** Retrieval score (raw BM25 / FTS5 rank). */\n98:   score: number;\n99:   /** Source channel identifier. Expected: 'bm25' or 'fts'. */\n100:   source: string;\n101: }\n102: \n103: /**\n104:  * A relevance judgment loaded from eval_ground_truth for a single query.\n105:  * Used to evaluate results returned by the injected search function.\n106:  */\n107: export interface QueryGroundTruth {\n108:   queryId: number;\n109:   memoryId: number;\n110:   relevance: number;\n111: }\n112: \n113: /** Query and graded relevance data for fixture-backed engine comparisons. */\n114: export interface BM25ComparisonQuery {\n115:   id: number;\n116:   query: string;\n117:   relevances: QueryGroundTruth[];\n118: }\n119: \n120: /** Search functions used to compare lexical engines on the same query set. */\n121: export interface BM25EngineComparisonSearches {\n122:   legacy: BM25SearchFn;\n123:   packed: BM25SearchFn;\n124:   fts5?: BM25SearchFn;\n125: }\n126: \n127: /** Metrics and pass/fail signals for a packed-vs-legacy BM25 comparison. */\n128: export interface BM25EngineComparisonResult {\n129:   legacy: BM25BaselineMetrics;\n130:   packed: BM25BaselineMetrics;\n131:   fts5?: BM25BaselineMetrics;\n132:   packedAtLeastLegacy: boolean;\n133:   titleSignalRestored: boolean;\n134: }\n135: \n136: /**\n137:  * Injected BM25-only search function signature.\n138:  *\n139:  * The function receives the query text and a limit and must return results\n140:  * using ONLY the BM25/FTS5 channel (vector, graph, trigger disabled).\n141:  * For production use, wire up the FTS5 path from hybrid-search with all\n142:  * other channels explicitly disabled.\n143:  */\n144: export type BM25SearchFn = (\n145:   query: string,\n146:   limit: number,\n147: ) => BM25SearchResult[] | Promise<BM25SearchResult[]>;\n148: \n149: /* ───────────────────────────────────────────────────────────────\n150:    2. CONTINGENCY DECISION MATRIX\n151: ──────────────────────────────────────────────────────────────── */\n152: \n153: /**\n154:  * Evaluate the BM25 MRR@5 value against the contingency decision matrix.\n155:  *\n156:  * Matrix:\n157:  *   MRR@5 >= 0.80 → PAUSE\n158:  *     BM25 alone is very strong — semantic/graph additions may not\n159:  *     justify the added complexity. Evaluate whether the multi-channel\n160:  *     architecture is warranted before proceeding.\n161:  *\n162:  *   MRR@5 0.50–0.79 → RATIONALIZE\n163:  *     BM25 is moderate — semantic/graph channels must demonstrably\n164:  *     improve over this baseline. Each additional channel needs\n165:  *     positive delta evidence.\n166:  *\n167:  *   MRR@5 < 0.50 → PROCEED\n168:  *     BM25 alone is weak — strong justification for multi-channel\n169:  *     retrieval. Proceed with hybrid search implementation.\n170:  *\n171:  * @param bm25MRR - The measured MRR@5 value (must be in [0, 1]).\n172:  * @returns ContingencyDecision with threshold label, action, and interpretation.\n173:  */\n174: export function evaluateContingency(bm25MRR: number): ContingencyDecision {\n175:   if (bm25MRR >= 0.80) {\n176:     return {\n177:       bm25MRR,\n178:       mode: 'absolute',\n179:       threshold: '>=0.8',\n180:       action: 'PAUSE',\n181:       interpretation:\n182:         'BM25 alone is very strong — semantic/graph additions may not justify complexity. ' +\n183:         'Re-evaluate whether a multi-channel architecture is warranted before proceeding with ' +\n184:         'additional retrieval channels. Consider whether the marginal gain from vector/graph ' +\n185:         'search is worth the operational overhead.',\n186:     };\n187:   }\n188: \n189:   if (bm25MRR >= 0.50) {\n190:     return {\n191:       bm25MRR,\n192:       mode: 'absolute',\n193:       threshold: '0.5-0.8',\n194:       action: 'RATIONALIZE',\n195:       interpretation:\n196:         'BM25 is moderate — semantic/graph channels should demonstrably improve over this baseline. ' +\n197:         'Each additional channel (vector, graph, trigger) must show a statistically meaningful ' +\n198:         'positive delta in MRR@5 before adoption. Track per-channel contribution carefully.',\n199:     };\n200:   }\n201: \n202:   return {\n203:     bm25MRR,\n204:     mode: 'absolute',\n205:     threshold: '<0.5',\n206:     action: 'PROCEED',\n207:     interpretation:\n208:       'BM25 alone is weak — strong justification for multi-channel retrieval. ' +\n209:       'The low keyword-only baseline confirms that semantic and graph augmentation ' +\n210:       'adds meaningful value. Proceed with hybrid search implementation.',\n211:   };\n212: }\n213: \n214: /**\n215:  * Compare lexical engines against a caller-provided fixture query set.\n216:  * The helper reuses the baseline metrics so relevance gates stay aligned\n217:  * with the production BM25-only evaluation report.\n218:  */\n219: export async function runBM25EngineComparison(\n220:   searches: BM25EngineComparisonSearches,\n221:   queries: BM25ComparisonQuery[],\n222:   config: Pick<BM25BaselineConfig, 'k'> = {},\n223: ): Promise<BM25EngineComparisonResult> {\n224:   const k = config.k ?? 20;\n225:   const legacy = await runComparisonMetrics(searches.legacy, queries, k);\n226:   const packed = await runComparisonMetrics(searches.packed, queries, k);\n227:   const fts5 = searches.fts5 ? await runComparisonMetrics(searches.fts5, queries, k) : undefined;\n228: \n229:   return {\n230:     legacy,\n231:     packed,\n232:     fts5,\n233:     packedAtLeastLegacy:\n234:       packed.mrr5 >= legacy.mrr5 &&\n235:       packed.ndcg10 >= legacy.ndcg10 &&\n236:       packed.recall20 >= legacy.recall20,\n237:     titleSignalRestored: packed.hitRate1 >= legacy.hitRate1,\n238:   };\n239: }\n240: \n241: async function runComparisonMetrics(\n242:   searchFn: BM25SearchFn,\n243:   queries: BM25ComparisonQuery[],\n244:   k: number,\n245: ): Promise<BM25BaselineMetrics> {\n246:   const fetchLimit = Math.max(20, k, 10);\n247:   let totalMRR = 0;\n248:   let totalNDCG = 0;\n249:   let totalRecall = 0;\n250:   let totalHitRate = 0;\n251: \n252:   for (const q of queries) {\n253:     const rawResults = await Promise.resolve(searchFn(q.query, fetchLimit));\n254:     const evalResults: EvalResult[] = rawResults.map((r, idx) => ({\n255:       memoryId: r.id,\n256:       score: r.score,\n257:       rank: idx + 1,\n258:     }));\n259: \n260:     const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({\n261:       queryId: r.queryId,\n262:       memoryId: r.memoryId,\n263:       relevance: r.relevance,\n264:     }));\n265: \n266:     totalMRR += computeMRR(evalResults, groundTruth, 5);\n267:     totalNDCG += computeNDCG(evalResults, groundTruth, 10);\n268:     totalRecall += computeRecall(evalResults, groundTruth, k);\n269:     totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n270:   }\n271: \n272:   const safeCount = queries.length > 0 ? queries.length : 1;\n273:   return {\n274:     mrr5: totalMRR / safeCount,\n275:     ndcg10: totalNDCG / safeCount,\n276:     recall20: totalRecall / safeCount,\n277:     hitRate1: totalHitRate / safeCount,\n278:   };\n279: }\n280: \n281: /* ───────────────────────────────────────────────────────────────\n282:    2a. RELATIVE CONTINGENCY (Spec-Compliant)\n283:    Compares BM25 MRR@5 as a percentage of hybrid MRR@5.\n284:    Spec: \"BM25 >= 80% of hybrid MRR@5\" → PAUSE.\n285: ──────────────────────────────────────────────────────────────── */\n286: \n287: /**\n288:  * Evaluate BM25 performance relative to hybrid MRR@5 (spec-compliant).\n289:  *\n290:  * The spec defines contingency thresholds as ratios:\n291:  *   ratio = bm25MRR / hybridMRR\n292:  *\n293:  *   ratio >= 0.80 → PAUSE\n294:  *     BM25 achieves ≥80% of hybrid — multi-channel adds little value.\n295:  *\n296:  *   ratio 0.50–0.79 → RATIONALIZE\n297:  *     BM25 achieves 50-79% of hybrid — channels need per-channel evidence.\n298:  *\n299:  *   ratio < 0.50 → PROCEED\n300:  *     BM25 achieves <50% of hybrid — multi-channel clearly justified.\n301:  *\n302:  * @param bm25MRR   - BM25-only MRR@5 (must be in [0, 1]).\n303:  * @param hybridMRR - Hybrid/multi-channel MRR@5 (must be in (0, 1]).\n304:  * @returns ContingencyDecision with ratio, mode='relative', and interpretation.\n305:  */\n306: export function evaluateContingencyRelative(\n307:   bm25MRR: number,\n308:   hybridMRR: number,\n309: ): ContingencyDecision {\n310:   if (!Number.isFinite(bm25MRR) || !Number.isFinite(hybridMRR) || hybridMRR <= 0) {\n311:     return {\n312:       bm25MRR,\n313:       hybridMRR,\n314:       ratio: 0,\n315:       mode: 'relative',\n316:       threshold: '<0.5',\n317:       action: 'PROCEED',\n318:       interpretation:\n319:         'Hybrid/BM25 MRR@5 is non-finite, zero, or negative — cannot compute meaningful ratio. ' +\n320:         'Defaulting to PROCEED until hybrid baseline is established.',\n321:     };\n322:   }\n323: \n324:   const ratio = bm25MRR / hybridMRR;\n325: \n326:   if (ratio >= 0.80) {\n327:     return {\n328:       bm25MRR,\n329:       hybridMRR,\n330:       ratio,\n331:       mode: 'relative',\n332:       threshold: '>=0.8',\n333:       action: 'PAUSE',\n334:       interpretation:\n335:         `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n336:         `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n337:         'The multi-channel architecture adds marginal value over keyword search alone. ' +\n338:         'PAUSE Sprints 3-7 and evaluate whether the complexity is warranted.',\n339:     };\n340:   }\n341: \n342:   if (ratio >= 0.50) {\n343:     return {\n344:       bm25MRR,\n345:       hybridMRR,\n346:       ratio,\n347:       mode: 'relative',\n348:       threshold: '0.5-0.8',\n349:       action: 'RATIONALIZE',\n350:       interpretation:\n351:         `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n352:         `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n353:         'Each additional channel must show a statistically meaningful positive delta ' +\n354:         'in MRR@5. Track per-channel contribution and justify retained complexity.',\n355:     };\n356:   }\n357: \n358:   return {\n359:     bm25MRR,\n360:     hybridMRR,\n361:     ratio,\n362:     mode: 'relative',\n363:     threshold: '<0.5',\n364:     action: 'PROCEED',\n365:     interpretation:\n366:       `BM25 achieves only ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n367:       `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n368:       'Multi-channel retrieval provides substantial improvement over keyword search. ' +\n369:       'Proceed with hybrid search optimization.',\n370:   };\n371: }\n372: \n373: /* ───────────────────────────────────────────────────────────────\n374:    2b. BOOTSTRAP CONFIDENCE INTERVAL\n375:    Statistical significance testing for the contingency decision.\n376:    Uses bootstrap resampling to compute 95% CI for MRR@5.\n377: ──────────────────────────────────────────────────────────────── */\n378: \n379: /** Result of bootstrap confidence interval computation. */\n380: export interface BootstrapCIResult {\n381:   /** Point estimate (mean MRR@5 across all queries). */\n382:   pointEstimate: number;\n383:   /** Lower bound of 95% CI. */\n384:   ciLower: number;\n385:   /** Upper bound of 95% CI. */\n386:   ciUpper: number;\n387:   /** CI width (ciUpper - ciLower). Narrower is more confident. */\n388:   ciWidth: number;\n389:   /** Number of bootstrap iterations. */\n390:   iterations: number;\n391:   /** Number of queries in the sample. */\n392:   sampleSize: number;\n393:   /** Whether the CI excludes the contingency threshold boundaries.\n394:    *  true = the decision is statistically significant at p<0.05. */\n395:   isSignificant: boolean;\n396:   /** Which threshold boundary was tested. */\n397:   testedBoundary: number;\n398: }\n399: \n400: /**\n401:  * Compute bootstrap 95% confidence interval for MRR@5.\n402:  *\n403:  * Uses percentile bootstrap with 10,000 iterations (default).\n404:  * Statistical significance is determined by whether the CI\n405:  * excludes the nearest contingency threshold boundary.\n406:  *\n407:  * @param perQueryMRR - Array of per-query MRR@5 values (one per query).\n408:  * @param iterations - Number of bootstrap iterations (default: 10000).\n409:  * @returns BootstrapCIResult with CI bounds and significance.\n410:  */\n411: export function computeBootstrapCI(\n412:   perQueryMRR: number[],\n413:   iterations: number = 10000,\n414: ): BootstrapCIResult {\n415:   const safeIterations = Number.isFinite(iterations) ? Math.floor(iterations) : 0;\n416:   const boundedIterations = Math.min(safeIterations, 100_000);\n417:   // Filter out NaN/Infinity values to prevent poisoning bootstrap means\n418:   const cleanMRR = perQueryMRR.filter(v => Number.isFinite(v));\n419:   const n = cleanMRR.length;\n420:   if (n === 0) {\n421:     return {\n422:       pointEstimate: 0,\n423:       ciLower: 0,\n424:       ciUpper: 0,\n425:       ciWidth: 0,\n426:       iterations: Math.max(0, boundedIterations),\n427:       sampleSize: 0,\n428:       isSignificant: false,\n429:       testedBoundary: 0,\n430:     };\n431:   }\n432: \n433:   // Point estimate\n434:   const pointEstimate = cleanMRR.reduce((s, v) => s + v, 0) / n;\n435: \n436:   if (boundedIterations <= 0) {\n437:     return {\n438:       pointEstimate,\n439:       ciLower: pointEstimate,\n440:       ciUpper: pointEstimate,\n441:       ciWidth: 0,\n442:       iterations: 0,\n443:       sampleSize: n,\n444:       isSignificant: false,\n445:       testedBoundary: 0,\n446:     };\n447:   }\n448: \n449:   // Bootstrap resampling\n450:   const bootstrapMeans: number[] = [];\n451:   for (let i = 0; i < boundedIterations; i++) {\n452:     let sum = 0;\n453:     for (let j = 0; j < n; j++) {\n454:       sum += cleanMRR[Math.floor(Math.random() * n)];\n455:     }\n456:     bootstrapMeans.push(sum / n);\n457:   }\n458: \n459:   // Sort for percentile computation\n460:   bootstrapMeans.sort((a, b) => a - b);\n461: \n462:   // 95% CI = 2.5th and 97.5th percentiles\n463:   const lowerIdx = Math.ceil(boundedIterations * 0.025) - 1;\n464:   const upperIdx = Math.ceil(boundedIterations * 0.975) - 1;\n465:   const ciLower = bootstrapMeans[lowerIdx];\n466:   const ciUpper = bootstrapMeans[upperIdx];\n467: \n468:   // Determine nearest threshold boundary and test significance\n469:   let testedBoundary = 0;\n470:   let isSignificant = false;\n471: \n472:   if (pointEstimate >= 0.80) {\n473:     // Testing whether we're significantly above 0.80 (PAUSE)\n474:     testedBoundary = 0.80;\n475:     isSignificant = ciLower >= 0.80;\n476:   } else if (pointEstimate >= 0.50) {\n477:     // Testing RATIONALIZE band: CI should not cross either boundary\n478:     testedBoundary = pointEstimate >= 0.65 ? 0.80 : 0.50;\n479:     isSignificant = ciLower >= 0.50 && ciUpper < 0.80;\n480:   } else {\n481:     // Testing whether we're significantly below 0.50 (PROCEED)\n482:     testedBoundary = 0.50;\n483:     isSignificant = ciUpper < 0.50;\n484:   }\n485: \n486:   return {\n487:     pointEstimate,\n488:     ciLower,\n489:     ciUpper,\n490:     ciWidth: ciUpper - ciLower,\n491:     iterations: boundedIterations,\n492:     sampleSize: n,\n493:     isSignificant,\n494:     testedBoundary,\n495:   };\n496: }\n497: \n498: /* ───────────────────────────────────────────────────────────────\n499:    3. METRIC RECORDING\n500: ──────────────────────────────────────────────────────────────── */\n501: \n502: /**\n503:  * Record BM25 baseline metrics to the eval DB (eval_metric_snapshots table).\n504:  *\n505:  * Inserts one row per metric (mrr@5, ndcg@10, recall@20, hit_rate@1) plus\n506:  * one metadata row containing the full contingency decision.\n507:  *\n508:  * Channel is recorded as 'bm25' to distinguish from multi-channel runs.\n509:  *\n510:  * @param evalDb - An initialized better-sqlite3 Database instance.\n511:  * @param result - The BM25BaselineResult to persist.\n512:  */\n513: export function recordBaselineMetrics(\n514:   evalDb: Database.Database,\n515:   result: BM25BaselineResult,\n516: ): void {\n517:   // Use a synthetic eval_run_id for baseline runs: negative integer based on\n518:   // Timestamp to avoid collision with production run IDs (which start at 1).\n519:   const evalRunId = -(Date.parse(result.timestamp));\n520: \n521:   const insertSnapshot = evalDb.prepare(`\n522:     INSERT INTO eval_metric_snapshots\n523:       (eval_run_id, metric_name, metric_value, channel, query_count, metadata, created_at)\n524:     VALUES (?, ?, ?, ?, ?, ?, ?)\n525:   `);\n526: \n527:   const channel = 'bm25';\n528:   const createdAt = result.timestamp;\n529:   const queryCount = result.queryCount;\n530: \n531:   const writeAll = evalDb.transaction(() => {\n532:     // Core metrics\n533:     insertSnapshot.run(evalRunId, 'mrr@5',       result.metrics.mrr5,      channel, queryCount, null, createdAt);\n534:     insertSnapshot.run(evalRunId, 'ndcg@10',      result.metrics.ndcg10,    channel, queryCount, null, createdAt);\n535:     insertSnapshot.run(evalRunId, 'recall@20',    result.metrics.recall20,  channel, queryCount, null, createdAt);\n536:     insertSnapshot.run(evalRunId, 'hit_rate@1',   result.metrics.hitRate1,  channel, queryCount, null, createdAt);\n537: \n538:     // Contingency decision (stored as JSON metadata on a sentinel row)\n539:     const contingencyMeta = JSON.stringify(result.contingencyDecision);\n540:     insertSnapshot.run(\n541:       evalRunId,\n542:       'bm25_contingency_decision',\n543:       result.contingencyDecision.bm25MRR,\n544:       channel,\n545:       queryCount,\n546:       contingencyMeta,\n547:       createdAt,\n548:     );\n549:   });\n550: \n551:   writeAll();\n552: }\n553: \n554: /* ───────────────────────────────────────────────────────────────\n555:    4. BM25 BASELINE RUNNER\n556: ──────────────────────────────────────────────────────────────── */\n557: \n558: /**\n559:  * Run the BM25-only baseline measurement over the ground truth query set.\n560:  *\n561:  * IMPORTANT: This function requires a live, populated database to produce\n562:  * meaningful metrics. The injected `searchFn` must return results from\n563:  * the BM25/FTS5 path ONLY — vector, graph, and trigger channels must be\n564:  * explicitly disabled before calling.\n565:  *\n566:  * For testing without a live DB, inject a mock `searchFn` that returns\n567:  * deterministic results (see tests/bm25-baseline.vitest.ts).\n568:  *\n569:  * The ground truth relevance judgments use the dataset\n570:  * (ground-truth-data.ts) with real production memory IDs mapped via\n571:  * multi-strategy FTS5 matching (scripts/map-ground-truth-ids.ts).\n572:  * Each non-hard-negative query has 1-3 graded relevance entries\n573:  * (grades 3=highly relevant, 2=relevant, 1=partial).\n574:  *\n575:  * @param searchFn - Injected BM25-only search function (dependency injection).\n576:  * @param config   - Optional configuration overrides.\n577:  * @returns        - BM25BaselineResult with metrics, timestamp, and contingency.\n578:  */\n579: export async function runBM25Baseline(\n580:   searchFn: BM25SearchFn,\n581:   config: BM25BaselineConfig = {},\n582: ): Promise<BM25BaselineResult> {\n583:   const {\n584:     queryLimit,\n585:     k,\n586:     skipHardNegatives = false,\n587:   } = config;\n588: \n589:   // MRR always uses k=5 (contingency matrix is calibrated for MRR@5)\n590:   const mrrK = 5;\n591:   // Other metrics use k override if provided\n592:   const ndcgK  = k ?? 10;\n593:   const recallK = k ?? 20;\n594:   // Retrieval limit: fetch enough results for all metric cutoffs\n595:   const fetchLimit = Math.max(mrrK, ndcgK, recallK, 20);\n596: \n597:   // Select query set\n598:   let queries: GroundTruthQuery[] = GROUND_TRUTH_QUERIES;\n599:   if (skipHardNegatives) {\n600:     queries = queries.filter(q => q.category !== 'hard_negative');\n601:   }\n602:   if (queryLimit !== undefined && queryLimit > 0) {\n603:     queries = queries.slice(0, queryLimit);\n604:   }\n605: \n606:   const queryCount = queries.length;\n607: \n608:   // Accumulators for averaging across queries\n609:   let totalMRR    = 0;\n610:   let totalNDCG   = 0;\n611:   let totalRecall = 0;\n612:   let totalHitRate = 0;\n613: \n614:   // Collect per-query MRR for bootstrap CI\n615:   const perQueryMRR: number[] = [];\n616: \n617:   for (const q of queries) {\n618:     // Run BM25-only search (channels: bm25/fts only, no vector/graph/trigger)\n619:     const rawResults = await Promise.resolve(searchFn(q.query, fetchLimit));\n620: \n621:     // Convert to EvalResult[] (1-based ranks by insertion order)\n622:     const evalResults: EvalResult[] = rawResults.map((r, idx) => ({\n623:       memoryId: r.id,\n624:       score: r.score,\n625:       rank: idx + 1,\n626:     }));\n627: \n628:     // Build ground truth for this query (real production memory IDs).\n629:     const groundTruth: GroundTruthEntry[] = buildQueryGroundTruth(q.id);\n630: \n631:     // Compute per-query metrics (hard negatives contribute 0 to all metrics\n632:     // Since their ground truth is empty — which is the correct behavior)\n633:     const qMRR = computeMRR(evalResults, groundTruth, mrrK);\n634:     perQueryMRR.push(qMRR);\n635: \n636:     totalMRR     += qMRR;\n637:     totalNDCG    += computeNDCG(evalResults, groundTruth, ndcgK);\n638:     totalRecall  += computeRecall(evalResults, groundTruth, recallK);\n639:     totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n640:   }\n641: \n642:   // Average across all queries (safely handle 0 queries)\n643:   const safeCount = queryCount > 0 ? queryCount : 1;\n644: \n645:   const metrics: BM25BaselineMetrics = {\n646:     mrr5:     totalMRR    / safeCount,\n647:     ndcg10:   totalNDCG   / safeCount,\n648:     recall20: totalRecall / safeCount,\n649:     hitRate1: totalHitRate / safeCount,\n650:   };\n651: \n652:   const timestamp = new Date().toISOString();\n653:   const contingencyDecision = evaluateContingency(metrics.mrr5);\n654: \n655:   // Compute bootstrap 95% CI for statistical significance (: p<0.05)\n656:   const bootstrapCI = computeBootstrapCI(perQueryMRR);\n657: \n658:   return {\n659:     metrics,\n660:     queryCount,\n661:     timestamp,\n662:     contingencyDecision,\n663:     perQueryMRR,\n664:     bootstrapCI,\n665:   };\n666: }\n667: \n668: /* ───────────────────────────────────────────────────────────────\n669:    5. INTERNAL HELPERS\n670: ──────────────────────────────────────────────────────────────── */\n671: \n672: /**\n673:  * Build GroundTruthEntry[] for a single query from the relevance dataset.\n674:  *\n675:  * Hard-negative queries have no relevant results (empty array).\n676:  * Non-hard-negative queries have 1-3 graded relevance entries mapped\n677:  * to real production memory IDs via FTS5 matching.\n678:  */\n679: function buildQueryGroundTruth(queryId: number): GroundTruthEntry[] {\n680:   const q = GROUND_TRUTH_QUERIES.find(g => g.id === queryId);\n681:   if (!q || q.category === 'hard_negative') {\n682:     return [];\n683:   }\n684: \n685:   // Return all relevance entries for this query (graded: 3=high, 2=relevant, 1=partial)\n686:   return GROUND_TRUTH_RELEVANCES\n687:     .filter(r => r.queryId === queryId)\n688:     .map(r => ({\n689:       queryId: r.queryId,\n690:       memoryId: r.memoryId,\n691:       relevance: r.relevance,\n692:     }));\n693: }\n\n(End of file - total 693 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25-Only Baseline Runner\n// ───────────────────────────────────────────────────────────────\n//\n// Runs the ground truth query set through the BM25/FTS5-only\n// Search path (disabling vector, graph, and trigger channels)\n// And computes baseline metrics. Records results in eval DB.\n//\n// The baseline measurement establishes the \"floor\" — what simple\n// Keyword search achieves without any semantic, graph, or trigger\n// Augmentation.\n//\n// Design notes:\n//   - The search function is injected as a dependency so tests\n// Can use mocks without a live DB.\n//   - The contingency decision matrix turns the measured MRR@5\n// Into an actionable gate: PAUSE / RATIONALIZE / PROCEED.\n//   - recordBaselineMetrics() is a pure DB write — no network I/O.\nimport type Database from 'better-sqlite3';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25-Only Baseline Runner\n// ───────────────────────────────────────────────────────────────\n//\n// Runs the ground truth query set through the BM25/FTS5-only\n// Search path (disabling vector, graph, and trigger channels)\n// And computes baseline metrics. Records results in eval DB.\n//\n// The baseline measurement establishes the \"floor\" — what simple\n// Keyword search achieves without any semantic, graph, or trigger\n// Augmentation.\n//\n// Design notes:\n//   - The search function is injected as a dependency so tests\n// Can use mocks without a live DB.\n//   - The contingency decision matrix turns the measured MRR@5\n// Into an actionable gate: PAUSE / RATIONALIZE / PROCEED.\n//   - recordBaselineMetrics() is a pure DB write — no network I/O.\nimport type Database from 'better-sqlite3';\n\nimport {\n  computeMRR,\n  computeNDCG,\n  computeRecall,\n  computeHitRate,\n  type EvalResult,\n  type GroundTruthEntry,\n} from './eval-metrics.js';\nimport {\n  GROUND_TRUTH_QUERIES,\n  GROUND_TRUTH_RELEVANCES,\n  type GroundTruthQuery,\n} from './ground-truth-data.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. PUBLIC TYPES\n──────────────────────────────────────────────────────────────── */\n\n/** Configuration options for the BM25 baseline runner. */\nexport interface BM25BaselineConfig {\n  /** Maximum number of queries to run. Defaults to all 110. */\n  queryLimit?: number;\n  /** Top-K cutoff for NDCG and Recall metrics. MRR always uses k=5 for contingency compatibility. */\n  k?: number;\n  /** Exclude hard-negative queries from the run. Default: false. */\n  skipHardNegatives?: boolean;\n}\n\n/** Metrics produced by a single BM25 baseline run. */\nexport interface BM25BaselineMetrics {\n  mrr5: number;\n  /** NDCG at configured K (default 10). Named ndcg10 for backwards compatibility. */\n  ndcg10: number;\n  /** Recall at configured K (default 20). Named recall20 for backwards compatibility. */\n  recall20: number;\n  hitRate1: number;\n}\n\n/** Full result returned by runBM25Baseline(). */\nexport interface BM25BaselineResult {\n  metrics: BM25BaselineMetrics;\n  queryCount: number;\n  timestamp: string;\n  contingencyDecision: ContingencyDecision;\n  /** Per-query MRR@5 values for bootstrap CI computation. */\n  perQueryMRR?: number[];\n  /** Bootstrap 95% CI for MRR@5 (computed if perQueryMRR available). */\n  bootstrapCI?: BootstrapCIResult;\n}\n\n/** Decision produced by evaluateContingency() or evaluateContingencyRelative(). */\nexport interface ContingencyDecision {\n  /** The MRR@5 value used to derive the decision. */\n  bm25MRR: number;\n  /** Human-readable threshold band: '>=0.8' | '0.5-0.8' | '<0.5'. */\n  threshold: string;\n  /** Gate action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED'. */\n  action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED';\n  /** Plain-language interpretation for humans reading the exit gate report. */\n  interpretation: string;\n  /** Comparison mode: 'absolute' (the rollout) or 'relative' (the original rollout+). */\n  mode?: 'absolute' | 'relative';\n  /** Hybrid MRR@5 used as reference (relative mode only). */\n  hybridMRR?: number;\n  /** BM25/hybrid ratio (relative mode only). */\n  ratio?: number;\n}\n\n/**\n * A single search result as returned by the injected BM25 search function.\n * Mirrors the shape used in hybrid-search.ts so callers can reuse the same\n * function reference.\n */\nexport interface BM25SearchResult {\n  /** Memory ID (numeric). */\n  id: number;\n  /** Retrieval score (raw BM25 / FTS5 rank). */\n  score: number;\n  /** Source channel identifier. Expected: 'bm25' or 'fts'. */\n  source: string;\n}\n\n/**\n * A relevance judgment loaded from eval_ground_truth for a single query.\n * Used to evaluate results returned by the injected search function.\n */\nexport interface QueryGroundTruth {\n  queryId: number;\n  memoryId: number;\n  relevance: number;\n}\n\n/** Query and graded relevance data for fixture-backed engine comparisons. */\nexport interface BM25ComparisonQuery {\n  id: number;\n  query: string;\n  relevances: QueryGroundTruth[];\n}\n\n/** Search functions used to compare lexical engines on the same query set. */\nexport interface BM25EngineComparisonSearches {\n  legacy: BM25SearchFn;\n  packed: BM25SearchFn;\n  fts5?: BM25SearchFn;\n}\n\n/** Metrics and pass/fail signals for a packed-vs-legacy BM25 comparison. */\nexport interface BM25EngineComparisonResult {\n  legacy: BM25BaselineMetrics;\n  packed: BM25BaselineMetrics;\n  fts5?: BM25BaselineMetrics;\n  packedAtLeastLegacy: boolean;\n  titleSignalRestored: boolean;\n}\n\n/**\n * Injected BM25-only search function signature.\n *\n * The function receives the query text and a limit and must return results\n * using ONLY the BM25/FTS5 channel (vector, graph, trigger disabled).\n * For production use, wire up the FTS5 path from hybrid-search with all\n * other channels explicitly disabled.\n */\nexport type BM25SearchFn = (\n  query: string,\n  limit: number,\n) => BM25SearchResult[] | Promise<BM25SearchResult[]>;\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONTINGENCY DECISION MATRIX\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Evaluate the BM25 MRR@5 value against the contingency decision matrix.\n *\n * Matrix:\n *   MRR@5 >= 0.80 → PAUSE\n *     BM25 alone is very strong — semantic/graph additions may not\n *     justify the added complexity. Evaluate whether the multi-channel\n *     architecture is warranted before proceeding.\n *\n *   MRR@5 0.50–0.79 → RATIONALIZE\n *     BM25 is moderate — semantic/graph channels must demonstrably\n *     improve over this baseline. Each additional channel needs\n *     positive delta evidence.\n *\n *   MRR@5 < 0.50 → PROCEED\n *     BM25 alone is weak — strong justification for multi-channel\n *     retrieval. Proceed with hybrid search implementation.\n *\n * @param bm25MRR - The measured MRR@5 value (must be in [0, 1]).\n * @returns ContingencyDecision with threshold label, action, and interpretation.\n */\nexport function evaluateContingency(bm25MRR: number): ContingencyDecision {\n  if (bm25MRR >= 0.80) {\n    return {\n      bm25MRR,\n      mode: 'absolute',\n      threshold: '>=0.8',\n      action: 'PAUSE',\n      interpretation:\n        'BM25 alone is very strong — semantic/graph additions may not justify complexity. ' +\n        'Re-evaluate whether a multi-channel architecture is warranted before proceeding with ' +\n        'additional retrieval channels. Consider whether the marginal gain from vector/graph ' +\n        'search is worth the operational overhead.',\n    };\n  }\n\n  if (bm25MRR >= 0.50) {\n    return {\n      bm25MRR,\n      mode: 'absolute',\n      threshold: '0.5-0.8',\n      action: 'RATIONALIZE',\n      interpretation:\n        'BM25 is moderate — semantic/graph channels should demonstrably improve over this baseline. ' +\n        'Each additional channel (vector, graph, trigger) must show a statistically meaningful ' +\n        'positive delta in MRR@5 before adoption. Track per-channel contribution carefully.',\n    };\n  }\n\n  return {\n    bm25MRR,\n    mode: 'absolute',\n    threshold: '<0.5',\n    action: 'PROCEED',\n    interpretation:\n      'BM25 alone is weak — strong justification for multi-channel retrieval. ' +\n      'The low keyword-only baseline confirms that semantic and graph augmentation ' +\n      'adds meaningful value. Proceed with hybrid search implementation.',\n  };\n}\n\n/**\n * Compare lexical engines against a caller-provided fixture query set.\n * The helper reuses the baseline metrics so relevance gates stay aligned\n * with the production BM25-only evaluation report.\n */\nexport async function runBM25EngineComparison(\n  searches: BM25EngineComparisonSearches,\n  queries: BM25ComparisonQuery[],\n  config: Pick<BM25BaselineConfig, 'k'> = {},\n): Promise<BM25EngineComparisonResult> {\n  const k = config.k ?? 20;\n  const legacy = await runComparisonMetrics(searches.legacy, queries, k);\n  const packed = await runComparisonMetrics(searches.packed, queries, k);\n  const fts5 = searches.fts5 ? await runComparisonMetrics(searches.fts5, queries, k) : undefined;\n\n  return {\n    legacy,\n    packed,\n    fts5,\n    packedAtLeastLegacy:\n      packed.mrr5 >= legacy.mrr5 &&\n      packed.ndcg10 >= legacy.ndcg10 &&\n      packed.recall20 >= legacy.recall20,\n    titleSignalRestored: packed.hitRate1 >= legacy.hitRate1,\n  };\n}\n\nasync function runComparisonMetrics(\n  searchFn: BM25SearchFn,\n  queries: BM25ComparisonQuery[],\n  k: number,\n): Promise<BM25BaselineMetrics> {\n  const fetchLimit = Math.max(20, k, 10);\n  let totalMRR = 0;\n  let totalNDCG = 0;\n  let totalRecall = 0;\n  let totalHitRate = 0;\n\n  for (const q of queries) {\n    const rawResults = await Promise.resolve(searchFn(q.query, fetchLimit));\n    const evalResults: EvalResult[] = rawResults.map((r, idx) => ({\n      memoryId: r.id,\n      score: r.score,\n      rank: idx + 1,\n    }));\n\n    const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({\n      queryId: r.queryId,\n      memoryId: r.memoryId,\n      relevance: r.relevance,\n    }));\n\n    totalMRR += computeMRR(evalResults, groundTruth, 5);\n    totalNDCG += computeNDCG(evalResults, groundTruth, 10);\n    totalRecall += computeRecall(evalResults, groundTruth, k);\n    totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n  }\n\n  const safeCount = queries.length > 0 ? queries.length : 1;\n  return {\n    mrr5: totalMRR / safeCount,\n    ndcg10: totalNDCG / safeCount,\n    recall20: totalRecall / safeCount,\n    hitRate1: totalHitRate / safeCount,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2a. RELATIVE CONTINGENCY (Spec-Compliant)\n   Compares BM25 MRR@5 as a percentage of hybrid MRR@5.\n   Spec: \"BM25 >= 80% of hybrid MRR@5\" → PAUSE.\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Evaluate BM25 performance relative to hybrid MRR@5 (spec-compliant).\n *\n * The spec defines contingency thresholds as ratios:\n *   ratio = bm25MRR / hybridMRR\n *\n *   ratio >= 0.80 → PAUSE\n *     BM25 achieves ≥80% of hybrid — multi-channel adds little value.\n *\n *   ratio 0.50–0.79 → RATIONALIZE\n *     BM25 achieves 50-79% of hybrid — channels need per-channel evidence.\n *\n *   ratio < 0.50 → PROCEED\n *     BM25 achieves <50% of hybrid — multi-channel clearly justified.\n *\n * @param bm25MRR   - BM25-only MRR@5 (must be in [0, 1]).\n * @param hybridMRR - Hybrid/multi-channel MRR@5 (must be in (0, 1]).\n * @returns ContingencyDecision with ratio, mode='relative', and interpretation.\n */\nexport function evaluateContingencyRelative(\n  bm25MRR: number,\n  hybridMRR: number,\n): ContingencyDecision {\n  if (!Number.isFinite(bm25MRR) || !Number.isFinite(hybridMRR) || hybridMRR <= 0) {\n    return {\n      bm25MRR,\n      hybridMRR,\n      ratio: 0,\n      mode: 'relative',\n      threshold: '<0.5',\n      action: 'PROCEED',\n      interpretation:\n        'Hybrid/BM25 MRR@5 is non-finite, zero, or negative — cannot compute meaningful ratio. ' +\n        'Defaulting to PROCEED until hybrid baseline is established.',\n    };\n  }\n\n  const ratio = bm25MRR / hybridMRR;\n\n  if (ratio >= 0.80) {\n    return {\n      bm25MRR,\n      hybridMRR,\n      ratio,\n      mode: 'relative',\n      threshold: '>=0.8',\n      action: 'PAUSE',\n      interpretation:\n        `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n        `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n        'The multi-channel architecture adds marginal value over keyword search alone. ' +\n        'PAUSE Sprints 3-7 and evaluate whether the complexity is warranted.',\n    };\n  }\n\n  if (ratio >= 0.50) {\n    return {\n      bm25MRR,\n      hybridMRR,\n      ratio,\n      mode: 'relative',\n      threshold: '0.5-0.8',\n      action: 'RATIONALIZE',\n      interpretation:\n        `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n        `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n        'Each additional channel must show a statistically meaningful positive delta ' +\n        'in MRR@5. Track per-channel contribution and justify retained complexity.',\n    };\n  }\n\n  return {\n    bm25MRR,\n    hybridMRR,\n    ratio,\n    mode: 'relative',\n    threshold: '<0.5',\n    action: 'PROCEED',\n    interpretation:\n      `BM25 achieves only ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n      `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n      'Multi-channel retrieval provides substantial improvement over keyword search. ' +\n      'Proceed with hybrid search optimization.',\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2b. BOOTSTRAP CONFIDENCE INTERVAL\n   Statistical significance testing for the contingency decision.\n   Uses bootstrap resampling to compute 95% CI for MRR@5.\n──────────────────────────────────────────────────────────────── */\n\n/** Result of bootstrap confidence interval computation. */\nexport interface BootstrapCIResult {\n  /** Point estimate (mean MRR@5 across all queries). */\n  pointEstimate: number;\n  /** Lower bound of 95% CI. */\n  ciLower: number;\n  /** Upper bound of 95% CI. */\n  ciUpper: number;\n  /** CI width (ciUpper - ciLower). Narrower is more confident. */\n  ciWidth: number;\n  /** Number of bootstrap iterations. */\n  iterations: number;\n  /** Number of queries in the sample. */\n  sampleSize: number;\n  /** Whether the CI excludes the contingency threshold boundaries.\n   *  true = the decision is statistically significant at p<0.05. */\n  isSignificant: boolean;\n  /** Which threshold boundary was tested. */\n  testedBoundary: number;\n}\n\n/**\n * Compute bootstrap 95% confidence interval for MRR@5.\n *\n * Uses percentile bootstrap with 10,000 iterations (default).\n * Statistical significance is determined by whether the CI\n * excludes the nearest contingency threshold boundary.\n *\n * @param perQueryMRR - Array of per-query MRR@5 values (one per query).\n * @param iterations - Number of bootstrap iterations (default: 10000).\n * @returns BootstrapCIResult with CI bounds and significance.\n */\nexport function computeBootstrapCI(\n  perQueryMRR: number[],\n  iterations: number = 10000,\n): BootstrapCIResult {\n  const safeIterations = Number.isFinite(iterations) ? Math.floor(iterations) : 0;\n  const boundedIterations = Math.min(safeIterations, 100_000);\n  // Filter out NaN/Infinity values to prevent poisoning bootstrap means\n  const cleanMRR = perQueryMRR.filter(v => Number.isFinite(v));\n  const n = cleanMRR.length;\n  if (n === 0) {\n    return {\n      pointEstimate: 0,\n      ciLower: 0,\n      ciUpper: 0,\n      ciWidth: 0,\n      iterations: Math.max(0, boundedIterations),\n      sampleSize: 0,\n      isSignificant: false,\n      testedBoundary: 0,\n    };\n  }\n\n  // Point estimate\n  const pointEstimate = cleanMRR.reduce((s, v) => s + v, 0) / n;\n\n  if (boundedIterations <= 0) {\n    return {\n      pointEstimate,\n      ciLower: pointEstimate,\n      ciUpper: pointEstimate,\n      ciWidth: 0,\n      iterations: 0,\n      sampleSize: n,\n      isSignificant: false,\n      testedBoundary: 0,\n    };\n  }\n\n  // Bootstrap resampling\n  const bootstrapMeans: number[] = [];\n  for (let i = 0; i < boundedIterations; i++) {\n    let sum = 0;\n    for (let j = 0; j < n; j++) {\n      sum += cleanMRR[Math.floor(Math.random() * n)];\n    }\n    bootstrapMeans.push(sum / n);\n  }\n\n  // Sort for percentile computation\n  bootstrapMeans.sort((a, b) => a - b);\n\n  // 95% CI = 2.5th and 97.5th percentiles\n  const lowerIdx = Math.ceil(boundedIterations * 0.025) - 1;\n  const upperIdx = Math.ceil(boundedIterations * 0.975) - 1;\n  const ciLower = bootstrapMeans[lowerIdx];\n  const ciUpper = bootstrapMeans[upperIdx];\n\n  // Determine nearest threshold boundary and test significance\n  let testedBoundary = 0;\n  let isSignificant = false;\n\n  if (pointEstimate >= 0.80) {\n    // Testing whether we're significantly above 0.80 (PAUSE)\n    testedBoundary = 0.80;\n    isSignificant = ciLower >= 0.80;\n  } else if (pointEstimate >= 0.50) {\n    // Testing RATIONALIZE band: CI should not cross either boundary\n    testedBoundary = pointEstimate >= 0.65 ? 0.80 : 0.50;\n    isSignificant = ciLower >= 0.50 && ciUpper < 0.80;\n  } else {\n    // Testing whether we're significantly below 0.50 (PROCEED)\n    testedBoundary = 0.50;\n    isSignificant = ciUpper < 0.50;\n  }\n\n  return {\n    pointEstimate,\n    ciLower,\n    ciUpper,\n    ciWidth: ciUpper - ciLower,\n    iterations: boundedIterations,\n    sampleSize: n,\n    isSignificant,\n    testedBoundary,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. METRIC RECORDING\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Record BM25 baseline metrics to the eval DB (eval_metric_snapshots table).\n *\n * Inserts one row per metric (mrr@5, ndcg@10, recall@20, hit_rate@1) plus\n * one metadata row containing the full contingency decision.\n *\n * Channel is recorded as 'bm25' to distinguish from multi-channel runs.\n *\n * @param evalDb - An initialized better-sqlite3 Database instance.\n * @param result - The BM25BaselineResult to persist.\n */\nexport function recordBaselineMetrics(\n  evalDb: Database.Database,\n  result: BM25BaselineResult,\n): void {\n  // Use a synthetic eval_run_id for baseline runs: negative integer based on\n  // Timestamp to avoid collision with production run IDs (which start at 1).\n  const evalRunId = -(Date.parse(result.timestamp));\n\n  const insertSnapshot = evalDb.prepare(`\n    INSERT INTO eval_metric_snapshots\n      (eval_run_id, metric_name, metric_value, channel, query_count, metadata, created_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const channel = 'bm25';\n  const createdAt = result.timestamp;\n  const queryCount = result.queryCount;\n\n  const writeAll = evalDb.transaction(() => {\n    // Core metrics\n    insertSnapshot.run(evalRunId, 'mrr@5',       result.metrics.mrr5,      channel, queryCount, null, createdAt);\n    insertSnapshot.run(evalRunId, 'ndcg@10',      result.metrics.ndcg10,    channel, queryCount, null, createdAt);\n    insertSnapshot.run(evalRunId, 'recall@20',    result.metrics.recall20,  channel, queryCount, null, createdAt);\n    insertSnapshot.run(evalRunId, 'hit_rate@1',   result.metrics.hitRate1,  channel, queryCount, null, createdAt);\n\n    // Contingency decision (stored as JSON metadata on a sentinel row)\n    const contingencyMeta = JSON.stringify(result.contingencyDecision);\n    insertSnapshot.run(\n      evalRunId,\n      'bm25_contingency_decision',\n      result.contingencyDecision.bm25MRR,\n      channel,\n      queryCount,\n      contingencyMeta,\n      createdAt,\n    );\n  });\n\n  writeAll();\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. BM25 BASELINE RUNNER\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Run the BM25-only baseline measurement over the ground truth query set.\n *\n * IMPORTANT: This function requires a live, populated database to produce\n * meaningful metrics. The injected `searchFn` must return results from\n * the BM25/FTS5 path ONLY — vector, graph, and trigger channels must be\n * explicitly disabled before calling.\n *\n * For testing without a live DB, inject a mock `searchFn` that returns\n * deterministic results (see tests/bm25-baseline.vitest.ts).\n *\n * The ground truth relevance judgments use the dataset\n * (ground-truth-data.ts) with real production memory IDs mapped via\n * multi-strategy FTS5 matching (scripts/map-ground-truth-ids.ts).\n * Each non-hard-negative query has 1-3 graded relevance entries\n * (grades 3=highly relevant, 2=relevant, 1=partial).\n *\n * @param searchFn - Injected BM25-only search function (dependency injection).\n * @param config   - Optional configuration overrides.\n * @returns        - BM25BaselineResult with metrics, timestamp, and contingency.\n */\nexport async function runBM25Baseline(\n  searchFn: BM25SearchFn,\n  config: BM25BaselineConfig = {},\n): Promise<BM25BaselineResult> {\n  const {\n    queryLimit,\n    k,\n    skipHardNegatives = false,\n  } = config;\n\n  // MRR always uses k=5 (contingency matrix is calibrated for MRR@5)\n  const mrrK = 5;\n  // Other metrics use k override if provided\n  const ndcgK  = k ?? 10;\n  const recallK = k ?? 20;\n  // Retrieval limit: fetch enough results for all metric cutoffs\n  const fetchLimit = Math.max(mrrK, ndcgK, recallK, 20);\n\n  // Select query set\n  let queries: GroundTruthQuery[] = GROUND_TRUTH_QUERIES;\n  if (skipHardNegatives) {\n    queries = queries.filter(q => q.category !== 'hard_negative');\n  }\n  if (queryLimit !== undefined && queryLimit > 0) {\n    queries = queries.slice(0, queryLimit);\n  }\n\n  const queryCount = queries.length;\n\n  // Accumulators for averaging across queries\n  let totalMRR    = 0;\n  let totalNDCG   = 0;\n  let totalRecall = 0;\n  let totalHitRate = 0;\n\n  // Collect per-query MRR for bootstrap CI\n  const perQueryMRR: number[] = [];\n\n  for (const q of queries) {\n    // Run BM25-only search (channels: bm25/fts only, no vector/graph/trigger)\n    const rawResults = await Promise.resolve(searchFn(q.query, fetchLimit));\n\n    // Convert to EvalResult[] (1-based ranks by insertion order)\n    const evalResults: EvalResult[] = rawResults.map((r, idx) => ({\n      memoryId: r.id,\n      score: r.score,\n      rank: idx + 1,\n    }));\n\n    // Build ground truth for this query (real production memory IDs).\n    const groundTruth: GroundTruthEntry[] = buildQueryGroundTruth(q.id);\n\n    // Compute per-query metrics (hard negatives contribute 0 to all metrics\n    // Since their ground truth is empty — which is the correct behavior)\n    const qMRR = computeMRR(evalResults, groundTruth, mrrK);\n    perQueryMRR.push(qMRR);\n\n    totalMRR     += qMRR;\n    totalNDCG    += computeNDCG(evalResults, groundTruth, ndcgK);\n    totalRecall  += computeRecall(evalResults, groundTruth, recallK);\n    totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n  }\n\n  // Average across all queries (safely handle 0 queries)\n  const safeCount = queryCount > 0 ? queryCount : 1;\n\n  const metrics: BM25BaselineMetrics = {\n    mrr5:     totalMRR    / safeCount,\n    ndcg10:   totalNDCG   / safeCount,\n    recall20: totalRecall / safeCount,\n    hitRate1: totalHitRate / safeCount,\n  };\n\n  const timestamp = new Date().toISOString();\n  const contingencyDecision = evaluateContingency(metrics.mrr5);\n\n  // Compute bootstrap 95% CI for statistical significance (: p<0.05)\n  const bootstrapCI = computeBootstrapCI(perQueryMRR);\n\n  return {\n    metrics,\n    queryCount,\n    timestamp,\n    contingencyDecision,\n    perQueryMRR,\n    bootstrapCI,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. INTERNAL HELPERS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Build GroundTruthEntry[] for a single query from the relevance dataset.\n *\n * Hard-negative queries have no relevant results (empty array).\n * Non-hard-negative queries have 1-3 graded relevance entries mapped\n * to real production memory IDs via FTS5 matching.\n */\nfunction buildQueryGroundTruth(queryId: number): GroundTruthEntry[] {\n  const q = GROUND_TRUTH_QUERIES.find(g => g.id === queryId);\n  if (!q || q.category === 'hard_negative') {\n    return [];\n  }\n\n  // Return all relevance entries for this query (graded: 3=high, 2=relevant, 1=partial)\n  return GROUND_TRUTH_RELEVANCES\n    .filter(r => r.queryId === queryId)\n    .map(r => ({\n      queryId: r.queryId,\n      memoryId: r.memoryId,\n      relevance: r.relevance,\n    }));\n}","lineStart":1,"lineEnd":693,"totalLines":693,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","time":{"start":1781151913729,"end":1781151913740}},"metadata":{"openai":{"itemId":"fc_0e1f5eb53c6bb8d3016a2a38a9aa9c819192870eab073b78a8"}},"id":"prt_eb4ed56ff001uawkbn6nxktobn","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed3406001QSvMXtyij9Xo5H"}}
{"type":"tool_use","timestamp":1781151913743,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"type":"tool","tool":"read","callID":"call_lCEwYvGzh5uXcEYatlUoSbTw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: BM25 Packed Engine Fixtures\n3: // ───────────────────────────────────────────────────────────────\n4: import type { BM25ComparisonQuery } from '../bm25-baseline.js';\n5: \n6: interface BM25PackedFixtureDocument {\n7:   id: number;\n8:   title: string;\n9:   content_text: string;\n10:   trigger_phrases: string[];\n11:   file_path: string;\n12: }\n13: \n14: interface CorpusFixtureOptions {\n15:   documentCount?: number;\n16:   targetIndexedBytes?: number;\n17: }\n18: \n19: const FIXTURE_FILLER = [\n20:   'the and of to in on at by from is it as was are be has had have been',\n21:   'this that these those not no do does did so if then than too very',\n22: ].join(' ');\n23: \n24: const GOLDEN_DOCUMENTS: BM25PackedFixtureDocument[] = [\n25:   {\n26:     id: 101,\n27:     title: 'Auth Guard Session Renewal',\n28:     content_text: 'Policy for renewing authenticated sessions and preserving access control context.',\n29:     trigger_phrases: ['auth guard', 'session renewal'],\n30:     file_path: 'specs/auth/session-renewal.md',\n31:   },\n32:   {\n33:     id: 102,\n34:     title: 'Cache Eviction Strategy',\n35:     content_text: 'Cache lifecycle and invalidation notes for retrieval pressure management.',\n36:     trigger_phrases: ['cache eviction', 'stale cache'],\n37:     file_path: 'specs/cache/eviction.md',\n38:   },\n39:   {\n40:     id: 103,\n41:     title: 'Trigger Phrase Backfill',\n42:     content_text: 'Backfill process for curated phrases and lexical discovery coverage.',\n43:     trigger_phrases: ['trigger phrase', 'phrase backfill'],\n44:     file_path: 'specs/search/trigger-backfill.md',\n45:   },\n46:   {\n47:     id: 104,\n48:     title: 'Vector Retention Policy',\n49:     content_text: 'Retention and retry behavior for vector embeddings and missing shard coverage.',\n50:     trigger_phrases: ['vector retention', 'embedding retry'],\n51:     file_path: 'specs/vector/retention.md',\n52:   },\n53:   {\n54:     id: 105,\n55:     title: 'Memory Search Ranking',\n56:     content_text: 'Ranking calibration for lexical search and semantic fusion channels.',\n57:     trigger_phrases: ['memory search', 'ranking calibration'],\n58:     file_path: 'specs/search/ranking.md',\n59:   },\n60:   {\n61:     id: 106,\n62:     title: 'Generic Operations Notes',\n63:     content_text: 'Auth guard appears repeatedly in a generic operational body auth guard auth guard auth guard.',\n64:     trigger_phrases: ['operations'],\n65:     file_path: 'specs/ops/generic.md',\n66:   },\n67: ];\n68: \n69: const GOLDEN_QUERIES: BM25ComparisonQuery[] = [\n70:   {\n71:     id: 1,\n72:     query: 'auth guard',\n73:     relevances: [{ queryId: 1, memoryId: 101, relevance: 3 }],\n74:   },\n75:   {\n76:     id: 2,\n77:     query: 'cache eviction',\n78:     relevances: [{ queryId: 2, memoryId: 102, relevance: 3 }],\n79:   },\n80:   {\n81:     id: 3,\n82:     query: 'trigger phrase backfill',\n83:     relevances: [{ queryId: 3, memoryId: 103, relevance: 3 }],\n84:   },\n85:   {\n86:     id: 4,\n87:     query: 'vector retention',\n88:     relevances: [{ queryId: 4, memoryId: 104, relevance: 3 }],\n89:   },\n90:   {\n91:     id: 5,\n92:     query: 'memory search ranking',\n93:     relevances: [{ queryId: 5, memoryId: 105, relevance: 3 }],\n94:   },\n95: ];\n96: \n97: function makeCorpusFiller(targetBytes: number): string {\n98:   const chunk = `${FIXTURE_FILLER} `;\n99:   return chunk.repeat(Math.max(1, Math.ceil(targetBytes / chunk.length))).slice(0, targetBytes);\n100: }\n101: \n102: function createCorpusSizedDocuments(options: CorpusFixtureOptions = {}): BM25PackedFixtureDocument[] {\n103:   const documentCount = options.documentCount ?? 10_245;\n104:   const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n105:   const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n106:   const sharedBody = makeCorpusFiller(bytesPerDocument);\n107:   const docs: BM25PackedFixtureDocument[] = [];\n108: \n109:   for (let i = 0; i < documentCount; i += 1) {\n110:     docs.push({\n111:       id: 10_000 + i,\n112:       title: `Corpus Fixture ${i}`,\n113:       content_text: sharedBody,\n114:       trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n115:       file_path: `fixtures/corpus/${i}.md`,\n116:     });\n117:   }\n118: \n119:   return docs;\n120: }\n121: \n122: function* iterateCorpusSizedDocuments(options: CorpusFixtureOptions = {}): Generator<BM25PackedFixtureDocument> {\n123:   const documentCount = options.documentCount ?? 10_245;\n124:   const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n125:   const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n126:   const sharedBody = makeCorpusFiller(bytesPerDocument);\n127: \n128:   for (let i = 0; i < documentCount; i += 1) {\n129:     yield {\n130:       id: 10_000 + i,\n131:       title: `Corpus Fixture ${i}`,\n132:       content_text: sharedBody,\n133:       trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n134:       file_path: `fixtures/corpus/${i}.md`,\n135:     };\n136:   }\n137: }\n138: \n139: function createPackedEvalDocuments(): BM25PackedFixtureDocument[] {\n140:   return GOLDEN_DOCUMENTS.map((doc) => ({ ...doc, trigger_phrases: [...doc.trigger_phrases] }));\n141: }\n142: \n143: function createPackedEvalQueries(): BM25ComparisonQuery[] {\n144:   return GOLDEN_QUERIES.map((query) => ({\n145:     ...query,\n146:     relevances: query.relevances.map((relevance) => ({ ...relevance })),\n147:   }));\n148: }\n149: \n150: export {\n151:   createCorpusSizedDocuments,\n152:   iterateCorpusSizedDocuments,\n153:   createPackedEvalDocuments,\n154:   createPackedEvalQueries,\n155: };\n156: \n157: export type {\n158:   BM25PackedFixtureDocument,\n159:   CorpusFixtureOptions,\n160: };\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: BM25 Packed Engine Fixtures\n// ───────────────────────────────────────────────────────────────\nimport type { BM25ComparisonQuery } from '../bm25-baseline.js';\n\ninterface BM25PackedFixtureDocument {\n  id: number;\n  title: string;\n  content_text: string;\n  trigger_phrases: string[];\n  file_path: string;\n}\n\ninterface CorpusFixtureOptions {\n  documentCount?: number;\n  targetIndexedBytes?: number;\n}\n\nconst FIXTURE_FILLER = [\n  'the and of to in on at by from is it as was are be has had have been',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: BM25 Packed Engine Fixtures\n// ───────────────────────────────────────────────────────────────\nimport type { BM25ComparisonQuery } from '../bm25-baseline.js';\n\ninterface BM25PackedFixtureDocument {\n  id: number;\n  title: string;\n  content_text: string;\n  trigger_phrases: string[];\n  file_path: string;\n}\n\ninterface CorpusFixtureOptions {\n  documentCount?: number;\n  targetIndexedBytes?: number;\n}\n\nconst FIXTURE_FILLER = [\n  'the and of to in on at by from is it as was are be has had have been',\n  'this that these those not no do does did so if then than too very',\n].join(' ');\n\nconst GOLDEN_DOCUMENTS: BM25PackedFixtureDocument[] = [\n  {\n    id: 101,\n    title: 'Auth Guard Session Renewal',\n    content_text: 'Policy for renewing authenticated sessions and preserving access control context.',\n    trigger_phrases: ['auth guard', 'session renewal'],\n    file_path: 'specs/auth/session-renewal.md',\n  },\n  {\n    id: 102,\n    title: 'Cache Eviction Strategy',\n    content_text: 'Cache lifecycle and invalidation notes for retrieval pressure management.',\n    trigger_phrases: ['cache eviction', 'stale cache'],\n    file_path: 'specs/cache/eviction.md',\n  },\n  {\n    id: 103,\n    title: 'Trigger Phrase Backfill',\n    content_text: 'Backfill process for curated phrases and lexical discovery coverage.',\n    trigger_phrases: ['trigger phrase', 'phrase backfill'],\n    file_path: 'specs/search/trigger-backfill.md',\n  },\n  {\n    id: 104,\n    title: 'Vector Retention Policy',\n    content_text: 'Retention and retry behavior for vector embeddings and missing shard coverage.',\n    trigger_phrases: ['vector retention', 'embedding retry'],\n    file_path: 'specs/vector/retention.md',\n  },\n  {\n    id: 105,\n    title: 'Memory Search Ranking',\n    content_text: 'Ranking calibration for lexical search and semantic fusion channels.',\n    trigger_phrases: ['memory search', 'ranking calibration'],\n    file_path: 'specs/search/ranking.md',\n  },\n  {\n    id: 106,\n    title: 'Generic Operations Notes',\n    content_text: 'Auth guard appears repeatedly in a generic operational body auth guard auth guard auth guard.',\n    trigger_phrases: ['operations'],\n    file_path: 'specs/ops/generic.md',\n  },\n];\n\nconst GOLDEN_QUERIES: BM25ComparisonQuery[] = [\n  {\n    id: 1,\n    query: 'auth guard',\n    relevances: [{ queryId: 1, memoryId: 101, relevance: 3 }],\n  },\n  {\n    id: 2,\n    query: 'cache eviction',\n    relevances: [{ queryId: 2, memoryId: 102, relevance: 3 }],\n  },\n  {\n    id: 3,\n    query: 'trigger phrase backfill',\n    relevances: [{ queryId: 3, memoryId: 103, relevance: 3 }],\n  },\n  {\n    id: 4,\n    query: 'vector retention',\n    relevances: [{ queryId: 4, memoryId: 104, relevance: 3 }],\n  },\n  {\n    id: 5,\n    query: 'memory search ranking',\n    relevances: [{ queryId: 5, memoryId: 105, relevance: 3 }],\n  },\n];\n\nfunction makeCorpusFiller(targetBytes: number): string {\n  const chunk = `${FIXTURE_FILLER} `;\n  return chunk.repeat(Math.max(1, Math.ceil(targetBytes / chunk.length))).slice(0, targetBytes);\n}\n\nfunction createCorpusSizedDocuments(options: CorpusFixtureOptions = {}): BM25PackedFixtureDocument[] {\n  const documentCount = options.documentCount ?? 10_245;\n  const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n  const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n  const sharedBody = makeCorpusFiller(bytesPerDocument);\n  const docs: BM25PackedFixtureDocument[] = [];\n\n  for (let i = 0; i < documentCount; i += 1) {\n    docs.push({\n      id: 10_000 + i,\n      title: `Corpus Fixture ${i}`,\n      content_text: sharedBody,\n      trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n      file_path: `fixtures/corpus/${i}.md`,\n    });\n  }\n\n  return docs;\n}\n\nfunction* iterateCorpusSizedDocuments(options: CorpusFixtureOptions = {}): Generator<BM25PackedFixtureDocument> {\n  const documentCount = options.documentCount ?? 10_245;\n  const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n  const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n  const sharedBody = makeCorpusFiller(bytesPerDocument);\n\n  for (let i = 0; i < documentCount; i += 1) {\n    yield {\n      id: 10_000 + i,\n      title: `Corpus Fixture ${i}`,\n      content_text: sharedBody,\n      trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n      file_path: `fixtures/corpus/${i}.md`,\n    };\n  }\n}\n\nfunction createPackedEvalDocuments(): BM25PackedFixtureDocument[] {\n  return GOLDEN_DOCUMENTS.map((doc) => ({ ...doc, trigger_phrases: [...doc.trigger_phrases] }));\n}\n\nfunction createPackedEvalQueries(): BM25ComparisonQuery[] {\n  return GOLDEN_QUERIES.map((query) => ({\n    ...query,\n    relevances: query.relevances.map((relevance) => ({ ...relevance })),\n  }));\n}\n\nexport {\n  createCorpusSizedDocuments,\n  iterateCorpusSizedDocuments,\n  createPackedEvalDocuments,\n  createPackedEvalQueries,\n};\n\nexport type {\n  BM25PackedFixtureDocument,\n  CorpusFixtureOptions,\n};","lineStart":1,"lineEnd":160,"totalLines":160,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts","time":{"start":1781151913731,"end":1781151913742}},"metadata":{"openai":{"itemId":"fc_0e1f5eb53c6bb8d3016a2a38a9aaa481919a6db266a6cd8090"}},"id":"prt_eb4ed5702001J2nfKc4sJCp2lR","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed3406001QSvMXtyij9Xo5H"}}
{"type":"tool_use","timestamp":1781151913770,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"type":"tool","tool":"read","callID":"call_gkyh6IWjDrA6Hk3J0vJ28HEO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: PACKED IN-MEMORY BM25\n3: // ───────────────────────────────────────────────────────────────\n4: import { performance } from 'node:perf_hooks';\n5: import Database from 'better-sqlite3';\n6: import { afterEach, describe, expect, it, vi } from 'vitest';\n7: \n8: import {\n9:   BM25Index,\n10:   BM25_FIELD_WEIGHTS,\n11:   buildBm25DocumentFields,\n12:   shouldWarmInMemoryBm25,\n13:   type BM25DocumentFields,\n14:   type BM25SearchResult,\n15: } from '../lib/search/bm25-index';\n16: import { fts5Bm25Search, isFts5Available } from '../lib/search/sqlite-fts';\n17: import { runBM25EngineComparison, type BM25SearchResult as BaselineResult } from '../lib/eval/bm25-baseline';\n18: import {\n19:   createPackedEvalDocuments,\n20:   createPackedEvalQueries,\n21:   iterateCorpusSizedDocuments,\n22:   type BM25PackedFixtureDocument,\n23: } from '../lib/eval/fixtures/bm25-packed-fixture';\n24: \n25: const ORIGINAL_BM25_ENGINE = process.env.SPECKIT_BM25_ENGINE;\n26: const ORIGINAL_ENABLE_BM25 = process.env.ENABLE_BM25;\n27: const RSS_BUDGET_BYTES = 150 * 1024 * 1024;\n28: const WARMUP_BUDGET_MS = 10_000;\n29: \n30: function toFields(doc: BM25PackedFixtureDocument): BM25DocumentFields {\n31:   return buildBm25DocumentFields({\n32:     title: doc.title,\n33:     content_text: doc.content_text,\n34:     trigger_phrases: doc.trigger_phrases,\n35:     file_path: doc.file_path,\n36:   });\n37: }\n38: \n39: function addFixtureDocuments(index: BM25Index, docs: BM25PackedFixtureDocument[]): void {\n40:   for (const doc of docs) {\n41:     index.addDocumentFields(String(doc.id), toFields(doc));\n42:   }\n43:   index.finalizePackedPostings();\n44: }\n45: \n46: function toBaselineResults(results: BM25SearchResult[], source: string): BaselineResult[] {\n47:   return results.map((result) => ({\n48:     id: Number(result.id),\n49:     score: result.score,\n50:     source,\n51:   }));\n52: }\n53: \n54: function createFtsDatabase(docs: BM25PackedFixtureDocument[]): Database.Database {\n55:   const db = new Database(':memory:');\n56:   db.exec(`\n57:     CREATE TABLE memory_index (\n58:       id INTEGER PRIMARY KEY,\n59:       title TEXT,\n60:       content_text TEXT,\n61:       trigger_phrases TEXT,\n62:       file_path TEXT,\n63:       importance_tier TEXT\n64:     );\n65:     CREATE VIRTUAL TABLE memory_fts USING fts5(\n66:       title,\n67:       trigger_phrases,\n68:       file_path,\n69:       content_text,\n70:       content='memory_index',\n71:       content_rowid='id'\n72:     );\n73:   `);\n74: \n75:   const insertMemory = db.prepare(`\n76:     INSERT INTO memory_index (id, title, content_text, trigger_phrases, file_path, importance_tier)\n77:     VALUES (?, ?, ?, ?, ?, 'normal')\n78:   `);\n79:   const insertFts = db.prepare(`\n80:     INSERT INTO memory_fts (rowid, title, trigger_phrases, file_path, content_text)\n81:     VALUES (?, ?, ?, ?, ?)\n82:   `);\n83: \n84:   const insertAll = db.transaction(() => {\n85:     for (const doc of docs) {\n86:       const triggers = doc.trigger_phrases.join(' ');\n87:       insertMemory.run(doc.id, doc.title, doc.content_text, triggers, doc.file_path);\n88:       insertFts.run(doc.id, doc.title, triggers, doc.file_path, doc.content_text);\n89:     }\n90:   });\n91:   insertAll();\n92:   return db;\n93: }\n94: \n95: afterEach(() => {\n96:   if (ORIGINAL_BM25_ENGINE === undefined) {\n97:     delete process.env.SPECKIT_BM25_ENGINE;\n98:   } else {\n99:     process.env.SPECKIT_BM25_ENGINE = ORIGINAL_BM25_ENGINE;\n100:   }\n101: \n102:   if (ORIGINAL_ENABLE_BM25 === undefined) {\n103:     delete process.env.ENABLE_BM25;\n104:   } else {\n105:     process.env.ENABLE_BM25 = ORIGINAL_ENABLE_BM25;\n106:   }\n107:   vi.restoreAllMocks();\n108: });\n109: \n110: describe('packed in-memory BM25 engine', () => {\n111:   it('warms the corpus fixture within RSS and latency budgets', () => {\n112:     process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n113:     const index = new BM25Index(undefined, undefined, 'packed-inmemory');\n114:     const beforeRss = process.memoryUsage().rss;\n115:     const start = performance.now();\n116: \n117:     for (const doc of iterateCorpusSizedDocuments()) {\n118:       index.addDocumentFields(String(doc.id), toFields(doc));\n119:     }\n120:     index.finalizePackedPostings();\n121: \n122:     const warmupMs = performance.now() - start;\n123:     const rssSpike = Math.max(0, process.memoryUsage().rss - beforeRss);\n124: \n125:     expect(index.getStats().documentCount).toBe(10_245);\n126:     expect(index.getStats().termCount).toBeGreaterThan(100);\n127:     expect(rssSpike).toBeLessThanOrEqual(RSS_BUDGET_BYTES);\n128:     expect(warmupMs).toBeLessThanOrEqual(WARMUP_BUDGET_MS);\n129:   });\n130: \n131:   it('restores field weighting and keeps weights query-time tunable', () => {\n132:     const docs = createPackedEvalDocuments();\n133:     const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n134:     const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n135: \n136:     addFixtureDocuments(packed, docs);\n137:     for (const doc of docs) {\n138:       legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n139:     }\n140: \n141:     const legacyTop = legacy.search('auth guard', 1)[0]?.id;\n142:     const packedTop = packed.search('auth guard', 1)[0]?.id;\n143:     const flatPackedTop = packed.search('auth guard', 1, {\n144:       fieldWeights: { title: 1, trigger_phrases: 1, content_generic: 1, body: 1 },\n145:     })[0]?.id;\n146: \n147:     expect(BM25_FIELD_WEIGHTS.title).toBeGreaterThan(BM25_FIELD_WEIGHTS.trigger_phrases);\n148:     expect(BM25_FIELD_WEIGHTS.trigger_phrases).toBeGreaterThan(BM25_FIELD_WEIGHTS.content_generic);\n149:     expect(BM25_FIELD_WEIGHTS.content_generic).toBeGreaterThan(BM25_FIELD_WEIGHTS.body);\n150:     expect(legacyTop).not.toBe('101');\n151:     expect(packedTop).toBe('101');\n152:     expect(flatPackedTop).not.toBe('101');\n153:   });\n154: \n155:   it('keeps legacy, packed, and auto selection explicit and logged', () => {\n156:     const infoSpy = vi.spyOn(console, 'info').mockImplementation(() => {});\n157: \n158:     process.env.ENABLE_BM25 = 'true';\n159:     process.env.SPECKIT_BM25_ENGINE = 'legacy-inmemory';\n160:     const legacy = new BM25Index();\n161:     expect((legacy as unknown as { engine: string }).engine).toBe('legacy-inmemory');\n162:     expect(shouldWarmInMemoryBm25(null)).toBe(true);\n163: \n164:     process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n165:     const packed = new BM25Index();\n166:     expect((packed as unknown as { engine: string }).engine).toBe('packed-inmemory');\n167:     expect(shouldWarmInMemoryBm25(null)).toBe(true);\n168: \n169:     delete process.env.SPECKIT_BM25_ENGINE;\n170:     const auto = new BM25Index();\n171:     expect((auto as unknown as { engine: string }).engine).toBe('packed-inmemory');\n172: \n173:     expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('legacy-inmemory'))).toBe(true);\n174:     expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('packed-inmemory'))).toBe(true);\n175:     expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('auto mode fallback'))).toBe(true);\n176:   });\n177: \n178:   it('passes packed-vs-legacy baseline comparison and matches FTS5 title intent', async () => {\n179:     const docs = createPackedEvalDocuments();\n180:     const queries = createPackedEvalQueries();\n181:     const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n182:     const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n183:     const ftsDb = createFtsDatabase(docs);\n184: \n185:     try {\n186:       addFixtureDocuments(packed, docs);\n187:       for (const doc of docs) {\n188:         legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n189:       }\n190: \n191:       expect(isFts5Available(ftsDb)).toBe(true);\n192:       const comparison = await runBM25EngineComparison({\n193:         legacy: (query, limit) => toBaselineResults(legacy.search(query, limit), 'bm25'),\n194:         packed: (query, limit) => toBaselineResults(packed.search(query, limit), 'bm25'),\n195:         fts5: (query, limit) => fts5Bm25Search(ftsDb, query, { limit }).map((row) => ({\n196:           id: Number(row.id),\n197:           score: row.fts_score,\n198:           source: 'fts',\n199:         })),\n200:       }, queries);\n201: \n202:       expect(comparison.packedAtLeastLegacy).toBe(true);\n203:       expect(comparison.titleSignalRestored).toBe(true);\n204:       expect(comparison.packed.mrr5).toBeGreaterThanOrEqual(comparison.legacy.mrr5);\n205:       expect(comparison.fts5?.hitRate1).toBe(1);\n206:     } finally {\n207:       ftsDb.close();\n208:     }\n209:   });\n210: });\n\n(End of file - total 210 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: PACKED IN-MEMORY BM25\n// ───────────────────────────────────────────────────────────────\nimport { performance } from 'node:perf_hooks';\nimport Database from 'better-sqlite3';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport {\n  BM25Index,\n  BM25_FIELD_WEIGHTS,\n  buildBm25DocumentFields,\n  shouldWarmInMemoryBm25,\n  type BM25DocumentFields,\n  type BM25SearchResult,\n} from '../lib/search/bm25-index';\nimport { fts5Bm25Search, isFts5Available } from '../lib/search/sqlite-fts';\nimport { runBM25EngineComparison, type BM25SearchResult as BaselineResult } from '../lib/eval/bm25-baseline';\nimport {\n  createPackedEvalDocuments,\n  createPackedEvalQueries,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: PACKED IN-MEMORY BM25\n// ───────────────────────────────────────────────────────────────\nimport { performance } from 'node:perf_hooks';\nimport Database from 'better-sqlite3';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport {\n  BM25Index,\n  BM25_FIELD_WEIGHTS,\n  buildBm25DocumentFields,\n  shouldWarmInMemoryBm25,\n  type BM25DocumentFields,\n  type BM25SearchResult,\n} from '../lib/search/bm25-index';\nimport { fts5Bm25Search, isFts5Available } from '../lib/search/sqlite-fts';\nimport { runBM25EngineComparison, type BM25SearchResult as BaselineResult } from '../lib/eval/bm25-baseline';\nimport {\n  createPackedEvalDocuments,\n  createPackedEvalQueries,\n  iterateCorpusSizedDocuments,\n  type BM25PackedFixtureDocument,\n} from '../lib/eval/fixtures/bm25-packed-fixture';\n\nconst ORIGINAL_BM25_ENGINE = process.env.SPECKIT_BM25_ENGINE;\nconst ORIGINAL_ENABLE_BM25 = process.env.ENABLE_BM25;\nconst RSS_BUDGET_BYTES = 150 * 1024 * 1024;\nconst WARMUP_BUDGET_MS = 10_000;\n\nfunction toFields(doc: BM25PackedFixtureDocument): BM25DocumentFields {\n  return buildBm25DocumentFields({\n    title: doc.title,\n    content_text: doc.content_text,\n    trigger_phrases: doc.trigger_phrases,\n    file_path: doc.file_path,\n  });\n}\n\nfunction addFixtureDocuments(index: BM25Index, docs: BM25PackedFixtureDocument[]): void {\n  for (const doc of docs) {\n    index.addDocumentFields(String(doc.id), toFields(doc));\n  }\n  index.finalizePackedPostings();\n}\n\nfunction toBaselineResults(results: BM25SearchResult[], source: string): BaselineResult[] {\n  return results.map((result) => ({\n    id: Number(result.id),\n    score: result.score,\n    source,\n  }));\n}\n\nfunction createFtsDatabase(docs: BM25PackedFixtureDocument[]): Database.Database {\n  const db = new Database(':memory:');\n  db.exec(`\n    CREATE TABLE memory_index (\n      id INTEGER PRIMARY KEY,\n      title TEXT,\n      content_text TEXT,\n      trigger_phrases TEXT,\n      file_path TEXT,\n      importance_tier TEXT\n    );\n    CREATE VIRTUAL TABLE memory_fts USING fts5(\n      title,\n      trigger_phrases,\n      file_path,\n      content_text,\n      content='memory_index',\n      content_rowid='id'\n    );\n  `);\n\n  const insertMemory = db.prepare(`\n    INSERT INTO memory_index (id, title, content_text, trigger_phrases, file_path, importance_tier)\n    VALUES (?, ?, ?, ?, ?, 'normal')\n  `);\n  const insertFts = db.prepare(`\n    INSERT INTO memory_fts (rowid, title, trigger_phrases, file_path, content_text)\n    VALUES (?, ?, ?, ?, ?)\n  `);\n\n  const insertAll = db.transaction(() => {\n    for (const doc of docs) {\n      const triggers = doc.trigger_phrases.join(' ');\n      insertMemory.run(doc.id, doc.title, doc.content_text, triggers, doc.file_path);\n      insertFts.run(doc.id, doc.title, triggers, doc.file_path, doc.content_text);\n    }\n  });\n  insertAll();\n  return db;\n}\n\nafterEach(() => {\n  if (ORIGINAL_BM25_ENGINE === undefined) {\n    delete process.env.SPECKIT_BM25_ENGINE;\n  } else {\n    process.env.SPECKIT_BM25_ENGINE = ORIGINAL_BM25_ENGINE;\n  }\n\n  if (ORIGINAL_ENABLE_BM25 === undefined) {\n    delete process.env.ENABLE_BM25;\n  } else {\n    process.env.ENABLE_BM25 = ORIGINAL_ENABLE_BM25;\n  }\n  vi.restoreAllMocks();\n});\n\ndescribe('packed in-memory BM25 engine', () => {\n  it('warms the corpus fixture within RSS and latency budgets', () => {\n    process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n    const index = new BM25Index(undefined, undefined, 'packed-inmemory');\n    const beforeRss = process.memoryUsage().rss;\n    const start = performance.now();\n\n    for (const doc of iterateCorpusSizedDocuments()) {\n      index.addDocumentFields(String(doc.id), toFields(doc));\n    }\n    index.finalizePackedPostings();\n\n    const warmupMs = performance.now() - start;\n    const rssSpike = Math.max(0, process.memoryUsage().rss - beforeRss);\n\n    expect(index.getStats().documentCount).toBe(10_245);\n    expect(index.getStats().termCount).toBeGreaterThan(100);\n    expect(rssSpike).toBeLessThanOrEqual(RSS_BUDGET_BYTES);\n    expect(warmupMs).toBeLessThanOrEqual(WARMUP_BUDGET_MS);\n  });\n\n  it('restores field weighting and keeps weights query-time tunable', () => {\n    const docs = createPackedEvalDocuments();\n    const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n    const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n\n    addFixtureDocuments(packed, docs);\n    for (const doc of docs) {\n      legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n    }\n\n    const legacyTop = legacy.search('auth guard', 1)[0]?.id;\n    const packedTop = packed.search('auth guard', 1)[0]?.id;\n    const flatPackedTop = packed.search('auth guard', 1, {\n      fieldWeights: { title: 1, trigger_phrases: 1, content_generic: 1, body: 1 },\n    })[0]?.id;\n\n    expect(BM25_FIELD_WEIGHTS.title).toBeGreaterThan(BM25_FIELD_WEIGHTS.trigger_phrases);\n    expect(BM25_FIELD_WEIGHTS.trigger_phrases).toBeGreaterThan(BM25_FIELD_WEIGHTS.content_generic);\n    expect(BM25_FIELD_WEIGHTS.content_generic).toBeGreaterThan(BM25_FIELD_WEIGHTS.body);\n    expect(legacyTop).not.toBe('101');\n    expect(packedTop).toBe('101');\n    expect(flatPackedTop).not.toBe('101');\n  });\n\n  it('keeps legacy, packed, and auto selection explicit and logged', () => {\n    const infoSpy = vi.spyOn(console, 'info').mockImplementation(() => {});\n\n    process.env.ENABLE_BM25 = 'true';\n    process.env.SPECKIT_BM25_ENGINE = 'legacy-inmemory';\n    const legacy = new BM25Index();\n    expect((legacy as unknown as { engine: string }).engine).toBe('legacy-inmemory');\n    expect(shouldWarmInMemoryBm25(null)).toBe(true);\n\n    process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n    const packed = new BM25Index();\n    expect((packed as unknown as { engine: string }).engine).toBe('packed-inmemory');\n    expect(shouldWarmInMemoryBm25(null)).toBe(true);\n\n    delete process.env.SPECKIT_BM25_ENGINE;\n    const auto = new BM25Index();\n    expect((auto as unknown as { engine: string }).engine).toBe('packed-inmemory');\n\n    expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('legacy-inmemory'))).toBe(true);\n    expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('packed-inmemory'))).toBe(true);\n    expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('auto mode fallback'))).toBe(true);\n  });\n\n  it('passes packed-vs-legacy baseline comparison and matches FTS5 title intent', async () => {\n    const docs = createPackedEvalDocuments();\n    const queries = createPackedEvalQueries();\n    const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n    const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n    const ftsDb = createFtsDatabase(docs);\n\n    try {\n      addFixtureDocuments(packed, docs);\n      for (const doc of docs) {\n        legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n      }\n\n      expect(isFts5Available(ftsDb)).toBe(true);\n      const comparison = await runBM25EngineComparison({\n        legacy: (query, limit) => toBaselineResults(legacy.search(query, limit), 'bm25'),\n        packed: (query, limit) => toBaselineResults(packed.search(query, limit), 'bm25'),\n        fts5: (query, limit) => fts5Bm25Search(ftsDb, query, { limit }).map((row) => ({\n          id: Number(row.id),\n          score: row.fts_score,\n          source: 'fts',\n        })),\n      }, queries);\n\n      expect(comparison.packedAtLeastLegacy).toBe(true);\n      expect(comparison.titleSignalRestored).toBe(true);\n      expect(comparison.packed.mrr5).toBeGreaterThanOrEqual(comparison.legacy.mrr5);\n      expect(comparison.fts5?.hitRate1).toBe(1);\n    } finally {\n      ftsDb.close();\n    }\n  });\n});","lineStart":1,"lineEnd":210,"totalLines":210,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts","time":{"start":1781151913766,"end":1781151913769}},"metadata":{"openai":{"itemId":"fc_0e1f5eb53c6bb8d3016a2a38a9aaa8819180de22414299aa9a"}},"id":"prt_eb4ed5704001hhpqRv2FkEdhgo","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed3406001QSvMXtyij9Xo5H"}}
