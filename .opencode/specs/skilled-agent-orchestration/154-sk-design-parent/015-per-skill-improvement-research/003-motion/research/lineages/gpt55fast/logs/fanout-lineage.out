 \\\"assets\\\": [], \\\"agent\\\": \\\"none\\\", \\\"disambiguation\\\": false}\\n```\"\n      }\n    },\n    {\n      \"scenarioId\": \"ID-012\",\n      \"tier\": \"live\",\n      \"dims\": {\n        \"d1intra\": {\n          \"score\": 0.6,\n          \"intentRecall\": 0,\n          \"resourceRecall\": 1,\n          \"negative\": false\n        },\n        \"d2\": {\n          \"score\": 1,\n          \"proxy\": \"router-replay-recall\",\n          \"note\": \"Mode A proxy; live-mode replaces with observed-load Hit@k/Recall@k/MRR\"\n        },\n        \"d3\": {\n          \"score\": 0.25,\n          \"routedCount\": 4,\n          \"wastedCount\": 3,\n          \"proxy\": \"router-overload\",\n          \"note\": \"Mode A proxy; live-mode replaces with calls/tokens-to-first-expected\"\n        },\n        \"assetRecall\": {\n          \"score\": null,\n          \"note\": \"no expected assets for this scenario\"\n        },\n        \"d1inter\": {\n          \"score\": null,\n          \"unscored\": \"no advisor probe (run with --advisor-mode=python)\"\n        },\n        \"d4\": {\n          \"score\": null,\n          \"unscored\": \"requires skill-on/off ablation (live mode)\"\n        },\n        \"modePrecision\": {\n          \"score\": null,\n          \"expectedMode\": null,\n          \"observedMode\": null,\n          \"advisory\": true,\n          \"unscored\": \"fixture carries no expected.mode\"\n        }\n      },\n      \"firstFailingStage\": null,\n      \"modeAScore\": 66,\n      \"applicable\": true,\n      \"classKind\": \"routing\",\n      \"expectedSurface\": null,\n      \"observedSurface\": \"UNKNOWN\",","lineStart":1,"lineEnd":260,"totalLines":961,"truncated":true}},"title":".opencode/specs/skilled-agent-orchestration/154-sk-design-parent/014-routing-benchmark/design-interface/skill-benchmark-report.json","time":{"start":1782532387314,"end":1782532387325}},"metadata":{"openai":{"itemId":"fc_08a38b95b1217e93016a3f4923349481919d98de529870