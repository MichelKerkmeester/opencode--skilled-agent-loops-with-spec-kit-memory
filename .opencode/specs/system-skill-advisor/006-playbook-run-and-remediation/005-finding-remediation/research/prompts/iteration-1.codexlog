    92	def run_case_subprocess(case: Dict[str, Any], threshold: float, uncertainty: float) -> List[Dict[str, Any]]:
    93	    """Evaluate a case through the CLI subprocess bridge."""
    94	    confidence_only = bool(case.get("confidence_only", False))
    95	    command = [
    96	        "python3",
    97	        ADVISOR_PATH,
    98	        "--force-local",
    99	        "--threshold",
   100	        str(threshold),
   101	        "--uncertainty",
   102	        str(uncertainty),
   103	    ]
   104	    if confidence_only:
   105	        command.append("--confidence-only")
   106	    command.extend(["--", case["prompt"]])
   107	    env = os.environ.copy()
   108	    env["SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC"] = "1"
   109	    completed = subprocess.run(
   110	        command,
   111	        check=True,
   112	        stdout=subprocess.PIPE,
   113	        stderr=subprocess.PIPE,
   114	        encoding="utf-8",
   115	        env=env,
   116	    )
   117	    parsed = json.loads(completed.stdout or "[]")
   118	    if not isinstance(parsed, list):
   119	        raise ValueError(f"subprocess advisor returned {type(parsed).__name__}, expected list")
   120	    return parsed
   121	
   122	
   123	def evaluate_case(
   124	    advisor: Any,
   125	    case: Dict[str, Any],
   126	    threshold: float,
   127	    uncertainty: float,
   128	    runner: str = "inprocess",
   129	) -> Dict[str, Any]:
   130	    """Run a single regression case and record its expectation checks."""
   131	    prompt = case["prompt"]
   132	    confidence_only = bool(case.get("confidence_only", False))
   133	    recommendations = (
   134	        run_case_subprocess(case, threshold, uncertainty)
   135	        if runner == "subprocess"
   136	        else run_case_inprocess(advisor, case, threshold, uncertainty)
   137	    )
   138	
   139	    top = recommendations[0] if recommendations else None
   140	    expected_top = case.get("expected_top_any", [])
   141	    expect_result = bool(case.get("expect_result", True))
   142	    expect_kind = case.get("expect_kind")
   143	
   144	    result_ok = bool(top) == expect_result
   145	    top_ok = True
   146	    kind_ok = True
   147	
   148	    if expect_result and top is not None and expected_top:
   149	        top_ok = top["skill"] in expected_top
   150	
   151	    if expect_result and top is not None and expect_kind:
   152	        kind_ok = top.get("kind") == expect_kind
   153	
   154	    passed = result_ok and top_ok and kind_ok
   155	
   156	    return {
   157	        "id": case.get("id", "unknown"),
   158	        "priority": case.get("priority", "P1"),
   159	        "prompt": prompt,
   160	        "runner": runner,
   161	        "confidence_only": confidence_only,
   162	        "expect_result": expect_result,
   163	        "expected_top_any": expected_top,
   164	        "expected_kind": expect_kind,
   165	        "top": top,
   166	        "passed": passed,
   167	        "checks": {
   168	            "result_ok": result_ok,
   169	            "top_ok": top_ok,
   170	            "kind_ok": kind_ok,
   171	        },
   172	        "allow_command_bridge": bool(case.get("allow_command_bridge", False)),
   173	        "non_slash": bool(case.get("non_slash", "/" not in prompt)),
   174	    }
   175	
   176	
   177	def compute_metrics(results: List[Dict[str, Any]]) -> Dict[str, Any]:
   178	    """Aggregate pass rates and command-bridge error metrics."""
   179	    total = len(results)
   180	    passed = sum(1 for item in results if item["passed"])
   181	
   182	    p0_results = [item for item in results if item.get("priority") == "P0"]
   183	    p0_passed = sum(1 for item in p0_results if item["passed"])
   184	
   185	    top1_cases = [
   186	        item
   187	        for item in results
   188	        if item["expect_result"]
   189	        and item["expected_top_any"]
   190	    ]
   191	    top1_correct = sum(1 for item in top1_cases if item["checks"]["top_ok"]) if top1_cases else 0
   192	
   193	    command_bridge_eval = [
   194	        item
   195	        for item in results
   196	        if item["non_slash"]
   197	        and item["top"] is not None
   198	    ]
   199	    command_bridge_fp = sum(
   200	        1
   201	        for item in command_bridge_eval
   202	        if item["top"].get("kind") == "command" and not item["allow_command_bridge"]
   203	    )
   204	
   205	    return {
   206	        "total_cases": total,
   207	        "passed_cases": passed,
   208	        "failed_cases": total - passed,
   209	        "pass_rate": round((passed / total) if total else 0.0, 4),
   210	        "p0_total": len(p0_results),
   211	        "p0_passed": p0_passed,
   212	        "p0_pass_rate": round((p0_passed / len(p0_results)) if p0_results else 0.0, 4),
   213	        "top1_cases": len(top1_cases),
   214	        "top1_accuracy": round((top1_correct / len(top1_cases)) if top1_cases else 0.0, 4),
   215	        "command_bridge_eval_cases": len(command_bridge_eval),
   216	        "command_bridge_fp": command_bridge_fp,
   217	        "command_bridge_fp_rate": round(
   218	            (command_bridge_fp / len(command_bridge_eval)) if command_bridge_eval else 0.0,
   219	            4,
   220	        ),
   221	    }
   222	
