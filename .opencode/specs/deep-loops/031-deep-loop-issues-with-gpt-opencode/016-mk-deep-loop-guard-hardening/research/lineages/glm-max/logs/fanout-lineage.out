essionID }) {\n274:     const startedAt = Date.now();\n275:     state.bridgeInvocations += 1;\n276:     return new Promise((resolve) => {\n277:       const child = spawn(options.nodeBinary, [BRIDGE_PATH], {\n278:         cwd: projectDir,\n279:         env: process.env,\n280:         stdio: ['pipe', 'pipe', 'pipe'],\n281:       });\n282:       let stdout = '';\n283:       let settled = false;\n284:       let timedOut = false;\n285:       let sigkillTimer = null;\n286:       const timeout = setTimeout(() => {\n287:         if (settled) return;\n288:         timedOut = true;\n289:         child.kill('SIGTERM');\n290:         sigkillTimer = setTimeout(() => {\n291:           if (!settled) child.kill('SIGKILL');\n292:         }, 1000);\n293:       }, options.bridgeTimeoutMs);\n294: \n295:       child.stdout?.setEncoding?.('utf8');\n296:       child.stdout?.on('data', (chunk) => {\n297:         stdout += String(chunk);\n298:       });\n299:       child.stderr?.on('data', () => {});\n\n(Showing lines 245-299 of 477. Use offset=300 to continue.)\n</content>","metadata":{"preview":" * @param {number} [rawOptions.cliTimeoutMs] - Warm CLI timeout passed to the bridge\n * @param {string} [rawOptions.nodeBinaryOverride] - Node binary used for the bridge subprocess\n * @param {string} [rawOptions.specFolder] - Optional spec folder scope for continuity recovery\n * @param {number} [rawOptions.maxBriefChars] - Maximum injected continuity brief characters\n * @param {number} [rawOptions.maxCacheEntries] - Maximum continuity cache entries\n * @param {string} [rawOptions.sourceSignatureOverride] - Test override for source signature\n * @returns {Promise<Object>} Hooks with `event`, `experimental.chat.system.transform`, and `tool`\n */\nexport default async function MkSpecMemoryPlugin(ctx, rawOptions) {\n  const fileConfig = await configPromise;\n  const merged = { ...fileConfig, ...rawOptions };\n  const options = normalizeOptions(merged);\n  const projectDir = normalizeWorkspaceRoot(ctx?.directory);\n\n  const state = {\n    continuityCache: new Map(),\n    inFlight: new Map(),\n    runtimeReady: false,\n    lastBridgeStatus: 'uninitialized',\n    lastErrorCode: null,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-spec-memory.js","text":" * @param {number} [rawOptions.cliTimeoutMs] - Warm CLI timeout passed to the bridge\n * @param {string} [rawOptions.nodeBinaryOverride] - Node binary used for the bridge subprocess\n * @param {string} [rawOptions.specFolder] - Optional spec folder scope for continuity recovery\n * @param {number} [rawOptions.maxBriefChars] - Maximum injected continuity brief characters\n * @param {number} [rawOptions.maxCacheEntries] - Maximum continuity cache entries\n * @param {string} [rawOptions.sourceSignatureOverride] - Test override for source signature\n * @returns {Promise<Object>} Hooks with `event`, `experimental.chat.system.transform`, and `tool`\n */\nexport default async function MkSpecMemoryPlugin(ctx, rawOptions) {\n  const fileConfig = await configPromise;\n  const merged = { ...fileConfig, ...rawOptions };\n  const options = normalizeOptions(merged);\n  const projectDir = normalizeWorkspaceRoot(ctx?.directory);\n\n  const state = {\n    continuityCache: new Map(),\n    inFlight: new Map(),\n    runtimeReady: false,\n    lastBridgeStatus: 'uninitialized',\n    lastErrorCode: null,\n    lastDurationMs: 0,\n    bridgeInvocations: 0,\n    cacheHits: 0,\n    cacheMisses: 0,\n    continuityLookups: 0,\n    disabledReason: !options.enabled ? (disabledEnvName() ?? 'config_enabled_false') : null,\n  };\n\n  function runBridge({ request, sessionID }) {\n    const startedAt = Date.now();\n    state.bridgeInvocations += 1;\n    return new Promise((resolve) => {\n      const child = spawn(options.nodeBinary, [BRIDGE_PATH], {\n        cwd: projectDir,\n        env: process.env,\n        stdio: ['pipe', 'pipe', 'pipe'],\n      });\n      let stdout = '';\n      let settled = false;\n      let timedOut = false;\n      let sigkillTimer = null;\n      const timeout = setTimeout(() => {\n        if (settled) return;\n        timedOut = true;\n        child.kill('SIGTERM');\n        sigkillTimer = setTimeout(() => {\n          if (!settled) child.kill('SIGKILL');\n        }, 1000);\n      }, options.bridgeTimeoutMs);\n\n      child.stdout?.setEncoding?.('utf8');\n      child.stdout?.on('data', (chunk) => {\n        stdout += String(chunk);\n      });\n      child.stderr?.on('data', () => {});","lineStart":245,"lineEnd":299,"totalLines":477,"truncated":true}},"title":".opencode/plugins/mk-spec-memory.js","time":{"start":1782925370215,"end":1782925370220}},"id":"prt_f1ea22365001PyBlCdlyF6ehH1","sessionID":"ses_0e161ba06ffe4N4jFh0zF4Zwuf","messageID":"msg_f1ea1d59e001S39EqX73rUCILG"}}
{"type":"tool_use","timestamp":1782925370223,"sessionID":"ses_0e161ba06ffe4N4jFh0zF4Zwuf","part":{"type":"tool","tool":"read","callID":"call_4570ca7559cf48e69fde596e","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","offset":620,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js</path>\n<type>file</type>\n<content>\n620: /**\n621:  * Ensure the goal state directory exists.\n622:  *\n623:  * @param {Object} [rawOptions] - State helper options\n624:  * @param {string} [rawOptions.stateDir] - Override directory for tests\n625:  * @returns {Promise<string>} Absolute state directory path\n626:  */\n627: async function ensureGoalStateDir(rawOptions = {}) {\n628:   const options = normalizeOptions(rawOptions);\n629:   await mkdir(options.stateDir, { recursive: true, mode: 0o700 });\n630:   return options.stateDir;\n631: }\n632: \n633: async function ensureGoalArchiveDir(rawOptions = {}) {\n634:   const stateDir = await ensureGoalStateDir(rawOptions);\n635:   const archiveDir = join(stateDir, '.archive');\n636:   await mkdir(archiveDir, { recursive: true, mode: 0o700 });\n637:   return archiveDir;\n638: }\n639: \n640: /**\n641:  * Resolve a per-session goal state file path.\n642:  *\n643:  * @param {string} sessionID - OpenCode session id\n644:  * @param {Object} [rawOptions] - State helper options\n645:  * @returns {string} Absolute JSON file path\n646:  */\n647: function goalPathForSession(sessionID, rawOptions = {}) {\n648:   const options = normalizeOptions(rawOptions);\n649:   return join(options.stateDir, `${sessionKeyForSession(sessionID)}.json`);\n650: }\n651: \n652: function normalizeStoredGoal(rawGoal, fallbackSessionID, rawOptions = {}) {\n653:   if (!rawGoal || typeof rawGoal !== 'object') {\n654:     throw new GoalError('INVALID_GOAL_STATE', 'Goal state is not a JSON object');\n655:   }\n656:   const options = normalizeOptions(rawOptions);\n657:   const sessionID = requireSessionID(rawGoal.sessionId ?? fallbackSessionID);\n658:   const objective = sanitizeInlineText(rawGoal.objective, options.maxObjectiveChars);\n659:   if (!objective) {\n660:     throw new GoalError('INVALID_GOAL_STATE', 'Goal state is missing an objective');\n661:   }\n662:   if (!VALID_STATUSES.has(rawGoal.status)) {\n663:     throw new GoalError('INVALID_GOAL_STATE', `Goal state has invalid status: ${rawGoal.status}`);\n664:   }\n665: \n666:   const createdAtMs = Number.isFinite(rawGoal.createdAtMs) ? Math.trunc(rawGoal.createdAtMs) : nowMs(options);\n667:   const updatedAtMs = Number.isFinite(rawGoal.updatedAtMs) ? Math.trunc(rawGoal.updatedAtMs) : createdAtMs;\n668:   const promptFields = normalizeGoalPromptFields(rawGoal, objective, options);\n669: \n670:   return {\n671:     ...rawGoal,\n672:     sessionId: sessionID,\n673:     goalId: sanitizeInlineText(rawGoal.goalId || goalIdFromFactory(options), 160).replace(/\\s+/g, '-'),\n674:     objective,\n675:     goalPrompt: promptFields.goalPrompt,\n676:     promptEnhancement: promptFields.promptEnhancement,\n677:     status: rawGoal.status,\n678:     tokenBudget: rawGoal.tokenBudget === undefined ? null : rawGoal.tokenBudget,\n679:     tokensUsed: Number.isFinite(rawGoal.tokensUsed) ? Math.max(0, Math.trunc(rawGoal.tokensUsed)) : 0,\n680:     timeUsedSeconds: Number.isFinite(rawGoal.timeUsedSeconds) ? Math.max(0, Math.trunc(rawGoal.timeUsedSeconds)) : 0,\n681:     createdAtMs,\n682:     updatedAtMs,\n683:     createdAt: typeof rawGoal.createdAt === 'string' ? rawGoal.createdAt : isoFromMs(createdAtMs),\n684:     updatedAt: typeof rawGoal.updatedAt === 'string' ? rawGoal.updatedAt : isoFromMs(updatedAtMs),\n685:     continuationSuppressed: rawGoal.continuationSuppressed === true,\n686:     autoTurnsUsed: normalizeAutoTurns(rawGoal.autoTurnsUsed),\n687:     maxAutoTurns: Number.isFinite(rawGoal.maxAutoTurns)\n688:       ? Math.max(0, Math.min(DEFAULT_MAX_AUTO_TURNS, Math.trunc(rawGoal.maxAutoTurns)))\n689:       : DEFAULT_MAX_AUTO_TURNS,\n\n(Showing lines 620-689 of 1907. Use offset=690 to continue.)\n</content>","metadata":{"preview":"/**\n * Ensure the goal state directory exists.\n *\n * @param {Object} [rawOptions] - State helper options\n * @param {string} [rawOptions.stateDir] - Override directory for tests\n * @returns {Promise<string>} Absolute state directory path\n */\nasync function ensureGoalStateDir(rawOptions = {}) {\n  const options = normalizeOptions(rawOptions);\n  await mkdir(options.stateDir, { recursive: true, mode: 0o700 });\n  return options.stateDir;\n}\n\nasync function ensureGoalArchiveDir(rawOptions = {}) {\n  const stateDir = await ensureGoalStateDir(rawOptions);\n  const archiveDir = join(stateDir, '.archive');\n  await mkdir(archiveDir, { recursive: true, mode: 0o700 });\n  return archiveDir;\n}\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","text":"/**\n * Ensure the goal state directory exists.\n *\n * @param {Object} [rawOptions] - State helper options\n * @param {string} [rawOptions.stateDir] - Override directory for tests\n * @returns {Promise<string>} Absolute state directory path\n */\nasync function ensureGoalStateDir(rawOptions = {}) {\n  const options = normalizeOptions(rawOptions);\n  await mkdir(options.stateDir, { recursive: true, mode: 0o700 });\n  return options.stateDir;\n}\n\nasync function ensureGoalArchiveDir(rawOptions = {}) {\n  const stateDir = await ensureGoalStateDir(rawOptions);\n  const archiveDir = join(stateDir, '.archive');\n  await mkdir(archiveDir, { recursive: true, mode: 0o700 });\n  return archiveDir;\n}\n\n/**\n * Resolve a per-session goal state file path.\n *\n * @param {string} sessionID - OpenCode session id\n * @param {Object} [rawOptions] - State helper options\n * @returns {string} Absolute JSON file path\n */\nfunction goalPathForSession(sessionID, rawOptions = {}) {\n  const options = normalizeOptions(rawOptions);\n  return join(options.stateDir, `${sessionKeyForSession(sessionID)}.json`);\n}\n\nfunction normalizeStoredGoal(rawGoal, fallbackSessionID, rawOptions = {}) {\n  if (!rawGoal || typeof rawGoal !== 'object') {\n    throw new GoalError('INVALID_GOAL_STATE', 'Goal state is not a JSON object');\n  }\n  const options = normalizeOptions(rawOptions);\n  const sessionID = requireSessionID(rawGoal.sessionId ?? fallbackSessionID);\n  const objective = sanitizeInlineText(rawGoal.objective, options.maxObjectiveChars);\n  if (!objective) {\n    throw new GoalError('INVALID_GOAL_STATE', 'Goal state is missing an objective');\n  }\n  if (!VALID_STATUSES.has(rawGoal.status)) {\n    throw new GoalError('INVALID_GOAL_STATE', `Goal state has invalid status: ${rawGoal.status}`);\n  }\n\n  const createdAtMs = Number.isFinite(rawGoal.createdAtMs) ? Math.trunc(rawGoal.createdAtMs) : nowMs(options);\n  const updatedAtMs = Number.isFinite(rawGoal.updatedAtMs) ? Math.trunc(rawGoal.updatedAtMs) : createdAtMs;\n  const promptFields = normalizeGoalPromptFields(rawGoal, objective, options);\n\n  return {\n    ...rawGoal,\n    sessionId: sessionID,\n    goalId: sanitizeInlineText(rawGoal.goalId || goalIdFromFactory(options), 160).replace(/\\s+/g, '-'),\n    objective,\n    goalPrompt: promptFields.goalPrompt,\n    promptEnhancement: promptFields.promptEnhancement,\n    status: rawGoal.status,\n    tokenBudget: rawGoal.tokenBudget === undefined ? null : rawGoal.tokenBudget,\n    tokensUsed: Number.isFinite(rawGoal.tokensUsed) ? Math.max(0, Math.trunc(rawGoal.tokensUsed)) : 0,\n    timeUsedSeconds: Number.isFinite(rawGoal.timeUsedSeconds) ? Math.max(0, Math.trunc(rawGoal.timeUsedSeconds)) : 0,\n    createdAtMs,\n    updatedAtMs,\n    createdAt: typeof rawGoal.createdAt === 'string' ? rawGoal.createdAt : isoFromMs(createdAtMs),\n    updatedAt: typeof rawGoal.updatedAt === 'string' ? rawGoal.updatedAt : isoFromMs(updatedAtMs),\n    continuationSuppressed: rawGoal.continuationSuppressed === true,\n    autoTurnsUsed: normalizeAutoTurns(rawGoal.autoTurnsUsed),\n    maxAutoTurns: Number.isFinite(rawGoal.maxAutoTurns)\n      ? Math.max(0, Math.min(DEFAULT_MAX_AUTO_TURNS, Math.trunc(rawGoal.maxAutoTurns)))\n      : DEFAULT_MAX_AUTO_TURNS,","lineStart":620,"lineEnd":689,"totalLines":1907,"truncated":true}},"title":".opencode/plugins/mk-goal.js","time":{"start":1782925370211,"end":1782925370222}},"id":"prt_f1ea2235f001AR7caFSst07kK2","sessionID":"ses_0e161ba06ffe4N4jFh0zF4Zwuf","messageID":"msg_f1ea1d59e001S39EqX73rUCILG"}}
