{"type":"text","timestamp":1780907210297,"sessionID":"ses_159acb43affeAz2922ChDQjScP","part":{"id":"prt_ea65775e3001G2uSXRtDqJPE2W","messageID":"msg_ea6575ece001BP06bZNWaUGP9s","sessionID":"ses_159acb43affeAz2922ChDQjScP","type":"text","text":"A substantive correctness risk surfaced in the owner-lease reclaim path: the normal release path clears ownership, but crash/stale-owner recovery may still use a non-exclusive overwrite. I’m checking existing tests before recording it as a finding.","time":{"start":1780907210211,"end":1780907210296},"metadata":{"openai":{"itemId":"msg_0c962319919755eb016a267cca31108191b72da5c2dee18f93","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780907210790,"sessionID":"ses_159acb43affeAz2922ChDQjScP","part":{"type":"tool","tool":"read","callID":"call_lEP6IHQXUv0Uc9z1Nb2AFI3j","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-lease.vitest.ts","offset":250,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-lease.vitest.ts</path>\n<type>file</type>\n<content>\n250:   });\n251:   if (typeof child.pid !== 'number') {\n252:     throw new Error('live-pid child did not get a pid');\n253:   }\n254:   return child;\n255: }\n256: \n257: describe('mk-spec-memory launcher lease', () => {\n258:   afterEach(async () => {\n259:     // Reap every spawned launcher (SIGTERM then SIGKILL) before deleting temp dirs so the run never\n260:     // leaks launcher/daemon processes.\n261:     while (launcherRuns.length > 0) {\n262:       const run = launcherRuns.pop();\n263:       if (run) await terminate(run);\n264:     }\n265:     while (tempDirs.length > 0) {\n266:       const dir = tempDirs.pop();\n267:       if (dir) rmSync(dir, { recursive: true, force: true });\n268:     }\n269:   });\n270: \n271:   // Duplicate launcher exits before opening SQLite.\n272:   it('exits with a retryable JSON-RPC error when a live owner exists but cannot be bridged', async () => {\n273:     const workspace = createWorkspace();\n274:     const first = spawnLauncher(workspace);\n275:     await waitForLeasePid(workspace.pidFilePath, first.child.pid);\n276: \n277:     // The launcher writes to stdout that is also the MCP client stream; keep unbridgeable boot-gap\n278:     // reports as JSON-RPC frames rather than plaintext diagnostics.\n279:     const second = spawnLauncher(workspace, { SPECKIT_LAUNCHER_BRIDGE_DISABLED: '1' });\n280:     await waitForStdoutClose(second);\n281:     const exit = await waitForExit(second.child, 10000);\n282: \n283:     expect(exit.code).toBe(0);\n284:     expectRetryableLeaseHeld(second.stdout, first.child.pid as number, 'bridge-disabled');\n285:   });\n286: \n287:   it('lets exactly one concurrent launcher own the owner lease', async () => {\n288:     const workspace = createWorkspace();\n289:     const first = spawnLauncher(workspace);\n290:     const second = spawnLauncher(workspace);\n291: \n292:     await waitFor(() => readOwnerLeasePid(workspace.root) !== null, 8000, 'owner lease');\n293:     await waitFor(\n294:       () =>\n295:         first.child.exitCode !== null ||\n296:         second.child.exitCode !== null ||\n297:         first.stdout.includes('lease held by pid') ||\n298:         second.stdout.includes('lease held by pid'),\n299:       10000,\n300:       'one launcher to report lease held',\n301:     );\n302: \n303:     const ownerPid = readOwnerLeasePid(workspace.root);\n304:     const runs = [first, second];\n305:     const running = runs.filter((run) => run.child.exitCode === null && !run.stdout.includes('lease held by pid'));\n306:     const blocked = runs.filter((run) => run.stdout.includes('lease held by pid'));\n307: \n308:     expect(ownerPid).not.toBeNull();\n309:     expect(running).toHaveLength(1);\n310:     expect(blocked).toHaveLength(1);\n311:   });\n312: \n313:   it('reaps the recorded owner before taking over a dead socket', async () => {\n314:     const workspace = createWorkspace();\n315:     const first = spawnLauncher(workspace);\n316:     await waitForLeasePid(workspace.pidFilePath, first.child.pid);\n317:     await waitFor(() => typeof readLease(workspace.pidFilePath)?.childPid === 'number', 8000, 'child pid in lease');\n318: \n319:     const lease = readLease(workspace.pidFilePath);\n320:     const socketPath = lease?.socketPath;\n321:     if (typeof socketPath !== 'string') throw new Error('expected lease socketPath');\n322:     writeFileSync(socketPath, 'stale socket placeholder', 'utf8');\n323: \n324:     const second = spawnLauncher(workspace);\n325: \n326:     await waitForExit(first.child, 10000);\n327:     await waitFor(() => readOwnerLeasePid(workspace.root) === second.child.pid, 10000, 'replacement owner lease');\n328:     await waitForLeasePid(workspace.pidFilePath, second.child.pid);\n329: \n330:     expect(second.stderr).toContain(`confirmed-dead socket; reaping recorded spec-memory owner pid ${first.child.pid} before respawn`);\n331:   });\n332: \n333:   // Live-owner JSON-RPC diagnostics include the recorded owner pid.\n334:   it('reports a retryable JSON-RPC error for a live owner', async () => {\n335:     const workspace = createWorkspace();\n336:     const holder = await createLivePid();\n337:     const startedAt = '2026-05-18T00:00:00.000Z';\n338: \n339:     try {\n340:       mkdirSync(dirname(workspace.pidFilePath), { recursive: true });\n341:       writeFileSync(workspace.pidFilePath, JSON.stringify({ pid: holder.pid, startedAt }));\n342: \n343:       // No socketPath in the planted lease + bridge disabled -> deterministic JSON-RPC diagnostic.\n344:       const run = spawnLauncher(workspace, { SPECKIT_LAUNCHER_BRIDGE_DISABLED: '1' });\n345:       await waitForStdoutClose(run);\n346:       const exit = await waitForExit(run.child, 10000);\n347: \n348:       expect(exit.code).toBe(0);\n349:       expectRetryableLeaseHeld(run.stdout, holder.pid as number, 'bridge-disabled');\n350:     } finally {\n351:       holder.kill('SIGTERM');\n352:       try {\n353:         await waitForExit(holder, 2000);\n354:       } catch {\n355:         holder.kill('SIGKILL');\n356:       }\n357:     }\n358:   });\n359: \n360:   // dead-PID lease files are reclaimable.\n361:   it('reclaims a dead-pid lease file and logs staleReclaimed', async () => {\n362:     const workspace = createWorkspace();\n363:     mkdirSync(dirname(workspace.pidFilePath), { recursive: true });\n364:     writeFileSync(workspace.pidFilePath, JSON.stringify({ pid: await createDeadPid(), startedAt: new Date().toISOString() }));\n365: \n366:     const run = spawnLauncher(workspace);\n367:     await waitFor(() => /^.*staleReclaimed: true\\b/m.test(run.stderr), 8000, 'stale reclaim log');\n368:     expect(run.stderr).toMatch(/^.*staleReclaimed: true\\b/m);\n369:     await waitForLeasePid(workspace.pidFilePath, run.child.pid);\n\n(Showing lines 250-369 of 498. Use offset=370 to continue.)\n</content>","metadata":{"preview":"  });\n  if (typeof child.pid !== 'number') {\n    throw new Error('live-pid child did not get a pid');\n  }\n  return child;\n}\n\ndescribe('mk-spec-memory launcher lease', () => {\n  afterEach(async () => {\n    // Reap every spawned launcher (SIGTERM then SIGKILL) before deleting temp dirs so the run never\n    // leaks launcher/daemon processes.\n    while (launcherRuns.length > 0) {\n      const run = launcherRuns.pop();\n      if (run) await terminate(run);\n    }\n    while (tempDirs.length > 0) {\n      const dir = tempDirs.pop();\n      if (dir) rmSync(dir, { recursive: true, force: true });\n    }\n  });","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-lease.vitest.ts","text":"  });\n  if (typeof child.pid !== 'number') {\n    throw new Error('live-pid child did not get a pid');\n  }\n  return child;\n}\n\ndescribe('mk-spec-memory launcher lease', () => {\n  afterEach(async () => {\n    // Reap every spawned launcher (SIGTERM then SIGKILL) before deleting temp dirs so the run never\n    // leaks launcher/daemon processes.\n    while (launcherRuns.length > 0) {\n      const run = launcherRuns.pop();\n      if (run) await terminate(run);\n    }\n    while (tempDirs.length > 0) {\n      const dir = tempDirs.pop();\n      if (dir) rmSync(dir, { recursive: true, force: true });\n    }\n  });\n\n  // Duplicate launcher exits before opening SQLite.\n  it('exits with a retryable JSON-RPC error when a live owner exists but cannot be bridged', async () => {\n    const workspace = createWorkspace();\n    const first = spawnLauncher(workspace);\n    await waitForLeasePid(workspace.pidFilePath, first.child.pid);\n\n    // The launcher writes to stdout that is also the MCP client stream; keep unbridgeable boot-gap\n    // reports as JSON-RPC frames rather than plaintext diagnostics.\n    const second = spawnLauncher(workspace, { SPECKIT_LAUNCHER_BRIDGE_DISABLED: '1' });\n    await waitForStdoutClose(second);\n    const exit = await waitForExit(second.child, 10000);\n\n    expect(exit.code).toBe(0);\n    expectRetryableLeaseHeld(second.stdout, first.child.pid as number, 'bridge-disabled');\n  });\n\n  it('lets exactly one concurrent launcher own the owner lease', async () => {\n    const workspace = createWorkspace();\n    const first = spawnLauncher(workspace);\n    const second = spawnLauncher(workspace);\n\n    await waitFor(() => readOwnerLeasePid(workspace.root) !== null, 8000, 'owner lease');\n    await waitFor(\n      () =>\n        first.child.exitCode !== null ||\n        second.child.exitCode !== null ||\n        first.stdout.includes('lease held by pid') ||\n        second.stdout.includes('lease held by pid'),\n      10000,\n      'one launcher to report lease held',\n    );\n\n    const ownerPid = readOwnerLeasePid(workspace.root);\n    const runs = [first, second];\n    const running = runs.filter((run) => run.child.exitCode === null && !run.stdout.includes('lease held by pid'));\n    const blocked = runs.filter((run) => run.stdout.includes('lease held by pid'));\n\n    expect(ownerPid).not.toBeNull();\n    expect(running).toHaveLength(1);\n    expect(blocked).toHaveLength(1);\n  });\n\n  it('reaps the recorded owner before taking over a dead socket', async () => {\n    const workspace = createWorkspace();\n    const first = spawnLauncher(workspace);\n    await waitForLeasePid(workspace.pidFilePath, first.child.pid);\n    await waitFor(() => typeof readLease(workspace.pidFilePath)?.childPid === 'number', 8000, 'child pid in lease');\n\n    const lease = readLease(workspace.pidFilePath);\n    const socketPath = lease?.socketPath;\n    if (typeof socketPath !== 'string') throw new Error('expected lease socketPath');\n    writeFileSync(socketPath, 'stale socket placeholder', 'utf8');\n\n    const second = spawnLauncher(workspace);\n\n    await waitForExit(first.child, 10000);\n    await waitFor(() => readOwnerLeasePid(workspace.root) === second.child.pid, 10000, 'replacement owner lease');\n    await waitForLeasePid(workspace.pidFilePath, second.child.pid);\n\n    expect(second.stderr).toContain(`confirmed-dead socket; reaping recorded spec-memory owner pid ${first.child.pid} before respawn`);\n  });\n\n  // Live-owner JSON-RPC diagnostics include the recorded owner pid.\n  it('reports a retryable JSON-RPC error for a live owner', async () => {\n    const workspace = createWorkspace();\n    const holder = await createLivePid();\n    const startedAt = '2026-05-18T00:00:00.000Z';\n\n    try {\n      mkdirSync(dirname(workspace.pidFilePath), { recursive: true });\n      writeFileSync(workspace.pidFilePath, JSON.stringify({ pid: holder.pid, startedAt }));\n\n      // No socketPath in the planted lease + bridge disabled -> deterministic JSON-RPC diagnostic.\n      const run = spawnLauncher(workspace, { SPECKIT_LAUNCHER_BRIDGE_DISABLED: '1' });\n      await waitForStdoutClose(run);\n      const exit = await waitForExit(run.child, 10000);\n\n      expect(exit.code).toBe(0);\n      expectRetryableLeaseHeld(run.stdout, holder.pid as number, 'bridge-disabled');\n    } finally {\n      holder.kill('SIGTERM');\n      try {\n        await waitForExit(holder, 2000);\n      } catch {\n        holder.kill('SIGKILL');\n      }\n    }\n  });\n\n  // dead-PID lease files are reclaimable.\n  it('reclaims a dead-pid lease file and logs staleReclaimed', async () => {\n    const workspace = createWorkspace();\n    mkdirSync(dirname(workspace.pidFilePath), { recursive: true });\n    writeFileSync(workspace.pidFilePath, JSON.stringify({ pid: await createDeadPid(), startedAt: new Date().toISOString() }));\n\n    const run = spawnLauncher(workspace);\n    await waitFor(() => /^.*staleReclaimed: true\\b/m.test(run.stderr), 8000, 'stale reclaim log');\n    expect(run.stderr).toMatch(/^.*staleReclaimed: true\\b/m);\n    await waitForLeasePid(workspace.pidFilePath, run.child.pid);","lineStart":250,"lineEnd":369,"totalLines":498,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-lease.vitest.ts","time":{"start":1780907210780,"end":1780907210788}},"metadata":{"openai":{"itemId":"fc_0c962319919755eb016a267cca4b5c8191b676ac0a21b29d9b"}},"id":"prt_ea657763a001td454o55KSfdHq","sessionID":"ses_159acb43affeAz2922ChDQjScP","messageID":"msg_ea6575ece001BP06bZNWaUGP9s"}}
