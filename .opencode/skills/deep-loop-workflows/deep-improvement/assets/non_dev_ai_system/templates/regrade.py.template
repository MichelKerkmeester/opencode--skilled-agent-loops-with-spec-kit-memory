#!/usr/bin/env python3
"""Independent blind re-grader (council guardrail #2).

  regrade.py <result-file.txt> [more files...]      (set GRADER_MODEL to override the default)

For each benchmark result file: extract the <DELIVERABLE>, grade it BLIND on a DIFFERENT model
family than the proposer ({{PROPOSER_FAMILY}}), against the FROZEN rubric in benchmark/_gates/, run the
deterministic linter, and append a phantom-gap record (self-reported score vs independent score) to
results/regrade.jsonl.

This is the go/no-go instrument: a large, persistent self-vs-independent gap means the benchmark's
self-reported scores are inflated and the auto-refine premise is unsafe until fixed.

Dispatch discipline (matches run.sh): single dispatch per call, stdin redirected from /dev/null
(opencode hangs at 0% CPU otherwise), and NEVER pkill 'opencode run' (kills operator sessions).
"""
import json
import os
import re
import subprocess
import sys
from typing import Any, Dict, List, Optional

CW = os.environ.get("{{PACKAGING_ROOT_ENV}}", "{{PACKAGING_ROOT}}")
BARTER = os.path.dirname(CW)
GATES = os.path.join(CW, "benchmark", "_gates")
HERE = os.path.dirname(os.path.abspath(__file__))
OUT = os.path.join(HERE, "..", "results", "regrade.jsonl")

GRADER_MODEL = os.environ.get("GRADER_MODEL", "{{GRADER_MODEL}}")
PROPOSER_FAMILY = "{{PROPOSER_FAMILY}}"

DIM_KEYS = {{DIMENSIONS_KEYS}}

# KILL-SWITCH: the grader must never be the proposer's model family (collusion / shared blind spots).
if PROPOSER_FAMILY in GRADER_MODEL.lower():
    sys.exit(f"KILL-SWITCH: grader model '{GRADER_MODEL}' is the proposer family '{PROPOSER_FAMILY}'. Grader MUST differ.")

ANSI = re.compile(r"\x1b\[[0-9;]*m")
DELIM = re.compile(r"<DELIVERABLE>(.*?)</DELIVERABLE>", re.S | re.I)
FENCE = re.compile(r"```[a-zA-Z]*\n(.*?)```", re.S)


def extract_deliverable(raw: str) -> str:
    """Extract the deliverable text from a benchmark result, stripping ANSI codes."""
    raw = ANSI.sub("", raw)
    m = DELIM.findall(raw) or FENCE.findall(raw)
    return "\n".join(m).strip() if m else ""


def self_score(raw: str) -> Optional[int]:
    m = re.search(r"{{SELF_SCORE_REGEX}}", ANSI.sub("", raw), re.I)
    return int(m.group(1)) if m else None


# R5-P2-003: scoring-rubric subset only (anchored frozen regions), not the full frozen surface
RUBRIC_FILES = {{RUBRIC_FROZEN_FILES}}


def rubric() -> str:
    return "\n".join(open(os.path.join(GATES, f), encoding="utf-8").read() for f in RUBRIC_FILES)


def grade(deliverable: str) -> Dict[str, Any]:
    prompt = (open(os.path.join(HERE, "grader_prompt.md"), encoding="utf-8").read()
              .replace("{RUBRIC}", rubric()).replace("{DELIVERABLE}", deliverable))
    r = subprocess.run(["opencode", "run", "--model", GRADER_MODEL, "--variant", "high",
                        "--dir", BARTER, prompt],
                       stdin=subprocess.DEVNULL, capture_output=True, text=True, timeout=600)
    out = ANSI.sub("", r.stdout)
    for line in reversed(out.splitlines()):
        if '"total"' not in line:
            continue
        start, end = line.find("{"), line.rfind("}")
        if start != -1 and end > start:
            try:
                return json.loads(line[start:end + 1])
            except Exception:
                continue
    m = re.search(r'\{[^{}]*"total"[^{}]*\}', out)
    return json.loads(m.group(0)) if m else {"error": "no-json", "tail": out[-200:]}


def lint(path: str) -> Dict[str, Any]:
    r = subprocess.run(["python3", os.path.join(HERE, "deterministic_lint.py"), path], capture_output=True, text=True)
    try:
        return json.loads(r.stdout)
    except Exception:
        return {"clean": None}


def main() -> None:
    files = sys.argv[1:]
    if not files:
        sys.exit("usage: regrade.py <result-file.txt> [more...]  (GRADER_MODEL env overrides the grader)")
    os.makedirs(os.path.dirname(OUT), exist_ok=True)
    for f in files:
        raw = open(f, encoding="utf-8", errors="replace").read()
        deliv = extract_deliverable(raw)
        if not deliv:
            print(f"skip {f}: no <DELIVERABLE> block (re-run the benchmark with the output contract first)")
            continue
        g, s, l = grade(deliv), self_score(raw), lint(f)
        indep = g.get("total")
        rec = {
            "file": os.path.relpath(f, CW), "grader_model": GRADER_MODEL,
            "self_meqt": s, "independent_meqt": indep,
            "dims": {k: g.get(k) for k in DIM_KEYS},
            "phantom_gap": (s - indep) if (s is not None and indep is not None) else None,
            "grader_floors_met": g.get("floors_met"), "hvr_lint_clean": l.get("clean"),
            "hvr_violations": [v["type"] for v in l.get("violations", []) if v.get("severity") == "hard"],
            "grader_notes": g.get("notes"), "grader_error": g.get("error"),
        }
        open(OUT, "a", encoding="utf-8").write(json.dumps(rec, ensure_ascii=False) + "\n")
        print(json.dumps(rec, ensure_ascii=False))


if __name__ == "__main__":
    main()
