notApplicable\": 0,\n      \"gatingFailures\": 2\n    },\n    \"results\": [\n      {\n        \"protocolId\": \"spec_code\",\n        \"status\": \"fail\",\n        \"gateClass\": \"hard\",\n        \"applicable\": true,\n        \"counts\": {\n          \"pass\": 0,\n          \"partial\": 0,\n          \"fail\": 1,\n          \"skipped\": 0\n        },\n        \"evidence\": [\n          \".opencode/specs/sk-code/019-split-doc-template-alignment/spec.md:67-72\",\n          \".opencode/skills/sk-code/code-webflow/references/shared/enforcement.md:15-30\"\n        ],\n        \"findingRefs\": [\n          \"C1-P1-001\"\n        ],\n        \"summary\": \"Provisional R3 contradiction.\"\n      },\n      {\n        \"protocolId\": \"checklist_evidence\",\n        \"status\": \"fail\",\n        \"gateClass\": \"hard\",\n        \"applicable\": true,\n        \"counts\": {\n          \"pass\": 0,\n          \"partial\": 0,\n          \"fail\": 1,\n          \"skipped\": 0\n        },\n        \"evidence\": [\n          \".opencode/specs/sk-code/019-split-doc-template-alignment/checklist.md:49-52\",\n          \".opencode/skills/sk-code/code-webflow/references/shared/enforcement.md:15-30\"\n        ],\n        \"findingRefs\": [\n          \"C1-P1-001\"\n        ],\n        \"summary\": \"Validator evidence does not prove the ordering invariant.\"\n      }\n    ]\n  },\n  \"divergence\": {\n    \"started\": [],\n    \"completed\": [],\n    \"failed\": [],\n    \"overrides\": [],\n    \"saturatedDirections\": [],\n    \"remainingFrontier\": [],\n    \"currentFocus\": \"\"\n  },\n  \"fieldWarnings\": [],\n  \"corruptionWarnings\": []\n}","lineStart":1,"lineEnd":233,"totalLines":233,"truncated":false}},"title":".opencode/specs/sk-code/019-split-doc-template-alignment/review/xhigh-confirm/lineages/confirm-c/deep-review-findings-registry.json","time":{"start":1783921771211,"end":1783921771222}},"metadata":{"openai":{"itemId":"fc_071f11a6fcdcb619016a547c6a208481919b82998047732