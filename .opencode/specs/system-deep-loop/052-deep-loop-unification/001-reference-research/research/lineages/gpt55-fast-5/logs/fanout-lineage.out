581:     minIdeaObservations: resolveMinIdeaObservations(config),\n2582:   });\n2583:   // Expose corruptionWarnings as a top-level registry field for parity with\n2584:   // deep-review.\n2585:   registry.corruptionWarnings = corruptionWarnings;\n2586:   registry.inboxPath = inboxPath;\n2587:   registry.inboxWarnings = inbox.warnings;\n2588:   registry.status = status;\n2589:   if (write) {\n2590:     for (const warning of registry.rejectedPatternWarnings) {\n2591:       console.warn(warning);\n2592:     }\n2593:   }\n2594:   const evidenceRecords = records.filter((record) => record.status !== 'thought');\n2595:   const ratioHistory = evidenceRecords\n2596:     .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n2597:     .filter((value) => value !== null);\n2598:   const scoreHistory = evidenceRecords\n2599:     .map(readIterationScore)\n2600:     .filter(isFiniteNumber);\n2601:   registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n2602:     newInfoRatio: ratioHistory,\n2603:     score: scoreHistory,\n2604:   }, evidenceRecords.at(-1));\n2605:   const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n2606:   const dashboard = renderDashboard(config, registry, records, iterationFiles);\n2607:   let resourceMap = null;\n2608:   let resourceMapSkipped = true;\n2609:   let resourceMapSkipReason = null;\n2610: \n2611:   if (corruptionWarnings.length > 0 && !lenient) {\n2612:     throw createCorruptionError(stateLogPath, corruptionWarnings);\n2613:   }\n2614: \n2615:   if (emitResourceMapOutput) {\n2616:     if (getResourceMapEmitSetting(config) === false) {\n2617:       resourceMapSkipReason = 'config.resource_map.emit=false';\n2618:     } else {\n2619:       const deltaPayloads = loadDeltaPayloads(deltaDir);\n2620:       if (!deltaPayloads.length) {\n2621:         resourceMapSkipReason = 'no delta files found';\n2622:       } else {\n2623:         resourceMap = emitResourceMap({\n