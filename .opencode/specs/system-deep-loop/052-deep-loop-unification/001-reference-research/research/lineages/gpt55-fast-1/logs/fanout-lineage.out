ries,\n643:             failure_class: result.error.failure_class,\n644:             retry_verdict: result.error.retry_verdict,\n645:           });\n646:         }\n647:         return;\n648:       }\n649: \n650:       result.retry_attempts = retryCount;\n651:       result.retry_exhausted = result.error.retryable === true && retryCount >= maxRetries;\n652:       results[index] = result;\n653:       emitSettledResult(result, true);\n654:     };\n655: \n656:     const buildPoolErrorResult = (activeAttempt, error) => ({\n657:       label: activeAttempt.label,\n658:       status: 'rejected',\n659:       index: activeAttempt.index,\n660:       attempt: activeAttempt.attempt,\n661:       started_at_iso: activeAttempt.startedAtIso,\n662:       completed_at_iso: normalizeTimestamp(now()),\n663:       duration_ms: Math.max(0, Date.now() - activeAttempt.startedAtMs),\n664:       error: normalizeError({ name: 'PoolError', message: String(error) }),\n665:     });\n666: \n667:     const settleActiveAttempt = (activeAttempt, result) => {\n668:       if (activeAttempt.settled) {\n669:         return;\n670:       }\n671:       activeAttempt.settled = true;\n672:       activeAttempts.delete(activeAttempt.id);\n673:       handleSettledResult(activeAttempt, result);\n674:       active -= 1;\n675:       // Every settlement (success, failure, or retry re-queue) is forward progress:\n676:       // reset the stall clock so a healthy pool's steady completions keep the lag\n677:       // metric small and only a true stall (no settlement) lets it grow.\n678:       markProgress();\n679:       scheduleLagCeilingCheck();\n680:       pump();\n681:     };\n682: \n683:     const abortStalledAttempt = (gauges) => {\n684:       if (!shouldAbortStalledLineages || activeAttempts.size === 0 || queue.length === 0) return false;\n685:       if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return false;\n686:       const activeAttempt = activeAttempts.values().next().value;\n687:       if (!activeA