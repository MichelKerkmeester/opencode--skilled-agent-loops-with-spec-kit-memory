{"type":"tool_use","timestamp":1784606395170,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d48a957fd2a1f9ffd4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Generation Manifest Tests                                                ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import assert from 'node:assert/strict';\n6: import { existsSync } from 'node:fs';\n7: import { mkdtemp, readdir, readFile, rm, writeFile } from 'node:fs/promises';\n8: import os from 'node:os';\n9: import path from 'node:path';\n10: import test from 'node:test';\n11: \n12: import { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\n13: import { buildStyleDatabase } from '../indexer.mjs';\n14: import { resolvePublishedDatabasePath, STYLE_DATABASE_POINTER_SUFFIX } from '../schema.mjs';\n15: import {\n16:   buildManifest,\n17:   hashArtifactFile,\n18:   pruneManifestGenerations,\n19:   readManifest,\n20:   resolveManifestArtifacts,\n21:   resolvePublishedTarget,\n22:   writeManifestPointer,\n23: } from '../generation-manifest.mjs';\n24: \n25: async function scratchDir() {\n26:   const base = await mkdtemp(path.join(os.tmpdir(), 'style-manifest-'));\n27:   return base;\n28: }\n29: \n30: async function writeArtifact(directory, file, bytes) {\n31:   await writeFile(path.join(directory, file), bytes);\n32:   const { sha256, bytes: byteLength } = await hashArtifactFile(path.join(directory, file));\n33:   return { role: file, file, sha256, bytes: byteLength };\n34: }\n35: \n36: test('a build publishes a manifest pointer that resolves every artifact', async (context) => {\n37:   const fixture = await createFixtureCorpus();\n38:   context.after(fixture.cleanup);\n39:   const databasePath = path.join(fixture.base, 'manifest-style.sqlite');\n40:   const built = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n41: \n42:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n43:   const manifest = await readManifest(pointerPath);\n44:   assert.equal(manifest.document.manifestVersion, 1);\n45:   assert.equal(manifest.generationHash, built.generationHash);\n46:   assert.equal(manifest.document.artifacts.sqlite.file, path.basename(built.generationDatabasePath));\n47:   assert.ok(manifest.document.artifacts.sqlite.sha256.startsWith('sha256:'));\n48:   assert.ok(Number.isInteger(manifest.document.artifacts.sqlite.bytes));\n49: \n50:   const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n51:   assert.equal(resolved.generationHash, built.generationHash);\n52:   assert.equal(resolved.legacy, false);\n53:   assert.ok(resolved.artifacts.sqlite.path.endsWith(path.basename(built.generationDatabasePath)));\n54: });\n55: \n56: test('an interrupted publish leaves the prior manifest fully readable', async (context) => {\n57:   const fixture = await createFixtureCorpus();\n58:   context.after(fixture.cleanup);\n59:   const databasePath = path.join(fixture.base, 'interrupted-style.sqlite');\n60:   const first = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n61: \n62:   const { appendDesignText } = await import('../../_engine/__tests__/fixtures.mjs');\n63:   await appendDesignText(fixture.root, 'alpha', 'An interrupted second generation.');\n64:   await assert.rejects(buildStyleDatabase({\n65:     corpusRoot: fixture.root,\n66:     databasePath,\n67:     failureInjector: ({ phase }) => {\n68:       if (phase === 'PUBLISH') throw new Error('simulated-pre-pointer-failure');\n69:     },\n70:   }), /simulated-pre-pointer-failure/);\n71: \n72:   assert.equal(resolvePublishedDatabasePath(databasePath), first.generationDatabasePath);\n73:   const resolved = await resolveManifestArtifacts(\n74:     `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`,\n75:     { verifyDigests: true },\n76:   );\n77:   assert.equal(resolved.generationHash, first.generationHash);\n78: });\n79: \n80: test('a multi-artifact manifest publishes and validates every artifact', async (context) => {\n81:   const directory = await scratchDir();\n82:   context.after(() => rm(directory, { recursive: true, force: true }));\n83:   const pointerPath = path.join(directory, 'style.sqlite.current.json');\n84: \n85:   const artifacts = {\n86:     sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'sqlite-gen1-bytes'),\n87:     screenshotFeatures: await writeArtifact(directory, 'style.features.gen1.bin', 'feature-gen1-bytes'),\n88:     modelProfiles: await writeArtifact(directory, 'style.models.gen1.json', '{\"profile\":\"gen1\"}'),\n89:   };\n90:   const manifest = buildManifest({\n91:     generationHash: 'sha256:gen1',\n92:     createdAt: '2026-01-01T00:00:00.000Z',\n93:     artifacts,\n94:   });\n95:   await writeManifestPointer(pointerPath, manifest);\n96: \n97:   const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n98:   assert.deepEqual(Object.keys(resolved.artifacts).sort(), ['modelProfiles', 'screenshotFeatures', 'sqlite']);\n99:   assert.equal(resolved.generationHash, 'sha256:gen1');\n100: });\n101: \n102: test('a tampered artifact fails digest verification', async (context) => {\n103:   const directory = await scratchDir();\n104:   context.after(() => rm(directory, { recursive: true, force: true }));\n105:   const pointerPath = path.join(directory, 'style.sqlite.current.json');\n106:   const artifacts = {\n107:     sqlite: await writeArtifact(directory, 'style.sqlite.sha256-genT.sqlite', 'original-bytes'),\n108:   };\n109:   await writeManifestPointer(pointerPath, buildManifest({\n110:     generationHash: 'sha256:genT',\n111:     createdAt: '2026-01-01T00:00:00.000Z',\n112:     artifacts,\n113:   }));\n114:   await writeFile(path.join(directory, 'style.sqlite.sha256-genT.sqlite'), 'tampered-bytes');\n115:   await assert.rejects(\n116:     resolveManifestArtifacts(pointerPath, { verifyDigests: true }),\n117:     (error) => error.code === 'generation-artifact-tampered',\n118:   );\n119: });\n120: \n121: test('an interrupted pointer flip is atomic and never leaves a temp file', async (context) => {\n122:   const directory = await scratchDir();\n123:   context.after(() => rm(directory, { recursive: true, force: true }));\n124:   const pointerPath = path.join(directory, 'style.sqlite.current.json');\n125: \n126:   const genOne = buildManifest({\n127:     generationHash: 'sha256:gen1',\n128:     createdAt: '2026-01-01T00:00:00.000Z',\n129:     artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'gen1') },\n130:   });\n131:   await writeManifestPointer(pointerPath, genOne);\n132: \n133:   const genTwo = buildManifest({\n134:     generationHash: 'sha256:gen2',\n135:     createdAt: '2026-01-02T00:00:00.000Z',\n136:     parentGenerationHash: 'sha256:gen1',\n137:     artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen2.sqlite', 'gen2') },\n138:   });\n139:   await assert.rejects(writeManifestPointer(pointerPath, genTwo, {\n140:     afterRename: () => { throw new Error('simulated-post-rename-failure'); },\n141:   }), /simulated-post-rename-failure/);\n142: \n143:   const manifest = await readManifest(pointerPath);\n144:   assert.ok(['sha256:gen1', 'sha256:gen2'].includes(manifest.generationHash));\n145:   assert.ok(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')));\n146:   const leftovers = (await readdir(directory)).filter((name) => name.includes('.tmp-'));\n147:   assert.deepEqual(leftovers, []);\n148: });\n149: \n150: test('retention prunes whole generations while keeping the retained set intact', async (context) => {\n151:   const directory = await scratchDir();\n152:   context.after(() => rm(directory, { recursive: true, force: true }));\n153: \n154:   const manifestFor = async (generation) => buildManifest({\n155:     generationHash: `sha256:${generation}`,\n156:     createdAt: '2026-01-01T00:00:00.000Z',\n157:     artifacts: {\n158:       sqlite: await writeArtifact(directory, `style.sqlite.sha256-${generation}.sqlite`, `${generation}-db`),\n159:       screenshotFeatures: await writeArtifact(directory, `style.features.${generation}.bin`, `${generation}-feat`),\n160:     },\n161:   });\n162:   const genOne = await manifestFor('gen1');\n163:   const genTwo = await manifestFor('gen2');\n164:   const genThree = await manifestFor('gen3');\n165: \n166:   const outcome = await pruneManifestGenerations({\n167:     directory,\n168:     retain: [genThree, genTwo],\n169:     prune: [genOne],\n170:   });\n171:   assert.deepEqual(outcome.removed.sort(), ['style.features.gen1.bin', 'style.sqlite.sha256-gen1.sqlite']);\n172:   assert.equal(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')), false);\n173:   assert.equal(existsSync(path.join(directory, 'style.features.gen1.bin')), false);\n174:   for (const generation of ['gen2', 'gen3']) {\n175:     assert.ok(existsSync(path.join(directory, `style.sqlite.sha256-${generation}.sqlite`)));\n176:     assert.ok(existsSync(path.join(directory, `style.features.${generation}.bin`)));\n177:   }\n178: });\n179: \n180: test('retention never removes an artifact shared with a retained manifest', async (context) => {\n181:   const directory = await scratchDir();\n182:   context.after(() => rm(directory, { recursive: true, force: true }));\n183:   const shared = await writeArtifact(directory, 'style.models.shared.json', '{\"shared\":true}');\n184:   const retained = buildManifest({\n185:     generationHash: 'sha256:keep',\n186:     createdAt: '2026-01-01T00:00:00.000Z',\n187:     artifacts: {\n188:       sqlite: await writeArtifact(directory, 'style.sqlite.sha256-keep.sqlite', 'keep'),\n189:       modelProfiles: shared,\n190:     },\n191:   });\n192:   const pruned = buildManifest({\n193:     generationHash: 'sha256:drop',\n194:     createdAt: '2026-01-01T00:00:00.000Z',\n195:     artifacts: {\n196:       sqlite: await writeArtifact(directory, 'style.sqlite.sha256-drop.sqlite', 'drop'),\n197:       modelProfiles: shared,\n198:     },\n199:   });\n200:   const outcome = await pruneManifestGenerations({ directory, retain: [retained], prune: [pruned] });\n201:   assert.deepEqual(outcome.removed, ['style.sqlite.sha256-drop.sqlite']);\n202:   assert.ok(existsSync(path.join(directory, 'style.models.shared.json')));\n203: });\n204: \n205: test('a legacy single-file pointer still resolves', async (context) => {\n206:   const directory = await scratchDir();\n207:   context.after(() => rm(directory, { recursive: true, force: true }));\n208:   const databasePath = path.join(directory, 'legacy.sqlite');\n209:   const generationFile = 'legacy.sqlite.sha256-legacy.sqlite';\n210:   await writeFile(path.join(directory, generationFile), 'legacy-db-bytes');\n211:   await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n212:     schemaVersion: 1,\n213:     generationHash: 'sha256:legacy',\n214:     databaseFile: generationFile,\n215:   }, null, 2)}\\n`);\n216: \n217:   const target = resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n218:   assert.equal(target.generationHash, 'sha256:legacy');\n219:   assert.equal(path.basename(target.databasePath), generationFile);\n220: \n221:   const manifest = await readManifest(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`);\n222:   assert.equal(manifest.legacy, true);\n223:   assert.equal(manifest.artifacts.sqlite.file, generationFile);\n224: });\n225: \n226: test('an invalid pointer shape is rejected', async (context) => {\n227:   const directory = await scratchDir();\n228:   context.after(() => rm(directory, { recursive: true, force: true }));\n229:   const databasePath = path.join(directory, 'broken.sqlite');\n230:   await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n231:     manifestVersion: 1,\n232:     generationHash: 'sha256:broken',\n233:     artifacts: { sqlite: { file: '../escape.sqlite' } },\n234:   })}\\n`);\n235:   assert.throws(\n236:     () => resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX),\n237:     (error) => error.code === 'generation-pointer-invalid',\n238:   );\n239: });\n\n(End of file - total 239 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation Manifest Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { existsSync } from 'node:fs';\nimport { mkdtemp, readdir, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { buildStyleDatabase } from '../indexer.mjs';\nimport { resolvePublishedDatabasePath, STYLE_DATABASE_POINTER_SUFFIX } from '../schema.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  pruneManifestGenerations,\n  readManifest,\n  resolveManifestArtifacts,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation Manifest Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { existsSync } from 'node:fs';\nimport { mkdtemp, readdir, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { buildStyleDatabase } from '../indexer.mjs';\nimport { resolvePublishedDatabasePath, STYLE_DATABASE_POINTER_SUFFIX } from '../schema.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  pruneManifestGenerations,\n  readManifest,\n  resolveManifestArtifacts,\n  resolvePublishedTarget,\n  writeManifestPointer,\n} from '../generation-manifest.mjs';\n\nasync function scratchDir() {\n  const base = await mkdtemp(path.join(os.tmpdir(), 'style-manifest-'));\n  return base;\n}\n\nasync function writeArtifact(directory, file, bytes) {\n  await writeFile(path.join(directory, file), bytes);\n  const { sha256, bytes: byteLength } = await hashArtifactFile(path.join(directory, file));\n  return { role: file, file, sha256, bytes: byteLength };\n}\n\ntest('a build publishes a manifest pointer that resolves every artifact', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const databasePath = path.join(fixture.base, 'manifest-style.sqlite');\n  const built = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const manifest = await readManifest(pointerPath);\n  assert.equal(manifest.document.manifestVersion, 1);\n  assert.equal(manifest.generationHash, built.generationHash);\n  assert.equal(manifest.document.artifacts.sqlite.file, path.basename(built.generationDatabasePath));\n  assert.ok(manifest.document.artifacts.sqlite.sha256.startsWith('sha256:'));\n  assert.ok(Number.isInteger(manifest.document.artifacts.sqlite.bytes));\n\n  const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n  assert.equal(resolved.generationHash, built.generationHash);\n  assert.equal(resolved.legacy, false);\n  assert.ok(resolved.artifacts.sqlite.path.endsWith(path.basename(built.generationDatabasePath)));\n});\n\ntest('an interrupted publish leaves the prior manifest fully readable', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const databasePath = path.join(fixture.base, 'interrupted-style.sqlite');\n  const first = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n\n  const { appendDesignText } = await import('../../_engine/__tests__/fixtures.mjs');\n  await appendDesignText(fixture.root, 'alpha', 'An interrupted second generation.');\n  await assert.rejects(buildStyleDatabase({\n    corpusRoot: fixture.root,\n    databasePath,\n    failureInjector: ({ phase }) => {\n      if (phase === 'PUBLISH') throw new Error('simulated-pre-pointer-failure');\n    },\n  }), /simulated-pre-pointer-failure/);\n\n  assert.equal(resolvePublishedDatabasePath(databasePath), first.generationDatabasePath);\n  const resolved = await resolveManifestArtifacts(\n    `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`,\n    { verifyDigests: true },\n  );\n  assert.equal(resolved.generationHash, first.generationHash);\n});\n\ntest('a multi-artifact manifest publishes and validates every artifact', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const pointerPath = path.join(directory, 'style.sqlite.current.json');\n\n  const artifacts = {\n    sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'sqlite-gen1-bytes'),\n    screenshotFeatures: await writeArtifact(directory, 'style.features.gen1.bin', 'feature-gen1-bytes'),\n    modelProfiles: await writeArtifact(directory, 'style.models.gen1.json', '{\"profile\":\"gen1\"}'),\n  };\n  const manifest = buildManifest({\n    generationHash: 'sha256:gen1',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts,\n  });\n  await writeManifestPointer(pointerPath, manifest);\n\n  const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n  assert.deepEqual(Object.keys(resolved.artifacts).sort(), ['modelProfiles', 'screenshotFeatures', 'sqlite']);\n  assert.equal(resolved.generationHash, 'sha256:gen1');\n});\n\ntest('a tampered artifact fails digest verification', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const pointerPath = path.join(directory, 'style.sqlite.current.json');\n  const artifacts = {\n    sqlite: await writeArtifact(directory, 'style.sqlite.sha256-genT.sqlite', 'original-bytes'),\n  };\n  await writeManifestPointer(pointerPath, buildManifest({\n    generationHash: 'sha256:genT',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts,\n  }));\n  await writeFile(path.join(directory, 'style.sqlite.sha256-genT.sqlite'), 'tampered-bytes');\n  await assert.rejects(\n    resolveManifestArtifacts(pointerPath, { verifyDigests: true }),\n    (error) => error.code === 'generation-artifact-tampered',\n  );\n});\n\ntest('an interrupted pointer flip is atomic and never leaves a temp file', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const pointerPath = path.join(directory, 'style.sqlite.current.json');\n\n  const genOne = buildManifest({\n    generationHash: 'sha256:gen1',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'gen1') },\n  });\n  await writeManifestPointer(pointerPath, genOne);\n\n  const genTwo = buildManifest({\n    generationHash: 'sha256:gen2',\n    createdAt: '2026-01-02T00:00:00.000Z',\n    parentGenerationHash: 'sha256:gen1',\n    artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen2.sqlite', 'gen2') },\n  });\n  await assert.rejects(writeManifestPointer(pointerPath, genTwo, {\n    afterRename: () => { throw new Error('simulated-post-rename-failure'); },\n  }), /simulated-post-rename-failure/);\n\n  const manifest = await readManifest(pointerPath);\n  assert.ok(['sha256:gen1', 'sha256:gen2'].includes(manifest.generationHash));\n  assert.ok(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')));\n  const leftovers = (await readdir(directory)).filter((name) => name.includes('.tmp-'));\n  assert.deepEqual(leftovers, []);\n});\n\ntest('retention prunes whole generations while keeping the retained set intact', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n\n  const manifestFor = async (generation) => buildManifest({\n    generationHash: `sha256:${generation}`,\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: {\n      sqlite: await writeArtifact(directory, `style.sqlite.sha256-${generation}.sqlite`, `${generation}-db`),\n      screenshotFeatures: await writeArtifact(directory, `style.features.${generation}.bin`, `${generation}-feat`),\n    },\n  });\n  const genOne = await manifestFor('gen1');\n  const genTwo = await manifestFor('gen2');\n  const genThree = await manifestFor('gen3');\n\n  const outcome = await pruneManifestGenerations({\n    directory,\n    retain: [genThree, genTwo],\n    prune: [genOne],\n  });\n  assert.deepEqual(outcome.removed.sort(), ['style.features.gen1.bin', 'style.sqlite.sha256-gen1.sqlite']);\n  assert.equal(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')), false);\n  assert.equal(existsSync(path.join(directory, 'style.features.gen1.bin')), false);\n  for (const generation of ['gen2', 'gen3']) {\n    assert.ok(existsSync(path.join(directory, `style.sqlite.sha256-${generation}.sqlite`)));\n    assert.ok(existsSync(path.join(directory, `style.features.${generation}.bin`)));\n  }\n});\n\ntest('retention never removes an artifact shared with a retained manifest', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const shared = await writeArtifact(directory, 'style.models.shared.json', '{\"shared\":true}');\n  const retained = buildManifest({\n    generationHash: 'sha256:keep',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: {\n      sqlite: await writeArtifact(directory, 'style.sqlite.sha256-keep.sqlite', 'keep'),\n      modelProfiles: shared,\n    },\n  });\n  const pruned = buildManifest({\n    generationHash: 'sha256:drop',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: {\n      sqlite: await writeArtifact(directory, 'style.sqlite.sha256-drop.sqlite', 'drop'),\n      modelProfiles: shared,\n    },\n  });\n  const outcome = await pruneManifestGenerations({ directory, retain: [retained], prune: [pruned] });\n  assert.deepEqual(outcome.removed, ['style.sqlite.sha256-drop.sqlite']);\n  assert.ok(existsSync(path.join(directory, 'style.models.shared.json')));\n});\n\ntest('a legacy single-file pointer still resolves', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const databasePath = path.join(directory, 'legacy.sqlite');\n  const generationFile = 'legacy.sqlite.sha256-legacy.sqlite';\n  await writeFile(path.join(directory, generationFile), 'legacy-db-bytes');\n  await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n    schemaVersion: 1,\n    generationHash: 'sha256:legacy',\n    databaseFile: generationFile,\n  }, null, 2)}\\n`);\n\n  const target = resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n  assert.equal(target.generationHash, 'sha256:legacy');\n  assert.equal(path.basename(target.databasePath), generationFile);\n\n  const manifest = await readManifest(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`);\n  assert.equal(manifest.legacy, true);\n  assert.equal(manifest.artifacts.sqlite.file, generationFile);\n});\n\ntest('an invalid pointer shape is rejected', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const databasePath = path.join(directory, 'broken.sqlite');\n  await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n    manifestVersion: 1,\n    generationHash: 'sha256:broken',\n    artifacts: { sqlite: { file: '../escape.sqlite' } },\n  })}\\n`);\n  assert.throws(\n    () => resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX),\n    (error) => error.code === 'generation-pointer-invalid',\n  );\n});","lineStart":1,"lineEnd":239,"totalLines":239,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs","time":{"start":1784606395163,"end":1784606395167}},"id":"prt_f82d48b0a001cwnjZYTdf8953I","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d4538a001dbeCSjMS0TbbUE"}}
{"type":"step_finish","timestamp":1784606395698,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d48d30001UwMfzfAAOEROLp","reason":"tool-calls","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","messageID":"msg_f82d4538a001dbeCSjMS0TbbUE","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","type":"step-finish","tokens":{"total":106001,"input":4524,"output":1381,"reasoning":0,"cache":{"write":0,"read":100096}},"cost":0.00902016}}
{"type":"step_start","timestamp":1784606397875,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d495b2001GYIVad0RRMSZAe","messageID":"msg_f82d48ebc001VpT7XtL2ogmu4X","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","type":"step-start"}}
{"type":"tool_use","timestamp":1784606406976,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d4b55e7a31856763bd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Incremental Style Database Indexer                                       ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import {\n6:   lstat,\n7:   open,\n8:   readFile,\n9:   readdir,\n10:   realpath,\n11:   rename,\n12:   rm,\n13:   stat,\n14: } from 'node:fs/promises';\n15: import path from 'node:path';\n16: \n17: import {\n18:   compareRawStrings,\n19:   digest,\n20:   lengthFrame,\n21:   stableJson,\n22: } from './canonical.mjs';\n23: import {\n24:   buildManifest,\n25:   hashArtifactFile,\n26:   writeManifestPointer,\n27: } from './generation-manifest.mjs';\n28: import {\n29:   RESIDENCY,\n30: } from './stage-telemetry.mjs';\n31: import {\n32:   DEFAULT_STYLE_DATABASE_PATH,\n33:   STYLE_DB_SCHEMA_VERSION,\n34:   STYLE_DATABASE_POINTER_SUFFIX,\n35:   openStyleDatabase,\n36: } from './schema.mjs';\n37: \n38: export const INDEXER_LIFECYCLE = Object.freeze([\n39:   'DISCOVER',\n40:   'VERIFY',\n41:   'PARSE_VALIDATE',\n42:   'COMMIT',\n43:   'VECTOR_DRAIN',\n44:   'PUBLISH',\n45: ]);\n46: export const DEFAULT_EMBEDDING_PROFILE = 'style-default-v1';\n47: \n48: const AGGREGATE_HASH_VERSION = 'style-all-artifacts-v2';\n49: const RETRIEVAL_HASH_VERSION = 'style-retrieval-document-v1';\n50: const GENERATION_HASH_VERSION = 'style-corpus-generation-v2';\n51: const LICENSE_ALLOWLIST = new Set(['allowed', 'licensed', 'public-domain']);\n52: const RESTRICTED_LICENSE_PATTERN = /\\b(unlicensed trial|license[- ]restricted)\\b/i;\n53: const WARM_SURFACE_PATTERN = /\\b(warm|cream|beige|bone|ivory|linen|sand|tan)\\b/i;\n54: const MOTION_PATTERN = /\\b(motion|animation|animated|transition|kinetic|scroll)\\b/i;\n55: const SERIF_PATTERN = /(^|[^a-z])serif([^a-z]|$)/i;\n56: const SANS_SERIF_PATTERN = /sans[- ]serif/i;\n57: \n58: function nowIso() {\n59:   return new Date().toISOString();\n60: }\n61: \n62: function normalizeTerm(value) {\n63:   return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n64: }\n65: \n66: function normalizeMarkdown(value) {\n67:   return String(value ?? '').normalize('NFC').replace(/\\r\\n?/g, '\\n')\n68:     .split('\\n').map((line) => line.trimEnd()).join('\\n').trimEnd();\n69: }\n70: \n71: function artifactRole(fileName) {\n72:   if (fileName.endsWith('-canonical.json')) return 'canonical';\n73:   if (fileName === 'design-tokens.json') return 'tokens';\n74:   if (fileName === 'DESIGN.md') return 'design';\n75:   if (fileName === 'source.md') return 'source';\n76:   if (fileName === 'css-variables.css') return 'css-variables';\n77:   if (fileName === 'tailwind-v4.css') return 'tailwind';\n78:   return null;\n79: }\n80: \n81: function isContained(rootPath, candidatePath) {\n82:   const relative = path.relative(rootPath, candidatePath);\n83:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n84: }\n85: \n86: function parseJson(artifact, label) {\n87:   if (!artifact) return {};\n88:   try {\n89:     return JSON.parse(artifact.buffer.toString('utf8'));\n90:   } catch (error) {\n91:     const invalid = new Error(`Invalid ${label} JSON: ${artifact.relativePath}`, { cause: error });\n92:     invalid.code = 'invalid-artifact';\n93:     throw invalid;\n94:   }\n95: }\n96: \n97: function countTokenLeaves(value) {\n98:   if (!value || typeof value !== 'object') return 0;\n99:   if (Object.hasOwn(value, '$value')) return 1;\n100:   return Object.values(value).reduce((sum, child) => sum + countTokenLeaves(child), 0);\n101: }\n102: \n103: function deriveTokenAxes(tokens, designSystem) {\n104:   const counts = new Map();\n105:   for (const [axis, value] of Object.entries(tokens ?? {})) {\n106:     const count = countTokenLeaves(value);\n107:     if (count > 0) counts.set(axis, count);\n108:   }\n109:   const fallbackCounts = {\n110:     color: Array.isArray(designSystem.colors) ? designSystem.colors.length : 0,\n111:     spacing: designSystem.spacing ? Object.keys(designSystem.spacing).length : 0,\n112:     typography: Array.isArray(designSystem.typography) ? designSystem.typography.length : 0,\n113:   };\n114:   for (const [axis, count] of Object.entries(fallbackCounts)) {\n115:     if (count > 0 && !counts.has(axis)) counts.set(axis, count);\n116:   }\n117:   return [...counts].map(([axis, count]) => ({ axis, count }))\n118:     .sort((left, right) => compareRawStrings(left.axis, right.axis));\n119: }\n120: \n121: function deriveSections(designMarkdown) {\n122:   const sections = [];\n123:   for (const [index, line] of designMarkdown.split('\\n').entries()) {\n124:     const match = /^##\\s+(.+?)\\s*$/.exec(line);\n125:     if (match) sections.push({ name: match[1], line: index + 1 });\n126:   }\n127:   return sections;\n128: }\n129: \n130: function deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus) {\n131:   const values = new Set();\n132:   if (tokenAxes.length > 0) values.add('tokens');\n133:   if ((designSystem.components?.length ?? 0) > 0) values.add('components');\n134:   if (designSystem.layout) values.add('layout');\n135:   if (designSystem.imagery) values.add('imagery');\n136:   if (designSystem.spacing) values.add('spacing');\n137:   if ((designSystem.dos?.length ?? 0) + (designSystem.donts?.length ?? 0) > 0) {\n138:     values.add('constraints');\n139:   }\n140:   if (provenanceStatus === 'known') values.add('provenance');\n141:   if (sections.some((section) => MOTION_PATTERN.test(section.name))) values.add('motion');\n142:   return [...values].sort(compareRawStrings);\n143: }\n144: \n145: function deriveFacets(style, designSystem, capabilities, tokenAxes, searchableText, licenseStatus) {\n146:   const values = new Set(capabilities);\n147:   for (const { axis } of tokenAxes) values.add(axis);\n148:   if (designSystem.theme) values.add(normalizeTerm(designSystem.theme));\n149:   if (designSystem.industry) values.add(normalizeTerm(designSystem.industry));\n150:   if (SERIF_PATTERN.test(searchableText) && !SANS_SERIF_PATTERN.test(searchableText)) {\n151:     values.add('serif-role');\n152:   }\n153:   if (WARM_SURFACE_PATTERN.test(searchableText)) values.add('warm-surface');\n154:   if (MOTION_PATTERN.test(searchableText)) values.add('motion');\n155:   if (licenseStatus === 'restricted') values.add('license-restricted');\n156:   values.add(normalizeTerm(style.slug));\n157:   return [...values].filter(Boolean).sort(compareRawStrings);\n158: }\n159: \n160: function excerpt(value, maxLength = 240) {\n161:   const normalized = String(value ?? '').replace(/\\s+/g, ' ').trim();\n162:   if (normalized.length <= maxLength) return normalized;\n163:   return `${normalized.slice(0, maxLength - 1).trimEnd()}…`;\n164: }\n165: \n166: function computeAggregateHash(styleId, artifacts) {\n167:   const parts = [\n168:     ...lengthFrame(AGGREGATE_HASH_VERSION),\n169:     ...lengthFrame(styleId),\n170:   ];\n171:   for (const artifact of artifacts.slice()\n172:     .sort((left, right) => compareRawStrings(left.role, right.role))) {\n173:     parts.push(...lengthFrame(artifact.role), ...lengthFrame(artifact.buffer));\n174:   }\n175:   return digest(parts);\n176: }\n177: \n178: function computeHintHash(artifacts) {\n179:   return digest([\n180:     'style-artifact-hints-v1\\0',\n181:     ...artifacts.map((artifact) => (\n182:       `${artifact.relativePath}\\0${artifact.byteLength}\\0${artifact.mtimeNs}\\0${artifact.ctimeNs}\\n`\n183:     )),\n184:   ]);\n185: }\n186: \n187: function computeCrawlRecordHash(crawlRecord) {\n188:   return digest([\n189:     'style-crawl-record-v1\\0',\n190:     stableJson(crawlRecord ?? null),\n191:   ]);\n192: }\n193: \n194: function computeGenerationHash(crawlManifestHash, styles, inactiveStates = []) {\n195:   const parts = [\n196:     ...lengthFrame(GENERATION_HASH_VERSION),\n197:     ...lengthFrame(STYLE_DB_SCHEMA_VERSION),\n198:     ...lengthFrame(crawlManifestHash),\n199:   ];\n200:   for (const style of styles.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n201:     parts.push(...lengthFrame(style.id), ...lengthFrame(style.aggregateHash));\n202:   }\n203:   for (const style of inactiveStates.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n204:     parts.push(...lengthFrame(style.id), ...lengthFrame(style.state));\n205:   }\n206:   return digest(parts);\n207: }\n208: \n209: async function readVerifiedArtifacts(corpusRoot, corpusRealPath, slug) {\n210:   const styleRoot = path.join(corpusRoot, slug);\n211:   const entries = (await readdir(styleRoot, { withFileTypes: true }))\n212:     .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n213:     .sort((left, right) => compareRawStrings(left.name, right.name));\n214:   const artifacts = [];\n215:   for (const entry of entries) {\n216:     const role = artifactRole(entry.name);\n217:     if (!role) {\n218:       const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n219:       error.code = 'invalid-artifact';\n220:       throw error;\n221:     }\n222:     const candidatePath = path.join(styleRoot, entry.name);\n223:     const linkInfo = await lstat(candidatePath, { bigint: true });\n224:     if (!linkInfo.isFile() && !linkInfo.isSymbolicLink()) continue;\n225:     const artifactRealPath = await realpath(candidatePath);\n226:     if (!isContained(corpusRealPath, artifactRealPath)) {\n227:       const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n228:       error.code = 'path-escape';\n229:       throw error;\n230:     }\n231:     const before = await stat(artifactRealPath, { bigint: true });\n232:     const buffer = await readFile(artifactRealPath);\n233:     const after = await stat(artifactRealPath, { bigint: true });\n234:     if (before.size !== after.size || before.mtimeNs !== after.mtimeNs || before.ctimeNs !== after.ctimeNs) {\n235:       const error = new Error(`Corpus changed while reading ${slug}/${entry.name}.`);\n236:       error.code = 'corpus-changing';\n237:       throw error;\n238:     }\n239:     artifacts.push({\n240:       role,\n241:       relativePath: `${slug}/${entry.name}`,\n242:       byteLength: buffer.byteLength,\n243:       sha256: digest([buffer]),\n244:       mtimeNs: String(after.mtimeNs),\n245:       ctimeNs: String(after.ctimeNs),\n246:       buffer,\n247:     });\n248:   }\n249:   if (!artifacts.some((artifact) => artifact.role === 'canonical')\n250:     || !artifacts.some((artifact) => artifact.role === 'design')) {\n251:     const error = new Error(`Style ${slug} lacks its canonical JSON or DESIGN.md artifact.`);\n252:     error.code = 'invalid-artifact';\n253:     throw error;\n254:   }\n255:   return artifacts;\n256: }\n257: \n258: async function readArtifactHints(corpusRoot, corpusRealPath, slug) {\n259:   const styleRoot = path.join(corpusRoot, slug);\n260:   const entries = (await readdir(styleRoot, { withFileTypes: true }))\n261:     .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n262:     .sort((left, right) => compareRawStrings(left.name, right.name));\n263:   const artifacts = [];\n264:   for (const entry of entries) {\n265:     const role = artifactRole(entry.name);\n266:     if (!role) {\n267:       const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n268:       error.code = 'invalid-artifact';\n269:       throw error;\n270:     }\n271:     const candidatePath = path.join(styleRoot, entry.name);\n272:     const artifactRealPath = await realpath(candidatePath);\n273:     if (!isContained(corpusRealPath, artifactRealPath)) {\n274:       const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n275:       error.code = 'path-escape';\n276:       throw error;\n277:     }\n278:     const fileInfo = await stat(artifactRealPath, { bigint: true });\n279:     artifacts.push({\n280:       role,\n281:       relativePath: `${slug}/${entry.name}`,\n282:       byteLength: Number(fileInfo.size),\n283:       mtimeNs: String(fileInfo.mtimeNs),\n284:       ctimeNs: String(fileInfo.ctimeNs),\n285:     });\n286:   }\n287:   return artifacts;\n288: }\n289: \n290: function parseStyle(slug, crawlRecord, artifacts) {\n291:   const canonical = parseJson(artifacts.find((artifact) => artifact.role === 'canonical'), 'canonical');\n292:   const tokens = parseJson(artifacts.find((artifact) => artifact.role === 'tokens'), 'token');\n293:   const designMarkdown = normalizeMarkdown(\n294:     artifacts.find((artifact) => artifact.role === 'design')?.buffer.toString('utf8'),\n295:   );\n296:   const designSystem = canonical.designSystem ?? {};\n297:   const id = canonical.uuid ?? crawlRecord?.uuid;\n298:   if (typeof id !== 'string' || id.length === 0) {\n299:     const error = new Error(`Style ${slug} has no stable UUID.`);\n300:     error.code = 'invalid-artifact';\n301:     throw error;\n302:   }\n303:   const title = excerpt(canonical.name ?? slug, 120);\n304:   const thesis = excerpt(canonical.northStar ?? designSystem.northStar ?? designSystem.description);\n305:   const theme = designSystem.theme == null ? null : String(designSystem.theme);\n306:   const industry = designSystem.industry == null ? null : String(designSystem.industry);\n307:   const sections = deriveSections(designMarkdown);\n308:   const tokenAxes = deriveTokenAxes(tokens, designSystem);\n309:   const provenanceStatus = canonical.source && canonical.uuid && canonical.meta?.url\n310:     ? 'known'\n311:     : 'missing';\n312:   const searchableText = [\n313:     title,\n314:     thesis,\n315:     designSystem.description,\n316:     theme,\n317:     industry,\n318:     designSystem.layout,\n319:     designSystem.imagery,\n320:     ...(Array.isArray(designSystem.typography)\n321:       ? designSystem.typography.map((entry) => `${entry.family ?? ''} ${entry.role ?? ''}`)\n322:       : []),\n323:     designMarkdown.slice(0, 65_536),\n324:   ].join(' ');\n325:   const licenseStatus = RESTRICTED_LICENSE_PATTERN.test(searchableText)\n326:     ? 'restricted'\n327:     : String(canonical.license?.status ?? 'unknown');\n328:   const rightsKnown = LICENSE_ALLOWLIST.has(licenseStatus) || licenseStatus === 'restricted';\n329:   const capabilities = deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus);\n330:   const facets = deriveFacets(\n331:     { slug },\n332:     designSystem,\n333:     capabilities,\n334:     tokenAxes,\n335:     searchableText,\n336:     licenseStatus,\n337:   );\n338:   const retrievalDocument = {\n339:     id,\n340:     title,\n341:     thesis,\n342:     theme,\n343:     industry,\n344:     capabilities,\n345:     facets,\n346:     tokenAxes,\n347:     sections: sections.map((section) => section.name),\n348:     designMarkdown,\n349:   };\n350:   const retrievalJson = stableJson(retrievalDocument);\n351:   const retrievalHash = digest([\n352:     ...lengthFrame(RETRIEVAL_HASH_VERSION),\n353:     ...lengthFrame(retrievalJson),\n354:   ]);\n355:   const aggregateHash = computeAggregateHash(id, artifacts);\n356:   return {\n357:     id,\n358:     slug,\n359:     crawlStatus: crawlRecord?.status ?? 'unknown',\n360:     title,\n361:     thesis,\n362:     theme,\n363:     industry,\n364:     aggregateHash,\n365:     artifactHintHash: computeHintHash(artifacts),\n366:     crawlRecordHash: computeCrawlRecordHash(crawlRecord),\n367:     retrievalHash,\n368:     artifacts,\n369:     tokenAxes,\n370:     sections,\n371:     capabilities,\n372:     facets,\n373:     provenance: {\n374:       status: provenanceStatus,\n375:       sourceUrl: canonical.source ?? crawlRecord?.url ?? null,\n376:       originalUrl: canonical.meta?.url ?? null,\n377:       screenshotUrl: canonical.screenshot?.url ?? null,\n378:       uuid: canonical.uuid ?? crawlRecord?.uuid ?? null,\n379:       capturedAt: canonical.capturedAt ?? crawlRecord?.capturedAt ?? null,\n380:       licenseStatus,\n381:       rightsKnown,\n382:       evidenceScope: ['reference', 'rationale'],\n383:     },\n384:     relationships: (Array.isArray(designSystem.similar) ? designSystem.similar : [])\n385:       .map((relationship, ordinal) => ({\n386:         ordinal,\n387:         rawTargetLabel: String(relationship.business ?? relationship.name ?? '').trim(),\n388:         rationale: String(relationship.why ?? relationship.rationale ?? '').trim(),\n389:       })).filter((relationship) => relationship.rawTargetLabel),\n390:     retrievalDocument: {\n391:       title,\n392:       thesis,\n393:       theme: theme ?? '',\n394:       industry: industry ?? '',\n395:       terms: [...new Set([...facets, ...capabilities, ...tokenAxes.map(({ axis }) => axis)])]\n396:         .sort(compareRawStrings).join(' '),\n397:       body: designMarkdown,\n398:       documentJson: retrievalJson,\n399:       retrievalHash,\n400:     },\n401:   };\n402: }\n403: \n404: function replaceStyleChildren(database, styleRowid, style, timestamp) {\n405:   for (const table of [\n406:     'style_provenance',\n407:     'style_artifacts',\n408:     'style_terms',\n409:     'style_token_axes',\n410:     'style_sections',\n411:     'retrieval_documents',\n412:     'style_relationships',\n413:   ]) {\n414:     const key = table === 'style_relationships' ? 'source_style_rowid' : 'style_rowid';\n415:     database.prepare(`DELETE FROM ${table} WHERE ${key} = ?`).run(styleRowid);\n416:   }\n417:   database.prepare(`\n418:     INSERT INTO style_provenance(\n419:       style_rowid, status, source_url, original_url, screenshot_url, source_uuid,\n420:       captured_at, license_status, rights_known, evidence_scope_json\n421:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n422:   `).run(\n423:     styleRowid,\n424:     style.provenance.status,\n425:     style.provenance.sourceUrl,\n426:     style.provenance.originalUrl,\n427:     style.provenance.screenshotUrl,\n428:     style.provenance.uuid,\n429:     style.provenance.capturedAt,\n430:     style.provenance.licenseStatus,\n431:     style.provenance.rightsKnown ? 1 : 0,\n432:     JSON.stringify(style.provenance.evidenceScope),\n433:   );\n434:   const insertArtifact = database.prepare(`\n435:     INSERT INTO style_artifacts(\n436:       style_rowid, role, relative_path, byte_length, sha256, mtime_ns, ctime_ns\n437:     ) VALUES (?, ?, ?, ?, ?, ?, ?)\n438:   `);\n439:   for (const artifact of style.artifacts) {\n440:     insertArtifact.run(\n441:       styleRowid,\n442:       artifact.role,\n443:       artifact.relativePath,\n444:       artifact.byteLength,\n445:       artifact.sha256,\n446:       artifact.mtimeNs,\n447:       artifact.ctimeNs,\n448:     );\n449:   }\n450:   const insertTerm = database.prepare(\n451:     'INSERT INTO style_terms(style_rowid, term_type, term) VALUES (?, ?, ?)',\n452:   );\n453:   for (const term of style.facets) insertTerm.run(styleRowid, 'facet', term);\n454:   for (const term of style.capabilities) insertTerm.run(styleRowid, 'capability', term);\n455:   const insertAxis = database.prepare(\n456:     'INSERT INTO style_token_axes(style_rowid, axis, token_count) VALUES (?, ?, ?)',\n457:   );\n458:   for (const axis of style.tokenAxes) insertAxis.run(styleRowid, axis.axis, axis.count);\n459:   const insertSection = database.prepare(`\n460:     INSERT INTO style_sections(style_rowid, ordinal, name, line_number) VALUES (?, ?, ?, ?)\n461:   `);\n462:   for (const [ordinal, section] of style.sections.entries()) {\n463:     insertSection.run(styleRowid, ordinal, section.name, section.line);\n464:   }\n465:   const document = style.retrievalDocument;\n466:   database.prepare(`\n467:     INSERT INTO retrieval_documents(\n468:       style_rowid, title, thesis, theme, industry, terms, body, document_json, retrieval_hash\n469:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n470:   `).run(\n471:     styleRowid,\n472:     document.title,\n473:     document.thesis,\n474:     document.theme,\n475:     document.industry,\n476:     document.terms,\n477:     document.body,\n478:     document.documentJson,\n479:     document.retrievalHash,\n480:   );\n481:   const insertRelationship = database.prepare(`\n482:     INSERT INTO style_relationships(\n483:       source_style_rowid, ordinal, raw_target_label, target_style_rowid,\n484:       rationale, resolution_state, confidence\n485:     ) VALUES (?, ?, ?, NULL, ?, 'unresolved', 0)\n486:   `);\n487:   for (const relationship of style.relationships) {\n488:     insertRelationship.run(\n489:       styleRowid,\n490:       relationship.ordinal,\n491:       relationship.rawTargetLabel,\n492:       relationship.rationale,\n493:     );\n494:   }\n495:   database.prepare(`\n496:     INSERT INTO style_index_state(\n497:       style_rowid, artifact_hint_hash, crawl_record_hash, aggregate_hash,\n498:       last_success_generation, last_success_at, missing_observations\n499:     ) VALUES (?, ?, ?, ?, ?, ?, 0)\n500:     ON CONFLICT(style_rowid) DO UPDATE SET\n501:       artifact_hint_hash = excluded.artifact_hint_hash,\n502:       crawl_record_hash = excluded.crawl_record_hash,\n503:       aggregate_hash = excluded.aggregate_hash,\n504:       last_success_generation = excluded.last_success_generation,\n505:       last_success_at = excluded.last_success_at,\n506:       missing_observations = 0\n507:   `).run(\n508:     styleRowid,\n509:     style.artifactHintHash,\n510:     style.crawlRecordHash,\n511:     style.aggregateHash,\n512:     '',\n513:     timestamp,\n514:   );\n515: }\n516: \n517: function resolveRelationships(database) {\n518:   const aliases = new Map();\n519:   for (const style of database.prepare(`\n520:     SELECT style_rowid, slug, title FROM styles WHERE lifecycle_state = 'active'\n521:   `).all()) {\n522:     for (const alias of [style.slug, style.title]) {\n523:       const key = normalizeTerm(alias);\n524:       if (!aliases.has(key)) aliases.set(key, []);\n525:       aliases.get(key).push(Number(style.style_rowid));\n526:     }\n527:   }\n528:   const update = database.prepare(`\n529:     UPDATE style_relationships\n530:     SET target_style_rowid = ?, resolution_state = ?, confidence = ?\n531:     WHERE relationship_id = ?\n532:   `);\n533:   for (const relationship of database.prepare(`\n534:     SELECT relationship_id, raw_target_label FROM style_relationships\n535:   `).all()) {\n536:     const matches = [...new Set(aliases.get(normalizeTerm(relationship.raw_target_label)) ?? [])];\n537:     if (matches.length === 1) update.run(matches[0], 'resolved', 1, relationship.relationship_id);\n538:     else if (matches.length > 1) update.run(null, 'ambiguous', 0.5, relationship.relationship_id);\n539:     else update.run(null, 'unresolved', 0, relationship.relationship_id);\n540:   }\n541: }\n542: \n543: function ensureEmbeddingProfile(database, profile, timestamp) {\n544:   const existing = database.prepare(`\n545:     SELECT provider, model, dimensions, config_hash\n546:     FROM embedding_profiles WHERE profile_id = ?\n547:   `).get(profile.id);\n548:   if (existing && (\n549:     existing.provider !== profile.provider\n550:     || existing.model !== profile.model\n551:     || existing.config_hash !== profile.configHash\n552:     || (existing.dimensions != null && profile.dimensions != null\n553:       && Number(existing.dimensions) !== profile.dimensions)\n554:   )) {\n555:     const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n556:     error.code = 'embedding-profile-conflict';\n557:     throw error;\n558:   }\n559:   if (existing) return;\n560:   database.prepare(`\n561:     INSERT INTO embedding_profiles(\n562:       profile_id, provider, model, dimensions, config_hash, created_at\n563:     ) VALUES (?, ?, ?, ?, ?, ?)\n564:   `).run(\n565:     profile.id,\n566:     profile.provider,\n567:     profile.model,\n568:     profile.dimensions ?? null,\n569:     profile.configHash,\n570:     timestamp,\n571:   );\n572: }\n573: \n574: function enqueueVector(database, styleRowid, retrievalHash, profileId, timestamp) {\n575:   database.prepare(`\n576:     UPDATE style_vector_jobs\n577:     SET status = 'superseded', updated_at = ?\n578:     WHERE style_rowid = ? AND profile_id = ?\n579:       AND retrieval_hash != ? AND status IN ('pending', 'running', 'failed')\n580:   `).run(timestamp, styleRowid, profileId, retrievalHash);\n581:   database.prepare(`\n582:     UPDATE style_vector_jobs\n583:     SET status = 'pending', updated_at = ?, last_error = NULL, next_attempt_at = NULL\n584:     WHERE style_rowid = ? AND retrieval_hash = ? AND profile_id = ?\n585:       AND status = 'completed'\n586:       AND NOT EXISTS (\n587:         SELECT 1 FROM style_vectors v\n588:         WHERE v.style_rowid = style_vector_jobs.style_rowid\n589:           AND v.retrieval_hash = style_vector_jobs.retrieval_hash\n590:           AND v.profile_id = style_vector_jobs.profile_id\n591:       )\n592:   `).run(timestamp, styleRowid, retrievalHash, profileId);\n593:   database.prepare(`\n594:     INSERT INTO style_vector_jobs(\n595:       style_rowid, retrieval_hash, profile_id, status, created_at, updated_at\n596:     ) VALUES (?, ?, ?, 'pending', ?, ?)\n597:     ON CONFLICT(style_rowid, retrieval_hash, profile_id) DO UPDATE SET\n598:       status = CASE\n599:         WHEN style_vector_jobs.status = 'completed' THEN 'completed'\n600:         ELSE 'pending'\n601:       END,\n602:       updated_at = excluded.updated_at,\n603:       last_error = NULL\n604:   `).run(styleRowid, retrievalHash, profileId, timestamp, timestamp);\n605: }\n606: \n607: /**\n608:  * Incrementally project an authoritative flat-file corpus into SQLite.\n609:  *\n610:  * @param {Object} options - Indexing controls.\n611:  * @param {string} options.corpusRoot - Authoritative style corpus root.\n612:  * @param {string} [options.databasePath] - SQLite destination when no connection is supplied.\n613:  * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n614:  * @param {'migration'|'rollback'} options.corpusWalkMode - Explicit filesystem-walk grant.\n615:  * @param {boolean} [options.confirmMissing=false] - Confirm quarantined absences as tombstones.\n616:  * @param {boolean} [options.verifyAll=false] - Bypass metadata hints and hash every bundle.\n617:  * @param {Function} [options.onStage] - Lifecycle observation hook.\n618:  * @param {Function} [options.failureInjector] - Test-only crash hook inside the transaction.\n619:  * @param {Object} [options.embeddingProfile] - Profile metadata for queued vectors.\n620:  * @param {Function} [options.embedder] - Optional asynchronous embedding callback.\n621:  * @returns {Promise<Object>} Publication and incremental-change summary.\n622:  */\n623: export async function indexStyleCorpus(options) {\n624:   if (!options?.corpusRoot || !['migration', 'rollback'].includes(options.corpusWalkMode)) {\n625:     const error = new Error('Corpus walking requires explicit migration or rollback mode.');\n626:     error.code = 'corpus-walk-forbidden';\n627:     throw error;\n628:   }\n629:   const database = options.database ?? openStyleDatabase(\n630:     options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n631:   );\n632:   const ownsDatabase = !options.database;\n633:   const telemetry = options.telemetry ?? null;\n634:   const overallTimer = telemetry?.overall() ?? null;\n635:   const emit = (stage, details = {}) => {\n636:     options.onStage?.(stage, details);\n637:   };\n638:   const profile = {\n639:     id: options.embeddingProfile?.id ?? DEFAULT_EMBEDDING_PROFILE,\n640:     provider: options.embeddingProfile?.provider ?? 'external',\n641:     model: options.embeddingProfile?.model ?? 'configured',\n642:     dimensions: options.embeddingProfile?.dimensions ?? null,\n643:     configHash: options.embeddingProfile?.configHash ?? 'style-default-v1',\n644:   };\n645:   try {\n646:     emit('DISCOVER');\n647:     const discoverSpan = telemetry?.span('discover', RESIDENCY.JS_RESIDENT);\n648:     const corpusRealPath = await realpath(options.corpusRoot);\n649:     const crawlPath = path.join(options.corpusRoot, '_manifest.json');\n650:     const crawlRealPath = await realpath(crawlPath);\n651:     if (!isContained(corpusRealPath, crawlRealPath)) {\n652:       const error = new Error('Crawl manifest escapes the corpus root.');\n653:       error.code = 'path-escape';\n654:       throw error;\n655:     }\n656:     const crawlBuffer = await readFile(crawlRealPath);\n657:     const crawlManifestHash = digest([crawlBuffer]);\n658:     const crawlRecords = JSON.parse(crawlBuffer.toString('utf8'));\n659:     const crawlBySlug = new Map(crawlRecords.map((record) => [record.slug, record]));\n660:     const entries = await readdir(options.corpusRoot, { withFileTypes: true });\n661:     const slugs = entries.filter((entry) => entry.isDirectory() && !entry.name.startsWith('_'))\n662:       .map((entry) => entry.name).sort(compareRawStrings);\n663:     discoverSpan?.end(slugs.length);\n664:     const snapshotSpan = telemetry?.span('snapshot.load', RESIDENCY.NATIVE);\n665:     const currentRows = database.prepare(`\n666:       SELECT s.style_rowid, s.style_id, s.slug, s.crawl_status, s.aggregate_hash,\n667:         s.retrieval_hash, s.lifecycle_state, i.artifact_hint_hash, i.crawl_record_hash\n668:       FROM styles s\n669:       LEFT JOIN style_index_state i ON i.style_rowid = s.style_rowid\n670:     `).all();\n671:     snapshotSpan?.end(currentRows.length);\n672:     const currentBySlug = new Map(currentRows.map((row) => [row.slug, row]));\n673:     const verifySpan = telemetry?.span('verify.parse', RESIDENCY.JS_RESIDENT);\n674:     const discovered = [];\n675:     let candidateCount = 0;\n676:     for (const slug of slugs) {\n677:       const crawlRecord = crawlBySlug.get(slug);\n678:       const crawlRecordHash = computeCrawlRecordHash(crawlRecord);\n679:       const hints = await readArtifactHints(options.corpusRoot, corpusRealPath, slug);\n680:       const artifactHintHash = computeHintHash(hints);\n681:       const current = currentBySlug.get(slug);\n682:       const needsVerification = options.verifyAll === true\n683:         || !current\n684:         || current.lifecycle_state !== 'active'\n685:         || current.artifact_hint_hash !== artifactHintHash\n686:         || current.crawl_record_hash !== crawlRecordHash;\n687:       if (needsVerification) {\n688:         candidateCount += 1;\n689:         const artifacts = await readVerifiedArtifacts(options.corpusRoot, corpusRealPath, slug);\n690:         discovered.push({\n691:           slug,\n692:           crawlRecord,\n693:           artifactHintHash,\n694:           crawlRecordHash,\n695:           style: parseStyle(slug, crawlRecord, artifacts),\n696:         });\n697:       } else {\n698:         discovered.push({\n699:           slug,\n700:           crawlRecord,\n701:           artifactHintHash,\n702:           crawlRecordHash,\n703:           style: {\n704:             id: current.style_id,\n705:             slug,\n706:             crawlStatus: current.crawl_status,\n707:             aggregateHash: current.aggregate_hash,\n708:             retrievalHash: current.retrieval_hash,\n709:           },\n710:         });\n711:       }\n712:     }\n713:     verifySpan?.end(candidateCount);\n714:     emit('VERIFY', { discovered: slugs.length, candidates: candidateCount });\n715:     emit('PARSE_VALIDATE', { verified: candidateCount });\n716:     const planSpan = telemetry?.span('plan.hash', RESIDENCY.JS_RESIDENT);\n717:     const parsedStyles = discovered.map((entry) => entry.style);\n718:     if (new Set(parsedStyles.map((style) => style.id)).size !== parsedStyles.length) {\n719:       const error = new Error('The corpus contains duplicate style UUIDs.');\n720:       error.code = 'duplicate-style-id';\n721:       throw error;\n722:     }\n723:     const currentById = new Map(currentRows.map((row) => [row.style_id, row]));\n724:     const verifiedStyles = discovered.filter((entry) => entry.style.artifacts)\n725:       .map((entry) => entry.style);\n726:     const changedStyles = verifiedStyles.filter((style) => {\n727:       const current = currentById.get(style.id);\n728:       return !current\n729:         || current.slug !== style.slug\n730:         || current.crawl_status !== style.crawlStatus\n731:         || current.aggregate_hash !== style.aggregateHash\n732:         || current.crawl_record_hash !== style.crawlRecordHash\n733:         || current.lifecycle_state !== 'active';\n734:     });\n735:     const changedIds = new Set(changedStyles.map((style) => style.id));\n736:     const hintOnlyStyles = verifiedStyles.filter((style) => !changedIds.has(style.id));\n737:     const discoveredIds = new Set(parsedStyles.map((style) => style.id));\n738:     const absentRows = currentRows.filter((row) => !discoveredIds.has(row.style_id));\n739:     const missingRows = absentRows.filter((row) => row.lifecycle_state !== 'tombstoned');\n740:     const inactiveStates = absentRows.map((row) => ({\n741:       id: row.style_id,\n742:       state: row.lifecycle_state === 'active' ? 'quarantined' : 'tombstoned',\n743:     }));\n744:     const generationHash = computeGenerationHash(\n745:       crawlManifestHash,\n746:       parsedStyles,\n747:       inactiveStates,\n748:     );\n749:     const aggregateCorpusHash = digest([\n750:       'style-corpus-aggregate-v1\\0',\n751:       ...parsedStyles.slice().sort((left, right) => compareRawStrings(left.id, right.id))\n752:         .map((style) => `${style.id}\\0${style.aggregateHash}\\n`),\n753:     ]);\n754:     const timestamp = nowIso();\n755:     planSpan?.end(parsedStyles.length);\n756:     const planLoadSpan = telemetry?.span('plan.load', RESIDENCY.NATIVE);\n757:     const currentGeneration = database.prepare(`\n758:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n759:     `).get()?.generation_hash ?? null;\n760:     const profileRow = database.prepare(`\n761:       SELECT provider, model, dimensions, config_hash\n762:       FROM embedding_profiles WHERE profile_id = ?\n763:     `).get(profile.id);\n764:     if (profileRow && (\n765:       profileRow.provider !== profile.provider\n766:       || profileRow.model !== profile.model\n767:       || profileRow.config_hash !== profile.configHash\n768:       || (profileRow.dimensions != null && profile.dimensions != null\n769:         && Number(profileRow.dimensions) !== profile.dimensions)\n770:     )) {\n771:       const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n772:       error.code = 'embedding-profile-conflict';\n773:       throw error;\n774:     }\n775:     const missingProfileJobs = profileRow ? Number(database.prepare(`\n776:       SELECT COUNT(*) AS count FROM styles s\n777:       WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n778:         SELECT 1 FROM style_vector_jobs j\n779:         WHERE j.style_rowid = s.style_rowid\n780:           AND j.retrieval_hash = s.retrieval_hash\n781:           AND j.profile_id = ?\n782:           AND j.status != 'superseded'\n783:           AND (j.status != 'completed' OR EXISTS (\n784:             SELECT 1 FROM style_vectors v\n785:             WHERE v.style_rowid = j.style_rowid\n786:               AND v.retrieval_hash = j.retrieval_hash\n787:               AND v.profile_id = j.profile_id\n788:           ))\n789:       )\n790:     `).get(profile.id).count) : parsedStyles.length;\n791:     planLoadSpan?.end(1);\n792:     const needsVectorQueue = !profileRow || missingProfileJobs > 0 || changedStyles.length > 0;\n793:     const shouldPublish = changedStyles.length > 0\n794:       || missingRows.length > 0\n795:       || currentGeneration !== generationHash;\n796:     if (!shouldPublish && hintOnlyStyles.length === 0 && !needsVectorQueue) {\n797:       return {\n798:         ok: true,\n799:         generationHash,\n800:         published: false,\n801:         indexed: 0,\n802:         unchanged: parsedStyles.length,\n803:         quarantined: 0,\n804:         tombstoned: 0,\n805:       };\n806:     }\n807: \n808:     database.exec('BEGIN IMMEDIATE');\n809:     try {\n810:       emit('COMMIT', {\n811:         changed: changedStyles.length,\n812:         hintOnly: hintOnlyStyles.length,\n813:         missing: missingRows.length,\n814:       });\n815:       const commitSpan = telemetry?.span('commit.write', RESIDENCY.NATIVE);\n816:       ensureEmbeddingProfile(database, profile, timestamp);\n817:       const upsertStyle = database.prepare(`\n818:         INSERT INTO styles(\n819:           style_id, slug, lifecycle_state, crawl_status, title, thesis, theme,\n820:           industry, aggregate_hash, retrieval_hash, quarantine_at, tombstoned_at,\n821:           created_at, updated_at\n822:         ) VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?, ?, NULL, NULL, ?, ?)\n823:         ON CONFLICT(style_id) DO UPDATE SET\n824:           slug = excluded.slug,\n825:           lifecycle_state = 'active',\n826:           crawl_status = excluded.crawl_status,\n827:           title = excluded.title,\n828:           thesis = excluded.thesis,\n829:           theme = excluded.theme,\n830:           industry = excluded.industry,\n831:           aggregate_hash = excluded.aggregate_hash,\n832:           retrieval_hash = excluded.retrieval_hash,\n833:           quarantine_at = NULL,\n834:           tombstoned_at = NULL,\n835:           updated_at = excluded.updated_at\n836:       `);\n837:       for (const [index, style] of changedStyles.entries()) {\n838:         upsertStyle.run(\n839:           style.id,\n840:           style.slug,\n841:           style.crawlStatus,\n842:           style.title,\n843:           style.thesis,\n844:           style.theme,\n845:           style.industry,\n846:           style.aggregateHash,\n847:           style.retrievalHash,\n848:           timestamp,\n849:           timestamp,\n850:         );\n851:         const styleRowid = Number(database.prepare(\n852:           'SELECT style_rowid FROM styles WHERE style_id = ?',\n853:         ).get(style.id).style_rowid);\n854:         replaceStyleChildren(database, styleRowid, style, timestamp);\n855:         options.failureInjector?.({ phase: 'COMMIT', style, index, database });\n856:       }\n857:       const updateHints = database.prepare(`\n858:         UPDATE style_index_state\n859:         SET artifact_hint_hash = ?, crawl_record_hash = ?, last_success_at = ?\n860:         WHERE style_rowid = ?\n861:       `);\n862:       for (const style of hintOnlyStyles) {\n863:         const current = currentById.get(style.id);\n864:         updateHints.run(\n865:           style.artifactHintHash,\n866:           style.crawlRecordHash,\n867:           timestamp,\n868:           current.style_rowid,\n869:         );\n870:       }\n871: \n872:       let queued = 0;\n873:       const queueRows = database.prepare(`\n874:         SELECT s.style_rowid, s.retrieval_hash FROM styles s\n875:         WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n876:           SELECT 1 FROM style_vector_jobs j\n877:           WHERE j.style_rowid = s.style_rowid\n878:             AND j.retrieval_hash = s.retrieval_hash\n879:             AND j.profile_id = ?\n880:             AND j.status != 'superseded'\n881:             AND (j.status != 'completed' OR EXISTS (\n882:               SELECT 1 FROM style_vectors v\n883:               WHERE v.style_rowid = j.style_rowid\n884:                 AND v.retrieval_hash = j.retrieval_hash\n885:                 AND v.profile_id = j.profile_id\n886:             ))\n887:         )\n888:       `).all(profile.id);\n889:       for (const row of queueRows) {\n890:         enqueueVector(database, row.style_rowid, row.retrieval_hash, profile.id, timestamp);\n891:         queued += 1;\n892:       }\n893:       commitSpan?.end(changedStyles.length + queued);\n894: \n895:       emit('VECTOR_DRAIN', { queued });\n896:       if (!shouldPublish) {\n897:         const finalizeSpan = telemetry?.span('commit.finalize', RESIDENCY.NATIVE);\n898:         database.exec('COMMIT');\n899:         finalizeSpan?.end(1);\n900:         if (options.embedder) {\n901:           const { drainVectorQueue } = await import('./vectors.mjs');\n902:           const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n903:           await drainVectorQueue(database, {\n904:             profileId: profile.id,\n905:             embedder: options.embedder,\n906:             limit: options.vectorDrainLimit,\n907:           });\n908:           drainSpan?.end(queued);\n909:         }\n910:         return {\n911:           ok: true,\n912:           generationHash,\n913:           published: false,\n914:           indexed: 0,\n915:           unchanged: parsedStyles.length,\n916:           quarantined: 0,\n917:           tombstoned: 0,\n918:           queued,\n919:         };\n920:       }\n921: \n922:       const missingSpan = telemetry?.span('publish.missing', RESIDENCY.NATIVE);\n923:       let quarantined = 0;\n924:       let tombstoned = 0;\n925:       for (const row of missingRows) {\n926:         const state = database.prepare(`\n927:           SELECT missing_observations FROM style_index_state WHERE style_rowid = ?\n928:         `).get(row.style_rowid);\n929:         const shouldTombstone = row.lifecycle_state === 'quarantined'\n930:           && (options.confirmMissing === true || Number(state?.missing_observations ?? 0) >= 1);\n931:         if (shouldTombstone) {\n932:           database.prepare(`\n933:             UPDATE styles SET lifecycle_state = 'tombstoned',\n934:               quarantine_at = COALESCE(quarantine_at, ?), tombstoned_at = ?, updated_at = ?\n935:             WHERE style_rowid = ?\n936:           `).run(timestamp, timestamp, timestamp, row.style_rowid);\n937:           tombstoned += 1;\n938:         } else if (row.lifecycle_state !== 'tombstoned') {\n939:           database.prepare(`\n940:             UPDATE styles SET lifecycle_state = 'quarantined', quarantine_at = ?,\n941:               tombstoned_at = NULL, updated_at = ? WHERE style_rowid = ?\n942:           `).run(timestamp, timestamp, row.style_rowid);\n943:           quarantined += 1;\n944:         }\n945:         database.prepare(`\n946:           UPDATE style_index_state\n947:           SET missing_observations = missing_observations + 1, last_success_at = ?\n948:           WHERE style_rowid = ?\n949:         `).run(timestamp, row.style_rowid);\n950:       }\n951:       missingSpan?.end(missingRows.length);\n952:       resolveRelationships(database);\n953: \n954:       const publishSpan = telemetry?.span('publish.write', RESIDENCY.NATIVE);\n955:       const counts = Object.fromEntries(database.prepare(`\n956:         SELECT lifecycle_state, COUNT(*) AS count FROM styles GROUP BY lifecycle_state\n957:       `).all().map((row) => [row.lifecycle_state, Number(row.count)]));\n958:       emit('PUBLISH', { generationHash });\n959:       database.prepare(`\n960:         INSERT OR IGNORE INTO corpus_generations(\n961:           generation_hash, parent_generation_hash, crawl_manifest_hash,\n962:           aggregate_corpus_hash, schema_version, active_style_count,\n963:           quarantined_style_count, tombstoned_style_count, created_at\n964:         ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n965:       `).run(\n966:         generationHash,\n967:         currentGeneration,\n968:         crawlManifestHash,\n969:         aggregateCorpusHash,\n970:         STYLE_DB_SCHEMA_VERSION,\n971:         counts.active ?? 0,\n972:         counts.quarantined ?? 0,\n973:         counts.tombstoned ?? 0,\n974:         timestamp,\n975:       );\n976:       database.prepare(`\n977:         INSERT INTO current_corpus_generation(singleton, generation_hash, published_at)\n978:         VALUES (1, ?, ?)\n979:         ON CONFLICT(singleton) DO UPDATE SET\n980:           generation_hash = excluded.generation_hash,\n981:           published_at = excluded.published_at\n982:       `).run(generationHash, timestamp);\n983:       database.prepare(`\n984:         UPDATE style_index_state SET last_success_generation = ?\n985:         WHERE style_rowid IN (SELECT style_rowid FROM styles WHERE lifecycle_state = 'active')\n986:       `).run(generationHash);\n987:       options.failureInjector?.({ phase: 'PUBLISH', database });\n988:       database.exec('COMMIT');\n989:       publishSpan?.end(changedStyles.length);\n990: \n991:       if (options.embedder) {\n992:         const { drainVectorQueue } = await import('./vectors.mjs');\n993:         const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n994:         await drainVectorQueue(database, {\n995:           profileId: profile.id,\n996:           embedder: options.embedder,\n997:           limit: options.vectorDrainLimit,\n998:         });\n999:         drainSpan?.end(changedStyles.length);\n1000:       }\n1001:       return {\n1002:         ok: true,\n1003:         generationHash,\n1004:         published: true,\n1005:         indexed: changedStyles.length,\n1006:         unchanged: parsedStyles.length - changedStyles.length,\n1007:         quarantined,\n1008:         tombstoned,\n1009:       };\n1010:     } catch (error) {\n1011:       database.exec('ROLLBACK');\n1012:       throw error;\n1013:     }\n1014:   } finally {\n1015:     overallTimer?.end();\n1016:     if (ownsDatabase) database.close();\n1017:   }\n1018: }\n1019: \n1020: /**\n1021:  * Build a complete database projection without making it a query side effect.\n1022:  *\n1023:  * @param {Object} options - The same controls as indexStyleCorpus.\n1024:  * @returns {Promise<Object>} Publication summary.\n1025:  */\n1026: async function writeGenerationPointer(\n1027:   databasePath,\n1028:   generationHash,\n1029:   databaseFile,\n1030:   afterRename,\n1031:   options = {},\n1032: ) {\n1033:   if (path.basename(databaseFile) !== databaseFile) {\n1034:     throw new TypeError('Generation database file must be a basename.');\n1035:   }\n1036:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n1037:   const artifactPath = path.join(path.dirname(databasePath), databaseFile);\n1038:   const { sha256, bytes } = await hashArtifactFile(artifactPath);\n1039:   const manifest = buildManifest({\n1040:     generationHash,\n1041:     createdAt: nowIso(),\n1042:     parentGenerationHash: options.parentGenerationHash ?? null,\n1043:     artifacts: { sqlite: { role: 'sqlite', file: databaseFile, sha256, bytes } },\n1044:   });\n1045:   await writeManifestPointer(pointerPath, manifest, { afterRename });\n1046: }\n1047: \n1048: export async function buildStyleDatabase(options) {\n1049:   if (options?.database) {\n1050:     const error = new Error('Full rebuild publication requires a databasePath, not an open connection.');\n1051:     error.code = 'staging-requires-database-path';\n1052:     throw error;\n1053:   }\n1054:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n1055:   const buildingPath = `${databasePath}.building-${process.pid}-${Date.now()}`;\n1056:   let generationPath = null;\n1057:   const removeSidecars = async (basePath) => {\n1058:     await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n1059:       rm(`${basePath}${suffix}`, { force: true })\n1060:     )));\n1061:   };\n1062:   await removeSidecars(buildingPath);\n1063:   try {\n1064:     const result = await indexStyleCorpus({\n1065:       ...options,\n1066:       databasePath: buildingPath,\n1067:       corpusWalkMode: options.corpusWalkMode ?? 'migration',\n1068:       verifyAll: true,\n1069:     });\n1070:     const staged = openStyleDatabase(buildingPath);\n1071:     try {\n1072:       const integrity = staged.prepare('PRAGMA integrity_check').get().integrity_check;\n1073:       const foreignKeyFailures = staged.prepare('PRAGMA foreign_key_check').all();\n1074:       const current = staged.prepare(`\n1075:         SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n1076:       `).get()?.generation_hash;\n1077:       if (integrity !== 'ok' || foreignKeyFailures.length > 0\n1078:         || current !== result.generationHash) {\n1079:         const error = new Error('Staged style database failed publication validation.');\n1080:         error.code = 'staging-validation-failed';\n1081:         throw error;\n1082:       }\n1083:       staged.prepare(`\n1084:         INSERT INTO style_fts(style_fts) VALUES ('integrity-check')\n1085:       `).run();\n1086:       staged.exec('PRAGMA wal_checkpoint(TRUNCATE)');\n1087:     } finally {\n1088:       staged.close();\n1089:     }\n1090:     const generationName = result.generationHash.replace(':', '-');\n1091:     const databaseFile = `${path.basename(databasePath)}.${generationName}`\n1092:       + `.${process.pid}-${Date.now()}.sqlite`;\n1093:     generationPath = path.join(path.dirname(databasePath), databaseFile);\n1094:     await removeSidecars(generationPath);\n1095:     await rename(buildingPath, generationPath);\n1096:     const immutableGenerationPath = generationPath;\n1097:     generationPath = null;\n1098:     const generationHandle = await open(immutableGenerationPath, 'r');\n1099:     try {\n1100:       await generationHandle.sync();\n1101:     } finally {\n1102:       await generationHandle.close();\n1103:     }\n1104:     const generationDirectory = await open(path.dirname(immutableGenerationPath), 'r');\n1105:     try {\n1106:       await generationDirectory.sync();\n1107:     } finally {\n1108:       await generationDirectory.close();\n1109:     }\n1110:     await writeGenerationPointer(\n1111:       databasePath,\n1112:       result.generationHash,\n1113:       databaseFile,\n1114:       options.failureInjector\n1115:         ? (details) => options.failureInjector({ phase: 'POINTER_RENAMED', ...details })\n1116:         : undefined,\n1117:     );\n1118:     return {\n1119:       ...result,\n1120:       databasePath,\n1121:       generationDatabasePath: path.join(path.dirname(databasePath), databaseFile),\n1122:     };\n1123:   } finally {\n1124:     await removeSidecars(buildingPath);\n1125:     if (generationPath) await removeSidecars(generationPath);\n1126:   }\n1127: }\n1128: \n1129: /**\n1130:  * Roll back by atomically repointing new readers to a retained generation file.\n1131:  *\n1132:  * @param {Object} options - Logical path and retained generation identity.\n1133:  * @param {string} options.databasePath - Logical database path.\n1134:  * @param {string} options.generationDatabasePath - Retained immutable database file.\n1135:  * @returns {Promise<Object>} Restored generation pointer details.\n1136:  */\n1137: export async function rollbackStyleDatabase(options) {\n1138:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n1139:   const generationDatabasePath = options?.generationDatabasePath;\n1140:   if (!generationDatabasePath\n1141:     || path.dirname(path.resolve(generationDatabasePath)) !== path.dirname(path.resolve(databasePath))) {\n1142:     const error = new Error('Rollback generation must be retained beside the logical database path.');\n1143:     error.code = 'rollback-generation-invalid';\n1144:     throw error;\n1145:   }\n1146:   try {\n1147:     const retainedInfo = await stat(generationDatabasePath);\n1148:     if (!retainedInfo.isFile()) throw new Error('not a file');\n1149:     const databaseDirectoryRealPath = await realpath(path.dirname(databasePath));\n1150:     const retainedRealPath = await realpath(generationDatabasePath);\n1151:     if (!isContained(databaseDirectoryRealPath, retainedRealPath)) {\n1152:       throw new Error('generation escapes database directory');\n1153:     }\n1154:   } catch (cause) {\n1155:     const error = new Error('Rollback generation is unavailable.', { cause });\n1156:     error.code = 'rollback-generation-invalid';\n1157:     throw error;\n1158:   }\n1159:   const retained = openStyleDatabase(generationDatabasePath);\n1160:   let generationHash;\n1161:   try {\n1162:     const integrity = retained.prepare('PRAGMA integrity_check').get().integrity_check;\n1163:     generationHash = retained.prepare(`\n1164:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n1165:     `).get()?.generation_hash;\n1166:     if (integrity !== 'ok' || !generationHash) {\n1167:       const error = new Error('Rollback generation failed validation.');\n1168:       error.code = 'rollback-generation-invalid';\n1169:       throw error;\n1170:     }\n1171:   } finally {\n1172:     retained.close();\n1173:   }\n1174:   await writeGenerationPointer(\n1175:     databasePath,\n1176:     generationHash,\n1177:     path.basename(generationDatabasePath),\n1178:   );\n1179:   return { databasePath, generationDatabasePath, generationHash };\n1180: }\n1181: \n1182: export const indexerInternals = Object.freeze({\n1183:   computeAggregateHash,\n1184:   computeGenerationHash,\n1185:   normalizeMarkdown,\n1186:   parseStyle,\n1187: });\n\n(End of file - total 1187 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Incremental Style Database Indexer                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport {\n  lstat,\n  open,\n  readFile,\n  readdir,\n  realpath,\n  rename,\n  rm,\n  stat,\n} from 'node:fs/promises';\nimport path from 'node:path';\n\nimport {\n  compareRawStrings,\n  digest,\n  lengthFrame,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Incremental Style Database Indexer                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport {\n  lstat,\n  open,\n  readFile,\n  readdir,\n  realpath,\n  rename,\n  rm,\n  stat,\n} from 'node:fs/promises';\nimport path from 'node:path';\n\nimport {\n  compareRawStrings,\n  digest,\n  lengthFrame,\n  stableJson,\n} from './canonical.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  writeManifestPointer,\n} from './generation-manifest.mjs';\nimport {\n  RESIDENCY,\n} from './stage-telemetry.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  STYLE_DB_SCHEMA_VERSION,\n  STYLE_DATABASE_POINTER_SUFFIX,\n  openStyleDatabase,\n} from './schema.mjs';\n\nexport const INDEXER_LIFECYCLE = Object.freeze([\n  'DISCOVER',\n  'VERIFY',\n  'PARSE_VALIDATE',\n  'COMMIT',\n  'VECTOR_DRAIN',\n  'PUBLISH',\n]);\nexport const DEFAULT_EMBEDDING_PROFILE = 'style-default-v1';\n\nconst AGGREGATE_HASH_VERSION = 'style-all-artifacts-v2';\nconst RETRIEVAL_HASH_VERSION = 'style-retrieval-document-v1';\nconst GENERATION_HASH_VERSION = 'style-corpus-generation-v2';\nconst LICENSE_ALLOWLIST = new Set(['allowed', 'licensed', 'public-domain']);\nconst RESTRICTED_LICENSE_PATTERN = /\\b(unlicensed trial|license[- ]restricted)\\b/i;\nconst WARM_SURFACE_PATTERN = /\\b(warm|cream|beige|bone|ivory|linen|sand|tan)\\b/i;\nconst MOTION_PATTERN = /\\b(motion|animation|animated|transition|kinetic|scroll)\\b/i;\nconst SERIF_PATTERN = /(^|[^a-z])serif([^a-z]|$)/i;\nconst SANS_SERIF_PATTERN = /sans[- ]serif/i;\n\nfunction nowIso() {\n  return new Date().toISOString();\n}\n\nfunction normalizeTerm(value) {\n  return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n}\n\nfunction normalizeMarkdown(value) {\n  return String(value ?? '').normalize('NFC').replace(/\\r\\n?/g, '\\n')\n    .split('\\n').map((line) => line.trimEnd()).join('\\n').trimEnd();\n}\n\nfunction artifactRole(fileName) {\n  if (fileName.endsWith('-canonical.json')) return 'canonical';\n  if (fileName === 'design-tokens.json') return 'tokens';\n  if (fileName === 'DESIGN.md') return 'design';\n  if (fileName === 'source.md') return 'source';\n  if (fileName === 'css-variables.css') return 'css-variables';\n  if (fileName === 'tailwind-v4.css') return 'tailwind';\n  return null;\n}\n\nfunction isContained(rootPath, candidatePath) {\n  const relative = path.relative(rootPath, candidatePath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction parseJson(artifact, label) {\n  if (!artifact) return {};\n  try {\n    return JSON.parse(artifact.buffer.toString('utf8'));\n  } catch (error) {\n    const invalid = new Error(`Invalid ${label} JSON: ${artifact.relativePath}`, { cause: error });\n    invalid.code = 'invalid-artifact';\n    throw invalid;\n  }\n}\n\nfunction countTokenLeaves(value) {\n  if (!value || typeof value !== 'object') return 0;\n  if (Object.hasOwn(value, '$value')) return 1;\n  return Object.values(value).reduce((sum, child) => sum + countTokenLeaves(child), 0);\n}\n\nfunction deriveTokenAxes(tokens, designSystem) {\n  const counts = new Map();\n  for (const [axis, value] of Object.entries(tokens ?? {})) {\n    const count = countTokenLeaves(value);\n    if (count > 0) counts.set(axis, count);\n  }\n  const fallbackCounts = {\n    color: Array.isArray(designSystem.colors) ? designSystem.colors.length : 0,\n    spacing: designSystem.spacing ? Object.keys(designSystem.spacing).length : 0,\n    typography: Array.isArray(designSystem.typography) ? designSystem.typography.length : 0,\n  };\n  for (const [axis, count] of Object.entries(fallbackCounts)) {\n    if (count > 0 && !counts.has(axis)) counts.set(axis, count);\n  }\n  return [...counts].map(([axis, count]) => ({ axis, count }))\n    .sort((left, right) => compareRawStrings(left.axis, right.axis));\n}\n\nfunction deriveSections(designMarkdown) {\n  const sections = [];\n  for (const [index, line] of designMarkdown.split('\\n').entries()) {\n    const match = /^##\\s+(.+?)\\s*$/.exec(line);\n    if (match) sections.push({ name: match[1], line: index + 1 });\n  }\n  return sections;\n}\n\nfunction deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus) {\n  const values = new Set();\n  if (tokenAxes.length > 0) values.add('tokens');\n  if ((designSystem.components?.length ?? 0) > 0) values.add('components');\n  if (designSystem.layout) values.add('layout');\n  if (designSystem.imagery) values.add('imagery');\n  if (designSystem.spacing) values.add('spacing');\n  if ((designSystem.dos?.length ?? 0) + (designSystem.donts?.length ?? 0) > 0) {\n    values.add('constraints');\n  }\n  if (provenanceStatus === 'known') values.add('provenance');\n  if (sections.some((section) => MOTION_PATTERN.test(section.name))) values.add('motion');\n  return [...values].sort(compareRawStrings);\n}\n\nfunction deriveFacets(style, designSystem, capabilities, tokenAxes, searchableText, licenseStatus) {\n  const values = new Set(capabilities);\n  for (const { axis } of tokenAxes) values.add(axis);\n  if (designSystem.theme) values.add(normalizeTerm(designSystem.theme));\n  if (designSystem.industry) values.add(normalizeTerm(designSystem.industry));\n  if (SERIF_PATTERN.test(searchableText) && !SANS_SERIF_PATTERN.test(searchableText)) {\n    values.add('serif-role');\n  }\n  if (WARM_SURFACE_PATTERN.test(searchableText)) values.add('warm-surface');\n  if (MOTION_PATTERN.test(searchableText)) values.add('motion');\n  if (licenseStatus === 'restricted') values.add('license-restricted');\n  values.add(normalizeTerm(style.slug));\n  return [...values].filter(Boolean).sort(compareRawStrings);\n}\n\nfunction excerpt(value, maxLength = 240) {\n  const normalized = String(value ?? '').replace(/\\s+/g, ' ').trim();\n  if (normalized.length <= maxLength) return normalized;\n  return `${normalized.slice(0, maxLength - 1).trimEnd()}…`;\n}\n\nfunction computeAggregateHash(styleId, artifacts) {\n  const parts = [\n    ...lengthFrame(AGGREGATE_HASH_VERSION),\n    ...lengthFrame(styleId),\n  ];\n  for (const artifact of artifacts.slice()\n    .sort((left, right) => compareRawStrings(left.role, right.role))) {\n    parts.push(...lengthFrame(artifact.role), ...lengthFrame(artifact.buffer));\n  }\n  return digest(parts);\n}\n\nfunction computeHintHash(artifacts) {\n  return digest([\n    'style-artifact-hints-v1\\0',\n    ...artifacts.map((artifact) => (\n      `${artifact.relativePath}\\0${artifact.byteLength}\\0${artifact.mtimeNs}\\0${artifact.ctimeNs}\\n`\n    )),\n  ]);\n}\n\nfunction computeCrawlRecordHash(crawlRecord) {\n  return digest([\n    'style-crawl-record-v1\\0',\n    stableJson(crawlRecord ?? null),\n  ]);\n}\n\nfunction computeGenerationHash(crawlManifestHash, styles, inactiveStates = []) {\n  const parts = [\n    ...lengthFrame(GENERATION_HASH_VERSION),\n    ...lengthFrame(STYLE_DB_SCHEMA_VERSION),\n    ...lengthFrame(crawlManifestHash),\n  ];\n  for (const style of styles.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n    parts.push(...lengthFrame(style.id), ...lengthFrame(style.aggregateHash));\n  }\n  for (const style of inactiveStates.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n    parts.push(...lengthFrame(style.id), ...lengthFrame(style.state));\n  }\n  return digest(parts);\n}\n\nasync function readVerifiedArtifacts(corpusRoot, corpusRealPath, slug) {\n  const styleRoot = path.join(corpusRoot, slug);\n  const entries = (await readdir(styleRoot, { withFileTypes: true }))\n    .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const artifacts = [];\n  for (const entry of entries) {\n    const role = artifactRole(entry.name);\n    if (!role) {\n      const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n      error.code = 'invalid-artifact';\n      throw error;\n    }\n    const candidatePath = path.join(styleRoot, entry.name);\n    const linkInfo = await lstat(candidatePath, { bigint: true });\n    if (!linkInfo.isFile() && !linkInfo.isSymbolicLink()) continue;\n    const artifactRealPath = await realpath(candidatePath);\n    if (!isContained(corpusRealPath, artifactRealPath)) {\n      const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n      error.code = 'path-escape';\n      throw error;\n    }\n    const before = await stat(artifactRealPath, { bigint: true });\n    const buffer = await readFile(artifactRealPath);\n    const after = await stat(artifactRealPath, { bigint: true });\n    if (before.size !== after.size || before.mtimeNs !== after.mtimeNs || before.ctimeNs !== after.ctimeNs) {\n      const error = new Error(`Corpus changed while reading ${slug}/${entry.name}.`);\n      error.code = 'corpus-changing';\n      throw error;\n    }\n    artifacts.push({\n      role,\n      relativePath: `${slug}/${entry.name}`,\n      byteLength: buffer.byteLength,\n      sha256: digest([buffer]),\n      mtimeNs: String(after.mtimeNs),\n      ctimeNs: String(after.ctimeNs),\n      buffer,\n    });\n  }\n  if (!artifacts.some((artifact) => artifact.role === 'canonical')\n    || !artifacts.some((artifact) => artifact.role === 'design')) {\n    const error = new Error(`Style ${slug} lacks its canonical JSON or DESIGN.md artifact.`);\n    error.code = 'invalid-artifact';\n    throw error;\n  }\n  return artifacts;\n}\n\nasync function readArtifactHints(corpusRoot, corpusRealPath, slug) {\n  const styleRoot = path.join(corpusRoot, slug);\n  const entries = (await readdir(styleRoot, { withFileTypes: true }))\n    .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const artifacts = [];\n  for (const entry of entries) {\n    const role = artifactRole(entry.name);\n    if (!role) {\n      const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n      error.code = 'invalid-artifact';\n      throw error;\n    }\n    const candidatePath = path.join(styleRoot, entry.name);\n    const artifactRealPath = await realpath(candidatePath);\n    if (!isContained(corpusRealPath, artifactRealPath)) {\n      const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n      error.code = 'path-escape';\n      throw error;\n    }\n    const fileInfo = await stat(artifactRealPath, { bigint: true });\n    artifacts.push({\n      role,\n      relativePath: `${slug}/${entry.name}`,\n      byteLength: Number(fileInfo.size),\n      mtimeNs: String(fileInfo.mtimeNs),\n      ctimeNs: String(fileInfo.ctimeNs),\n    });\n  }\n  return artifacts;\n}\n\nfunction parseStyle(slug, crawlRecord, artifacts) {\n  const canonical = parseJson(artifacts.find((artifact) => artifact.role === 'canonical'), 'canonical');\n  const tokens = parseJson(artifacts.find((artifact) => artifact.role === 'tokens'), 'token');\n  const designMarkdown = normalizeMarkdown(\n    artifacts.find((artifact) => artifact.role === 'design')?.buffer.toString('utf8'),\n  );\n  const designSystem = canonical.designSystem ?? {};\n  const id = canonical.uuid ?? crawlRecord?.uuid;\n  if (typeof id !== 'string' || id.length === 0) {\n    const error = new Error(`Style ${slug} has no stable UUID.`);\n    error.code = 'invalid-artifact';\n    throw error;\n  }\n  const title = excerpt(canonical.name ?? slug, 120);\n  const thesis = excerpt(canonical.northStar ?? designSystem.northStar ?? designSystem.description);\n  const theme = designSystem.theme == null ? null : String(designSystem.theme);\n  const industry = designSystem.industry == null ? null : String(designSystem.industry);\n  const sections = deriveSections(designMarkdown);\n  const tokenAxes = deriveTokenAxes(tokens, designSystem);\n  const provenanceStatus = canonical.source && canonical.uuid && canonical.meta?.url\n    ? 'known'\n    : 'missing';\n  const searchableText = [\n    title,\n    thesis,\n    designSystem.description,\n    theme,\n    industry,\n    designSystem.layout,\n    designSystem.imagery,\n    ...(Array.isArray(designSystem.typography)\n      ? designSystem.typography.map((entry) => `${entry.family ?? ''} ${entry.role ?? ''}`)\n      : []),\n    designMarkdown.slice(0, 65_536),\n  ].join(' ');\n  const licenseStatus = RESTRICTED_LICENSE_PATTERN.test(searchableText)\n    ? 'restricted'\n    : String(canonical.license?.status ?? 'unknown');\n  const rightsKnown = LICENSE_ALLOWLIST.has(licenseStatus) || licenseStatus === 'restricted';\n  const capabilities = deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus);\n  const facets = deriveFacets(\n    { slug },\n    designSystem,\n    capabilities,\n    tokenAxes,\n    searchableText,\n    licenseStatus,\n  );\n  const retrievalDocument = {\n    id,\n    title,\n    thesis,\n    theme,\n    industry,\n    capabilities,\n    facets,\n    tokenAxes,\n    sections: sections.map((section) => section.name),\n    designMarkdown,\n  };\n  const retrievalJson = stableJson(retrievalDocument);\n  const retrievalHash = digest([\n    ...lengthFrame(RETRIEVAL_HASH_VERSION),\n    ...lengthFrame(retrievalJson),\n  ]);\n  const aggregateHash = computeAggregateHash(id, artifacts);\n  return {\n    id,\n    slug,\n    crawlStatus: crawlRecord?.status ?? 'unknown',\n    title,\n    thesis,\n    theme,\n    industry,\n    aggregateHash,\n    artifactHintHash: computeHintHash(artifacts),\n    crawlRecordHash: computeCrawlRecordHash(crawlRecord),\n    retrievalHash,\n    artifacts,\n    tokenAxes,\n    sections,\n    capabilities,\n    facets,\n    provenance: {\n      status: provenanceStatus,\n      sourceUrl: canonical.source ?? crawlRecord?.url ?? null,\n      originalUrl: canonical.meta?.url ?? null,\n      screenshotUrl: canonical.screenshot?.url ?? null,\n      uuid: canonical.uuid ?? crawlRecord?.uuid ?? null,\n      capturedAt: canonical.capturedAt ?? crawlRecord?.capturedAt ?? null,\n      licenseStatus,\n      rightsKnown,\n      evidenceScope: ['reference', 'rationale'],\n    },\n    relationships: (Array.isArray(designSystem.similar) ? designSystem.similar : [])\n      .map((relationship, ordinal) => ({\n        ordinal,\n        rawTargetLabel: String(relationship.business ?? relationship.name ?? '').trim(),\n        rationale: String(relationship.why ?? relationship.rationale ?? '').trim(),\n      })).filter((relationship) => relationship.rawTargetLabel),\n    retrievalDocument: {\n      title,\n      thesis,\n      theme: theme ?? '',\n      industry: industry ?? '',\n      terms: [...new Set([...facets, ...capabilities, ...tokenAxes.map(({ axis }) => axis)])]\n        .sort(compareRawStrings).join(' '),\n      body: designMarkdown,\n      documentJson: retrievalJson,\n      retrievalHash,\n    },\n  };\n}\n\nfunction replaceStyleChildren(database, styleRowid, style, timestamp) {\n  for (const table of [\n    'style_provenance',\n    'style_artifacts',\n    'style_terms',\n    'style_token_axes',\n    'style_sections',\n    'retrieval_documents',\n    'style_relationships',\n  ]) {\n    const key = table === 'style_relationships' ? 'source_style_rowid' : 'style_rowid';\n    database.prepare(`DELETE FROM ${table} WHERE ${key} = ?`).run(styleRowid);\n  }\n  database.prepare(`\n    INSERT INTO style_provenance(\n      style_rowid, status, source_url, original_url, screenshot_url, source_uuid,\n      captured_at, license_status, rights_known, evidence_scope_json\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    styleRowid,\n    style.provenance.status,\n    style.provenance.sourceUrl,\n    style.provenance.originalUrl,\n    style.provenance.screenshotUrl,\n    style.provenance.uuid,\n    style.provenance.capturedAt,\n    style.provenance.licenseStatus,\n    style.provenance.rightsKnown ? 1 : 0,\n    JSON.stringify(style.provenance.evidenceScope),\n  );\n  const insertArtifact = database.prepare(`\n    INSERT INTO style_artifacts(\n      style_rowid, role, relative_path, byte_length, sha256, mtime_ns, ctime_ns\n    ) VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n  for (const artifact of style.artifacts) {\n    insertArtifact.run(\n      styleRowid,\n      artifact.role,\n      artifact.relativePath,\n      artifact.byteLength,\n      artifact.sha256,\n      artifact.mtimeNs,\n      artifact.ctimeNs,\n    );\n  }\n  const insertTerm = database.prepare(\n    'INSERT INTO style_terms(style_rowid, term_type, term) VALUES (?, ?, ?)',\n  );\n  for (const term of style.facets) insertTerm.run(styleRowid, 'facet', term);\n  for (const term of style.capabilities) insertTerm.run(styleRowid, 'capability', term);\n  const insertAxis = database.prepare(\n    'INSERT INTO style_token_axes(style_rowid, axis, token_count) VALUES (?, ?, ?)',\n  );\n  for (const axis of style.tokenAxes) insertAxis.run(styleRowid, axis.axis, axis.count);\n  const insertSection = database.prepare(`\n    INSERT INTO style_sections(style_rowid, ordinal, name, line_number) VALUES (?, ?, ?, ?)\n  `);\n  for (const [ordinal, section] of style.sections.entries()) {\n    insertSection.run(styleRowid, ordinal, section.name, section.line);\n  }\n  const document = style.retrievalDocument;\n  database.prepare(`\n    INSERT INTO retrieval_documents(\n      style_rowid, title, thesis, theme, industry, terms, body, document_json, retrieval_hash\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    styleRowid,\n    document.title,\n    document.thesis,\n    document.theme,\n    document.industry,\n    document.terms,\n    document.body,\n    document.documentJson,\n    document.retrievalHash,\n  );\n  const insertRelationship = database.prepare(`\n    INSERT INTO style_relationships(\n      source_style_rowid, ordinal, raw_target_label, target_style_rowid,\n      rationale, resolution_state, confidence\n    ) VALUES (?, ?, ?, NULL, ?, 'unresolved', 0)\n  `);\n  for (const relationship of style.relationships) {\n    insertRelationship.run(\n      styleRowid,\n      relationship.ordinal,\n      relationship.rawTargetLabel,\n      relationship.rationale,\n    );\n  }\n  database.prepare(`\n    INSERT INTO style_index_state(\n      style_rowid, artifact_hint_hash, crawl_record_hash, aggregate_hash,\n      last_success_generation, last_success_at, missing_observations\n    ) VALUES (?, ?, ?, ?, ?, ?, 0)\n    ON CONFLICT(style_rowid) DO UPDATE SET\n      artifact_hint_hash = excluded.artifact_hint_hash,\n      crawl_record_hash = excluded.crawl_record_hash,\n      aggregate_hash = excluded.aggregate_hash,\n      last_success_generation = excluded.last_success_generation,\n      last_success_at = excluded.last_success_at,\n      missing_observations = 0\n  `).run(\n    styleRowid,\n    style.artifactHintHash,\n    style.crawlRecordHash,\n    style.aggregateHash,\n    '',\n    timestamp,\n  );\n}\n\nfunction resolveRelationships(database) {\n  const aliases = new Map();\n  for (const style of database.prepare(`\n    SELECT style_rowid, slug, title FROM styles WHERE lifecycle_state = 'active'\n  `).all()) {\n    for (const alias of [style.slug, style.title]) {\n      const key = normalizeTerm(alias);\n      if (!aliases.has(key)) aliases.set(key, []);\n      aliases.get(key).push(Number(style.style_rowid));\n    }\n  }\n  const update = database.prepare(`\n    UPDATE style_relationships\n    SET target_style_rowid = ?, resolution_state = ?, confidence = ?\n    WHERE relationship_id = ?\n  `);\n  for (const relationship of database.prepare(`\n    SELECT relationship_id, raw_target_label FROM style_relationships\n  `).all()) {\n    const matches = [...new Set(aliases.get(normalizeTerm(relationship.raw_target_label)) ?? [])];\n    if (matches.length === 1) update.run(matches[0], 'resolved', 1, relationship.relationship_id);\n    else if (matches.length > 1) update.run(null, 'ambiguous', 0.5, relationship.relationship_id);\n    else update.run(null, 'unresolved', 0, relationship.relationship_id);\n  }\n}\n\nfunction ensureEmbeddingProfile(database, profile, timestamp) {\n  const existing = database.prepare(`\n    SELECT provider, model, dimensions, config_hash\n    FROM embedding_profiles WHERE profile_id = ?\n  `).get(profile.id);\n  if (existing && (\n    existing.provider !== profile.provider\n    || existing.model !== profile.model\n    || existing.config_hash !== profile.configHash\n    || (existing.dimensions != null && profile.dimensions != null\n      && Number(existing.dimensions) !== profile.dimensions)\n  )) {\n    const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n    error.code = 'embedding-profile-conflict';\n    throw error;\n  }\n  if (existing) return;\n  database.prepare(`\n    INSERT INTO embedding_profiles(\n      profile_id, provider, model, dimensions, config_hash, created_at\n    ) VALUES (?, ?, ?, ?, ?, ?)\n  `).run(\n    profile.id,\n    profile.provider,\n    profile.model,\n    profile.dimensions ?? null,\n    profile.configHash,\n    timestamp,\n  );\n}\n\nfunction enqueueVector(database, styleRowid, retrievalHash, profileId, timestamp) {\n  database.prepare(`\n    UPDATE style_vector_jobs\n    SET status = 'superseded', updated_at = ?\n    WHERE style_rowid = ? AND profile_id = ?\n      AND retrieval_hash != ? AND status IN ('pending', 'running', 'failed')\n  `).run(timestamp, styleRowid, profileId, retrievalHash);\n  database.prepare(`\n    UPDATE style_vector_jobs\n    SET status = 'pending', updated_at = ?, last_error = NULL, next_attempt_at = NULL\n    WHERE style_rowid = ? AND retrieval_hash = ? AND profile_id = ?\n      AND status = 'completed'\n      AND NOT EXISTS (\n        SELECT 1 FROM style_vectors v\n        WHERE v.style_rowid = style_vector_jobs.style_rowid\n          AND v.retrieval_hash = style_vector_jobs.retrieval_hash\n          AND v.profile_id = style_vector_jobs.profile_id\n      )\n  `).run(timestamp, styleRowid, retrievalHash, profileId);\n  database.prepare(`\n    INSERT INTO style_vector_jobs(\n      style_rowid, retrieval_hash, profile_id, status, created_at, updated_at\n    ) VALUES (?, ?, ?, 'pending', ?, ?)\n    ON CONFLICT(style_rowid, retrieval_hash, profile_id) DO UPDATE SET\n      status = CASE\n        WHEN style_vector_jobs.status = 'completed' THEN 'completed'\n        ELSE 'pending'\n      END,\n      updated_at = excluded.updated_at,\n      last_error = NULL\n  `).run(styleRowid, retrievalHash, profileId, timestamp, timestamp);\n}\n\n/**\n * Incrementally project an authoritative flat-file corpus into SQLite.\n *\n * @param {Object} options - Indexing controls.\n * @param {string} options.corpusRoot - Authoritative style corpus root.\n * @param {string} [options.databasePath] - SQLite destination when no connection is supplied.\n * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n * @param {'migration'|'rollback'} options.corpusWalkMode - Explicit filesystem-walk grant.\n * @param {boolean} [options.confirmMissing=false] - Confirm quarantined absences as tombstones.\n * @param {boolean} [options.verifyAll=false] - Bypass metadata hints and hash every bundle.\n * @param {Function} [options.onStage] - Lifecycle observation hook.\n * @param {Function} [options.failureInjector] - Test-only crash hook inside the transaction.\n * @param {Object} [options.embeddingProfile] - Profile metadata for queued vectors.\n * @param {Function} [options.embedder] - Optional asynchronous embedding callback.\n * @returns {Promise<Object>} Publication and incremental-change summary.\n */\nexport async function indexStyleCorpus(options) {\n  if (!options?.corpusRoot || !['migration', 'rollback'].includes(options.corpusWalkMode)) {\n    const error = new Error('Corpus walking requires explicit migration or rollback mode.');\n    error.code = 'corpus-walk-forbidden';\n    throw error;\n  }\n  const database = options.database ?? openStyleDatabase(\n    options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n  );\n  const ownsDatabase = !options.database;\n  const telemetry = options.telemetry ?? null;\n  const overallTimer = telemetry?.overall() ?? null;\n  const emit = (stage, details = {}) => {\n    options.onStage?.(stage, details);\n  };\n  const profile = {\n    id: options.embeddingProfile?.id ?? DEFAULT_EMBEDDING_PROFILE,\n    provider: options.embeddingProfile?.provider ?? 'external',\n    model: options.embeddingProfile?.model ?? 'configured',\n    dimensions: options.embeddingProfile?.dimensions ?? null,\n    configHash: options.embeddingProfile?.configHash ?? 'style-default-v1',\n  };\n  try {\n    emit('DISCOVER');\n    const discoverSpan = telemetry?.span('discover', RESIDENCY.JS_RESIDENT);\n    const corpusRealPath = await realpath(options.corpusRoot);\n    const crawlPath = path.join(options.corpusRoot, '_manifest.json');\n    const crawlRealPath = await realpath(crawlPath);\n    if (!isContained(corpusRealPath, crawlRealPath)) {\n      const error = new Error('Crawl manifest escapes the corpus root.');\n      error.code = 'path-escape';\n      throw error;\n    }\n    const crawlBuffer = await readFile(crawlRealPath);\n    const crawlManifestHash = digest([crawlBuffer]);\n    const crawlRecords = JSON.parse(crawlBuffer.toString('utf8'));\n    const crawlBySlug = new Map(crawlRecords.map((record) => [record.slug, record]));\n    const entries = await readdir(options.corpusRoot, { withFileTypes: true });\n    const slugs = entries.filter((entry) => entry.isDirectory() && !entry.name.startsWith('_'))\n      .map((entry) => entry.name).sort(compareRawStrings);\n    discoverSpan?.end(slugs.length);\n    const snapshotSpan = telemetry?.span('snapshot.load', RESIDENCY.NATIVE);\n    const currentRows = database.prepare(`\n      SELECT s.style_rowid, s.style_id, s.slug, s.crawl_status, s.aggregate_hash,\n        s.retrieval_hash, s.lifecycle_state, i.artifact_hint_hash, i.crawl_record_hash\n      FROM styles s\n      LEFT JOIN style_index_state i ON i.style_rowid = s.style_rowid\n    `).all();\n    snapshotSpan?.end(currentRows.length);\n    const currentBySlug = new Map(currentRows.map((row) => [row.slug, row]));\n    const verifySpan = telemetry?.span('verify.parse', RESIDENCY.JS_RESIDENT);\n    const discovered = [];\n    let candidateCount = 0;\n    for (const slug of slugs) {\n      const crawlRecord = crawlBySlug.get(slug);\n      const crawlRecordHash = computeCrawlRecordHash(crawlRecord);\n      const hints = await readArtifactHints(options.corpusRoot, corpusRealPath, slug);\n      const artifactHintHash = computeHintHash(hints);\n      const current = currentBySlug.get(slug);\n      const needsVerification = options.verifyAll === true\n        || !current\n        || current.lifecycle_state !== 'active'\n        || current.artifact_hint_hash !== artifactHintHash\n        || current.crawl_record_hash !== crawlRecordHash;\n      if (needsVerification) {\n        candidateCount += 1;\n        const artifacts = await readVerifiedArtifacts(options.corpusRoot, corpusRealPath, slug);\n        discovered.push({\n          slug,\n          crawlRecord,\n          artifactHintHash,\n          crawlRecordHash,\n          style: parseStyle(slug, crawlRecord, artifacts),\n        });\n      } else {\n        discovered.push({\n          slug,\n          crawlRecord,\n          artifactHintHash,\n          crawlRecordHash,\n          style: {\n            id: current.style_id,\n            slug,\n            crawlStatus: current.crawl_status,\n            aggregateHash: current.aggregate_hash,\n            retrievalHash: current.retrieval_hash,\n          },\n        });\n      }\n    }\n    verifySpan?.end(candidateCount);\n    emit('VERIFY', { discovered: slugs.length, candidates: candidateCount });\n    emit('PARSE_VALIDATE', { verified: candidateCount });\n    const planSpan = telemetry?.span('plan.hash', RESIDENCY.JS_RESIDENT);\n    const parsedStyles = discovered.map((entry) => entry.style);\n    if (new Set(parsedStyles.map((style) => style.id)).size !== parsedStyles.length) {\n      const error = new Error('The corpus contains duplicate style UUIDs.');\n      error.code = 'duplicate-style-id';\n      throw error;\n    }\n    const currentById = new Map(currentRows.map((row) => [row.style_id, row]));\n    const verifiedStyles = discovered.filter((entry) => entry.style.artifacts)\n      .map((entry) => entry.style);\n    const changedStyles = verifiedStyles.filter((style) => {\n      const current = currentById.get(style.id);\n      return !current\n        || current.slug !== style.slug\n        || current.crawl_status !== style.crawlStatus\n        || current.aggregate_hash !== style.aggregateHash\n        || current.crawl_record_hash !== style.crawlRecordHash\n        || current.lifecycle_state !== 'active';\n    });\n    const changedIds = new Set(changedStyles.map((style) => style.id));\n    const hintOnlyStyles = verifiedStyles.filter((style) => !changedIds.has(style.id));\n    const discoveredIds = new Set(parsedStyles.map((style) => style.id));\n    const absentRows = currentRows.filter((row) => !discoveredIds.has(row.style_id));\n    const missingRows = absentRows.filter((row) => row.lifecycle_state !== 'tombstoned');\n    const inactiveStates = absentRows.map((row) => ({\n      id: row.style_id,\n      state: row.lifecycle_state === 'active' ? 'quarantined' : 'tombstoned',\n    }));\n    const generationHash = computeGenerationHash(\n      crawlManifestHash,\n      parsedStyles,\n      inactiveStates,\n    );\n    const aggregateCorpusHash = digest([\n      'style-corpus-aggregate-v1\\0',\n      ...parsedStyles.slice().sort((left, right) => compareRawStrings(left.id, right.id))\n        .map((style) => `${style.id}\\0${style.aggregateHash}\\n`),\n    ]);\n    const timestamp = nowIso();\n    planSpan?.end(parsedStyles.length);\n    const planLoadSpan = telemetry?.span('plan.load', RESIDENCY.NATIVE);\n    const currentGeneration = database.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash ?? null;\n    const profileRow = database.prepare(`\n      SELECT provider, model, dimensions, config_hash\n      FROM embedding_profiles WHERE profile_id = ?\n    `).get(profile.id);\n    if (profileRow && (\n      profileRow.provider !== profile.provider\n      || profileRow.model !== profile.model\n      || profileRow.config_hash !== profile.configHash\n      || (profileRow.dimensions != null && profile.dimensions != null\n        && Number(profileRow.dimensions) !== profile.dimensions)\n    )) {\n      const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n      error.code = 'embedding-profile-conflict';\n      throw error;\n    }\n    const missingProfileJobs = profileRow ? Number(database.prepare(`\n      SELECT COUNT(*) AS count FROM styles s\n      WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n        SELECT 1 FROM style_vector_jobs j\n        WHERE j.style_rowid = s.style_rowid\n          AND j.retrieval_hash = s.retrieval_hash\n          AND j.profile_id = ?\n          AND j.status != 'superseded'\n          AND (j.status != 'completed' OR EXISTS (\n            SELECT 1 FROM style_vectors v\n            WHERE v.style_rowid = j.style_rowid\n              AND v.retrieval_hash = j.retrieval_hash\n              AND v.profile_id = j.profile_id\n          ))\n      )\n    `).get(profile.id).count) : parsedStyles.length;\n    planLoadSpan?.end(1);\n    const needsVectorQueue = !profileRow || missingProfileJobs > 0 || changedStyles.length > 0;\n    const shouldPublish = changedStyles.length > 0\n      || missingRows.length > 0\n      || currentGeneration !== generationHash;\n    if (!shouldPublish && hintOnlyStyles.length === 0 && !needsVectorQueue) {\n      return {\n        ok: true,\n        generationHash,\n        published: false,\n        indexed: 0,\n        unchanged: parsedStyles.length,\n        quarantined: 0,\n        tombstoned: 0,\n      };\n    }\n\n    database.exec('BEGIN IMMEDIATE');\n    try {\n      emit('COMMIT', {\n        changed: changedStyles.length,\n        hintOnly: hintOnlyStyles.length,\n        missing: missingRows.length,\n      });\n      const commitSpan = telemetry?.span('commit.write', RESIDENCY.NATIVE);\n      ensureEmbeddingProfile(database, profile, timestamp);\n      const upsertStyle = database.prepare(`\n        INSERT INTO styles(\n          style_id, slug, lifecycle_state, crawl_status, title, thesis, theme,\n          industry, aggregate_hash, retrieval_hash, quarantine_at, tombstoned_at,\n          created_at, updated_at\n        ) VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?, ?, NULL, NULL, ?, ?)\n        ON CONFLICT(style_id) DO UPDATE SET\n          slug = excluded.slug,\n          lifecycle_state = 'active',\n          crawl_status = excluded.crawl_status,\n          title = excluded.title,\n          thesis = excluded.thesis,\n          theme = excluded.theme,\n          industry = excluded.industry,\n          aggregate_hash = excluded.aggregate_hash,\n          retrieval_hash = excluded.retrieval_hash,\n          quarantine_at = NULL,\n          tombstoned_at = NULL,\n          updated_at = excluded.updated_at\n      `);\n      for (const [index, style] of changedStyles.entries()) {\n        upsertStyle.run(\n          style.id,\n          style.slug,\n          style.crawlStatus,\n          style.title,\n          style.thesis,\n          style.theme,\n          style.industry,\n          style.aggregateHash,\n          style.retrievalHash,\n          timestamp,\n          timestamp,\n        );\n        const styleRowid = Number(database.prepare(\n          'SELECT style_rowid FROM styles WHERE style_id = ?',\n        ).get(style.id).style_rowid);\n        replaceStyleChildren(database, styleRowid, style, timestamp);\n        options.failureInjector?.({ phase: 'COMMIT', style, index, database });\n      }\n      const updateHints = database.prepare(`\n        UPDATE style_index_state\n        SET artifact_hint_hash = ?, crawl_record_hash = ?, last_success_at = ?\n        WHERE style_rowid = ?\n      `);\n      for (const style of hintOnlyStyles) {\n        const current = currentById.get(style.id);\n        updateHints.run(\n          style.artifactHintHash,\n          style.crawlRecordHash,\n          timestamp,\n          current.style_rowid,\n        );\n      }\n\n      let queued = 0;\n      const queueRows = database.prepare(`\n        SELECT s.style_rowid, s.retrieval_hash FROM styles s\n        WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n          SELECT 1 FROM style_vector_jobs j\n          WHERE j.style_rowid = s.style_rowid\n            AND j.retrieval_hash = s.retrieval_hash\n            AND j.profile_id = ?\n            AND j.status != 'superseded'\n            AND (j.status != 'completed' OR EXISTS (\n              SELECT 1 FROM style_vectors v\n              WHERE v.style_rowid = j.style_rowid\n                AND v.retrieval_hash = j.retrieval_hash\n                AND v.profile_id = j.profile_id\n            ))\n        )\n      `).all(profile.id);\n      for (const row of queueRows) {\n        enqueueVector(database, row.style_rowid, row.retrieval_hash, profile.id, timestamp);\n        queued += 1;\n      }\n      commitSpan?.end(changedStyles.length + queued);\n\n      emit('VECTOR_DRAIN', { queued });\n      if (!shouldPublish) {\n        const finalizeSpan = telemetry?.span('commit.finalize', RESIDENCY.NATIVE);\n        database.exec('COMMIT');\n        finalizeSpan?.end(1);\n        if (options.embedder) {\n          const { drainVectorQueue } = await import('./vectors.mjs');\n          const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n          await drainVectorQueue(database, {\n            profileId: profile.id,\n            embedder: options.embedder,\n            limit: options.vectorDrainLimit,\n          });\n          drainSpan?.end(queued);\n        }\n        return {\n          ok: true,\n          generationHash,\n          published: false,\n          indexed: 0,\n          unchanged: parsedStyles.length,\n          quarantined: 0,\n          tombstoned: 0,\n          queued,\n        };\n      }\n\n      const missingSpan = telemetry?.span('publish.missing', RESIDENCY.NATIVE);\n      let quarantined = 0;\n      let tombstoned = 0;\n      for (const row of missingRows) {\n        const state = database.prepare(`\n          SELECT missing_observations FROM style_index_state WHERE style_rowid = ?\n        `).get(row.style_rowid);\n        const shouldTombstone = row.lifecycle_state === 'quarantined'\n          && (options.confirmMissing === true || Number(state?.missing_observations ?? 0) >= 1);\n        if (shouldTombstone) {\n          database.prepare(`\n            UPDATE styles SET lifecycle_state = 'tombstoned',\n              quarantine_at = COALESCE(quarantine_at, ?), tombstoned_at = ?, updated_at = ?\n            WHERE style_rowid = ?\n          `).run(timestamp, timestamp, timestamp, row.style_rowid);\n          tombstoned += 1;\n        } else if (row.lifecycle_state !== 'tombstoned') {\n          database.prepare(`\n            UPDATE styles SET lifecycle_state = 'quarantined', quarantine_at = ?,\n              tombstoned_at = NULL, updated_at = ? WHERE style_rowid = ?\n          `).run(timestamp, timestamp, row.style_rowid);\n          quarantined += 1;\n        }\n        database.prepare(`\n          UPDATE style_index_state\n          SET missing_observations = missing_observations + 1, last_success_at = ?\n          WHERE style_rowid = ?\n        `).run(timestamp, row.style_rowid);\n      }\n      missingSpan?.end(missingRows.length);\n      resolveRelationships(database);\n\n      const publishSpan = telemetry?.span('publish.write', RESIDENCY.NATIVE);\n      const counts = Object.fromEntries(database.prepare(`\n        SELECT lifecycle_state, COUNT(*) AS count FROM styles GROUP BY lifecycle_state\n      `).all().map((row) => [row.lifecycle_state, Number(row.count)]));\n      emit('PUBLISH', { generationHash });\n      database.prepare(`\n        INSERT OR IGNORE INTO corpus_generations(\n          generation_hash, parent_generation_hash, crawl_manifest_hash,\n          aggregate_corpus_hash, schema_version, active_style_count,\n          quarantined_style_count, tombstoned_style_count, created_at\n        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n      `).run(\n        generationHash,\n        currentGeneration,\n        crawlManifestHash,\n        aggregateCorpusHash,\n        STYLE_DB_SCHEMA_VERSION,\n        counts.active ?? 0,\n        counts.quarantined ?? 0,\n        counts.tombstoned ?? 0,\n        timestamp,\n      );\n      database.prepare(`\n        INSERT INTO current_corpus_generation(singleton, generation_hash, published_at)\n        VALUES (1, ?, ?)\n        ON CONFLICT(singleton) DO UPDATE SET\n          generation_hash = excluded.generation_hash,\n          published_at = excluded.published_at\n      `).run(generationHash, timestamp);\n      database.prepare(`\n        UPDATE style_index_state SET last_success_generation = ?\n        WHERE style_rowid IN (SELECT style_rowid FROM styles WHERE lifecycle_state = 'active')\n      `).run(generationHash);\n      options.failureInjector?.({ phase: 'PUBLISH', database });\n      database.exec('COMMIT');\n      publishSpan?.end(changedStyles.length);\n\n      if (options.embedder) {\n        const { drainVectorQueue } = await import('./vectors.mjs');\n        const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n        await drainVectorQueue(database, {\n          profileId: profile.id,\n          embedder: options.embedder,\n          limit: options.vectorDrainLimit,\n        });\n        drainSpan?.end(changedStyles.length);\n      }\n      return {\n        ok: true,\n        generationHash,\n        published: true,\n        indexed: changedStyles.length,\n        unchanged: parsedStyles.length - changedStyles.length,\n        quarantined,\n        tombstoned,\n      };\n    } catch (error) {\n      database.exec('ROLLBACK');\n      throw error;\n    }\n  } finally {\n    overallTimer?.end();\n    if (ownsDatabase) database.close();\n  }\n}\n\n/**\n * Build a complete database projection without making it a query side effect.\n *\n * @param {Object} options - The same controls as indexStyleCorpus.\n * @returns {Promise<Object>} Publication summary.\n */\nasync function writeGenerationPointer(\n  databasePath,\n  generationHash,\n  databaseFile,\n  afterRename,\n  options = {},\n) {\n  if (path.basename(databaseFile) !== databaseFile) {\n    throw new TypeError('Generation database file must be a basename.');\n  }\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const artifactPath = path.join(path.dirname(databasePath), databaseFile);\n  const { sha256, bytes } = await hashArtifactFile(artifactPath);\n  const manifest = buildManifest({\n    generationHash,\n    createdAt: nowIso(),\n    parentGenerationHash: options.parentGenerationHash ?? null,\n    artifacts: { sqlite: { role: 'sqlite', file: databaseFile, sha256, bytes } },\n  });\n  await writeManifestPointer(pointerPath, manifest, { afterRename });\n}\n\nexport async function buildStyleDatabase(options) {\n  if (options?.database) {\n    const error = new Error('Full rebuild publication requires a databasePath, not an open connection.');\n    error.code = 'staging-requires-database-path';\n    throw error;\n  }\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const buildingPath = `${databasePath}.building-${process.pid}-${Date.now()}`;\n  let generationPath = null;\n  const removeSidecars = async (basePath) => {\n    await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n      rm(`${basePath}${suffix}`, { force: true })\n    )));\n  };\n  await removeSidecars(buildingPath);\n  try {\n    const result = await indexStyleCorpus({\n      ...options,\n      databasePath: buildingPath,\n      corpusWalkMode: options.corpusWalkMode ?? 'migration',\n      verifyAll: true,\n    });\n    const staged = openStyleDatabase(buildingPath);\n    try {\n      const integrity = staged.prepare('PRAGMA integrity_check').get().integrity_check;\n      const foreignKeyFailures = staged.prepare('PRAGMA foreign_key_check').all();\n      const current = staged.prepare(`\n        SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n      `).get()?.generation_hash;\n      if (integrity !== 'ok' || foreignKeyFailures.length > 0\n        || current !== result.generationHash) {\n        const error = new Error('Staged style database failed publication validation.');\n        error.code = 'staging-validation-failed';\n        throw error;\n      }\n      staged.prepare(`\n        INSERT INTO style_fts(style_fts) VALUES ('integrity-check')\n      `).run();\n      staged.exec('PRAGMA wal_checkpoint(TRUNCATE)');\n    } finally {\n      staged.close();\n    }\n    const generationName = result.generationHash.replace(':', '-');\n    const databaseFile = `${path.basename(databasePath)}.${generationName}`\n      + `.${process.pid}-${Date.now()}.sqlite`;\n    generationPath = path.join(path.dirname(databasePath), databaseFile);\n    await removeSidecars(generationPath);\n    await rename(buildingPath, generationPath);\n    const immutableGenerationPath = generationPath;\n    generationPath = null;\n    const generationHandle = await open(immutableGenerationPath, 'r');\n    try {\n      await generationHandle.sync();\n    } finally {\n      await generationHandle.close();\n    }\n    const generationDirectory = await open(path.dirname(immutableGenerationPath), 'r');\n    try {\n      await generationDirectory.sync();\n    } finally {\n      await generationDirectory.close();\n    }\n    await writeGenerationPointer(\n      databasePath,\n      result.generationHash,\n      databaseFile,\n      options.failureInjector\n        ? (details) => options.failureInjector({ phase: 'POINTER_RENAMED', ...details })\n        : undefined,\n    );\n    return {\n      ...result,\n      databasePath,\n      generationDatabasePath: path.join(path.dirname(databasePath), databaseFile),\n    };\n  } finally {\n    await removeSidecars(buildingPath);\n    if (generationPath) await removeSidecars(generationPath);\n  }\n}\n\n/**\n * Roll back by atomically repointing new readers to a retained generation file.\n *\n * @param {Object} options - Logical path and retained generation identity.\n * @param {string} options.databasePath - Logical database path.\n * @param {string} options.generationDatabasePath - Retained immutable database file.\n * @returns {Promise<Object>} Restored generation pointer details.\n */\nexport async function rollbackStyleDatabase(options) {\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const generationDatabasePath = options?.generationDatabasePath;\n  if (!generationDatabasePath\n    || path.dirname(path.resolve(generationDatabasePath)) !== path.dirname(path.resolve(databasePath))) {\n    const error = new Error('Rollback generation must be retained beside the logical database path.');\n    error.code = 'rollback-generation-invalid';\n    throw error;\n  }\n  try {\n    const retainedInfo = await stat(generationDatabasePath);\n    if (!retainedInfo.isFile()) throw new Error('not a file');\n    const databaseDirectoryRealPath = await realpath(path.dirname(databasePath));\n    const retainedRealPath = await realpath(generationDatabasePath);\n    if (!isContained(databaseDirectoryRealPath, retainedRealPath)) {\n      throw new Error('generation escapes database directory');\n    }\n  } catch (cause) {\n    const error = new Error('Rollback generation is unavailable.', { cause });\n    error.code = 'rollback-generation-invalid';\n    throw error;\n  }\n  const retained = openStyleDatabase(generationDatabasePath);\n  let generationHash;\n  try {\n    const integrity = retained.prepare('PRAGMA integrity_check').get().integrity_check;\n    generationHash = retained.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash;\n    if (integrity !== 'ok' || !generationHash) {\n      const error = new Error('Rollback generation failed validation.');\n      error.code = 'rollback-generation-invalid';\n      throw error;\n    }\n  } finally {\n    retained.close();\n  }\n  await writeGenerationPointer(\n    databasePath,\n    generationHash,\n    path.basename(generationDatabasePath),\n  );\n  return { databasePath, generationDatabasePath, generationHash };\n}\n\nexport const indexerInternals = Object.freeze({\n  computeAggregateHash,\n  computeGenerationHash,\n  normalizeMarkdown,\n  parseStyle,\n});","lineStart":1,"lineEnd":1187,"totalLines":1187,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/indexer.mjs","time":{"start":1784606406968,"end":1784606406974}},"id":"prt_f82d4b670001mnHSZ6sZSmpemR","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d48ebc001VpT7XtL2ogmu4X"}}
