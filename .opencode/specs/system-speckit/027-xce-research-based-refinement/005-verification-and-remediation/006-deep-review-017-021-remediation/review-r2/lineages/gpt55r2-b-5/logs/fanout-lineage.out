{"type":"tool_use","timestamp":1781762663886,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_GD0lCkvkPfnAiIEmEtnbQHud","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2140,"limit":760},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2140: \n2141: function resolveIndexingOrigin(options: {\n2142:   origin?: IndexingOrigin;\n2143:   fromScan?: boolean;\n2144: }): IndexingOrigin {\n2145:   return options.origin ?? (options.fromScan ? 'scan' : 'direct');\n2146: }\n2147: \n2148: async function processPreparedMemory(\n2149:   prepared: PreparedParsedMemory,\n2150:   filePath: string,\n2151:   options: {\n2152:     force?: boolean;\n2153:     asyncEmbedding?: boolean;\n2154:     plannerMode?: AtomicSaveParams['plannerMode'];\n2155:     origin?: IndexingOrigin;\n2156:     fromScan?: boolean;\n2157:     persistQualityLoopContent?: boolean;\n2158:     refreshFromDiskAfterLock?: boolean;\n2159:     specFolderLockAlreadyHeld?: boolean;\n2160:     scope?: MemoryScopeMatch;\n2161:     qualityGateMode?: 'enforce' | 'warn-only';\n2162:     routing?: RoutedSaveOptions;\n2163:     provenance?: WriteProvenanceContext;\n2164:   } = {},\n2165: ): Promise<IndexResult> {\n2166:   const {\n2167:     force = false,\n2168:     asyncEmbedding = false,\n2169:     plannerMode: requestedPlannerMode,\n2170:     origin,\n2171:     fromScan = false,\n2172:     persistQualityLoopContent = true,\n2173:     refreshFromDiskAfterLock = false,\n2174:     specFolderLockAlreadyHeld = false,\n2175:     scope = {},\n2176:     qualityGateMode = 'enforce',\n2177:     routing = {},\n2178:     provenance = {},\n2179:   } = options;\n2180:   const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n2181:   const indexingOrigin = resolveIndexingOrigin({ origin, fromScan });\n2182: \n2183:   const evaluatePreparedMemory = (currentPrepared: PreparedParsedMemory): IndexResult | null => {\n2184:     const {\n2185:       parsed,\n2186:       validation,\n2187:       qualityLoopResult,\n2188:       sufficiencyResult,\n2189:       templateContract,\n2190:       sourceClassification,\n2191:     } = currentPrepared;\n2192:     const templateContractBypassed = shouldBypassTemplateContract(\n2193:       sourceClassification,\n2194:       sufficiencyResult,\n2195:       templateContract,\n2196:       currentPrepared.specDocHealth,\n2197:       parsed.documentType,\n2198:     );\n2199: \n2200:     if (!qualityLoopResult.passed && qualityLoopResult.rejected) {\n2201:       if (qualityGateMode === 'warn-only') {\n2202:         console.warn(`[memory-save] V-rule warn-only (spec doc) for ${path.basename(filePath)}: ${qualityLoopResult.rejectionReason}`);\n2203:       } else {\n2204:         return {\n2205:           status: 'rejected',\n2206:           id: 0,\n2207:           specFolder: parsed.specFolder,\n2208:           title: parsed.title ?? '',\n2209:           triggerPhrases: parsed.triggerPhrases,\n2210:           contextType: parsed.contextType,\n2211:           importanceTier: parsed.importanceTier,\n2212:           qualityScore: parsed.qualityScore,\n2213:           qualityFlags: parsed.qualityFlags,\n2214:           warnings: validation.warnings,\n2215:           rejectionReason: qualityLoopResult.rejectionReason,\n2216:           message: qualityLoopResult.rejectionReason,\n2217:         };\n2218:       }\n2219:     }\n2220: \n2221:     if (!sufficiencyResult.pass) {\n2222:       if (isStructuralMetadataFile(filePath)) {\n2223:         console.warn(`[memory-save] Sufficiency exempt for structural metadata file ${path.basename(filePath)}: ${sufficiencyResult.reasons.join('; ')}`);\n2224:       } else if (qualityGateMode === 'warn-only') {\n2225:         console.warn(`[memory-save] Sufficiency warn-only (spec doc) for ${path.basename(filePath)}: ${sufficiencyResult.reasons.join('; ')}`);\n2226:       } else {\n2227:         return buildInsufficiencyRejectionResult(parsed, validation, sufficiencyResult);\n2228:       }\n2229:     }\n2230: \n2231:     if (!templateContract.valid) {\n2232:       if (isStructuralMetadataFile(filePath)) {\n2233:         console.warn(\n2234:           `[memory-save] Template contract exempt for structural metadata file ${path.basename(filePath)}: ${templateContract.violations.map((v: { message?: string; rule?: string }) => v.message || v.rule).join('; ')}`,\n2235:         );\n2236:       } else if (templateContractBypassed) {\n2237:         console.warn(\n2238:           `[memory-save] Template contract bypassed in ${MANUAL_FALLBACK_SOURCE_CLASSIFICATION} mode for ${path.basename(filePath)}: ${templateContract.violations.map((v: { message?: string; rule?: string }) => v.message || v.rule).join('; ')}`,\n2239:         );\n2240:       } else if (qualityGateMode === 'warn-only') {\n2241:         console.warn(\n2242:           `[memory-save] Template contract warn-only (spec doc) for ${path.basename(filePath)}: ${templateContract.violations.map((v: { message?: string; rule?: string }) => v.message || v.rule).join('; ')}`,\n2243:         );\n2244:       } else {\n2245:         return buildTemplateContractRejectionResult(parsed, validation, templateContract);\n2246:       }\n2247:     }\n2248: \n2249:     return null;\n2250:   };\n2251: \n2252:   if (!refreshFromDiskAfterLock) {\n2253:     const earlyResult = evaluatePreparedMemory(prepared);\n2254:     if (earlyResult) {\n2255:       return earlyResult;\n2256:     }\n2257:   }\n2258: \n2259:   const runWithinSpecFolderLock = async (): Promise<IndexResult> => {\n2260:     const database = requireDb();\n2261:     const activePrepared = refreshFromDiskAfterLock\n2262:       ? prepareParsedMemoryForIndexing(memoryParser.parseMemoryFile(filePath), database, {\n2263:           qualityLoopMode: 'full-auto',\n2264:         })\n2265:       : prepared;\n2266:     const lockedResult = evaluatePreparedMemory(activePrepared);\n2267:     if (lockedResult) {\n2268:       return lockedResult;\n2269:     }\n2270:     const {\n2271:       parsed,\n2272:       validation,\n2273:       finalizedFileContent,\n2274:     } = activePrepared;\n2275:     const routedFilePath = routing.targetDocPath ?? filePath;\n2276:     const writeProvenance: WriteProvenanceContext = {\n2277:       tool: 'memory_save',\n2278:       filePath: routedFilePath,\n2279:       scope,\n2280:       ...provenance,\n2281:     };\n2282:     const routedParsed = Object.keys(routing).length > 0\n2283:       ? applyRoutedSaveHints(parsed, {\n2284:           ...routing,\n2285:           targetDocPath: routedFilePath,\n2286:         })\n2287:       : parsed;\n2288:     const recordIdentity = resolveRoutedRecordIdentity(routedParsed, routedFilePath, {\n2289:       ...routing,\n2290:       targetDocPath: routedFilePath,\n2291:     });\n2292:     const canonicalFilePath = recordIdentity.canonicalFilePath;\n2293:     const samePathDedupExclusion = {\n2294:       canonicalFilePath,\n2295:       filePath: routedFilePath,\n2296:       ...(recordIdentity.targetAnchorId != null ? { targetAnchorId: recordIdentity.targetAnchorId } : {}),\n2297:     };\n2298:     const samePathExisting = findSamePathExistingMemory(\n2299:       database,\n2300:       routedParsed.specFolder,\n2301:       canonicalFilePath,\n2302:       routedFilePath,\n2303:       scope,\n2304:       recordIdentity,\n2305:     );\n2306:     const shouldChunkContent = shouldUseChunkedIndexing(routedParsed.content, plannerMode);\n2307:     const shouldPersistFinalizedFile = persistQualityLoopContent && typeof finalizedFileContent === 'string';\n2308:     let finalizeWarning: string | null = null;\n2309: \n2310:     // DEDUP: Check existing row by file path\n2311:     const existingResult = checkExistingRow(\n2312:       database,\n2313:       routedParsed,\n2314:       canonicalFilePath,\n2315:       routedFilePath,\n2316:       recordIdentity.targetAnchorId,\n2317:       force,\n2318:       validation.warnings,\n2319:       scope,\n2320:     );\n2321:     if (existingResult) return existingResult;\n2322: \n2323:     // NOTE: Content-hash dedup (C5-1) moved inside BEGIN IMMEDIATE transaction\n2324:     // to eliminate TOCTOU race between check and insert.\n2325: \n2326:     // EMBEDDING GENERATION (with persistent SQLite cache)\n2327:     const embeddingResult = await generateOrCacheEmbedding(database, routedParsed, routedFilePath, asyncEmbedding);\n2328:     const {\n2329:       embedding,\n2330:       status: embeddingStatus,\n2331:       failureReason: embeddingFailureReason,\n2332:       pendingCacheWrite,\n2333:     } = embeddingResult;\n2334: \n2335:     // the rollout: Quality Gate (before PE gating, after embedding)\n2336:     if (isSaveQualityGateEnabled() && isQualityGateEnabled()) {\n2337:       try {\n2338:         const qualityGateResult = runQualityGate({\n2339:           title: routedParsed.title,\n2340:           content: routedParsed.content,\n2341:           specFolder: routedParsed.specFolder,\n2342:           triggerPhrases: routedParsed.triggerPhrases,\n2343:           contextType: routedParsed.contextType,\n2344:           mode: 'legacy',\n2345:           embedding: embedding,\n2346:           findSimilar: embedding ? (emb, gateOptions) => {\n2347:             return findSimilarMemories(emb as Float32Array, {\n2348:               limit: gateOptions.limit,\n2349:               specFolder: gateOptions.specFolder,\n2350:               tenantId: scope.tenantId,\n2351:               userId: scope.userId,\n2352:               agentId: scope.agentId,\n2353:               sessionId: scope.sessionId,\n2354:             }).map(m => ({\n2355:               id: m.id,\n2356:               file_path: m.file_path,\n2357:               similarity: m.similarity,\n2358:             }));\n2359:           } : null,\n2360:         });\n2361: \n2362:         if (!qualityGateResult.pass && !qualityGateResult.warnOnly && qualityGateMode !== 'warn-only') {\n2363:           console.error(`[memory-save] TM-04: Quality gate REJECTED save for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2364:           return {\n2365:             status: 'rejected',\n2366:             id: 0,\n2367:             specFolder: routedParsed.specFolder,\n2368:             title: routedParsed.title ?? '',\n2369:             qualityScore: routedParsed.qualityScore,\n2370:             qualityFlags: routedParsed.qualityFlags,\n2371:             rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2372:             message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2373:             qualityGate: {\n2374:               pass: false,\n2375:               reasons: qualityGateResult.reasons,\n2376:               layers: qualityGateResult.layers,\n2377:             },\n2378:           };\n2379:         }\n2380: \n2381:         if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n2382:           console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2383:         }\n2384: \n2385:         if (qualityGateResult.wouldReject) {\n2386:           console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2387:         }\n2388:       } catch (qgErr: unknown) {\n2389:         const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n2390:         console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n2391:         // Quality gate errors must not block saves\n2392:       }\n2393:     }\n2394: \n2395:     const duplicatePrecheck = checkContentHashDedup(\n2396:       database,\n2397:       routedParsed,\n2398:       force,\n2399:       validation.warnings,\n2400:       samePathDedupExclusion,\n2401:       scope,\n2402:     );\n2403:     if (duplicatePrecheck) {\n2404:       await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n2405:       return duplicatePrecheck;\n2406:     }\n2407: \n2408:     persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n2409: \n2410:     // PE GATING\n2411:     const peResult = evaluateAndApplyPeDecision(\n2412:       database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope, writeProvenance,\n2413:     );\n2414:     if (peResult.earlyReturn) return peResult.earlyReturn;\n2415: \n2416:     let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n2417:       earlyReturn: null,\n2418:       warnings: [],\n2419:       saveTimeReconsolidation: {\n2420:         status: 'skipped',\n2421:         persistedState: { kind: 'create' },\n2422:       },\n2423:     };\n2424: \n2425:     // Complete async reconsolidation planning before chunking or\n2426:     // taking the SQLite writer lock, so chunked saves do not bypass the gate\n2427:     // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n2428:     reconResult = await runReconsolidationIfEnabled(\n2429:       database,\n2430:       routedParsed,\n2431:       routedFilePath,\n2432:       force,\n2433:       embedding,\n2434:       scope,\n2435:       { plannerMode, provenance: writeProvenance },\n2436:     );\n2437:     if (reconResult.earlyReturn) return reconResult.earlyReturn;\n2438:     if (reconResult.saveTimeReconsolidation.status === 'failed') {\n2439:       return buildSaveTimeReconsolidationFailureResult({\n2440:         parsed: routedParsed,\n2441:         validation,\n2442:         reconWarnings: reconResult.warnings,\n2443:         failure: {\n2444:           status: 'failed',\n2445:           reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n2446:           ...(reconResult.saveTimeReconsolidation.warnings\n2447:             ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n2448:             : {}),\n2449:           ...(reconResult.saveTimeReconsolidation.persistedState\n2450:             ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n2451:             : {}),\n2452:         },\n2453:       });\n2454:     }\n2455: \n2456:     if (shouldChunkContent) {\n2457:       console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n2458:       const chunkedInsertTracker = createChunkedInsertTracker();\n2459:       const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n2460:         force,\n2461:         scope,\n2462:         provenance: writeProvenance,\n2463:         applyPostInsertMetadata: (db, memoryId, fields) => {\n2464:           applyPostInsertMetadata(db, memoryId, fields);\n2465:           trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n2466:         },\n2467:       });\n2468: \n2469:       if (\n2470:         peResult.supersededId != null\n2471:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2472:       ) {\n2473:         try {\n2474:           const finalizeChunkedPeTx = database.transaction(() => {\n2475:             if (chunkedResult.id > 0) {\n2476:               recordCrossPathPeSupersedes(\n2477:                 database,\n2478:                 chunkedResult.id,\n2479:                 peResult.supersededId,\n2480:                 samePathExisting?.id ?? null,\n2481:                 peResult.decision.reason,\n2482:               );\n2483:             }\n2484:             if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n2485:               throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2486:             }\n2487:           });\n2488:           finalizeChunkedPeTx.immediate();\n2489:         } catch (supersedeErr: unknown) {\n2490:           const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n2491:           const cleanupSuffix = cleanup.cleaned\n2492:             ? ' Rolled back the newly created chunk tree.'\n2493:             : cleanup.attempted && cleanup.error\n2494:               ? ` Cleanup failed: ${cleanup.error}`\n2495:               : '';\n2496:           return {\n2497:             ...chunkedResult,\n2498:             status: 'error',\n2499:             error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n2500:             message: `Chunked indexing succeeded, but predecessor ${peResult.supersededId} could not be superseded.${cleanupSuffix}`,\n2501:           };\n2502:         }\n2503:       }\n2504: \n2505:       if (\n2506:         shouldPersistFinalizedFile\n2507:         && finalizedFileContent\n2508:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2509:       ) {\n2510:         try {\n2511:           await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n2512:         } catch (finalizeErr: unknown) {\n2513:           finalizeWarning = `Quality-loop file persistence failed after chunked indexing: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}`;\n2514:           console.warn(`[memory-save] ${finalizeWarning}`);\n2515:         }\n2516:       }\n2517: \n2518:       if (peResult.decision.action !== 'CREATE') {\n2519:         chunkedResult.pe_action = peResult.decision.action;\n2520:         chunkedResult.pe_reason = peResult.decision.reason;\n2521:       }\n2522:       if (peResult.supersededId != null) {\n2523:         chunkedResult.superseded_id = peResult.supersededId;\n2524:       }\n2525:       if (Array.isArray(reconResult.warnings) && reconResult.warnings.length > 0) {\n2526:         const existingWarnings = Array.isArray(chunkedResult.warnings)\n2527:           ? [...(chunkedResult.warnings as string[])]\n2528:           : [];\n2529:         chunkedResult.warnings = [...existingWarnings, ...reconResult.warnings];\n2530:       }\n2531:       if (reconResult.assistiveRecommendation) {\n2532:         reconResult.assistiveRecommendation.advisory_stale = true;\n2533:         chunkedResult.assistiveRecommendation = reconResult.assistiveRecommendation;\n2534:       }\n2535:       chunkedResult.saveTimeReconsolidation = reconResult.saveTimeReconsolidation;\n2536: \n2537:       return appendResultWarning(chunkedResult, finalizeWarning);\n2538:     }\n2539: \n2540:     // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n2541:     // atomicity. Uses database.transaction() so inner transaction() calls in\n2542:     // createMemoryRecord / index_memory correctly nest via SAVEPOINTs instead\n2543:     // of failing with \"cannot start a transaction within a transaction\".\n2544:     // withSpecFolderLock handles in-process serialization; this transaction\n2545:     // provides defense-in-depth against multi-process races.\n2546:     let existing: { id: number; content_hash: string } | undefined;\n2547: \n2548:     // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n2549:     // safe outside the transaction and this avoids an early-return inside the\n2550:     // transaction callback (which would COMMIT an empty tx unnecessarily).\n2551:     const dupResult = checkContentHashDedup(\n2552:       database,\n2553:       routedParsed,\n2554:       force,\n2555:       validation.warnings,\n2556:       samePathDedupExclusion,\n2557:       scope,\n2558:     );\n2559:     if (dupResult) {\n2560:       await repairReplayEnrichmentIfNeeded(database, dupResult.id, routedParsed);\n2561:       return dupResult;\n2562:     }\n2563: \n2564:     const requestedScope = getRequestedScope(scope);\n2565:     const writeTransaction = database.transaction((): number => {\n2566:       if (indexingOrigin !== 'scan' && embedding) {\n2567:         const complementRecheck = findScopeFilteredCandidates({\n2568:           database,\n2569:           embedding,\n2570:           parsed: routedParsed,\n2571:           requestedScope,\n2572:           limit: 1,\n2573:           minSimilarity: 50,\n2574:           overfetchMultiplier: 3,\n2575:         });\n2576:         const topCandidate = complementRecheck.candidates[0];\n2577:         if (topCandidate) {\n2578:           const transactionalAction = determineAction(topCandidate.similarity);\n2579:           if (transactionalAction !== 'complement') {\n2580:             throw new SaveTimeReconsolidationAbort({\n2581:               status: 'failed',\n2582:               reason: 'candidate_changed',\n2583:               warnings: [\n2584:                 `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n2585:               ],\n2586:               persistedState: {\n2587:                 kind: transactionalAction,\n2588:                 candidateMemoryIds: [topCandidate.id],\n2589:               },\n2590:             });\n2591:           }\n2592:         }\n2593:       }\n2594: \n2595:       // CREATE NEW MEMORY\n2596:       existing = findSamePathExistingMemory(\n2597:         database,\n2598:         routedParsed.specFolder,\n2599:         canonicalFilePath,\n2600:         routedFilePath,\n2601:         scope,\n2602:         recordIdentity,\n2603:       ) as { id: number; content_hash: string } | undefined;\n2604: \n2605:       // A same-path re-index whose file content changed appends a new version\n2606:       // row; the prior row for this logical key is retired below so re-indexing\n2607:       // replaces in place rather than leaving a deprecated duplicate. Scoped to\n2608:       // this branch only — PE-gate / reconsolidation lineage (createMemoryRecord)\n2609:       // is intentionally preserved.\n2610:       const samePathSupersededPredecessorId =\n2611:         existing && existing.content_hash !== routedParsed.contentHash ? existing.id : null;\n2612: \n2613:       // Retire the same-path predecessor before inserting the new version so the\n2614:       // active-row uniqueness guard holds at insert time. Deprecating (not deleting)\n2615:       // keeps the predecessor row, its lineage chain, and its history intact while\n2616:       // removing it from the active-row guard; the new version supersedes it in place.\n2617:       const reindexTierCarry = samePathSupersededPredecessorId != null\n2618:         ? retirePredecessorForActiveReindex(database, samePathSupersededPredecessorId)\n2619:         : null;\n2620: \n2621:       const memoryId = samePathSupersededPredecessorId != null\n2622:         ? createAppendOnlyMemoryRecord({\n2623:             database,\n2624:             parsed: routedParsed,\n2625:             filePath: routedFilePath,\n2626:             embedding,\n2627:             embeddingFailureReason,\n2628:             predecessorMemoryId: samePathSupersededPredecessorId,\n2629:             anchorId: recordIdentity.targetAnchorId,\n2630:             tenantId: scope.tenantId,\n2631:             userId: scope.userId,\n2632:             agentId: scope.agentId,\n2633:             sessionId: scope.sessionId,\n2634:             actor: 'mcp:memory_save',\n2635:           })\n2636:         : createMemoryRecord(\n2637:             database,\n2638:             routedParsed,\n2639:             routedFilePath,\n2640:             embedding,\n2641:             embeddingFailureReason,\n2642:             peResult.decision,\n2643:             scope,\n2644:             recordIdentity,\n2645:             writeProvenance,\n2646:           );\n2647: \n2648:       if (samePathSupersededPredecessorId != null) {\n2649:         applyWriteProvenance(database, memoryId, writeProvenance);\n2650:       }\n2651: \n2652:       // A human's tier decision on the retired predecessor carries forward to the\n2653:       // reindexed successor. Re-stamp after provenance so the manual tier and its\n2654:       // human source-kind survive the reindex instead of resetting to the default.\n2655:       if (reindexTierCarry != null) {\n2656:         database\n2657:           .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n2658:           .run(reindexTierCarry.importanceTier, memoryId);\n2659:         persistSourceKind(database, memoryId, reindexTierCarry.sourceKind as SourceKind);\n2660:       }\n2661: \n2662:       // F1.01 fix: Mark superseded memory AFTER new record creation, inside\n2663:       // the same transaction, so a creation failure rolls back both operations.\n2664:       if (peResult.supersededId != null) {\n2665:         const supersededOk = markMemorySuperseded(peResult.supersededId);\n2666:         // C5-3: Supersede failure should abort the transaction\n2667:         if (!supersededOk) {\n2668:           throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2669:         }\n2670:       }\n2671: \n2672:       recordLineageVersion(database, {\n2673:         memoryId,\n2674:         predecessorMemoryId: samePathSupersededPredecessorId,\n2675:         actor: 'mcp:memory_save',\n2676:         transitionEvent: samePathSupersededPredecessorId != null ? 'SUPERSEDE' : 'CREATE',\n2677:       });\n2678:       markEnrichmentPending(database, memoryId, POST_INSERT_ENRICHMENT_VERSION);\n2679: \n2680:       return memoryId;\n2681:     });\n2682: \n2683:     let id: number;\n2684:     try {\n2685:       id = writeTransaction.immediate();\n2686:     } catch (error: unknown) {\n2687:       if (error instanceof SaveTimeReconsolidationAbort) {\n2688:         return buildSaveTimeReconsolidationFailureResult({\n2689:           parsed: routedParsed,\n2690:           validation,\n2691:           reconWarnings: reconResult.warnings,\n2692:           failure: error.result,\n2693:           message: `Save aborted before commit: ${error.result.reason}`,\n2694:         });\n2695:       }\n2696:       throw error;\n2697:     }\n2698: \n2699:     if (shouldPersistFinalizedFile && finalizedFileContent) {\n2700:       try {\n2701:         await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n2702:       } catch (finalizeErr: unknown) {\n2703:         finalizeWarning = `[file-persistence-failed] Quality-loop file persistence failed after DB commit: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}. DB row committed — manual file recovery may be needed.`;\n2704:         console.warn(`[memory-save] ${finalizeWarning}`);\n2705:       }\n2706:     }\n2707: \n2708:     // Data integrity: clean stale auto-entities before re-extraction on update\n2709:     // When a memory is superseded or replaced in-place, purge the predecessor's\n2710:     // auto-entity rows so the entity catalog reflects only active content.\n2711:     if (existing && existing.id !== id) {\n2712:       try {\n2713:         refreshAutoEntitiesForMemory(database, existing.id, []);\n2714:         console.error(`[memory-save] Cleaned stale auto-entities for superseded memory #${existing.id}`);\n2715:       } catch (entityCleanupErr: unknown) {\n2716:         // Entity cleanup failure must not block save — log and continue\n2717:         console.warn(`[memory-save] Auto-entity cleanup for #${existing.id} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n2718:       }\n2719:     }\n2720:     if (peResult.supersededId != null && peResult.supersededId !== existing?.id) {\n2721:       try {\n2722:         refreshAutoEntitiesForMemory(database, peResult.supersededId, []);\n2723:         console.error(`[memory-save] Cleaned stale auto-entities for PE-superseded memory #${peResult.supersededId}`);\n2724:       } catch (entityCleanupErr: unknown) {\n2725:         console.warn(`[memory-save] Auto-entity cleanup for PE #${peResult.supersededId} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n2726:       }\n2727:     }\n2728: \n2729:     if (embedding) {\n2730:       try {\n2731:         recordNearDuplicateCheck({\n2732:           database,\n2733:           memoryId: id,\n2734:           specFolder: routedParsed.specFolder,\n2735:           contentHash: routedParsed.contentHash,\n2736:           embedding,\n2737:           scope,\n2738:         });\n2739:       } catch (error: unknown) {\n2740:         const message = error instanceof Error ? error.message : String(error);\n2741:         console.warn(`[memory-save] Near-duplicate advisory skipped: ${message}`);\n2742:       }\n2743:     }\n2744: \n2745:     // POST-INSERT ENRICHMENT: causal links, entities, summaries, entity linking.\n2746:     // When enrichment is enabled and async (default), run the bundle in the background so the\n2747:     // save returns immediately. The row was marked enrichment-pending inside the commit\n2748:     // transaction (markEnrichmentPending), so a crash before the background run completes is\n2749:     // recovered by the pending-marker replay/backfill path. SPECKIT_POST_INSERT_ENRICHMENT_SYNC\n2750:     // forces synchronous execution when a caller needs the graph fresh in the same response.\n2751:     let postInsertEnrichmentResult: PostInsertEnrichmentResult;\n2752:     if (shouldRunPostInsertEnrichment(plannerMode) && isPostInsertEnrichmentAsync()) {\n2753:       scheduleBackgroundEnrichment(id, routedParsed);\n2754:       postInsertEnrichmentResult = buildDeferredEnrichmentResult('async-background');\n2755:     } else {\n2756:       postInsertEnrichmentResult = await runPostInsertEnrichmentIfEnabled(\n2757:         database,\n2758:         id,\n2759:         routedParsed,\n2760:         { plannerMode },\n2761:       );\n2762:       recordEnrichmentResult(database, id, postInsertEnrichmentResult);\n2763:       emitPostInsertEnrichmentSubscribers(id, 'post-insert-enrichment');\n2764:     }\n2765:     const { causalLinksResult, enrichmentStatus, executionStatus } = postInsertEnrichmentResult;\n2766: \n2767:     if (reconResult.assistiveRecommendation) {\n2768:       reconResult.assistiveRecommendation.advisory_stale = true;\n2769:       if (reconResult.saveTimeReconsolidation.persistedState) {\n2770:         reconResult.saveTimeReconsolidation.persistedState.advisory_stale = true;\n2771:       }\n2772:     }\n2773: \n2774:     // BUILD RESULT\n2775:     return appendResultWarning(buildIndexResult({\n2776:       database,\n2777:       existing,\n2778:       embeddingStatus,\n2779:       id,\n2780:       parsed: routedParsed,\n2781:       validation,\n2782:       reconWarnings: reconResult.warnings,\n2783:       peDecision: peResult.decision,\n2784:       embeddingFailureReason,\n2785:       asyncEmbedding,\n2786:       causalLinksResult,\n2787:       enrichmentStatus,\n2788:       enrichmentExecutionStatus: executionStatus,\n2789:       saveTimeReconsolidation: reconResult.saveTimeReconsolidation,\n2790:       filePath: routedFilePath,\n2791:       routeCategory: routing.routeAs ?? recordIdentity.routeAs ?? undefined,\n2792:       mergeMode: routing.mergeModeHint,\n2793:       targetDocPath: routedFilePath,\n2794:       targetAnchorId: recordIdentity.targetAnchorId,\n2795:     }), finalizeWarning);\n2796:   };\n2797: \n2798:   if (specFolderLockAlreadyHeld) {\n2799:     return runWithinSpecFolderLock();\n2800:   }\n2801: \n2802:   return withSpecFolderLock(prepared.parsed.specFolder, runWithinSpecFolderLock);\n2803: }\n2804: \n2805: /* --- 8. INDEX MEMORY FILE --- */\n2806: \n2807: type BaseIndexMemoryFileOptions = {\n2808:   force?: boolean;\n2809:   parsedOverride?: ReturnType<typeof memoryParser.parseMemoryFile> | null;\n2810:   asyncEmbedding?: boolean;\n2811:   plannerMode?: AtomicSaveParams['plannerMode'];\n2812:   scope?: MemoryScopeMatch;\n2813:   qualityGateMode?: 'enforce' | 'warn-only';\n2814:   routing?: RoutedSaveOptions;\n2815:   provenance?: WriteProvenanceContext;\n2816:   // Validated governance decision threaded from the bulk scan/ingest paths so\n2817:   // their indexed rows carry the same provenance/retention/scope metadata the\n2818:   // direct memory_save path applies post-insert. Omitted for ungoverned saves.\n2819:   governance?: GovernanceDecision;\n2820: };\n2821: \n2822: type IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n2823:   origin?: IndexingOrigin;\n2824:   fromScan?: never;\n2825: };\n2826: \n2827: type LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n2828:   fromScan?: boolean;\n2829:   origin?: never;\n2830: };\n2831: \n2832: /** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\n2833: async function indexMemoryFile(\n2834:   filePath: string,\n2835:   {\n2836:     force = false,\n2837:     parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n2838:     asyncEmbedding = false,\n2839:     plannerMode,\n2840:     scope = {} as MemoryScopeMatch,\n2841:     qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n2842:     routing,\n2843:     provenance,\n2844:     governance,\n2845:     ...originOptions\n2846:   }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n2847: ): Promise<IndexResult> {\n2848:   // Reuse parsed content when provided by caller to avoid a second parse.\n2849:   const indexingOrigin = resolveIndexingOrigin(originOptions);\n2850:   const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n2851:   const database = requireDb();\n2852:   const prepared = prepareParsedMemoryForIndexing(parsed, database);\n2853:   const validation = prepared.validation;\n2854:   if (!validation.valid) {\n2855:     throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n2856:   }\n2857:   if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n2858:     console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n2859:   }\n2860: \n2861:   // When a governance decision is threaded in (bulk scan/ingest), derive the\n2862:   // scope tuple from it so the row is created under the governed scope, matching\n2863:   // how the direct save path seeds saveScope from governanceDecision.normalized.\n2864:   const effectiveScope: MemoryScopeMatch = governance\n2865:     ? {\n2866:         tenantId: governance.normalized.tenantId ?? null,\n2867:         userId: governance.normalized.userId ?? null,\n2868:         agentId: governance.normalized.agentId ?? null,\n2869:         sessionId: governance.normalized.sessionId ?? null,\n2870:       }\n2871:     : scope;\n2872:   const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n2873:     ? {\n2874:         provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n2875:         provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n2876:         tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n2877:       }\n2878:     : undefined);\n2879: \n2880:   const result = await processPreparedMemory(prepared, filePath, {\n2881:     force,\n2882:     asyncEmbedding,\n2883:     plannerMode,\n2884:     origin: indexingOrigin,\n2885:     persistQualityLoopContent: true,\n2886:     refreshFromDiskAfterLock: parsedOverride !== null,\n2887:     scope: effectiveScope,\n2888:     qualityGateMode,\n2889:     routing,\n2890:     provenance: effectiveProvenance,\n2891:   });\n2892: \n2893:   // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n2894:   // direct memory_save path so governed bulk/scan/async ingests are not silently\n2895:   // downgraded to ungoverned rows. Only for freshly written rows.\n2896:   if (governance && typeof result.id === 'number' && result.id > 0\n2897:     && result.status !== 'unchanged' && result.status !== 'duplicate') {\n2898:     applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n2899:   }\n\n(Showing lines 2140-2899 of 4082. Use offset=2900 to continue.)\n</content>","metadata":{"preview":"\nfunction resolveIndexingOrigin(options: {\n  origin?: IndexingOrigin;\n  fromScan?: boolean;\n}): IndexingOrigin {\n  return options.origin ?? (options.fromScan ? 'scan' : 'direct');\n}\n\nasync function processPreparedMemory(\n  prepared: PreparedParsedMemory,\n  filePath: string,\n  options: {\n    force?: boolean;\n    asyncEmbedding?: boolean;\n    plannerMode?: AtomicSaveParams['plannerMode'];\n    origin?: IndexingOrigin;\n    fromScan?: boolean;\n    persistQualityLoopContent?: boolean;\n    refreshFromDiskAfterLock?: boolean;\n    specFolderLockAlreadyHeld?: boolean;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"\nfunction resolveIndexingOrigin(options: {\n  origin?: IndexingOrigin;\n  fromScan?: boolean;\n}): IndexingOrigin {\n  return options.origin ?? (options.fromScan ? 'scan' : 'direct');\n}\n\nasync function processPreparedMemory(\n  prepared: PreparedParsedMemory,\n  filePath: string,\n  options: {\n    force?: boolean;\n    asyncEmbedding?: boolean;\n    plannerMode?: AtomicSaveParams['plannerMode'];\n    origin?: IndexingOrigin;\n    fromScan?: boolean;\n    persistQualityLoopContent?: boolean;\n    refreshFromDiskAfterLock?: boolean;\n    specFolderLockAlreadyHeld?: boolean;\n    scope?: MemoryScopeMatch;\n    qualityGateMode?: 'enforce' | 'warn-only';\n    routing?: RoutedSaveOptions;\n    provenance?: WriteProvenanceContext;\n  } = {},\n): Promise<IndexResult> {\n  const {\n    force = false,\n    asyncEmbedding = false,\n    plannerMode: requestedPlannerMode,\n    origin,\n    fromScan = false,\n    persistQualityLoopContent = true,\n    refreshFromDiskAfterLock = false,\n    specFolderLockAlreadyHeld = false,\n    scope = {},\n    qualityGateMode = 'enforce',\n    routing = {},\n    provenance = {},\n  } = options;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const indexingOrigin = resolveIndexingOrigin({ origin, fromScan });\n\n  const evaluatePreparedMemory = (currentPrepared: PreparedParsedMemory): IndexResult | null => {\n    const {\n      parsed,\n      validation,\n      qualityLoopResult,\n      sufficiencyResult,\n      templateContract,\n      sourceClassification,\n    } = currentPrepared;\n    const templateContractBypassed = shouldBypassTemplateContract(\n      sourceClassification,\n      sufficiencyResult,\n      templateContract,\n      currentPrepared.specDocHealth,\n      parsed.documentType,\n    );\n\n    if (!qualityLoopResult.passed && qualityLoopResult.rejected) {\n      if (qualityGateMode === 'warn-only') {\n        console.warn(`[memory-save] V-rule warn-only (spec doc) for ${path.basename(filePath)}: ${qualityLoopResult.rejectionReason}`);\n      } else {\n        return {\n          status: 'rejected',\n          id: 0,\n          specFolder: parsed.specFolder,\n          title: parsed.title ?? '',\n          triggerPhrases: parsed.triggerPhrases,\n          contextType: parsed.contextType,\n          importanceTier: parsed.importanceTier,\n          qualityScore: parsed.qualityScore,\n          qualityFlags: parsed.qualityFlags,\n          warnings: validation.warnings,\n          rejectionReason: qualityLoopResult.rejectionReason,\n          message: qualityLoopResult.rejectionReason,\n        };\n      }\n    }\n\n    if (!sufficiencyResult.pass) {\n      if (isStructuralMetadataFile(filePath)) {\n        console.warn(`[memory-save] Sufficiency exempt for structural metadata file ${path.basename(filePath)}: ${sufficiencyResult.reasons.join('; ')}`);\n      } else if (qualityGateMode === 'warn-only') {\n        console.warn(`[memory-save] Sufficiency warn-only (spec doc) for ${path.basename(filePath)}: ${sufficiencyResult.reasons.join('; ')}`);\n      } else {\n        return buildInsufficiencyRejectionResult(parsed, validation, sufficiencyResult);\n      }\n    }\n\n    if (!templateContract.valid) {\n      if (isStructuralMetadataFile(filePath)) {\n        console.warn(\n          `[memory-save] Template contract exempt for structural metadata file ${path.basename(filePath)}: ${templateContract.violations.map((v: { message?: string; rule?: string }) => v.message || v.rule).join('; ')}`,\n        );\n      } else if (templateContractBypassed) {\n        console.warn(\n          `[memory-save] Template contract bypassed in ${MANUAL_FALLBACK_SOURCE_CLASSIFICATION} mode for ${path.basename(filePath)}: ${templateContract.violations.map((v: { message?: string; rule?: string }) => v.message || v.rule).join('; ')}`,\n        );\n      } else if (qualityGateMode === 'warn-only') {\n        console.warn(\n          `[memory-save] Template contract warn-only (spec doc) for ${path.basename(filePath)}: ${templateContract.violations.map((v: { message?: string; rule?: string }) => v.message || v.rule).join('; ')}`,\n        );\n      } else {\n        return buildTemplateContractRejectionResult(parsed, validation, templateContract);\n      }\n    }\n\n    return null;\n  };\n\n  if (!refreshFromDiskAfterLock) {\n    const earlyResult = evaluatePreparedMemory(prepared);\n    if (earlyResult) {\n      return earlyResult;\n    }\n  }\n\n  const runWithinSpecFolderLock = async (): Promise<IndexResult> => {\n    const database = requireDb();\n    const activePrepared = refreshFromDiskAfterLock\n      ? prepareParsedMemoryForIndexing(memoryParser.parseMemoryFile(filePath), database, {\n          qualityLoopMode: 'full-auto',\n        })\n      : prepared;\n    const lockedResult = evaluatePreparedMemory(activePrepared);\n    if (lockedResult) {\n      return lockedResult;\n    }\n    const {\n      parsed,\n      validation,\n      finalizedFileContent,\n    } = activePrepared;\n    const routedFilePath = routing.targetDocPath ?? filePath;\n    const writeProvenance: WriteProvenanceContext = {\n      tool: 'memory_save',\n      filePath: routedFilePath,\n      scope,\n      ...provenance,\n    };\n    const routedParsed = Object.keys(routing).length > 0\n      ? applyRoutedSaveHints(parsed, {\n          ...routing,\n          targetDocPath: routedFilePath,\n        })\n      : parsed;\n    const recordIdentity = resolveRoutedRecordIdentity(routedParsed, routedFilePath, {\n      ...routing,\n      targetDocPath: routedFilePath,\n    });\n    const canonicalFilePath = recordIdentity.canonicalFilePath;\n    const samePathDedupExclusion = {\n      canonicalFilePath,\n      filePath: routedFilePath,\n      ...(recordIdentity.targetAnchorId != null ? { targetAnchorId: recordIdentity.targetAnchorId } : {}),\n    };\n    const samePathExisting = findSamePathExistingMemory(\n      database,\n      routedParsed.specFolder,\n      canonicalFilePath,\n      routedFilePath,\n      scope,\n      recordIdentity,\n    );\n    const shouldChunkContent = shouldUseChunkedIndexing(routedParsed.content, plannerMode);\n    const shouldPersistFinalizedFile = persistQualityLoopContent && typeof finalizedFileContent === 'string';\n    let finalizeWarning: string | null = null;\n\n    // DEDUP: Check existing row by file path\n    const existingResult = checkExistingRow(\n      database,\n      routedParsed,\n      canonicalFilePath,\n      routedFilePath,\n      recordIdentity.targetAnchorId,\n      force,\n      validation.warnings,\n      scope,\n    );\n    if (existingResult) return existingResult;\n\n    // NOTE: Content-hash dedup (C5-1) moved inside BEGIN IMMEDIATE transaction\n    // to eliminate TOCTOU race between check and insert.\n\n    // EMBEDDING GENERATION (with persistent SQLite cache)\n    const embeddingResult = await generateOrCacheEmbedding(database, routedParsed, routedFilePath, asyncEmbedding);\n    const {\n      embedding,\n      status: embeddingStatus,\n      failureReason: embeddingFailureReason,\n      pendingCacheWrite,\n    } = embeddingResult;\n\n    // the rollout: Quality Gate (before PE gating, after embedding)\n    if (isSaveQualityGateEnabled() && isQualityGateEnabled()) {\n      try {\n        const qualityGateResult = runQualityGate({\n          title: routedParsed.title,\n          content: routedParsed.content,\n          specFolder: routedParsed.specFolder,\n          triggerPhrases: routedParsed.triggerPhrases,\n          contextType: routedParsed.contextType,\n          mode: 'legacy',\n          embedding: embedding,\n          findSimilar: embedding ? (emb, gateOptions) => {\n            return findSimilarMemories(emb as Float32Array, {\n              limit: gateOptions.limit,\n              specFolder: gateOptions.specFolder,\n              tenantId: scope.tenantId,\n              userId: scope.userId,\n              agentId: scope.agentId,\n              sessionId: scope.sessionId,\n            }).map(m => ({\n              id: m.id,\n              file_path: m.file_path,\n              similarity: m.similarity,\n            }));\n          } : null,\n        });\n\n        if (!qualityGateResult.pass && !qualityGateResult.warnOnly && qualityGateMode !== 'warn-only') {\n          console.error(`[memory-save] TM-04: Quality gate REJECTED save for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n          return {\n            status: 'rejected',\n            id: 0,\n            specFolder: routedParsed.specFolder,\n            title: routedParsed.title ?? '',\n            qualityScore: routedParsed.qualityScore,\n            qualityFlags: routedParsed.qualityFlags,\n            rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            qualityGate: {\n              pass: false,\n              reasons: qualityGateResult.reasons,\n              layers: qualityGateResult.layers,\n            },\n          };\n        }\n\n        if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n          console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n\n        if (qualityGateResult.wouldReject) {\n          console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n      } catch (qgErr: unknown) {\n        const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n        console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n        // Quality gate errors must not block saves\n      }\n    }\n\n    const duplicatePrecheck = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (duplicatePrecheck) {\n      await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n      return duplicatePrecheck;\n    }\n\n    persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n\n    // PE GATING\n    const peResult = evaluateAndApplyPeDecision(\n      database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope, writeProvenance,\n    );\n    if (peResult.earlyReturn) return peResult.earlyReturn;\n\n    let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n      earlyReturn: null,\n      warnings: [],\n      saveTimeReconsolidation: {\n        status: 'skipped',\n        persistedState: { kind: 'create' },\n      },\n    };\n\n    // Complete async reconsolidation planning before chunking or\n    // taking the SQLite writer lock, so chunked saves do not bypass the gate\n    // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n    reconResult = await runReconsolidationIfEnabled(\n      database,\n      routedParsed,\n      routedFilePath,\n      force,\n      embedding,\n      scope,\n      { plannerMode, provenance: writeProvenance },\n    );\n    if (reconResult.earlyReturn) return reconResult.earlyReturn;\n    if (reconResult.saveTimeReconsolidation.status === 'failed') {\n      return buildSaveTimeReconsolidationFailureResult({\n        parsed: routedParsed,\n        validation,\n        reconWarnings: reconResult.warnings,\n        failure: {\n          status: 'failed',\n          reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n          ...(reconResult.saveTimeReconsolidation.warnings\n            ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n            : {}),\n          ...(reconResult.saveTimeReconsolidation.persistedState\n            ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n            : {}),\n        },\n      });\n    }\n\n    if (shouldChunkContent) {\n      console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n      const chunkedInsertTracker = createChunkedInsertTracker();\n      const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n        force,\n        scope,\n        provenance: writeProvenance,\n        applyPostInsertMetadata: (db, memoryId, fields) => {\n          applyPostInsertMetadata(db, memoryId, fields);\n          trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n        },\n      });\n\n      if (\n        peResult.supersededId != null\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          const finalizeChunkedPeTx = database.transaction(() => {\n            if (chunkedResult.id > 0) {\n              recordCrossPathPeSupersedes(\n                database,\n                chunkedResult.id,\n                peResult.supersededId,\n                samePathExisting?.id ?? null,\n                peResult.decision.reason,\n              );\n            }\n            if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n              throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n            }\n          });\n          finalizeChunkedPeTx.immediate();\n        } catch (supersedeErr: unknown) {\n          const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n          const cleanupSuffix = cleanup.cleaned\n            ? ' Rolled back the newly created chunk tree.'\n            : cleanup.attempted && cleanup.error\n              ? ` Cleanup failed: ${cleanup.error}`\n              : '';\n          return {\n            ...chunkedResult,\n            status: 'error',\n            error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n            message: `Chunked indexing succeeded, but predecessor ${peResult.supersededId} could not be superseded.${cleanupSuffix}`,\n          };\n        }\n      }\n\n      if (\n        shouldPersistFinalizedFile\n        && finalizedFileContent\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n        } catch (finalizeErr: unknown) {\n          finalizeWarning = `Quality-loop file persistence failed after chunked indexing: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}`;\n          console.warn(`[memory-save] ${finalizeWarning}`);\n        }\n      }\n\n      if (peResult.decision.action !== 'CREATE') {\n        chunkedResult.pe_action = peResult.decision.action;\n        chunkedResult.pe_reason = peResult.decision.reason;\n      }\n      if (peResult.supersededId != null) {\n        chunkedResult.superseded_id = peResult.supersededId;\n      }\n      if (Array.isArray(reconResult.warnings) && reconResult.warnings.length > 0) {\n        const existingWarnings = Array.isArray(chunkedResult.warnings)\n          ? [...(chunkedResult.warnings as string[])]\n          : [];\n        chunkedResult.warnings = [...existingWarnings, ...reconResult.warnings];\n      }\n      if (reconResult.assistiveRecommendation) {\n        reconResult.assistiveRecommendation.advisory_stale = true;\n        chunkedResult.assistiveRecommendation = reconResult.assistiveRecommendation;\n      }\n      chunkedResult.saveTimeReconsolidation = reconResult.saveTimeReconsolidation;\n\n      return appendResultWarning(chunkedResult, finalizeWarning);\n    }\n\n    // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n    // atomicity. Uses database.transaction() so inner transaction() calls in\n    // createMemoryRecord / index_memory correctly nest via SAVEPOINTs instead\n    // of failing with \"cannot start a transaction within a transaction\".\n    // withSpecFolderLock handles in-process serialization; this transaction\n    // provides defense-in-depth against multi-process races.\n    let existing: { id: number; content_hash: string } | undefined;\n\n    // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n    // safe outside the transaction and this avoids an early-return inside the\n    // transaction callback (which would COMMIT an empty tx unnecessarily).\n    const dupResult = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (dupResult) {\n      await repairReplayEnrichmentIfNeeded(database, dupResult.id, routedParsed);\n      return dupResult;\n    }\n\n    const requestedScope = getRequestedScope(scope);\n    const writeTransaction = database.transaction((): number => {\n      if (indexingOrigin !== 'scan' && embedding) {\n        const complementRecheck = findScopeFilteredCandidates({\n          database,\n          embedding,\n          parsed: routedParsed,\n          requestedScope,\n          limit: 1,\n          minSimilarity: 50,\n          overfetchMultiplier: 3,\n        });\n        const topCandidate = complementRecheck.candidates[0];\n        if (topCandidate) {\n          const transactionalAction = determineAction(topCandidate.similarity);\n          if (transactionalAction !== 'complement') {\n            throw new SaveTimeReconsolidationAbort({\n              status: 'failed',\n              reason: 'candidate_changed',\n              warnings: [\n                `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n              ],\n              persistedState: {\n                kind: transactionalAction,\n                candidateMemoryIds: [topCandidate.id],\n              },\n            });\n          }\n        }\n      }\n\n      // CREATE NEW MEMORY\n      existing = findSamePathExistingMemory(\n        database,\n        routedParsed.specFolder,\n        canonicalFilePath,\n        routedFilePath,\n        scope,\n        recordIdentity,\n      ) as { id: number; content_hash: string } | undefined;\n\n      // A same-path re-index whose file content changed appends a new version\n      // row; the prior row for this logical key is retired below so re-indexing\n      // replaces in place rather than leaving a deprecated duplicate. Scoped to\n      // this branch only — PE-gate / reconsolidation lineage (createMemoryRecord)\n      // is intentionally preserved.\n      const samePathSupersededPredecessorId =\n        existing && existing.content_hash !== routedParsed.contentHash ? existing.id : null;\n\n      // Retire the same-path predecessor before inserting the new version so the\n      // active-row uniqueness guard holds at insert time. Deprecating (not deleting)\n      // keeps the predecessor row, its lineage chain, and its history intact while\n      // removing it from the active-row guard; the new version supersedes it in place.\n      const reindexTierCarry = samePathSupersededPredecessorId != null\n        ? retirePredecessorForActiveReindex(database, samePathSupersededPredecessorId)\n        : null;\n\n      const memoryId = samePathSupersededPredecessorId != null\n        ? createAppendOnlyMemoryRecord({\n            database,\n            parsed: routedParsed,\n            filePath: routedFilePath,\n            embedding,\n            embeddingFailureReason,\n            predecessorMemoryId: samePathSupersededPredecessorId,\n            anchorId: recordIdentity.targetAnchorId,\n            tenantId: scope.tenantId,\n            userId: scope.userId,\n            agentId: scope.agentId,\n            sessionId: scope.sessionId,\n            actor: 'mcp:memory_save',\n          })\n        : createMemoryRecord(\n            database,\n            routedParsed,\n            routedFilePath,\n            embedding,\n            embeddingFailureReason,\n            peResult.decision,\n            scope,\n            recordIdentity,\n            writeProvenance,\n          );\n\n      if (samePathSupersededPredecessorId != null) {\n        applyWriteProvenance(database, memoryId, writeProvenance);\n      }\n\n      // A human's tier decision on the retired predecessor carries forward to the\n      // reindexed successor. Re-stamp after provenance so the manual tier and its\n      // human source-kind survive the reindex instead of resetting to the default.\n      if (reindexTierCarry != null) {\n        database\n          .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n          .run(reindexTierCarry.importanceTier, memoryId);\n        persistSourceKind(database, memoryId, reindexTierCarry.sourceKind as SourceKind);\n      }\n\n      // F1.01 fix: Mark superseded memory AFTER new record creation, inside\n      // the same transaction, so a creation failure rolls back both operations.\n      if (peResult.supersededId != null) {\n        const supersededOk = markMemorySuperseded(peResult.supersededId);\n        // C5-3: Supersede failure should abort the transaction\n        if (!supersededOk) {\n          throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n        }\n      }\n\n      recordLineageVersion(database, {\n        memoryId,\n        predecessorMemoryId: samePathSupersededPredecessorId,\n        actor: 'mcp:memory_save',\n        transitionEvent: samePathSupersededPredecessorId != null ? 'SUPERSEDE' : 'CREATE',\n      });\n      markEnrichmentPending(database, memoryId, POST_INSERT_ENRICHMENT_VERSION);\n\n      return memoryId;\n    });\n\n    let id: number;\n    try {\n      id = writeTransaction.immediate();\n    } catch (error: unknown) {\n      if (error instanceof SaveTimeReconsolidationAbort) {\n        return buildSaveTimeReconsolidationFailureResult({\n          parsed: routedParsed,\n          validation,\n          reconWarnings: reconResult.warnings,\n          failure: error.result,\n          message: `Save aborted before commit: ${error.result.reason}`,\n        });\n      }\n      throw error;\n    }\n\n    if (shouldPersistFinalizedFile && finalizedFileContent) {\n      try {\n        await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n      } catch (finalizeErr: unknown) {\n        finalizeWarning = `[file-persistence-failed] Quality-loop file persistence failed after DB commit: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}. DB row committed — manual file recovery may be needed.`;\n        console.warn(`[memory-save] ${finalizeWarning}`);\n      }\n    }\n\n    // Data integrity: clean stale auto-entities before re-extraction on update\n    // When a memory is superseded or replaced in-place, purge the predecessor's\n    // auto-entity rows so the entity catalog reflects only active content.\n    if (existing && existing.id !== id) {\n      try {\n        refreshAutoEntitiesForMemory(database, existing.id, []);\n        console.error(`[memory-save] Cleaned stale auto-entities for superseded memory #${existing.id}`);\n      } catch (entityCleanupErr: unknown) {\n        // Entity cleanup failure must not block save — log and continue\n        console.warn(`[memory-save] Auto-entity cleanup for #${existing.id} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n      }\n    }\n    if (peResult.supersededId != null && peResult.supersededId !== existing?.id) {\n      try {\n        refreshAutoEntitiesForMemory(database, peResult.supersededId, []);\n        console.error(`[memory-save] Cleaned stale auto-entities for PE-superseded memory #${peResult.supersededId}`);\n      } catch (entityCleanupErr: unknown) {\n        console.warn(`[memory-save] Auto-entity cleanup for PE #${peResult.supersededId} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n      }\n    }\n\n    if (embedding) {\n      try {\n        recordNearDuplicateCheck({\n          database,\n          memoryId: id,\n          specFolder: routedParsed.specFolder,\n          contentHash: routedParsed.contentHash,\n          embedding,\n          scope,\n        });\n      } catch (error: unknown) {\n        const message = error instanceof Error ? error.message : String(error);\n        console.warn(`[memory-save] Near-duplicate advisory skipped: ${message}`);\n      }\n    }\n\n    // POST-INSERT ENRICHMENT: causal links, entities, summaries, entity linking.\n    // When enrichment is enabled and async (default), run the bundle in the background so the\n    // save returns immediately. The row was marked enrichment-pending inside the commit\n    // transaction (markEnrichmentPending), so a crash before the background run completes is\n    // recovered by the pending-marker replay/backfill path. SPECKIT_POST_INSERT_ENRICHMENT_SYNC\n    // forces synchronous execution when a caller needs the graph fresh in the same response.\n    let postInsertEnrichmentResult: PostInsertEnrichmentResult;\n    if (shouldRunPostInsertEnrichment(plannerMode) && isPostInsertEnrichmentAsync()) {\n      scheduleBackgroundEnrichment(id, routedParsed);\n      postInsertEnrichmentResult = buildDeferredEnrichmentResult('async-background');\n    } else {\n      postInsertEnrichmentResult = await runPostInsertEnrichmentIfEnabled(\n        database,\n        id,\n        routedParsed,\n        { plannerMode },\n      );\n      recordEnrichmentResult(database, id, postInsertEnrichmentResult);\n      emitPostInsertEnrichmentSubscribers(id, 'post-insert-enrichment');\n    }\n    const { causalLinksResult, enrichmentStatus, executionStatus } = postInsertEnrichmentResult;\n\n    if (reconResult.assistiveRecommendation) {\n      reconResult.assistiveRecommendation.advisory_stale = true;\n      if (reconResult.saveTimeReconsolidation.persistedState) {\n        reconResult.saveTimeReconsolidation.persistedState.advisory_stale = true;\n      }\n    }\n\n    // BUILD RESULT\n    return appendResultWarning(buildIndexResult({\n      database,\n      existing,\n      embeddingStatus,\n      id,\n      parsed: routedParsed,\n      validation,\n      reconWarnings: reconResult.warnings,\n      peDecision: peResult.decision,\n      embeddingFailureReason,\n      asyncEmbedding,\n      causalLinksResult,\n      enrichmentStatus,\n      enrichmentExecutionStatus: executionStatus,\n      saveTimeReconsolidation: reconResult.saveTimeReconsolidation,\n      filePath: routedFilePath,\n      routeCategory: routing.routeAs ?? recordIdentity.routeAs ?? undefined,\n      mergeMode: routing.mergeModeHint,\n      targetDocPath: routedFilePath,\n      targetAnchorId: recordIdentity.targetAnchorId,\n    }), finalizeWarning);\n  };\n\n  if (specFolderLockAlreadyHeld) {\n    return runWithinSpecFolderLock();\n  }\n\n  return withSpecFolderLock(prepared.parsed.specFolder, runWithinSpecFolderLock);\n}\n\n/* --- 8. INDEX MEMORY FILE --- */\n\ntype BaseIndexMemoryFileOptions = {\n  force?: boolean;\n  parsedOverride?: ReturnType<typeof memoryParser.parseMemoryFile> | null;\n  asyncEmbedding?: boolean;\n  plannerMode?: AtomicSaveParams['plannerMode'];\n  scope?: MemoryScopeMatch;\n  qualityGateMode?: 'enforce' | 'warn-only';\n  routing?: RoutedSaveOptions;\n  provenance?: WriteProvenanceContext;\n  // Validated governance decision threaded from the bulk scan/ingest paths so\n  // their indexed rows carry the same provenance/retention/scope metadata the\n  // direct memory_save path applies post-insert. Omitted for ungoverned saves.\n  governance?: GovernanceDecision;\n};\n\ntype IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  origin?: IndexingOrigin;\n  fromScan?: never;\n};\n\ntype LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  fromScan?: boolean;\n  origin?: never;\n};\n\n/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    provenance,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);\n  const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n  const database = requireDb();\n  const prepared = prepareParsedMemoryForIndexing(parsed, database);\n  const validation = prepared.validation;\n  if (!validation.valid) {\n    throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n  }\n  if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n    console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n  }\n\n  // When a governance decision is threaded in (bulk scan/ingest), derive the\n  // scope tuple from it so the row is created under the governed scope, matching\n  // how the direct save path seeds saveScope from governanceDecision.normalized.\n  const effectiveScope: MemoryScopeMatch = governance\n    ? {\n        tenantId: governance.normalized.tenantId ?? null,\n        userId: governance.normalized.userId ?? null,\n        agentId: governance.normalized.agentId ?? null,\n        sessionId: governance.normalized.sessionId ?? null,\n      }\n    : scope;\n  const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n    ? {\n        provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n        provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n        tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n      }\n    : undefined);\n\n  const result = await processPreparedMemory(prepared, filePath, {\n    force,\n    asyncEmbedding,\n    plannerMode,\n    origin: indexingOrigin,\n    persistQualityLoopContent: true,\n    refreshFromDiskAfterLock: parsedOverride !== null,\n    scope: effectiveScope,\n    qualityGateMode,\n    routing,\n    provenance: effectiveProvenance,\n  });\n\n  // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n  // direct memory_save path so governed bulk/scan/async ingests are not silently\n  // downgraded to ungoverned rows. Only for freshly written rows.\n  if (governance && typeof result.id === 'number' && result.id > 0\n    && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n  }","lineStart":2140,"lineEnd":2899,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781762663865,"end":1781762663883}},"metadata":{"openai":{"itemId":"fc_0102f34a51111b95016a338a676e0881918225961f9f145ed1"}},"id":"prt_ed954a424001NjqR2BY83Pcv2U","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95487cb001Ri88MpG72wXp55"}}
{"type":"step_finish","timestamp":1781762664181,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"id":"prt_ed954a6f3001ciiFWpBAjTiOtC","reason":"tool-calls","snapshot":"34c3e0d1be3e90a8849c9ee51d3e388be5897316","messageID":"msg_ed95487cb001Ri88MpG72wXp55","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","type":"step-finish","tokens":{"total":194912,"input":21184,"output":62,"reasoning":98,"cache":{"write":0,"read":173568}},"cost":0}}
{"type":"step_start","timestamp":1781762666308,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"id":"prt_ed954af400012ay2NQrZOlV9Ud","messageID":"msg_ed954a837001ZSjuFNxCLCd2ax","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","snapshot":"34c3e0d1be3e90a8849c9ee51d3e388be5897316","type":"step-start"}}
{"type":"text","timestamp":1781762676209,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"id":"prt_ed954c054001W2fqWlCGDwFXka","messageID":"msg_ed954a837001ZSjuFNxCLCd2ax","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","type":"text","text":"The atomic-save mtime mismatch is likely at most reindex churn, not a blocker, because content is indexed from prepared memory and scans can correct mtimes. I’m checking CRUD and causal lifecycle transactions for stronger integrity issues.","time":{"start":1781762670676,"end":1781762676206},"metadata":{"openai":{"itemId":"msg_0eee0a4785417890016a338a6e9f448191a5366e6c6c899afe","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781762676277,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_Kci2VwgTOxnRrFp4VHJv9wzw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n261:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n262:           mutationType: 'delete',\n263:           reason: 'memory_delete: bulk delete by spec folder',\n264:           priorHash: snapshot?.content_hash ?? null,\n265:           newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n266:           linkedMemoryIds: [deletedId],\n267:           decisionMeta: {\n268:             tool: 'memory_delete',\n269:             bulk: true,\n270:             specFolder,\n271:             checkpoint: checkpointName,\n272:             memoryId: deletedId,\n273:             filePath: snapshot?.file_path ?? null,\n274:           },\n275:           actor: 'mcp:memory_delete',\n276:         });\n277:         if (!ledgerRecorded) {\n278:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n279:         }\n280:       }\n281:     });\n282:     bulkDeleteTx();\n283:   }\n284: \n285:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n286:   if (deletedCount > 0) {\n287:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n288:     try {\n289:       postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n290:     } catch (hookError: unknown) {\n291:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n292:       postMutationHooks = {\n293:         latencyMs: 0, triggerCacheCleared: false,\n294:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n295:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n296:         errors: [msg],\n297:       };\n298:     }\n299:     postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n300:   }\n301: \n302:   const summary = deletedCount > 0\n303:     ? `Deleted ${deletedCount} memory(s)`\n304:     : 'No spec-doc records found to delete';\n305: \n306:   const hints: string[] = [];\n307:   if (checkpointName) {\n308:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n309:   }\n310:   if (deletedCount === 0) {\n311:     hints.push('Use memory_list() to find existing memories');\n312:   }\n313:   if (postMutationFeedback) {\n314:     hints.push(...postMutationFeedback.hints);\n315:   }\n316:   if (mutationLedgerWarning) {\n317:     hints.push(mutationLedgerWarning);\n318:   }\n319: \n320:   const data: Record<string, unknown> = { deleted: deletedCount };\n321:   if (checkpointName) {\n322:     data.checkpoint = checkpointName;\n323:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n324:   }\n325:   if (postMutationFeedback) {\n326:     data.postMutationHooks = postMutationFeedback.data;\n327:   }\n328:   if (mutationLedgerWarning) {\n329:     data.warning = mutationLedgerWarning;\n330:   }\n331: \n332:   return createMCPSuccessResponse({\n333:     tool: 'memory_delete',\n334:     summary,\n335:     data,\n336:     hints,\n337:   });\n338: }\n339: \n340: /* ───────────────────────────────────────────────────────────────\n341:    EXPORTS\n342: ──────────────────────────────────────────────────────────────── */\n343: \n344: export { handleMemoryDelete };\n\n(End of file - total 344 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: bulk delete by spec folder',\n          priorHash: snapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n          linkedMemoryIds: [deletedId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: true,\n            specFolder,\n            checkpoint: checkpointName,\n            memoryId: deletedId,\n            filePath: snapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    });\n    bulkDeleteTx();\n  }\n\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n  }\n\n  const summary = deletedCount > 0\n    ? `Deleted ${deletedCount} memory(s)`\n    : 'No spec-doc records found to delete';\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  }\n  if (deletedCount === 0) {\n    hints.push('Use memory_list() to find existing memories');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n\n  const data: Record<string, unknown> = { deleted: deletedCount };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (mutationLedgerWarning) {\n    data.warning = mutationLedgerWarning;\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryDelete };","lineStart":1,"lineEnd":344,"totalLines":344,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781762676259,"end":1781762676268}},"metadata":{"openai":{"itemId":"fc_0eee0a4785417890016a338a74290881919e93af78e7a72038"}},"id":"prt_ed954d5f0001EFVRITP652hyLp","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed954a837001ZSjuFNxCLCd2ax"}}
{"type":"tool_use","timestamp":1781762676292,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_VlPIMf5Ksm8KqqXXVt82nYH9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Bulk Delete\n3: // ────────────────────────────────────────────────────────────────\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* ───────────────────────────────────────────────────────────────\n29:    1. TYPES\n30: ──────────────────────────────────────────────────────────────── */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* ───────────────────────────────────────────────────────────────\n74:     2. HANDLER\n75: ──────────────────────────────────────────────────────────────── */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n261:         deletedCount++;\n262:         deletedIds.push(memory.id);\n263: \n264:         // Clean up causal edges\n265:         // Propagate edge-cleanup errors to fail the transaction.\n266:         // Previously errors were caught and logged, leaving orphan causal edges\n267:         // When memory rows were successfully deleted but edge cleanup failed.\n268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n269:           reason: 'memory row mutation cleanup',\n270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n272:         });\n273:       }\n274:     }\n275:   });\n276: \n277:   bulkDeleteTx();\n278: \n279:   // Record in mutation ledger (single entry for bulk operation)\n280:   const ledgerRecorded = appendMutationLedgerSafe(database, {\n281:     mutationType: 'delete',\n282:     reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n283:     priorHash: null,\n284:     newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n285:     linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n286:     decisionMeta: {\n287:       tool: 'memory_bulk_delete',\n288:       tier,\n289:       specFolder: specFolder || null,\n290:       olderThanDays: olderThanDays || null,\n291:       totalDeleted: deletedCount,\n292:       checkpoint: checkpointName,\n293:       skipCheckpoint,\n294:     },\n295:     actor: 'mcp:memory_bulk_delete',\n296:   });\n297: \n298:   // Invalidate caches\n299:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n300:   if (deletedCount > 0) {\n301:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n302:     try {\n303:       postMutationHooks = runPostMutationHooks('bulk-delete', {\n304:         specFolder,\n305:         tier,\n306:         deletedCount,\n307:         statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n308:           target: 'memory_index',\n309:           key: String(id),\n310:           sourceOperation: 'bulk-delete',\n311:           metadata: { tier, specFolder: specFolder ?? null },\n312:         })),\n313:       });\n314:     } catch (hookError: unknown) {\n315:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n316:       postMutationHooks = {\n317:         latencyMs: 0, triggerCacheCleared: false,\n318:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n319:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n320:         errors: [msg],\n321:       };\n322:     }\n323:     postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n324:   }\n325: \n326:   const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n327: \n328:   const hints: string[] = [];\n329:   if (checkpointName) {\n330:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n331:   } else if (skipCheckpoint) {\n332:     hints.push('Checkpoint skipped: restore is not available for this operation');\n333:   }\n334:   if (postMutationFeedback) {\n335:     hints.push(...postMutationFeedback.hints);\n336:   }\n337:   if (!ledgerRecorded) {\n338:     hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n339:   }\n340:   hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n341: \n342:   const data: Record<string, unknown> = {\n343:     deleted: deletedCount,\n344:     tier,\n345:     specFolder: specFolder || null,\n346:     olderThanDays: olderThanDays || null,\n347:     skipCheckpoint,\n348:   };\n349:   if (checkpointName) {\n350:     data.checkpoint = checkpointName;\n351:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n352:   }\n353:   if (postMutationFeedback) {\n354:     data.postMutationHooks = postMutationFeedback.data;\n355:   }\n356:   if (!ledgerRecorded) {\n357:     data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n358:   }\n359: \n360:   return createMCPSuccessResponse({\n361:     tool: 'memory_bulk_delete',\n362:     summary,\n363:     data,\n364:     hints,\n365:   });\n366: }\n367: \n368: /* ───────────────────────────────────────────────────────────────\n369:    3. EXPORTS\n370: ──────────────────────────────────────────────────────────────── */\n371: \n372: export { handleMemoryBulkDelete };\n\n(End of file - total 372 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n    2. HANDLER\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }\n        deletedCount++;\n        deletedIds.push(memory.id);\n\n        // Clean up causal edges\n        // Propagate edge-cleanup errors to fail the transaction.\n        // Previously errors were caught and logged, leaving orphan causal edges\n        // When memory rows were successfully deleted but edge cleanup failed.\n        causalEdges.deleteEdgesForMemory(String(memory.id), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-bulk-delete.handleMemoryBulkDelete',\n          restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n        });\n      }\n    }\n  });\n\n  bulkDeleteTx();\n\n  // Record in mutation ledger (single entry for bulk operation)\n  const ledgerRecorded = appendMutationLedgerSafe(database, {\n    mutationType: 'delete',\n    reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n    priorHash: null,\n    newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n    linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n    decisionMeta: {\n      tool: 'memory_bulk_delete',\n      tier,\n      specFolder: specFolder || null,\n      olderThanDays: olderThanDays || null,\n      totalDeleted: deletedCount,\n      checkpoint: checkpointName,\n      skipCheckpoint,\n    },\n    actor: 'mcp:memory_bulk_delete',\n  });\n\n  // Invalidate caches\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('bulk-delete', {\n        specFolder,\n        tier,\n        deletedCount,\n        statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n          target: 'memory_index',\n          key: String(id),\n          sourceOperation: 'bulk-delete',\n          metadata: { tier, specFolder: specFolder ?? null },\n        })),\n      });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n  }\n\n  const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  } else if (skipCheckpoint) {\n    hints.push('Checkpoint skipped: restore is not available for this operation');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (!ledgerRecorded) {\n    hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n  }\n  hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n\n  const data: Record<string, unknown> = {\n    deleted: deletedCount,\n    tier,\n    specFolder: specFolder || null,\n    olderThanDays: olderThanDays || null,\n    skipCheckpoint,\n  };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (!ledgerRecorded) {\n    data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_bulk_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryBulkDelete };","lineStart":1,"lineEnd":372,"totalLines":372,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781762676287,"end":1781762676291}},"metadata":{"openai":{"itemId":"fc_0eee0a4785417890016a338a7429208191848863f41b012ee8"}},"id":"prt_ed954d63d001SryqrUdDxqeg49","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed954a837001ZSjuFNxCLCd2ax"}}
{"type":"tool_use","timestamp":1781762676294,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_uqnwWAmR8VgIYAQyJUVHgu6A","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Update Handler\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { randomUUID } from 'node:crypto';\n10: import { checkDatabaseUpdated } from '../core/index.js';\n11: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n12: import * as vectorIndex from '../lib/search/vector-index.js';\n13: import type { UpdateMemoryParams } from '../lib/search/vector-index.js';\n14: import * as embeddings from '../lib/providers/embeddings.js';\n15: import * as bm25Index from '../lib/search/bm25-index.js';\n16: import { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\n17: import { MemoryError, ErrorCodes } from '../lib/errors.js';\n18: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n19: import { runInTransaction } from '../lib/storage/transaction-manager.js';\n20: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n21: import {\n22:   buildGovernanceLogicalKey,\n23:   recordTierDowngradeAudit,\n24: } from '../lib/governance/scope-governance.js';\n25: import { isConstitutionalPath } from '../lib/utils/index-scope.js';\n26: import { scrubSecrets, SecretScrubberError } from '../lib/parsing/secret-scrubber.js';\n27: import { toErrorMessage } from '../utils/index.js';\n28: import {\n29:   deleteIdempotencyReceiptByKey,\n30:   extractMemoryIdFromResponse,\n31:   isMemoryIdempotencyEnabled,\n32:   lookupIdempotencyReceipt,\n33:   lookupIdempotencyReceiptByKey,\n34:   markResponseWithReceiptStoreConflict,\n35:   storeIdempotencyReceipt,\n36:   type IdempotencyReceiptKey,\n37: } from '../lib/storage/idempotency-receipts.js';\n38: \n39: import { recordHistory } from '../lib/storage/history.js';\n40: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n41: import { runPostMutationHooks } from './mutation-hooks.js';\n42: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n43: import {\n44:   deriveSourceKindFromContext,\n45:   normalizeSourceKind,\n46:   persistProvenanceMetadata,\n47:   persistSourceKind,\n48:   type SourceKind,\n49: } from '../lib/storage/write-provenance.js';\n50: \n51: import type { MCPResponse } from './types.js';\n52: import type { UpdateArgs } from './memory-crud-types.js';\n53: \n54: // Feature catalog: Memory metadata update (memory_update)\n55: // Feature catalog: Validation feedback (memory_validate)\n56: // Feature catalog: Transaction wrappers on mutation handlers\n57: // Feature catalog: Per-memory history log\n58: \n59: \n60: /* ───────────────────────────────────────────────────────────────\n61:    CORE LOGIC\n62: ──────────────────────────────────────────────────────────────── */\n63: \n64: const PROTECTED_AUTOMATED_UPDATE_FIELDS = new Set(['title', 'triggerPhrases', 'importanceTier']);\n65: const SKIPPED_MANUAL_PROTECTION_HINT = 'skipped to protect manual data';\n66: \n67: interface ProvenanceGuardResult {\n68:   updateParams: UpdateMemoryParams;\n69:   requestedFields: string[];\n70:   persistedFields: string[];\n71:   skippedFields: string[];\n72:   sourceKind: SourceKind;\n73:   storedSourceKind: SourceKind;\n74:   hint: string | null;\n75: }\n76: \n77: function getInternalProvenanceContext(args: UpdateArgs): Record<string, unknown> {\n78:   const rawArgs = args as unknown as Record<string, unknown>;\n79:   const context = rawArgs.__provenanceContext;\n80:   return context && typeof context === 'object' && !Array.isArray(context)\n81:     ? context as Record<string, unknown>\n82:     : {};\n83: }\n84: \n85: function isProtectedExistingRow(existing: Record<string, unknown>): boolean {\n86:   const existingSourceKind = normalizeSourceKind(existing.source_kind);\n87:   const importanceTier = typeof existing.importance_tier === 'string' ? existing.importance_tier : null;\n88:   const isPinned = existing.is_pinned === true || existing.is_pinned === 1;\n89:   const pathCandidate = [existing.canonical_file_path, existing.file_path]\n90:     .find((value) => typeof value === 'string' && value.length > 0);\n91:   const rowPath = typeof pathCandidate === 'string' ? pathCandidate : null;\n92:   return existingSourceKind === null\n93:     || existingSourceKind === 'human'\n94:     || importanceTier === 'constitutional'\n95:     || importanceTier === 'critical'\n96:     || isPinned\n97:     || (rowPath !== null && isConstitutionalPath(rowPath));\n98: }\n99: \n100: function buildGuardedUpdateParams(\n101:   args: UpdateArgs,\n102:   existing: Record<string, unknown>,\n103: ): ProvenanceGuardResult {\n104:   const internalContext = getInternalProvenanceContext(args);\n105:   const sourceKind = deriveSourceKindFromContext({\n106:     provenanceSource: internalContext.provenanceSource ?? internalContext.provenance_source,\n107:     provenanceActor: internalContext.provenanceActor ?? internalContext.provenance_actor,\n108:     tool: internalContext.tool,\n109:   });\n110:   const existingSourceKind = normalizeSourceKind(existing.source_kind);\n111:   const automated = sourceKind !== 'human';\n112:   const protectExisting = automated && isProtectedExistingRow(existing);\n113:   const updateParams: UpdateMemoryParams = { id: args.id };\n114:   const requestedFields: string[] = [];\n115:   const persistedFields: string[] = [];\n116:   const skippedFields: string[] = [];\n117: \n118:   const maybeAssign = <K extends keyof UpdateMemoryParams>(field: K, value: UpdateMemoryParams[K]): void => {\n119:     if (value === undefined) {\n120:       return;\n121:     }\n122:     requestedFields.push(field);\n123:     if (protectExisting && PROTECTED_AUTOMATED_UPDATE_FIELDS.has(field)) {\n124:       skippedFields.push(field);\n125:       return;\n126:     }\n127:     updateParams[field] = value;\n128:     persistedFields.push(field);\n129:   };\n130: \n131:   maybeAssign('title', args.title);\n132:   maybeAssign('triggerPhrases', args.triggerPhrases);\n133:   maybeAssign('importanceWeight', args.importanceWeight);\n134:   maybeAssign('importanceTier', args.importanceTier);\n135: \n136:   const storedSourceKind = sourceKind === 'human'\n137:     ? 'human'\n138:     : (protectExisting ? (existingSourceKind ?? 'human') : sourceKind);\n139: \n140:   return {\n141:     updateParams,\n142:     requestedFields,\n143:     persistedFields,\n144:     skippedFields,\n145:     sourceKind,\n146:     storedSourceKind,\n147:     hint: skippedFields.length > 0 ? SKIPPED_MANUAL_PROTECTION_HINT : null,\n148:   };\n149: }\n150: \n151: /** Handle memory_update tool -- updates metadata fields and optionally regenerates embeddings. */\n152: async function handleMemoryUpdate(args: UpdateArgs): Promise<MCPResponse> {\n153:   await ensureMemoryRuntimeInitialized('handler:memory_update');\n154:   // Generate requestId for incident correlation in error responses\n155:   const requestId = randomUUID();\n156:   await checkDatabaseUpdated();\n157: \n158:   const {\n159:     id,\n160:     title: rawTitle,\n161:     triggerPhrases: rawTriggerPhrases,\n162:     importanceWeight,\n163:     importanceTier,\n164:     allowPartialUpdate = false,\n165:   } = args;\n166: \n167:   if (typeof id !== 'number') {\n168:     throw new MemoryError(ErrorCodes.MISSING_REQUIRED_PARAM, 'id is required', { param: 'id' });\n169:   }\n170: \n171:   // Title and trigger phrases are persisted/indexed fields written outside\n172:   // the parse path, so they get the same pre-index secret redaction. A\n173:   // scrubber failure refuses this write (fail-closed) rather than persisting\n174:   // potentially unscrubbed text.\n175:   let title = rawTitle;\n176:   let triggerPhrases = rawTriggerPhrases;\n177:   try {\n178:     if (typeof title === 'string') {\n179:       title = scrubSecrets(title);\n180:     }\n181:     if (Array.isArray(triggerPhrases)) {\n182:       triggerPhrases = triggerPhrases.map((phrase) => (\n183:         typeof phrase === 'string' ? scrubSecrets(phrase) : phrase\n184:       ));\n185:     }\n186:   } catch (error: unknown) {\n187:     if (error instanceof SecretScrubberError) {\n188:       throw new MemoryError(\n189:         ErrorCodes.INVALID_PARAMETER,\n190:         `Update refused: ${error.message}`,\n191:         { param: 'title/triggerPhrases', memoryId: id },\n192:       );\n193:     }\n194:     throw error;\n195:   }\n196: \n197:   if (importanceWeight !== undefined && (typeof importanceWeight !== 'number' || importanceWeight < 0 || importanceWeight > 1)) {\n198:     throw new MemoryError(\n199:       ErrorCodes.INVALID_PARAMETER,\n200:       'importanceWeight must be a number between 0 and 1',\n201:       { param: 'importanceWeight', value: importanceWeight }\n202:     );\n203:   }\n204: \n205:   if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n206:     throw new MemoryError(\n207:       ErrorCodes.INVALID_PARAMETER,\n208:       `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n209:       { param: 'importanceTier', value: importanceTier }\n210:     );\n211:   }\n212: \n213:   const existing = vectorIndex.getMemory(id);\n214:   if (!existing) {\n215:     throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n216:   }\n217: \n218:   const database = vectorIndex.getDb();\n219:   const priorSnapshot = getMemoryHashSnapshot(database, id);\n220: \n221:   const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n222:   const updateParams = guard.updateParams;\n223:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n224: \n225:   if (database && isMemoryIdempotencyEnabled()) {\n226:     try {\n227:       const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n228:       const logicalMutation = {\n229:         id,\n230:         title: updateParams.title ?? null,\n231:         triggerPhrases: updateParams.triggerPhrases ?? null,\n232:         importanceWeight: updateParams.importanceWeight ?? null,\n233:         importanceTier: updateParams.importanceTier ?? null,\n234:         contentHash,\n235:       };\n236:       const lookup = lookupIdempotencyReceipt(database, {\n237:         operation: 'memory_update',\n238:         contentHash,\n239:         requestFingerprint: {\n240:           id,\n241:           contentHash,\n242:           logicalMutation,\n243:         },\n244:         // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n245:         // payloadHash always equals requestFingerprintHash and the receiptKey is\n246:         // derived from it. Consequence: distinct logical updates always produce\n247:         // distinct keys, so the same-key/different-payload 'conflict' status can\n248:         // never fire from this caller; the conflict branch below is fail-safe\n249:         // defense-in-depth, not active protection. To make conflicts detectable\n250:         // the payload would have to carry MORE than the key material (e.g.\n251:         // execution-mode flags like allowPartialUpdate); it deliberately does\n252:         // not, so a benign flag flip cannot become a false hard conflict.\n253:         payload: {\n254:           id,\n255:           contentHash,\n256:           logicalMutation,\n257:         },\n258:       });\n259:       idempotencyKey = lookup.key;\n260:       if (lookup.status === 'replay') {\n261:         // A receipt is a replay cache, not proof the cached response still\n262:         // describes the live row. Re-read this id's current content_hash and\n263:         // honor the replay ONLY when it still matches the receipt's content_hash\n264:         // AND the cached response still reports this same id; an A->B->A content\n265:         // revert leaves the receipt for A intact while the row moved on, and a\n266:         // delete-then-recreate can leave the cached response naming a stale id,\n267:         // so replaying it would diverge from the row.\n268:         const liveRow = database\n269:           .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n270:           .get(id) as { content_hash: string | null } | undefined;\n271:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n272:         if (\n273:           liveRow\n274:           && liveRow.content_hash === lookup.key.contentHash\n275:           && (replayMemoryId == null || replayMemoryId === id)\n276:         ) {\n277:           return lookup.response;\n278:         }\n279:         // Stale receipt for this attempt: drop the cache entry so the live\n280:         // update stores its current response (the post-write store uses\n281:         // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n282:         // stale receipt), then fall through to the normal update path.\n283:         deleteIdempotencyReceiptByKey(database, lookup.key);\n284:       } else if (lookup.status === 'conflict') {\n285:         // Unreachable from this caller: payload is a structural copy of\n286:         // requestFingerprint (above), so a key match implies a payload match and\n287:         // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n288:         // case the key material and payload ever diverge.\n289:         return createMCPErrorResponse({\n290:           tool: 'memory_update',\n291:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n292:           code: 'idempotency_key_conflict',\n293:           details: { requestId, receiptKey: lookup.key.receiptKey, id },\n294:           recovery: {\n295:             hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n296:             severity: 'warning',\n297:           },\n298:         });\n299:       }\n300:     } catch (error: unknown) {\n301:       console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n302:       idempotencyKey = null;\n303:     }\n304:   }\n305: \n306:   let embeddingRegenerated = false;\n307:   let embeddingMarkedForReindex = false;\n308:   let embeddingStatusNeedsPendingWrite = false;\n309:   let mutationLedgerWarning: string | null = null;\n310: \n311:   if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n312:     console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n313:     let newEmbedding: Float32Array | null = null;\n314: \n315:     try {\n316:       // Embed title + content_text, not title alone.\n317:       // This produces better semantic embeddings that capture the full memory context.\n318:       const contentText = existing.content_text || '';\n319:       const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n320:       newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n321:     } catch (err: unknown) {\n322:       const message = toErrorMessage(err);\n323:       if (allowPartialUpdate) {\n324:         console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n325:         embeddingStatusNeedsPendingWrite = true;\n326:         embeddingMarkedForReindex = true;\n327:       } else {\n328:         console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n329:         throw new MemoryError(\n330:           ErrorCodes.EMBEDDING_FAILED,\n331:           'Embedding regeneration failed, update rolled back. No changes were made.',\n332:           { originalError: message, memoryId: id }\n333:         );\n334:       }\n335:     }\n336: \n337:     if (newEmbedding) {\n338:       updateParams.embedding = newEmbedding;\n339:       embeddingRegenerated = true;\n340:     } else if (!embeddingMarkedForReindex) {\n341:       if (allowPartialUpdate) {\n342:         console.warn('[memory-update] Embedding returned null, marking for re-index');\n343:         embeddingStatusNeedsPendingWrite = true;\n344:         embeddingMarkedForReindex = true;\n345:       } else {\n346:         throw new MemoryError(\n347:           ErrorCodes.EMBEDDING_FAILED,\n348:           'Failed to regenerate embedding (null result), update rolled back. No changes were made.',\n349:           { memoryId: id }\n350:         );\n351:       }\n352:     }\n353:   }\n354: \n355:   // transaction wrapper — wraps all synchronous mutation steps (DB update,\n356:   // Cache invalidation, BM25 re-index, ledger append) in a single transaction for atomicity.\n357:   // Embedding generation (async) runs before this block; its result feeds into updateParams.\n358:   const fields = guard.persistedFields;\n359: \n360:   if (database) {\n361:     runInTransaction(database, () => {\n362:       if (embeddingStatusNeedsPendingWrite) {\n363:         vectorIndex.updateEmbeddingStatus(id, 'pending');\n364:       }\n365: \n366:       if (fields.length > 0 || updateParams.embedding !== undefined) {\n367:         vectorIndex.updateMemory(updateParams);\n368:       }\n369:       persistSourceKind(database, id, guard.storedSourceKind);\n370:       persistProvenanceMetadata(database, id, getInternalProvenanceContext(args));\n371: \n372:       if (updateParams.importanceTier !== undefined) {\n373:         const updated = vectorIndex.getMemory(id) as (Record<string, unknown> | null);\n374:         const previousTier = typeof existing.importance_tier === 'string'\n375:           ? existing.importance_tier\n376:           : undefined;\n377:         const nextTier = typeof updated?.importance_tier === 'string'\n378:           ? updated.importance_tier\n379:           : (previousTier ?? updateParams.importanceTier);\n380:         const guardPathCandidate = [\n381:           updated?.canonical_file_path,\n382:           updated?.file_path,\n383:           existing.canonical_file_path,\n384:           existing.file_path,\n385:         ].find((value) => typeof value === 'string' && value.length > 0);\n386:         const guardPath = typeof guardPathCandidate === 'string' ? guardPathCandidate : null;\n387: \n388:         if (\n389:           guardPath\n390:           && !isConstitutionalPath(guardPath)\n391:           && previousTier === 'constitutional'\n392:           && nextTier !== 'constitutional'\n393:         ) {\n394:           try {\n395:             const specFolder = typeof updated?.spec_folder === 'string'\n396:               ? updated.spec_folder\n397:               : (typeof existing.spec_folder === 'string' ? existing.spec_folder : null);\n398:             const anchorIdCandidate = typeof updated?.anchor_id === 'string'\n399:               ? updated.anchor_id\n400:               : (typeof existing.anchor_id === 'string' ? existing.anchor_id : null);\n401:             const anchorId = typeof anchorIdCandidate === 'string' ? anchorIdCandidate : null;\n402:             const updatedFilePath = typeof updated?.file_path === 'string'\n403:               ? updated.file_path\n404:               : (typeof existing.file_path === 'string' ? existing.file_path : null);\n405:             const updatedCanonicalFilePath = typeof updated?.canonical_file_path === 'string'\n406:               ? updated.canonical_file_path\n407:               : (typeof existing.canonical_file_path === 'string' ? existing.canonical_file_path : null);\n408:             recordTierDowngradeAudit(database, {\n409:               memoryId: id,\n410:               logicalKey: buildGovernanceLogicalKey(specFolder, guardPath, anchorId),\n411:               requestedTier: updateParams.importanceTier,\n412:               previousTier,\n413:               nextTier,\n414:               source: 'memory_update',\n415:               filePath: updatedFilePath,\n416:               canonicalFilePath: updatedCanonicalFilePath,\n417:             });\n418:           } catch (error: unknown) {\n419:             console.warn(\n420:               `[memory-crud-update] governance_audit insert failed for memory ${id}: ${toErrorMessage(error)}`,\n421:             );\n422:           }\n423:         }\n424:       }\n425: \n426:       // BM25 index stores title + trigger phrases; must re-index when either changes\n427:       // so keyword search reflects the updated content.\n428:       // BM25 re-index failure now rolls back the transaction when the index is operational.\n429:       // Infrastructure failures (BM25 not available, DB missing prepare) are non-fatal warnings.\n430:       if ((updateParams.title !== undefined || updateParams.triggerPhrases !== undefined) && bm25Index.isBm25Enabled()) {\n431:         try {\n432:           const bm25Idx = bm25Index.getIndex();\n433:           const row = database.prepare(\n434:             'SELECT title, content_text, trigger_phrases, file_path FROM memory_index WHERE id = ?'\n435:           ).get(id) as { title: string | null; content_text: string | null; trigger_phrases: string | null; file_path: string | null } | undefined;\n436:           if (row) {\n437:             const text = bm25Index.buildBm25DocumentText(row);\n438:             if (text.trim()) {\n439:               bm25Idx.addDocument(String(id), text);\n440:             }\n441:           }\n442:         } catch (e: unknown) {\n443:           const bm25ErrMsg = e instanceof Error ? e.message : String(e);\n444:           // Distinguish infrastructure failures from data failures.\n445:           // Infrastructure failures mean the BM25 subsystem is unavailable or torn down —\n446:           // These are non-fatal warnings. Data failures mean the index IS operational but rejected\n447:           // The input — those must re-throw to roll back the transaction.\n448:           const isBm25InfraFailure = (msg: string): boolean =>\n449:             msg.includes('not a function') ||\n450:             msg.includes('not initialized') ||\n451:             msg.includes('Cannot read properties') ||\n452:             msg.includes('is not defined') ||\n453:             msg.includes('database is closed') ||\n454:             msg.includes('no such table');\n455:           if (isBm25InfraFailure(bm25ErrMsg)) {\n456:             console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n457:           } else {\n458:             console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n459:             throw new Error(`BM25 re-index failed: ${bm25ErrMsg}`);\n460:           }\n461:         }\n462:       }\n463: \n464:       // Record UPDATE history after successful mutation\n465:       try {\n466:         recordHistory(\n467:           id, 'UPDATE',\n468:           existing.title ?? null,\n469:           updateParams.title ?? existing.title ?? null,\n470:           'mcp:memory_update'\n471:         );\n472:       } catch (_histErr: unknown) {\n473:         // History recording is best-effort\n474:       }\n475: \n476:       const ledgerRecorded = appendMutationLedgerSafe(database, {\n477:         mutationType: 'update',\n478:         reason: 'memory_update: metadata update',\n479:         priorHash: priorSnapshot?.content_hash ?? (existing.content_hash as string | null) ?? null,\n480:         newHash: mutationLedger.computeHash(JSON.stringify({\n481:           id,\n482:           title: updateParams.title ?? existing.title ?? null,\n483:           triggerPhrases: updateParams.triggerPhrases ?? null,\n484:           importanceWeight: updateParams.importanceWeight ?? null,\n485:           importanceTier: updateParams.importanceTier ?? null,\n486:         })),\n487:         linkedMemoryIds: [id],\n488:         decisionMeta: {\n489:           tool: 'memory_update',\n490:           fields,\n491:           requestedFields: guard.requestedFields,\n492:           skippedFields: guard.skippedFields,\n493:           sourceKind: guard.sourceKind,\n494:           storedSourceKind: guard.storedSourceKind,\n495:           embeddingRegenerated,\n496:           embeddingMarkedForReindex,\n497:           allowPartialUpdate,\n498:         },\n499:         actor: 'mcp:memory_update',\n500:       });\n501:       if (!ledgerRecorded) {\n502:         mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n503:       }\n504:     });\n505:   } else {\n506:     // No database handle means we cannot guarantee transactional\n507:     // Consistency. Abort early rather than risk partial state.\n508:     console.warn('[memory-crud-update] No database handle, aborting update to prevent partial state');\n509:     return createMCPErrorResponse({\n510:       tool: 'memory_update',\n511:       error: `Memory ${id} update aborted: database unavailable`,\n512:       code: 'E_DB_UNAVAILABLE',\n513:       details: { updated: null, fields, skippedFields: guard.skippedFields },\n514:       recovery: {\n515:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n516:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n517:         severity: 'error',\n518:       },\n519:     });\n520:   }\n521: \n522:   let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n523:   try {\n524:     postMutationHooks = runPostMutationHooks('update', {\n525:       database,\n526:       memoryId: id,\n527:       sourceKind: guard.sourceKind,\n528:       actor: 'mcp:memory_update',\n529:       auditReason: `memory_update:${id}:${fields.slice().sort().join(',') || 'source_kind'}`,\n530:     });\n531:   } catch (hookError: unknown) {\n532:     const msg = hookError instanceof Error ? hookError.message : String(hookError);\n533:     postMutationHooks = {\n534:       latencyMs: 0, triggerCacheCleared: false,\n535:       constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n536:       graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n537:       errors: [msg],\n538:     };\n539:   }\n540:   const postMutationFeedback = buildMutationHookFeedback('update', postMutationHooks);\n541: \n542:   const summary = embeddingMarkedForReindex\n543:     ? `Memory ${id} updated (embedding pending re-index)`\n544:     : `Memory ${id} updated successfully`;\n545: \n546:   const hints: string[] = [];\n547:   if (embeddingMarkedForReindex) {\n548:     hints.push('Run memory_index_scan() to regenerate embeddings');\n549:   }\n550:   if (embeddingRegenerated) {\n551:     hints.push('Embedding regenerated - search results may differ');\n552:   }\n553:   if (mutationLedgerWarning) {\n554:     hints.push(mutationLedgerWarning);\n555:   }\n556:   if (guard.hint) {\n557:     hints.push(guard.hint);\n558:   }\n559:   hints.push(...postMutationFeedback.hints);\n560: \n561:   const data: Record<string, unknown> = {\n562:     updated: id,\n563:     fields,\n564:     skippedFields: guard.skippedFields,\n565:     provenance: {\n566:       sourceKind: guard.sourceKind,\n567:       storedSourceKind: guard.storedSourceKind,\n568:     },\n569:     embeddingRegenerated,\n570:     postMutationHooks: postMutationFeedback.data,\n571:   };\n572: \n573:   if (embeddingMarkedForReindex) {\n574:     data.warning = 'Embedding regeneration failed, memory marked for re-indexing';\n575:     data.embeddingStatus = 'pending';\n576:   }\n577:   if (mutationLedgerWarning) {\n578:     data.mutationLedgerWarning = mutationLedgerWarning;\n579:   }\n580: \n581:   const response = createMCPSuccessResponse({\n582:     tool: 'memory_update',\n583:     summary,\n584:     data,\n585:     hints,\n586:   });\n587:   if (database && idempotencyKey) {\n588:     try {\n589:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n590:       if (!won) {\n591:         // Same lost-store semantics as memory_save: a same-payload loser\n592:         // replays the canonical winner; a different-payload loser already\n593:         // mutated, so it returns its own response with the conflict made\n594:         // visible rather than silently diverging from the receipt.\n595:         const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n596:         if (winner.status === 'replay') {\n597:           return winner.response;\n598:         }\n599:         if (winner.status === 'conflict') {\n600:           return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n601:         }\n602:       }\n603:     } catch (error: unknown) {\n604:       console.warn(`[memory-crud-update] idempotency receipt store failed; continuing without replay receipt: ${toErrorMessage(error)}`);\n605:     }\n606:   }\n607:   return response;\n608: }\n609: \n610: /* ───────────────────────────────────────────────────────────────\n611:    EXPORTS\n612: ──────────────────────────────────────────────────────────────── */\n613: \n614: export { handleMemoryUpdate };\n\n(End of file - total 614 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Update Handler\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { UpdateMemoryParams } from '../lib/search/vector-index.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\nimport { MemoryError, ErrorCodes } from '../lib/errors.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport { runInTransaction } from '../lib/storage/transaction-manager.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Update Handler\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { UpdateMemoryParams } from '../lib/search/vector-index.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\nimport { MemoryError, ErrorCodes } from '../lib/errors.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport { runInTransaction } from '../lib/storage/transaction-manager.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../lib/governance/scope-governance.js';\nimport { isConstitutionalPath } from '../lib/utils/index-scope.js';\nimport { scrubSecrets, SecretScrubberError } from '../lib/parsing/secret-scrubber.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport {\n  deleteIdempotencyReceiptByKey,\n  extractMemoryIdFromResponse,\n  isMemoryIdempotencyEnabled,\n  lookupIdempotencyReceipt,\n  lookupIdempotencyReceiptByKey,\n  markResponseWithReceiptStoreConflict,\n  storeIdempotencyReceipt,\n  type IdempotencyReceiptKey,\n} from '../lib/storage/idempotency-receipts.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport {\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  persistProvenanceMetadata,\n  persistSourceKind,\n  type SourceKind,\n} from '../lib/storage/write-provenance.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { UpdateArgs } from './memory-crud-types.js';\n\n// Feature catalog: Memory metadata update (memory_update)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nconst PROTECTED_AUTOMATED_UPDATE_FIELDS = new Set(['title', 'triggerPhrases', 'importanceTier']);\nconst SKIPPED_MANUAL_PROTECTION_HINT = 'skipped to protect manual data';\n\ninterface ProvenanceGuardResult {\n  updateParams: UpdateMemoryParams;\n  requestedFields: string[];\n  persistedFields: string[];\n  skippedFields: string[];\n  sourceKind: SourceKind;\n  storedSourceKind: SourceKind;\n  hint: string | null;\n}\n\nfunction getInternalProvenanceContext(args: UpdateArgs): Record<string, unknown> {\n  const rawArgs = args as unknown as Record<string, unknown>;\n  const context = rawArgs.__provenanceContext;\n  return context && typeof context === 'object' && !Array.isArray(context)\n    ? context as Record<string, unknown>\n    : {};\n}\n\nfunction isProtectedExistingRow(existing: Record<string, unknown>): boolean {\n  const existingSourceKind = normalizeSourceKind(existing.source_kind);\n  const importanceTier = typeof existing.importance_tier === 'string' ? existing.importance_tier : null;\n  const isPinned = existing.is_pinned === true || existing.is_pinned === 1;\n  const pathCandidate = [existing.canonical_file_path, existing.file_path]\n    .find((value) => typeof value === 'string' && value.length > 0);\n  const rowPath = typeof pathCandidate === 'string' ? pathCandidate : null;\n  return existingSourceKind === null\n    || existingSourceKind === 'human'\n    || importanceTier === 'constitutional'\n    || importanceTier === 'critical'\n    || isPinned\n    || (rowPath !== null && isConstitutionalPath(rowPath));\n}\n\nfunction buildGuardedUpdateParams(\n  args: UpdateArgs,\n  existing: Record<string, unknown>,\n): ProvenanceGuardResult {\n  const internalContext = getInternalProvenanceContext(args);\n  const sourceKind = deriveSourceKindFromContext({\n    provenanceSource: internalContext.provenanceSource ?? internalContext.provenance_source,\n    provenanceActor: internalContext.provenanceActor ?? internalContext.provenance_actor,\n    tool: internalContext.tool,\n  });\n  const existingSourceKind = normalizeSourceKind(existing.source_kind);\n  const automated = sourceKind !== 'human';\n  const protectExisting = automated && isProtectedExistingRow(existing);\n  const updateParams: UpdateMemoryParams = { id: args.id };\n  const requestedFields: string[] = [];\n  const persistedFields: string[] = [];\n  const skippedFields: string[] = [];\n\n  const maybeAssign = <K extends keyof UpdateMemoryParams>(field: K, value: UpdateMemoryParams[K]): void => {\n    if (value === undefined) {\n      return;\n    }\n    requestedFields.push(field);\n    if (protectExisting && PROTECTED_AUTOMATED_UPDATE_FIELDS.has(field)) {\n      skippedFields.push(field);\n      return;\n    }\n    updateParams[field] = value;\n    persistedFields.push(field);\n  };\n\n  maybeAssign('title', args.title);\n  maybeAssign('triggerPhrases', args.triggerPhrases);\n  maybeAssign('importanceWeight', args.importanceWeight);\n  maybeAssign('importanceTier', args.importanceTier);\n\n  const storedSourceKind = sourceKind === 'human'\n    ? 'human'\n    : (protectExisting ? (existingSourceKind ?? 'human') : sourceKind);\n\n  return {\n    updateParams,\n    requestedFields,\n    persistedFields,\n    skippedFields,\n    sourceKind,\n    storedSourceKind,\n    hint: skippedFields.length > 0 ? SKIPPED_MANUAL_PROTECTION_HINT : null,\n  };\n}\n\n/** Handle memory_update tool -- updates metadata fields and optionally regenerates embeddings. */\nasync function handleMemoryUpdate(args: UpdateArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_update');\n  // Generate requestId for incident correlation in error responses\n  const requestId = randomUUID();\n  await checkDatabaseUpdated();\n\n  const {\n    id,\n    title: rawTitle,\n    triggerPhrases: rawTriggerPhrases,\n    importanceWeight,\n    importanceTier,\n    allowPartialUpdate = false,\n  } = args;\n\n  if (typeof id !== 'number') {\n    throw new MemoryError(ErrorCodes.MISSING_REQUIRED_PARAM, 'id is required', { param: 'id' });\n  }\n\n  // Title and trigger phrases are persisted/indexed fields written outside\n  // the parse path, so they get the same pre-index secret redaction. A\n  // scrubber failure refuses this write (fail-closed) rather than persisting\n  // potentially unscrubbed text.\n  let title = rawTitle;\n  let triggerPhrases = rawTriggerPhrases;\n  try {\n    if (typeof title === 'string') {\n      title = scrubSecrets(title);\n    }\n    if (Array.isArray(triggerPhrases)) {\n      triggerPhrases = triggerPhrases.map((phrase) => (\n        typeof phrase === 'string' ? scrubSecrets(phrase) : phrase\n      ));\n    }\n  } catch (error: unknown) {\n    if (error instanceof SecretScrubberError) {\n      throw new MemoryError(\n        ErrorCodes.INVALID_PARAMETER,\n        `Update refused: ${error.message}`,\n        { param: 'title/triggerPhrases', memoryId: id },\n      );\n    }\n    throw error;\n  }\n\n  if (importanceWeight !== undefined && (typeof importanceWeight !== 'number' || importanceWeight < 0 || importanceWeight > 1)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      'importanceWeight must be a number between 0 and 1',\n      { param: 'importanceWeight', value: importanceWeight }\n    );\n  }\n\n  if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n      { param: 'importanceTier', value: importanceTier }\n    );\n  }\n\n  const existing = vectorIndex.getMemory(id);\n  if (!existing) {\n    throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n  }\n\n  const database = vectorIndex.getDb();\n  const priorSnapshot = getMemoryHashSnapshot(database, id);\n\n  const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n  const updateParams = guard.updateParams;\n  let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  if (database && isMemoryIdempotencyEnabled()) {\n    try {\n      const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n      const logicalMutation = {\n        id,\n        title: updateParams.title ?? null,\n        triggerPhrases: updateParams.triggerPhrases ?? null,\n        importanceWeight: updateParams.importanceWeight ?? null,\n        importanceTier: updateParams.importanceTier ?? null,\n        contentHash,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_update',\n        contentHash,\n        requestFingerprint: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n        // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n        // payloadHash always equals requestFingerprintHash and the receiptKey is\n        // derived from it. Consequence: distinct logical updates always produce\n        // distinct keys, so the same-key/different-payload 'conflict' status can\n        // never fire from this caller; the conflict branch below is fail-safe\n        // defense-in-depth, not active protection. To make conflicts detectable\n        // the payload would have to carry MORE than the key material (e.g.\n        // execution-mode flags like allowPartialUpdate); it deliberately does\n        // not, so a benign flag flip cannot become a false hard conflict.\n        payload: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live row. Re-read this id's current content_hash and\n        // honor the replay ONLY when it still matches the receipt's content_hash\n        // AND the cached response still reports this same id; an A->B->A content\n        // revert leaves the receipt for A intact while the row moved on, and a\n        // delete-then-recreate can leave the cached response naming a stale id,\n        // so replaying it would diverge from the row.\n        const liveRow = database\n          .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n          .get(id) as { content_hash: string | null } | undefined;\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          liveRow\n          && liveRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || replayMemoryId === id)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the live\n        // update stores its current response (the post-write store uses\n        // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n        // stale receipt), then fall through to the normal update path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload is a structural copy of\n        // requestFingerprint (above), so a key match implies a payload match and\n        // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n        // case the key material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_update',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey, id },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n      idempotencyKey = null;\n    }\n  }\n\n  let embeddingRegenerated = false;\n  let embeddingMarkedForReindex = false;\n  let embeddingStatusNeedsPendingWrite = false;\n  let mutationLedgerWarning: string | null = null;\n\n  if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n    console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n    let newEmbedding: Float32Array | null = null;\n\n    try {\n      // Embed title + content_text, not title alone.\n      // This produces better semantic embeddings that capture the full memory context.\n      const contentText = existing.content_text || '';\n      const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n      newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      if (allowPartialUpdate) {\n        console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n        embeddingStatusNeedsPendingWrite = true;\n        embeddingMarkedForReindex = true;\n      } else {\n        console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n        throw new MemoryError(\n          ErrorCodes.EMBEDDING_FAILED,\n          'Embedding regeneration failed, update rolled back. No changes were made.',\n          { originalError: message, memoryId: id }\n        );\n      }\n    }\n\n    if (newEmbedding) {\n      updateParams.embedding = newEmbedding;\n      embeddingRegenerated = true;\n    } else if (!embeddingMarkedForReindex) {\n      if (allowPartialUpdate) {\n        console.warn('[memory-update] Embedding returned null, marking for re-index');\n        embeddingStatusNeedsPendingWrite = true;\n        embeddingMarkedForReindex = true;\n      } else {\n        throw new MemoryError(\n          ErrorCodes.EMBEDDING_FAILED,\n          'Failed to regenerate embedding (null result), update rolled back. No changes were made.',\n          { memoryId: id }\n        );\n      }\n    }\n  }\n\n  // transaction wrapper — wraps all synchronous mutation steps (DB update,\n  // Cache invalidation, BM25 re-index, ledger append) in a single transaction for atomicity.\n  // Embedding generation (async) runs before this block; its result feeds into updateParams.\n  const fields = guard.persistedFields;\n\n  if (database) {\n    runInTransaction(database, () => {\n      if (embeddingStatusNeedsPendingWrite) {\n        vectorIndex.updateEmbeddingStatus(id, 'pending');\n      }\n\n      if (fields.length > 0 || updateParams.embedding !== undefined) {\n        vectorIndex.updateMemory(updateParams);\n      }\n      persistSourceKind(database, id, guard.storedSourceKind);\n      persistProvenanceMetadata(database, id, getInternalProvenanceContext(args));\n\n      if (updateParams.importanceTier !== undefined) {\n        const updated = vectorIndex.getMemory(id) as (Record<string, unknown> | null);\n        const previousTier = typeof existing.importance_tier === 'string'\n          ? existing.importance_tier\n          : undefined;\n        const nextTier = typeof updated?.importance_tier === 'string'\n          ? updated.importance_tier\n          : (previousTier ?? updateParams.importanceTier);\n        const guardPathCandidate = [\n          updated?.canonical_file_path,\n          updated?.file_path,\n          existing.canonical_file_path,\n          existing.file_path,\n        ].find((value) => typeof value === 'string' && value.length > 0);\n        const guardPath = typeof guardPathCandidate === 'string' ? guardPathCandidate : null;\n\n        if (\n          guardPath\n          && !isConstitutionalPath(guardPath)\n          && previousTier === 'constitutional'\n          && nextTier !== 'constitutional'\n        ) {\n          try {\n            const specFolder = typeof updated?.spec_folder === 'string'\n              ? updated.spec_folder\n              : (typeof existing.spec_folder === 'string' ? existing.spec_folder : null);\n            const anchorIdCandidate = typeof updated?.anchor_id === 'string'\n              ? updated.anchor_id\n              : (typeof existing.anchor_id === 'string' ? existing.anchor_id : null);\n            const anchorId = typeof anchorIdCandidate === 'string' ? anchorIdCandidate : null;\n            const updatedFilePath = typeof updated?.file_path === 'string'\n              ? updated.file_path\n              : (typeof existing.file_path === 'string' ? existing.file_path : null);\n            const updatedCanonicalFilePath = typeof updated?.canonical_file_path === 'string'\n              ? updated.canonical_file_path\n              : (typeof existing.canonical_file_path === 'string' ? existing.canonical_file_path : null);\n            recordTierDowngradeAudit(database, {\n              memoryId: id,\n              logicalKey: buildGovernanceLogicalKey(specFolder, guardPath, anchorId),\n              requestedTier: updateParams.importanceTier,\n              previousTier,\n              nextTier,\n              source: 'memory_update',\n              filePath: updatedFilePath,\n              canonicalFilePath: updatedCanonicalFilePath,\n            });\n          } catch (error: unknown) {\n            console.warn(\n              `[memory-crud-update] governance_audit insert failed for memory ${id}: ${toErrorMessage(error)}`,\n            );\n          }\n        }\n      }\n\n      // BM25 index stores title + trigger phrases; must re-index when either changes\n      // so keyword search reflects the updated content.\n      // BM25 re-index failure now rolls back the transaction when the index is operational.\n      // Infrastructure failures (BM25 not available, DB missing prepare) are non-fatal warnings.\n      if ((updateParams.title !== undefined || updateParams.triggerPhrases !== undefined) && bm25Index.isBm25Enabled()) {\n        try {\n          const bm25Idx = bm25Index.getIndex();\n          const row = database.prepare(\n            'SELECT title, content_text, trigger_phrases, file_path FROM memory_index WHERE id = ?'\n          ).get(id) as { title: string | null; content_text: string | null; trigger_phrases: string | null; file_path: string | null } | undefined;\n          if (row) {\n            const text = bm25Index.buildBm25DocumentText(row);\n            if (text.trim()) {\n              bm25Idx.addDocument(String(id), text);\n            }\n          }\n        } catch (e: unknown) {\n          const bm25ErrMsg = e instanceof Error ? e.message : String(e);\n          // Distinguish infrastructure failures from data failures.\n          // Infrastructure failures mean the BM25 subsystem is unavailable or torn down —\n          // These are non-fatal warnings. Data failures mean the index IS operational but rejected\n          // The input — those must re-throw to roll back the transaction.\n          const isBm25InfraFailure = (msg: string): boolean =>\n            msg.includes('not a function') ||\n            msg.includes('not initialized') ||\n            msg.includes('Cannot read properties') ||\n            msg.includes('is not defined') ||\n            msg.includes('database is closed') ||\n            msg.includes('no such table');\n          if (isBm25InfraFailure(bm25ErrMsg)) {\n            console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n          } else {\n            console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n            throw new Error(`BM25 re-index failed: ${bm25ErrMsg}`);\n          }\n        }\n      }\n\n      // Record UPDATE history after successful mutation\n      try {\n        recordHistory(\n          id, 'UPDATE',\n          existing.title ?? null,\n          updateParams.title ?? existing.title ?? null,\n          'mcp:memory_update'\n        );\n      } catch (_histErr: unknown) {\n        // History recording is best-effort\n      }\n\n      const ledgerRecorded = appendMutationLedgerSafe(database, {\n        mutationType: 'update',\n        reason: 'memory_update: metadata update',\n        priorHash: priorSnapshot?.content_hash ?? (existing.content_hash as string | null) ?? null,\n        newHash: mutationLedger.computeHash(JSON.stringify({\n          id,\n          title: updateParams.title ?? existing.title ?? null,\n          triggerPhrases: updateParams.triggerPhrases ?? null,\n          importanceWeight: updateParams.importanceWeight ?? null,\n          importanceTier: updateParams.importanceTier ?? null,\n        })),\n        linkedMemoryIds: [id],\n        decisionMeta: {\n          tool: 'memory_update',\n          fields,\n          requestedFields: guard.requestedFields,\n          skippedFields: guard.skippedFields,\n          sourceKind: guard.sourceKind,\n          storedSourceKind: guard.storedSourceKind,\n          embeddingRegenerated,\n          embeddingMarkedForReindex,\n          allowPartialUpdate,\n        },\n        actor: 'mcp:memory_update',\n      });\n      if (!ledgerRecorded) {\n        mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n      }\n    });\n  } else {\n    // No database handle means we cannot guarantee transactional\n    // Consistency. Abort early rather than risk partial state.\n    console.warn('[memory-crud-update] No database handle, aborting update to prevent partial state');\n    return createMCPErrorResponse({\n      tool: 'memory_update',\n      error: `Memory ${id} update aborted: database unavailable`,\n      code: 'E_DB_UNAVAILABLE',\n      details: { updated: null, fields, skippedFields: guard.skippedFields },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n  try {\n    postMutationHooks = runPostMutationHooks('update', {\n      database,\n      memoryId: id,\n      sourceKind: guard.sourceKind,\n      actor: 'mcp:memory_update',\n      auditReason: `memory_update:${id}:${fields.slice().sort().join(',') || 'source_kind'}`,\n    });\n  } catch (hookError: unknown) {\n    const msg = hookError instanceof Error ? hookError.message : String(hookError);\n    postMutationHooks = {\n      latencyMs: 0, triggerCacheCleared: false,\n      constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n      graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n      errors: [msg],\n    };\n  }\n  const postMutationFeedback = buildMutationHookFeedback('update', postMutationHooks);\n\n  const summary = embeddingMarkedForReindex\n    ? `Memory ${id} updated (embedding pending re-index)`\n    : `Memory ${id} updated successfully`;\n\n  const hints: string[] = [];\n  if (embeddingMarkedForReindex) {\n    hints.push('Run memory_index_scan() to regenerate embeddings');\n  }\n  if (embeddingRegenerated) {\n    hints.push('Embedding regenerated - search results may differ');\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n  if (guard.hint) {\n    hints.push(guard.hint);\n  }\n  hints.push(...postMutationFeedback.hints);\n\n  const data: Record<string, unknown> = {\n    updated: id,\n    fields,\n    skippedFields: guard.skippedFields,\n    provenance: {\n      sourceKind: guard.sourceKind,\n      storedSourceKind: guard.storedSourceKind,\n    },\n    embeddingRegenerated,\n    postMutationHooks: postMutationFeedback.data,\n  };\n\n  if (embeddingMarkedForReindex) {\n    data.warning = 'Embedding regeneration failed, memory marked for re-indexing';\n    data.embeddingStatus = 'pending';\n  }\n  if (mutationLedgerWarning) {\n    data.mutationLedgerWarning = mutationLedgerWarning;\n  }\n\n  const response = createMCPSuccessResponse({\n    tool: 'memory_update',\n    summary,\n    data,\n    hints,\n  });\n  if (database && idempotencyKey) {\n    try {\n      const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n      if (!won) {\n        // Same lost-store semantics as memory_save: a same-payload loser\n        // replays the canonical winner; a different-payload loser already\n        // mutated, so it returns its own response with the conflict made\n        // visible rather than silently diverging from the receipt.\n        const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n        if (winner.status === 'replay') {\n          return winner.response;\n        }\n        if (winner.status === 'conflict') {\n          return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n        }\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt store failed; continuing without replay receipt: ${toErrorMessage(error)}`);\n    }\n  }\n  return response;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryUpdate };","lineStart":1,"lineEnd":614,"totalLines":614,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","time":{"start":1781762676284,"end":1781762676292}},"metadata":{"openai":{"itemId":"fc_0eee0a4785417890016a338a7429188191855f7c38c61bba4b"}},"id":"prt_ed954d635001Ck48zt0cGAcRqX","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed954a837001ZSjuFNxCLCd2ax"}}
{"type":"tool_use","timestamp":1781762676406,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_OG2RHh6HK0U6DeYBGGdmN8MP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-links-processor.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-links-processor.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Causal Links Processor\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: // ───────────────────────────────────────────────────────────────────\n6: // 1. IMPORTS\n7: // ───────────────────────────────────────────────────────────────────\n8: \n9: import type BetterSqlite3 from 'better-sqlite3';\n10: \n11: import type { CausalLinks } from '../lib/parsing/memory-parser.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n14: import { toErrorMessage } from '../utils/index.js';\n15: import { escapeLikePattern } from './handler-utils.js';\n16: \n17: // Feature catalog: Causal edge creation (memory_causal_link)\n18: // Feature catalog: Causal edge deletion (memory_causal_unlink)\n19: // Feature catalog: Memory indexing (memory_save)\n20: \n21: // ───────────────────────────────────────────────────────────────────\n22: // 2. TYPES\n23: // ───────────────────────────────────────────────────────────────────\n24: \n25: interface CausalLinkMapping {\n26:   relation: typeof causalEdges.RELATION_TYPES[keyof typeof causalEdges.RELATION_TYPES];\n27:   reverse: boolean;\n28: }\n29: \n30: interface CausalLinksResult {\n31:   processed: number;\n32:   inserted: number;\n33:   resolved: number;\n34:   unresolved: { type: string; reference: string }[];\n35:   errors: { type: string; reference: string; error: string }[];\n36: }\n37: \n38: interface MemoryIdRow {\n39:   id: number;\n40: }\n41: \n42: interface PathLookupRow extends MemoryIdRow {\n43:   canonical_file_path: string | null;\n44:   file_path: string | null;\n45:   spec_folder: string | null;\n46: }\n47: \n48: interface TitleLookupRow extends MemoryIdRow {\n49:   title: string | null;\n50: }\n51: \n52: interface PreparedReference {\n53:   original: string;\n54:   trimmed: string;\n55:   normalizedReference: string;\n56:   normalizedLower: string;\n57:   escapedLike: string;\n58:   numericId: number | null;\n59:   isSessionLike: boolean;\n60:   isPathLike: boolean;\n61: }\n62: \n63: // ───────────────────────────────────────────────────────────────────\n64: // 3. CONSTANTS\n65: // ───────────────────────────────────────────────────────────────────\n66: \n67: const CAUSAL_LINK_MAPPINGS: Record<string, CausalLinkMapping> = {\n68:   caused_by: { relation: causalEdges.RELATION_TYPES.CAUSED, reverse: true },\n69:   supersedes: { relation: causalEdges.RELATION_TYPES.SUPERSEDES, reverse: false },\n70:   derived_from: { relation: causalEdges.RELATION_TYPES.DERIVED_FROM, reverse: false },\n71:   blocks: { relation: causalEdges.RELATION_TYPES.ENABLED, reverse: true },\n72:   related_to: { relation: causalEdges.RELATION_TYPES.SUPPORTS, reverse: false }\n73: };\n74: \n75: // ───────────────────────────────────────────────────────────────────\n76: // 4. HELPERS\n77: // ───────────────────────────────────────────────────────────────────\n78: \n79: /** Resolve a memory reference (ID, path, or title) to a numeric memory ID */\n80: function resolveMemoryReference(database: BetterSqlite3.Database, reference: string): number | null {\n81:   const resolved = resolveMemoryReferencesBatch(database, [reference]).get(reference);\n82:   return typeof resolved === 'number' ? resolved : null;\n83: }\n84: \n85: function buildPreparedReference(reference: string): PreparedReference | null {\n86:   if (!reference || typeof reference !== 'string') {\n87:     return null;\n88:   }\n89: \n90:   const trimmed = reference.trim();\n91:   if (!trimmed) {\n92:     return null;\n93:   }\n94: \n95:   const normalizedReference = trimmed.replace(/\\\\/g, '/');\n96:   const normalizedLower = normalizedReference.toLowerCase();\n97:   const numericId = /^\\d+$/.test(trimmed) ? Number.parseInt(trimmed, 10) : null;\n98: \n99:   return {\n100:     original: reference,\n101:     trimmed,\n102:     normalizedReference,\n103:     normalizedLower,\n104:     escapedLike: escapeLikePattern(normalizedReference),\n105:     numericId: Number.isFinite(numericId) ? numericId : null,\n106:     isSessionLike: normalizedLower.includes('session') || /^\\d{4}-\\d{2}-\\d{2}/.test(normalizedReference),\n107:     isPathLike:\n108:       normalizedLower.includes('specs/')\n109:       || normalizedLower.includes('memory/')\n110:       || normalizedReference.includes('/'),\n111:   };\n112: }\n113: \n114: function buildPathExactCandidates(normalizedReference: string): string[] {\n115:   const candidates = new Set<string>();\n116: \n117:   const canonical = getCanonicalPathKey(normalizedReference);\n118:   const trimmedLeadingSlash = normalizedReference.replace(/^\\/+/, '');\n119: \n120:   candidates.add(normalizedReference);\n121:   candidates.add(canonical);\n122:   candidates.add(trimmedLeadingSlash);\n123:   if (!normalizedReference.startsWith('/')) {\n124:     candidates.add(`/${normalizedReference}`);\n125:   }\n126:   if (!canonical.startsWith('/')) {\n127:     candidates.add(`/${canonical}`);\n128:   }\n129: \n130:   return Array.from(candidates).filter((candidate) => candidate.length > 0);\n131: }\n132: \n133: function buildInClause(values: readonly unknown[]): string {\n134:   return values.map(() => '?').join(', ');\n135: }\n136: \n137: function getMemoryIndexColumns(database: BetterSqlite3.Database): Set<string> {\n138:   const rows = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name?: string }>;\n139:   return new Set(rows.map((row) => row.name).filter((name): name is string => typeof name === 'string'));\n140: }\n141: \n142: /** Resolve many memory references in batch (exact first, fuzzy fallback). */\n143: function resolveMemoryReferencesBatch(\n144:   database: BetterSqlite3.Database,\n145:   references: readonly string[],\n146: ): Map<string, number | null> {\n147:   const resolved = new Map<string, number | null>();\n148:   const preparedRefs: PreparedReference[] = [];\n149:   const memoryIndexColumns = getMemoryIndexColumns(database);\n150:   const hasCanonicalFilePath = memoryIndexColumns.has('canonical_file_path');\n151: \n152:   for (const reference of references) {\n153:     const prepared = buildPreparedReference(reference);\n154:     if (!prepared) {\n155:       resolved.set(reference, null);\n156:       continue;\n157:     }\n158:     preparedRefs.push(prepared);\n159:     resolved.set(reference, null);\n160:   }\n161: \n162:   if (preparedRefs.length === 0) {\n163:     return resolved;\n164:   }\n165: \n166:   const unresolved = (reference: PreparedReference): boolean => {\n167:     return !resolved.has(reference.original) || resolved.get(reference.original) == null;\n168:   };\n169: \n170:   const setResolved = (reference: PreparedReference, id: number | null): void => {\n171:     if (typeof id === 'number' && Number.isFinite(id)) {\n172:       resolved.set(reference.original, id);\n173:     }\n174:   };\n175: \n176:   // 1) Batch numeric IDs\n177:   const numericIds = Array.from(\n178:     new Set(preparedRefs.map((ref) => ref.numericId).filter((id): id is number => typeof id === 'number')),\n179:   );\n180:   if (numericIds.length > 0) {\n181:     const numericRows = database.prepare(`\n182:       SELECT id\n183:       FROM memory_index\n184:       WHERE id IN (${buildInClause(numericIds)})\n185:     `).all(...numericIds) as MemoryIdRow[];\n186:     const foundIds = new Set(numericRows.map((row) => row.id));\n187:     for (const ref of preparedRefs) {\n188:       if (!unresolved(ref) || ref.numericId == null) {\n189:         continue;\n190:       }\n191:       if (foundIds.has(ref.numericId)) {\n192:         setResolved(ref, ref.numericId);\n193:       }\n194:     }\n195:   }\n196: \n197:   // 2) Batch exact path matches via canonical_file_path/file_path equality\n198:   const pathCandidates = new Set<string>();\n199:   const pathCandidateRefs = new Map<string, PreparedReference[]>();\n200:   for (const ref of preparedRefs) {\n201:     if (!unresolved(ref) || (!ref.isPathLike && !ref.isSessionLike)) {\n202:       continue;\n203:     }\n204: \n205:     for (const candidate of buildPathExactCandidates(ref.normalizedReference)) {\n206:       pathCandidates.add(candidate);\n207:       const current = pathCandidateRefs.get(candidate) ?? [];\n208:       current.push(ref);\n209:       pathCandidateRefs.set(candidate, current);\n210:     }\n211:   }\n212: \n213:   if (pathCandidates.size > 0) {\n214:     const values = Array.from(pathCandidates);\n215:     const inClause = buildInClause(values);\n216:   const pathRows = hasCanonicalFilePath\n217:       ? database.prepare(`\n218:         SELECT id, canonical_file_path, file_path, spec_folder\n219:         FROM memory_index\n220:         WHERE canonical_file_path IN (${inClause})\n221:            OR file_path IN (${inClause})\n222:            OR spec_folder IN (${inClause})\n223:         ORDER BY id DESC\n224:       `).all(...values, ...values, ...values) as PathLookupRow[]\n225:       : database.prepare(`\n226:         SELECT id, NULL AS canonical_file_path, file_path, spec_folder\n227:         FROM memory_index\n228:         WHERE file_path IN (${inClause})\n229:            OR spec_folder IN (${inClause})\n230:         ORDER BY id DESC\n231:       `).all(...values, ...values) as PathLookupRow[];\n232: \n233:     const idByCandidate = new Map<string, number>();\n234:     for (const row of pathRows) {\n235:       const rowKeys = [row.canonical_file_path, row.file_path, row.spec_folder].filter((value): value is string => typeof value === 'string');\n236:       for (const rowKey of rowKeys) {\n237:         if (!idByCandidate.has(rowKey)) {\n238:           idByCandidate.set(rowKey, row.id);\n239:         }\n240:       }\n241:     }\n242: \n243:     for (const [candidate, refs] of pathCandidateRefs.entries()) {\n244:       const id = idByCandidate.get(candidate);\n245:       if (typeof id !== 'number') {\n246:         continue;\n247:       }\n248:       for (const ref of refs) {\n249:         if (unresolved(ref)) {\n250:           setResolved(ref, id);\n251:         }\n252:       }\n253:     }\n254:   }\n255: \n256:   // 3) Batch exact title matches\n257:   const titleCandidates = Array.from(new Set(\n258:     preparedRefs\n259:       .filter((ref) => unresolved(ref))\n260:       .map((ref) => ref.trimmed),\n261:   ));\n262: \n263:   if (titleCandidates.length > 0) {\n264:     const titleRows = database.prepare(`\n265:       SELECT id, title\n266:       FROM memory_index\n267:       WHERE title IN (${buildInClause(titleCandidates)})\n268:       ORDER BY id DESC\n269:     `).all(...titleCandidates) as TitleLookupRow[];\n270: \n271:     const idByTitle = new Map<string, number>();\n272:     for (const row of titleRows) {\n273:       if (typeof row.title !== 'string' || idByTitle.has(row.title)) {\n274:         continue;\n275:       }\n276:       idByTitle.set(row.title, row.id);\n277:     }\n278: \n279:     for (const ref of preparedRefs) {\n280:       if (!unresolved(ref)) {\n281:         continue;\n282:       }\n283:       const id = idByTitle.get(ref.trimmed);\n284:       if (typeof id === 'number') {\n285:         setResolved(ref, id);\n286:       }\n287:     }\n288:   }\n289: \n290:   // 4) Fuzzy fallback (LIKE with leading wildcard is intentionally last-resort)\n291:   const byPathFallbackStmt = hasCanonicalFilePath\n292:     ? database.prepare(`\n293:       SELECT id\n294:       FROM memory_index\n295:       WHERE canonical_file_path LIKE ? ESCAPE '\\\\'\n296:          OR file_path LIKE ? ESCAPE '\\\\'\n297:       ORDER BY id DESC\n298:       LIMIT 1\n299:     `)\n300:     : database.prepare(`\n301:       SELECT id\n302:       FROM memory_index\n303:       WHERE file_path LIKE ? ESCAPE '\\\\'\n304:       ORDER BY id DESC\n305:       LIMIT 1\n306:     `);\n307:   const byTitlePartialStmt = database.prepare(`\n308:     SELECT id\n309:     FROM memory_index\n310:     WHERE title LIKE ? ESCAPE '\\\\'\n311:     ORDER BY id DESC\n312:     LIMIT 1\n313:   `);\n314: \n315:   for (const ref of preparedRefs) {\n316:     if (!unresolved(ref)) {\n317:       continue;\n318:     }\n319: \n320:     if (ref.isSessionLike || ref.isPathLike) {\n321:       const byPath = hasCanonicalFilePath\n322:         ? byPathFallbackStmt.get(`%${ref.escapedLike}%`, `%${ref.escapedLike}%`) as MemoryIdRow | undefined\n323:         : byPathFallbackStmt.get(`%${ref.escapedLike}%`) as MemoryIdRow | undefined;\n324:       if (byPath) {\n325:         setResolved(ref, byPath.id);\n326:         continue;\n327:       }\n328:     }\n329: \n330:     const byTitlePartial = byTitlePartialStmt.get(`%${escapeLikePattern(ref.trimmed)}%`) as MemoryIdRow | undefined;\n331:     if (byTitlePartial) {\n332:       setResolved(ref, byTitlePartial.id);\n333:     }\n334:   }\n335: \n336:   return resolved;\n337: }\n338: \n339: // ───────────────────────────────────────────────────────────────────\n340: // 5. CORE LOGIC\n341: // ───────────────────────────────────────────────────────────────────\n342: \n343: /** Process causal link declarations from a memory file and insert edges into the graph */\n344: function processCausalLinks(database: BetterSqlite3.Database, memoryId: number, causalLinks: CausalLinks): CausalLinksResult {\n345:   const result: CausalLinksResult = {\n346:     processed: 0,\n347:     inserted: 0,\n348:     resolved: 0,\n349:     unresolved: [],\n350:     errors: []\n351:   };\n352: \n353:   if (!causalLinks || typeof causalLinks !== 'object') {\n354:     return result;\n355:   }\n356: \n357:   // Initialize causal-edges module with database connection\n358:   causalEdges.init(database);\n359: \n360:   const memoryIdStr = String(memoryId);\n361:   const allReferences: string[] = [];\n362:   for (const references of Object.values(causalLinks)) {\n363:     if (Array.isArray(references)) {\n364:       allReferences.push(...references);\n365:     }\n366:   }\n367:   const resolvedReferenceMap = resolveMemoryReferencesBatch(database, allReferences);\n368: \n369:   for (const [link_type, references] of Object.entries(causalLinks)) {\n370:     if (!Array.isArray(references) || references.length === 0) {\n371:       continue;\n372:     }\n373: \n374:     const mapping = CAUSAL_LINK_MAPPINGS[link_type];\n375:     if (!mapping) {\n376:       console.warn(`[causal-links] Unknown link type: ${link_type}`);\n377:       continue;\n378:     }\n379: \n380:     for (const reference of references) {\n381:       result.processed++;\n382: \n383:       let resolvedId: number | null;\n384:       try {\n385:         const candidate = resolvedReferenceMap.get(reference);\n386:         resolvedId = typeof candidate === 'number' ? candidate : null;\n387:       } catch (err: unknown) {\n388:         const message = toErrorMessage(err);\n389:         result.errors.push({ type: link_type, reference, error: `Resolution failed: ${message}` });\n390:         console.warn(`[causal-links] Failed to resolve reference \"${reference}\": ${message}`);\n391:         continue;\n392:       }\n393: \n394:       if (!resolvedId) {\n395:         result.unresolved.push({ type: link_type, reference });\n396:         continue;\n397:       }\n398: \n399:       result.resolved++;\n400: \n401:       const edgeSourceId = mapping.reverse ? String(resolvedId) : memoryIdStr;\n402:       const edgeTargetId = mapping.reverse ? memoryIdStr : String(resolvedId);\n403: \n404:       try {\n405:         // causalEdges.insertEdge returns `number | null`. The\n406:         // null path covers: database not initialized, self-loop rejected,\n407:         // edge bounds exceeded, contradiction detected, non-finite strength\n408:         // clamp. Previously the count incremented unconditionally, masking\n409:         // these skip reasons. We now gate on a real (non-null) return id\n410:         // and record the skip reason in `result.errors` when null is\n411:         // returned so downstream callers see exactly what was dropped.\n412:         const insertedRowId = causalEdges.insertEdge(\n413:           edgeSourceId,\n414:           edgeTargetId,\n415:           mapping.relation,\n416:           1.0,\n417:           `Auto-extracted from ${link_type} in memory file`,\n418:           true,\n419:           'auto-causal-links',\n420:         );\n421:         if (insertedRowId !== null) {\n422:           result.inserted++;\n423:           console.error(`[causal-links] Inserted edge id=${insertedRowId}: ${edgeSourceId} -[${mapping.relation}]-> ${edgeTargetId}`);\n424:         } else {\n425:           const outcome = causalEdges.getLastInsertEdgeOutcome();\n426:           // Surface skipped reasons rather than masking them.\n427:           result.errors.push({\n428:             type: link_type,\n429:             reference,\n430:             error: outcome?.reason === 'skipped manual edge'\n431:               ? 'skipped manual edge'\n432:               : 'edge insert returned null (db not ready, self-loop, edge cap, or contradiction)',\n433:           });\n434:           console.warn(`[causal-links] Edge insert returned null (skipped): ${edgeSourceId} -[${mapping.relation}]-> ${edgeTargetId}`);\n435:         }\n436:       } catch (err: unknown) {\n437:         const message = toErrorMessage(err);\n438:         if (message.includes('UNIQUE constraint')) {\n439:           console.error(`[causal-links] Edge already exists: ${edgeSourceId} -[${mapping.relation}]-> ${edgeTargetId}`);\n440:         } else {\n441:           result.errors.push({ type: link_type, reference, error: message });\n442:           console.warn(`[causal-links] Failed to insert edge: ${message}`);\n443:         }\n444:       }\n445:     }\n446:   }\n447: \n448:   return result;\n449: }\n450: \n451: // ───────────────────────────────────────────────────────────────────\n452: // 6. EXPORTS\n453: // ───────────────────────────────────────────────────────────────────\n454: \n455: export {\n456:   processCausalLinks,\n457:   resolveMemoryReference,\n458:   resolveMemoryReferencesBatch,\n459:   CAUSAL_LINK_MAPPINGS,\n460: };\n461: \n462: // Re-export from handler-utils for backward compatibility\n463: export { detectSpecLevelFromParsed } from './handler-utils.js';\n464: \n465: export type {\n466:   CausalLinkMapping,\n467:   CausalLinksResult,\n468: };\n\n(End of file - total 468 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Causal Links Processor\n// ────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ───────────────────────────────────────────────────────────────────\n\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { CausalLinks } from '../lib/parsing/memory-parser.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { escapeLikePattern } from './handler-utils.js';\n\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Feature catalog: Causal edge deletion (memory_causal_unlink)\n// Feature catalog: Memory indexing (memory_save)\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-links-processor.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Causal Links Processor\n// ────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ───────────────────────────────────────────────────────────────────\n\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { CausalLinks } from '../lib/parsing/memory-parser.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { escapeLikePattern } from './handler-utils.js';\n\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Feature catalog: Causal edge deletion (memory_causal_unlink)\n// Feature catalog: Memory indexing (memory_save)\n\n// ───────────────────────────────────────────────────────────────────\n// 2. TYPES\n// ───────────────────────────────────────────────────────────────────\n\ninterface CausalLinkMapping {\n  relation: typeof causalEdges.RELATION_TYPES[keyof typeof causalEdges.RELATION_TYPES];\n  reverse: boolean;\n}\n\ninterface CausalLinksResult {\n  processed: number;\n  inserted: number;\n  resolved: number;\n  unresolved: { type: string; reference: string }[];\n  errors: { type: string; reference: string; error: string }[];\n}\n\ninterface MemoryIdRow {\n  id: number;\n}\n\ninterface PathLookupRow extends MemoryIdRow {\n  canonical_file_path: string | null;\n  file_path: string | null;\n  spec_folder: string | null;\n}\n\ninterface TitleLookupRow extends MemoryIdRow {\n  title: string | null;\n}\n\ninterface PreparedReference {\n  original: string;\n  trimmed: string;\n  normalizedReference: string;\n  normalizedLower: string;\n  escapedLike: string;\n  numericId: number | null;\n  isSessionLike: boolean;\n  isPathLike: boolean;\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 3. CONSTANTS\n// ───────────────────────────────────────────────────────────────────\n\nconst CAUSAL_LINK_MAPPINGS: Record<string, CausalLinkMapping> = {\n  caused_by: { relation: causalEdges.RELATION_TYPES.CAUSED, reverse: true },\n  supersedes: { relation: causalEdges.RELATION_TYPES.SUPERSEDES, reverse: false },\n  derived_from: { relation: causalEdges.RELATION_TYPES.DERIVED_FROM, reverse: false },\n  blocks: { relation: causalEdges.RELATION_TYPES.ENABLED, reverse: true },\n  related_to: { relation: causalEdges.RELATION_TYPES.SUPPORTS, reverse: false }\n};\n\n// ───────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\n/** Resolve a memory reference (ID, path, or title) to a numeric memory ID */\nfunction resolveMemoryReference(database: BetterSqlite3.Database, reference: string): number | null {\n  const resolved = resolveMemoryReferencesBatch(database, [reference]).get(reference);\n  return typeof resolved === 'number' ? resolved : null;\n}\n\nfunction buildPreparedReference(reference: string): PreparedReference | null {\n  if (!reference || typeof reference !== 'string') {\n    return null;\n  }\n\n  const trimmed = reference.trim();\n  if (!trimmed) {\n    return null;\n  }\n\n  const normalizedReference = trimmed.replace(/\\\\/g, '/');\n  const normalizedLower = normalizedReference.toLowerCase();\n  const numericId = /^\\d+$/.test(trimmed) ? Number.parseInt(trimmed, 10) : null;\n\n  return {\n    original: reference,\n    trimmed,\n    normalizedReference,\n    normalizedLower,\n    escapedLike: escapeLikePattern(normalizedReference),\n    numericId: Number.isFinite(numericId) ? numericId : null,\n    isSessionLike: normalizedLower.includes('session') || /^\\d{4}-\\d{2}-\\d{2}/.test(normalizedReference),\n    isPathLike:\n      normalizedLower.includes('specs/')\n      || normalizedLower.includes('memory/')\n      || normalizedReference.includes('/'),\n  };\n}\n\nfunction buildPathExactCandidates(normalizedReference: string): string[] {\n  const candidates = new Set<string>();\n\n  const canonical = getCanonicalPathKey(normalizedReference);\n  const trimmedLeadingSlash = normalizedReference.replace(/^\\/+/, '');\n\n  candidates.add(normalizedReference);\n  candidates.add(canonical);\n  candidates.add(trimmedLeadingSlash);\n  if (!normalizedReference.startsWith('/')) {\n    candidates.add(`/${normalizedReference}`);\n  }\n  if (!canonical.startsWith('/')) {\n    candidates.add(`/${canonical}`);\n  }\n\n  return Array.from(candidates).filter((candidate) => candidate.length > 0);\n}\n\nfunction buildInClause(values: readonly unknown[]): string {\n  return values.map(() => '?').join(', ');\n}\n\nfunction getMemoryIndexColumns(database: BetterSqlite3.Database): Set<string> {\n  const rows = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name?: string }>;\n  return new Set(rows.map((row) => row.name).filter((name): name is string => typeof name === 'string'));\n}\n\n/** Resolve many memory references in batch (exact first, fuzzy fallback). */\nfunction resolveMemoryReferencesBatch(\n  database: BetterSqlite3.Database,\n  references: readonly string[],\n): Map<string, number | null> {\n  const resolved = new Map<string, number | null>();\n  const preparedRefs: PreparedReference[] = [];\n  const memoryIndexColumns = getMemoryIndexColumns(database);\n  const hasCanonicalFilePath = memoryIndexColumns.has('canonical_file_path');\n\n  for (const reference of references) {\n    const prepared = buildPreparedReference(reference);\n    if (!prepared) {\n      resolved.set(reference, null);\n      continue;\n    }\n    preparedRefs.push(prepared);\n    resolved.set(reference, null);\n  }\n\n  if (preparedRefs.length === 0) {\n    return resolved;\n  }\n\n  const unresolved = (reference: PreparedReference): boolean => {\n    return !resolved.has(reference.original) || resolved.get(reference.original) == null;\n  };\n\n  const setResolved = (reference: PreparedReference, id: number | null): void => {\n    if (typeof id === 'number' && Number.isFinite(id)) {\n      resolved.set(reference.original, id);\n    }\n  };\n\n  // 1) Batch numeric IDs\n  const numericIds = Array.from(\n    new Set(preparedRefs.map((ref) => ref.numericId).filter((id): id is number => typeof id === 'number')),\n  );\n  if (numericIds.length > 0) {\n    const numericRows = database.prepare(`\n      SELECT id\n      FROM memory_index\n      WHERE id IN (${buildInClause(numericIds)})\n    `).all(...numericIds) as MemoryIdRow[];\n    const foundIds = new Set(numericRows.map((row) => row.id));\n    for (const ref of preparedRefs) {\n      if (!unresolved(ref) || ref.numericId == null) {\n        continue;\n      }\n      if (foundIds.has(ref.numericId)) {\n        setResolved(ref, ref.numericId);\n      }\n    }\n  }\n\n  // 2) Batch exact path matches via canonical_file_path/file_path equality\n  const pathCandidates = new Set<string>();\n  const pathCandidateRefs = new Map<string, PreparedReference[]>();\n  for (const ref of preparedRefs) {\n    if (!unresolved(ref) || (!ref.isPathLike && !ref.isSessionLike)) {\n      continue;\n    }\n\n    for (const candidate of buildPathExactCandidates(ref.normalizedReference)) {\n      pathCandidates.add(candidate);\n      const current = pathCandidateRefs.get(candidate) ?? [];\n      current.push(ref);\n      pathCandidateRefs.set(candidate, current);\n    }\n  }\n\n  if (pathCandidates.size > 0) {\n    const values = Array.from(pathCandidates);\n    const inClause = buildInClause(values);\n  const pathRows = hasCanonicalFilePath\n      ? database.prepare(`\n        SELECT id, canonical_file_path, file_path, spec_folder\n        FROM memory_index\n        WHERE canonical_file_path IN (${inClause})\n           OR file_path IN (${inClause})\n           OR spec_folder IN (${inClause})\n        ORDER BY id DESC\n      `).all(...values, ...values, ...values) as PathLookupRow[]\n      : database.prepare(`\n        SELECT id, NULL AS canonical_file_path, file_path, spec_folder\n        FROM memory_index\n        WHERE file_path IN (${inClause})\n           OR spec_folder IN (${inClause})\n        ORDER BY id DESC\n      `).all(...values, ...values) as PathLookupRow[];\n\n    const idByCandidate = new Map<string, number>();\n    for (const row of pathRows) {\n      const rowKeys = [row.canonical_file_path, row.file_path, row.spec_folder].filter((value): value is string => typeof value === 'string');\n      for (const rowKey of rowKeys) {\n        if (!idByCandidate.has(rowKey)) {\n          idByCandidate.set(rowKey, row.id);\n        }\n      }\n    }\n\n    for (const [candidate, refs] of pathCandidateRefs.entries()) {\n      const id = idByCandidate.get(candidate);\n      if (typeof id !== 'number') {\n        continue;\n      }\n      for (const ref of refs) {\n        if (unresolved(ref)) {\n          setResolved(ref, id);\n        }\n      }\n    }\n  }\n\n  // 3) Batch exact title matches\n  const titleCandidates = Array.from(new Set(\n    preparedRefs\n      .filter((ref) => unresolved(ref))\n      .map((ref) => ref.trimmed),\n  ));\n\n  if (titleCandidates.length > 0) {\n    const titleRows = database.prepare(`\n      SELECT id, title\n      FROM memory_index\n      WHERE title IN (${buildInClause(titleCandidates)})\n      ORDER BY id DESC\n    `).all(...titleCandidates) as TitleLookupRow[];\n\n    const idByTitle = new Map<string, number>();\n    for (const row of titleRows) {\n      if (typeof row.title !== 'string' || idByTitle.has(row.title)) {\n        continue;\n      }\n      idByTitle.set(row.title, row.id);\n    }\n\n    for (const ref of preparedRefs) {\n      if (!unresolved(ref)) {\n        continue;\n      }\n      const id = idByTitle.get(ref.trimmed);\n      if (typeof id === 'number') {\n        setResolved(ref, id);\n      }\n    }\n  }\n\n  // 4) Fuzzy fallback (LIKE with leading wildcard is intentionally last-resort)\n  const byPathFallbackStmt = hasCanonicalFilePath\n    ? database.prepare(`\n      SELECT id\n      FROM memory_index\n      WHERE canonical_file_path LIKE ? ESCAPE '\\\\'\n         OR file_path LIKE ? ESCAPE '\\\\'\n      ORDER BY id DESC\n      LIMIT 1\n    `)\n    : database.prepare(`\n      SELECT id\n      FROM memory_index\n      WHERE file_path LIKE ? ESCAPE '\\\\'\n      ORDER BY id DESC\n      LIMIT 1\n    `);\n  const byTitlePartialStmt = database.prepare(`\n    SELECT id\n    FROM memory_index\n    WHERE title LIKE ? ESCAPE '\\\\'\n    ORDER BY id DESC\n    LIMIT 1\n  `);\n\n  for (const ref of preparedRefs) {\n    if (!unresolved(ref)) {\n      continue;\n    }\n\n    if (ref.isSessionLike || ref.isPathLike) {\n      const byPath = hasCanonicalFilePath\n        ? byPathFallbackStmt.get(`%${ref.escapedLike}%`, `%${ref.escapedLike}%`) as MemoryIdRow | undefined\n        : byPathFallbackStmt.get(`%${ref.escapedLike}%`) as MemoryIdRow | undefined;\n      if (byPath) {\n        setResolved(ref, byPath.id);\n        continue;\n      }\n    }\n\n    const byTitlePartial = byTitlePartialStmt.get(`%${escapeLikePattern(ref.trimmed)}%`) as MemoryIdRow | undefined;\n    if (byTitlePartial) {\n      setResolved(ref, byTitlePartial.id);\n    }\n  }\n\n  return resolved;\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 5. CORE LOGIC\n// ───────────────────────────────────────────────────────────────────\n\n/** Process causal link declarations from a memory file and insert edges into the graph */\nfunction processCausalLinks(database: BetterSqlite3.Database, memoryId: number, causalLinks: CausalLinks): CausalLinksResult {\n  const result: CausalLinksResult = {\n    processed: 0,\n    inserted: 0,\n    resolved: 0,\n    unresolved: [],\n    errors: []\n  };\n\n  if (!causalLinks || typeof causalLinks !== 'object') {\n    return result;\n  }\n\n  // Initialize causal-edges module with database connection\n  causalEdges.init(database);\n\n  const memoryIdStr = String(memoryId);\n  const allReferences: string[] = [];\n  for (const references of Object.values(causalLinks)) {\n    if (Array.isArray(references)) {\n      allReferences.push(...references);\n    }\n  }\n  const resolvedReferenceMap = resolveMemoryReferencesBatch(database, allReferences);\n\n  for (const [link_type, references] of Object.entries(causalLinks)) {\n    if (!Array.isArray(references) || references.length === 0) {\n      continue;\n    }\n\n    const mapping = CAUSAL_LINK_MAPPINGS[link_type];\n    if (!mapping) {\n      console.warn(`[causal-links] Unknown link type: ${link_type}`);\n      continue;\n    }\n\n    for (const reference of references) {\n      result.processed++;\n\n      let resolvedId: number | null;\n      try {\n        const candidate = resolvedReferenceMap.get(reference);\n        resolvedId = typeof candidate === 'number' ? candidate : null;\n      } catch (err: unknown) {\n        const message = toErrorMessage(err);\n        result.errors.push({ type: link_type, reference, error: `Resolution failed: ${message}` });\n        console.warn(`[causal-links] Failed to resolve reference \"${reference}\": ${message}`);\n        continue;\n      }\n\n      if (!resolvedId) {\n        result.unresolved.push({ type: link_type, reference });\n        continue;\n      }\n\n      result.resolved++;\n\n      const edgeSourceId = mapping.reverse ? String(resolvedId) : memoryIdStr;\n      const edgeTargetId = mapping.reverse ? memoryIdStr : String(resolvedId);\n\n      try {\n        // causalEdges.insertEdge returns `number | null`. The\n        // null path covers: database not initialized, self-loop rejected,\n        // edge bounds exceeded, contradiction detected, non-finite strength\n        // clamp. Previously the count incremented unconditionally, masking\n        // these skip reasons. We now gate on a real (non-null) return id\n        // and record the skip reason in `result.errors` when null is\n        // returned so downstream callers see exactly what was dropped.\n        const insertedRowId = causalEdges.insertEdge(\n          edgeSourceId,\n          edgeTargetId,\n          mapping.relation,\n          1.0,\n          `Auto-extracted from ${link_type} in memory file`,\n          true,\n          'auto-causal-links',\n        );\n        if (insertedRowId !== null) {\n          result.inserted++;\n          console.error(`[causal-links] Inserted edge id=${insertedRowId}: ${edgeSourceId} -[${mapping.relation}]-> ${edgeTargetId}`);\n        } else {\n          const outcome = causalEdges.getLastInsertEdgeOutcome();\n          // Surface skipped reasons rather than masking them.\n          result.errors.push({\n            type: link_type,\n            reference,\n            error: outcome?.reason === 'skipped manual edge'\n              ? 'skipped manual edge'\n              : 'edge insert returned null (db not ready, self-loop, edge cap, or contradiction)',\n          });\n          console.warn(`[causal-links] Edge insert returned null (skipped): ${edgeSourceId} -[${mapping.relation}]-> ${edgeTargetId}`);\n        }\n      } catch (err: unknown) {\n        const message = toErrorMessage(err);\n        if (message.includes('UNIQUE constraint')) {\n          console.error(`[causal-links] Edge already exists: ${edgeSourceId} -[${mapping.relation}]-> ${edgeTargetId}`);\n        } else {\n          result.errors.push({ type: link_type, reference, error: message });\n          console.warn(`[causal-links] Failed to insert edge: ${message}`);\n        }\n      }\n    }\n  }\n\n  return result;\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 6. EXPORTS\n// ───────────────────────────────────────────────────────────────────\n\nexport {\n  processCausalLinks,\n  resolveMemoryReference,\n  resolveMemoryReferencesBatch,\n  CAUSAL_LINK_MAPPINGS,\n};\n\n// Re-export from handler-utils for backward compatibility\nexport { detectSpecLevelFromParsed } from './handler-utils.js';\n\nexport type {\n  CausalLinkMapping,\n  CausalLinksResult,\n};","lineStart":1,"lineEnd":468,"totalLines":468,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/causal-links-processor.ts","time":{"start":1781762676400,"end":1781762676404}},"metadata":{"openai":{"itemId":"fc_0eee0a4785417890016a338a74292881919ac7a5dbe378402e"}},"id":"prt_ed954d661001Fqq3ukp5FKpXiw","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed954a837001ZSjuFNxCLCd2ax"}}
