iteration prompt template. `post-dispatch-validate` checks that an iteration produced valid markdown, J...\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-speckit/027-xce-research-based-refinement/005-verification-and-remediation/007-release-alignment-review/003-readme-remediation/fixers/AF04.out.json:\n  Line 28: {\"type\":\"tool_use\",\"timestamp\":1781783569144,\"sessionID\":\"ses_1256d4ed4ffen8v1O1UaVmlyQN\",\"part\":{\"type\":\"tool\",\"tool\":\"glob\",\"callID\":\"call_Jrpk27qCqMiie8X0YnYLbEjT\",\"state\":{\"status\":\"completed\",\"input\":{\"pattern\":\".opencode/skills/deep-loop-workflows/deep-improvement/scripts/*.cjs\",\"path\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public\"},\"output\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/check-agent-mirror-sync.cjs\",\"metadata\":{\"count\":1,\"truncated\":false},\"title\":\"\",\"time\":{\"start\":1781783568912,\"end\":1781783569133}},\"metadata\":{\"openai\":{\"itemId\":\"fc_0947047cb703aa4f016a33dc10bd348191ad5dc0b599435acb\"}},\"id\":\"prt_eda93a20d001MLqbq8k7r1Aucv\",\"sessionID\":\"ses_1256d4ed4ffen8v1O1UaVmlyQN\",\"messageID\":\"msg_eda9370ac001J1aEk2LVNzcqXc\"}}\n","metadata":{"matches":61,"truncated":false},"title":"check-agent-mirror-sync|deep-loop-workflows/deep-improvement/scripts/check-agent-mirror-sync","time":{"start":1783487206709,"end":1783487207399}},"metadata":{"openai":{"itemId":"fc_08b47c33535e2684016a4ddae68098819185a296b65cf99891"}},"id":"prt_f401f1505001gDpWH7AA6cQtY4","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f401ef5d5001WMUT2Sv4wzffLJ"}}
