y.js';\n21: // Artifact-class routing (spec/plan/tasks/checklist/memory)\n22: import { getStrategyForQuery } from '../lib/search/artifact-routing.js';\n23: import { routeQuery } from '../lib/search/query-router.js';\n24: import { createEmptyQueryPlan, type QueryPlan } from '../lib/query/query-plan.js';\n25: import { getGraphReadinessSnapshotFromMarker } from '../lib/code-graph-boundary.js';\n26: import { mapGraphReadinessToTelemetry } from '../lib/search/graph-readiness-mapper.js';\n27: import {\n28:   buildSearchDecisionEnvelope,\n29:   type SearchDecisionEnvelope,\n30: } from '../lib/search/search-decision-envelope.js';\n31: import { recordSearchDecision } from '../lib/search/decision-audit.js';\n32: // Chunk reassembly (extracted from this file)\n33: import { collapseAndReassembleChunkResults } from '../lib/search/chunk-reassembly.js';\n34: // Search utilities (extracted from this file)\n35: import {\n36:   filterByMinQualityScore,\n37:   resolveQualityThreshold,\n38:   buildCacheArgs,\n39:   resolveRowContextType,\n40:   resolveArtifactRoutingQuery,\n41:   applyArtifactRouting,\n42: } from '../lib/search/search-utils.js';\n43: // CacheArgsInput used internally by buildCacheArgs (lib/search/search-utils.ts)\n44: // Eval channel tracking (extracted from this file)\n45: import {\n46:   collectEvalChannelsFromRow,\n47:   buildEvalChannelPayloads,\n48:   summarizeGraphWalkDiagnostics,\n49: } from '../lib/telemetry/eval-channel-tracking.js';\n50: import type { EvalChannelPayload } from '../lib/telemetry/eval-channel-tracking.js';\n51: \n52: // Eval logger — fail-safe, no-op when SPECKIT_EVAL_LOGGING !== \"true\"\n53: import { logSearchQuery, logChannelResult, logFinalResult } from '../lib/eval/eval-logger.js';\n54: import {\n55:   logFeedbackEvents,\n56:   isImplicitFeedbackLogEnabled,\n57: } from '../lib/feedback/feedback-ledger.js';\n58: import type { FeedbackEvent } from '../lib/feedback/feedback-ledger.js';\n59: import { trackQueryAndDetect, logResultCited } from '../lib/feedback/query-flow-tracker.js';\n60: \n61: // Core utilities\n62: import { checkDatabaseUpdated } from '../core/index.js';\n63: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n64: import { validateQuery, requireDb, toErrorMessage } from '../utils/index.js';\n65: \n66: // Response envelope + formatters\n67: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n68: import { formatSearchResults } from '../formatters/index.js';\n69: \n70: // Shared handler types\n71: import type { MCPResponse, IntentClassification } from './types.js';\n72: \n73: // Retrieval trace contracts (C136-08)\n74: import { createTrace } from '@spec-kit/shared/contracts/retrieval-trace';\n75: import { buildAdaptiveShadowProposal } from '../lib/cognitive/adaptive-ranking.js';\n76: import { normalizeScopeContext, filterRowsByScope } from '../lib/governance/scope-governance.js';\n77: import {\n78:   attachSessionTransitionTrace,\n79:   type SessionTransitionTrace,\n80: } from '../lib/search/session-transition.js';\n81: \n82: // Mode-Aware Response Shape\n83: import {\n84:   applyProfileToEnvelope,\n85:   isResponseProfileEnabled,\n86: } from '../lib/response/profile-formatters.js';\n87: import {\n88:   buildProgressiveResponse,\n89:   extractSnippets,\n90:   isProgressiveDisclosureEnabled,\n91:   resolveCursor,\n92: } from '../lib/search/progressive-disclosure.js';\n93: import {\n94:   SPEC_DOCUMENT_FILENAMES,\n95:   canClassifyAsSpecDocument,\n96:   normalizeSpecPath,\n97: } from '../lib/config/spec-doc-paths.js';\n98: import {\n99:   getLastLexicalCapabilitySnapshot,\n100:   resetLastLexicalCapabilitySnapshot,\n101: } from '../lib/search/sqlite-fts.js';\n102: import type { LexicalCapabilitySnapshot } from '../lib/search/sqlite-fts.js';\n103: import { evaluatePublicationGate } from '../lib/context/publication-gate.js';\n104: import {\n105:   deduplicateResults as deduplicateWithSessionState,\n106:   isSessionRetrievalStateEnabled,\n107:   manager as retrievalSessionStateManager,\n108:   refineForGoal,\n109: } from '../lib/search/session-state.js';\n110: \n111: // Type imports for casting\n112: import type { IntentType, IntentWeights as IntentClassifierWeights } from '../lib/search/intent-classifier.js';\n113: import type { RawSearchResult } from '../formatters/index.js';\n114: // RoutingResult, WeightedResult — now used internally by lib/search/search-utils.ts\n115: \n116: // Feature catalog: Semantic and lexical search (memory_search)\n117: // Feature catalog: Hybrid search pipeline\n118: // Feature catalog: 4-stage pipeline architecture\n119: // Feature catalog: Quality-aware 3-tier search fallback\n120: \n121: \n122: /* ───────────────────────────────────────────────────────────────\n123:    2. TYPES\n124: ──────────────────────────────────────────────────────────────── */\n125: \n126: /**\n127:  * Internal search result row — enriched DB row used within this handler.\n128:  * NOT the same as the canonical SearchResult in shared/types.ts.\n129:  * Self-contained: uses local types instead of the deprecated MemoryRow/MemoryRecord shapes.\n130:  * This can migrate to MemoryDbRow & Record<string, unknown> later without changing the handler contract.\n131:  */\n132: interface MemorySearchRow extends Record<string, unknown> {\n133:   id: number;\n134:   similarity?: number;\n135:   importance_tier?: string;\n136:   contextType?: string;\n137:   context_type?: string;\n138:   attentionScore?: number;\n139:   retrievability?: number;\n140:   stability?: number;\n141:   last_review?: string | null;\n142:   created_at?: string;\n143:   last_accessed?: number;\n144:   content?: string;\n145:   memoryState?: string;\n146:   file_path?: string;\n147:   parent_id?: number | null;\n148:   chunk_index?: number | null;\n149:   chunk_label?: string | null;\n150:   isChunk?: boolean;\n151:   parentId?: number | null;\n152:   chunkIndex?: number | null;\n153:   chunkLabel?: string | null;\n154:   chunkCount?: number | null;\n155:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n156:   precomputedContent?: string;\n157: }\n158: \n159: interface DedupResult {\n160:   results: MemorySearchRow[];\n161:   dedupStats: Record<string, unknown>;\n162: }\n163: \n164: interface SearchCachePayload {\n165:   summary: string;\n166:   data: Record<string, unknown>;\n167:   hints: string[];\n168: }\n169: \n170: type SessionAwareResult = Record<string, unknown> & {\n171:   id: number | string;\n172:   score?: number;\n173:   content?: string;\n174: };\n175: \n176: type CanonicalSourceKind = 'spec_doc' | 'continuity' | 'constitutional';\n177: \n178: interface CanonicalSourceStats {\n179:   retained: number;\n180:   dropped: number;\n181:   bySourceKind: Record<CanonicalSourceKind, number>;\n182: }\n183: \n184: const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n185: const CANONICAL_READER_CACHE_VERSION = 'gate-d-reader-ready-v1';\n186: const CANONICAL_SPEC_DOC_DOCUMENT_TYPES = new Set([\n187:   'spec',\n188:   'plan',\n189:   'tasks',\n190:   'checklist',\n191:   'decision_record',\n192:   'implementation_summary',\n193:   'research',\n194:   'handover',\n195:   'graph_metadata',\n196:   'spec_doc',\n197: ]);\n198: const NON_CANONICAL_DOCUMENT_TYPES = new Set([\n199:   'memory',\n200:   'scratch',\n201: ]);\n202: \n203: function normalizeDocumentType(value: unknown): string | null {\n204:   if (typeof value !== 'string') {\n205:     return null;\n206:   }\n207:   const normalized = value.trim().toLowerCase();\n208:   return normalized.length > 0 ? normalized : null;\n209: }\n210: \n211: function resolveAnchorId(row: Record<string, unknown>): string | null {\n212:   const value = row.anchor_id ?? row.anchorId;\n213:   return typeof value === 'string' && value.trim().length > 0\n214:     ? value.trim()\n215:     : null;\n216: }\n217: \n218: function resolveFilePath(row: Record<string, unknown>): string | null {\n219:   const value = row.file_path ?? row.filePath;\n220:   return typeof value === 'string' && value.trim().length > 0\n221:     ? value\n222:     : null;\n223: }\n224: \n225: function resolveCanonicalSourceKind(row: Record<string, unknown>): CanonicalSourceKind | null {\n226:   const documentType = normalizeDocumentType(row.document_type ?? row.documentType);\n227:   const importanceTier = normalizeDocumentType(row.importance_tier ?? row.importanceTier);\n228:   const anchorId = resolveAnchorId(row);\n229: \n230:   if (importanceTier === 'constitutional' || documentType === 'constitutional') {\n231:     return 'constitutional';\n232:   }\n233: \n234:   if (anchorId === CONTINUITY_ANCHOR_ID || documentType === 'continuity') {\n235:     return 'continuity';\n236:   }\n237: \n238:   if (documentType && CANONICAL_SPEC_DOC_DOCUMENT_TYPES.has(documentType)) {\n239:     return 'spec_doc';\n240:   }\n241: \n242:   if (documentType && NON_CANONICAL_DOCUMENT_TYPES.has(documentType)) {\n243:     return null;\n244:   }\n245: \n246:   const filePath = resolveFilePath(row);\n247:   if (!filePath) {\n248:     return null;\n249:   }\n250:   const normalizedPath = normalizeSpecPath(filePath);\n251:   const basename = normalizedPath.split('/').filter(Boolean).pop() ?? '';\n252: \n253:   if (\n254:     basename.length > 0 &&\n255:     SPEC_DOCUMENT_FILENAMES.has(basename) &&\n256:     canClassifyAsSpecDocument(normalizedPath)\n257:   ) {\n258:     return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n259:   }\n260: \n\n(Showing lines 1-260 of 1657. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Search\n// ───────────────────────────────────────────────────────────────\n/* ───────────────────────────────────────────────────────────────\n   1. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\nimport * as intentClassifier from '../lib/search/intent-classifier.js';\n// TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\nimport { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\nimport { searchCommunities } from '../lib/search/community-search.js';\n// 4-stage pipeline architecture\nimport { executePipeline } from '../lib/search/pipeline/index.js';\nimport type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\nimport type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\nimport { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Search\n// ───────────────────────────────────────────────────────────────\n/* ───────────────────────────────────────────────────────────────\n   1. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\nimport * as intentClassifier from '../lib/search/intent-classifier.js';\n// TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\nimport { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\nimport { searchCommunities } from '../lib/search/community-search.js';\n// 4-stage pipeline architecture\nimport { executePipeline } from '../lib/search/pipeline/index.js';\nimport type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\nimport type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\nimport { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n// Artifact-class routing (spec/plan/tasks/checklist/memory)\nimport { getStrategyForQuery } from '../lib/search/artifact-routing.js';\nimport { routeQuery } from '../lib/search/query-router.js';\nimport { createEmptyQueryPlan, type QueryPlan } from '../lib/query/query-plan.js';\nimport { getGraphReadinessSnapshotFromMarker } from '../lib/code-graph-boundary.js';\nimport { mapGraphReadinessToTelemetry } from '../lib/search/graph-readiness-mapper.js';\nimport {\n  buildSearchDecisionEnvelope,\n  type SearchDecisionEnvelope,\n} from '../lib/search/search-decision-envelope.js';\nimport { recordSearchDecision } from '../lib/search/decision-audit.js';\n// Chunk reassembly (extracted from this file)\nimport { collapseAndReassembleChunkResults } from '../lib/search/chunk-reassembly.js';\n// Search utilities (extracted from this file)\nimport {\n  filterByMinQualityScore,\n  resolveQualityThreshold,\n  buildCacheArgs,\n  resolveRowContextType,\n  resolveArtifactRoutingQuery,\n  applyArtifactRouting,\n} from '../lib/search/search-utils.js';\n// CacheArgsInput used internally by buildCacheArgs (lib/search/search-utils.ts)\n// Eval channel tracking (extracted from this file)\nimport {\n  collectEvalChannelsFromRow,\n  buildEvalChannelPayloads,\n  summarizeGraphWalkDiagnostics,\n} from '../lib/telemetry/eval-channel-tracking.js';\nimport type { EvalChannelPayload } from '../lib/telemetry/eval-channel-tracking.js';\n\n// Eval logger — fail-safe, no-op when SPECKIT_EVAL_LOGGING !== \"true\"\nimport { logSearchQuery, logChannelResult, logFinalResult } from '../lib/eval/eval-logger.js';\nimport {\n  logFeedbackEvents,\n  isImplicitFeedbackLogEnabled,\n} from '../lib/feedback/feedback-ledger.js';\nimport type { FeedbackEvent } from '../lib/feedback/feedback-ledger.js';\nimport { trackQueryAndDetect, logResultCited } from '../lib/feedback/query-flow-tracker.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { validateQuery, requireDb, toErrorMessage } from '../utils/index.js';\n\n// Response envelope + formatters\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { formatSearchResults } from '../formatters/index.js';\n\n// Shared handler types\nimport type { MCPResponse, IntentClassification } from './types.js';\n\n// Retrieval trace contracts (C136-08)\nimport { createTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { buildAdaptiveShadowProposal } from '../lib/cognitive/adaptive-ranking.js';\nimport { normalizeScopeContext, filterRowsByScope } from '../lib/governance/scope-governance.js';\nimport {\n  attachSessionTransitionTrace,\n  type SessionTransitionTrace,\n} from '../lib/search/session-transition.js';\n\n// Mode-Aware Response Shape\nimport {\n  applyProfileToEnvelope,\n  isResponseProfileEnabled,\n} from '../lib/response/profile-formatters.js';\nimport {\n  buildProgressiveResponse,\n  extractSnippets,\n  isProgressiveDisclosureEnabled,\n  resolveCursor,\n} from '../lib/search/progressive-disclosure.js';\nimport {\n  SPEC_DOCUMENT_FILENAMES,\n  canClassifyAsSpecDocument,\n  normalizeSpecPath,\n} from '../lib/config/spec-doc-paths.js';\nimport {\n  getLastLexicalCapabilitySnapshot,\n  resetLastLexicalCapabilitySnapshot,\n} from '../lib/search/sqlite-fts.js';\nimport type { LexicalCapabilitySnapshot } from '../lib/search/sqlite-fts.js';\nimport { evaluatePublicationGate } from '../lib/context/publication-gate.js';\nimport {\n  deduplicateResults as deduplicateWithSessionState,\n  isSessionRetrievalStateEnabled,\n  manager as retrievalSessionStateManager,\n  refineForGoal,\n} from '../lib/search/session-state.js';\n\n// Type imports for casting\nimport type { IntentType, IntentWeights as IntentClassifierWeights } from '../lib/search/intent-classifier.js';\nimport type { RawSearchResult } from '../formatters/index.js';\n// RoutingResult, WeightedResult — now used internally by lib/search/search-utils.ts\n\n// Feature catalog: Semantic and lexical search (memory_search)\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Quality-aware 3-tier search fallback\n\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Internal search result row — enriched DB row used within this handler.\n * NOT the same as the canonical SearchResult in shared/types.ts.\n * Self-contained: uses local types instead of the deprecated MemoryRow/MemoryRecord shapes.\n * This can migrate to MemoryDbRow & Record<string, unknown> later without changing the handler contract.\n */\ninterface MemorySearchRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  attentionScore?: number;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n}\n\ninterface DedupResult {\n  results: MemorySearchRow[];\n  dedupStats: Record<string, unknown>;\n}\n\ninterface SearchCachePayload {\n  summary: string;\n  data: Record<string, unknown>;\n  hints: string[];\n}\n\ntype SessionAwareResult = Record<string, unknown> & {\n  id: number | string;\n  score?: number;\n  content?: string;\n};\n\ntype CanonicalSourceKind = 'spec_doc' | 'continuity' | 'constitutional';\n\ninterface CanonicalSourceStats {\n  retained: number;\n  dropped: number;\n  bySourceKind: Record<CanonicalSourceKind, number>;\n}\n\nconst CONTINUITY_ANCHOR_ID = '_memory.continuity';\nconst CANONICAL_READER_CACHE_VERSION = 'gate-d-reader-ready-v1';\nconst CANONICAL_SPEC_DOC_DOCUMENT_TYPES = new Set([\n  'spec',\n  'plan',\n  'tasks',\n  'checklist',\n  'decision_record',\n  'implementation_summary',\n  'research',\n  'handover',\n  'graph_metadata',\n  'spec_doc',\n]);\nconst NON_CANONICAL_DOCUMENT_TYPES = new Set([\n  'memory',\n  'scratch',\n]);\n\nfunction normalizeDocumentType(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim().toLowerCase();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction resolveAnchorId(row: Record<string, unknown>): string | null {\n  const value = row.anchor_id ?? row.anchorId;\n  return typeof value === 'string' && value.trim().length > 0\n    ? value.trim()\n    : null;\n}\n\nfunction resolveFilePath(row: Record<string, unknown>): string | null {\n  const value = row.file_path ?? row.filePath;\n  return typeof value === 'string' && value.trim().length > 0\n    ? value\n    : null;\n}\n\nfunction resolveCanonicalSourceKind(row: Record<string, unknown>): CanonicalSourceKind | null {\n  const documentType = normalizeDocumentType(row.document_type ?? row.documentType);\n  const importanceTier = normalizeDocumentType(row.importance_tier ?? row.importanceTier);\n  const anchorId = resolveAnchorId(row);\n\n  if (importanceTier === 'constitutional' || documentType === 'constitutional') {\n    return 'constitutional';\n  }\n\n  if (anchorId === CONTINUITY_ANCHOR_ID || documentType === 'continuity') {\n    return 'continuity';\n  }\n\n  if (documentType && CANONICAL_SPEC_DOC_DOCUMENT_TYPES.has(documentType)) {\n    return 'spec_doc';\n  }\n\n  if (documentType && NON_CANONICAL_DOCUMENT_TYPES.has(documentType)) {\n    return null;\n  }\n\n  const filePath = resolveFilePath(row);\n  if (!filePath) {\n    return null;\n  }\n  const normalizedPath = normalizeSpecPath(filePath);\n  const basename = normalizedPath.split('/').filter(Boolean).pop() ?? '';\n\n  if (\n    basename.length > 0 &&\n    SPEC_DOCUMENT_FILENAMES.has(basename) &&\n    canClassifyAsSpecDocument(normalizedPath)\n  ) {\n    return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n  }\n","lineStart":1,"lineEnd":260,"totalLines":1657,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1780738218578,"end":1780738218585}},"metadata":{"openai":{"itemId":"fc_0ba051a4fa2a2d9c016a23e8aa79bc8191ae1eb680787e93fc"}},"id":"prt_e9c44da50001NRLiVXVsu2mO32","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c44a065001e6aOre36aWfwzo"}}
