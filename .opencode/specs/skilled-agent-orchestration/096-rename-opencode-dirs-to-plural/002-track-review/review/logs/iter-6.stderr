import path from 'node:path';
import { createRequire } from 'node:module';
const require = createRequire(import.meta.url);
const { resolveArtifactRoot } = require('./.opencode/skills/system-spec-kit/shared/review-research-paths.cjs');
const cases = [
  ['empty', ''],
  ['whitespace', '   \\t  '],
  ['dotdot', '..'],
  ['absolute_tmp', '/tmp/hostile-spec'],
  ['absolute_existing_packet', path.resolve('.opencode/specs/skilled-agent-orchestration/097-track-review')],
  ['glob', '.opencode/specs/*'],
  ['template_literal', '{spec_folder}'],
  ['template_dollar', '"'${spec_folder}'"'],
  ['relative_valid', '.opencode/specs/skilled-agent-orchestration/097-track-review'],
  ['nested_child_valid', '.opencode/specs/skilled-agent-orchestration/097-track-review/001-child'],
];
for (const [name, input] of cases) {
  try {
    const out = resolveArtifactRoot(input, 'review');
    console.log(JSON.stringify({name,input,specDir:out.specDir,artifactDir:out.artifactDir,packetDir:out.packetDir ?? null}));
  } catch (err) {
    console.log(JSON.stringify({name,input,error:String(err && err.message || err)}));
  }
}
