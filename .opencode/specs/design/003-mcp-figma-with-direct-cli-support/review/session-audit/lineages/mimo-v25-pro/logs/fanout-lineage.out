tion-setup/binary-detection.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/manual_testing_playbook/02--daemon-health/daemon-status-diagnose.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/manual_testing_playbook/05--optional-mcp/framelink-discovery.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/manual_testing_playbook/04--safety-gate/destructive-verb-refused.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/manual_testing_playbook/manual_testing_playbook.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/manual_testing_playbook/03--read-only/read-only-inspect.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/manual_testing_playbook/03--read-only/read-only-export.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/INSTALL_GUIDE.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/install.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-safe.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/daemon.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/unpatch.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/print-utcp-snippets.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-yolo.sh\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/_common.sh\n/