    49	  const rows = Array.isArray(report && report.scenarioRows) ? report.scenarioRows : [];
    50	  const gatedRows = rows.filter((row) => row && row.errorClass != null);
    51	  if (excluded.length === 0 && gatedRows.length === 0) return problems;
    52	
    53	  if (!report || !report.targetSkill || !report.targetSkill.root) {
