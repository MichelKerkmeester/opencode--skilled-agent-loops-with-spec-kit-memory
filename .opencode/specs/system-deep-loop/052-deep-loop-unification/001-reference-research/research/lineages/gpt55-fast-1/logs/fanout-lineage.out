sets/deep_research_auto.yaml:64-77\",\n         \".opencode/commands/doctor/_routes.yaml:100-110\",\n         \".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2570-2587\"\n       ]\n+    },\n+    {\n+      \"id\": \"q-speckit-borrow\",\n+      \"text\": \"Which system-spec-kit tooling should be borrowed, wrapped, or left external instead of duplicated inside the merged deep-loop system?\",\n+      \"resolvedAtIteration\": 3,\n+      \"answer\": \"Keep spec-folder topology, validation, templates, memory/context save, and canonical resource-map extraction under system-spec-kit. Consume them through narrow deep-loop seams and rewrite external consumer configs rather than duplicating the tooling.\",\n+      \"sources\": [\n+        \".opencode/skills/system-spec-kit/SKILL.md:61\",\n+        \".opencode/skills/deep-loop-runtime/lib/deep-loop/artifact-root.cjs:4-18\",\n+        \".opencode/skills/deep-loop-workflows/shared/synthesis/resource-map.cjs:4-18\"\n+      ]\n     }\n   ],\n   \"keyFindings\": [\n     {\n@@ -104,8 +115,49 @@\n       \"sources\": [\n         \".opencode/skills/system-spec-kit/mcp_server/vitest.config.ts:15-22\",\n         \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json:7-18\"\n       ]\n+    },\n+    {\n+      \"id\": \"f-003-speckit-governance-external\",\n+      \"title\": \"Spec-kit governance stays external\",\n+      \"summary\": \"Spec validation, templates, generate-context continuity, and memory save remain system-spec-kit ownership; deep-loop should not duplicate them.\",\n+      \"iteration\": 3,\n+      \"sources\": [\n+        \".opencode/skills/system-spec-kit/SKILL.md:61\",\n+        \".opencode/skills/system-spec-kit/SKILL.md:414-418\",\n+        \".opencode/skills/system-spec-kit/SKILL.md:439\"\n+      ]\n+    },\n+    {\n+      \"id\": \"f-003-artifact-root-seam\",\n+      \"title\": \"Artifact topology remains single-source via runtime seam\",\n+      \"summary\": \"`artifact-root.cjs` re-exports the system-spec-kit topology resolver so deep-loop consumers use a backend seam without copying the artifact contract.\",\n+      \"iteration\": 3,\n+      \"sources\": [\n+        \".opencode/skills/deep-loop-runtime/lib/deep-loop/artifact-root.cjs:4-18\",\n+        \".opencode/skills/system-spec-kit/shared/review-research-paths.cjs:166-214\"\n+      ]\n+    },\n+    {\n+      \"id\": \"f-003-resource-map-seam\",\n+      \"title\": \"Resource-map rendering is workflow synthesis\",\n+      \"summary\": \"The workflow shared synthesis seam re-exports the canonical system-spec-kit extractor because rendering resource-map markdown is workflow output, not runtime backend plumbing.\",\n+      \"iteration\": 3,\n+      \"sources\": [\n+        \".opencode/skills/deep-loop-workflows/shared/synthesis/resource-map.cjs:4-18\",\n+        \".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs:14-20\"\n+      ]\n+    },\n+    {\n+      \"id\": \"f-003-dev-tool-borrow\",\n+      \"title\": \"Runtime has a narrow dev-tool dependency borrow\",\n+      \"summary\": \"Runtime typecheck and type roots still point at system-spec-kit node_modules; this is package hygiene for the merge, not a reason to duplicate spec-kit governance.\",\n+      \"iteration\": 3,\n+      \"sources\": [\n+        \".opencode/skills/deep-loop-runtime/package.json:10-17\",\n+        \".opencode/skills/deep-loop-runtime/tsconfig.json:12-14\"\n+      ]\n     }\n   ],\n   \"ruledOutDirections\": [\n     {\n@@ -118,12 +170,18 @@\n       \"approach\": \"Move directories first and rely on generated contracts to catch up\",\n       \"reason\": \"Generated contracts are outputs; source YAML, advisor code, agents, and test configs must rewrite first.\",\n       \"iteration\": 2,\n       \"evidence\": \".opencode/commands/deep/assets/compiled/deep_research.contract.md:1-80\"\n+    },\n+    {\n+      \"approach\": \"Duplicate system-spec-kit governance tooling inside system-deep-loop\",\n+      \"reason\": \"Spec-folder validation, continuity, memory save, and canonical templates are system-spec-kit ownership, not deep-loop runtime ownership.\",\n+      \"iteration\": 3,\n+      \"evidence\": \".opencode/skills/system-spec-kit/SKILL.md:61; .opencode/skills/deep-loop-runtime/README.md:120-127\"\n     }\n   ],\n   \"carriedForwardOpenQuestions\": [\n-    \"Which system-spec-kit tooling should remain borrowed/external instead of moving into system-deep-loop?\"\n+    \"What exact reference migration is required across commands, agents, READMEs, skill docs, feature catalogs, manual testing playbooks, specs, advisor metadata, and generated records?\"\n   ],\n   \"blockedStopHistory\": [],\n   \"rejectedPatterns\": [],\n   \"rejectedPatternIndex\": {\n@@ -136,13 +194,13 @@\n   \"promotedIdeas\": [],\n   \"suppressedIdeas\": [],\n   \"suppressedCandidates\": [],\n   \"metrics\": {\n-    \"iterationsCompleted\": 2,\n-    \"openQuestions\": 3,\n-    \"resolvedQuestions\": 2,\n-    \"keyFindings\": 5,\n-    \"convergenceScore\": 0.4,\n+    \"iterationsCompleted\": 3,\n+    \"openQuestions\": 2,\n+    \"resolvedQuestions\": 3,\n+    \"keyFindings\": 9,\n+    \"convergenceScore\": 0.6,\n     \"coverageBySources\": {\n       \".opencode/skills/deep-loop-workflows/SKILL.md\": 3,\n       \".opencode/skills/deep-loop-workflows/mode-registry.json\": 2,\n       \".opencode/skills/deep-loop-runtime/README.md\": 3,\n@@ -153,8 +211,16 @@\n       \".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py\": 1,\n       \".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts\": 1,\n       \".opencode/skills/system-spec-kit/mcp_server/vitest.config.ts\": 1,\n       \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\": 2,\n-      \".opencode/skills/deep-loop-runtime/references/integration_points.md\": 1\n+      \".opencode/skills/deep-loop-runtime/references/integration_points.md\": 1,\n+      \".opencod