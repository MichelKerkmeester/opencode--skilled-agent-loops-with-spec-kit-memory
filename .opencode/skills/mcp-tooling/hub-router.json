{
  "skill": "mcp-tooling",
  "version": "1.0.0.0",
  "routerPolicy": {
    "defaultMode": "mcp-chrome-devtools",
    "ambiguityDelta": 1,
    "tieBreak": [
      "mcp-chrome-devtools",
      "mcp-click-up",
      "mcp-aside-devtools",
      "mcp-figma",
      "mcp-refero",
      "mcp-mobbin"
    ],
    "outcomes": {
      "single": "one dominant tool signal routes to one mode",
      "orderedBundle": "multiple explicitly requested tools route in tie-break order",
      "defer": "unclear or contradictory tool intent asks for disambiguation"
    },
    "defaultResource": [
      "mcp-chrome-devtools/SKILL.md"
    ]
  },
  "routerSignals": {
    "mcp-chrome-devtools": {
      "weight": 4,
      "classes": [
        "chrome-devtools-aliases",
        "browser-debug",
        "hub-identity"
      ],
      "resources": [
        "mcp-chrome-devtools/SKILL.md"
      ]
    },
    "mcp-click-up": {
      "weight": 4,
      "classes": [
        "clickup-aliases",
        "task-management",
        "hub-identity"
      ],
      "resources": [
        "mcp-click-up/SKILL.md"
      ]
    },
    "mcp-aside-devtools": {
      "weight": 4,
      "classes": [
        "aside-devtools-aliases",
        "agentic-browser",
        "hub-identity"
      ],
      "resources": [
        "mcp-aside-devtools/SKILL.md"
      ]
    },
    "mcp-figma": {
      "weight": 4,
      "classes": [
        "figma-aliases",
        "design-transport",
        "hub-identity"
      ],
      "resources": [
        "mcp-figma/SKILL.md"
      ]
    },
    "mcp-refero": {
      "weight": 4,
      "classes": [
        "refero-aliases",
        "design-reference-research",
        "hub-identity"
      ],
      "resources": [
        "mcp-refero/SKILL.md"
      ]
    },
    "mcp-mobbin": {
      "weight": 4,
      "classes": [
        "mobbin-aliases",
        "app-design-research",
        "hub-identity"
      ],
      "resources": [
        "mcp-mobbin/SKILL.md"
      ]
    }
  },
