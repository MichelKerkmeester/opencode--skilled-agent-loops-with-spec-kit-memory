{"type":"tool_use","timestamp":1784313829513,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_9gevi3HPIVBuKMM7WQHkts6I","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","offset":2670,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n2670:     '## 10. GRAPH CONVERGENCE',\n2671:     `- graphConvergenceScore: ${Number.isFinite(registry.graphConvergenceScore) ? registry.graphConvergenceScore.toFixed(2) : '[Not recorded]'}`,\n2672:     `- graphDecision: ${registry.graphDecision || '[Not recorded]'}`,\n2673:     ...(registry.graphBlockers.length\n2674:       ? registry.graphBlockers.map((blocker) => `- Blocker: ${formatGraphBlocker(blocker)}`)\n2675:       : ['- graphBlockers: none recorded']),\n2676:     '',\n2677:     '<!-- /ANCHOR:graph-convergence -->',\n2678:     '',\n2679:   ].join('\\n');\n2680: }\n2681: \n2682: /**\n2683:  * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n2684:  * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n2685:  *\n2686:  * @param {string} specFolder - Path to the target spec folder for the research packet\n2687:  * @param {Object} [options] - Reducer options\n2688:  * @param {boolean} [options.write=true] - Write outputs to disk when true\n2689:  * @returns {Object} Paths and content for registry, strategy, and dashboard\n2690:  */\n2691: function reduceResearchState(specFolder, options = {}) {\n2692:   const write = options.write !== false;\n2693:   const lenient = Boolean(options.lenient);\n2694:   const emitResourceMapOutput = Boolean(options.emitResourceMap);\n2695:   const requireExistingState = Boolean(options.requireExistingState);\n2696:   const resolvedSpecFolder = path.resolve(specFolder);\n2697:   const { artifactDir: researchDir } = resolveArtifactRoot(resolvedSpecFolder, 'research');\n2698:   const configPath = path.join(researchDir, 'deep-research-config.json');\n2699:   const stateLogPath = path.join(researchDir, 'deep-research-state.jsonl');\n2700:   const strategyPath = path.join(researchDir, 'deep-research-strategy.md');\n2701:   const registryPath = path.join(researchDir, 'findings-registry.json');\n2702:   const documentedRegistryPath = path.join(researchDir, 'deep-research-findings-registry.json');\n2703:   const dashboardPath = path.join(researchDir, 'deep-research-dashboard.md');\n2704:   const resourceMapPath = path.join(researchDir, 'resource-map.md');\n2705:   const inboxPath = path.join(researchDir, INBOX_FILE_NAME);\n2706:   const iterationDir = path.join(researchDir, 'iterations');\n2707:   const deltaDir = path.join(researchDir, 'deltas');\n2708: \n2709:   const config = readJson(configPath);\n2710:   const { records: parsedRecords, corruptionWarnings } = readStateLogForReduction(stateLogPath, requireExistingState);\n2711:   // Allowlist: only iteration + event types bear completion semantics. Progress\n2712:   // records (type:'progress') are additive liveness signals — they reset the\n2713:   // no-progress watchdog but MUST NOT count as iterations or completion events.\n2714:   const completionBearingRecords = filterCompletionBearingRecords(parsedRecords);\n2715:   const records = completionBearingRecords.filter((record) => record.type === 'iteration');\n2716:   const mainEvents = completionBearingRecords.filter((record) => record.type === 'event');\n2717:   const pivotEvents = loadPivotEventRecords(researchDir);\n2718:   const events = mainEvents.concat(pivotEvents);\n2719:   const strategyContent = readUtf8(strategyPath);\n2720:   const strategyQuestions = parseStrategyQuestions(strategyContent);\n2721:   const inbox = readInboxQuestions(inboxPath);\n2722:   const priorRegistry = readPriorQuestionRegistry(registryPath, documentedRegistryPath);\n2723:   const questionResolution = resolveQuestionConflicts({\n2724:     strategyQuestions,\n2725:     inboxQuestions: inbox.questions,\n2726:     priorRegistry,\n2727:   });\n2728:   const questionInputs = questionResolution.questions;\n2729:   if (write) {\n2730:     warnLegacyImportQuestions(questionInputs);\n2731:   }\n2732:   for (const warning of inbox.warnings) {\n2733:     console.warn(`[deep-research] skipped inbox record: ${warning}`);\n2734:   }\n2735:   const iterationFiles = fs.existsSync(iterationDir)\n2736:     ? fs.readdirSync(iterationDir)\n2737:         .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n2738:         .sort((a, b) => {\n2739:           // Numeric sort on trailing iter number; default .sort() puts iteration-10.md between iteration-1.md and iteration-2.md.\n2740:           const numA = parseInt(a.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n2741:           const numB = parseInt(b.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n2742:           return numA - numB;\n2743:         })\n2744:         .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n2745:     : [];\n2746: \n2747:   const terminalStop = buildTerminalStopState(completionBearingRecords);\n2748:   const lineage = buildLineageState(config, events);\n2749:   config.lineage = {\n2750:     ...(config.lineage && typeof config.lineage === 'object' ? config.lineage : {}),\n2751:     sessionId: lineage.sessionId,\n2752:     parentSessionId: lineage.parentSessionId,\n2753:     lineageMode: lineage.lineageMode,\n2754:     generation: lineage.generation,\n2755:     continuedFromRun: lineage.continuedFromRun,\n2756:   };\n2757:   const status = deriveDashboardStatus(config, records, events, terminalStop);\n2758:   const registry = buildRegistry(questionInputs, iterationFiles, records, events, {\n2759:     lineage,\n2760:     terminalStop,\n2761:     status,\n2762:     questionConflicts: questionResolution.questionConflicts,\n2763:     rejectedPatternFuzzyThreshold: resolveRejectedPatternFuzzyThreshold(config),\n2764:     minIdeaObservations: resolveMinIdeaObservations(config),\n2765:   });\n2766:   // Expose corruptionWarnings as a top-level registry field for parity with\n2767:   // deep-review.\n2768:   registry.corruptionWarnings = corruptionWarnings;\n2769:   registry.inboxPath = inboxPath;\n2770:   registry.inboxWarnings = inbox.warnings;\n2771:   registry.status = status;\n2772:   if (write) {\n2773:     for (const warning of registry.rejectedPatternWarnings) {\n2774:       console.warn(warning);\n2775:     }\n2776:   }\n2777:   const evidenceRecords = records.filter((record) => record.status !== 'thought');\n2778:   const ratioHistory = evidenceRecords\n2779:     .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n2780:     .filter((value) => value !== null);\n2781:   const scoreHistory = evidenceRecords\n2782:     .map(readIterationScore)\n2783:     .filter(isFiniteNumber);\n2784:   registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n2785:     newInfoRatio: ratioHistory,\n2786:     score: scoreHistory,\n2787:   }, evidenceRecords.at(-1));\n2788:   const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n2789:   const dashboard = renderDashboard(config, registry, records, iterationFiles);\n2790:   let resourceMap = null;\n2791:   let resourceMapSkipped = true;\n2792:   let resourceMapSkipReason = null;\n2793: \n2794:   if (corruptionWarnings.length > 0 && !lenient) {\n2795:     throw createCorruptionError(stateLogPath, corruptionWarnings);\n2796:   }\n2797: \n2798:   if (emitResourceMapOutput) {\n2799:     if (getResourceMapEmitSetting(config) === false) {\n2800:       resourceMapSkipReason = 'config.resource_map.emit=false';\n2801:     } else {\n2802:       const deltaPayloads = loadDeltaPayloads(deltaDir);\n2803:       if (!deltaPayloads.length) {\n2804:         resourceMapSkipReason = 'no delta files found';\n2805:       } else {\n2806:         resourceMap = emitResourceMap({\n2807:           shape: 'research',\n2808:           deltas: deltaPayloads,\n2809:           packet: {\n2810:             title: config.topic || path.basename(resolvedSpecFolder),\n2811:             specFolder: resolvedSpecFolder,\n2812:           },\n2813:           scope: `research convergence output for ${path.basename(resolvedSpecFolder)}`,\n2814:           createdAt: new Date().toISOString(),\n2815:         });\n2816:         resourceMapSkipped = false;\n2817:       }\n2818:     }\n2819:   }\n2820: \n2821:   if (write) {\n2822:     appendQuestionConflictEvents(stateLogPath, questionResolution.questionConflicts, events, {\n2823:       run: records.at(-1)?.run ?? null,\n2824:       sessionId: registry.sessionId || null,\n2825:       generation: registry.generation ?? null,\n2826:     });\n2827:     appendIdeaPromotionEvents(stateLogPath, registry.promotedIdeas, events, {\n2828:       run: records.at(-1)?.run ?? null,\n2829:       minIdeaObservations: registry.minIdeaObservations,\n2830:       sessionId: registry.sessionId || null,\n2831:       generation: registry.generation ?? null,\n2832:     });\n2833:     writeUtf8(registryPath, `${JSON.stringify(registry, null, 2)}\\n`);\n2834:     writeUtf8(strategyPath, strategy.endsWith('\\n') ? strategy : `${strategy}\\n`);\n2835:     writeUtf8(dashboardPath, dashboard);\n2836:     if (emitResourceMapOutput && resourceMap) {\n2837:       writeUtf8(resourceMapPath, resourceMap);\n2838:     }\n2839:   }\n2840: \n2841:   return {\n2842:     configPath,\n2843:     stateLogPath,\n2844:     strategyPath,\n2845:     registryPath,\n2846:     dashboardPath,\n2847:     resourceMapPath,\n2848:     registry,\n2849:     strategy,\n2850:     dashboard,\n2851:     resourceMap,\n2852:     resourceMapSkipped,\n2853:     resourceMapSkipReason,\n2854:     corruptionWarnings,\n2855:     hasCorruption: corruptionWarnings.length > 0,\n2856:   };\n2857: }\n2858: \n2859: // ─────────────────────────────────────────────────────────────────────────────\n2860: // 5. CLI ENTRY POINT\n2861: // ─────────────────────────────────────────────────────────────────────────────\n2862: \n2863: if (require.main === module) {\n2864:   const args = process.argv.slice(2);\n2865:   const lenient = args.includes('--lenient');\n2866:   const emitResourceMapOutput = args.includes('--emit-resource-map');\n2867:   const requireExistingState = args.includes('--require-existing-state');\n2868:   const positional = args.filter((arg) => !arg.startsWith('--'));\n2869:   const specFolder = positional[0];\n2870: \n2871:   if (!specFolder) {\n2872:     process.stderr.write(\n2873:       'Usage: node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n2874:     );\n2875:     process.exit(1);\n2876:   }\n2877: \n2878:   try {\n2879:     const result = reduceResearchState(specFolder, {\n2880:       write: true,\n2881:       lenient,\n2882:       emitResourceMap: emitResourceMapOutput,\n2883:       requireExistingState,\n2884:     });\n2885:     process.stdout.write(\n2886:       `${JSON.stringify(\n2887:         {\n2888:           registryPath: result.registryPath,\n2889:           dashboardPath: result.dashboardPath,\n2890:           strategyPath: result.strategyPath,\n2891:           iterationsCompleted: result.registry.metrics.iterationsCompleted,\n2892:           corruptionCount: result.corruptionWarnings.length,\n2893:           resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n2894:           resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n2895:           resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n2896:         },\n2897:         null,\n2898:         2,\n2899:       )}\\n`,\n2900:     );\n2901:     // Fail-closed exit semantics matching deep-review.\n2902:     if (result.hasCorruption && !lenient) {\n2903:       process.exit(2);\n2904:     }\n2905:   } catch (error) {\n2906:     if (error && error.code === 'STATE_RECOVERY_REFUSED') {\n2907:       process.stderr.write(`${error.message}\\n`);\n2908:       process.exit(2);\n2909:     }\n2910:     if (error && error.code === 'STATE_CORRUPTION') {\n2911:       process.stderr.write(`${error.message}\\n`);\n2912:       process.exit(2);\n2913:     }\n2914:     process.stderr.write(`[deep-research] reducer failed: ${error instanceof Error ? error.message : String(error)}\\n`);\n2915:     process.exit(3);\n2916:   }\n2917: }\n2918: \n2919: // ─────────────────────────────────────────────────────────────────────────────\n2920: // 6. EXPORTS\n2921: // ─────────────────────────────────────────────────────────────────────────────\n2922: \n2923: module.exports = {\n2924:   buildGraphConvergenceRollup,\n2925:   buildLineageState,\n2926:   buildTerminalStopState,\n2927:   buildTrendFlatlineAdvisories,\n2928:   computeGraphConvergenceScore,\n2929:   deriveRejectedPatternIndex,\n2930:   deriveDashboardStatus,\n2931:   filterRejectedIdeaCandidates,\n2932:   findRejectedPatternMatch,\n2933:   formatTrendAdvisoryEvent,\n2934:   parseIterationFile,\n2935:   parseJsonl,\n2936:   parseJsonlDetailed,\n2937:   reduceResearchState,\n2938:   renderSparkline,\n2939:   readStateLogForReduction,\n2940:   resolveQuestionConflicts,\n2941: };\n\n(End of file - total 2941 lines)\n</content>","metadata":{"preview":"    '## 10. GRAPH CONVERGENCE',\n    `- graphConvergenceScore: ${Number.isFinite(registry.graphConvergenceScore) ? registry.graphConvergenceScore.toFixed(2) : '[Not recorded]'}`,\n    `- graphDecision: ${registry.graphDecision || '[Not recorded]'}`,\n    ...(registry.graphBlockers.length\n      ? registry.graphBlockers.map((blocker) => `- Blocker: ${formatGraphBlocker(blocker)}`)\n      : ['- graphBlockers: none recorded']),\n    '',\n    '<!-- /ANCHOR:graph-convergence -->',\n    '',\n  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the research packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","text":"    '## 10. GRAPH CONVERGENCE',\n    `- graphConvergenceScore: ${Number.isFinite(registry.graphConvergenceScore) ? registry.graphConvergenceScore.toFixed(2) : '[Not recorded]'}`,\n    `- graphDecision: ${registry.graphDecision || '[Not recorded]'}`,\n    ...(registry.graphBlockers.length\n      ? registry.graphBlockers.map((blocker) => `- Blocker: ${formatGraphBlocker(blocker)}`)\n      : ['- graphBlockers: none recorded']),\n    '',\n    '<!-- /ANCHOR:graph-convergence -->',\n    '',\n  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the research packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard\n */\nfunction reduceResearchState(specFolder, options = {}) {\n  const write = options.write !== false;\n  const lenient = Boolean(options.lenient);\n  const emitResourceMapOutput = Boolean(options.emitResourceMap);\n  const requireExistingState = Boolean(options.requireExistingState);\n  const resolvedSpecFolder = path.resolve(specFolder);\n  const { artifactDir: researchDir } = resolveArtifactRoot(resolvedSpecFolder, 'research');\n  const configPath = path.join(researchDir, 'deep-research-config.json');\n  const stateLogPath = path.join(researchDir, 'deep-research-state.jsonl');\n  const strategyPath = path.join(researchDir, 'deep-research-strategy.md');\n  const registryPath = path.join(researchDir, 'findings-registry.json');\n  const documentedRegistryPath = path.join(researchDir, 'deep-research-findings-registry.json');\n  const dashboardPath = path.join(researchDir, 'deep-research-dashboard.md');\n  const resourceMapPath = path.join(researchDir, 'resource-map.md');\n  const inboxPath = path.join(researchDir, INBOX_FILE_NAME);\n  const iterationDir = path.join(researchDir, 'iterations');\n  const deltaDir = path.join(researchDir, 'deltas');\n\n  const config = readJson(configPath);\n  const { records: parsedRecords, corruptionWarnings } = readStateLogForReduction(stateLogPath, requireExistingState);\n  // Allowlist: only iteration + event types bear completion semantics. Progress\n  // records (type:'progress') are additive liveness signals — they reset the\n  // no-progress watchdog but MUST NOT count as iterations or completion events.\n  const completionBearingRecords = filterCompletionBearingRecords(parsedRecords);\n  const records = completionBearingRecords.filter((record) => record.type === 'iteration');\n  const mainEvents = completionBearingRecords.filter((record) => record.type === 'event');\n  const pivotEvents = loadPivotEventRecords(researchDir);\n  const events = mainEvents.concat(pivotEvents);\n  const strategyContent = readUtf8(strategyPath);\n  const strategyQuestions = parseStrategyQuestions(strategyContent);\n  const inbox = readInboxQuestions(inboxPath);\n  const priorRegistry = readPriorQuestionRegistry(registryPath, documentedRegistryPath);\n  const questionResolution = resolveQuestionConflicts({\n    strategyQuestions,\n    inboxQuestions: inbox.questions,\n    priorRegistry,\n  });\n  const questionInputs = questionResolution.questions;\n  if (write) {\n    warnLegacyImportQuestions(questionInputs);\n  }\n  for (const warning of inbox.warnings) {\n    console.warn(`[deep-research] skipped inbox record: ${warning}`);\n  }\n  const iterationFiles = fs.existsSync(iterationDir)\n    ? fs.readdirSync(iterationDir)\n        .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n        .sort((a, b) => {\n          // Numeric sort on trailing iter number; default .sort() puts iteration-10.md between iteration-1.md and iteration-2.md.\n          const numA = parseInt(a.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n          const numB = parseInt(b.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n          return numA - numB;\n        })\n        .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n    : [];\n\n  const terminalStop = buildTerminalStopState(completionBearingRecords);\n  const lineage = buildLineageState(config, events);\n  config.lineage = {\n    ...(config.lineage && typeof config.lineage === 'object' ? config.lineage : {}),\n    sessionId: lineage.sessionId,\n    parentSessionId: lineage.parentSessionId,\n    lineageMode: lineage.lineageMode,\n    generation: lineage.generation,\n    continuedFromRun: lineage.continuedFromRun,\n  };\n  const status = deriveDashboardStatus(config, records, events, terminalStop);\n  const registry = buildRegistry(questionInputs, iterationFiles, records, events, {\n    lineage,\n    terminalStop,\n    status,\n    questionConflicts: questionResolution.questionConflicts,\n    rejectedPatternFuzzyThreshold: resolveRejectedPatternFuzzyThreshold(config),\n    minIdeaObservations: resolveMinIdeaObservations(config),\n  });\n  // Expose corruptionWarnings as a top-level registry field for parity with\n  // deep-review.\n  registry.corruptionWarnings = corruptionWarnings;\n  registry.inboxPath = inboxPath;\n  registry.inboxWarnings = inbox.warnings;\n  registry.status = status;\n  if (write) {\n    for (const warning of registry.rejectedPatternWarnings) {\n      console.warn(warning);\n    }\n  }\n  const evidenceRecords = records.filter((record) => record.status !== 'thought');\n  const ratioHistory = evidenceRecords\n    .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n    .filter((value) => value !== null);\n  const scoreHistory = evidenceRecords\n    .map(readIterationScore)\n    .filter(isFiniteNumber);\n  registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n    newInfoRatio: ratioHistory,\n    score: scoreHistory,\n  }, evidenceRecords.at(-1));\n  const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n  const dashboard = renderDashboard(config, registry, records, iterationFiles);\n  let resourceMap = null;\n  let resourceMapSkipped = true;\n  let resourceMapSkipReason = null;\n\n  if (corruptionWarnings.length > 0 && !lenient) {\n    throw createCorruptionError(stateLogPath, corruptionWarnings);\n  }\n\n  if (emitResourceMapOutput) {\n    if (getResourceMapEmitSetting(config) === false) {\n      resourceMapSkipReason = 'config.resource_map.emit=false';\n    } else {\n      const deltaPayloads = loadDeltaPayloads(deltaDir);\n      if (!deltaPayloads.length) {\n        resourceMapSkipReason = 'no delta files found';\n      } else {\n        resourceMap = emitResourceMap({\n          shape: 'research',\n          deltas: deltaPayloads,\n          packet: {\n            title: config.topic || path.basename(resolvedSpecFolder),\n            specFolder: resolvedSpecFolder,\n          },\n          scope: `research convergence output for ${path.basename(resolvedSpecFolder)}`,\n          createdAt: new Date().toISOString(),\n        });\n        resourceMapSkipped = false;\n      }\n    }\n  }\n\n  if (write) {\n    appendQuestionConflictEvents(stateLogPath, questionResolution.questionConflicts, events, {\n      run: records.at(-1)?.run ?? null,\n      sessionId: registry.sessionId || null,\n      generation: registry.generation ?? null,\n    });\n    appendIdeaPromotionEvents(stateLogPath, registry.promotedIdeas, events, {\n      run: records.at(-1)?.run ?? null,\n      minIdeaObservations: registry.minIdeaObservations,\n      sessionId: registry.sessionId || null,\n      generation: registry.generation ?? null,\n    });\n    writeUtf8(registryPath, `${JSON.stringify(registry, null, 2)}\\n`);\n    writeUtf8(strategyPath, strategy.endsWith('\\n') ? strategy : `${strategy}\\n`);\n    writeUtf8(dashboardPath, dashboard);\n    if (emitResourceMapOutput && resourceMap) {\n      writeUtf8(resourceMapPath, resourceMap);\n    }\n  }\n\n  return {\n    configPath,\n    stateLogPath,\n    strategyPath,\n    registryPath,\n    dashboardPath,\n    resourceMapPath,\n    registry,\n    strategy,\n    dashboard,\n    resourceMap,\n    resourceMapSkipped,\n    resourceMapSkipReason,\n    corruptionWarnings,\n    hasCorruption: corruptionWarnings.length > 0,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CLI ENTRY POINT\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const lenient = args.includes('--lenient');\n  const emitResourceMapOutput = args.includes('--emit-resource-map');\n  const requireExistingState = args.includes('--require-existing-state');\n  const positional = args.filter((arg) => !arg.startsWith('--'));\n  const specFolder = positional[0];\n\n  if (!specFolder) {\n    process.stderr.write(\n      'Usage: node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n    );\n    process.exit(1);\n  }\n\n  try {\n    const result = reduceResearchState(specFolder, {\n      write: true,\n      lenient,\n      emitResourceMap: emitResourceMapOutput,\n      requireExistingState,\n    });\n    process.stdout.write(\n      `${JSON.stringify(\n        {\n          registryPath: result.registryPath,\n          dashboardPath: result.dashboardPath,\n          strategyPath: result.strategyPath,\n          iterationsCompleted: result.registry.metrics.iterationsCompleted,\n          corruptionCount: result.corruptionWarnings.length,\n          resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n          resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n          resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n        },\n        null,\n        2,\n      )}\\n`,\n    );\n    // Fail-closed exit semantics matching deep-review.\n    if (result.hasCorruption && !lenient) {\n      process.exit(2);\n    }\n  } catch (error) {\n    if (error && error.code === 'STATE_RECOVERY_REFUSED') {\n      process.stderr.write(`${error.message}\\n`);\n      process.exit(2);\n    }\n    if (error && error.code === 'STATE_CORRUPTION') {\n      process.stderr.write(`${error.message}\\n`);\n      process.exit(2);\n    }\n    process.stderr.write(`[deep-research] reducer failed: ${error instanceof Error ? error.message : String(error)}\\n`);\n    process.exit(3);\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  buildGraphConvergenceRollup,\n  buildLineageState,\n  buildTerminalStopState,\n  buildTrendFlatlineAdvisories,\n  computeGraphConvergenceScore,\n  deriveRejectedPatternIndex,\n  deriveDashboardStatus,\n  filterRejectedIdeaCandidates,\n  findRejectedPatternMatch,\n  formatTrendAdvisoryEvent,\n  parseIterationFile,\n  parseJsonl,\n  parseJsonlDetailed,\n  reduceResearchState,\n  renderSparkline,\n  readStateLogForReduction,\n  resolveQuestionConflicts,\n};","lineStart":2670,"lineEnd":2941,"totalLines":2941,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","time":{"start":1784313829506,"end":1784313829511}},"metadata":{"openai":{"itemId":"fc_00de89c195a820dc016a5a77e45cd881918b7ee0c080083510"}},"id":"prt_f7164544900197y7N4L6Q7p85B","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f716440a8001U9vf1sWDACd5gn"}}
