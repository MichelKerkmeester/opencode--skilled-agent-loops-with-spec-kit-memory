{"type":"tool_use","timestamp":1780925435875,"sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","part":{"type":"tool","tool":"read","callID":"call_hVGilSdnjHwo4MKxZO9GxGHH","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts","offset":1,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Graph Search Fn\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Unified graph retrieval, deterministic ranking, explainability, and rollback\n5: // Causal graph search channel — uses FTS5 for node matching\n6: \n7: import { sanitizeFTS5Query } from './bm25-index.js';\n8: import { queryHierarchyMemories } from './spec-folder-hierarchy.js';\n9: import { registerDatabaseRebindListener } from '../../core/db-state.js';\n10: \n11: import type Database from 'better-sqlite3';\n12: import type { GraphSearchFn } from './search-types.js';\n13: \n14: // ───────────────────────────────────────────────────────────────\n15: // 1. TYPES\n16: \n17: // ───────────────────────────────────────────────────────────────\n18: interface CausalEdgeRow {\n19:   id: string;\n20:   source_id: string;\n21:   target_id: string;\n22:   relation: string;\n23:   strength: number;\n24: }\n25: \n26: interface DegreeCacheState {\n27:   perNodeBoost: Map<string, number>;\n28:   maxTypedDegree: number | null;\n29: }\n30: \n31: // ───────────────────────────────────────────────────────────────\n32: // 2. TYPED-DEGREE CONSTANTS\n33: \n34: // ───────────────────────────────────────────────────────────────\n35: /** Edge type weights for typed-degree computation (5th RRF channel) */\n36: const EDGE_TYPE_WEIGHTS: Record<string, number> = {\n37:   caused: 1.0,\n38:   derived_from: 0.9,\n39:   enabled: 0.8,\n40:   contradicts: 0.7,\n41:   supersedes: 0.6,\n42:   supports: 0.5,\n43: };\n44: \n45: /** Fallback maximum typed degree when no edges exist in the database */\n46: const DEFAULT_MAX_TYPED_DEGREE = 15;\n47: \n48: /** Hard cap on raw typed degree before normalization */\n49: const MAX_TOTAL_DEGREE = 50;\n50: \n51: /** Maximum normalized boost score */\n52: const DEGREE_BOOST_CAP = 0.15;\n53: \n54: /** Runtime fusion weight for the degree channel. Keep aligned with the boost cap. */\n55: const DEGREE_CHANNEL_WEIGHT = DEGREE_BOOST_CAP;\n56: \n57: // ───────────────────────────────────────────────────────────────\n58: // 3. CAUSAL EDGE CHANNEL (FTS5-BACKED)\n59: \n60: // ───────────────────────────────────────────────────────────────\n61: let ftsTableAvailabilityPerDb = new WeakMap<Database.Database, boolean>();\n62: \n63: /**\n64:  * Check whether the FTS5 table exists in the database.\n65:  * Used to determine if FTS5 matching is available.\n66:  *\n67:  * Cache is scoped per bound DB instance to avoid repeated sqlite_master probes.\n68:  */\n69: function isFtsTableAvailable(database: Database.Database): boolean {\n70:   const cached = ftsTableAvailabilityPerDb.get(database);\n71:   if (typeof cached === 'boolean') {\n72:     return cached;\n73:   }\n74: \n75:   try {\n76:     const result = (database.prepare(\n77:       `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n78:     ) as Database.Statement).get() as { name: string } | undefined;\n79:     const available = !!result;\n80:     ftsTableAvailabilityPerDb.set(database, available);\n81:     return available;\n82:   } catch (_err: unknown) {\n83:     ftsTableAvailabilityPerDb.set(database, false);\n84:     return false;\n85:   }\n86: }\n87: \n88: /**\n89:  * Find causal edges connected to memories matching the query.\n90:  *\n91:  * Uses FTS5 full-text search (memory_fts table) instead of naive LIKE matching.\n92:  * Falls back to LIKE only when the FTS5 table is not available.\n93:  */\n94: function queryCausalEdges(\n95:   database: Database.Database,\n96:   query: string,\n97:   limit: number,\n98:   specFolder?: string,\n99: ): Array<Record<string, unknown>> {\n100:   const graphResults: Array<Record<string, unknown>> = [];\n\n(Showing lines 1-100 of 703. Use offset=101 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Graph Search Fn\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Unified graph retrieval, deterministic ranking, explainability, and rollback\n// Causal graph search channel — uses FTS5 for node matching\n\nimport { sanitizeFTS5Query } from './bm25-index.js';\nimport { queryHierarchyMemories } from './spec-folder-hierarchy.js';\nimport { registerDatabaseRebindListener } from '../../core/db-state.js';\n\nimport type Database from 'better-sqlite3';\nimport type { GraphSearchFn } from './search-types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\ninterface CausalEdgeRow {\n  id: string;\n  source_id: string;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Graph Search Fn\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Unified graph retrieval, deterministic ranking, explainability, and rollback\n// Causal graph search channel — uses FTS5 for node matching\n\nimport { sanitizeFTS5Query } from './bm25-index.js';\nimport { queryHierarchyMemories } from './spec-folder-hierarchy.js';\nimport { registerDatabaseRebindListener } from '../../core/db-state.js';\n\nimport type Database from 'better-sqlite3';\nimport type { GraphSearchFn } from './search-types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\ninterface CausalEdgeRow {\n  id: string;\n  source_id: string;\n  target_id: string;\n  relation: string;\n  strength: number;\n}\n\ninterface DegreeCacheState {\n  perNodeBoost: Map<string, number>;\n  maxTypedDegree: number | null;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. TYPED-DEGREE CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\n/** Edge type weights for typed-degree computation (5th RRF channel) */\nconst EDGE_TYPE_WEIGHTS: Record<string, number> = {\n  caused: 1.0,\n  derived_from: 0.9,\n  enabled: 0.8,\n  contradicts: 0.7,\n  supersedes: 0.6,\n  supports: 0.5,\n};\n\n/** Fallback maximum typed degree when no edges exist in the database */\nconst DEFAULT_MAX_TYPED_DEGREE = 15;\n\n/** Hard cap on raw typed degree before normalization */\nconst MAX_TOTAL_DEGREE = 50;\n\n/** Maximum normalized boost score */\nconst DEGREE_BOOST_CAP = 0.15;\n\n/** Runtime fusion weight for the degree channel. Keep aligned with the boost cap. */\nconst DEGREE_CHANNEL_WEIGHT = DEGREE_BOOST_CAP;\n\n// ───────────────────────────────────────────────────────────────\n// 3. CAUSAL EDGE CHANNEL (FTS5-BACKED)\n\n// ───────────────────────────────────────────────────────────────\nlet ftsTableAvailabilityPerDb = new WeakMap<Database.Database, boolean>();\n\n/**\n * Check whether the FTS5 table exists in the database.\n * Used to determine if FTS5 matching is available.\n *\n * Cache is scoped per bound DB instance to avoid repeated sqlite_master probes.\n */\nfunction isFtsTableAvailable(database: Database.Database): boolean {\n  const cached = ftsTableAvailabilityPerDb.get(database);\n  if (typeof cached === 'boolean') {\n    return cached;\n  }\n\n  try {\n    const result = (database.prepare(\n      `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n    ) as Database.Statement).get() as { name: string } | undefined;\n    const available = !!result;\n    ftsTableAvailabilityPerDb.set(database, available);\n    return available;\n  } catch (_err: unknown) {\n    ftsTableAvailabilityPerDb.set(database, false);\n    return false;\n  }\n}\n\n/**\n * Find causal edges connected to memories matching the query.\n *\n * Uses FTS5 full-text search (memory_fts table) instead of naive LIKE matching.\n * Falls back to LIKE only when the FTS5 table is not available.\n */\nfunction queryCausalEdges(\n  database: Database.Database,\n  query: string,\n  limit: number,\n  specFolder?: string,\n): Array<Record<string, unknown>> {\n  const graphResults: Array<Record<string, unknown>> = [];","lineStart":1,"lineEnd":100,"totalLines":703,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts","time":{"start":1780925435859,"end":1780925435873}},"metadata":{"openai":{"itemId":"fc_09b999595329de51016a26c3fbce708191a3bda866cff2c4d2"}},"id":"prt_ea76d8fc7001bRrxYduT5UsK1a","sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","messageID":"msg_ea76d6d61001brZTPTjFoRNDQ7"}}
