pecs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_builders.py:\n  Line 26:     still live in `mcp_server.py`'s `@mcp.tool` decorators).\n\n  Line 131:         \"plugin_exposed\": spec.plugin_exposed,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_stats.py:\n  Line 24:     name=\"memclaw_stats\",\n\n  Line 27:     plugin_exposed=True,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_evolve.py:\n  Line 26:     name=\"memclaw_evolve\",\n\n  Line 29:     plugin_exposed=True,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_types.py:\n  Line 4: `mcp_server` derives `@mcp.tool` registrations from these. The plugin reads\n\n  Line 61:     live in `mcp_server.py`'s `@mcp.tool` decorators). Phase 2 wires real\n\n  Line 68:     plugin_exposed: bool = True\n\n  Line 84:         if self.impl_status == \"reserved\" and self.plugin_exposed:\n\n  Line 85:             raise ValueError(f\"reserved tools must set plugin_exposed=False: {self.name}\")\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_tune.py:\n  Line 16:     name=\"memclaw_tune\",\n\n  Line 19:     plugin_exposed=True,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_recall.py:\n  Line 20:     name=\"memclaw_recall\",\n\n  Line 23:     plugin_exposed=True,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/plugin/tools.json:\n  Line 8:     \"name\": \"memclaw_doc\",\n\n  Line 153:     \"plugin_exposed\": true,\n\n  Line 160:     \"name\": \"memclaw_entity_get\",\n\n  Line 170:     \"plugin_exposed\": true,\n\n  Line 177:     \"name\": \"memclaw_evolve\",\n\n  Line 221:     \"plugin_exposed\": true,\n\n  Line 228:     \"name\": \"memclaw_insights\",\n\n  Line 259:     \"plugin_exposed\": true,\n\n  Line 268:     \"name\": \"memclaw_keystones\",\n\n  Line 286:     \"plugin_exposed\": true,\n\n  Line 298:     \"name\": \"memclaw_keystones_set\",\n\n  Line 384:     \"plugin_exposed\": false,\n\n  Line 391:     \"name\": \"memclaw_list\",\n\n  Line 500:     \"plugin_exposed\": true,\n\n  Line 509:     \"name\": \"memclaw_manage\",\n\n  Line 623:     \"plugin_exposed\": true,\n\n  Line 630:     \"name\": \"memclaw_recall\",\n\n  Line 689:     \"plugin_exposed\": true,\n\n  Line 696:     \"name\": \"memclaw_stats\",\n\n  Line 742:     \"plugin_exposed\": true,\n\n  Line 749:     \"name\": \"memclaw_tune\",\n\n  Line 823:     \"plugin_exposed\": true,\n\n  Line 834:     \"name\": \"memclaw_write\",\n\n  Line 922:     \"plugin_exposed\": true,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_tools_registry.py:\n  Line 8: - ``impl_status=\"reserved\"`` implies ``plugin_exposed=False``.\n\n  Line 53: # tools — implementation is real, but they stay plugin_exposed=False until\n\n  Line 73: def test_reserved_implies_not_plugin_exposed():\n\n  Line 78:             assert spec.plugin_exposed is False, (\n\n  Line 79:                 f\"{spec.name}: reserved specs must set plugin_exposed=False\"\n\n  Line 119: def test_plugin_exposed_set_is_v1_surface():\n\n  Line 122:     exposed = {name for name, spec in REGISTRY.items() if spec.plugin_exposed}\n\n  Line 190: def test_mcp_only_tools_are_not_plugin_exposed():\n\n  Line 198:         assert REGISTRY[name].plugin_exposed is False, (\n\n  Line 212:         assert d[\"plugin_exposed\"] == spec.plugin_exposed\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_plugin_source_manifest.py:\n  Line 229:     ``alsoAllow`` because ``tools.json`` marks it ``plugin_exposed: false``\n\n  Line 233:     future plugin_exposed flip is picked up automatically.\n\n  Line 254:         \"Both lists must hold every ``plugin_exposed: true`` tool from \"\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/fixtures/tools_list_baseline_v1.json:\n  Line 3:     \"name\": \"memclaw_doc\",\n\n  Line 150:     \"name\": \"memclaw_entity_get\",\n\n  Line 174:     \"name\": \"memclaw_evolve\",\n\n  Line 245:     \"name\": \"memclaw_insights\",\n\n  Line 294:     \"name\": \"memclaw_keystones\",\n\n  Line 329:     \"name\": \"memclaw_keystones_set\",\n\n  Line 450:     \"name\": \"memclaw_list\",\n\n  Line 619:     \"name\": \"memclaw_manage\",\n\n  Line 763:     \"name\": \"memclaw_recall\",\n\n  Line 860:     \"name\": \"memclaw_stats\",\n\n  Line 933:     \"name\": \"memclaw_tune\",\n\n  Line 1072:     \"name\": \"memclaw_write\",\n","metadata":{"matches":94,"truncated":false},"title":"@mcp\\.tool|def memclaw_|name=\"memclaw_|plugin_exposed|\"name\": \"memclaw_","time":{"start":1780728406679,"end":1780728406698}},"metadata":{"openai":{"itemId":"fc_0f54eebdfaa63f7b016a23c256048c81918f3b4c7d0a87304e"}},"id":"prt_e9baf224a001347NlhCfzIuHAO","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baee63a001rxtH2xe8QMSIFO"}}
{"type":"step_finish","timestamp":1780728407020,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"id":"prt_e9baf23ea001CkQyW1UcBzXrvJ","reason":"tool-calls","snapshot":"2c10e11e7e78a5d432af4f38b53ac3e8fe874f4e","messageID":"msg_e9baee63a001rxtH2xe8QMSIFO","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","type":"step-finish","tokens":{"total":39602,"input":17967,"output":573,"reasoning":70,"cache":{"write":0,"read":20992}},"cost":0}}
{"type":"step_start","timestamp":1780728408442,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"id":"prt_e9baf2978001pyD84hdlaoQEmu","messageID":"msg_e9baf24f1001MpVDpIN74GuluG","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","snapshot":"73240a6137f243fe1eaf5ab6a0f793f6b91640aa","type":"step-start"}}
{"type":"text","timestamp":1780728421226,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"id":"prt_e9baf38f40015wMklKFNg0n3aX","messageID":"msg_e9baf24f1001MpVDpIN74GuluG","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","type":"text","text":"The actual MCP server defines 12 functions, and plugin metadata marks one as MCP-only, producing an 11-tool plugin contract; that distinction is central to the stable-vs-internal split.","time":{"start":1780728412404,"end":1780728421224},"metadata":{"openai":{"itemId":"msg_0033b7a40e8c48d1016a23c25c5b008191a53e9f62077e2a35","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780728421265,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_zSSCNZ4NqC5r8rspLkqpUbbl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","offset":321,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md</path>\n<type>file</type>\n<content>\n321:       \"headers\": { \"X-API-Key\": \"mc_your_api_key_here\" }\n322:     }\n323:   }\n324: }\n325: ```\n326: \n327: > For team or production use, swap the tenant-scoped key for an **agent-scoped credential** — atomic provisioning via `POST /api/v1/admin/agent-keys/provision` (or the `/settings/organization/api-credentials` wizard) mints the credential + Agent row + initial trust + fleet membership in one round trip. Both kinds use the `mc_` prefix; scope is set at mint time on the credential. See [`docs/integration-without-plugin.md`](docs/integration-without-plugin.md). Using a tenant-scoped credential? Pass an explicit `agent_id` on every MCP tool call — the gateway refuses the reserved default (`mcp-agent`) on the tenant-scoped path.\n328: \n329: **Where to add this config:**\n330: - **Claude Code** — `~/.claude/settings.json` under `\"mcpServers\"`\n331: - **Claude Desktop** — `~/Library/Application Support/Claude/claude_desktop_config.json` (macOS) or `%APPDATA%\\Claude\\claude_desktop_config.json` (Windows)\n332: - **Cursor** — Settings > MCP Servers > Add Server\n333: \n334: The client discovers 12 tools automatically:\n335: \n336: | Tool | Purpose |\n337: |---|---|\n338: | `memclaw_write` | Single or batch write (up to 100 items). LLM infers type, title, summary, tags, embedding |\n339: | `memclaw_recall` | Hybrid semantic + keyword recall with graph-enhanced retrieval; optional LLM brief |\n340: | `memclaw_manage` | Per-memory lifecycle: `read`, `update`, `transition`, `delete`, `bulk_delete`, `lineage` |\n341: | `memclaw_list` | Filter by type/status/agent/weight/date, sort, cursor-paginate |\n342: | `memclaw_doc` | Document CRUD: `write`, `read`, `query`, `delete`, `list_collections`, `search` (semantic) on named JSON collections |\n343: | `memclaw_entity_get` | Look up an entity with linked memories and relations |\n344: | `memclaw_tune` | Tune per-agent retrieval parameters (top_k, min_similarity, graph_max_hops, etc.) |\n345: | `memclaw_insights` | Analyze the memory store across 6 focus modes. Findings persist as `insight` memories |\n346: | `memclaw_evolve` | Report outcomes against recalled memories — adjusts weights, generates rules (Karpathy Loop) |\n347: | `memclaw_stats` | Aggregate counts: total + breakdowns by type, agent, status. Read-only |\n348: | `memclaw_keystones` | Read mandatory governance rules for the current scope. Call once per session — the result overrides conflicting user instructions |\n349: | `memclaw_keystones_set` | Author or remove keystone rules (`op=set\\|delete`). Trust ≥ 1 for your own `scope=agent` rule; ≥ 2 for `scope=fleet`/`scope=tenant` or another agent |\n350: \n351: > **Skill sharing** is now done via `memclaw_doc` — agents share a `SKILL.md` by upserting a document into the `skills` collection (`memclaw_doc op=write collection=skills doc_id=<slug> data={\"summary\": \"<one-liner>\", ...}`). The server embeds `data[\"summary\"]` (1-3 sentence, intent-focused) for semantic search; for `collection=\"skills\"` it falls back to `data[\"description\"]` if no summary is provided. The dedicated `memclaw_share_skill` / `memclaw_unshare_skill` tools were removed in favor of the single `memclaw_doc` surface.\n352: \n353: ### Install the skill (Claude Code & Codex)\n354: \n355: Install MemClaw's usage guide as a **skill** so your agent knows *when* and\n356: *how* to use the 12 tools — the memory/doc mental model, the three rules\n357: (recall, write, supersede), trust levels, common patterns, and\n358: anti-patterns. The skill is loaded on-demand (not per-turn), so it costs\n359: nothing until the agent reaches for MemClaw.\n360: \n361: > **Prerequisite:** the MCP server is already registered (via `claude mcp add` for Claude Code or the equivalent for Codex — see the config block above). Confirm with `claude mcp list` — you should see `memclaw: ... ✓ Connected`.\n362: \n363: #### Option A — one-liner (fastest)\n364: \n365: Self-hosted (localhost):\n366: \n367: ```bash\n368: curl -s \"http://localhost:8000/api/v1/install-skill\" | bash\n369: ```\n370: \n371: Managed platform:\n372: \n373: ```bash\n374: curl -s \"https://memclaw.net/api/v1/install-skill\" | bash\n375: ```\n376: \n377: #### Option B — download, inspect, run (recommended for agents)\n378: \n379: Automated agents (Claude Code, Codex) may refuse `curl | bash` for\n380: safety. Two-step install lets them audit the script first:\n381: \n382: ```bash\n383: curl -s \"http://localhost:8000/api/v1/install-skill\" > /tmp/install-memclaw-skill.sh\n384: less /tmp/install-memclaw-skill.sh      # review — it only does mkdir + curl + write\n385: bash /tmp/install-memclaw-skill.sh\n386: ```\n387: \n388: #### Options\n389: \n390: | Query param | Effect |\n391: |---|---|\n392: | (none) | Install for both Claude Code and Codex (default) |\n393: | `?agent=claude-code` | Only Claude Code → `~/.claude/skills/memclaw/SKILL.md` |\n394: | `?agent=codex` | Only Codex → `~/.agents/skills/memclaw/SKILL.md` |\n395: \n396: #### Verify\n397: \n398: ```bash\n399: ls -la ~/.claude/skills/memclaw/SKILL.md       # Claude Code\n400: ls -la ~/.agents/skills/memclaw/SKILL.md       # Codex\n401: ```\n402: \n403: Restart your agent after installing — skills are loaded at startup.\n404: Re-run the installer any time to pull the latest version.\n405: \n406: OpenClaw-plugin users get the skill automatically when the plugin\n407: installs; skip this step.\n408: \n409: ---\n410: \n411: ## Deployment\n412: \n413: The recommended way to run MemClaw is via Docker Compose (see [Quick Start](#quick-start)). This gives you a production-ready PostgreSQL + pgvector + Redis + API stack with a single command.\n414: \n415: ### Published container images\n416: \n417: Each release publishes multi-arch (linux/amd64, linux/arm64) images to [GitHub Container Registry](https://github.com/orgs/caura-ai/packages):\n418: \n419: ```\n420: ghcr.io/caura-ai/caura-memclaw-core-api:v2.5.0\n421: ghcr.io/caura-ai/caura-memclaw-core-storage-api:v2.5.0\n422: ```\n423: \n424: Tags follow SemVer with floating aliases — `:v1`, `:v1.0`, `:v1.0.0`, plus `:latest` for the latest stable release. Pull them in your own compose file or Kubernetes manifests instead of building from source.\n425: \n426: <a id=\"manual-deployment\"></a>\n427: \n428: ### Manual deployment (without Docker)\n429: \n430: The `core-api/` service is a standard FastAPI app that runs under any ASGI server (uvicorn, hypercorn). Requirements:\n431: \n432: - Python 3.12+\n433: - PostgreSQL 16+ with the `pgvector` extension\n434: - Redis (optional — falls back to in-memory cache if unavailable)\n435: \n436: ```bash\n437: uvicorn core_api.app:app --host 0.0.0.0 --port 8000 --workers 2\n438: ```\n439: \n440: ### Deployment topologies\n\n(Showing lines 321-440 of 965. Use offset=441 to continue.)\n</content>","metadata":{"preview":"      \"headers\": { \"X-API-Key\": \"mc_your_api_key_here\" }\n    }\n  }\n}\n```\n\n> For team or production use, swap the tenant-scoped key for an **agent-scoped credential** — atomic provisioning via `POST /api/v1/admin/agent-keys/provision` (or the `/settings/organization/api-credentials` wizard) mints the credential + Agent row + initial trust + fleet membership in one round trip. Both kinds use the `mc_` prefix; scope is set at mint time on the credential. See [`docs/integration-without-plugin.md`](docs/integration-without-plugin.md). Using a tenant-scoped credential? Pass an explicit `agent_id` on every MCP tool call — the gateway refuses the reserved default (`mcp-agent`) on the tenant-scoped path.\n\n**Where to add this config:**\n- **Claude Code** — `~/.claude/settings.json` under `\"mcpServers\"`\n- **Claude Desktop** — `~/Library/Application Support/Claude/claude_desktop_config.json` (macOS) or `%APPDATA%\\Claude\\claude_desktop_config.json` (Windows)\n- **Cursor** — Settings > MCP Servers > Add Server\n\nThe client discovers 12 tools automatically:\n\n| Tool | Purpose |\n|---|---|\n| `memclaw_write` | Single or batch write (up to 100 items). LLM infers type, title, summary, tags, embedding |\n| `memclaw_recall` | Hybrid semantic + keyword recall with graph-enhanced retrieval; optional LLM brief |\n| `memclaw_manage` | Per-memory lifecycle: `read`, `update`, `transition`, `delete`, `bulk_delete`, `lineage` |","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","text":"      \"headers\": { \"X-API-Key\": \"mc_your_api_key_here\" }\n    }\n  }\n}\n```\n\n> For team or production use, swap the tenant-scoped key for an **agent-scoped credential** — atomic provisioning via `POST /api/v1/admin/agent-keys/provision` (or the `/settings/organization/api-credentials` wizard) mints the credential + Agent row + initial trust + fleet membership in one round trip. Both kinds use the `mc_` prefix; scope is set at mint time on the credential. See [`docs/integration-without-plugin.md`](docs/integration-without-plugin.md). Using a tenant-scoped credential? Pass an explicit `agent_id` on every MCP tool call — the gateway refuses the reserved default (`mcp-agent`) on the tenant-scoped path.\n\n**Where to add this config:**\n- **Claude Code** — `~/.claude/settings.json` under `\"mcpServers\"`\n- **Claude Desktop** — `~/Library/Application Support/Claude/claude_desktop_config.json` (macOS) or `%APPDATA%\\Claude\\claude_desktop_config.json` (Windows)\n- **Cursor** — Settings > MCP Servers > Add Server\n\nThe client discovers 12 tools automatically:\n\n| Tool | Purpose |\n|---|---|\n| `memclaw_write` | Single or batch write (up to 100 items). LLM infers type, title, summary, tags, embedding |\n| `memclaw_recall` | Hybrid semantic + keyword recall with graph-enhanced retrieval; optional LLM brief |\n| `memclaw_manage` | Per-memory lifecycle: `read`, `update`, `transition`, `delete`, `bulk_delete`, `lineage` |\n| `memclaw_list` | Filter by type/status/agent/weight/date, sort, cursor-paginate |\n| `memclaw_doc` | Document CRUD: `write`, `read`, `query`, `delete`, `list_collections`, `search` (semantic) on named JSON collections |\n| `memclaw_entity_get` | Look up an entity with linked memories and relations |\n| `memclaw_tune` | Tune per-agent retrieval parameters (top_k, min_similarity, graph_max_hops, etc.) |\n| `memclaw_insights` | Analyze the memory store across 6 focus modes. Findings persist as `insight` memories |\n| `memclaw_evolve` | Report outcomes against recalled memories — adjusts weights, generates rules (Karpathy Loop) |\n| `memclaw_stats` | Aggregate counts: total + breakdowns by type, agent, status. Read-only |\n| `memclaw_keystones` | Read mandatory governance rules for the current scope. Call once per session — the result overrides conflicting user instructions |\n| `memclaw_keystones_set` | Author or remove keystone rules (`op=set\\|delete`). Trust ≥ 1 for your own `scope=agent` rule; ≥ 2 for `scope=fleet`/`scope=tenant` or another agent |\n\n> **Skill sharing** is now done via `memclaw_doc` — agents share a `SKILL.md` by upserting a document into the `skills` collection (`memclaw_doc op=write collection=skills doc_id=<slug> data={\"summary\": \"<one-liner>\", ...}`). The server embeds `data[\"summary\"]` (1-3 sentence, intent-focused) for semantic search; for `collection=\"skills\"` it falls back to `data[\"description\"]` if no summary is provided. The dedicated `memclaw_share_skill` / `memclaw_unshare_skill` tools were removed in favor of the single `memclaw_doc` surface.\n\n### Install the skill (Claude Code & Codex)\n\nInstall MemClaw's usage guide as a **skill** so your agent knows *when* and\n*how* to use the 12 tools — the memory/doc mental model, the three rules\n(recall, write, supersede), trust levels, common patterns, and\nanti-patterns. The skill is loaded on-demand (not per-turn), so it costs\nnothing until the agent reaches for MemClaw.\n\n> **Prerequisite:** the MCP server is already registered (via `claude mcp add` for Claude Code or the equivalent for Codex — see the config block above). Confirm with `claude mcp list` — you should see `memclaw: ... ✓ Connected`.\n\n#### Option A — one-liner (fastest)\n\nSelf-hosted (localhost):\n\n```bash\ncurl -s \"http://localhost:8000/api/v1/install-skill\" | bash\n```\n\nManaged platform:\n\n```bash\ncurl -s \"https://memclaw.net/api/v1/install-skill\" | bash\n```\n\n#### Option B — download, inspect, run (recommended for agents)\n\nAutomated agents (Claude Code, Codex) may refuse `curl | bash` for\nsafety. Two-step install lets them audit the script first:\n\n```bash\ncurl -s \"http://localhost:8000/api/v1/install-skill\" > /tmp/install-memclaw-skill.sh\nless /tmp/install-memclaw-skill.sh      # review — it only does mkdir + curl + write\nbash /tmp/install-memclaw-skill.sh\n```\n\n#### Options\n\n| Query param | Effect |\n|---|---|\n| (none) | Install for both Claude Code and Codex (default) |\n| `?agent=claude-code` | Only Claude Code → `~/.claude/skills/memclaw/SKILL.md` |\n| `?agent=codex` | Only Codex → `~/.agents/skills/memclaw/SKILL.md` |\n\n#### Verify\n\n```bash\nls -la ~/.claude/skills/memclaw/SKILL.md       # Claude Code\nls -la ~/.agents/skills/memclaw/SKILL.md       # Codex\n```\n\nRestart your agent after installing — skills are loaded at startup.\nRe-run the installer any time to pull the latest version.\n\nOpenClaw-plugin users get the skill automatically when the plugin\ninstalls; skip this step.\n\n---\n\n## Deployment\n\nThe recommended way to run MemClaw is via Docker Compose (see [Quick Start](#quick-start)). This gives you a production-ready PostgreSQL + pgvector + Redis + API stack with a single command.\n\n### Published container images\n\nEach release publishes multi-arch (linux/amd64, linux/arm64) images to [GitHub Container Registry](https://github.com/orgs/caura-ai/packages):\n\n```\nghcr.io/caura-ai/caura-memclaw-core-api:v2.5.0\nghcr.io/caura-ai/caura-memclaw-core-storage-api:v2.5.0\n```\n\nTags follow SemVer with floating aliases — `:v1`, `:v1.0`, `:v1.0.0`, plus `:latest` for the latest stable release. Pull them in your own compose file or Kubernetes manifests instead of building from source.\n\n<a id=\"manual-deployment\"></a>\n\n### Manual deployment (without Docker)\n\nThe `core-api/` service is a standard FastAPI app that runs under any ASGI server (uvicorn, hypercorn). Requirements:\n\n- Python 3.12+\n- PostgreSQL 16+ with the `pgvector` extension\n- Redis (optional — falls back to in-memory cache if unavailable)\n\n```bash\nuvicorn core_api.app:app --host 0.0.0.0 --port 8000 --workers 2\n```\n\n### Deployment topologies","lineStart":321,"lineEnd":440,"totalLines":965,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","time":{"start":1780728421258,"end":1780728421263}},"metadata":{"openai":{"itemId":"fc_0033b7a40e8c48d1016a23c265296c819187619291cd54e8bb"}},"id":"prt_e9baf5b6b0010hk0P2wArfqn6b","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf24f1001MpVDpIN74GuluG"}}
{"type":"tool_use","timestamp":1780728421281,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_2RWtoPi7iQRcku1I3iddYqut","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","offset":812,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md</path>\n<type>file</type>\n<content>\n812: ## Public API & Stability\n813: \n814: MemClaw v1.x follows [SemVer 2.0.0](https://semver.org/spec/v2.0.0.html). The surfaces below are stable; everything else is internal and may change in any release.\n815: \n816: ### Stable surfaces\n817: \n818: #### MCP tools (12)\n819: \n820: The MCP server is mounted at `/mcp`. Tool names, parameter names, and the documented op-dispatch values are stable.\n821: \n822: | Tool | Purpose |\n823: |---|---|\n824: | `memclaw_recall` | Hybrid semantic + keyword search over memories, with optional LLM-summarised brief. |\n825: | `memclaw_write` | Single or batch (≤100) memory write; auto-enriched with type, title, summary, tags. |\n826: | `memclaw_manage` | Per-memory lifecycle, op-dispatched: `read` \\| `update` \\| `transition` \\| `delete` \\| `bulk_delete` \\| `lineage`. |\n827: | `memclaw_list` | Non-semantic enumeration with filters, sort, cursor pagination. |\n828: | `memclaw_doc` | Structured-document CRUD, op-dispatched: `write` \\| `read` \\| `query` \\| `delete` \\| `list_collections` \\| `search`. |\n829: | `memclaw_entity_get` | Look up a knowledge-graph entity by UUID. |\n830: | `memclaw_tune` | Read/update an agent's per-search profile (top_k, fts_weight, freshness, blend, …). |\n831: | `memclaw_insights` | Karpathy-Loop reflection: contradictions, failures, stale, divergence, patterns, discover. |\n832: | `memclaw_evolve` | Karpathy-Loop feedback: record an outcome (`success` \\| `failure` \\| `partial`) against memories. |\n833: | `memclaw_stats` | Aggregate counts: total + breakdowns by `type` / `agent` / `status`. Read-only. |\n834: | `memclaw_keystones` | Read mandatory governance rules for the current scope (tenant + fleet + agent merged). Call once per session. |\n835: | `memclaw_keystones_set` | Author/remove keystone rules, op-dispatched: `set` \\| `delete`. Trust ≥ 1 for self-authored `scope=agent`; ≥ 2 otherwise. |\n836: \n837: > Skill sharing uses the generic `memclaw_doc` surface — write/read/query/search/delete on `collection=\"skills\"`. The server validates the slug and embeds `data[\"summary\"]` for semantic discovery (with a back-compat fallback to `data[\"description\"]` for skills).\n838: \n839: #### REST endpoints\n840: \n841: All paths are prefixed with `/api/v1` unless noted. Request and response shapes documented in the OpenAPI schema at `/openapi.json` are part of the contract.\n842: \n843: | Area | Endpoints |\n844: |---|---|\n845: | Memory | `GET/POST /memories`, `PATCH /memories/{id}`, `DELETE /memories/{id}`, `PATCH /memories/{id}/status`, `POST /memories/bulk`, `POST /memories/bulk-delete`, `GET /memories/stats`, `GET /memories/{id}`, `GET /memories/{id}/contradictions`, `POST /search`, `POST /recall`, `POST /ingest/preview`, `POST /ingest/commit` |\n846: | Knowledge graph | `GET /entities`, `GET /entities/{id}`, `POST /entities/upsert`, `GET /graph`, `POST /relations/upsert` |\n847: | Documents | `POST /documents`, `GET /documents`, `GET /documents/{id}`, `POST /documents/query`, `DELETE /documents/{id}` |\n848: | Keystones | `GET /memclaw/keystones`, `POST /memclaw/keystones`, `DELETE /memclaw/keystones/{doc_id}` |\n849: | Fleet | `POST /fleet/heartbeat`, `GET /fleet/nodes`, `POST /fleet/commands`, `GET /fleet/commands` |\n850: | Agents | `GET /agents`, `GET /agents/{id}`, `PATCH /agents/{id}/trust`, `POST /admin/agent-keys/provision` (atomic key + row + trust + fleet), `GET /whoami` (identity probe) |\n851: | Insights | `POST /insights/generate` |\n852: | Evolve | `POST /evolve/report` |\n853: | Crystallizer | `POST /crystallize`, `POST /crystallize/all`, `GET /crystallize/reports`, `GET /crystallize/latest` |\n854: | Settings | `GET/PUT /settings` |\n855: | System | `GET /health`, `GET /version`, `GET /tool-descriptions`, `GET /audit-log` |\n856: | MCP | `POST /mcp` (Streamable HTTP transport, mounted at app root) |\n857: | Bootstrap (plugin) | `GET /plugin-source`, `GET /plugin-source-hash`, `GET/POST /install-plugin`, `GET /install-skill`, `GET /skill/memclaw`. Aliased under `/api` (no `/v1`) for one-line installers. |\n858: \n859: #### Plugin environment variables\n860: \n861: Read by the OpenClaw plugin. The plugin's published name (`memclaw`) and these variables are the public contract; the plugin's TypeScript module structure is internal.\n862: \n863: | Var | Purpose |\n864: |---|---|\n865: | `MEMCLAW_API_URL` | Base URL of the core-api server. |\n866: | `MEMCLAW_API_KEY` | Tenant or admin API key sent in `X-API-Key`. |\n867: | `MEMCLAW_TENANT_ID` | Optional pre-resolved tenant id; bypasses lookup. |\n868: | `MEMCLAW_FLEET_ID` | Default fleet id for writes/heartbeat. |\n869: | `MEMCLAW_NODE_NAME` | Fleet node identifier reported on heartbeat. |\n870: | `MEMCLAW_AUTO_WRITE_TURNS` | Auto-write turn summaries (default `true`). |\n871: \n872: #### Server environment variables\n873: \n874: These mirror the Configuration table above. See it for defaults.\n875: \n876: | Group | Vars |\n877: |---|---|\n878: | Database | `POSTGRES_HOST`, `POSTGRES_PORT`, `POSTGRES_USER`, `POSTGRES_PASSWORD`, `POSTGRES_DB`, `POSTGRES_USE_IAM_AUTH`, `POSTGRES_REQUIRE_SSL` |\n879: | Auth | `ADMIN_API_KEY`, `MEMCLAW_API_KEY`, `IS_STANDALONE` |\n880: | Providers | `EMBEDDING_PROVIDER`, `ENTITY_EXTRACTION_PROVIDER`, `OPENAI_API_KEY`, `ANTHROPIC_API_KEY`, `OPENROUTER_API_KEY`, `GEMINI_API_KEY`, `USE_LLM_FOR_MEMORY_CREATION` |\n881: | Runtime | `CORS_ORIGINS`, `ENVIRONMENT`, `SETTINGS_ENCRYPTION_KEY`, `REDIS_URL` |\n882: \n883: #### Auth modes\n884: \n885: | Mode | Activated by | Use case |\n886: |---|---|---|\n887: | Standalone | `IS_STANDALONE=true` | Single-tenant self-host; auth bypassed. |\n888: | Multi-tenant admin | `ADMIN_API_KEY=…` | Operator key for multi-tenant deployments. |\n889: | Shared gate | `MEMCLAW_API_KEY=…` | Optional shared secret required on every non-admin request. |\n890: \n891: See [AGENT-INSTALL.md](AGENT-INSTALL.md) for installation flows that exercise each mode.\n892: \n893: ### Internal (not covered by SemVer)\n894: \n895: Anything not listed above is internal and may change in any release without a major version bump:\n896: \n897: - Python module layout (`core_api.middleware.*`, `core_api.providers.*`, `core_api.pipeline.*`, `core_api.services.*`, `common/*`)\n898: - Database schema, table names, migration paths\n899: - Gateway-injected HTTP headers (`X-Memclaw-Gateway`, `X-Tenant-ID`, `X-Agent-ID`, `X-Org-Read-Only`)\n900: - Most `/api/v1/admin/*` and all `/api/v1/testing/*` routes (the documented exception is `POST /admin/agent-keys/provision`, which is part of the stable identity-bootstrap surface — see the Agents row above)\n901: - The `core-storage-api` microservice (internal, not user-facing)\n902: - The plugin's TypeScript module structure\n903: - API-key prefix formats — currently unified on `mc_…` (with legacy `mca_…` / `mci_…` aliases still accepted via back-compat); formats may continue to evolve\n904: \n905: ### Reporting breaking changes\n906: \n907: Contributors who introduce a breaking change to a stable surface must:\n908: \n909: - Add a `BREAKING CHANGE:` trailer to the commit message describing the impact and any migration steps.\n910: - Apply the `kind/breaking` label to the pull request.\n911: \n912: Reviewers will block merges to `dev` that touch a stable surface without these markers. If you are unsure whether a change is breaking, open the PR with the label and let review decide — better to over-label than ship a silent break.\n913: \n914: ---\n915: \n916: ## Telemetry and error tracking\n917: \n918: MemClaw supports optional [Sentry](https://sentry.io) integration for error tracking and performance monitoring:\n919: \n920: - **Opt-in only** — set the `SENTRY_DSN` environment variable to enable. No errors are reported unless you explicitly configure a DSN.\n921: - **No usage analytics** — MemClaw does not collect usage statistics, feature flags, or behavioral data.\n\n(Showing lines 812-921 of 965. Use offset=922 to continue.)\n</content>","metadata":{"preview":"## Public API & Stability\n\nMemClaw v1.x follows [SemVer 2.0.0](https://semver.org/spec/v2.0.0.html). The surfaces below are stable; everything else is internal and may change in any release.\n\n### Stable surfaces\n\n#### MCP tools (12)\n\nThe MCP server is mounted at `/mcp`. Tool names, parameter names, and the documented op-dispatch values are stable.\n\n| Tool | Purpose |\n|---|---|\n| `memclaw_recall` | Hybrid semantic + keyword search over memories, with optional LLM-summarised brief. |\n| `memclaw_write` | Single or batch (≤100) memory write; auto-enriched with type, title, summary, tags. |\n| `memclaw_manage` | Per-memory lifecycle, op-dispatched: `read` \\| `update` \\| `transition` \\| `delete` \\| `bulk_delete` \\| `lineage`. |\n| `memclaw_list` | Non-semantic enumeration with filters, sort, cursor pagination. |\n| `memclaw_doc` | Structured-document CRUD, op-dispatched: `write` \\| `read` \\| `query` \\| `delete` \\| `list_collections` \\| `search`. |\n| `memclaw_entity_get` | Look up a knowledge-graph entity by UUID. |\n| `memclaw_tune` | Read/update an agent's per-search profile (top_k, fts_weight, freshness, blend, …). |\n| `memclaw_insights` | Karpathy-Loop reflection: contradictions, failures, stale, divergence, patterns, discover. |","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","text":"## Public API & Stability\n\nMemClaw v1.x follows [SemVer 2.0.0](https://semver.org/spec/v2.0.0.html). The surfaces below are stable; everything else is internal and may change in any release.\n\n### Stable surfaces\n\n#### MCP tools (12)\n\nThe MCP server is mounted at `/mcp`. Tool names, parameter names, and the documented op-dispatch values are stable.\n\n| Tool | Purpose |\n|---|---|\n| `memclaw_recall` | Hybrid semantic + keyword search over memories, with optional LLM-summarised brief. |\n| `memclaw_write` | Single or batch (≤100) memory write; auto-enriched with type, title, summary, tags. |\n| `memclaw_manage` | Per-memory lifecycle, op-dispatched: `read` \\| `update` \\| `transition` \\| `delete` \\| `bulk_delete` \\| `lineage`. |\n| `memclaw_list` | Non-semantic enumeration with filters, sort, cursor pagination. |\n| `memclaw_doc` | Structured-document CRUD, op-dispatched: `write` \\| `read` \\| `query` \\| `delete` \\| `list_collections` \\| `search`. |\n| `memclaw_entity_get` | Look up a knowledge-graph entity by UUID. |\n| `memclaw_tune` | Read/update an agent's per-search profile (top_k, fts_weight, freshness, blend, …). |\n| `memclaw_insights` | Karpathy-Loop reflection: contradictions, failures, stale, divergence, patterns, discover. |\n| `memclaw_evolve` | Karpathy-Loop feedback: record an outcome (`success` \\| `failure` \\| `partial`) against memories. |\n| `memclaw_stats` | Aggregate counts: total + breakdowns by `type` / `agent` / `status`. Read-only. |\n| `memclaw_keystones` | Read mandatory governance rules for the current scope (tenant + fleet + agent merged). Call once per session. |\n| `memclaw_keystones_set` | Author/remove keystone rules, op-dispatched: `set` \\| `delete`. Trust ≥ 1 for self-authored `scope=agent`; ≥ 2 otherwise. |\n\n> Skill sharing uses the generic `memclaw_doc` surface — write/read/query/search/delete on `collection=\"skills\"`. The server validates the slug and embeds `data[\"summary\"]` for semantic discovery (with a back-compat fallback to `data[\"description\"]` for skills).\n\n#### REST endpoints\n\nAll paths are prefixed with `/api/v1` unless noted. Request and response shapes documented in the OpenAPI schema at `/openapi.json` are part of the contract.\n\n| Area | Endpoints |\n|---|---|\n| Memory | `GET/POST /memories`, `PATCH /memories/{id}`, `DELETE /memories/{id}`, `PATCH /memories/{id}/status`, `POST /memories/bulk`, `POST /memories/bulk-delete`, `GET /memories/stats`, `GET /memories/{id}`, `GET /memories/{id}/contradictions`, `POST /search`, `POST /recall`, `POST /ingest/preview`, `POST /ingest/commit` |\n| Knowledge graph | `GET /entities`, `GET /entities/{id}`, `POST /entities/upsert`, `GET /graph`, `POST /relations/upsert` |\n| Documents | `POST /documents`, `GET /documents`, `GET /documents/{id}`, `POST /documents/query`, `DELETE /documents/{id}` |\n| Keystones | `GET /memclaw/keystones`, `POST /memclaw/keystones`, `DELETE /memclaw/keystones/{doc_id}` |\n| Fleet | `POST /fleet/heartbeat`, `GET /fleet/nodes`, `POST /fleet/commands`, `GET /fleet/commands` |\n| Agents | `GET /agents`, `GET /agents/{id}`, `PATCH /agents/{id}/trust`, `POST /admin/agent-keys/provision` (atomic key + row + trust + fleet), `GET /whoami` (identity probe) |\n| Insights | `POST /insights/generate` |\n| Evolve | `POST /evolve/report` |\n| Crystallizer | `POST /crystallize`, `POST /crystallize/all`, `GET /crystallize/reports`, `GET /crystallize/latest` |\n| Settings | `GET/PUT /settings` |\n| System | `GET /health`, `GET /version`, `GET /tool-descriptions`, `GET /audit-log` |\n| MCP | `POST /mcp` (Streamable HTTP transport, mounted at app root) |\n| Bootstrap (plugin) | `GET /plugin-source`, `GET /plugin-source-hash`, `GET/POST /install-plugin`, `GET /install-skill`, `GET /skill/memclaw`. Aliased under `/api` (no `/v1`) for one-line installers. |\n\n#### Plugin environment variables\n\nRead by the OpenClaw plugin. The plugin's published name (`memclaw`) and these variables are the public contract; the plugin's TypeScript module structure is internal.\n\n| Var | Purpose |\n|---|---|\n| `MEMCLAW_API_URL` | Base URL of the core-api server. |\n| `MEMCLAW_API_KEY` | Tenant or admin API key sent in `X-API-Key`. |\n| `MEMCLAW_TENANT_ID` | Optional pre-resolved tenant id; bypasses lookup. |\n| `MEMCLAW_FLEET_ID` | Default fleet id for writes/heartbeat. |\n| `MEMCLAW_NODE_NAME` | Fleet node identifier reported on heartbeat. |\n| `MEMCLAW_AUTO_WRITE_TURNS` | Auto-write turn summaries (default `true`). |\n\n#### Server environment variables\n\nThese mirror the Configuration table above. See it for defaults.\n\n| Group | Vars |\n|---|---|\n| Database | `POSTGRES_HOST`, `POSTGRES_PORT`, `POSTGRES_USER`, `POSTGRES_PASSWORD`, `POSTGRES_DB`, `POSTGRES_USE_IAM_AUTH`, `POSTGRES_REQUIRE_SSL` |\n| Auth | `ADMIN_API_KEY`, `MEMCLAW_API_KEY`, `IS_STANDALONE` |\n| Providers | `EMBEDDING_PROVIDER`, `ENTITY_EXTRACTION_PROVIDER`, `OPENAI_API_KEY`, `ANTHROPIC_API_KEY`, `OPENROUTER_API_KEY`, `GEMINI_API_KEY`, `USE_LLM_FOR_MEMORY_CREATION` |\n| Runtime | `CORS_ORIGINS`, `ENVIRONMENT`, `SETTINGS_ENCRYPTION_KEY`, `REDIS_URL` |\n\n#### Auth modes\n\n| Mode | Activated by | Use case |\n|---|---|---|\n| Standalone | `IS_STANDALONE=true` | Single-tenant self-host; auth bypassed. |\n| Multi-tenant admin | `ADMIN_API_KEY=…` | Operator key for multi-tenant deployments. |\n| Shared gate | `MEMCLAW_API_KEY=…` | Optional shared secret required on every non-admin request. |\n\nSee [AGENT-INSTALL.md](AGENT-INSTALL.md) for installation flows that exercise each mode.\n\n### Internal (not covered by SemVer)\n\nAnything not listed above is internal and may change in any release without a major version bump:\n\n- Python module layout (`core_api.middleware.*`, `core_api.providers.*`, `core_api.pipeline.*`, `core_api.services.*`, `common/*`)\n- Database schema, table names, migration paths\n- Gateway-injected HTTP headers (`X-Memclaw-Gateway`, `X-Tenant-ID`, `X-Agent-ID`, `X-Org-Read-Only`)\n- Most `/api/v1/admin/*` and all `/api/v1/testing/*` routes (the documented exception is `POST /admin/agent-keys/provision`, which is part of the stable identity-bootstrap surface — see the Agents row above)\n- The `core-storage-api` microservice (internal, not user-facing)\n- The plugin's TypeScript module structure\n- API-key prefix formats — currently unified on `mc_…` (with legacy `mca_…` / `mci_…` aliases still accepted via back-compat); formats may continue to evolve\n\n### Reporting breaking changes\n\nContributors who introduce a breaking change to a stable surface must:\n\n- Add a `BREAKING CHANGE:` trailer to the commit message describing the impact and any migration steps.\n- Apply the `kind/breaking` label to the pull request.\n\nReviewers will block merges to `dev` that touch a stable surface without these markers. If you are unsure whether a change is breaking, open the PR with the label and let review decide — better to over-label than ship a silent break.\n\n---\n\n## Telemetry and error tracking\n\nMemClaw supports optional [Sentry](https://sentry.io) integration for error tracking and performance monitoring:\n\n- **Opt-in only** — set the `SENTRY_DSN` environment variable to enable. No errors are reported unless you explicitly configure a DSN.\n- **No usage analytics** — MemClaw does not collect usage statistics, feature flags, or behavioral data.","lineStart":812,"lineEnd":921,"totalLines":965,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","time":{"start":1780728421273,"end":1780728421278}},"metadata":{"openai":{"itemId":"fc_0033b7a40e8c48d1016a23c265297c819197d0cc869b4a654a"}},"id":"prt_e9baf5b90001Dz7Eru6TapXKrU","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf24f1001MpVDpIN74GuluG"}}
{"type":"tool_use","timestamp":1780728421284,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_6FO6zsfU7dT3vqcxwprgwXBn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_types.py","offset":1,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_types.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Core dataclasses for the tool-spec single source of truth.\n2: \n3: A `ToolSpec` is the declarative description of a single MCP tool. The\n4: `mcp_server` derives `@mcp.tool` registrations from these. The plugin reads\n5: the same shape via `tools.json` (CI-synced from `scripts/export_tool_specs.py`).\n6: \n7: Parameter info is intentionally NOT duplicated here — it lives on the handler\n8: function's `Annotated[type, Field(description=...)]` signature and is\n9: introspected on demand. That keeps the spec lean and the handler the single\n10: source of truth for its own arguments.\n11: \"\"\"\n12: \n13: from __future__ import annotations\n14: \n15: from collections.abc import Awaitable, Callable\n16: from dataclasses import dataclass, field\n17: from typing import Literal\n18: \n19: from mcp.types import CallToolResult\n20: \n21: HandlerFn = Callable[..., Awaitable[str | CallToolResult]]\n22: \"\"\"Async; success returns a string, errors return ``CallToolResult`` via\n23: ``_as_error_result``. Type checkers accept ``CallToolResult`` on any path —\n24: returning it from a success branch silently sets ``isError=True`` for\n25: clients; enforce the split in code review. Registration sets\n26: ``structured_output=False`` to accept this union — see ``mcp_register``\n27: in ``_builders.py``.\"\"\"\n28: \n29: \n30: ImplStatus = Literal[\"live\", \"reserved\", \"deprecated\"]\n31: \"\"\"\n32: - live       — handler does the real thing\n33: - reserved   — handler returns NOT_IMPLEMENTED; slot reserved for a teammate\n34: - deprecated — kept for one release; will be removed\n35: \"\"\"\n36: \n37: \n38: @dataclass(frozen=True)\n39: class OpSpec:\n40:     \"\"\"One op of an op-dispatched tool (e.g., memclaw_doc op=write|read|query|delete).\"\"\"\n41: \n42:     name: str\n43:     description: str\n44:     required_params: tuple[str, ...] = ()\n45:     trust_required: int = 0  # 0 = inherit from ToolSpec.trust_required\n46: \n47: \n48: @dataclass(frozen=True)\n49: class ToolSpec:\n50:     \"\"\"Declarative spec for a single MCP tool. Drives MCP registration,\n51:     `/tool-descriptions` output, plugin `tools.json`, and per-tool trust gating.\n52: \n53:     Param schemas are derived from `handler`'s signature at runtime — do NOT\n54:     restate them here.\n55:     \"\"\"\n56: \n57:     name: str\n58:     description: str\n59:     handler: HandlerFn | None = None\n60:     \"\"\"Handler is None during Phase 1 of the v1.0 refactor (handlers still\n61:     live in `mcp_server.py`'s `@mcp.tool` decorators). Phase 2 wires real\n62:     handlers in and `mcp_register` becomes the registration path.\"\"\"\n63:     trust_required: int = 0\n64:     \"\"\"Baseline trust to invoke. 0 = no MCP-level gate (existing behavior for\n65:     tools that enforce trust deeper in the service layer).\"\"\"\n66: \n67:     impl_status: ImplStatus = \"live\"\n68:     plugin_exposed: bool = True\n69:     \"\"\"Whether the OpenClaw plugin should expose this tool. STM tools and\n70:     placeholders set False.\"\"\"\n71: \n72:     ops: tuple[OpSpec, ...] = field(default_factory=tuple)\n73:     \"\"\"Optional — for op-dispatched tools. Empty for non-dispatch tools.\"\"\"\n74: \n75:     error_codes: tuple[str, ...] = field(default_factory=tuple)\n76:     \"\"\"Codes this tool may emit in the unified error envelope.\"\"\"\n77: \n78:     def __post_init__(self) -> None:\n79:         # Light invariants (full validation happens in _registry on import).\n80:         if not self.name.startswith(\"memclaw_\"):\n81:             raise ValueError(f\"Tool name must start with 'memclaw_': {self.name}\")\n82:         if self.trust_required not in (0, 1, 2, 3):\n83:             raise ValueError(f\"trust_required must be 0..3, got {self.trust_required} for {self.name}\")\n84:         if self.impl_status == \"reserved\" and self.plugin_exposed:\n85:             raise ValueError(f\"reserved tools must set plugin_exposed=False: {self.name}\")\n\n(End of file - total 85 lines)\n</content>","metadata":{"preview":"\"\"\"Core dataclasses for the tool-spec single source of truth.\n\nA `ToolSpec` is the declarative description of a single MCP tool. The\n`mcp_server` derives `@mcp.tool` registrations from these. The plugin reads\nthe same shape via `tools.json` (CI-synced from `scripts/export_tool_specs.py`).\n\nParameter info is intentionally NOT duplicated here — it lives on the handler\nfunction's `Annotated[type, Field(description=...)]` signature and is\nintrospected on demand. That keeps the spec lean and the handler the single\nsource of truth for its own arguments.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Awaitable, Callable\nfrom dataclasses import dataclass, field\nfrom typing import Literal\n\nfrom mcp.types import CallToolResult\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_types.py","text":"\"\"\"Core dataclasses for the tool-spec single source of truth.\n\nA `ToolSpec` is the declarative description of a single MCP tool. The\n`mcp_server` derives `@mcp.tool` registrations from these. The plugin reads\nthe same shape via `tools.json` (CI-synced from `scripts/export_tool_specs.py`).\n\nParameter info is intentionally NOT duplicated here — it lives on the handler\nfunction's `Annotated[type, Field(description=...)]` signature and is\nintrospected on demand. That keeps the spec lean and the handler the single\nsource of truth for its own arguments.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Awaitable, Callable\nfrom dataclasses import dataclass, field\nfrom typing import Literal\n\nfrom mcp.types import CallToolResult\n\nHandlerFn = Callable[..., Awaitable[str | CallToolResult]]\n\"\"\"Async; success returns a string, errors return ``CallToolResult`` via\n``_as_error_result``. Type checkers accept ``CallToolResult`` on any path —\nreturning it from a success branch silently sets ``isError=True`` for\nclients; enforce the split in code review. Registration sets\n``structured_output=False`` to accept this union — see ``mcp_register``\nin ``_builders.py``.\"\"\"\n\n\nImplStatus = Literal[\"live\", \"reserved\", \"deprecated\"]\n\"\"\"\n- live       — handler does the real thing\n- reserved   — handler returns NOT_IMPLEMENTED; slot reserved for a teammate\n- deprecated — kept for one release; will be removed\n\"\"\"\n\n\n@dataclass(frozen=True)\nclass OpSpec:\n    \"\"\"One op of an op-dispatched tool (e.g., memclaw_doc op=write|read|query|delete).\"\"\"\n\n    name: str\n    description: str\n    required_params: tuple[str, ...] = ()\n    trust_required: int = 0  # 0 = inherit from ToolSpec.trust_required\n\n\n@dataclass(frozen=True)\nclass ToolSpec:\n    \"\"\"Declarative spec for a single MCP tool. Drives MCP registration,\n    `/tool-descriptions` output, plugin `tools.json`, and per-tool trust gating.\n\n    Param schemas are derived from `handler`'s signature at runtime — do NOT\n    restate them here.\n    \"\"\"\n\n    name: str\n    description: str\n    handler: HandlerFn | None = None\n    \"\"\"Handler is None during Phase 1 of the v1.0 refactor (handlers still\n    live in `mcp_server.py`'s `@mcp.tool` decorators). Phase 2 wires real\n    handlers in and `mcp_register` becomes the registration path.\"\"\"\n    trust_required: int = 0\n    \"\"\"Baseline trust to invoke. 0 = no MCP-level gate (existing behavior for\n    tools that enforce trust deeper in the service layer).\"\"\"\n\n    impl_status: ImplStatus = \"live\"\n    plugin_exposed: bool = True\n    \"\"\"Whether the OpenClaw plugin should expose this tool. STM tools and\n    placeholders set False.\"\"\"\n\n    ops: tuple[OpSpec, ...] = field(default_factory=tuple)\n    \"\"\"Optional — for op-dispatched tools. Empty for non-dispatch tools.\"\"\"\n\n    error_codes: tuple[str, ...] = field(default_factory=tuple)\n    \"\"\"Codes this tool may emit in the unified error envelope.\"\"\"\n\n    def __post_init__(self) -> None:\n        # Light invariants (full validation happens in _registry on import).\n        if not self.name.startswith(\"memclaw_\"):\n            raise ValueError(f\"Tool name must start with 'memclaw_': {self.name}\")\n        if self.trust_required not in (0, 1, 2, 3):\n            raise ValueError(f\"trust_required must be 0..3, got {self.trust_required} for {self.name}\")\n        if self.impl_status == \"reserved\" and self.plugin_exposed:\n            raise ValueError(f\"reserved tools must set plugin_exposed=False: {self.name}\")","lineStart":1,"lineEnd":85,"totalLines":85,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_types.py","time":{"start":1780728421279,"end":1780728421283}},"metadata":{"openai":{"itemId":"fc_0033b7a40e8c48d1016a23c2652984819192ceefe6b611aa6d"}},"id":"prt_e9baf5b9b001N86agAc1H5BCDO","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf24f1001MpVDpIN74GuluG"}}
{"type":"tool_use","timestamp":1780728421317,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_iyR6iCSzWhfP2nyRlMOl228u","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_tools_registry.py","offset":1,"limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_tools_registry.py</path>\n<type>file</type>\n<content>\n1: \"\"\"SoT registry invariants — structural lints over ``core_api.tools``.\n2: \n3: Every assertion here is meant to make a design contract concrete so\n4: future refactors can't silently break it:\n5: \n6: - Every spec name has the ``memclaw_`` prefix.\n7: - Trust values live in [0, 3].\n8: - ``impl_status=\"reserved\"`` implies ``plugin_exposed=False``.\n9: - Every ``OpSpec.required_params`` references a real handler parameter.\n10: - Every non-reserved spec has a real, callable async handler.\n11: - No name collisions.\n12: - The plugin-exposed set matches the expected v1.0 surface.\n13: \"\"\"\n14: \n15: from __future__ import annotations\n16: \n17: import inspect\n18: \n19: import pytest\n20: \n21: pytestmark = pytest.mark.unit\n22: \n23: \n24: EXPECTED_PLUGIN_EXPOSED = {\n25:     \"memclaw_recall\",\n26:     \"memclaw_write\",\n27:     \"memclaw_manage\",\n28:     \"memclaw_doc\",\n29:     \"memclaw_list\",\n30:     \"memclaw_entity_get\",\n31:     \"memclaw_tune\",\n32:     \"memclaw_insights\",\n33:     \"memclaw_evolve\",\n34:     \"memclaw_stats\",\n35:     # Read tool is plugin-exposed so the plugin can auto-inject keystone\n36:     # rules at session start (CAURA-000). The write tool\n37:     # (``memclaw_keystones_set``) is MCP-only — authoring is an\n38:     # admin/governance path, not an agent path.\n39:     \"memclaw_keystones\",\n40: }\n41: \n42: # MCP-only tools — not surfaced through the plugin. ``memclaw_keystones_set``\n43: # is the write half of the keystone pair; admins/governance use it from\n44: # REST/MCP, agents do not.\n45: EXPECTED_MCP_ONLY = {\n46:     \"memclaw_keystones_set\",\n47: }\n48: \n49: EXPECTED_PLACEHOLDERS: set[str] = set()\n50: \n51: \n52: # memclaw_insights and memclaw_evolve landed in d6f212b as live MCP-only\n53: # tools — implementation is real, but they stay plugin_exposed=False until\n54: # REST endpoints land (the plugin dispatches via REST).\n55: \n56: \n57: def test_all_specs_have_memclaw_prefix():\n58:     from core_api.tools import REGISTRY\n59: \n60:     for name in REGISTRY:\n61:         assert name.startswith(\"memclaw_\"), f\"Spec name '{name}' lacks memclaw_ prefix\"\n62: \n63: \n64: def test_all_trust_values_in_0_3():\n65:     from core_api.tools import REGISTRY\n66: \n67:     for spec in REGISTRY.values():\n68:         assert spec.trust_required in (0, 1, 2, 3), (\n69:             f\"{spec.name}: trust_required={spec.trust_required} out of range\"\n70:         )\n71: \n72: \n73: def test_reserved_implies_not_plugin_exposed():\n74:     from core_api.tools import REGISTRY\n75: \n76:     for spec in REGISTRY.values():\n77:         if spec.impl_status == \"reserved\":\n78:             assert spec.plugin_exposed is False, (\n79:                 f\"{spec.name}: reserved specs must set plugin_exposed=False\"\n80:             )\n81: \n82: \n83: def test_all_non_reserved_specs_have_callable_handler():\n84:     from core_api.tools import REGISTRY\n85: \n86:     for spec in REGISTRY.values():\n87:         if spec.impl_status == \"reserved\":\n88:             # Placeholder stubs still need handlers — they return NOT_IMPLEMENTED.\n89:             pass\n90:         assert spec.handler is not None, f\"{spec.name}: handler is None\"\n91:         assert inspect.iscoroutinefunction(spec.handler), (\n92:             f\"{spec.name}: handler must be an async function\"\n93:         )\n94: \n95: \n96: def test_op_required_params_reference_real_handler_params():\n97:     from core_api.tools import REGISTRY\n98: \n99:     for spec in REGISTRY.values():\n100:         if not spec.ops:\n101:             continue\n102:         sig = inspect.signature(spec.handler)\n103:         param_names = set(sig.parameters.keys())\n104:         for op in spec.ops:\n105:             for required in op.required_params:\n106:                 assert required in param_names, (\n107:                     f\"{spec.name} op={op.name}: required_param '{required}' \"\n108:                     f\"is not a parameter of the handler (has {sorted(param_names)})\"\n109:                 )\n110: \n111: \n112: def test_no_name_collisions():\n113:     from core_api.tools import REGISTRY\n114: \n115:     names = [spec.name for spec in REGISTRY.values()]\n116:     assert len(names) == len(set(names))\n117: \n118: \n119: def test_plugin_exposed_set_is_v1_surface():\n120:     from core_api.tools import REGISTRY\n121: \n122:     exposed = {name for name, spec in REGISTRY.items() if spec.plugin_exposed}\n123:     assert exposed == EXPECTED_PLUGIN_EXPOSED\n124: \n125: \n126: def test_placeholders_are_reserved_set():\n127:     from core_api.tools import REGISTRY\n128: \n129:     reserved = {\n130:         name for name, spec in REGISTRY.items() if spec.impl_status == \"reserved\"\n131:     }\n132:     assert reserved == EXPECTED_PLACEHOLDERS\n133: \n134: \n135: def test_op_dispatched_tools_have_expected_op_sets():\n136:     from core_api.tools import REGISTRY\n137: \n138:     manage_ops = {op.name for op in REGISTRY[\"memclaw_manage\"].ops}\n139:     doc_ops = {op.name for op in REGISTRY[\"memclaw_doc\"].ops}\n140:     assert manage_ops == {\"read\", \"update\", \"transition\", \"delete\"}\n141:     assert doc_ops == {\"write\", \"read\", \"query\", \"delete\", \"list_collections\", \"search\"}\n142: \n143: \n144: def test_placeholder_tools_declare_not_implemented_error_code():\n145:     from core_api.tools import REGISTRY\n146: \n147:     for name in EXPECTED_PLACEHOLDERS:\n148:         spec = REGISTRY[name]\n149:         assert \"NOT_IMPLEMENTED\" in spec.error_codes, (\n150:             f\"{name}: must advertise NOT_IMPLEMENTED in error_codes\"\n151:         )\n152: \n153: \n154: def test_descriptions_are_non_empty():\n155:     from core_api.tools import REGISTRY\n156: \n157:     for spec in REGISTRY.values():\n158:         assert isinstance(spec.description, str)\n159:         assert spec.description.strip(), f\"{spec.name}: description is empty\"\n160: \n161: \n162: def test_descriptions_no_leftover_tool_descriptions_import():\n163:     \"\"\"After Phase 4, no spec module should import TOOL_DESCRIPTIONS.\"\"\"\n164:     import pkgutil\n165:     from pathlib import Path\n166: \n167:     import core_api.tools as pkg\n168: \n169:     tool_dir = Path(pkg.__file__).parent\n170:     for info in pkgutil.iter_modules([str(tool_dir)]):\n171:         if not info.name.startswith(\"memclaw_\"):\n172:             continue\n173:         src = (tool_dir / f\"{info.name}.py\").read_text()\n174:         assert \"TOOL_DESCRIPTIONS\" not in src, (\n175:             f\"{info.name}.py still imports TOOL_DESCRIPTIONS; \"\n176:             \"descriptions should live inline in each spec module.\"\n177:         )\n178: \n179: \n180: def test_registry_size_matches_expected_surface():\n181:     \"\"\"Registry size must match the expected plugin-exposed + MCP-only +\n182:     placeholder sets — the three disjoint categories that span the surface.\"\"\"\n183:     from core_api.tools import REGISTRY\n184: \n185:     assert len(REGISTRY) == len(\n186:         EXPECTED_PLUGIN_EXPOSED | EXPECTED_MCP_ONLY | EXPECTED_PLACEHOLDERS\n187:     )\n188: \n189: \n190: def test_mcp_only_tools_are_not_plugin_exposed():\n191:     \"\"\"Tools in EXPECTED_MCP_ONLY are present in the registry and stay off\n192:     the plugin surface — locks the boundary between agent-facing and\n193:     admin/governance tools.\"\"\"\n194:     from core_api.tools import REGISTRY\n195: \n196:     for name in EXPECTED_MCP_ONLY:\n197:         assert name in REGISTRY, f\"{name}: expected MCP-only tool missing from REGISTRY\"\n198:         assert REGISTRY[name].plugin_exposed is False, (\n199:             f\"{name}: MCP-only tools must not be plugin-exposed\"\n200:         )\n201: \n202: \n203: def test_every_spec_renders_to_descriptor_json():\n204:     \"\"\"``to_descriptor_json`` handles every spec without errors.\"\"\"\n205:     from core_api.tools import REGISTRY, to_descriptor_json\n206: \n207:     for spec in REGISTRY.values():\n208:         d = to_descriptor_json(spec)\n209:         assert d[\"name\"] == spec.name\n210:         assert d[\"trust_required\"] == spec.trust_required\n211:         assert d[\"impl_status\"] == spec.impl_status\n212:         assert d[\"plugin_exposed\"] == spec.plugin_exposed\n213:         assert isinstance(d[\"params\"], list)\n214:         assert isinstance(d[\"ops\"], list)\n\n(End of file - total 214 lines)\n</content>","metadata":{"preview":"\"\"\"SoT registry invariants — structural lints over ``core_api.tools``.\n\nEvery assertion here is meant to make a design contract concrete so\nfuture refactors can't silently break it:\n\n- Every spec name has the ``memclaw_`` prefix.\n- Trust values live in [0, 3].\n- ``impl_status=\"reserved\"`` implies ``plugin_exposed=False``.\n- Every ``OpSpec.required_params`` references a real handler parameter.\n- Every non-reserved spec has a real, callable async handler.\n- No name collisions.\n- The plugin-exposed set matches the expected v1.0 surface.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport inspect\n\nimport pytest\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_tools_registry.py","text":"\"\"\"SoT registry invariants — structural lints over ``core_api.tools``.\n\nEvery assertion here is meant to make a design contract concrete so\nfuture refactors can't silently break it:\n\n- Every spec name has the ``memclaw_`` prefix.\n- Trust values live in [0, 3].\n- ``impl_status=\"reserved\"`` implies ``plugin_exposed=False``.\n- Every ``OpSpec.required_params`` references a real handler parameter.\n- Every non-reserved spec has a real, callable async handler.\n- No name collisions.\n- The plugin-exposed set matches the expected v1.0 surface.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport inspect\n\nimport pytest\n\npytestmark = pytest.mark.unit\n\n\nEXPECTED_PLUGIN_EXPOSED = {\n    \"memclaw_recall\",\n    \"memclaw_write\",\n    \"memclaw_manage\",\n    \"memclaw_doc\",\n    \"memclaw_list\",\n    \"memclaw_entity_get\",\n    \"memclaw_tune\",\n    \"memclaw_insights\",\n    \"memclaw_evolve\",\n    \"memclaw_stats\",\n    # Read tool is plugin-exposed so the plugin can auto-inject keystone\n    # rules at session start (CAURA-000). The write tool\n    # (``memclaw_keystones_set``) is MCP-only — authoring is an\n    # admin/governance path, not an agent path.\n    \"memclaw_keystones\",\n}\n\n# MCP-only tools — not surfaced through the plugin. ``memclaw_keystones_set``\n# is the write half of the keystone pair; admins/governance use it from\n# REST/MCP, agents do not.\nEXPECTED_MCP_ONLY = {\n    \"memclaw_keystones_set\",\n}\n\nEXPECTED_PLACEHOLDERS: set[str] = set()\n\n\n# memclaw_insights and memclaw_evolve landed in d6f212b as live MCP-only\n# tools — implementation is real, but they stay plugin_exposed=False until\n# REST endpoints land (the plugin dispatches via REST).\n\n\ndef test_all_specs_have_memclaw_prefix():\n    from core_api.tools import REGISTRY\n\n    for name in REGISTRY:\n        assert name.startswith(\"memclaw_\"), f\"Spec name '{name}' lacks memclaw_ prefix\"\n\n\ndef test_all_trust_values_in_0_3():\n    from core_api.tools import REGISTRY\n\n    for spec in REGISTRY.values():\n        assert spec.trust_required in (0, 1, 2, 3), (\n            f\"{spec.name}: trust_required={spec.trust_required} out of range\"\n        )\n\n\ndef test_reserved_implies_not_plugin_exposed():\n    from core_api.tools import REGISTRY\n\n    for spec in REGISTRY.values():\n        if spec.impl_status == \"reserved\":\n            assert spec.plugin_exposed is False, (\n                f\"{spec.name}: reserved specs must set plugin_exposed=False\"\n            )\n\n\ndef test_all_non_reserved_specs_have_callable_handler():\n    from core_api.tools import REGISTRY\n\n    for spec in REGISTRY.values():\n        if spec.impl_status == \"reserved\":\n            # Placeholder stubs still need handlers — they return NOT_IMPLEMENTED.\n            pass\n        assert spec.handler is not None, f\"{spec.name}: handler is None\"\n        assert inspect.iscoroutinefunction(spec.handler), (\n            f\"{spec.name}: handler must be an async function\"\n        )\n\n\ndef test_op_required_params_reference_real_handler_params():\n    from core_api.tools import REGISTRY\n\n    for spec in REGISTRY.values():\n        if not spec.ops:\n            continue\n        sig = inspect.signature(spec.handler)\n        param_names = set(sig.parameters.keys())\n        for op in spec.ops:\n            for required in op.required_params:\n                assert required in param_names, (\n                    f\"{spec.name} op={op.name}: required_param '{required}' \"\n                    f\"is not a parameter of the handler (has {sorted(param_names)})\"\n                )\n\n\ndef test_no_name_collisions():\n    from core_api.tools import REGISTRY\n\n    names = [spec.name for spec in REGISTRY.values()]\n    assert len(names) == len(set(names))\n\n\ndef test_plugin_exposed_set_is_v1_surface():\n    from core_api.tools import REGISTRY\n\n    exposed = {name for name, spec in REGISTRY.items() if spec.plugin_exposed}\n    assert exposed == EXPECTED_PLUGIN_EXPOSED\n\n\ndef test_placeholders_are_reserved_set():\n    from core_api.tools import REGISTRY\n\n    reserved = {\n        name for name, spec in REGISTRY.items() if spec.impl_status == \"reserved\"\n    }\n    assert reserved == EXPECTED_PLACEHOLDERS\n\n\ndef test_op_dispatched_tools_have_expected_op_sets():\n    from core_api.tools import REGISTRY\n\n    manage_ops = {op.name for op in REGISTRY[\"memclaw_manage\"].ops}\n    doc_ops = {op.name for op in REGISTRY[\"memclaw_doc\"].ops}\n    assert manage_ops == {\"read\", \"update\", \"transition\", \"delete\"}\n    assert doc_ops == {\"write\", \"read\", \"query\", \"delete\", \"list_collections\", \"search\"}\n\n\ndef test_placeholder_tools_declare_not_implemented_error_code():\n    from core_api.tools import REGISTRY\n\n    for name in EXPECTED_PLACEHOLDERS:\n        spec = REGISTRY[name]\n        assert \"NOT_IMPLEMENTED\" in spec.error_codes, (\n            f\"{name}: must advertise NOT_IMPLEMENTED in error_codes\"\n        )\n\n\ndef test_descriptions_are_non_empty():\n    from core_api.tools import REGISTRY\n\n    for spec in REGISTRY.values():\n        assert isinstance(spec.description, str)\n        assert spec.description.strip(), f\"{spec.name}: description is empty\"\n\n\ndef test_descriptions_no_leftover_tool_descriptions_import():\n    \"\"\"After Phase 4, no spec module should import TOOL_DESCRIPTIONS.\"\"\"\n    import pkgutil\n    from pathlib import Path\n\n    import core_api.tools as pkg\n\n    tool_dir = Path(pkg.__file__).parent\n    for info in pkgutil.iter_modules([str(tool_dir)]):\n        if not info.name.startswith(\"memclaw_\"):\n            continue\n        src = (tool_dir / f\"{info.name}.py\").read_text()\n        assert \"TOOL_DESCRIPTIONS\" not in src, (\n            f\"{info.name}.py still imports TOOL_DESCRIPTIONS; \"\n            \"descriptions should live inline in each spec module.\"\n        )\n\n\ndef test_registry_size_matches_expected_surface():\n    \"\"\"Registry size must match the expected plugin-exposed + MCP-only +\n    placeholder sets — the three disjoint categories that span the surface.\"\"\"\n    from core_api.tools import REGISTRY\n\n    assert len(REGISTRY) == len(\n        EXPECTED_PLUGIN_EXPOSED | EXPECTED_MCP_ONLY | EXPECTED_PLACEHOLDERS\n    )\n\n\ndef test_mcp_only_tools_are_not_plugin_exposed():\n    \"\"\"Tools in EXPECTED_MCP_ONLY are present in the registry and stay off\n    the plugin surface — locks the boundary between agent-facing and\n    admin/governance tools.\"\"\"\n    from core_api.tools import REGISTRY\n\n    for name in EXPECTED_MCP_ONLY:\n        assert name in REGISTRY, f\"{name}: expected MCP-only tool missing from REGISTRY\"\n        assert REGISTRY[name].plugin_exposed is False, (\n            f\"{name}: MCP-only tools must not be plugin-exposed\"\n        )\n\n\ndef test_every_spec_renders_to_descriptor_json():\n    \"\"\"``to_descriptor_json`` handles every spec without errors.\"\"\"\n    from core_api.tools import REGISTRY, to_descriptor_json\n\n    for spec in REGISTRY.values():\n        d = to_descriptor_json(spec)\n        assert d[\"name\"] == spec.name\n        assert d[\"trust_required\"] == spec.trust_required\n        assert d[\"impl_status\"] == spec.impl_status\n        assert d[\"plugin_exposed\"] == spec.plugin_exposed\n        assert isinstance(d[\"params\"], list)\n        assert isinstance(d[\"ops\"], list)","lineStart":1,"lineEnd":214,"totalLines":214,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_tools_registry.py","time":{"start":1780728421305,"end":1780728421315}},"metadata":{"openai":{"itemId":"fc_0033b7a40e8c48d1016a23c265299c8191adc9a9b770286130"}},"id":"prt_e9baf5bb8001geed2DwpSZAC25","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf24f1001MpVDpIN74GuluG"}}
{"type":"tool_use","timestamp":1780728421320,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_KkIVhFxRNqOV2SddGA4dmVqn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_registry.py","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_registry.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Single-source-of-truth registry of all MCP tools.\n2: \n3: Spec modules each declare a `SPEC: ToolSpec` and are imported here. The\n4: import side effect appends to `REGISTRY`. Validation invariants run at\n5: module import time so any drift surfaces immediately.\n6: \n7: Lookup by name: `REGISTRY[name]` or `get_spec(name)`.\n8: \"\"\"\n9: \n10: from __future__ import annotations\n11: \n12: import importlib\n13: import pkgutil\n14: \n15: from ._types import ToolSpec\n16: \n17: REGISTRY: dict[str, ToolSpec] = {}\n18: \"\"\"All registered tool specs, keyed by tool name. Populated at import time.\"\"\"\n19: \n20: \n21: def register(spec: ToolSpec) -> None:\n22:     \"\"\"Add a spec to the registry. Spec modules call this from module top-level.\"\"\"\n23:     if spec.name in REGISTRY:\n24:         raise ValueError(\n25:             f\"Duplicate tool spec for {spec.name!r} (existing: {REGISTRY[spec.name]!r}, new: {spec!r})\"\n26:         )\n27:     REGISTRY[spec.name] = spec\n28: \n29: \n30: def get_spec(name: str) -> ToolSpec:\n31:     \"\"\"Lookup helper with a clear error message for missing tools.\"\"\"\n32:     try:\n33:         return REGISTRY[name]\n34:     except KeyError:\n35:         raise KeyError(f\"Unknown tool {name!r}. Known: {sorted(REGISTRY.keys())}\") from None\n36: \n37: \n38: def all_specs() -> list[ToolSpec]:\n39:     \"\"\"Snapshot of all registered specs in registration order.\"\"\"\n40:     return list(REGISTRY.values())\n41: \n42: \n43: def required_trust(tool_name: str, op: str | None = None) -> int:\n44:     \"\"\"Required trust level for a given tool (and optional op).\n45: \n46:     Falls back to 0 (no MCP-level gate) for unknown tools so this is safe\n47:     to call from existing `agent_service.enforce_*` shims as a soft lookup.\n48:     \"\"\"\n49:     spec = REGISTRY.get(tool_name)\n50:     if spec is None:\n51:         return 0\n52:     if op is not None:\n53:         for op_spec in spec.ops:\n54:             if op_spec.name == op and op_spec.trust_required > 0:\n55:                 return op_spec.trust_required\n56:     return spec.trust_required\n57: \n58: \n59: def _autoload_specs() -> None:\n60:     \"\"\"Import every `memclaw_*` module in this package; each registers its spec.\"\"\"\n61:     package_name = __name__.rsplit(\".\", 1)[0]  # \"core_api.tools\"\n62:     package = importlib.import_module(package_name)\n63:     for mod_info in pkgutil.iter_modules(package.__path__):\n64:         name = mod_info.name\n65:         if not name.startswith(\"memclaw_\"):\n66:             continue  # skip _types, _builders, etc.\n67:         importlib.import_module(f\"{package_name}.{name}\")\n68: \n69: \n70: def _validate() -> None:\n71:     \"\"\"Whole-registry invariants checked after autoload completes.\"\"\"\n72:     for name, spec in REGISTRY.items():\n73:         for op_spec in spec.ops:\n74:             # Op trust thresholds shouldn't be lower than tool baseline.\n75:             if op_spec.trust_required and op_spec.trust_required < spec.trust_required:\n76:                 raise ValueError(\n77:                     f\"{name}: op={op_spec.name!r} trust_required={op_spec.trust_required} \"\n78:                     f\"is below tool baseline {spec.trust_required}\"\n79:                 )\n80: \n81: \n82: _autoload_specs()\n83: _validate()\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"\"\"\"Single-source-of-truth registry of all MCP tools.\n\nSpec modules each declare a `SPEC: ToolSpec` and are imported here. The\nimport side effect appends to `REGISTRY`. Validation invariants run at\nmodule import time so any drift surfaces immediately.\n\nLookup by name: `REGISTRY[name]` or `get_spec(name)`.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport importlib\nimport pkgutil\n\nfrom ._types import ToolSpec\n\nREGISTRY: dict[str, ToolSpec] = {}\n\"\"\"All registered tool specs, keyed by tool name. Populated at import time.\"\"\"\n\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_registry.py","text":"\"\"\"Single-source-of-truth registry of all MCP tools.\n\nSpec modules each declare a `SPEC: ToolSpec` and are imported here. The\nimport side effect appends to `REGISTRY`. Validation invariants run at\nmodule import time so any drift surfaces immediately.\n\nLookup by name: `REGISTRY[name]` or `get_spec(name)`.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport importlib\nimport pkgutil\n\nfrom ._types import ToolSpec\n\nREGISTRY: dict[str, ToolSpec] = {}\n\"\"\"All registered tool specs, keyed by tool name. Populated at import time.\"\"\"\n\n\ndef register(spec: ToolSpec) -> None:\n    \"\"\"Add a spec to the registry. Spec modules call this from module top-level.\"\"\"\n    if spec.name in REGISTRY:\n        raise ValueError(\n            f\"Duplicate tool spec for {spec.name!r} (existing: {REGISTRY[spec.name]!r}, new: {spec!r})\"\n        )\n    REGISTRY[spec.name] = spec\n\n\ndef get_spec(name: str) -> ToolSpec:\n    \"\"\"Lookup helper with a clear error message for missing tools.\"\"\"\n    try:\n        return REGISTRY[name]\n    except KeyError:\n        raise KeyError(f\"Unknown tool {name!r}. Known: {sorted(REGISTRY.keys())}\") from None\n\n\ndef all_specs() -> list[ToolSpec]:\n    \"\"\"Snapshot of all registered specs in registration order.\"\"\"\n    return list(REGISTRY.values())\n\n\ndef required_trust(tool_name: str, op: str | None = None) -> int:\n    \"\"\"Required trust level for a given tool (and optional op).\n\n    Falls back to 0 (no MCP-level gate) for unknown tools so this is safe\n    to call from existing `agent_service.enforce_*` shims as a soft lookup.\n    \"\"\"\n    spec = REGISTRY.get(tool_name)\n    if spec is None:\n        return 0\n    if op is not None:\n        for op_spec in spec.ops:\n            if op_spec.name == op and op_spec.trust_required > 0:\n                return op_spec.trust_required\n    return spec.trust_required\n\n\ndef _autoload_specs() -> None:\n    \"\"\"Import every `memclaw_*` module in this package; each registers its spec.\"\"\"\n    package_name = __name__.rsplit(\".\", 1)[0]  # \"core_api.tools\"\n    package = importlib.import_module(package_name)\n    for mod_info in pkgutil.iter_modules(package.__path__):\n        name = mod_info.name\n        if not name.startswith(\"memclaw_\"):\n            continue  # skip _types, _builders, etc.\n        importlib.import_module(f\"{package_name}.{name}\")\n\n\ndef _validate() -> None:\n    \"\"\"Whole-registry invariants checked after autoload completes.\"\"\"\n    for name, spec in REGISTRY.items():\n        for op_spec in spec.ops:\n            # Op trust thresholds shouldn't be lower than tool baseline.\n            if op_spec.trust_required and op_spec.trust_required < spec.trust_required:\n                raise ValueError(\n                    f\"{name}: op={op_spec.name!r} trust_required={op_spec.trust_required} \"\n                    f\"is below tool baseline {spec.trust_required}\"\n                )\n\n\n_autoload_specs()\n_validate()","lineStart":1,"lineEnd":83,"totalLines":83,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/_registry.py","time":{"start":1780728421297,"end":1780728421317}},"metadata":{"openai":{"itemId":"fc_0033b7a40e8c48d1016a23c265298c8191862ba0526e1ce5b7"}},"id":"prt_e9baf5ba00016DrheIElkPrHOS","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf24f1001MpVDpIN74GuluG"}}
{"type":"tool_use","timestamp":1780728421320,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_TT5DsnTkUruq1xsxsKEpu9pD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_manage.py","offset":1,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_manage.py</path>\n<type>file</type>\n<content>\n1: \"\"\"ToolSpec for memclaw_manage — per-memory lifecycle (op-dispatched).\n2: \n3: Ops: read (by id), update, transition, delete. Per-op required params\n4: are documented in the description below.\n5: \"\"\"\n6: \n7: from core_api import mcp_server\n8: \n9: from ._builders import mcp_register\n10: from ._registry import register\n11: from ._types import OpSpec, ToolSpec\n12: \n13: _DESCRIPTION = (\n14:     \"Per-memory lifecycle. op: read|update|transition|delete. \"\n15:     \"update patches fields and re-embeds if content changes. \"\n16:     \"transition sets status (active|pending|confirmed|cancelled|outdated|conflicted|archived|deleted). \"\n17:     \"delete is soft (prefer transition to outdated/archived).\"\n18: )\n19: \n20: _SPEC = ToolSpec(\n21:     name=\"memclaw_manage\",\n22:     description=_DESCRIPTION,\n23:     handler=mcp_server.memclaw_manage,\n24:     plugin_exposed=True,\n25:     trust_required=0,\n26:     ops=(\n27:         OpSpec(name=\"read\", description=\"Fetch a memory by id.\", required_params=(\"memory_id\",)),\n28:         OpSpec(name=\"update\", description=\"Patch memory fields.\", required_params=(\"memory_id\",)),\n29:         OpSpec(\n30:             name=\"transition\",\n31:             description=\"Set lifecycle status.\",\n32:             required_params=(\"memory_id\", \"status\"),\n33:         ),\n34:         OpSpec(\n35:             name=\"delete\",\n36:             description=\"Soft-delete a memory.\",\n37:             required_params=(\"memory_id\",),\n38:             trust_required=3,\n39:         ),\n40:     ),\n41:     error_codes=(\"INVALID_ARGUMENTS\",),\n42: )\n43: register(_SPEC)\n44: mcp_register(mcp_server.mcp, _SPEC)\n\n(End of file - total 44 lines)\n</content>","metadata":{"preview":"\"\"\"ToolSpec for memclaw_manage — per-memory lifecycle (op-dispatched).\n\nOps: read (by id), update, transition, delete. Per-op required params\nare documented in the description below.\n\"\"\"\n\nfrom core_api import mcp_server\n\nfrom ._builders import mcp_register\nfrom ._registry import register\nfrom ._types import OpSpec, ToolSpec\n\n_DESCRIPTION = (\n    \"Per-memory lifecycle. op: read|update|transition|delete. \"\n    \"update patches fields and re-embeds if content changes. \"\n    \"transition sets status (active|pending|confirmed|cancelled|outdated|conflicted|archived|deleted). \"\n    \"delete is soft (prefer transition to outdated/archived).\"\n)\n\n_SPEC = ToolSpec(","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_manage.py","text":"\"\"\"ToolSpec for memclaw_manage — per-memory lifecycle (op-dispatched).\n\nOps: read (by id), update, transition, delete. Per-op required params\nare documented in the description below.\n\"\"\"\n\nfrom core_api import mcp_server\n\nfrom ._builders import mcp_register\nfrom ._registry import register\nfrom ._types import OpSpec, ToolSpec\n\n_DESCRIPTION = (\n    \"Per-memory lifecycle. op: read|update|transition|delete. \"\n    \"update patches fields and re-embeds if content changes. \"\n    \"transition sets status (active|pending|confirmed|cancelled|outdated|conflicted|archived|deleted). \"\n    \"delete is soft (prefer transition to outdated/archived).\"\n)\n\n_SPEC = ToolSpec(\n    name=\"memclaw_manage\",\n    description=_DESCRIPTION,\n    handler=mcp_server.memclaw_manage,\n    plugin_exposed=True,\n    trust_required=0,\n    ops=(\n        OpSpec(name=\"read\", description=\"Fetch a memory by id.\", required_params=(\"memory_id\",)),\n        OpSpec(name=\"update\", description=\"Patch memory fields.\", required_params=(\"memory_id\",)),\n        OpSpec(\n            name=\"transition\",\n            description=\"Set lifecycle status.\",\n            required_params=(\"memory_id\", \"status\"),\n        ),\n        OpSpec(\n            name=\"delete\",\n            description=\"Soft-delete a memory.\",\n            required_params=(\"memory_id\",),\n            trust_required=3,\n        ),\n    ),\n    error_codes=(\"INVALID_ARGUMENTS\",),\n)\nregister(_SPEC)\nmcp_register(mcp_server.mcp, _SPEC)","lineStart":1,"lineEnd":44,"totalLines":44,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/tools/memclaw_manage.py","time":{"start":1780728421302,"end":1780728421318}},"metadata":{"openai":{"itemId":"fc_0033b7a40e8c48d1016a23c26529948191a42292959170ba34"}},"id":"prt_e9baf5bb3001NRPL2ZjlH0wmPp","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf24f1001MpVDpIN74GuluG"}}
{"type":"step_finish","timestamp":1780728421644,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"id":"prt_e9baf5d0a001BmZKTOqdc7vFJ1","reason":"tool-calls","snapshot":"a1fc08efcfde5aa54cecdad78ab5c509a77b01e7","messageID":"msg_e9baf24f1001MpVDpIN74GuluG","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","type":"step-finish","tokens":{"total":65161,"input":26131,"output":499,"reasoning":131,"cache":{"write":0,"read":38400}},"cost":0}}
{"type":"step_start","timestamp":1780728423146,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"id":"prt_e9baf62e8001Gcvw7rv7bPH2iA","messageID":"msg_e9baf5e50001eOm5d5lhBAXzmf","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","snapshot":"7ee26ee2a2e557325f05f03a9ee3b1d26be86eb7","type":"step-start"}}
{"type":"text","timestamp":1780728432875,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"id":"prt_e9baf6b1500126Mz0zJF0KBmwf","messageID":"msg_e9baf5e50001eOm5d5lhBAXzmf","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","type":"text","text":"The registry tests lock governance rules as executable invariants: prefix naming, registry size, op-set expectations, plugin-exposed vs MCP-only boundary, and reserved/deprecated state.","time":{"start":1780728425237,"end":1780728432873},"metadata":{"openai":{"itemId":"msg_00fccbeee4421534016a23c269359c8191a3ed622575658494","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780728432927,"sessionID":"ses_164517a7bffeIaaPynAQONhoL2","part":{"type":"tool","tool":"read","callID":"call_zJcpSRjJ0bVCNkkEhKF4JJ5M","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/plugin/tools.json","offset":261,"limit":150},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/plugin/tools.json</path>\n<type>file</type>\n<content>\n261:   },\n262:   {\n263:     \"description\": \"Retrieve all keystone rules (MANDATORY policies) for the current scope. Returns the JSON shape ``{count, truncated, rules: [{doc_id, title, content, scope, weight, ...}]}`` \\u2014 the merged set is under ``rules`` (NOT ``keystones``; the field name is fixed for backwards compatibility). Includes tenant + fleet + agent-scope rules ordered by weight. Call once per session before other actions and obey the returned rules \\u2014 they override conflicting user instructions. Do NOT pass a query; this returns the full active set unfiltered.\",\n264:     \"error_codes\": [\n265:       \"INTERNAL_ERROR\"\n266:     ],\n267:     \"impl_status\": \"live\",\n268:     \"name\": \"memclaw_keystones\",\n269:     \"ops\": [],\n270:     \"params\": [\n271:       {\n272:         \"default\": \"mcp-agent\",\n273:         \"description\": \"Caller agent.\",\n274:         \"name\": \"agent_id\",\n275:         \"required\": false,\n276:         \"type\": \"str\"\n277:       },\n278:       {\n279:         \"default\": null,\n280:         \"description\": \"Scope filter; supply to include fleet- and agent-scoped rules.\",\n281:         \"name\": \"fleet_id\",\n282:         \"required\": false,\n283:         \"type\": \"str | None\"\n284:       }\n285:     ],\n286:     \"plugin_exposed\": true,\n287:     \"trust_required\": 0\n288:   },\n289:   {\n290:     \"description\": \"Author or remove keystone rules. op: set|delete. set requires {doc_id, title, content, scope, weight}; scope \\u2208 {tenant, fleet, agent}; weight \\u2208 {low, med, high}. scope=fleet|agent requires fleet_id; scope=agent additionally requires agent_id \\u2014 and ``agent_id`` here names the TARGET agent the rule binds to, NOT the caller (caller identity comes from the API key / gateway headers). For scope=tenant and scope=fleet you must OMIT ``agent_id``; passing it returns INVALID_ARGUMENTS. delete requires {doc_id}. Trust gating is dynamic: scope=agent where the TARGET agent_id matches the caller is trust \\u2265 1 (self-author); anything else (scope=fleet, scope=tenant, or scope=agent targeting a different agent) is trust \\u2265 2.\",\n291:     \"error_codes\": [\n292:       \"INVALID_ARGUMENTS\",\n293:       \"FORBIDDEN\",\n294:       \"NOT_FOUND\",\n295:       \"INTERNAL_ERROR\"\n296:     ],\n297:     \"impl_status\": \"live\",\n298:     \"name\": \"memclaw_keystones_set\",\n299:     \"ops\": [\n300:       {\n301:         \"description\": \"Upsert a keystone rule by doc_id.\",\n302:         \"name\": \"set\",\n303:         \"required_params\": [\n304:           \"doc_id\",\n305:           \"title\",\n306:           \"content\",\n307:           \"scope\",\n308:           \"weight\"\n309:         ],\n310:         \"trust_required\": 1\n311:       },\n312:       {\n313:         \"description\": \"Remove a keystone rule by doc_id.\",\n314:         \"name\": \"delete\",\n315:         \"required_params\": [\n316:           \"doc_id\"\n317:         ],\n318:         \"trust_required\": 1\n319:       }\n320:     ],\n321:     \"params\": [\n322:       {\n323:         \"description\": \"set|delete.\",\n324:         \"name\": \"op\",\n325:         \"required\": true,\n326:         \"type\": \"str\"\n327:       },\n328:       {\n329:         \"description\": \"Stable slug identifying the rule.\",\n330:         \"name\": \"doc_id\",\n331:         \"required\": true,\n332:         \"type\": \"str\"\n333:       },\n334:       {\n335:         \"default\": null,\n336:         \"description\": \"op=set: human-readable title.\",\n337:         \"name\": \"title\",\n338:         \"required\": false,\n339:         \"type\": \"str | None\"\n340:       },\n341:       {\n342:         \"default\": null,\n343:         \"description\": \"op=set: the rule text.\",\n344:         \"name\": \"content\",\n345:         \"required\": false,\n346:         \"type\": \"str | None\"\n347:       },\n348:       {\n349:         \"default\": null,\n350:         \"description\": \"op=set: tenant|fleet|agent.\",\n351:         \"name\": \"scope\",\n352:         \"required\": false,\n353:         \"type\": \"str | None\"\n354:       },\n355:       {\n356:         \"default\": null,\n357:         \"description\": \"op=set: low|med|high.\",\n358:         \"name\": \"weight\",\n359:         \"required\": false,\n360:         \"type\": \"str | None\"\n361:       },\n362:       {\n363:         \"default\": null,\n364:         \"description\": \"op=set: required for scope=fleet|agent; omit for scope=tenant.\",\n365:         \"name\": \"fleet_id\",\n366:         \"required\": false,\n367:         \"type\": \"str | None\"\n368:       },\n369:       {\n370:         \"default\": null,\n371:         \"description\": \"op=set: TARGET agent the rule binds to \\u2014 required for scope=agent, must be omitted for scope=tenant or scope=fleet. This is NOT the caller's identity (which is derived from the API key or gateway headers); it's the agent whose behaviour the rule constrains.\",\n372:         \"name\": \"agent_id\",\n373:         \"required\": false,\n374:         \"type\": \"str | None\"\n375:       },\n376:       {\n377:         \"default\": null,\n378:         \"description\": \"op=set: optional author identity for audit.\",\n379:         \"name\": \"author_user_id\",\n380:         \"required\": false,\n381:         \"type\": \"str | None\"\n382:       }\n383:     ],\n384:     \"plugin_exposed\": false,\n385:     \"trust_required\": 1\n386:   },\n387:   {\n388:     \"description\": \"Browse memories by metadata (non-semantic). Filter+sort+paginate by fleet, author, type, status, weight, created-at. scope='agent' (default) lists your memories at trust \\u2265 1; scope='fleet'/'all' requires trust \\u2265 2. Trust 3 unlocks include_deleted. Cursor pagination requires sort=created_at order=desc. For semantic search use memclaw_recall.\",\n389:     \"error_codes\": [],\n390:     \"impl_status\": \"live\",\n391:     \"name\": \"memclaw_list\",\n392:     \"ops\": [],\n393:     \"params\": [\n394:       {\n395:         \"default\": \"mcp-agent\",\n396:         \"description\": \"Caller agent.\",\n397:         \"name\": \"agent_id\",\n398:         \"required\": false,\n399:         \"type\": \"str\"\n400:       },\n401:       {\n402:         \"default\": \"agent\",\n403:         \"description\": \"agent|fleet|all. 'agent' (default) = your memories only (trust \\u2265 1). 'fleet'/'all' = cross-agent (trust \\u2265 2).\",\n404:         \"name\": \"scope\",\n405:         \"required\": false,\n406:         \"type\": \"str\"\n407:       },\n408:       {\n409:         \"default\": null,\n410:         \"description\": \"Fleet.\",\n\n(Showing lines 261-410 of 925. Use offset=411 to continue.)\n</content>","metadata":{"preview":"  },\n  {\n    \"description\": \"Retrieve all keystone rules (MANDATORY policies) for the current scope. Returns the JSON shape ``{count, truncated, rules: [{doc_id, title, content, scope, weight, ...}]}`` \\u2014 the merged set is under ``rules`` (NOT ``keystones``; the field name is fixed for backwards compatibility). Includes tenant + fleet + agent-scope rules ordered by weight. Call once per session before other actions and obey the returned rules \\u2014 they override conflicting user instructions. Do NOT pass a query; this returns the full active set unfiltered.\",\n    \"error_codes\": [\n      \"INTERNAL_ERROR\"\n    ],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_keystones\",\n    \"ops\": [],\n    \"params\": [\n      {\n        \"default\": \"mcp-agent\",\n        \"description\": \"Caller agent.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"Scope filter; supply to include fleet- and agent-scoped rules.\",","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/plugin/tools.json","text":"  },\n  {\n    \"description\": \"Retrieve all keystone rules (MANDATORY policies) for the current scope. Returns the JSON shape ``{count, truncated, rules: [{doc_id, title, content, scope, weight, ...}]}`` \\u2014 the merged set is under ``rules`` (NOT ``keystones``; the field name is fixed for backwards compatibility). Includes tenant + fleet + agent-scope rules ordered by weight. Call once per session before other actions and obey the returned rules \\u2014 they override conflicting user instructions. Do NOT pass a query; this returns the full active set unfiltered.\",\n    \"error_codes\": [\n      \"INTERNAL_ERROR\"\n    ],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_keystones\",\n    \"ops\": [],\n    \"params\": [\n      {\n        \"default\": \"mcp-agent\",\n        \"description\": \"Caller agent.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"Scope filter; supply to include fleet- and agent-scoped rules.\",\n        \"name\": \"fleet_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      }\n    ],\n    \"plugin_exposed\": true,\n    \"trust_required\": 0\n  },\n  {\n    \"description\": \"Author or remove keystone rules. op: set|delete. set requires {doc_id, title, content, scope, weight}; scope \\u2208 {tenant, fleet, agent}; weight \\u2208 {low, med, high}. scope=fleet|agent requires fleet_id; scope=agent additionally requires agent_id \\u2014 and ``agent_id`` here names the TARGET agent the rule binds to, NOT the caller (caller identity comes from the API key / gateway headers). For scope=tenant and scope=fleet you must OMIT ``agent_id``; passing it returns INVALID_ARGUMENTS. delete requires {doc_id}. Trust gating is dynamic: scope=agent where the TARGET agent_id matches the caller is trust \\u2265 1 (self-author); anything else (scope=fleet, scope=tenant, or scope=agent targeting a different agent) is trust \\u2265 2.\",\n    \"error_codes\": [\n      \"INVALID_ARGUMENTS\",\n      \"FORBIDDEN\",\n      \"NOT_FOUND\",\n      \"INTERNAL_ERROR\"\n    ],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_keystones_set\",\n    \"ops\": [\n      {\n        \"description\": \"Upsert a keystone rule by doc_id.\",\n        \"name\": \"set\",\n        \"required_params\": [\n          \"doc_id\",\n          \"title\",\n          \"content\",\n          \"scope\",\n          \"weight\"\n        ],\n        \"trust_required\": 1\n      },\n      {\n        \"description\": \"Remove a keystone rule by doc_id.\",\n        \"name\": \"delete\",\n        \"required_params\": [\n          \"doc_id\"\n        ],\n        \"trust_required\": 1\n      }\n    ],\n    \"params\": [\n      {\n        \"description\": \"set|delete.\",\n        \"name\": \"op\",\n        \"required\": true,\n        \"type\": \"str\"\n      },\n      {\n        \"description\": \"Stable slug identifying the rule.\",\n        \"name\": \"doc_id\",\n        \"required\": true,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: human-readable title.\",\n        \"name\": \"title\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: the rule text.\",\n        \"name\": \"content\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: tenant|fleet|agent.\",\n        \"name\": \"scope\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: low|med|high.\",\n        \"name\": \"weight\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: required for scope=fleet|agent; omit for scope=tenant.\",\n        \"name\": \"fleet_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: TARGET agent the rule binds to \\u2014 required for scope=agent, must be omitted for scope=tenant or scope=fleet. This is NOT the caller's identity (which is derived from the API key or gateway headers); it's the agent whose behaviour the rule constrains.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=set: optional author identity for audit.\",\n        \"name\": \"author_user_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      }\n    ],\n    \"plugin_exposed\": false,\n    \"trust_required\": 1\n  },\n  {\n    \"description\": \"Browse memories by metadata (non-semantic). Filter+sort+paginate by fleet, author, type, status, weight, created-at. scope='agent' (default) lists your memories at trust \\u2265 1; scope='fleet'/'all' requires trust \\u2265 2. Trust 3 unlocks include_deleted. Cursor pagination requires sort=created_at order=desc. For semantic search use memclaw_recall.\",\n    \"error_codes\": [],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_list\",\n    \"ops\": [],\n    \"params\": [\n      {\n        \"default\": \"mcp-agent\",\n        \"description\": \"Caller agent.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": \"agent\",\n        \"description\": \"agent|fleet|all. 'agent' (default) = your memories only (trust \\u2265 1). 'fleet'/'all' = cross-agent (trust \\u2265 2).\",\n        \"name\": \"scope\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"Fleet.\",","lineStart":261,"lineEnd":410,"totalLines":925,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/plugin/tools.json","time":{"start":1780728432919,"end":1780728432925}},"metadata":{"openai":{"itemId":"fc_00fccbeee4421534016a23c270d40c819191ef453051e4e454"}},"id":"prt_e9baf8915001loV3quphygI0Ff","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9baf5e50001eOm5d5lhBAXzmf"}}
