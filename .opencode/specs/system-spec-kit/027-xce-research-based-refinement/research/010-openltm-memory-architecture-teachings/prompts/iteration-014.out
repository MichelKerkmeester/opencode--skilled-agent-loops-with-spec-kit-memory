{"type":"tool_use","timestamp":1780929393763,"sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","part":{"type":"tool","tool":"read","callID":"call_Wg4MVvucmfy7vS4Z9MEJAiB5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","offset":261,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts</path>\n<type>file</type>\n<content>\n261: }\n262: \n263: /* ───────────────────────────────────────────────────────────────\n264:    7. BATCH OPERATIONS\n265: ----------------------------------------------------------------*/\n266: \n267: function categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n268:   const result: CategorizedFiles = {\n269:     toIndex: [],\n270:     toUpdate: [],\n271:     toSkip: [],\n272:     toDelete: [],\n273:   };\n274: \n275:   for (const filePath of filePaths) {\n276:     const decision = shouldReindex(filePath);\n277: \n278:     switch (decision) {\n279:       case 'new':\n280:         result.toIndex.push(filePath);\n281:         break;\n282:       case 'modified':\n283:       case 'reindex':\n284:         result.toUpdate.push(filePath);\n285:         break;\n286:       case 'deleted':\n287:         result.toDelete.push(filePath);\n288:         break;\n289:       case 'skip':\n290:       default:\n291:         result.toSkip.push(filePath);\n292:         break;\n293:     }\n294:   }\n295: \n296:   // Include stale indexed paths that are no longer discovered on disk.\n297:   // Without this pass, removed files never enter toDelete during normal scans\n298:   // Because discovery only returns files that currently exist.\n299:   const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n300:   if (staleIndexedPaths.length > 0) {\n301:     const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n302:     for (const stalePath of staleIndexedPaths) {\n303:       const staleKey = getCanonicalPathKey(stalePath);\n304:       if (!seenDeleteKeys.has(staleKey)) {\n305:         result.toDelete.push(stalePath);\n306:         seenDeleteKeys.add(staleKey);\n307:       }\n308:     }\n309:   }\n310: \n311:   return result;\n312: }\n313: \n314: function listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n315:   if (!db) return [];\n316: \n317:   const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n318:   const stalePaths = new Set<string>();\n319: \n320:   try {\n321:     const rows = hasCanonicalPathColumn()\n322:       ? (db.prepare(`\n323:           SELECT DISTINCT file_path, canonical_file_path\n324:           FROM memory_index\n325:           WHERE file_path IS NOT NULL AND file_path != ''\n326:         `) as Database.Statement).all() as IndexedPathRow[]\n327:       : (db.prepare(`\n328:           SELECT DISTINCT file_path\n329:           FROM memory_index\n330:           WHERE file_path IS NOT NULL AND file_path != ''\n331:         `) as Database.Statement).all() as IndexedPathRow[];\n332: \n333:     for (const row of rows) {\n334:       if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n335:         continue;\n336:       }\n337: \n338:       const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n339:         ? row.canonical_file_path\n340:         : getCanonicalPathKey(row.file_path);\n341: \n342:       if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n343:         continue;\n344:       }\n345: \n346:       const filePathExists = getFileMetadata(row.file_path).exists;\n347:       const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n348:         ? getFileMetadata(row.canonical_file_path).exists\n349:         : false;\n350: \n351:       if (!filePathExists && !canonicalPathExists) {\n352:         stalePaths.add(row.file_path);\n353:       }\n354:     }\n355:   } catch (error: unknown) {\n356:     const msg = error instanceof Error ? error.message : String(error);\n357:     console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n358:   }\n359: \n360:   return Array.from(stalePaths);\n361: }\n362: \n363: function listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n364:   if (!db || filePaths.length === 0) return [];\n365: \n366:   const ids = new Set<number>();\n367:   const seenLookupKeys = new Set<string>();\n368: \n369:   try {\n370:     for (const filePath of filePaths) {\n371:       if (typeof filePath !== 'string' || filePath.length === 0) {\n372:         continue;\n373:       }\n374: \n375:       const canonicalPath = getCanonicalPathKey(filePath);\n376:       const lookupKey = `${canonicalPath}::${filePath}`;\n377:       if (seenLookupKeys.has(lookupKey)) {\n378:         continue;\n379:       }\n380:       seenLookupKeys.add(lookupKey);\n381: \n382:       const rows = hasCanonicalPathColumn()\n383:         ? (db.prepare(`\n384:             SELECT id, file_path, canonical_file_path\n385:             FROM memory_index\n386:             WHERE canonical_file_path = ? OR file_path = ?\n387:           `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n388:         : (db.prepare(`\n389:             SELECT id, file_path\n390:             FROM memory_index\n391:             WHERE file_path = ?\n392:           `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n393: \n394:       for (const row of rows) {\n395:         if (!row || typeof row.id !== 'number') {\n396:           continue;\n397:         }\n398: \n399:         const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n400:           ? getFileMetadata(row.file_path).exists\n401:           : false;\n402:         const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n403:           ? getFileMetadata(row.canonical_file_path).exists\n404:           : false;\n405: \n406:         if (rowFileExists || rowCanonicalExists) {\n407:           continue;\n408:         }\n409: \n410:         ids.add(row.id);\n411:       }\n412:     }\n413:   } catch (error: unknown) {\n414:     const msg = error instanceof Error ? error.message : String(error);\n415:     console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n416:     return [];\n417:   }\n418: \n419:   return Array.from(ids).sort((a, b) => a - b);\n420: }\n421: \n422: function normalizeOrphanSweepLimit(limit?: number): number {\n423:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n424:     return DEFAULT_ORPHAN_SWEEP_LIMIT;\n425:   }\n426: \n427:   return Math.max(1, Math.floor(limit));\n428: }\n429: \n430: function indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n431:   const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n432:     ? getFileMetadata(row.file_path).exists\n433:     : false;\n434:   const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n435:     ? getFileMetadata(row.canonical_file_path).exists\n436:     : false;\n437: \n438:   return !rowFileExists && !rowCanonicalExists;\n439: }\n440: \n441: function sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n442:   if (!db) {\n443:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n444:   }\n445: \n446:   const limit = normalizeOrphanSweepLimit(options.limit);\n447:   const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n448:     ? Math.floor(options.cursor)\n449:     : 0;\n450: \n451:   try {\n452:     const rows = hasCanonicalPathColumn()\n453:       ? (db.prepare(`\n454:           SELECT id, file_path, canonical_file_path\n455:           FROM memory_index\n456:           WHERE id > ?\n457:             AND file_path IS NOT NULL\n458:             AND file_path != ''\n459:           ORDER BY id ASC\n460:           LIMIT ?\n461:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n462:       : (db.prepare(`\n463:           SELECT id, file_path\n464:           FROM memory_index\n465:           WHERE id > ?\n466:             AND file_path IS NOT NULL\n467:             AND file_path != ''\n468:           ORDER BY id ASC\n469:           LIMIT ?\n470:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n471: \n472:     const orphanRecordIds: number[] = [];\n473:     for (const row of rows) {\n474:       if (!row || typeof row.id !== 'number') {\n475:         continue;\n476:       }\n477:       if (indexedRecordIsAbsent(row)) {\n478:         orphanRecordIds.push(row.id);\n479:       }\n480:     }\n481: \n482:     return {\n483:       swept: orphanRecordIds.length,\n484:       nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n485:       scannedRows: rows.length,\n486:       orphanRecordIds,\n487:     };\n488:   } catch (error: unknown) {\n489:     const msg = error instanceof Error ? error.message : String(error);\n490:     console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n491:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n492:   }\n493: }\n494: \n495: /* ───────────────────────────────────────────────────────────────\n496:    7b. MOVE RECONCILIATION\n497: ----------------------------------------------------------------*/\n498: \n499: interface MoveReconcileCandidate {\n500:   oldPath: string;\n\n(Showing lines 261-500 of 689. Use offset=501 to continue.)\n</content>","metadata":{"preview":"}\n\n/* ───────────────────────────────────────────────────────────────\n   7. BATCH OPERATIONS\n----------------------------------------------------------------*/\n\nfunction categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n  const result: CategorizedFiles = {\n    toIndex: [],\n    toUpdate: [],\n    toSkip: [],\n    toDelete: [],\n  };\n\n  for (const filePath of filePaths) {\n    const decision = shouldReindex(filePath);\n\n    switch (decision) {\n      case 'new':\n        result.toIndex.push(filePath);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","text":"}\n\n/* ───────────────────────────────────────────────────────────────\n   7. BATCH OPERATIONS\n----------------------------------------------------------------*/\n\nfunction categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n  const result: CategorizedFiles = {\n    toIndex: [],\n    toUpdate: [],\n    toSkip: [],\n    toDelete: [],\n  };\n\n  for (const filePath of filePaths) {\n    const decision = shouldReindex(filePath);\n\n    switch (decision) {\n      case 'new':\n        result.toIndex.push(filePath);\n        break;\n      case 'modified':\n      case 'reindex':\n        result.toUpdate.push(filePath);\n        break;\n      case 'deleted':\n        result.toDelete.push(filePath);\n        break;\n      case 'skip':\n      default:\n        result.toSkip.push(filePath);\n        break;\n    }\n  }\n\n  // Include stale indexed paths that are no longer discovered on disk.\n  // Without this pass, removed files never enter toDelete during normal scans\n  // Because discovery only returns files that currently exist.\n  const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n  if (staleIndexedPaths.length > 0) {\n    const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n    for (const stalePath of staleIndexedPaths) {\n      const staleKey = getCanonicalPathKey(stalePath);\n      if (!seenDeleteKeys.has(staleKey)) {\n        result.toDelete.push(stalePath);\n        seenDeleteKeys.add(staleKey);\n      }\n    }\n  }\n\n  return result;\n}\n\nfunction listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n  if (!db) return [];\n\n  const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n  const stalePaths = new Set<string>();\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT DISTINCT file_path, canonical_file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[]\n      : (db.prepare(`\n          SELECT DISTINCT file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[];\n\n    for (const row of rows) {\n      if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n        continue;\n      }\n\n      const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? row.canonical_file_path\n        : getCanonicalPathKey(row.file_path);\n\n      if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n        continue;\n      }\n\n      const filePathExists = getFileMetadata(row.file_path).exists;\n      const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? getFileMetadata(row.canonical_file_path).exists\n        : false;\n\n      if (!filePathExists && !canonicalPathExists) {\n        stalePaths.add(row.file_path);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n  }\n\n  return Array.from(stalePaths);\n}\n\nfunction listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n  if (!db || filePaths.length === 0) return [];\n\n  const ids = new Set<number>();\n  const seenLookupKeys = new Set<string>();\n\n  try {\n    for (const filePath of filePaths) {\n      if (typeof filePath !== 'string' || filePath.length === 0) {\n        continue;\n      }\n\n      const canonicalPath = getCanonicalPathKey(filePath);\n      const lookupKey = `${canonicalPath}::${filePath}`;\n      if (seenLookupKeys.has(lookupKey)) {\n        continue;\n      }\n      seenLookupKeys.add(lookupKey);\n\n      const rows = hasCanonicalPathColumn()\n        ? (db.prepare(`\n            SELECT id, file_path, canonical_file_path\n            FROM memory_index\n            WHERE canonical_file_path = ? OR file_path = ?\n          `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n        : (db.prepare(`\n            SELECT id, file_path\n            FROM memory_index\n            WHERE file_path = ?\n          `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n\n      for (const row of rows) {\n        if (!row || typeof row.id !== 'number') {\n          continue;\n        }\n\n        const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n          ? getFileMetadata(row.file_path).exists\n          : false;\n        const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n          ? getFileMetadata(row.canonical_file_path).exists\n          : false;\n\n        if (rowFileExists || rowCanonicalExists) {\n          continue;\n        }\n\n        ids.add(row.id);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n    return [];\n  }\n\n  return Array.from(ids).sort((a, b) => a - b);\n}\n\nfunction normalizeOrphanSweepLimit(limit?: number): number {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return DEFAULT_ORPHAN_SWEEP_LIMIT;\n  }\n\n  return Math.max(1, Math.floor(limit));\n}\n\nfunction indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n  const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n    ? getFileMetadata(row.file_path).exists\n    : false;\n  const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n    ? getFileMetadata(row.canonical_file_path).exists\n    : false;\n\n  return !rowFileExists && !rowCanonicalExists;\n}\n\nfunction sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n  if (!db) {\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n\n  const limit = normalizeOrphanSweepLimit(options.limit);\n  const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n    ? Math.floor(options.cursor)\n    : 0;\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT id, file_path, canonical_file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n      : (db.prepare(`\n          SELECT id, file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n\n    const orphanRecordIds: number[] = [];\n    for (const row of rows) {\n      if (!row || typeof row.id !== 'number') {\n        continue;\n      }\n      if (indexedRecordIsAbsent(row)) {\n        orphanRecordIds.push(row.id);\n      }\n    }\n\n    return {\n      swept: orphanRecordIds.length,\n      nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n      scannedRows: rows.length,\n      orphanRecordIds,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7b. MOVE RECONCILIATION\n----------------------------------------------------------------*/\n\ninterface MoveReconcileCandidate {\n  oldPath: string;","lineStart":261,"lineEnd":500,"totalLines":689,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","time":{"start":1780929393748,"end":1780929393760}},"metadata":{"openai":{"itemId":"fc_00ec9df091445201016a26d37147ac8191a4ebc74d1bff1b49"}},"id":"prt_ea7a9f29c001FZkj69nqVytbF8","sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","messageID":"msg_ea7a9dd00001qLwUiIMXxz9I7l"}}
