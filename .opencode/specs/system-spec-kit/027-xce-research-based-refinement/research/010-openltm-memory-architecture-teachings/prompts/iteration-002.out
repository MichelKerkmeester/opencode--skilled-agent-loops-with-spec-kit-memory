{"type":"tool_use","timestamp":1780925339174,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_HBRwwVmyEUE2gEwTpJKgNtjz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/cognitive/fsrs-scheduler.ts","offset":297,"limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/cognitive/fsrs-scheduler.ts</path>\n<type>file</type>\n<content>\n297: const IMPORTANCE_TIER_STABILITY_MULTIPLIER: Record<string, number> = {\n298:   constitutional: Infinity, // never decays\n299:   critical: Infinity,       // never decays\n300:   important: 1.5,           // slower decay\n301:   normal: 1.0,              // standard\n302:   temporary: 0.5,           // faster decay\n303:   deprecated: 0.25,         // fastest decay\n304: };\n305: \n306: /**\n307:  * Compute combined stability multiplier from context_type and importance_tier.\n308:  *\n309:  * Logic:\n310:  *   - If either dimension resolves to Infinity, the combined result is Infinity\n311:  *     (no-decay wins unconditionally).\n312:  *   - Unknown context_type or importance_tier values default to 1.0 (standard).\n313:  *   - Combined multiplier = contextMult * tierMult.\n314:  *\n315:  * When the result is Infinity, callers should treat stability as Infinity,\n316:  * which makes R(t) = (1 + factor * t / Infinity)^decay = 1.0 for all t.\n317:  *\n318:  * @param contextType    Continuity-row context_type field (e.g. \"decision\", \"research\")\n319:  * @param importanceTier Continuity-row importance_tier field (e.g. \"constitutional\", \"normal\")\n320:  * @returns Combined stability multiplier (may be Infinity)\n321:  */\n322: function getClassificationDecayMultiplier(contextType: string, importanceTier: string): number {\n323:   const contextMult = CONTEXT_TYPE_STABILITY_MULTIPLIER[contextType] ?? 1.0;\n324:   const tierMult = IMPORTANCE_TIER_STABILITY_MULTIPLIER[importanceTier] ?? 1.0;\n325: \n326:   // Infinity * anything = Infinity (no-decay wins)\n327:   if (!isFinite(contextMult) || !isFinite(tierMult)) {\n328:     return Infinity;\n329:   }\n330: \n331:   return contextMult * tierMult;\n332: }\n333: \n334: /**\n335:  * Apply classification-based decay to a stability value.\n336:  * Gated by SPECKIT_CLASSIFICATION_DECAY env var (must be \"true\" or \"1\").\n337:  *\n338:  * Returns stability unchanged when the feature flag is disabled.\n339:  * Returns Infinity when the combined multiplier is Infinity (no-decay).\n340:  *\n341:  * @param stability      Base FSRS stability value\n342:  * @param contextType    Continuity-row context_type field\n343:  * @param importanceTier Continuity-row importance_tier field\n344:  * @returns Adjusted stability value\n345:  */\n346: function applyClassificationDecay(\n347:   stability: number,\n348:   contextType: string,\n349:   importanceTier: string\n350: ): number {\n351:   if (isHybridDecayPolicyEnabled() && HYBRID_NO_DECAY_CONTEXT_TYPES.has(contextType)) {\n352:     return Infinity;\n353:   }\n354: \n355:   // Graduated: default-ON. Set SPECKIT_CLASSIFICATION_DECAY=false to disable.\n356:   const flag = process.env.SPECKIT_CLASSIFICATION_DECAY?.toLowerCase();\n357:   if (flag === 'false' || flag === '0') {\n358:     return stability;\n359:   }\n360: \n361:   const multiplier = getClassificationDecayMultiplier(contextType, importanceTier);\n362:   if (!isFinite(multiplier)) {\n363:     return Infinity;\n364:   }\n365: \n366:   return stability * multiplier;\n367: }\n368: \n369: /* --- 4b. HYBRID DECAY POLICY ---\n370:    Gated by SPECKIT_HYBRID_DECAY_POLICY env var (default OFF).\n371:    Distinguishes two classes of memory:\n372: \n373:    1. NO-DECAY documents — context_type in {decision, constitutional, critical}\n374:       These represent permanent knowledge artifacts. Their stability is treated as\n375:       Infinity so R(t) = 1.0 at all times.\n376: \n377:    2. ENGAGEMENT-SENSITIVE documents — all other context_types (session, scratch,\n378:       transient, implementation, discovery, research, general)\n379:       Normal FSRS schedule applies without modification.\n380: \n381:    This is intentionally SEPARATE from applyClassificationDecay, which\n382:    uses a combined context_type × importance_tier multiplier and is default-ON.\n383:    SPECKIT_HYBRID_DECAY_POLICY is default-OFF and must be opted into explicitly.\n384:    DO NOT combine both policies on the same memory. */\n385: \n386: /**\n387:  * Context types that should never decay under the hybrid decay policy.\n388:  * Classified as permanent knowledge artifacts.\n389:  */\n390: const HYBRID_NO_DECAY_CONTEXT_TYPES: ReadonlySet<string> = new Set([\n391:   'planning',\n392:   ...Object.keys(LEGACY_CONTEXT_TYPE_ALIASES).filter(k => LEGACY_CONTEXT_TYPE_ALIASES[k] === 'planning'),\n393:   'constitutional',\n394:   'critical',\n395: ]);\n396: const HYBRID_FSRS_CONTEXT_TYPES: ReadonlySet<string> = new Set([\n397:   'session',\n398:   'scratch',\n399:   'transient',\n400:   'implementation',\n401:   'discovery',\n402:   'research',\n403:   'general',\n404: ]);\n405: const NO_DECAY = Infinity;\n406: \n407: /**\n408:  * Check whether the hybrid decay policy feature flag is enabled.\n409:  * Default: TRUE (graduated). Set SPECKIT_HYBRID_DECAY_POLICY=false to disable.\n410:  */\n411: function isHybridDecayPolicyEnabled(): boolean {\n412:   const val = process.env.SPECKIT_HYBRID_DECAY_POLICY?.toLowerCase().trim();\n413:   return val !== 'false' && val !== '0';\n414: }\n415: \n416: /**\n417:  * Classify a memory's decay behaviour under the hybrid policy.\n418:  *\n419:  * Returns:\n420:  *   - 'no_decay'       for decision / constitutional / critical context types\n421:  *   - 'fsrs_schedule'  for all engagement-sensitive types (session, scratch, etc.)\n422:  */\n423: type HybridDecayClass = 'no_decay' | 'fsrs_schedule';\n424: \n425: function classifyHybridDecay(contextType: string): HybridDecayClass {\n426:   if (HYBRID_NO_DECAY_CONTEXT_TYPES.has(contextType)) {\n427:     return 'no_decay';\n428:   }\n429:   return 'fsrs_schedule';\n430: }\n431: \n432: function getHybridDecayMultiplier(contextType: string, _importanceTier?: string): number {\n433:   if (!isHybridDecayPolicyEnabled()) {\n434:     return 1;\n435:   }\n436:   return HYBRID_NO_DECAY_CONTEXT_TYPES.has(contextType) ? NO_DECAY : 1;\n437: }\n438: \n439: /**\n440:  * Apply the hybrid decay policy to a stability value.\n441:  *\n442:  * When SPECKIT_HYBRID_DECAY_POLICY is OFF (default), returns stability unchanged.\n443:  * When ON:\n444:  *   - decision / constitutional / critical → returns Infinity (no decay)\n445:  *   - all others → returns stability unchanged (normal FSRS schedule)\n446:  *\n447:  * @param stability    Base FSRS stability value\n448:  * @param contextType  Continuity-row context_type field (classified at save time)\n449:  * @returns Adjusted stability: Infinity for no-decay types, original otherwise\n450:  */\n451: function applyHybridDecayPolicy(stability: number, contextType: string, importanceTier?: string): number {\n452:   const multiplier = getHybridDecayMultiplier(contextType, importanceTier);\n453:   return Number.isFinite(multiplier) ? stability * multiplier : NO_DECAY;\n454: }\n455: \n456: export {\n457:   // Constants\n458:   FSRS_FACTOR,\n459:   FSRS_DECAY,\n460:   FSRS_HALF_LIFE_FACTOR, // Derived constant for half-life ↔ stability\n461:   GRADE_AGAIN,\n462:   GRADE_HARD,\n463:   GRADE_GOOD,\n464:   GRADE_EASY,\n465:   DEFAULT_INITIAL_STABILITY,\n466:   DEFAULT_INITIAL_DIFFICULTY,\n467:   MIN_DIFFICULTY,\n468:   MAX_DIFFICULTY,\n469:   MIN_STABILITY,\n470:   FSRS_CONSTANTS,\n471:   TIER_MULTIPLIER,\n472: \n473:   // Classification-based decay constants and functions\n474:   CONTEXT_TYPE_STABILITY_MULTIPLIER,\n475:   IMPORTANCE_TIER_STABILITY_MULTIPLIER,\n476:   getClassificationDecayMultiplier,\n477:   applyClassificationDecay,\n478: \n479:   // Hybrid decay policy\n480:   NO_DECAY,\n481:   HYBRID_FSRS_CONTEXT_TYPES,\n482:   HYBRID_NO_DECAY_CONTEXT_TYPES,\n483:   isHybridDecayPolicyEnabled,\n484:   classifyHybridDecay,\n485:   getHybridDecayMultiplier,\n486:   applyHybridDecayPolicy,\n487: \n488:   // Core functions\n489:   calculateRetrievability,\n490:   updateStability,\n491:   calculateOptimalInterval,\n492:   updateDifficulty,\n493:   calculateElapsedDays,\n494:   getNextReviewDate,\n495:   createInitialParams,\n496:   processReview,\n497: };\n498: \n499: export type {\n500:   FsrsParams,\n501:   ReviewResult,\n502:   HybridDecayClass,\n503: };\n\n(End of file - total 503 lines)\n</content>","metadata":{"preview":"const IMPORTANCE_TIER_STABILITY_MULTIPLIER: Record<string, number> = {\n  constitutional: Infinity, // never decays\n  critical: Infinity,       // never decays\n  important: 1.5,           // slower decay\n  normal: 1.0,              // standard\n  temporary: 0.5,           // faster decay\n  deprecated: 0.25,         // fastest decay\n};\n\n/**\n * Compute combined stability multiplier from context_type and importance_tier.\n *\n * Logic:\n *   - If either dimension resolves to Infinity, the combined result is Infinity\n *     (no-decay wins unconditionally).\n *   - Unknown context_type or importance_tier values default to 1.0 (standard).\n *   - Combined multiplier = contextMult * tierMult.\n *\n * When the result is Infinity, callers should treat stability as Infinity,\n * which makes R(t) = (1 + factor * t / Infinity)^decay = 1.0 for all t.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/cognitive/fsrs-scheduler.ts","text":"const IMPORTANCE_TIER_STABILITY_MULTIPLIER: Record<string, number> = {\n  constitutional: Infinity, // never decays\n  critical: Infinity,       // never decays\n  important: 1.5,           // slower decay\n  normal: 1.0,              // standard\n  temporary: 0.5,           // faster decay\n  deprecated: 0.25,         // fastest decay\n};\n\n/**\n * Compute combined stability multiplier from context_type and importance_tier.\n *\n * Logic:\n *   - If either dimension resolves to Infinity, the combined result is Infinity\n *     (no-decay wins unconditionally).\n *   - Unknown context_type or importance_tier values default to 1.0 (standard).\n *   - Combined multiplier = contextMult * tierMult.\n *\n * When the result is Infinity, callers should treat stability as Infinity,\n * which makes R(t) = (1 + factor * t / Infinity)^decay = 1.0 for all t.\n *\n * @param contextType    Continuity-row context_type field (e.g. \"decision\", \"research\")\n * @param importanceTier Continuity-row importance_tier field (e.g. \"constitutional\", \"normal\")\n * @returns Combined stability multiplier (may be Infinity)\n */\nfunction getClassificationDecayMultiplier(contextType: string, importanceTier: string): number {\n  const contextMult = CONTEXT_TYPE_STABILITY_MULTIPLIER[contextType] ?? 1.0;\n  const tierMult = IMPORTANCE_TIER_STABILITY_MULTIPLIER[importanceTier] ?? 1.0;\n\n  // Infinity * anything = Infinity (no-decay wins)\n  if (!isFinite(contextMult) || !isFinite(tierMult)) {\n    return Infinity;\n  }\n\n  return contextMult * tierMult;\n}\n\n/**\n * Apply classification-based decay to a stability value.\n * Gated by SPECKIT_CLASSIFICATION_DECAY env var (must be \"true\" or \"1\").\n *\n * Returns stability unchanged when the feature flag is disabled.\n * Returns Infinity when the combined multiplier is Infinity (no-decay).\n *\n * @param stability      Base FSRS stability value\n * @param contextType    Continuity-row context_type field\n * @param importanceTier Continuity-row importance_tier field\n * @returns Adjusted stability value\n */\nfunction applyClassificationDecay(\n  stability: number,\n  contextType: string,\n  importanceTier: string\n): number {\n  if (isHybridDecayPolicyEnabled() && HYBRID_NO_DECAY_CONTEXT_TYPES.has(contextType)) {\n    return Infinity;\n  }\n\n  // Graduated: default-ON. Set SPECKIT_CLASSIFICATION_DECAY=false to disable.\n  const flag = process.env.SPECKIT_CLASSIFICATION_DECAY?.toLowerCase();\n  if (flag === 'false' || flag === '0') {\n    return stability;\n  }\n\n  const multiplier = getClassificationDecayMultiplier(contextType, importanceTier);\n  if (!isFinite(multiplier)) {\n    return Infinity;\n  }\n\n  return stability * multiplier;\n}\n\n/* --- 4b. HYBRID DECAY POLICY ---\n   Gated by SPECKIT_HYBRID_DECAY_POLICY env var (default OFF).\n   Distinguishes two classes of memory:\n\n   1. NO-DECAY documents — context_type in {decision, constitutional, critical}\n      These represent permanent knowledge artifacts. Their stability is treated as\n      Infinity so R(t) = 1.0 at all times.\n\n   2. ENGAGEMENT-SENSITIVE documents — all other context_types (session, scratch,\n      transient, implementation, discovery, research, general)\n      Normal FSRS schedule applies without modification.\n\n   This is intentionally SEPARATE from applyClassificationDecay, which\n   uses a combined context_type × importance_tier multiplier and is default-ON.\n   SPECKIT_HYBRID_DECAY_POLICY is default-OFF and must be opted into explicitly.\n   DO NOT combine both policies on the same memory. */\n\n/**\n * Context types that should never decay under the hybrid decay policy.\n * Classified as permanent knowledge artifacts.\n */\nconst HYBRID_NO_DECAY_CONTEXT_TYPES: ReadonlySet<string> = new Set([\n  'planning',\n  ...Object.keys(LEGACY_CONTEXT_TYPE_ALIASES).filter(k => LEGACY_CONTEXT_TYPE_ALIASES[k] === 'planning'),\n  'constitutional',\n  'critical',\n]);\nconst HYBRID_FSRS_CONTEXT_TYPES: ReadonlySet<string> = new Set([\n  'session',\n  'scratch',\n  'transient',\n  'implementation',\n  'discovery',\n  'research',\n  'general',\n]);\nconst NO_DECAY = Infinity;\n\n/**\n * Check whether the hybrid decay policy feature flag is enabled.\n * Default: TRUE (graduated). Set SPECKIT_HYBRID_DECAY_POLICY=false to disable.\n */\nfunction isHybridDecayPolicyEnabled(): boolean {\n  const val = process.env.SPECKIT_HYBRID_DECAY_POLICY?.toLowerCase().trim();\n  return val !== 'false' && val !== '0';\n}\n\n/**\n * Classify a memory's decay behaviour under the hybrid policy.\n *\n * Returns:\n *   - 'no_decay'       for decision / constitutional / critical context types\n *   - 'fsrs_schedule'  for all engagement-sensitive types (session, scratch, etc.)\n */\ntype HybridDecayClass = 'no_decay' | 'fsrs_schedule';\n\nfunction classifyHybridDecay(contextType: string): HybridDecayClass {\n  if (HYBRID_NO_DECAY_CONTEXT_TYPES.has(contextType)) {\n    return 'no_decay';\n  }\n  return 'fsrs_schedule';\n}\n\nfunction getHybridDecayMultiplier(contextType: string, _importanceTier?: string): number {\n  if (!isHybridDecayPolicyEnabled()) {\n    return 1;\n  }\n  return HYBRID_NO_DECAY_CONTEXT_TYPES.has(contextType) ? NO_DECAY : 1;\n}\n\n/**\n * Apply the hybrid decay policy to a stability value.\n *\n * When SPECKIT_HYBRID_DECAY_POLICY is OFF (default), returns stability unchanged.\n * When ON:\n *   - decision / constitutional / critical → returns Infinity (no decay)\n *   - all others → returns stability unchanged (normal FSRS schedule)\n *\n * @param stability    Base FSRS stability value\n * @param contextType  Continuity-row context_type field (classified at save time)\n * @returns Adjusted stability: Infinity for no-decay types, original otherwise\n */\nfunction applyHybridDecayPolicy(stability: number, contextType: string, importanceTier?: string): number {\n  const multiplier = getHybridDecayMultiplier(contextType, importanceTier);\n  return Number.isFinite(multiplier) ? stability * multiplier : NO_DECAY;\n}\n\nexport {\n  // Constants\n  FSRS_FACTOR,\n  FSRS_DECAY,\n  FSRS_HALF_LIFE_FACTOR, // Derived constant for half-life ↔ stability\n  GRADE_AGAIN,\n  GRADE_HARD,\n  GRADE_GOOD,\n  GRADE_EASY,\n  DEFAULT_INITIAL_STABILITY,\n  DEFAULT_INITIAL_DIFFICULTY,\n  MIN_DIFFICULTY,\n  MAX_DIFFICULTY,\n  MIN_STABILITY,\n  FSRS_CONSTANTS,\n  TIER_MULTIPLIER,\n\n  // Classification-based decay constants and functions\n  CONTEXT_TYPE_STABILITY_MULTIPLIER,\n  IMPORTANCE_TIER_STABILITY_MULTIPLIER,\n  getClassificationDecayMultiplier,\n  applyClassificationDecay,\n\n  // Hybrid decay policy\n  NO_DECAY,\n  HYBRID_FSRS_CONTEXT_TYPES,\n  HYBRID_NO_DECAY_CONTEXT_TYPES,\n  isHybridDecayPolicyEnabled,\n  classifyHybridDecay,\n  getHybridDecayMultiplier,\n  applyHybridDecayPolicy,\n\n  // Core functions\n  calculateRetrievability,\n  updateStability,\n  calculateOptimalInterval,\n  updateDifficulty,\n  calculateElapsedDays,\n  getNextReviewDate,\n  createInitialParams,\n  processReview,\n};\n\nexport type {\n  FsrsParams,\n  ReviewResult,\n  HybridDecayClass,\n};","lineStart":297,"lineEnd":503,"totalLines":503,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/cognitive/fsrs-scheduler.ts","time":{"start":1780925339164,"end":1780925339172}},"metadata":{"openai":{"itemId":"fc_0553fa997664a5a3016a26c39a03248191aa94ec9bcc519683"}},"id":"prt_ea76c11a8001n5k2ktG1bhqXL5","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76c04d6001tlAr50IMDY4Ml7"}}
