═════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\nconst fs = require('node:fs');\nconst path = require('node:path');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\nconst MIRROR_TEMPLATES = [\n  '.opencode/agents/{name}.md',\n  '.claude/agents/{name}.md',\n];\nconst GLOBAL_DOC_PATHS = ['CLAUDE.md', '.claude/CLAUDE.md'];\nconst SKILL_ADVISOR_PATH = '.opencode/skills/scripts/skill_advisor.py';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/agent-improvement/scan-integration.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ scan-integration — scan agent integration surfaces across runtimes      ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\nconst fs = require('node:fs');\nconst path = require('node:path');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\nconst MIRROR_TEMPLATES = [\n  '.opencode/agents/{name}.md',\n  '.claude/agents/{name}.md',\n];\nconst GLOBAL_DOC_PATHS = ['CLAUDE.md', '.claude/CLAUDE.md'];\nconst SKILL_ADVISOR_PATH = '.opencode/skills/scripts/skill_advisor.py';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\nfunction parseArgs(argv) {\n  const args = {};\n  for (const entry of argv) {\n    if (!entry.startsWith('--')) continue;\n    const [key, ...rest] = entry.slice(2).split('=');\n    args[key] = rest.length > 0 ? rest.join('=') : true;\n  }\n  return args;\n}\n\nfunction readOptional(filePath) {\n  try { return fs.readFileSync(filePath, 'utf8'); } catch (_e) { return null; }\n}\n\nfunction walk(dir, acc) {\n  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {\n    if (entry.name === 'node_modules' || entry.name === '.git') continue;\n    const full = path.join(dir, entry.name);\n    if (entry.isDirectory()) walk(full, acc);\n    else acc.push(full);\n  }\n}\n\nfunction stripFrontmatter(content) {\n  return content.replace(/^---[\\s\\S]*?---\\n/, '');\n}\n\nfunction parseFrontmatter(content) {\n  const match = content.match(/^---\\n([\\s\\S]*?)\\n---/);\n  if (!match) return null;\n  const fm = {};\n  for (const line of match[1].split('\\n')) {\n    const idx = line.indexOf(':');\n    if (idx < 0) continue;\n    const key = line.slice(0, idx).trim();\n    const val = line.slice(idx + 1).trim().replace(/^[\"']|[\"']$/g, '');\n    if (key) fm[key] = val;\n  }\n  return fm;\n}\n\nfunction collectFiles(rootDir) {\n  if (!fs.existsSync(rootDir)) return [];\n  const files = [];\n  walk(rootDir, files);\n  return files;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\nfunction extractSignals(body) {\n  const signals = [];\n  const re = /\\*\\*(.+?)\\*\\*/g;\n  let m;\n  while ((m = re.exec(body)) !== null) {","lineStart":1,"lineEnd":80,"totalLines":233,"truncated":true}},"title":".opencode/skills/deep-loop-workflows/deep-improvement/scripts/agent-improvement/scan-integration.cjs","time":{"start":1782925289018,"end":1782925289038}},"metadata":{"op