tions, etc). ║\n\n  Line 27:  * Concatenates all text parts; falls back to raw stdout for other executors.\n\n  Line 62:  * files from the saved stdout (write-failure salvage path).\n\n  Line 66:  *     salvaged_from_stdout event to the state log.\n\n  Line 73:  * @returns {{ salvaged: number, failed: number }}\n\n  Line 77:   if (!stateLogName) return { salvaged: 0, failed: 0 };\n\n  Line 82:   if (!fs.existsSync(stateLogPath)) return { salvaged: 0, failed: 0 };\n\n  Line 90:     return { salvaged: 0, failed: 0 };\n\n  Line 105:   if (iterationNumbers.size === 0) return { salvaged: 0, failed: 0 };\n\n  Line 107:   let salvaged = 0;\n\n  Line 129:         event: 'salvaged_from_stdout',\n\n  Line 131:         id: 'salvaged_from_stdout',\n\n  Line 136:       salvaged += 1;\n\n  Line 140:         `<!-- fanout_salvage_failed: iteration ${iterNum} content not recoverable from subprocess stdout -->\\n`,\n\n  Line 147:   return { salvaged, failed };\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/compile-command-contracts.cjs:\n  Line 22:     writer: '.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts',\n\n  Line 93:         'executor',\n\n  Line 98:         'executor.mode',\n\n  Line 99:         'executor.cli',\n\n  Line 100:         'executor.model',\n\n  Line 101:         'executor.reasoning',\n\n  Line 102:         'executor.service_tier',\n\n  Line 103:         'executor.timeout',\n\n  Line 145:         'mixing multiple CLI executors within one round',\n\n  Line 209:         'executor',\n\n  Line 210:         'executor_model',\n\n  Line 211:         'executor_config_dir',\n\n  Line 212:         'executor_reasoning',\n\n  Line 213:         'executor_service_tier',\n\n  Line 214:         'executor_timeout',\n\n  Line 217:         'fanout_executors',\n\n  Line 309:         'executor',\n\n  Line 310:         'executor_model',\n\n  Line 311:         'executor_config_dir',\n\n  Line 312:         'executor_reasoning',\n\n  Line 313:         'executor_service_tier',\n\n  Line 314:         'executor_timeout',\n\n  Line 316:         'fanout_executors',\n\n  Line 462:   // Council convenes its seats in-CLI (the runtime's own models); every other deep\n\n  Line 464:   // work differ accordingly, so the executor is told the right thing per mode.\n\n  Line 470:         `- CONVENE IN-CLI: run the round's seats using your OWN model bench / distinct reasoning lenses in-CLI — do NOT dispatch a task per seat (in-CLI is the default and common council mode). Produce at least ${minSeats} DISTINCT seats.`,\n\n  Line 483:     '- DO NOT emit the consolidated setup question (target/mode, research topic, Spec Folder A/B/C/D/E, execution mode, max iterations, executor). The bound spec_folder is your write authority; do not ask which spec folder should own the writes.',\n\n  Line 511:     'This generated contract collapses the maintained command authority chain into one grep-checkable executor contract. Maintained sources remain authoritative; regenerate this file when any source digest changes.',\n\n  Line 515:     '> Read this first. It is an imperative to you, the executor — not background information.',\n\n  Line 568:     '## executorContract',\n\n  Line 571:     'block: executorContract',\n\n  Line 578:     '  - \"Native and CLI executors must produce only the required prompt-pack artifacts inside the resolved boundary.\"',\n\n  Line 603:     ...Object.entries(definition.tools.permittedByExecutor).flatMap(([executor, tools]) => [\n\n  Line 604:       `  ${executor}:`,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs:\n  Line 10: // resolved_route). A model-driven loop is trusted to self-check today, which lets a\n\n  Line 147:   // the bounded retry. The state reducer applies the same latest-record-wins rule.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs:\n  Line 163: function parseRatioWithDefault(value, key, fallback) {\n\n  Line 165:   return parsed === null ? fallback : parsed;\n\n  Line 321:     // (by-model confidence); then scope coverage, relevance gate, dependency map.\n\n  Line 472:     blockers.push({ type: 'low_cross_executor_agreement', description: `Cross-executor agreement (${(signals.agreementRate * 100).toFixed(0)}%) is below threshold. Findings are not yet confirmed by multiple model lenses; STOP is blocked.`, count: 1, severity: 'blocking' });\n\n  Line 475:     blockers.push({ type: 'context_contradictions', description: `${contradictions.length} contradiction(s) detected across executors; reconcile before STOP.`, count: contradictions.length, severity: 'warning' });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs:\n  Line 28:   SALVAGE_MISS: 'salvage_miss',\n\n  Line 158:     salvaged: readNonNegativeInteger(value.salvaged) ?? 0,\n\n  Line 164:  * Classify a lineage failure using only bounded process and salvage signals.\n\n  Line 167:  * @returns {{failure_class:string,retry_verdict:string,retryable:boolean,exit_code:number|null,timed_out:boolean,salvage:{salvaged:number,failed:number}|null}}\n\n  Line 172:   const salvage = error && typeof error === 'object' ? normalizeSalvageSummary(error.salvage) : null;\n\n  Line 177:   } else if (salvage && salvage.failed > 0 && salvage.salvaged === 0) {\n\n  Line 179:   } else if (salvage && salvage.failed > 0) {\n\n  Line 180:     // Mixed salvage: at least one iteration was recovered but some artifact/iteration\n\n  Line 183:     // than consumed as terminal. Without this branch a { salvaged: >0, failed: >0 }\n\n  Line 188:   const retryable =\n\n  Line 194:     retry_verdict: retryable ? LINEAGE_RETRY_VERDICTS.TRANSIENT : LINEAGE_RETRY_VERDICTS.FATAL,\n\n  Line 195:     retryable,\n\n  Line 198:     salvage,\n\n  Line 233: function readNonNegativeEnvNumber(name, fallback) {\n\n  Line 235:   if (raw === undefined || raw === '') return fallback;\n\n  Line 237:   return Number.isFinite(value) && value >= 0 ? value : fallback;\n\n  Line 279:     // Vanished between EEXIST and read — already gone, so retrying openSync wins.\n\n  Line 356:  * remove, then retry). A lock held by a LIVE pid inside the age window keeps the\n\n  Line 357:  * original maxWait/retry-deadline-then-throw behavior.\n\n  Line 370:  * @throws {Error} With code DB_ERROR if the lock remains held after retry.\n\n  Line 375:   const retryIntervalMs = readNonNegativeEnvNumber('DEEP_LOOP_WRITER_LOCK_RETRY_INTERVAL_MS', DEFAULT_WRITER_LOCK_RETRY_INTERVAL_MS);\n\n  Line 396:       // stamp failure fall through to the contention path and retry rather than\n\n  Line 406:         // Release the half-formed lock so a peer (or our own retry) can take it,\n\n  Line 428:         sleepSync(Math.min(retryIntervalMs, remainingMs));\n\n  Line 449:         sleepSync(Math.min(retryIntervalMs, remainingMs));\n\n  Line 458:       // remove it and retry the open. This can itself race a second reclaimer,\n\n  Line 467:           // Another reclaimer may have removed it first; the retry settles it.\n\n  Line 478:       sleepSync(Math.min(retryIntervalMs, remainingMs));\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs:\n  Line 4: // ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n\n  Line 5: // ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n\n  Line 7: // ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n\n  Line 132:     salvage_miss: 0,\n\n  Line 161: function normalizePositiveDuration(value, fallback) {\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"maxRetries|retry|salvage|model|exec