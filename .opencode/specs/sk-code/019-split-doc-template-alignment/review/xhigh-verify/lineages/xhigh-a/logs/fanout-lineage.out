d\",\n111:         \"source\": \"derived\"\n112:       },\n113:       {\n114:         \"name\": \"3. SCOPE\",\n115:         \"kind\": \"heading\",\n116:         \"path\": \"spec.md\",\n117:         \"source\": \"derived\"\n118:       },\n119:       {\n120:         \"name\": \"Implementation Plan\",\n121:         \"kind\": \"proper_noun\",\n122:         \"path\": \"plan.md\",\n123:         \"source\": \"derived\"\n124:       },\n125:       {\n126:         \"name\": \"Technical Context Documentation\",\n127:         \"kind\": \"proper_noun\",\n128:         \"path\": \"plan.md\",\n129:         \"source\": \"derived\"\n130:       },\n131:       {\n132:         \"name\": \"Overview Conform\",\n133:         \"kind\": \"proper_noun\",\n134:         \"path\": \"plan.md\",\n135:         \"source\": \"derived\"\n136:       },\n137:       {\n138:         \"name\": \"Ready Templates\",\n139:         \"kind\": \"proper_noun\",\n140:         \"path\": \"plan.md\",\n141:         \"source\": \"derived\"\n142:       },\n143:       {\n144:         \"name\": \"Pattern Serial\",\n145:         \"kind\": \"proper_noun\",\n146:         \"path\": \"plan.md\",\n147:         \"source\": \"derived\"\n148:       },\n149:       {\n150:         \"name\": \"Task Notation\",\n151:         \"kind\": \"proper_noun\",\n152:         \"path\": \"tasks.md\",\n153:         \"source\": \"derived\"\n154:       },\n155:       {\n156:         \"name\": \"Completion Criteria\",\n157:         \"kind\": \"proper_noun\",\n158:         \"path\": \"tasks.md\",\n159:         \"source\": \"derived\"\n160:       },\n161:       {\n162:         \"name\": \"evidence\",\n163:         \"kind\": \"key_phrase\",\n164:         \"path\": \"tasks.md\",\n165:         \"source\": \"derived\"\n166:       },\n167:       {\n168:         \"name\": \"Phase 1: Setup\",\n169:         \"kind\": \"heading\",\n170:         \"path\": \"tasks.md\",\n171:         \"source\": \"derived\"\n172:       },\n173:       {\n174:         \"name\": \"Phase 2: Implementation\",\n175:         \"kind\": \"heading\",\n176:         \"path\": \"tasks.md\",\n177:         \"source\": \"derived\"\n178:       },\n179:       {\n180:         \"name\": \"Verification Protocol Every\",\n181:         \"kind\": \"proper_noun\",\n182:         \"path\": \"checklist.md\",\n183:         \"source\": \"derived\"\n184:       },\n185:       {\n186:         \"name\": \"Code Quality\",\n187:         \"kind\": \"proper_noun\",\n188:         \"path\": \"checklist.md\",\n189:         \"source\": \"derived\"\n190:       }\n191:     ],\n192:     \"causal_summary\": \"Conform the ~104 hyphenated + ~160 total mechanically-sliced reference/asset .md files under sk-code/{code-opencode,code-webflow,code-quality} to the canonical create-skill asset/reference templates: 5-field frontmatter + 4-part version, snake_case filenames, H1 + intro + `## 1. OVERVIEW` before content, optional RELATED RESOURCES last. Every rename updates all in-hub references. Extends 027's underscore convention to the reference/asset split files 027 did not cover.\",\n193:     \"created_at\": \"2026-07-12T14:23:01.630Z\",\n194:     \"last_save_at\": \"2026-07-13T03:41:44.925Z\",\n195:     \"save_lineage\": \"graph_only\",\n196:     \"last_accessed_at\": null,\n197:     \"source_docs\": [\n198:       \"spec.md\",\n199:       \"plan.md\",\n200:       \"tasks.md\",\n201:       \"checklist.md\",\n202:       \"implementation-summary.md\"\n203:     ],\n204:     \"source_fingerprint\": \"sha256:37fa5677389178745dfdc4ff6de7df3e3be20f133e0ec279871ebd1c7d55d368\",\n205:     \"source_doc_hashes\": {\n206:       \"spec.md\": \"dd345226556a8bb9abc4de80b9d59ae293004196cf024385b72c3070cd39a617\",\n207:       \"plan.md\": \"aad345aa84428ebb8d4bbcbe8b85caeb8719eba60117b6363c998c89036fa947\",\n208:       \"tasks.md\": \"ed18a119344bf9701a36033a2f49bcaf03bbe7b890e3d1d0c9145649c0daeb02\",\n209:       \"checklist.md\": \"63ce2b53de438995644f0211fdeadd119e93fb41d8e3b966e34f2a64871bb5fb\",\n210:   