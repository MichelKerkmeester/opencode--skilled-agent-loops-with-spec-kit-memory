{"type":"tool_use","timestamp":1781763777825,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_NQnpBK0UiBsvdUflIvjXMs7i","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage1 Candidate Gen\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-stage retrieval pipeline architecture\n5: //\n6: // Responsibility: Execute search channels and collect raw candidate results.\n7: // This stage avoids downstream fusion/reranking, but may apply temporal\n8: // Contiguity to raw vector-channel hits before later pipeline stages.\n9: // Results are collected from the appropriate search channel based on search type.\n10: //\n11: // Search channels handled:\n12: //   - multi-concept: Generate per-concept embeddings, run multiConceptSearch\n13: //   - hybrid (deep mode): Query expansion + multi-variant hybrid search + dedup\n14: // hybrid: Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n15: // Suppressed when classifies query as \"simple\" (mutual exclusion)\n16: //   - hybrid: collectRawCandidates → falls back to vector on failure\n17: //   - vector: Direct vectorSearch\n18: //\n19: // Post-channel operations:\n20: //   - Constitutional memory injection (if not already present)\n21: //   - Quality score filtering\n22: //   - Tier and contextType filtering\n23: //\n24: // I/O CONTRACT:\n25: // Input:  Stage1Input { config: PipelineConfig }\n26: // Output: Stage1Output { candidates: PipelineRow[], metadata }\n27: // Key invariants:\n28: //     - candidates contains raw channel scores; vector hits may include an\n29: //       optional temporal-contiguity boost applied before downstream fusion\n30: //     - Constitutional rows are always present when includeConstitutional=true and no tier filter\n31: //     - All rows pass qualityThreshold (if set) and tier/contextType filters\n32: // Side effects:\n33: //     - Generates query embeddings via the embeddings provider (external call)\n34: //     - Reads from the vector index and FTS5 / BM25 index (DB reads only)\n35: //\n36: import type { Stage1Input, Stage1Output, PipelineRow } from './types.js';\n37: import { resolveEffectiveScore } from './types.js';\n38: import * as vectorIndex from '../vector-index.js';\n39: import * as hybridSearch from '../hybrid-search.js';\n40: import { vectorSearchWithContiguity } from '../../cognitive/temporal-contiguity.js';\n41: import { isMultiQueryEnabled, isEmbeddingExpansionEnabled, isMemorySummariesEnabled, isQueryDecompositionEnabled, isGraphConceptRoutingEnabled, isLlmReformulationEnabled, isHyDEEnabled, isQuerySurrogatesEnabled, isTemporalContiguityEnabled, isQueryConceptExpansionEnabled } from '../search-flags.js';\n42: import { expandQuery } from '../query-expander.js';\n43: import { expandQueryWithEmbeddings, isExpansionActive } from '../embedding-expansion.js';\n44: import { querySummaryEmbeddings, checkScaleGate } from '../memory-summaries.js';\n45: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n46: import { requireDb } from '../../../utils/db-helpers.js';\n47: import { filterRowsByScope } from '../../governance/scope-governance.js';\n48: import { withTimeout } from '../../errors/core.js';\n49: import { GRAPH_METADATA_MIGRATED_QUALITY_FLAG } from '../../graph/graph-metadata-schema.js';\n50: import { computeBackfillQualityScore } from '../../validation/save-quality-gate.js';\n51: import {\n52:   isMultiFacet,\n53:   decompose,\n54:   mergeByFacetCoverage as mergeFacetCoveragePools,\n55:   MAX_FACETS,\n56: } from '../query-decomposer.js';\n57: import { routeQueryConcepts, nounPhrases, getConceptExpansionTerms } from '../entity-linker.js';\n58: import { cheapSeedRetrieve, llm, fanout } from '../llm-reformulation.js';\n59: import { runHyDE } from '../hyde.js';\n60: import { matchSurrogates } from '../query-surrogates.js';\n61: import { loadSurrogatesBatch } from '../surrogate-storage.js';\n62: \n63: // Feature catalog: 4-stage pipeline architecture\n64: // Feature catalog: Hybrid search pipeline\n65: \n66: \n67: // -- Constants --\n68: \n69: /** Maximum number of deep-mode query variants to generate (original + expanded). */\n70: const MAX_DEEP_QUERY_VARIANTS = 3;\n71: \n72: /** F1: Deep-mode expansion timeout — fall back to base query if variants take too long. */\n73: const DEEP_EXPANSION_TIMEOUT_MS = 5000;\n74: \n75: /** Minimum cosine similarity for multi-concept search. */\n76: const MULTI_CONCEPT_MIN_SIMILARITY = 0.5;\n77: \n78: /** Number of constitutional results to fetch when none appear in hybrid/vector results. */\n79: const CONSTITUTIONAL_INJECT_LIMIT = 5;\n80: \n81: /** Number of similar memories to mine for embedding-based query expansion terms. */\n82: const DEFAULT_EXPANSION_CANDIDATE_LIMIT = 5;\n83: \n84: /** D2: Timeout for facet decomposition parallel searches (ms). */\n85: const DECOMPOSITION_TIMEOUT_MS = 5000;\n86: const MAX_QUERY_DECOMPOSITION_FACETS = MAX_FACETS;\n87: \n88: // -- Helper Functions --\n89: \n90: /**\n91:  * Filter results by a minimum quality score threshold.\n92:  *\n93:  * - If no threshold is provided or it is not a finite number, all results pass.\n94:  * - Threshold is clamped to [0, 1].\n95:  * - Rows with a missing or non-finite `quality_score` are treated as 0.\n96:  *\n97:  * @param results - Candidate rows to filter.\n98:  * @param threshold - Minimum quality score in [0, 1] (inclusive).\n99:  * @returns Filtered array; original array returned unchanged when no threshold applies.\n100:  */\n101: function filterByMinQualityScore(\n102:   results: PipelineRow[],\n103:   threshold?: number\n104: ): PipelineRow[] {\n105:   if (typeof threshold !== 'number' || !Number.isFinite(threshold)) {\n106:     return results;\n107:   }\n108: \n109:   const clampedThreshold = Math.max(0, Math.min(1, threshold));\n110: \n111:   return results.filter((row) => {\n112:     const rawScore = row.quality_score as number | undefined;\n113:     const score =\n114:       typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n115:     return score >= clampedThreshold;\n116:   });\n117: }\n118: \n119: function backfillMissingQualityScores(results: PipelineRow[]): PipelineRow[] {\n120:   return results.map((row) => {\n121:     if (row.quality_score !== 0 && row.quality_score != null) {\n122:       return row;\n123:     }\n124: \n125:     return {\n126:       ...row,\n127:       quality_score: computeBackfillQualityScore(row),\n128:     };\n129:   });\n130: }\n131: \n132: function applyArchiveFilter(\n133:   results: PipelineRow[],\n134:   _includeArchived: boolean\n135: ): PipelineRow[] {\n136:   return results;\n137: }\n138: \n139: function applyFolderFilter(\n140:   results: PipelineRow[],\n141:   specFolder?: string\n142: ): PipelineRow[] {\n143:   if (!specFolder) return results;\n144:   return results.filter((row) => {\n145:     const rowSpecFolder = row.spec_folder ?? row.specFolder;\n146:     return rowSpecFolder === specFolder;\n147:   });\n148: }\n149: \n150: function applyTierFilter(\n151:   results: PipelineRow[],\n152:   tier?: string\n153: ): PipelineRow[] {\n154:   if (!tier) return results;\n155:   return results.filter((row) => row.importance_tier === tier);\n156: }\n157: \n158: /**\n159:  * Resolve the effective context type from a pipeline row.\n160:  *\n161:  * Rows may carry context type under either `contextType` (camelCase) or\n162:  * `context_type` (snake_case). This function normalises the lookup.\n163:  *\n164:  * @param row - The pipeline row to inspect.\n165:  * @returns The context type string, or `undefined` if absent.\n166:  */\n167: function resolveRowContextType(row: PipelineRow): string | undefined {\n168:   if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n169:     return row.contextType;\n170:   }\n171:   if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n172:     return row.context_type;\n173:   }\n174:   return undefined;\n175: }\n176: \n177: function mergeStringLists(...values: unknown[]): string[] {\n178:   const merged = new Set<string>();\n179:   for (const value of values) {\n180:     if (!Array.isArray(value)) {\n181:       continue;\n182:     }\n183:     for (const entry of value) {\n184:       if (typeof entry === 'string' && entry.length > 0) {\n185:         merged.add(entry);\n186:       }\n187:     }\n188:   }\n189:   return Array.from(merged);\n190: }\n191: \n192: function readFiniteScoreMap(value: unknown): Record<string, number> {\n193:   if (!value || typeof value !== 'object' || Array.isArray(value)) {\n194:     return {};\n195:   }\n196: \n197:   const normalized: Record<string, number> = {};\n198:   for (const [key, score] of Object.entries(value as Record<string, unknown>)) {\n199:     if (typeof score === 'number' && Number.isFinite(score)) {\n200:       normalized[key] = score;\n201:     }\n202:   }\n203:   return normalized;\n204: }\n205: \n206: function readQualityFlags(value: unknown): string[] {\n207:   if (Array.isArray(value)) {\n208:     return value.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n209:   }\n210:   if (typeof value !== 'string' || value.trim().length === 0) {\n211:     return [];\n212:   }\n213:   try {\n214:     const parsed = JSON.parse(value) as unknown;\n215:     if (Array.isArray(parsed)) {\n216:       return parsed.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n217:     }\n218:   } catch {\n219:     // Fall back to comma-delimited parsing for legacy callers/tests.\n220:   }\n221:   return value\n222:     .split(',')\n223:     .map((entry) => entry.trim())\n224:     .filter((entry) => entry.length > 0);\n225: }\n226: \n227: function isMigratedGraphMetadataCandidate(row: PipelineRow): boolean {\n228:   const migratedValue = row.migrated ?? row.is_migrated ?? row.metadata_migrated;\n229:   if (migratedValue === true || migratedValue === 1 || migratedValue === '1' || migratedValue === 'true') {\n230:     return true;\n231:   }\n232:   const qualityFlags = readQualityFlags(row.quality_flags ?? row.qualityFlags);\n233:   return qualityFlags.includes(GRAPH_METADATA_MIGRATED_QUALITY_FLAG);\n234: }\n235: \n236: function mergeScoreMaps(...maps: Array<Record<string, number>>): Record<string, number> {\n237:   const merged: Record<string, number> = {};\n238:   for (const map of maps) {\n239:     for (const [key, score] of Object.entries(map)) {\n240:       if (!(key in merged) || score > merged[key]!) {\n241:         merged[key] = score;\n242:       }\n243:     }\n244:   }\n245:   return merged;\n246: }\n247: \n248: function getCandidateSources(row: PipelineRow): string[] {\n249:   const explicitSources = mergeStringLists(row.sources);\n250:   if (explicitSources.length > 0) {\n251:     return explicitSources;\n252:   }\n253:   return typeof row.source === 'string' && row.source.length > 0 ? [row.source] : [];\n254: }\n255: \n256: function getCandidateSourceScores(row: PipelineRow): Record<string, number> {\n257:   const sourceScores = readFiniteScoreMap(row.sourceScores);\n258:   if (Object.keys(sourceScores).length > 0) {\n259:     return sourceScores;\n260:   }\n261: \n262:   const resolvedScore = resolveEffectiveScore(row);\n263:   if (resolvedScore <= 0) {\n264:     return {};\n265:   }\n266: \n267:   const fallbackScores: Record<string, number> = {};\n268:   for (const source of getCandidateSources(row)) {\n269:     fallbackScores[source] = resolvedScore;\n270:   }\n271:   return fallbackScores;\n272: }\n273: \n274: function isPacketOrientedQuery(query: string): boolean {\n275:   const normalized = query.toLowerCase();\n276:   return [\n277:     'packet',\n278:     'spec folder',\n279:     'graph metadata',\n280:     'dependency',\n281:     'depends on',\n282:     'related to',\n283:     'supersedes',\n284:     'resume',\n285:     'key files',\n286:     'parent',\n287:     'children',\n288:   ].some((term) => normalized.includes(term));\n289: }\n290: \n291: function boostGraphMetadataCandidates(\n292:   results: PipelineRow[],\n293:   query: string,\n294: ): PipelineRow[] {\n295:   if (!isPacketOrientedQuery(query)) {\n296:     return results;\n297:   }\n298: \n299:   return results.map((row) => {\n300:     if (row.document_type !== 'graph_metadata' && row.documentType !== 'graph_metadata') {\n301:       return row;\n302:     }\n303: \n304:     const currentScore = resolveEffectiveScore(row);\n305:     const adjustedScore = isMigratedGraphMetadataCandidate(row)\n306:       ? Math.max(0, currentScore - 0.12)\n307:       : Math.min(1, currentScore + 0.12);\n308:     const sourceScores = getCandidateSourceScores(row);\n309:     return {\n310:       ...row,\n311:       score: adjustedScore,\n312:       rrfScore: adjustedScore,\n313:       sourceScores: {\n314:         ...sourceScores,\n315:         graph_metadata: adjustedScore,\n316:       },\n317:     };\n318:   });\n319: }\n320: \n321: function annotateBranchScore(row: PipelineRow, branchLabel: string): Record<string, number> {\n322:   const existingBranchScores = readFiniteScoreMap(row.stage1BranchScores);\n323:   const effectiveScore = resolveEffectiveScore(row);\n324:   if (branchLabel.length === 0 || !Number.isFinite(effectiveScore)) {\n325:     return existingBranchScores;\n326:   }\n327:   return mergeScoreMaps(existingBranchScores, { [branchLabel]: effectiveScore });\n328: }\n329: \n330: function mergeCandidateRows(\n331:   existing: PipelineRow | undefined,\n332:   incoming: PipelineRow,\n333:   branchLabel: string,\n334: ): PipelineRow {\n335:   const incomingBranchScores = annotateBranchScore(incoming, branchLabel);\n336:   if (!existing) {\n337:     const sources = getCandidateSources(incoming);\n338:     const channelAttribution = mergeStringLists(incoming.channelAttribution, sources);\n339:     return {\n340:       ...incoming,\n341:       sources: sources.length > 0 ? sources : incoming.sources,\n342:       channelAttribution: channelAttribution.length > 0 ? channelAttribution : incoming.channelAttribution,\n343:       sourceScores: Object.keys(getCandidateSourceScores(incoming)).length > 0\n344:         ? getCandidateSourceScores(incoming)\n345:         : incoming.sourceScores,\n346:       stage1BranchScores: Object.keys(incomingBranchScores).length > 0 ? incomingBranchScores : undefined,\n347:       stage1BranchCount: Object.keys(incomingBranchScores).length || incoming.stage1BranchCount,\n348:       channelCount: sources.length > 0 ? sources.length : incoming.channelCount,\n349:     };\n350:   }\n351: \n352:   const existingScore = resolveEffectiveScore(existing);\n353:   const incomingScore = resolveEffectiveScore(incoming);\n354:   const primary = incomingScore > existingScore ? incoming : existing;\n355:   const secondary = primary === incoming ? existing : incoming;\n356: \n357:   const mergedSources = mergeStringLists(getCandidateSources(existing), getCandidateSources(incoming));\n358:   const mergedChannelAttribution = mergeStringLists(\n359:     existing.channelAttribution,\n360:     incoming.channelAttribution,\n361:     mergedSources,\n362:   );\n363:   const mergedSourceScores = mergeScoreMaps(\n364:     getCandidateSourceScores(existing),\n365:     getCandidateSourceScores(incoming),\n366:   );\n367:   const mergedBranchScores = mergeScoreMaps(\n368:     readFiniteScoreMap(existing.stage1BranchScores),\n369:     incomingBranchScores,\n370:   );\n371: \n372:   return {\n373:     ...secondary,\n374:     ...primary,\n375:     sources: mergedSources.length > 0 ? mergedSources : primary.sources,\n376:     source: typeof primary.source === 'string' && primary.source.length > 0\n377:       ? primary.source\n378:       : (mergedSources[0] ?? primary.source),\n379:     channelAttribution: mergedChannelAttribution.length > 0\n380:       ? mergedChannelAttribution\n381:       : primary.channelAttribution,\n382:     sourceScores: Object.keys(mergedSourceScores).length > 0\n383:       ? mergedSourceScores\n384:       : primary.sourceScores,\n385:     stage1BranchScores: Object.keys(mergedBranchScores).length > 0\n386:       ? mergedBranchScores\n387:       : primary.stage1BranchScores,\n388:     stage1BranchCount: Object.keys(mergedBranchScores).length || primary.stage1BranchCount,\n389:     channelCount: mergedSources.length > 0 ? mergedSources.length : primary.channelCount,\n390:   };\n391: }\n392: \n393: function mergeCandidateBatches(\n394:   batches: Array<{ label: string; rows: PipelineRow[] }>,\n395:   options: { seedCandidates?: PipelineRow[]; seedLabel?: string } = {},\n396: ): PipelineRow[] {\n397:   const merged = new Map<string, PipelineRow>();\n398:   const seedLabel = options.seedLabel ?? '';\n399: \n400:   for (const row of options.seedCandidates ?? []) {\n401:     const key = String(row.id);\n402:     merged.set(key, mergeCandidateRows(merged.get(key), row, seedLabel));\n403:   }\n404: \n405:   for (const batch of batches) {\n406:     for (const row of batch.rows) {\n407:       const key = String(row.id);\n408:       merged.set(key, mergeCandidateRows(merged.get(key), row, batch.label));\n409:     }\n410:   }\n411: \n412:   return Array.from(merged.values());\n413: }\n414: \n415: /**\n416:  * Build deep-mode query variants using rule-based synonym expansion.\n417:  *\n418:  * The original query is always the first variant. Up to `MAX_DEEP_QUERY_VARIANTS - 1`\n419:  * additional variants are produced by `expandQuery`. If expansion fails or produces\n420:  * no new terms, the array contains only the original query.\n421:  *\n422:  * Simple-query bypass (038): When classifies the query as \"simple\",\n423:  * rule-based expansion is skipped — consistent with the embedding-expansion\n424:  * path's `isExpansionActive()` gate. Simple queries do not benefit from synonym\n425:  * expansion and the additional search channels add latency without recall gain.\n426:  *\n427:  * Duplicates are eliminated via `Set` deduplication before slicing.\n428:  *\n429:  * @param query - The original search query string.\n430:  * @returns Array of distinct query variants, original first, capped at MAX_DEEP_QUERY_VARIANTS.\n431:  */\n432: async function buildDeepQueryVariants(query: string): Promise<string[]> {\n433:   try {\n434:     const expanded = expandQuery(query);\n435:     const variants = new Set<string>(expanded);\n436:     // ExpandQuery already includes the original as the first entry,\n437:     // But be explicit in case the implementation changes.\n438:     variants.add(query);\n439: \n440:     // Deep mode: ensure at least 2 variants so the multi-search branch fires.\n441:     // When synonym expansion produces no new variants (simple/domain-specific queries),\n442:     // generate a basic reformulation to trigger the parallel search path.\n443:     if (variants.size < 2) {\n444:       const words = query.trim().split(/\\s+/);\n445:       if (words.length >= 2) {\n446:         variants.add(words.slice().reverse().join(' '));\n447:       } else {\n448:         variants.add(`what is ${query}`);\n449:       }\n450:     }\n451: \n452:     return Array.from(variants).slice(0, MAX_DEEP_QUERY_VARIANTS);\n453:   } catch (err: unknown) {\n454:     const msg = err instanceof Error ? err.message : String(err);\n455:     console.warn(\n456:       `[stage1-candidate-gen] buildDeepQueryVariants failed, using original query: ${msg}`\n457:     );\n458:     return [query];\n459:   }\n460: }\n461: \n462: function normalizeFacetText(fragment: string): string {\n463:   return fragment\n464:     .replace(/^[\\s,:;]+|[\\s,.:;?!]+$/g, '')\n465:     .replace(/\\s+/g, ' ')\n466:     .trim();\n467: }\n468: \n469: function decomposeQueryFacets(query: string): string[] {\n470:   const trimmed = normalizeFacetText(query);\n471:   if (trimmed.length === 0) return [];\n472: \n473:   const focusMatch = trimmed.match(/\\babout\\s+(.+?)[?.!]*$/i);\n474:   const focusSegment = focusMatch?.[1]?.trim() ?? trimmed;\n475: \n476:   const listLikeFacets = focusSegment\n477:     .split(/\\s*(?:,|\\band\\b|\\bor\\b|\\balso\\b|\\bplus\\b|\\bas well as\\b|\\balong with\\b)\\s*/i)\n478:     .map(normalizeFacetText)\n479:     .filter((facet) => facet.length > 0);\n480: \n481:   if (listLikeFacets.length >= 2) {\n482:     return [...new Set(listLikeFacets)].slice(0, MAX_QUERY_DECOMPOSITION_FACETS);\n483:   }\n484: \n485:   if (!isMultiFacet(trimmed)) {\n486:     return [trimmed];\n487:   }\n488: \n489:   const decomposedFacets = decompose(trimmed)\n490:     .map(normalizeFacetText)\n491:     .filter((facet) => facet.length > 0);\n492: \n493:   if (decomposedFacets.length === 0) {\n494:     return [trimmed];\n495:   }\n496: \n497:   return [...new Set(decomposedFacets)].slice(0, MAX_QUERY_DECOMPOSITION_FACETS);\n498: }\n499: \n500: function buildQueryDecompositionPool(query: string, mode?: string | null): string[] {\n501:   const normalizedQuery = normalizeFacetText(query);\n502:   if (mode !== 'deep' || !isQueryDecompositionEnabled()) {\n503:     return [normalizedQuery];\n504:   }\n505: \n506:   const facets = decomposeQueryFacets(query).filter((facet) => facet !== normalizedQuery);\n507:   return [normalizedQuery, ...facets];\n508: }\n509: \n510: function mergeQueryFacetCoverage(resultSets: PipelineRow[][]): PipelineRow[] {\n511:   const firstSeenById = new Map<number, PipelineRow>();\n512:   for (const resultSet of resultSets) {\n513:     for (const row of resultSet) {\n514:       if (!firstSeenById.has(row.id)) {\n515:         firstSeenById.set(row.id, row);\n516:       }\n517:     }\n518:   }\n519:   return Array.from(firstSeenById.values());\n520: }\n521: \n522: // -- Stage 1 --\n523: \n524: /**\n525:  * Execute Stage 1: Candidate Generation.\n526:  *\n527:  * Selects and runs the appropriate search channel(s) based on `config.searchType`\n528:  * and `config.mode`, then applies vector-channel temporal contiguity when\n529:  * enabled, followed by constitutional injection, quality filtering, and\n530:  * tier/contextType filtering.\n531:  *\n532:  * This stage does not apply Stage 2 fusion/reranking signals. Vector-channel\n533:  * results may receive a temporal proximity boost before moving downstream.\n534:  *\n535:  * @param input - Stage 1 input containing the resolved pipeline configuration.\n536:  * @returns Stage 1 output with raw candidate rows and channel metadata.\n537:  */\n538: export async function executeStage1(input: Stage1Input): Promise<Stage1Output> {\n539:   const startTime = Date.now();\n540:   try {\n541:     return await executeStage1Core(input, startTime);\n542:   } catch (error: unknown) {\n543:     const message = error instanceof Error ? error.message : String(error);\n544:     console.warn(`[stage1-candidate-gen] Stage 1 failed, returning empty candidates: ${message}`);\n545:     return {\n546:       candidates: [],\n547:       metadata: {\n548:         searchType: input.config.searchType,\n549:         channelCount: 0,\n550:         activeChannels: 0,\n551:         candidateCount: 0,\n552:         constitutionalInjected: 0,\n553:         durationMs: Date.now() - startTime,\n554:       },\n555:     };\n556:   }\n557: }\n558: \n559: async function executeStage1Core(input: Stage1Input, startTime: number): Promise<Stage1Output> {\n560:   const { config } = input;\n561:   // Cache embedding at function scope for reuse in constitutional injection\n562:   let cachedEmbedding: Float32Array | number[] | null = null;\n563:   let constitutionalInjectedCount = 0;\n564: \n565:   const {\n566:     query,\n567:     queryEmbedding,\n568:     concepts,\n569:     searchType,\n570:     mode,\n571:     limit,\n572:     specFolder,\n573:     tenantId,\n574:     userId,\n575:     agentId,\n576:     tier,\n577:     contextType,\n578:     includeArchived,\n579:     includeConstitutional,\n580:     qualityThreshold,\n581:     trace,\n582:   } = config;\n583: \n584:   let candidates: PipelineRow[] = [];\n585:   let channelCount = 0;\n586:   const hybridSearchOptions = {\n587:     limit,\n588:     specFolder,\n589:     includeArchived,\n590:     intent: config.adaptiveFusionIntent ?? undefined,\n591:   };\n592: \n593:   // -- Graph Concept Routing -----------------------------------\n594:   //\n595:   // When SPECKIT_GRAPH_CONCEPT_ROUTING is enabled, extract noun phrases from\n596:   // the query and match them against the concept alias table. If concepts are\n597:   // matched, log them to the trace for downstream use (graph channel activation\n598:   // is surfaced via trace metadata; actual graph channel is handled in Stage 2).\n599:   //\n600:   // When SPECKIT_QUERY_CONCEPT_EXPANSION is also enabled,\n601:   // matched concepts are reverse-mapped to their alias terms and appended to\n602:   // the query for the hybrid search channel, improving recall for alias-rich\n603:   // queries (e.g. \"semantic search\" → also searches \"retrieval\", \"query\", etc.).\n604:   //\n605:   // Fail-open: any error leaves candidates unchanged.\n606: \n607:   /** Effective query for hybrid search — may be expanded by concept routing. */\n608:   let effectiveQuery = query;\n609: \n610:   if (isGraphConceptRoutingEnabled() && searchType === 'hybrid') {\n611:     try {\n612:       let routingDb: Parameters<typeof routeQueryConcepts>[1];\n613:       try {\n614:         routingDb = requireDb();\n615:       } catch (_dbErr: unknown) {\n616:         routingDb = undefined;\n617:       }\n618:       const routing = routeQueryConcepts(query, routingDb);\n619:       if (routing.graphActivated && routing.concepts.length > 0) {\n620:         // Expand query with concept alias terms\n621:         if (isQueryConceptExpansionEnabled()) {\n622:           try {\n623:             const originalTokens = nounPhrases(query);\n624:             const expansionTerms = getConceptExpansionTerms(\n625:               routing.concepts,\n626:               originalTokens,\n627:               5,\n628:             );\n629:             if (expansionTerms.length > 0) {\n630:               effectiveQuery = `${query} ${expansionTerms.join(' ')}`;\n631:               if (trace) {\n632:                 addTraceEntry(trace, 'candidate', 0, 0, 0, {\n633:                   channel: 'd2-concept-expansion',\n634:                   originalQuery: query,\n635:                   expandedQuery: effectiveQuery,\n636:                   expansionTerms,\n637:                   matchedConcepts: routing.concepts,\n638:                 });\n639:               }\n640:             }\n641:           } catch (expansionErr: unknown) {\n642:             const expansionMsg = expansionErr instanceof Error ? expansionErr.message : String(expansionErr);\n643:             console.warn(`[stage1-candidate-gen] D2 concept expansion failed (fail-open): ${expansionMsg}`);\n644:           }\n645:         }\n646: \n647:         if (trace) {\n648:           addTraceEntry(trace, 'candidate', 0, 0, 0, {\n649:             channel: 'd2-concept-routing',\n650:             matchedConcepts: routing.concepts,\n651:             graphActivated: true,\n652:           });\n653:         }\n654:       }\n655:     } catch (routingErr: unknown) {\n656:       const routingMsg = routingErr instanceof Error ? routingErr.message : String(routingErr);\n657:       console.warn(`[stage1-candidate-gen] D2 concept routing failed: ${routingMsg}`);\n658:     }\n659:   }\n660: \n661:   // -- Channel: Multi-Concept --------------------------------------------------\n662: \n663:   if (searchType === 'multi-concept' && Array.isArray(concepts) && concepts.length >= 2) {\n664:     // Validate concept list: 2-5 non-empty strings\n665:     if (concepts.length > 5) {\n666:       throw new Error('[stage1-candidate-gen] Maximum 5 concepts allowed for multi-concept search');\n667:     }\n668: \n669:     for (const concept of concepts) {\n670:       if (typeof concept !== 'string' || concept.trim().length === 0) {\n671:         throw new Error('[stage1-candidate-gen] Each concept must be a non-empty string');\n672:       }\n673:     }\n674: \n675:     // Generate one embedding per concept\n676:     const conceptEmbeddings: Float32Array[] = [];\n677:     for (const concept of concepts) {\n678:       const emb = await vectorIndex.generateQueryEmbedding(concept);\n679:       if (!emb) {\n680:         throw new Error(\n681:           `[stage1-candidate-gen] Failed to generate embedding for concept: \"${concept}\"`\n682:         );\n683:       }\n684:       conceptEmbeddings.push(emb);\n685:     }\n686: \n687:     channelCount = 1;\n688:     candidates = vectorIndex.multiConceptSearch(conceptEmbeddings, {\n689:       minSimilarity: MULTI_CONCEPT_MIN_SIMILARITY,\n690:       limit,\n691:       specFolder,\n692:     }) as PipelineRow[];\n693:   }\n694: \n695:   // -- Channel: Hybrid (with optional deep-mode query expansion) ---------------\n696:   //\n697:   else if (searchType === 'hybrid') {\n698:     // Resolve the query embedding — either pre-computed in config or generate now\n699:     // Cache this embedding for reuse in constitutional injection path\n700:     // To avoid a duplicate generateQueryEmbedding() call.\n701:     const effectiveEmbedding: Float32Array | number[] | null =\n702:       queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n703:     cachedEmbedding = effectiveEmbedding;\n704: \n705:     if (!effectiveEmbedding) {\n706:       throw new Error('[stage1-candidate-gen] Failed to generate embedding for hybrid search query');\n707:     }\n708: \n709:     // Deep mode: expand query into variants and run hybrid for each, then dedup\n710:     if (mode === 'deep' && isMultiQueryEnabled()) {\n711:       // -- Query Decomposition (SPECKIT_QUERY_DECOMPOSITION) ---\n712:       //\n713:       // When enabled and the query is multi-faceted, decompose into up to 3\n714:       // sub-query facets and run hybrid search per facet. Results are merged\n715:       // by facet coverage (items appearing in multiple facets rank higher).\n716:       //\n717:       // This block takes the place of the synonym-expansion path below when\n718:       // decomposition fires. If decomposition is disabled, not applicable, or\n719:       // fails, execution falls through to the existing expansion logic.\n720: \n721:       if (isQueryDecompositionEnabled() && isMultiFacet(query)) {\n722:         try {\n723:           const normalizedQuery = normalizeFacetText(query);\n724:           let facets: string[] = [];\n725: \n726:           try {\n727:             facets = buildQueryDecompositionPool(query, mode)\n728:               .filter((facet) => facet !== normalizedQuery)\n729:               .map(normalizeFacetText)\n730:               .filter((facet) => facet.length > 0);\n731:           } catch (facetErr: unknown) {\n732:             const facetMsg = facetErr instanceof Error ? facetErr.message : String(facetErr);\n733:             console.warn(\n734:               `[stage1-candidate-gen] D2 faceted query decomposition failed, falling back to basic decomposition: ${facetMsg}`\n735:             );\n736:           }\n737: \n738:           if (facets.length === 0) {\n739:             facets = decompose(query)\n740:               .map(normalizeFacetText)\n741:               .filter((facet) => facet.length > 0 && facet !== normalizedQuery);\n742:           }\n743: \n744:           facets = [...new Set(facets)].slice(0, MAX_QUERY_DECOMPOSITION_FACETS);\n745: \n746:           if (facets.length > 0) {\n747:             // Run hybrid for the original query plus each facet, in parallel\n748:             const allQueries = [query, ...facets];\n749:             // FIX #7: Use Promise.allSettled so one failing facet branch\n750:             // does not discard results from all other branches.\n751:             const facetSettledResults = await withTimeout(\n752:               Promise.allSettled(\n753:                 allQueries.map(async (q): Promise<PipelineRow[]> => {\n754:                   const facetEmbedding = await vectorIndex.generateQueryEmbedding(q);\n755:                   if (!facetEmbedding) {\n756:                     console.warn('[stage1-candidate-gen] D2 facet embedding generation returned null');\n757:                     return [];\n758:                   }\n759:                   return hybridSearch.collectRawCandidates(\n760:                     q,\n761:                     facetEmbedding,\n762:                     hybridSearchOptions\n763:                   ) as Promise<PipelineRow[]>;\n764:                 })\n765:               ),\n766:               DECOMPOSITION_TIMEOUT_MS,\n767:               'D2 facet decomposition',\n768:             );\n769:             const facetResultSets = facetSettledResults.map((result, idx) => {\n770:               if (result.status === 'fulfilled') return result.value;\n771:               console.warn(`[stage1-candidate-gen] D2 facet branch ${idx} rejected: ${result.reason}`);\n772:               return [] as PipelineRow[];\n773:             });\n774: \n775:             channelCount = allQueries.length;\n776:             const pools = allQueries.map((q, i) => ({\n777:               query: q,\n778:               results: facetResultSets[i] ?? [],\n779:             }));\n780:             candidates = mergeFacetCoveragePools(pools);\n781: \n782:             if (trace) {\n783:               addTraceEntry(trace, 'candidate', channelCount, candidates.length, 0, {\n784:                 channel: 'd2-query-decomposition',\n785:                 originalQuery: query,\n786:                 facets,\n787:                 facetCount: facets.length,\n788:               });\n789:             }\n790: \n791:             // Skip the standard deep-mode expansion path below\n792:             // (jump to post-channel processing via the else-if chain)\n793:           }\n794:         } catch (decompErr: unknown) {\n795:           const decompMsg = decompErr instanceof Error ? decompErr.message : String(decompErr);\n796:           console.warn(\n797:             `[stage1-candidate-gen] D2 query decomposition failed, falling through to expansion: ${decompMsg}`\n798:           );\n799:           // Fall through to standard deep expansion path below (candidates is empty)\n800:         }\n801:       }\n802: \n803:       // Only run existing expansion logic when decomposition did not produce results\n804:       if (candidates.length === 0) {\n805: \n806:       const queryVariants = await buildDeepQueryVariants(query);\n807: \n808:       if (queryVariants.length > 1) {\n809:         try {\n810:           // F1: Wrap parallel variant searches with latency budget.\n811:           // If variants exceed DEEP_EXPANSION_TIMEOUT_MS, fall back to base query.\n812:           // FIX #7: Use Promise.allSettled so one failing variant does not\n813:           // discard results from all other variant branches.\n814:           const variantSettledResults = await withTimeout(\n815:             Promise.allSettled(\n816:               queryVariants.map(async (variant): Promise<PipelineRow[]> => {\n817:                 const variantEmbedding = await vectorIndex.generateQueryEmbedding(variant);\n818:                 if (!variantEmbedding) {\n819:                   console.warn('[stage1-candidate-gen] Deep variant embedding generation returned null');\n820:                   return [];\n821:                 }\n822:                 const variantResults = await hybridSearch.collectRawCandidates(\n823:                   variant,\n824:                   variantEmbedding,\n825:                   hybridSearchOptions\n826:                 );\n827:                 return variantResults as PipelineRow[];\n828:               })\n829:             ),\n830:             DEEP_EXPANSION_TIMEOUT_MS,\n831:             'Deep-mode query expansion',\n832:           );\n833:           const variantResultSets: PipelineRow[][] = variantSettledResults.map((result, idx) => {\n834:             if (result.status === 'fulfilled') return result.value;\n835:             console.warn(`[stage1-candidate-gen] Deep variant branch ${idx} rejected: ${result.reason}`);\n836:             return [] as PipelineRow[];\n837:           });\n838: \n839:           channelCount = queryVariants.length;\n840: \n841:           // Merge variant results, deduplicate by id, preserve first-occurrence order\n842:           candidates = mergeCandidateBatches(\n843:             variantResultSets.map((rows, index) => ({\n844:               label: queryVariants[index] ?? `deep-variant-${index}`,\n845:               rows,\n846:             })),\n847:           );\n848:         } catch (expandErr: unknown) {\n849:           const expandMsg =\n850:             expandErr instanceof Error ? expandErr.message : String(expandErr);\n851:           console.warn(\n852:             `[stage1-candidate-gen] Deep query expansion failed, falling back to single hybrid: ${expandMsg}`\n853:           );\n854:           // Fall through to single hybrid search below\n855:           channelCount = 1;\n856:           candidates = (await hybridSearch.collectRawCandidates(\n857:             query,\n858:             effectiveEmbedding,\n859:             hybridSearchOptions\n860:           )) as PipelineRow[];\n861:         }\n862:       } else {\n863:         // ExpandQuery returned only the original; treat as standard hybrid\n864:         channelCount = 1;\n865:         candidates = (await hybridSearch.collectRawCandidates(\n866:           query,\n867:           effectiveEmbedding,\n868:           hybridSearchOptions\n869:         )) as PipelineRow[];\n870:       }\n871: \n872:       } // end: if (candidates.length === 0)\n873:     } else {\n874:       // Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n875:       //\n876:       // When is enabled and does not classify the query as \"simple\",\n877:       // We expand the query using embedding similarity to find related terms\n878:       // From the memory index. The expanded query is used as an additional\n879:       // Hybrid search channel whose results are merged with the baseline.\n880:       //\n881:       // Mutual exclusion: isExpansionActive returns false when classifies\n882:       // The query as \"simple\", suppressing expansion with zero added latency.\n883: \n884:       let r12ExpansionApplied = false;\n885: \n886:       if (isEmbeddingExpansionEnabled() && isExpansionActive(query)) {\n887:         try {\n888:           // ExpandQueryWithEmbeddings requires a Float32Array; the effective\n889:           // Embedding may be a number[] when generated by some providers, so\n890:           // Convert if necessary before passing it in.\n891:           const expansionEmbedding: Float32Array =\n892:             effectiveEmbedding instanceof Float32Array\n893:               ? effectiveEmbedding\n894:               : Float32Array.from(effectiveEmbedding as number[]);\n895: \n896:           const expanded = await expandQueryWithEmbeddings(query, expansionEmbedding, {\n897:             limit: DEFAULT_EXPANSION_CANDIDATE_LIMIT,\n898:           });\n899: \n900:           // Only run an extra channel if the expansion actually produced new terms\n901:           if (expanded.expanded.length > 0 && expanded.combinedQuery !== query) {\n902:             // Run the baseline and the expanded query in parallel\n903:             const [baselineResults, expansionResults] = await Promise.all([\n904:               hybridSearch.collectRawCandidates(\n905:                 query,\n906:                 effectiveEmbedding,\n907:                 hybridSearchOptions\n908:               ).catch((err: unknown): PipelineRow[] => {\n909:                 console.warn(\n910:                   '[stage1-candidate-gen] Baseline candidate collection failed:',\n911:                   err instanceof Error ? err.message : String(err)\n912:                 );\n913:                 return [];\n914:               }),\n915:               vectorIndex.generateQueryEmbedding(expanded.combinedQuery).then(\n916:                 async (expandedEmb): Promise<PipelineRow[]> => {\n917:                   if (!expandedEmb) {\n918:                     console.warn('[stage1-candidate-gen] Expanded query embedding generation returned null');\n919:                     return [];\n920:                   }\n921:                   return hybridSearch.collectRawCandidates(\n922:                     expanded.combinedQuery,\n923:                     expandedEmb,\n924:                     hybridSearchOptions\n925:                   ) as Promise<PipelineRow[]>;\n926:                 }\n927:               ).catch((err: unknown): PipelineRow[] => {\n928:                 console.warn(\n929:                   '[stage1-candidate-gen] Expansion candidate collection failed:',\n930:                   err instanceof Error ? err.message : String(err)\n931:                 );\n932:                 return [];\n933:               }),\n934:             ]);\n935: \n936:             channelCount = 2;\n937:             r12ExpansionApplied = true;\n938: \n939:             // Merge both result sets, deduplicate by id, baseline-first ordering\n940:             // So baseline scores dominate when the same memory appears in both.\n941:             candidates = mergeCandidateBatches([\n942:               { label: query, rows: baselineResults as PipelineRow[] },\n943:               { label: expanded.combinedQuery, rows: expansionResults as PipelineRow[] },\n944:             ]);\n945: \n946:             if (trace) {\n947:               addTraceEntry(trace, 'candidate', channelCount, candidates.length, 0, {\n948:                 channel: 'r12-embedding-expansion',\n949:                 expandedTerms: expanded.expanded,\n950:                 combinedQuery: expanded.combinedQuery,\n951:               });\n952:             }\n953:           }\n954:         } catch (r12Err: unknown) {\n955:           const r12Msg = r12Err instanceof Error ? r12Err.message : String(r12Err);\n956:           console.warn(\n957:             `[stage1-candidate-gen] R12 embedding expansion failed, using standard hybrid: ${r12Msg}`\n958:           );\n959:         }\n960:       }\n961: \n962:       // Standard hybrid search — runs when is off, suppressed by,\n963:       // Or produced no results (candidates still empty from the try block above).\n964:       // Uses effectiveQuery (concept-expanded) for BM25 recall.\n965:       if (!r12ExpansionApplied) {\n966:         try {\n967:           channelCount = 1;\n968:           const hybridResults = (await hybridSearch.collectRawCandidates(\n969:             effectiveQuery,\n970:             effectiveEmbedding,\n971:             hybridSearchOptions\n972:           )) as PipelineRow[];\n973:           candidates = hybridResults;\n974:         } catch (hybridErr: unknown) {\n975:           const hybridMsg =\n976:             hybridErr instanceof Error ? hybridErr.message : String(hybridErr);\n977:           console.warn(\n978:             `[stage1-candidate-gen] Hybrid search failed, falling back to vector: ${hybridMsg}`\n979:           );\n980: \n981:           // Fallback: pure vector search\n982:           channelCount = 1;\n983:           let vectorResults = vectorIndex.vectorSearch(effectiveEmbedding, {\n984:             limit,\n985:             specFolder,\n986:             tier,\n987:             contextType,\n988:             includeConstitutional: false, // Constitutional managed separately below\n989:             includeArchived,\n990:           }) as PipelineRow[];\n991:           if (isTemporalContiguityEnabled()) {\n992:             vectorResults = (\n993:               vectorSearchWithContiguity(\n994:                 vectorResults as Array<PipelineRow & { similarity: number; created_at: string }>,\n995:                 3600,\n996:               ) as PipelineRow[] | null\n997:             ) ?? vectorResults;\n998:           }\n999:           candidates = vectorResults;\n1000: \n1001:           if (trace) {\n1002:             addTraceEntry(trace, 'fallback', 0, candidates.length, 0, {\n1003:               reason: hybridMsg,\n1004:               channel: 'vector',\n1005:             });\n1006:           }\n1007:         }\n1008:       }\n1009:     }\n1010:   }\n1011: \n1012:   // -- Channel: Vector ---------------------------------------------------------\n1013: \n1014:   else if (searchType === 'vector') {\n1015:     const effectiveEmbedding: Float32Array | number[] | null =\n1016:       queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n1017: \n1018:     if (!effectiveEmbedding) {\n1019:       throw new Error('[stage1-candidate-gen] Failed to generate embedding for vector search query');\n1020:     }\n1021: \n1022:     channelCount = 1;\n1023:     let vectorResults = vectorIndex.vectorSearch(effectiveEmbedding, {\n1024:       limit,\n1025:       specFolder,\n1026:       tier,\n1027:       contextType,\n1028:       includeConstitutional: false, // Constitutional managed separately below\n1029:       includeArchived,\n1030:     }) as PipelineRow[];\n1031:     if (isTemporalContiguityEnabled()) {\n1032:       vectorResults = (\n1033:         vectorSearchWithContiguity(\n1034:           vectorResults as Array<PipelineRow & { similarity: number; created_at: string }>,\n1035:           3600,\n1036:         ) as PipelineRow[] | null\n1037:       ) ?? vectorResults;\n1038:     }\n1039:     candidates = vectorResults;\n1040:   }\n1041: \n1042:   // -- Unknown search type -----------------------------------------------------\n1043: \n1044:   else {\n1045:     throw new Error(\n1046:       `[stage1-candidate-gen] Unknown searchType: \"${searchType}\". Expected 'multi-concept', 'hybrid', or 'vector'.`\n1047:     );\n1048:   }\n1049: \n1050:   // -- Tier and contextType filtering -----------------------------------------\n1051:   //\n1052:   // Applied after candidate collection but before constitutional injection so\n1053:   // Injected constitutional rows are evaluated by the same filters.\n1054:   // Exception: for hybrid search, tier/contextType are applied here because\n1055:   // SearchWithFallback does not accept these parameters directly.\n1056:   // For vector search, tier/contextType were already passed to vectorSearch,\n1057:   // So this is a no-op guard for those fields.\n1058: \n1059:   if (tier) {\n1060:     candidates = candidates.filter((r) => r.importance_tier === tier);\n1061:   }\n1062: \n1063:   if (contextType) {\n1064:     candidates = candidates.filter(\n1065:       (r) => resolveRowContextType(r) === contextType\n1066:     );\n1067:   }\n1068: \n1069:   // P0 fix: sessionId is for dedup/state tracking, NOT a governance boundary.\n1070:   // Including it here caused all candidates to be filtered out when memory_context\n1071:   // passed an ephemeral sessionId, because memories don't have session-scoped access.\n1072:   const hasGovernanceScope = Boolean(\n1073:     tenantId\n1074:     || userId\n1075:     || agentId\n1076:   );\n1077:   const shouldApplyScopeFiltering = hasGovernanceScope;\n1078:   const scopeFilter = {\n1079:     tenantId,\n1080:     userId,\n1081:     agentId,\n1082:   };\n1083: \n1084:   if (shouldApplyScopeFiltering) {\n1085:     try {\n1086:       const db = requireDb();\n1087:       void db;\n1088:       candidates = filterRowsByScope(candidates, scopeFilter);\n1089:     } catch (_error: unknown) {\n1090:       candidates = filterRowsByScope(candidates, scopeFilter);\n1091:     }\n1092:   }\n1093: \n1094:   // -- Constitutional Memory Injection ----------------------------------------\n1095:   //\n1096:   // If includeConstitutional is requested and no constitutional results exist\n1097:   // In the current candidate set, fetch them separately via vector search.\n1098:   // They enter the pipeline here so all subsequent stages (scoring, reranking)\n1099:   // Treat them uniformly. Constitutional tier boost is applied in Stage 2.\n1100:   //\n1101:   // Injection is skipped when:\n1102:   //   - includeConstitutional is false\n1103:   //   - A tier filter is active (caller explicitly requested a specific tier)\n1104:   //   - Constitutional results already exist in the candidate set\n1105: \n1106:   if (includeConstitutional && !tier) {\n1107:     const existingConstitutional = candidates.filter(\n1108:       (r) => r.importance_tier === 'constitutional'\n1109:     );\n1110: \n1111:     if (existingConstitutional.length === 0) {\n1112:       // Reuse cached embedding instead of generating a new one\n1113:       const constitutionalEmbedding: Float32Array | number[] | null =\n1114:         cachedEmbedding ?? queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n1115: \n1116:       if (constitutionalEmbedding) {\n1117:         const constitutionalResults = vectorIndex.vectorSearch(\n1118:           constitutionalEmbedding,\n1119:           {\n1120:             limit: CONSTITUTIONAL_INJECT_LIMIT,\n1121:             specFolder,\n1122:             tier: 'constitutional',\n1123:             useDecay: false,\n1124:           }\n1125:         ) as PipelineRow[];\n1126: \n1127:         // Only inject rows not already present\n1128:         const existingIds = new Set(candidates.map((r) => r.id));\n1129:         const uniqueConstitutional = constitutionalResults.filter(\n1130:           (r) => !existingIds.has(r.id)\n1131:         );\n1132: \n1133:         // Re-apply filters after injection because constitutional rows fetched\n1134:         // via vector search bypass the earlier governance/context gate.\n1135:         const contextFilteredConstitutional = contextType\n1136:           ? uniqueConstitutional.filter((r) => resolveRowContextType(r) === contextType)\n1137:           : uniqueConstitutional;\n1138:         // Re-apply any explicit governance scope after the injection query.\n1139:         const filteredConstitutional = shouldApplyScopeFiltering\n1140:           ? filterRowsByScope(contextFilteredConstitutional, scopeFilter)\n1141:           : contextFilteredConstitutional;\n1142:         candidates = [...candidates, ...filteredConstitutional];\n1143:         constitutionalInjectedCount = filteredConstitutional.length;\n1144:       }\n1145:     }\n1146:   } else if (!includeConstitutional) {\n1147:     // Explicitly exclude constitutional results if flag is off\n1148:     candidates = candidates.filter(\n1149:       (r) => r.importance_tier !== 'constitutional'\n1150:     );\n1151:   }\n1152: \n1153:   // -- Quality Score Filtering ------------------------------------------------\n1154: \n1155:   candidates = backfillMissingQualityScores(candidates);\n1156:   candidates = filterByMinQualityScore(candidates, qualityThreshold);\n1157:   candidates = boostGraphMetadataCandidates(candidates, query);\n1158: \n1159:   // -- Corpus-Grounded LLM Reformulation ----------------------\n1160:   //\n1161:   // When SPECKIT_LLM_REFORMULATION is enabled and mode === 'deep':\n1162:   //   1. Retrieve top-3 seed results via fast BM25/FTS5 (no embedding call).\n1163:   //   2. Ask the LLM to produce a step-back abstraction + corpus-grounded variants.\n1164:   //   3. Fan-out [original, abstract, ...variants] as additional hybrid search channels.\n1165:   //   4. Deduplicate and merge into candidates.\n1166:   //\n1167:   // Budget: 1 LLM call per cache miss (0 on cache hit).\n1168:   // Fail-open: any error leaves candidates unchanged.\n1169: \n1170:   if (mode === 'deep' && isLlmReformulationEnabled() && searchType === 'hybrid') {\n1171:     try {\n1172:       const seeds = cheapSeedRetrieve(query, { limit: 3 });\n1173:       const reform = await llm.rewrite({ q: query, seeds, mode: 'step_back+corpus' });\n1174:       const allQueries = fanout([query, reform.abstract, ...reform.variants]);\n1175: \n1176:       if (allQueries.length > 1) {\n1177:         const reformEmbedding: Float32Array | number[] | null =\n1178:           cachedEmbedding ?? queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n1179: \n1180:         if (reformEmbedding) {\n1181:           // FIX #7: Use Promise.allSettled so one failing reformulation\n1182:           // branch does not discard results from all other branches.\n1183:           const reformSettledResults = await Promise.allSettled(\n1184:             allQueries.map(async (q, idx): Promise<PipelineRow[]> => {\n1185:               // Reuse cached embedding for original query (idx 0); generate fresh for variants\n1186:               const emb = idx === 0 ? reformEmbedding : await vectorIndex.generateQueryEmbedding(q);\n1187:               if (!emb) {\n1188:                 console.warn('[stage1-candidate-gen] LLM reform embedding generation returned null');\n1189:                 return [];\n1190:               }\n1191:               return hybridSearch.collectRawCandidates(\n1192:                 q,\n1193:                 emb,\n1194:                 hybridSearchOptions\n1195:               ) as Promise<PipelineRow[]>;\n1196:             })\n1197:           );\n1198:           const reformResultSets = reformSettledResults.map((result, idx) => {\n1199:             if (result.status === 'fulfilled') return result.value;\n1200:             console.warn(`[stage1-candidate-gen] D2 LLM reform branch ${idx} rejected: ${result.reason}`);\n1201:             return [] as PipelineRow[];\n1202:           });\n1203: \n1204:           if (reformResultSets.length > 0) {\n1205:             const filteredReformSets = reformResultSets.map((resultSet, index) => {\n1206:               let rows = shouldApplyScopeFiltering\n1207:                 ? filterRowsByScope(resultSet, scopeFilter)\n1208:                 : resultSet;\n1209:               if (contextType) {\n1210:                 rows = rows.filter((r) => resolveRowContextType(r) === contextType);\n1211:               }\n1212:               if (tier) {\n1213:                 rows = applyTierFilter(rows, tier);\n1214:               }\n1215:               rows = backfillMissingQualityScores(rows);\n1216:               rows = filterByMinQualityScore(rows, qualityThreshold);\n1217:               return {\n1218:                 label: allQueries[index] ?? `d2-reform-${index}`,\n1219:                 rows,\n1220:               };\n1221:             });\n1222:             const reformMergedCount = filteredReformSets.reduce((sum, batch) => sum + batch.rows.length, 0);\n1223:             candidates = mergeCandidateBatches(filteredReformSets, {\n1224:               seedCandidates: candidates,\n1225:               seedLabel: query,\n1226:             });\n1227:             channelCount += allQueries.length - 1; // discount original (already counted)\n1228: \n1229:             if (trace) {\n1230:               addTraceEntry(trace, 'candidate', allQueries.length - 1, reformMergedCount, 0, {\n1231:                 channel: 'd2-llm-reformulation',\n1232:                 abstract: reform.abstract,\n1233:                 variantCount: reform.variants.length,\n1234:                 fanoutCount: allQueries.length,\n1235:               });\n1236:             }\n1237:           }\n1238:         }\n1239:       }\n1240:     } catch (reformErr: unknown) {\n1241:       const reformMsg = reformErr instanceof Error ? reformErr.message : String(reformErr);\n1242:       console.warn(`[stage1-candidate-gen] D2 LLM reformulation failed: ${reformMsg}`);\n1243:     }\n1244:   }\n1245: \n1246:   // -- HyDE Shadow Mode ----------------------------------------\n1247:   //\n1248:   // When SPECKIT_HYDE is enabled and mode === 'deep':\n1249:   //   - Check if the current baseline has low confidence.\n1250:   //   - If so, generate a HyDE pseudo-document and embed it.\n1251:   //   - Run a vector-only search with the pseudo-document embedding.\n1252:   //   - Shadow mode (SPECKIT_HYDE_ACTIVE=false): log results, do NOT merge.\n1253:   //   - Active mode (SPECKIT_HYDE_ACTIVE=true): merge into candidates.\n1254:   //\n1255:   // Budget: 1 LLM call per cache miss (shared cache with reformulation → ≤2 total).\n1256:   // Fail-open: any error leaves candidates unchanged.\n1257: \n1258:   if (mode === 'deep' && isHyDEEnabled() && searchType === 'hybrid') {\n1259:     try {\n1260:       const rawHydeCandidates = await runHyDE(query, candidates, limit, specFolder);\n1261:       const hydeCandidates = shouldApplyScopeFiltering\n1262:         ? filterRowsByScope(rawHydeCandidates, scopeFilter)\n1263:         : rawHydeCandidates;\n1264:       if (hydeCandidates.length > 0) {\n1265:         let newHydeCandidates = hydeCandidates;\n1266:         // Apply the same tier/context/quality filters as main candidates\n1267:         if (contextType) {\n1268:           newHydeCandidates = newHydeCandidates.filter((r) => resolveRowContextType(r) === contextType);\n1269:         }\n1270:         if (tier) {\n1271:           newHydeCandidates = applyTierFilter(newHydeCandidates, tier);\n1272:         }\n1273:         newHydeCandidates = backfillMissingQualityScores(newHydeCandidates);\n1274:         newHydeCandidates = filterByMinQualityScore(newHydeCandidates, qualityThreshold);\n1275:         candidates = mergeCandidateBatches([\n1276:           { label: 'hyde', rows: newHydeCandidates },\n1277:         ], {\n1278:           seedCandidates: candidates,\n1279:           seedLabel: query,\n1280:         });\n1281:         channelCount++;\n1282: \n1283:         if (trace) {\n1284:           addTraceEntry(trace, 'candidate', 1, newHydeCandidates.length, 0, {\n1285:             channel: 'd2-hyde',\n1286:             hydeCandidates: newHydeCandidates.length,\n1287:           });\n1288:         }\n1289:       }\n1290:     } catch (hydeErr: unknown) {\n1291:       const hydeMsg = hydeErr instanceof Error ? hydeErr.message : String(hydeErr);\n1292:       console.warn(`[stage1-candidate-gen] D2 HyDE failed: ${hydeMsg}`);\n1293:     }\n1294:   }\n1295: \n1296:   // Summary Embedding Channel\n1297:   // When SPECKIT_MEMORY_SUMMARIES is enabled (default-ON) and scale gate is\n1298:   // Met (>5000 indexed), run a parallel search on summary embeddings and merge\n1299:   // Results. Pattern follows embedding expansion: run in parallel, merge\n1300:   // + deduplicate by ID.\n1301:   if (isMemorySummariesEnabled()) {\n1302:     try {\n1303:       const db = requireDb();\n1304:       if (checkScaleGate(db)) {\n1305:         const summaryEmbedding: Float32Array | number[] | null =\n1306:           queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n1307: \n1308:         if (summaryEmbedding) {\n1309:           const summaryResults = querySummaryEmbeddings(db, summaryEmbedding, limit);\n1310:           if (summaryResults.length > 0) {\n1311:             const existingIds = new Set(candidates.map((r) => String(r.id)));\n1312:             const newSummaryHits: PipelineRow[] = [];\n1313: \n1314:             // F02-003: Batch-fetch instead of N+1 per-item queries\n1315:             const newSummaryIds = summaryResults\n1316:               .filter((sr) => !existingIds.has(String(sr.memoryId)))\n1317:               .map((sr) => sr.memoryId);\n1318: \n1319:             if (newSummaryIds.length > 0) {\n1320:               const placeholders = newSummaryIds.map(() => '?').join(', ');\n1321:               const memRows = db.prepare(\n\n(Output capped at 50 KB. Showing lines 1-1321. Use offset=1322 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage1 Candidate Gen\n// ───────────────────────────────────────────────────────────────\n// 4-stage retrieval pipeline architecture\n//\n// Responsibility: Execute search channels and collect raw candidate results.\n// This stage avoids downstream fusion/reranking, but may apply temporal\n// Contiguity to raw vector-channel hits before later pipeline stages.\n// Results are collected from the appropriate search channel based on search type.\n//\n// Search channels handled:\n//   - multi-concept: Generate per-concept embeddings, run multiConceptSearch\n//   - hybrid (deep mode): Query expansion + multi-variant hybrid search + dedup\n// hybrid: Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n// Suppressed when classifies query as \"simple\" (mutual exclusion)\n//   - hybrid: collectRawCandidates → falls back to vector on failure\n//   - vector: Direct vectorSearch\n//\n// Post-channel operations:\n//   - Constitutional memory injection (if not already present)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage1 Candidate Gen\n// ───────────────────────────────────────────────────────────────\n// 4-stage retrieval pipeline architecture\n//\n// Responsibility: Execute search channels and collect raw candidate results.\n// This stage avoids downstream fusion/reranking, but may apply temporal\n// Contiguity to raw vector-channel hits before later pipeline stages.\n// Results are collected from the appropriate search channel based on search type.\n//\n// Search channels handled:\n//   - multi-concept: Generate per-concept embeddings, run multiConceptSearch\n//   - hybrid (deep mode): Query expansion + multi-variant hybrid search + dedup\n// hybrid: Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n// Suppressed when classifies query as \"simple\" (mutual exclusion)\n//   - hybrid: collectRawCandidates → falls back to vector on failure\n//   - vector: Direct vectorSearch\n//\n// Post-channel operations:\n//   - Constitutional memory injection (if not already present)\n//   - Quality score filtering\n//   - Tier and contextType filtering\n//\n// I/O CONTRACT:\n// Input:  Stage1Input { config: PipelineConfig }\n// Output: Stage1Output { candidates: PipelineRow[], metadata }\n// Key invariants:\n//     - candidates contains raw channel scores; vector hits may include an\n//       optional temporal-contiguity boost applied before downstream fusion\n//     - Constitutional rows are always present when includeConstitutional=true and no tier filter\n//     - All rows pass qualityThreshold (if set) and tier/contextType filters\n// Side effects:\n//     - Generates query embeddings via the embeddings provider (external call)\n//     - Reads from the vector index and FTS5 / BM25 index (DB reads only)\n//\nimport type { Stage1Input, Stage1Output, PipelineRow } from './types.js';\nimport { resolveEffectiveScore } from './types.js';\nimport * as vectorIndex from '../vector-index.js';\nimport * as hybridSearch from '../hybrid-search.js';\nimport { vectorSearchWithContiguity } from '../../cognitive/temporal-contiguity.js';\nimport { isMultiQueryEnabled, isEmbeddingExpansionEnabled, isMemorySummariesEnabled, isQueryDecompositionEnabled, isGraphConceptRoutingEnabled, isLlmReformulationEnabled, isHyDEEnabled, isQuerySurrogatesEnabled, isTemporalContiguityEnabled, isQueryConceptExpansionEnabled } from '../search-flags.js';\nimport { expandQuery } from '../query-expander.js';\nimport { expandQueryWithEmbeddings, isExpansionActive } from '../embedding-expansion.js';\nimport { querySummaryEmbeddings, checkScaleGate } from '../memory-summaries.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/db-helpers.js';\nimport { filterRowsByScope } from '../../governance/scope-governance.js';\nimport { withTimeout } from '../../errors/core.js';\nimport { GRAPH_METADATA_MIGRATED_QUALITY_FLAG } from '../../graph/graph-metadata-schema.js';\nimport { computeBackfillQualityScore } from '../../validation/save-quality-gate.js';\nimport {\n  isMultiFacet,\n  decompose,\n  mergeByFacetCoverage as mergeFacetCoveragePools,\n  MAX_FACETS,\n} from '../query-decomposer.js';\nimport { routeQueryConcepts, nounPhrases, getConceptExpansionTerms } from '../entity-linker.js';\nimport { cheapSeedRetrieve, llm, fanout } from '../llm-reformulation.js';\nimport { runHyDE } from '../hyde.js';\nimport { matchSurrogates } from '../query-surrogates.js';\nimport { loadSurrogatesBatch } from '../surrogate-storage.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Hybrid search pipeline\n\n\n// -- Constants --\n\n/** Maximum number of deep-mode query variants to generate (original + expanded). */\nconst MAX_DEEP_QUERY_VARIANTS = 3;\n\n/** F1: Deep-mode expansion timeout — fall back to base query if variants take too long. */\nconst DEEP_EXPANSION_TIMEOUT_MS = 5000;\n\n/** Minimum cosine similarity for multi-concept search. */\nconst MULTI_CONCEPT_MIN_SIMILARITY = 0.5;\n\n/** Number of constitutional results to fetch when none appear in hybrid/vector results. */\nconst CONSTITUTIONAL_INJECT_LIMIT = 5;\n\n/** Number of similar memories to mine for embedding-based query expansion terms. */\nconst DEFAULT_EXPANSION_CANDIDATE_LIMIT = 5;\n\n/** D2: Timeout for facet decomposition parallel searches (ms). */\nconst DECOMPOSITION_TIMEOUT_MS = 5000;\nconst MAX_QUERY_DECOMPOSITION_FACETS = MAX_FACETS;\n\n// -- Helper Functions --\n\n/**\n * Filter results by a minimum quality score threshold.\n *\n * - If no threshold is provided or it is not a finite number, all results pass.\n * - Threshold is clamped to [0, 1].\n * - Rows with a missing or non-finite `quality_score` are treated as 0.\n *\n * @param results - Candidate rows to filter.\n * @param threshold - Minimum quality score in [0, 1] (inclusive).\n * @returns Filtered array; original array returned unchanged when no threshold applies.\n */\nfunction filterByMinQualityScore(\n  results: PipelineRow[],\n  threshold?: number\n): PipelineRow[] {\n  if (typeof threshold !== 'number' || !Number.isFinite(threshold)) {\n    return results;\n  }\n\n  const clampedThreshold = Math.max(0, Math.min(1, threshold));\n\n  return results.filter((row) => {\n    const rawScore = row.quality_score as number | undefined;\n    const score =\n      typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n    return score >= clampedThreshold;\n  });\n}\n\nfunction backfillMissingQualityScores(results: PipelineRow[]): PipelineRow[] {\n  return results.map((row) => {\n    if (row.quality_score !== 0 && row.quality_score != null) {\n      return row;\n    }\n\n    return {\n      ...row,\n      quality_score: computeBackfillQualityScore(row),\n    };\n  });\n}\n\nfunction applyArchiveFilter(\n  results: PipelineRow[],\n  _includeArchived: boolean\n): PipelineRow[] {\n  return results;\n}\n\nfunction applyFolderFilter(\n  results: PipelineRow[],\n  specFolder?: string\n): PipelineRow[] {\n  if (!specFolder) return results;\n  return results.filter((row) => {\n    const rowSpecFolder = row.spec_folder ?? row.specFolder;\n    return rowSpecFolder === specFolder;\n  });\n}\n\nfunction applyTierFilter(\n  results: PipelineRow[],\n  tier?: string\n): PipelineRow[] {\n  if (!tier) return results;\n  return results.filter((row) => row.importance_tier === tier);\n}\n\n/**\n * Resolve the effective context type from a pipeline row.\n *\n * Rows may carry context type under either `contextType` (camelCase) or\n * `context_type` (snake_case). This function normalises the lookup.\n *\n * @param row - The pipeline row to inspect.\n * @returns The context type string, or `undefined` if absent.\n */\nfunction resolveRowContextType(row: PipelineRow): string | undefined {\n  if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n    return row.contextType;\n  }\n  if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n    return row.context_type;\n  }\n  return undefined;\n}\n\nfunction mergeStringLists(...values: unknown[]): string[] {\n  const merged = new Set<string>();\n  for (const value of values) {\n    if (!Array.isArray(value)) {\n      continue;\n    }\n    for (const entry of value) {\n      if (typeof entry === 'string' && entry.length > 0) {\n        merged.add(entry);\n      }\n    }\n  }\n  return Array.from(merged);\n}\n\nfunction readFiniteScoreMap(value: unknown): Record<string, number> {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) {\n    return {};\n  }\n\n  const normalized: Record<string, number> = {};\n  for (const [key, score] of Object.entries(value as Record<string, unknown>)) {\n    if (typeof score === 'number' && Number.isFinite(score)) {\n      normalized[key] = score;\n    }\n  }\n  return normalized;\n}\n\nfunction readQualityFlags(value: unknown): string[] {\n  if (Array.isArray(value)) {\n    return value.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n  }\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    return [];\n  }\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n    }\n  } catch {\n    // Fall back to comma-delimited parsing for legacy callers/tests.\n  }\n  return value\n    .split(',')\n    .map((entry) => entry.trim())\n    .filter((entry) => entry.length > 0);\n}\n\nfunction isMigratedGraphMetadataCandidate(row: PipelineRow): boolean {\n  const migratedValue = row.migrated ?? row.is_migrated ?? row.metadata_migrated;\n  if (migratedValue === true || migratedValue === 1 || migratedValue === '1' || migratedValue === 'true') {\n    return true;\n  }\n  const qualityFlags = readQualityFlags(row.quality_flags ?? row.qualityFlags);\n  return qualityFlags.includes(GRAPH_METADATA_MIGRATED_QUALITY_FLAG);\n}\n\nfunction mergeScoreMaps(...maps: Array<Record<string, number>>): Record<string, number> {\n  const merged: Record<string, number> = {};\n  for (const map of maps) {\n    for (const [key, score] of Object.entries(map)) {\n      if (!(key in merged) || score > merged[key]!) {\n        merged[key] = score;\n      }\n    }\n  }\n  return merged;\n}\n\nfunction getCandidateSources(row: PipelineRow): string[] {\n  const explicitSources = mergeStringLists(row.sources);\n  if (explicitSources.length > 0) {\n    return explicitSources;\n  }\n  return typeof row.source === 'string' && row.source.length > 0 ? [row.source] : [];\n}\n\nfunction getCandidateSourceScores(row: PipelineRow): Record<string, number> {\n  const sourceScores = readFiniteScoreMap(row.sourceScores);\n  if (Object.keys(sourceScores).length > 0) {\n    return sourceScores;\n  }\n\n  const resolvedScore = resolveEffectiveScore(row);\n  if (resolvedScore <= 0) {\n    return {};\n  }\n\n  const fallbackScores: Record<string, number> = {};\n  for (const source of getCandidateSources(row)) {\n    fallbackScores[source] = resolvedScore;\n  }\n  return fallbackScores;\n}\n\nfunction isPacketOrientedQuery(query: string): boolean {\n  const normalized = query.toLowerCase();\n  return [\n    'packet',\n    'spec folder',\n    'graph metadata',\n    'dependency',\n    'depends on',\n    'related to',\n    'supersedes',\n    'resume',\n    'key files',\n    'parent',\n    'children',\n  ].some((term) => normalized.includes(term));\n}\n\nfunction boostGraphMetadataCandidates(\n  results: PipelineRow[],\n  query: string,\n): PipelineRow[] {\n  if (!isPacketOrientedQuery(query)) {\n    return results;\n  }\n\n  return results.map((row) => {\n    if (row.document_type !== 'graph_metadata' && row.documentType !== 'graph_metadata') {\n      return row;\n    }\n\n    const currentScore = resolveEffectiveScore(row);\n    const adjustedScore = isMigratedGraphMetadataCandidate(row)\n      ? Math.max(0, currentScore - 0.12)\n      : Math.min(1, currentScore + 0.12);\n    const sourceScores = getCandidateSourceScores(row);\n    return {\n      ...row,\n      score: adjustedScore,\n      rrfScore: adjustedScore,\n      sourceScores: {\n        ...sourceScores,\n        graph_metadata: adjustedScore,\n      },\n    };\n  });\n}\n\nfunction annotateBranchScore(row: PipelineRow, branchLabel: string): Record<string, number> {\n  const existingBranchScores = readFiniteScoreMap(row.stage1BranchScores);\n  const effectiveScore = resolveEffectiveScore(row);\n  if (branchLabel.length === 0 || !Number.isFinite(effectiveScore)) {\n    return existingBranchScores;\n  }\n  return mergeScoreMaps(existingBranchScores, { [branchLabel]: effectiveScore });\n}\n\nfunction mergeCandidateRows(\n  existing: PipelineRow | undefined,\n  incoming: PipelineRow,\n  branchLabel: string,\n): PipelineRow {\n  const incomingBranchScores = annotateBranchScore(incoming, branchLabel);\n  if (!existing) {\n    const sources = getCandidateSources(incoming);\n    const channelAttribution = mergeStringLists(incoming.channelAttribution, sources);\n    return {\n      ...incoming,\n      sources: sources.length > 0 ? sources : incoming.sources,\n      channelAttribution: channelAttribution.length > 0 ? channelAttribution : incoming.channelAttribution,\n      sourceScores: Object.keys(getCandidateSourceScores(incoming)).length > 0\n        ? getCandidateSourceScores(incoming)\n        : incoming.sourceScores,\n      stage1BranchScores: Object.keys(incomingBranchScores).length > 0 ? incomingBranchScores : undefined,\n      stage1BranchCount: Object.keys(incomingBranchScores).length || incoming.stage1BranchCount,\n      channelCount: sources.length > 0 ? sources.length : incoming.channelCount,\n    };\n  }\n\n  const existingScore = resolveEffectiveScore(existing);\n  const incomingScore = resolveEffectiveScore(incoming);\n  const primary = incomingScore > existingScore ? incoming : existing;\n  const secondary = primary === incoming ? existing : incoming;\n\n  const mergedSources = mergeStringLists(getCandidateSources(existing), getCandidateSources(incoming));\n  const mergedChannelAttribution = mergeStringLists(\n    existing.channelAttribution,\n    incoming.channelAttribution,\n    mergedSources,\n  );\n  const mergedSourceScores = mergeScoreMaps(\n    getCandidateSourceScores(existing),\n    getCandidateSourceScores(incoming),\n  );\n  const mergedBranchScores = mergeScoreMaps(\n    readFiniteScoreMap(existing.stage1BranchScores),\n    incomingBranchScores,\n  );\n\n  return {\n    ...secondary,\n    ...primary,\n    sources: mergedSources.length > 0 ? mergedSources : primary.sources,\n    source: typeof primary.source === 'string' && primary.source.length > 0\n      ? primary.source\n      : (mergedSources[0] ?? primary.source),\n    channelAttribution: mergedChannelAttribution.length > 0\n      ? mergedChannelAttribution\n      : primary.channelAttribution,\n    sourceScores: Object.keys(mergedSourceScores).length > 0\n      ? mergedSourceScores\n      : primary.sourceScores,\n    stage1BranchScores: Object.keys(mergedBranchScores).length > 0\n      ? mergedBranchScores\n      : primary.stage1BranchScores,\n    stage1BranchCount: Object.keys(mergedBranchScores).length || primary.stage1BranchCount,\n    channelCount: mergedSources.length > 0 ? mergedSources.length : primary.channelCount,\n  };\n}\n\nfunction mergeCandidateBatches(\n  batches: Array<{ label: string; rows: PipelineRow[] }>,\n  options: { seedCandidates?: PipelineRow[]; seedLabel?: string } = {},\n): PipelineRow[] {\n  const merged = new Map<string, PipelineRow>();\n  const seedLabel = options.seedLabel ?? '';\n\n  for (const row of options.seedCandidates ?? []) {\n    const key = String(row.id);\n    merged.set(key, mergeCandidateRows(merged.get(key), row, seedLabel));\n  }\n\n  for (const batch of batches) {\n    for (const row of batch.rows) {\n      const key = String(row.id);\n      merged.set(key, mergeCandidateRows(merged.get(key), row, batch.label));\n    }\n  }\n\n  return Array.from(merged.values());\n}\n\n/**\n * Build deep-mode query variants using rule-based synonym expansion.\n *\n * The original query is always the first variant. Up to `MAX_DEEP_QUERY_VARIANTS - 1`\n * additional variants are produced by `expandQuery`. If expansion fails or produces\n * no new terms, the array contains only the original query.\n *\n * Simple-query bypass (038): When classifies the query as \"simple\",\n * rule-based expansion is skipped — consistent with the embedding-expansion\n * path's `isExpansionActive()` gate. Simple queries do not benefit from synonym\n * expansion and the additional search channels add latency without recall gain.\n *\n * Duplicates are eliminated via `Set` deduplication before slicing.\n *\n * @param query - The original search query string.\n * @returns Array of distinct query variants, original first, capped at MAX_DEEP_QUERY_VARIANTS.\n */\nasync function buildDeepQueryVariants(query: string): Promise<string[]> {\n  try {\n    const expanded = expandQuery(query);\n    const variants = new Set<string>(expanded);\n    // ExpandQuery already includes the original as the first entry,\n    // But be explicit in case the implementation changes.\n    variants.add(query);\n\n    // Deep mode: ensure at least 2 variants so the multi-search branch fires.\n    // When synonym expansion produces no new variants (simple/domain-specific queries),\n    // generate a basic reformulation to trigger the parallel search path.\n    if (variants.size < 2) {\n      const words = query.trim().split(/\\s+/);\n      if (words.length >= 2) {\n        variants.add(words.slice().reverse().join(' '));\n      } else {\n        variants.add(`what is ${query}`);\n      }\n    }\n\n    return Array.from(variants).slice(0, MAX_DEEP_QUERY_VARIANTS);\n  } catch (err: unknown) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(\n      `[stage1-candidate-gen] buildDeepQueryVariants failed, using original query: ${msg}`\n    );\n    return [query];\n  }\n}\n\nfunction normalizeFacetText(fragment: string): string {\n  return fragment\n    .replace(/^[\\s,:;]+|[\\s,.:;?!]+$/g, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction decomposeQueryFacets(query: string): string[] {\n  const trimmed = normalizeFacetText(query);\n  if (trimmed.length === 0) return [];\n\n  const focusMatch = trimmed.match(/\\babout\\s+(.+?)[?.!]*$/i);\n  const focusSegment = focusMatch?.[1]?.trim() ?? trimmed;\n\n  const listLikeFacets = focusSegment\n    .split(/\\s*(?:,|\\band\\b|\\bor\\b|\\balso\\b|\\bplus\\b|\\bas well as\\b|\\balong with\\b)\\s*/i)\n    .map(normalizeFacetText)\n    .filter((facet) => facet.length > 0);\n\n  if (listLikeFacets.length >= 2) {\n    return [...new Set(listLikeFacets)].slice(0, MAX_QUERY_DECOMPOSITION_FACETS);\n  }\n\n  if (!isMultiFacet(trimmed)) {\n    return [trimmed];\n  }\n\n  const decomposedFacets = decompose(trimmed)\n    .map(normalizeFacetText)\n    .filter((facet) => facet.length > 0);\n\n  if (decomposedFacets.length === 0) {\n    return [trimmed];\n  }\n\n  return [...new Set(decomposedFacets)].slice(0, MAX_QUERY_DECOMPOSITION_FACETS);\n}\n\nfunction buildQueryDecompositionPool(query: string, mode?: string | null): string[] {\n  const normalizedQuery = normalizeFacetText(query);\n  if (mode !== 'deep' || !isQueryDecompositionEnabled()) {\n    return [normalizedQuery];\n  }\n\n  const facets = decomposeQueryFacets(query).filter((facet) => facet !== normalizedQuery);\n  return [normalizedQuery, ...facets];\n}\n\nfunction mergeQueryFacetCoverage(resultSets: PipelineRow[][]): PipelineRow[] {\n  const firstSeenById = new Map<number, PipelineRow>();\n  for (const resultSet of resultSets) {\n    for (const row of resultSet) {\n      if (!firstSeenById.has(row.id)) {\n        firstSeenById.set(row.id, row);\n      }\n    }\n  }\n  return Array.from(firstSeenById.values());\n}\n\n// -- Stage 1 --\n\n/**\n * Execute Stage 1: Candidate Generation.\n *\n * Selects and runs the appropriate search channel(s) based on `config.searchType`\n * and `config.mode`, then applies vector-channel temporal contiguity when\n * enabled, followed by constitutional injection, quality filtering, and\n * tier/contextType filtering.\n *\n * This stage does not apply Stage 2 fusion/reranking signals. Vector-channel\n * results may receive a temporal proximity boost before moving downstream.\n *\n * @param input - Stage 1 input containing the resolved pipeline configuration.\n * @returns Stage 1 output with raw candidate rows and channel metadata.\n */\nexport async function executeStage1(input: Stage1Input): Promise<Stage1Output> {\n  const startTime = Date.now();\n  try {\n    return await executeStage1Core(input, startTime);\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[stage1-candidate-gen] Stage 1 failed, returning empty candidates: ${message}`);\n    return {\n      candidates: [],\n      metadata: {\n        searchType: input.config.searchType,\n        channelCount: 0,\n        activeChannels: 0,\n        candidateCount: 0,\n        constitutionalInjected: 0,\n        durationMs: Date.now() - startTime,\n      },\n    };\n  }\n}\n\nasync function executeStage1Core(input: Stage1Input, startTime: number): Promise<Stage1Output> {\n  const { config } = input;\n  // Cache embedding at function scope for reuse in constitutional injection\n  let cachedEmbedding: Float32Array | number[] | null = null;\n  let constitutionalInjectedCount = 0;\n\n  const {\n    query,\n    queryEmbedding,\n    concepts,\n    searchType,\n    mode,\n    limit,\n    specFolder,\n    tenantId,\n    userId,\n    agentId,\n    tier,\n    contextType,\n    includeArchived,\n    includeConstitutional,\n    qualityThreshold,\n    trace,\n  } = config;\n\n  let candidates: PipelineRow[] = [];\n  let channelCount = 0;\n  const hybridSearchOptions = {\n    limit,\n    specFolder,\n    includeArchived,\n    intent: config.adaptiveFusionIntent ?? undefined,\n  };\n\n  // -- Graph Concept Routing -----------------------------------\n  //\n  // When SPECKIT_GRAPH_CONCEPT_ROUTING is enabled, extract noun phrases from\n  // the query and match them against the concept alias table. If concepts are\n  // matched, log them to the trace for downstream use (graph channel activation\n  // is surfaced via trace metadata; actual graph channel is handled in Stage 2).\n  //\n  // When SPECKIT_QUERY_CONCEPT_EXPANSION is also enabled,\n  // matched concepts are reverse-mapped to their alias terms and appended to\n  // the query for the hybrid search channel, improving recall for alias-rich\n  // queries (e.g. \"semantic search\" → also searches \"retrieval\", \"query\", etc.).\n  //\n  // Fail-open: any error leaves candidates unchanged.\n\n  /** Effective query for hybrid search — may be expanded by concept routing. */\n  let effectiveQuery = query;\n\n  if (isGraphConceptRoutingEnabled() && searchType === 'hybrid') {\n    try {\n      let routingDb: Parameters<typeof routeQueryConcepts>[1];\n      try {\n        routingDb = requireDb();\n      } catch (_dbErr: unknown) {\n        routingDb = undefined;\n      }\n      const routing = routeQueryConcepts(query, routingDb);\n      if (routing.graphActivated && routing.concepts.length > 0) {\n        // Expand query with concept alias terms\n        if (isQueryConceptExpansionEnabled()) {\n          try {\n            const originalTokens = nounPhrases(query);\n            const expansionTerms = getConceptExpansionTerms(\n              routing.concepts,\n              originalTokens,\n              5,\n            );\n            if (expansionTerms.length > 0) {\n              effectiveQuery = `${query} ${expansionTerms.join(' ')}`;\n              if (trace) {\n                addTraceEntry(trace, 'candidate', 0, 0, 0, {\n                  channel: 'd2-concept-expansion',\n                  originalQuery: query,\n                  expandedQuery: effectiveQuery,\n                  expansionTerms,\n                  matchedConcepts: routing.concepts,\n                });\n              }\n            }\n          } catch (expansionErr: unknown) {\n            const expansionMsg = expansionErr instanceof Error ? expansionErr.message : String(expansionErr);\n            console.warn(`[stage1-candidate-gen] D2 concept expansion failed (fail-open): ${expansionMsg}`);\n          }\n        }\n\n        if (trace) {\n          addTraceEntry(trace, 'candidate', 0, 0, 0, {\n            channel: 'd2-concept-routing',\n            matchedConcepts: routing.concepts,\n            graphActivated: true,\n          });\n        }\n      }\n    } catch (routingErr: unknown) {\n      const routingMsg = routingErr instanceof Error ? routingErr.message : String(routingErr);\n      console.warn(`[stage1-candidate-gen] D2 concept routing failed: ${routingMsg}`);\n    }\n  }\n\n  // -- Channel: Multi-Concept --------------------------------------------------\n\n  if (searchType === 'multi-concept' && Array.isArray(concepts) && concepts.length >= 2) {\n    // Validate concept list: 2-5 non-empty strings\n    if (concepts.length > 5) {\n      throw new Error('[stage1-candidate-gen] Maximum 5 concepts allowed for multi-concept search');\n    }\n\n    for (const concept of concepts) {\n      if (typeof concept !== 'string' || concept.trim().length === 0) {\n        throw new Error('[stage1-candidate-gen] Each concept must be a non-empty string');\n      }\n    }\n\n    // Generate one embedding per concept\n    const conceptEmbeddings: Float32Array[] = [];\n    for (const concept of concepts) {\n      const emb = await vectorIndex.generateQueryEmbedding(concept);\n      if (!emb) {\n        throw new Error(\n          `[stage1-candidate-gen] Failed to generate embedding for concept: \"${concept}\"`\n        );\n      }\n      conceptEmbeddings.push(emb);\n    }\n\n    channelCount = 1;\n    candidates = vectorIndex.multiConceptSearch(conceptEmbeddings, {\n      minSimilarity: MULTI_CONCEPT_MIN_SIMILARITY,\n      limit,\n      specFolder,\n    }) as PipelineRow[];\n  }\n\n  // -- Channel: Hybrid (with optional deep-mode query expansion) ---------------\n  //\n  else if (searchType === 'hybrid') {\n    // Resolve the query embedding — either pre-computed in config or generate now\n    // Cache this embedding for reuse in constitutional injection path\n    // To avoid a duplicate generateQueryEmbedding() call.\n    const effectiveEmbedding: Float32Array | number[] | null =\n      queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n    cachedEmbedding = effectiveEmbedding;\n\n    if (!effectiveEmbedding) {\n      throw new Error('[stage1-candidate-gen] Failed to generate embedding for hybrid search query');\n    }\n\n    // Deep mode: expand query into variants and run hybrid for each, then dedup\n    if (mode === 'deep' && isMultiQueryEnabled()) {\n      // -- Query Decomposition (SPECKIT_QUERY_DECOMPOSITION) ---\n      //\n      // When enabled and the query is multi-faceted, decompose into up to 3\n      // sub-query facets and run hybrid search per facet. Results are merged\n      // by facet coverage (items appearing in multiple facets rank higher).\n      //\n      // This block takes the place of the synonym-expansion path below when\n      // decomposition fires. If decomposition is disabled, not applicable, or\n      // fails, execution falls through to the existing expansion logic.\n\n      if (isQueryDecompositionEnabled() && isMultiFacet(query)) {\n        try {\n          const normalizedQuery = normalizeFacetText(query);\n          let facets: string[] = [];\n\n          try {\n            facets = buildQueryDecompositionPool(query, mode)\n              .filter((facet) => facet !== normalizedQuery)\n              .map(normalizeFacetText)\n              .filter((facet) => facet.length > 0);\n          } catch (facetErr: unknown) {\n            const facetMsg = facetErr instanceof Error ? facetErr.message : String(facetErr);\n            console.warn(\n              `[stage1-candidate-gen] D2 faceted query decomposition failed, falling back to basic decomposition: ${facetMsg}`\n            );\n          }\n\n          if (facets.length === 0) {\n            facets = decompose(query)\n              .map(normalizeFacetText)\n              .filter((facet) => facet.length > 0 && facet !== normalizedQuery);\n          }\n\n          facets = [...new Set(facets)].slice(0, MAX_QUERY_DECOMPOSITION_FACETS);\n\n          if (facets.length > 0) {\n            // Run hybrid for the original query plus each facet, in parallel\n            const allQueries = [query, ...facets];\n            // FIX #7: Use Promise.allSettled so one failing facet branch\n            // does not discard results from all other branches.\n            const facetSettledResults = await withTimeout(\n              Promise.allSettled(\n                allQueries.map(async (q): Promise<PipelineRow[]> => {\n                  const facetEmbedding = await vectorIndex.generateQueryEmbedding(q);\n                  if (!facetEmbedding) {\n                    console.warn('[stage1-candidate-gen] D2 facet embedding generation returned null');\n                    return [];\n                  }\n                  return hybridSearch.collectRawCandidates(\n                    q,\n                    facetEmbedding,\n                    hybridSearchOptions\n                  ) as Promise<PipelineRow[]>;\n                })\n              ),\n              DECOMPOSITION_TIMEOUT_MS,\n              'D2 facet decomposition',\n            );\n            const facetResultSets = facetSettledResults.map((result, idx) => {\n              if (result.status === 'fulfilled') return result.value;\n              console.warn(`[stage1-candidate-gen] D2 facet branch ${idx} rejected: ${result.reason}`);\n              return [] as PipelineRow[];\n            });\n\n            channelCount = allQueries.length;\n            const pools = allQueries.map((q, i) => ({\n              query: q,\n              results: facetResultSets[i] ?? [],\n            }));\n            candidates = mergeFacetCoveragePools(pools);\n\n            if (trace) {\n              addTraceEntry(trace, 'candidate', channelCount, candidates.length, 0, {\n                channel: 'd2-query-decomposition',\n                originalQuery: query,\n                facets,\n                facetCount: facets.length,\n              });\n            }\n\n            // Skip the standard deep-mode expansion path below\n            // (jump to post-channel processing via the else-if chain)\n          }\n        } catch (decompErr: unknown) {\n          const decompMsg = decompErr instanceof Error ? decompErr.message : String(decompErr);\n          console.warn(\n            `[stage1-candidate-gen] D2 query decomposition failed, falling through to expansion: ${decompMsg}`\n          );\n          // Fall through to standard deep expansion path below (candidates is empty)\n        }\n      }\n\n      // Only run existing expansion logic when decomposition did not produce results\n      if (candidates.length === 0) {\n\n      const queryVariants = await buildDeepQueryVariants(query);\n\n      if (queryVariants.length > 1) {\n        try {\n          // F1: Wrap parallel variant searches with latency budget.\n          // If variants exceed DEEP_EXPANSION_TIMEOUT_MS, fall back to base query.\n          // FIX #7: Use Promise.allSettled so one failing variant does not\n          // discard results from all other variant branches.\n          const variantSettledResults = await withTimeout(\n            Promise.allSettled(\n              queryVariants.map(async (variant): Promise<PipelineRow[]> => {\n                const variantEmbedding = await vectorIndex.generateQueryEmbedding(variant);\n                if (!variantEmbedding) {\n                  console.warn('[stage1-candidate-gen] Deep variant embedding generation returned null');\n                  return [];\n                }\n                const variantResults = await hybridSearch.collectRawCandidates(\n                  variant,\n                  variantEmbedding,\n                  hybridSearchOptions\n                );\n                return variantResults as PipelineRow[];\n              })\n            ),\n            DEEP_EXPANSION_TIMEOUT_MS,\n            'Deep-mode query expansion',\n          );\n          const variantResultSets: PipelineRow[][] = variantSettledResults.map((result, idx) => {\n            if (result.status === 'fulfilled') return result.value;\n            console.warn(`[stage1-candidate-gen] Deep variant branch ${idx} rejected: ${result.reason}`);\n            return [] as PipelineRow[];\n          });\n\n          channelCount = queryVariants.length;\n\n          // Merge variant results, deduplicate by id, preserve first-occurrence order\n          candidates = mergeCandidateBatches(\n            variantResultSets.map((rows, index) => ({\n              label: queryVariants[index] ?? `deep-variant-${index}`,\n              rows,\n            })),\n          );\n        } catch (expandErr: unknown) {\n          const expandMsg =\n            expandErr instanceof Error ? expandErr.message : String(expandErr);\n          console.warn(\n            `[stage1-candidate-gen] Deep query expansion failed, falling back to single hybrid: ${expandMsg}`\n          );\n          // Fall through to single hybrid search below\n          channelCount = 1;\n          candidates = (await hybridSearch.collectRawCandidates(\n            query,\n            effectiveEmbedding,\n            hybridSearchOptions\n          )) as PipelineRow[];\n        }\n      } else {\n        // ExpandQuery returned only the original; treat as standard hybrid\n        channelCount = 1;\n        candidates = (await hybridSearch.collectRawCandidates(\n          query,\n          effectiveEmbedding,\n          hybridSearchOptions\n        )) as PipelineRow[];\n      }\n\n      } // end: if (candidates.length === 0)\n    } else {\n      // Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n      //\n      // When is enabled and does not classify the query as \"simple\",\n      // We expand the query using embedding similarity to find related terms\n      // From the memory index. The expanded query is used as an additional\n      // Hybrid search channel whose results are merged with the baseline.\n      //\n      // Mutual exclusion: isExpansionActive returns false when classifies\n      // The query as \"simple\", suppressing expansion with zero added latency.\n\n      let r12ExpansionApplied = false;\n\n      if (isEmbeddingExpansionEnabled() && isExpansionActive(query)) {\n        try {\n          // ExpandQueryWithEmbeddings requires a Float32Array; the effective\n          // Embedding may be a number[] when generated by some providers, so\n          // Convert if necessary before passing it in.\n          const expansionEmbedding: Float32Array =\n            effectiveEmbedding instanceof Float32Array\n              ? effectiveEmbedding\n              : Float32Array.from(effectiveEmbedding as number[]);\n\n          const expanded = await expandQueryWithEmbeddings(query, expansionEmbedding, {\n            limit: DEFAULT_EXPANSION_CANDIDATE_LIMIT,\n          });\n\n          // Only run an extra channel if the expansion actually produced new terms\n          if (expanded.expanded.length > 0 && expanded.combinedQuery !== query) {\n            // Run the baseline and the expanded query in parallel\n            const [baselineResults, expansionResults] = await Promise.all([\n              hybridSearch.collectRawCandidates(\n                query,\n                effectiveEmbedding,\n                hybridSearchOptions\n              ).catch((err: unknown): PipelineRow[] => {\n                console.warn(\n                  '[stage1-candidate-gen] Baseline candidate collection failed:',\n                  err instanceof Error ? err.message : String(err)\n                );\n                return [];\n              }),\n              vectorIndex.generateQueryEmbedding(expanded.combinedQuery).then(\n                async (expandedEmb): Promise<PipelineRow[]> => {\n                  if (!expandedEmb) {\n                    console.warn('[stage1-candidate-gen] Expanded query embedding generation returned null');\n                    return [];\n                  }\n                  return hybridSearch.collectRawCandidates(\n                    expanded.combinedQuery,\n                    expandedEmb,\n                    hybridSearchOptions\n                  ) as Promise<PipelineRow[]>;\n                }\n              ).catch((err: unknown): PipelineRow[] => {\n                console.warn(\n                  '[stage1-candidate-gen] Expansion candidate collection failed:',\n                  err instanceof Error ? err.message : String(err)\n                );\n                return [];\n              }),\n            ]);\n\n            channelCount = 2;\n            r12ExpansionApplied = true;\n\n            // Merge both result sets, deduplicate by id, baseline-first ordering\n            // So baseline scores dominate when the same memory appears in both.\n            candidates = mergeCandidateBatches([\n              { label: query, rows: baselineResults as PipelineRow[] },\n              { label: expanded.combinedQuery, rows: expansionResults as PipelineRow[] },\n            ]);\n\n            if (trace) {\n              addTraceEntry(trace, 'candidate', channelCount, candidates.length, 0, {\n                channel: 'r12-embedding-expansion',\n                expandedTerms: expanded.expanded,\n                combinedQuery: expanded.combinedQuery,\n              });\n            }\n          }\n        } catch (r12Err: unknown) {\n          const r12Msg = r12Err instanceof Error ? r12Err.message : String(r12Err);\n          console.warn(\n            `[stage1-candidate-gen] R12 embedding expansion failed, using standard hybrid: ${r12Msg}`\n          );\n        }\n      }\n\n      // Standard hybrid search — runs when is off, suppressed by,\n      // Or produced no results (candidates still empty from the try block above).\n      // Uses effectiveQuery (concept-expanded) for BM25 recall.\n      if (!r12ExpansionApplied) {\n        try {\n          channelCount = 1;\n          const hybridResults = (await hybridSearch.collectRawCandidates(\n            effectiveQuery,\n            effectiveEmbedding,\n            hybridSearchOptions\n          )) as PipelineRow[];\n          candidates = hybridResults;\n        } catch (hybridErr: unknown) {\n          const hybridMsg =\n            hybridErr instanceof Error ? hybridErr.message : String(hybridErr);\n          console.warn(\n            `[stage1-candidate-gen] Hybrid search failed, falling back to vector: ${hybridMsg}`\n          );\n\n          // Fallback: pure vector search\n          channelCount = 1;\n          let vectorResults = vectorIndex.vectorSearch(effectiveEmbedding, {\n            limit,\n            specFolder,\n            tier,\n            contextType,\n            includeConstitutional: false, // Constitutional managed separately below\n            includeArchived,\n          }) as PipelineRow[];\n          if (isTemporalContiguityEnabled()) {\n            vectorResults = (\n              vectorSearchWithContiguity(\n                vectorResults as Array<PipelineRow & { similarity: number; created_at: string }>,\n                3600,\n              ) as PipelineRow[] | null\n            ) ?? vectorResults;\n          }\n          candidates = vectorResults;\n\n          if (trace) {\n            addTraceEntry(trace, 'fallback', 0, candidates.length, 0, {\n              reason: hybridMsg,\n              channel: 'vector',\n            });\n          }\n        }\n      }\n    }\n  }\n\n  // -- Channel: Vector ---------------------------------------------------------\n\n  else if (searchType === 'vector') {\n    const effectiveEmbedding: Float32Array | number[] | null =\n      queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n    if (!effectiveEmbedding) {\n      throw new Error('[stage1-candidate-gen] Failed to generate embedding for vector search query');\n    }\n\n    channelCount = 1;\n    let vectorResults = vectorIndex.vectorSearch(effectiveEmbedding, {\n      limit,\n      specFolder,\n      tier,\n      contextType,\n      includeConstitutional: false, // Constitutional managed separately below\n      includeArchived,\n    }) as PipelineRow[];\n    if (isTemporalContiguityEnabled()) {\n      vectorResults = (\n        vectorSearchWithContiguity(\n          vectorResults as Array<PipelineRow & { similarity: number; created_at: string }>,\n          3600,\n        ) as PipelineRow[] | null\n      ) ?? vectorResults;\n    }\n    candidates = vectorResults;\n  }\n\n  // -- Unknown search type -----------------------------------------------------\n\n  else {\n    throw new Error(\n      `[stage1-candidate-gen] Unknown searchType: \"${searchType}\". Expected 'multi-concept', 'hybrid', or 'vector'.`\n    );\n  }\n\n  // -- Tier and contextType filtering -----------------------------------------\n  //\n  // Applied after candidate collection but before constitutional injection so\n  // Injected constitutional rows are evaluated by the same filters.\n  // Exception: for hybrid search, tier/contextType are applied here because\n  // SearchWithFallback does not accept these parameters directly.\n  // For vector search, tier/contextType were already passed to vectorSearch,\n  // So this is a no-op guard for those fields.\n\n  if (tier) {\n    candidates = candidates.filter((r) => r.importance_tier === tier);\n  }\n\n  if (contextType) {\n    candidates = candidates.filter(\n      (r) => resolveRowContextType(r) === contextType\n    );\n  }\n\n  // P0 fix: sessionId is for dedup/state tracking, NOT a governance boundary.\n  // Including it here caused all candidates to be filtered out when memory_context\n  // passed an ephemeral sessionId, because memories don't have session-scoped access.\n  const hasGovernanceScope = Boolean(\n    tenantId\n    || userId\n    || agentId\n  );\n  const shouldApplyScopeFiltering = hasGovernanceScope;\n  const scopeFilter = {\n    tenantId,\n    userId,\n    agentId,\n  };\n\n  if (shouldApplyScopeFiltering) {\n    try {\n      const db = requireDb();\n      void db;\n      candidates = filterRowsByScope(candidates, scopeFilter);\n    } catch (_error: unknown) {\n      candidates = filterRowsByScope(candidates, scopeFilter);\n    }\n  }\n\n  // -- Constitutional Memory Injection ----------------------------------------\n  //\n  // If includeConstitutional is requested and no constitutional results exist\n  // In the current candidate set, fetch them separately via vector search.\n  // They enter the pipeline here so all subsequent stages (scoring, reranking)\n  // Treat them uniformly. Constitutional tier boost is applied in Stage 2.\n  //\n  // Injection is skipped when:\n  //   - includeConstitutional is false\n  //   - A tier filter is active (caller explicitly requested a specific tier)\n  //   - Constitutional results already exist in the candidate set\n\n  if (includeConstitutional && !tier) {\n    const existingConstitutional = candidates.filter(\n      (r) => r.importance_tier === 'constitutional'\n    );\n\n    if (existingConstitutional.length === 0) {\n      // Reuse cached embedding instead of generating a new one\n      const constitutionalEmbedding: Float32Array | number[] | null =\n        cachedEmbedding ?? queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n      if (constitutionalEmbedding) {\n        const constitutionalResults = vectorIndex.vectorSearch(\n          constitutionalEmbedding,\n          {\n            limit: CONSTITUTIONAL_INJECT_LIMIT,\n            specFolder,\n            tier: 'constitutional',\n            useDecay: false,\n          }\n        ) as PipelineRow[];\n\n        // Only inject rows not already present\n        const existingIds = new Set(candidates.map((r) => r.id));\n        const uniqueConstitutional = constitutionalResults.filter(\n          (r) => !existingIds.has(r.id)\n        );\n\n        // Re-apply filters after injection because constitutional rows fetched\n        // via vector search bypass the earlier governance/context gate.\n        const contextFilteredConstitutional = contextType\n          ? uniqueConstitutional.filter((r) => resolveRowContextType(r) === contextType)\n          : uniqueConstitutional;\n        // Re-apply any explicit governance scope after the injection query.\n        const filteredConstitutional = shouldApplyScopeFiltering\n          ? filterRowsByScope(contextFilteredConstitutional, scopeFilter)\n          : contextFilteredConstitutional;\n        candidates = [...candidates, ...filteredConstitutional];\n        constitutionalInjectedCount = filteredConstitutional.length;\n      }\n    }\n  } else if (!includeConstitutional) {\n    // Explicitly exclude constitutional results if flag is off\n    candidates = candidates.filter(\n      (r) => r.importance_tier !== 'constitutional'\n    );\n  }\n\n  // -- Quality Score Filtering ------------------------------------------------\n\n  candidates = backfillMissingQualityScores(candidates);\n  candidates = filterByMinQualityScore(candidates, qualityThreshold);\n  candidates = boostGraphMetadataCandidates(candidates, query);\n\n  // -- Corpus-Grounded LLM Reformulation ----------------------\n  //\n  // When SPECKIT_LLM_REFORMULATION is enabled and mode === 'deep':\n  //   1. Retrieve top-3 seed results via fast BM25/FTS5 (no embedding call).\n  //   2. Ask the LLM to produce a step-back abstraction + corpus-grounded variants.\n  //   3. Fan-out [original, abstract, ...variants] as additional hybrid search channels.\n  //   4. Deduplicate and merge into candidates.\n  //\n  // Budget: 1 LLM call per cache miss (0 on cache hit).\n  // Fail-open: any error leaves candidates unchanged.\n\n  if (mode === 'deep' && isLlmReformulationEnabled() && searchType === 'hybrid') {\n    try {\n      const seeds = cheapSeedRetrieve(query, { limit: 3 });\n      const reform = await llm.rewrite({ q: query, seeds, mode: 'step_back+corpus' });\n      const allQueries = fanout([query, reform.abstract, ...reform.variants]);\n\n      if (allQueries.length > 1) {\n        const reformEmbedding: Float32Array | number[] | null =\n          cachedEmbedding ?? queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n        if (reformEmbedding) {\n          // FIX #7: Use Promise.allSettled so one failing reformulation\n          // branch does not discard results from all other branches.\n          const reformSettledResults = await Promise.allSettled(\n            allQueries.map(async (q, idx): Promise<PipelineRow[]> => {\n              // Reuse cached embedding for original query (idx 0); generate fresh for variants\n              const emb = idx === 0 ? reformEmbedding : await vectorIndex.generateQueryEmbedding(q);\n              if (!emb) {\n                console.warn('[stage1-candidate-gen] LLM reform embedding generation returned null');\n                return [];\n              }\n              return hybridSearch.collectRawCandidates(\n                q,\n                emb,\n                hybridSearchOptions\n              ) as Promise<PipelineRow[]>;\n            })\n          );\n          const reformResultSets = reformSettledResults.map((result, idx) => {\n            if (result.status === 'fulfilled') return result.value;\n            console.warn(`[stage1-candidate-gen] D2 LLM reform branch ${idx} rejected: ${result.reason}`);\n            return [] as PipelineRow[];\n          });\n\n          if (reformResultSets.length > 0) {\n            const filteredReformSets = reformResultSets.map((resultSet, index) => {\n              let rows = shouldApplyScopeFiltering\n                ? filterRowsByScope(resultSet, scopeFilter)\n                : resultSet;\n              if (contextType) {\n                rows = rows.filter((r) => resolveRowContextType(r) === contextType);\n              }\n              if (tier) {\n                rows = applyTierFilter(rows, tier);\n              }\n              rows = backfillMissingQualityScores(rows);\n              rows = filterByMinQualityScore(rows, qualityThreshold);\n              return {\n                label: allQueries[index] ?? `d2-reform-${index}`,\n                rows,\n              };\n            });\n            const reformMergedCount = filteredReformSets.reduce((sum, batch) => sum + batch.rows.length, 0);\n            candidates = mergeCandidateBatches(filteredReformSets, {\n              seedCandidates: candidates,\n              seedLabel: query,\n            });\n            channelCount += allQueries.length - 1; // discount original (already counted)\n\n            if (trace) {\n              addTraceEntry(trace, 'candidate', allQueries.length - 1, reformMergedCount, 0, {\n                channel: 'd2-llm-reformulation',\n                abstract: reform.abstract,\n                variantCount: reform.variants.length,\n                fanoutCount: allQueries.length,\n              });\n            }\n          }\n        }\n      }\n    } catch (reformErr: unknown) {\n      const reformMsg = reformErr instanceof Error ? reformErr.message : String(reformErr);\n      console.warn(`[stage1-candidate-gen] D2 LLM reformulation failed: ${reformMsg}`);\n    }\n  }\n\n  // -- HyDE Shadow Mode ----------------------------------------\n  //\n  // When SPECKIT_HYDE is enabled and mode === 'deep':\n  //   - Check if the current baseline has low confidence.\n  //   - If so, generate a HyDE pseudo-document and embed it.\n  //   - Run a vector-only search with the pseudo-document embedding.\n  //   - Shadow mode (SPECKIT_HYDE_ACTIVE=false): log results, do NOT merge.\n  //   - Active mode (SPECKIT_HYDE_ACTIVE=true): merge into candidates.\n  //\n  // Budget: 1 LLM call per cache miss (shared cache with reformulation → ≤2 total).\n  // Fail-open: any error leaves candidates unchanged.\n\n  if (mode === 'deep' && isHyDEEnabled() && searchType === 'hybrid') {\n    try {\n      const rawHydeCandidates = await runHyDE(query, candidates, limit, specFolder);\n      const hydeCandidates = shouldApplyScopeFiltering\n        ? filterRowsByScope(rawHydeCandidates, scopeFilter)\n        : rawHydeCandidates;\n      if (hydeCandidates.length > 0) {\n        let newHydeCandidates = hydeCandidates;\n        // Apply the same tier/context/quality filters as main candidates\n        if (contextType) {\n          newHydeCandidates = newHydeCandidates.filter((r) => resolveRowContextType(r) === contextType);\n        }\n        if (tier) {\n          newHydeCandidates = applyTierFilter(newHydeCandidates, tier);\n        }\n        newHydeCandidates = backfillMissingQualityScores(newHydeCandidates);\n        newHydeCandidates = filterByMinQualityScore(newHydeCandidates, qualityThreshold);\n        candidates = mergeCandidateBatches([\n          { label: 'hyde', rows: newHydeCandidates },\n        ], {\n          seedCandidates: candidates,\n          seedLabel: query,\n        });\n        channelCount++;\n\n        if (trace) {\n          addTraceEntry(trace, 'candidate', 1, newHydeCandidates.length, 0, {\n            channel: 'd2-hyde',\n            hydeCandidates: newHydeCandidates.length,\n          });\n        }\n      }\n    } catch (hydeErr: unknown) {\n      const hydeMsg = hydeErr instanceof Error ? hydeErr.message : String(hydeErr);\n      console.warn(`[stage1-candidate-gen] D2 HyDE failed: ${hydeMsg}`);\n    }\n  }\n\n  // Summary Embedding Channel\n  // When SPECKIT_MEMORY_SUMMARIES is enabled (default-ON) and scale gate is\n  // Met (>5000 indexed), run a parallel search on summary embeddings and merge\n  // Results. Pattern follows embedding expansion: run in parallel, merge\n  // + deduplicate by ID.\n  if (isMemorySummariesEnabled()) {\n    try {\n      const db = requireDb();\n      if (checkScaleGate(db)) {\n        const summaryEmbedding: Float32Array | number[] | null =\n          queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n        if (summaryEmbedding) {\n          const summaryResults = querySummaryEmbeddings(db, summaryEmbedding, limit);\n          if (summaryResults.length > 0) {\n            const existingIds = new Set(candidates.map((r) => String(r.id)));\n            const newSummaryHits: PipelineRow[] = [];\n\n            // F02-003: Batch-fetch instead of N+1 per-item queries\n            const newSummaryIds = summaryResults\n              .filter((sr) => !existingIds.has(String(sr.memoryId)))\n              .map((sr) => sr.memoryId);\n\n            if (newSummaryIds.length > 0) {\n              const placeholders = newSummaryIds.map(() => '?').join(', ');\n              const memRows = db.prepare(","lineStart":1,"lineEnd":1321,"totalLines":1322,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781763777811,"end":1781763777821}},"metadata":{"openai":{"itemId":"fc_0d5b12e0056d81cf016a338ec1bf6881919a4e2365cc56a276"}},"id":"prt_ed965a50e001BOPIOq3ized14q","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96570b6001iiEKAma30bzCSA"}}
{"type":"tool_use","timestamp":1781763777875,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_xzuuZkcjkeTIyY9rTpRtqyz8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Search\n3: // ───────────────────────────────────────────────────────────────\n4: /* ───────────────────────────────────────────────────────────────\n5:    1. DEPENDENCIES\n6: ──────────────────────────────────────────────────────────────── */\n7: \n8: import * as toolCache from '../lib/cache/tool-cache.js';\n9: import * as causalEdges from '../lib/storage/causal-edges.js';\n10: import * as sessionManager from '../lib/session/session-manager.js';\n11: import * as intentClassifier from '../lib/search/intent-classifier.js';\n12: // TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\n13: import { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\n14: import { searchCommunities } from '../lib/search/community-search.js';\n15: // 4-stage pipeline architecture\n16: import { executePipeline } from '../lib/search/pipeline/index.js';\n17: import type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\n18: import type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\n19: import { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\n20: import * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n21: // Artifact-class routing (spec/plan/tasks/checklist/memory)\n22: import { getStrategyForQuery } from '../lib/search/artifact-routing.js';\n23: import { routeQuery } from '../lib/search/query-router.js';\n24: import { createEmptyQueryPlan, type QueryPlan } from '../lib/query/query-plan.js';\n25: import { getGraphReadinessSnapshotFromMarker } from '../lib/code-graph-boundary.js';\n26: import { mapGraphReadinessToTelemetry } from '../lib/search/graph-readiness-mapper.js';\n27: import {\n28:   buildSearchDecisionEnvelope,\n29:   type SearchDecisionEnvelope,\n30: } from '../lib/search/search-decision-envelope.js';\n31: import { recordSearchDecision } from '../lib/search/decision-audit.js';\n32: // Chunk reassembly (extracted from this file)\n33: import { collapseAndReassembleChunkResults } from '../lib/search/chunk-reassembly.js';\n34: // Search utilities (extracted from this file)\n35: import {\n36:   filterByMinQualityScore,\n37:   resolveQualityThreshold,\n38:   buildCacheArgs,\n39:   resolveRowContextType,\n40:   resolveArtifactRoutingQuery,\n41:   applyArtifactRouting,\n42: } from '../lib/search/search-utils.js';\n43: // CacheArgsInput used internally by buildCacheArgs (lib/search/search-utils.ts)\n44: // Eval channel tracking (extracted from this file)\n45: import {\n46:   collectEvalChannelsFromRow,\n47:   buildEvalChannelPayloads,\n48:   summarizeGraphWalkDiagnostics,\n49: } from '../lib/telemetry/eval-channel-tracking.js';\n50: import type { EvalChannelPayload } from '../lib/telemetry/eval-channel-tracking.js';\n51: \n52: // Eval logger — fail-safe, no-op when SPECKIT_EVAL_LOGGING !== \"true\"\n53: import { logSearchQuery, logChannelResult, logFinalResult } from '../lib/eval/eval-logger.js';\n54: import {\n55:   logFeedbackEvents,\n56:   isImplicitFeedbackLogEnabled,\n57: } from '../lib/feedback/feedback-ledger.js';\n58: import type { FeedbackEvent } from '../lib/feedback/feedback-ledger.js';\n59: import { trackQueryAndDetect, logResultCited } from '../lib/feedback/query-flow-tracker.js';\n60: \n61: // Core utilities\n62: import { checkDatabaseUpdated } from '../core/index.js';\n63: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n64: import { validateQuery, requireDb, toErrorMessage } from '../utils/index.js';\n65: \n66: // Response envelope + formatters\n67: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n68: import { formatSearchResults } from '../formatters/index.js';\n69: \n70: // Shared handler types\n71: import type { MCPResponse, IntentClassification } from './types.js';\n72: \n73: // Retrieval trace contracts (C136-08)\n74: import { createTrace } from '@spec-kit/shared/contracts/retrieval-trace';\n75: import { buildAdaptiveShadowProposal } from '../lib/cognitive/adaptive-ranking.js';\n76: import { normalizeScopeContext, filterRowsByScope } from '../lib/governance/scope-governance.js';\n77: import {\n78:   attachSessionTransitionTrace,\n79:   type SessionTransitionTrace,\n80: } from '../lib/search/session-transition.js';\n81: \n82: // Mode-Aware Response Shape\n83: import {\n84:   applyProfileToEnvelope,\n85:   isResponseProfileEnabled,\n86: } from '../lib/response/profile-formatters.js';\n87: import {\n88:   buildProgressiveResponse,\n89:   extractSnippets,\n90:   isProgressiveDisclosureEnabled,\n91:   resolveCursor,\n92: } from '../lib/search/progressive-disclosure.js';\n93: import {\n94:   SPEC_DOCUMENT_FILENAMES,\n95:   canClassifyAsSpecDocument,\n96:   normalizeSpecPath,\n97: } from '../lib/config/spec-doc-paths.js';\n98: import {\n99:   getLastLexicalCapabilitySnapshot,\n100:   resetLastLexicalCapabilitySnapshot,\n101: } from '../lib/search/sqlite-fts.js';\n102: import * as vectorIndex from '../lib/search/vector-index.js';\n103: import type { LexicalCapabilitySnapshot } from '../lib/search/sqlite-fts.js';\n104: import { buildVectorDegradationSignal } from '../lib/observability/retrieval-observability.js';\n105: import { evaluatePublicationGate } from '../lib/context/publication-gate.js';\n106: import {\n107:   deduplicateResults as deduplicateWithSessionState,\n108:   isSessionRetrievalStateEnabled,\n109:   manager as retrievalSessionStateManager,\n110:   refineForGoal,\n111: } from '../lib/search/session-state.js';\n112: \n113: // Type imports for casting\n114: import type { IntentType, IntentWeights as IntentClassifierWeights } from '../lib/search/intent-classifier.js';\n115: import type { RawSearchResult } from '../formatters/index.js';\n116: // RoutingResult, WeightedResult — now used internally by lib/search/search-utils.ts\n117: \n118: // Feature catalog: Semantic and lexical search (memory_search)\n119: // Feature catalog: Hybrid search pipeline\n120: // Feature catalog: 4-stage pipeline architecture\n121: // Feature catalog: Quality-aware 3-tier search fallback\n122: \n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    2. TYPES\n126: ──────────────────────────────────────────────────────────────── */\n127: \n128: /**\n129:  * Internal search result row — enriched DB row used within this handler.\n130:  * NOT the same as the canonical SearchResult in shared/types.ts.\n131:  * Self-contained: uses local types instead of the deprecated MemoryRow/MemoryRecord shapes.\n132:  * This can migrate to MemoryDbRow & Record<string, unknown> later without changing the handler contract.\n133:  */\n134: interface MemorySearchRow extends Record<string, unknown> {\n135:   id: number;\n136:   similarity?: number;\n137:   importance_tier?: string;\n138:   contextType?: string;\n139:   context_type?: string;\n140:   attentionScore?: number;\n141:   retrievability?: number;\n142:   stability?: number;\n143:   last_review?: string | null;\n144:   created_at?: string;\n145:   last_accessed?: number;\n146:   content?: string;\n147:   memoryState?: string;\n148:   file_path?: string;\n149:   parent_id?: number | null;\n150:   chunk_index?: number | null;\n151:   chunk_label?: string | null;\n152:   isChunk?: boolean;\n153:   parentId?: number | null;\n154:   chunkIndex?: number | null;\n155:   chunkLabel?: string | null;\n156:   chunkCount?: number | null;\n157:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n158:   precomputedContent?: string;\n159: }\n160: \n161: interface DedupResult {\n162:   results: MemorySearchRow[];\n163:   dedupStats: Record<string, unknown>;\n164: }\n165: \n166: interface FolderBoost {\n167:   folder: string;\n168:   factor: number;\n169: }\n170: \n171: interface SearchCachePayload {\n172:   summary: string;\n173:   data: Record<string, unknown>;\n174:   hints: string[];\n175: }\n176: \n177: type SessionAwareResult = Record<string, unknown> & {\n178:   id: number | string;\n179:   score?: number;\n180:   content?: string;\n181: };\n182: \n183: type CanonicalSourceKind = 'spec_doc' | 'continuity' | 'constitutional';\n184: \n185: interface CanonicalSourceStats {\n186:   retained: number;\n187:   dropped: number;\n188:   bySourceKind: Record<CanonicalSourceKind, number>;\n189: }\n190: \n191: const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n192: const CANONICAL_READER_CACHE_VERSION = 'gate-d-reader-ready-v1';\n193: const CANONICAL_SPEC_DOC_DOCUMENT_TYPES = new Set([\n194:   'spec',\n195:   'plan',\n196:   'tasks',\n197:   'checklist',\n198:   'decision_record',\n199:   'implementation_summary',\n200:   'research',\n201:   'handover',\n202:   'graph_metadata',\n203:   'spec_doc',\n204: ]);\n205: const NON_CANONICAL_DOCUMENT_TYPES = new Set([\n206:   'memory',\n207:   'scratch',\n208: ]);\n209: \n210: function normalizeDocumentType(value: unknown): string | null {\n211:   if (typeof value !== 'string') {\n212:     return null;\n213:   }\n214:   const normalized = value.trim().toLowerCase();\n215:   return normalized.length > 0 ? normalized : null;\n216: }\n217: \n218: function resolveAnchorId(row: Record<string, unknown>): string | null {\n219:   const value = row.anchor_id ?? row.anchorId;\n220:   return typeof value === 'string' && value.trim().length > 0\n221:     ? value.trim()\n222:     : null;\n223: }\n224: \n225: function resolveFilePath(row: Record<string, unknown>): string | null {\n226:   const value = row.file_path ?? row.filePath;\n227:   return typeof value === 'string' && value.trim().length > 0\n228:     ? value\n229:     : null;\n230: }\n231: \n232: function resolveCanonicalSourceKind(row: Record<string, unknown>): CanonicalSourceKind | null {\n233:   const documentType = normalizeDocumentType(row.document_type ?? row.documentType);\n234:   const importanceTier = normalizeDocumentType(row.importance_tier ?? row.importanceTier);\n235:   const anchorId = resolveAnchorId(row);\n236: \n237:   if (importanceTier === 'constitutional' || documentType === 'constitutional') {\n238:     return 'constitutional';\n239:   }\n240: \n241:   if (anchorId === CONTINUITY_ANCHOR_ID || documentType === 'continuity') {\n242:     return 'continuity';\n243:   }\n244: \n245:   if (documentType && CANONICAL_SPEC_DOC_DOCUMENT_TYPES.has(documentType)) {\n246:     return 'spec_doc';\n247:   }\n248: \n249:   if (documentType && NON_CANONICAL_DOCUMENT_TYPES.has(documentType)) {\n250:     return null;\n251:   }\n252: \n253:   const filePath = resolveFilePath(row);\n254:   if (!filePath) {\n255:     return null;\n256:   }\n257:   const normalizedPath = normalizeSpecPath(filePath);\n258:   const basename = normalizedPath.split('/').filter(Boolean).pop() ?? '';\n259: \n260:   if (\n261:     basename.length > 0 &&\n262:     SPEC_DOCUMENT_FILENAMES.has(basename) &&\n263:     canClassifyAsSpecDocument(normalizedPath)\n264:   ) {\n265:     return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n266:   }\n267: \n268:   return null;\n269: }\n270: \n271: function filterCanonicalSourceRows<T extends SessionAwareResult>(\n272:   results: T[],\n273: ): { results: T[]; stats: CanonicalSourceStats } {\n274:   const stats: CanonicalSourceStats = {\n275:     retained: 0,\n276:     dropped: 0,\n277:     bySourceKind: {\n278:       spec_doc: 0,\n279:       continuity: 0,\n280:       constitutional: 0,\n281:     },\n282:   };\n283: \n284:   const filtered: T[] = [];\n285:   for (const result of results) {\n286:     const sourceKind = resolveCanonicalSourceKind(result);\n287:     if (!sourceKind) {\n288:       stats.dropped += 1;\n289:       continue;\n290:     }\n291: \n292:     filtered.push({\n293:       ...result,\n294:       canonicalSource: sourceKind,\n295:       canonicalSourceType: sourceKind,\n296:       documentType: sourceKind,\n297:     });\n298:     stats.retained += 1;\n299:     stats.bySourceKind[sourceKind] += 1;\n300:   }\n301: \n302:   return { results: filtered, stats };\n303: }\n304: \n305: // ChunkReassemblyResult — now imported from lib/search/chunk-reassembly.ts\n306: \n307: type IntentWeights = IntentClassifierWeights;\n308: \n309: function toIntentWeightsConfig(weights: IntentWeights | null): IntentWeightsConfig | null {\n310:   if (!weights) return null;\n311:   return {\n312:     similarity: weights.similarity,\n313:     importance: weights.importance,\n314:     recency: weights.recency,\n315:   };\n316: }\n317: \n318: // EvalChannelPayload — now imported from lib/telemetry/eval-channel-tracking.ts\n319: \n320: interface SearchArgs {\n321:   cursor?: string;\n322:   query?: string;\n323:   concepts?: string[];\n324:   specFolder?: string;\n325:   folderBoost?: FolderBoost;\n326:   tenantId?: string;\n327:   userId?: string;\n328:   agentId?: string;\n329:   limit?: number;\n330:   tier?: string;\n331:   contextType?: string;\n332:   useDecay?: boolean;\n333:   includeContiguity?: boolean;\n334:   includeConstitutional?: boolean;\n335:   includeContent?: boolean;\n336:   anchors?: string[];\n337:   bypassCache?: boolean;\n338:   sessionId?: string;\n339:   enableDedup?: boolean;\n340:   intent?: string;\n341:   autoDetectIntent?: boolean;\n342:   minState?: string;\n343:   applyStateLimits?: boolean;\n344:   rerank?: boolean;\n345:   applyLengthPenalty?: boolean;\n346:   trackAccess?: boolean; // opt-in access tracking (default false)\n347:   includeArchived?: boolean; // Include archived memories in search (default false)\n348:   enableSessionBoost?: boolean;\n349:   enableCausalBoost?: boolean;\n350:   minQualityScore?: number;\n351:   min_quality_score?: number;\n352:   mode?: string; // \"deep\" mode enables query expansion for multi-query RAG\n353:   includeTrace?: boolean;\n354:   sessionTransition?: SessionTransitionTrace;\n355:   /** Presentation profile ('quick'|'research'|'resume'|'debug'). Default: full response. */\n356:   profile?: string;\n357:   /** Dual-level retrieval — 'local' (entity), 'global' (community), 'auto' (local + fallback). */\n358:   retrievalLevel?: 'local' | 'global' | 'auto';\n359: }\n360: \n361: // resolveRowContextType — now imported from lib/search/search-utils.ts\n362: // resolveEvalScore, collectEvalChannelsFromRow — now imported from lib/telemetry/eval-channel-tracking.ts\n363: \n364: function attachTelemetryMeta(\n365:   response: MCPResponse,\n366:   telemetryPayload: Record<string, unknown>,\n367: ): MCPResponse {\n368:   const firstEntry = response?.content?.[0];\n369:   if (!firstEntry || typeof firstEntry.text !== 'string') {\n370:     return response;\n371:   }\n372: \n373:   try {\n374:     const envelope = JSON.parse(firstEntry.text) as Record<string, unknown>;\n375:     const meta = envelope.meta && typeof envelope.meta === 'object'\n376:       ? envelope.meta as Record<string, unknown>\n377:       : {};\n378:     envelope.meta = {\n379:       ...meta,\n380:       _telemetry: telemetryPayload,\n381:     };\n382: \n383:     return {\n384:       ...response,\n385:       content: [{ ...firstEntry, text: JSON.stringify(envelope, null, 2) }],\n386:     };\n387:   } catch (error: unknown) {\n388:     const message = toErrorMessage(error);\n389:     console.warn('[memory-search] Failed to attach telemetry payload:', message);\n390:     return response;\n391:   }\n392: }\n393: \n394: function extractResponseResults(response: MCPResponse): Array<Record<string, unknown>> {\n395:   const firstEntry = response?.content?.[0];\n396:   if (!firstEntry || typeof firstEntry.text !== 'string') {\n397:     return [];\n398:   }\n399: \n400:   try {\n401:     const envelope = JSON.parse(firstEntry.text) as Record<string, unknown>;\n402:     const data = envelope.data && typeof envelope.data === 'object'\n403:       ? envelope.data as Record<string, unknown>\n404:       : null;\n405:     return Array.isArray(data?.results)\n406:       ? data.results as Array<Record<string, unknown>>\n407:       : [];\n408:   } catch {\n409:     return [];\n410:   }\n411: }\n412: \n413: function extractSearchCachePayload(response: MCPResponse): SearchCachePayload | null {\n414:   const firstEntry = response?.content?.[0];\n415:   if (!firstEntry || typeof firstEntry.text !== 'string') {\n416:     return null;\n417:   }\n418: \n419:   try {\n420:     const envelope = JSON.parse(firstEntry.text) as Record<string, unknown>;\n421:     const summary = typeof envelope.summary === 'string' ? envelope.summary : null;\n422:     const data = envelope.data && typeof envelope.data === 'object'\n423:       ? envelope.data as Record<string, unknown>\n424:       : null;\n425:     const hints = Array.isArray(envelope.hints)\n426:       ? envelope.hints.filter((hint): hint is string => typeof hint === 'string')\n427:       : [];\n428: \n429:     if (!summary || !data) {\n430:       return null;\n431:     }\n432: \n433:     return { summary, data, hints };\n434:   } catch {\n435:     return null;\n436:   }\n437: }\n438: \n439: function parseResponseEnvelope(\n440:   response: MCPResponse,\n441: ): { firstEntry: { type: 'text'; text: string }; envelope: Record<string, unknown> } | null {\n442:   const firstEntry = response?.content?.[0];\n443:   if (!firstEntry || firstEntry.type !== 'text' || typeof firstEntry.text !== 'string') {\n444:     return null;\n445:   }\n446: \n447:   try {\n448:     return {\n449:       firstEntry,\n450:       envelope: JSON.parse(firstEntry.text) as Record<string, unknown>,\n451:     };\n452:   } catch {\n453:     return null;\n454:   }\n455: }\n456: \n457: function replaceResponseEnvelope(\n458:   response: MCPResponse,\n459:   firstEntry: { type: 'text'; text: string },\n460:   envelope: Record<string, unknown>,\n461: ): MCPResponse {\n462:   return {\n463:     ...response,\n464:     content: [{ ...firstEntry, text: JSON.stringify(envelope, null, 2) }],\n465:   };\n466: }\n467: \n468: function buildSessionStatePayload(sessionId: string): Record<string, unknown> {\n469:   const session = retrievalSessionStateManager.getOrCreate(sessionId);\n470:   return {\n471:     activeGoal: session.activeGoal,\n472:     seenResultIds: Array.from(session.seenResultIds),\n473:     openQuestions: [...session.openQuestions],\n474:     preferredAnchors: [...session.preferredAnchors],\n475:   };\n476: }\n477: \n478: function buildSearchResponseFromPayload(\n479:   payload: SearchCachePayload,\n480:   startTime: number,\n481:   cacheHit: boolean,\n482: ): MCPResponse {\n483:   return createMCPSuccessResponse({\n484:     tool: 'memory_search',\n485:     summary: payload.summary,\n486:     data: payload.data,\n487:     hints: payload.hints,\n488:     startTime,\n489:     cacheHit,\n490:   });\n491: }\n492: \n493: function resolveSearchScore(result: Record<string, unknown>): number | null {\n494:   const candidate = result.score ?? result.similarity ?? result.averageSimilarity ?? result.intentAdjustedScore;\n495:   if (typeof candidate !== 'number' || !Number.isFinite(candidate)) {\n496:     return null;\n497:   }\n498:   return candidate > 1 ? candidate / 100 : candidate;\n499: }\n500: \n501: function computeAverageScore(results: Array<Record<string, unknown>>): number {\n502:   const scores = results\n503:     .map(resolveSearchScore)\n504:     .filter((score): score is number => score !== null);\n505:   if (scores.length === 0) return 0;\n506:   return scores.reduce((sum, score) => sum + score, 0) / scores.length;\n507: }\n508: \n509: function attachLexicalCapabilityMetadata(\n510:   response: MCPResponse,\n511:   snapshot: LexicalCapabilitySnapshot | null,\n512: ): MCPResponse {\n513:   const parsed = parseResponseEnvelope(response);\n514:   if (!parsed) {\n515:     return response;\n516:   }\n517: \n518:   const data = parsed.envelope.data && typeof parsed.envelope.data === 'object'\n519:     ? parsed.envelope.data as Record<string, unknown>\n520:     : {};\n521: \n522:   if (typeof data.lexicalPath !== 'string' && snapshot) {\n523:     data.lexicalPath = snapshot.lexicalPath;\n524:   }\n525:   if (typeof data.fallbackState !== 'string' && snapshot) {\n526:     data.fallbackState = snapshot.fallbackState;\n527:   }\n528: \n529:   parsed.envelope.data = data;\n530:   return replaceResponseEnvelope(response, parsed.firstEntry, parsed.envelope);\n531: }\n532: \n533: function hasPublicationContractFields(result: Record<string, unknown>): boolean {\n534:   return [\n535:     'certainty',\n536:     'methodologyStatus',\n537:     'schemaVersion',\n538:     'provenance',\n539:     'multiplierAuthorityFields',\n540:   ].some((field) => Object.prototype.hasOwnProperty.call(result, field));\n541: }\n542: \n543: function normalizePublicationProvenanceEntry(value: unknown): string | null {\n544:   if (typeof value !== 'string') {\n545:     return null;\n546:   }\n547:   const normalized = value.trim();\n548:   return normalized.length > 0 ? normalized : null;\n549: }\n550: \n551: function resolvePublicationProvenance(result: Record<string, unknown>): string[] {\n552:   const explicit = Array.isArray(result.provenance)\n553:     ? result.provenance\n554:         .map(normalizePublicationProvenanceEntry)\n555:         .filter((entry): entry is string => entry !== null)\n556:     : [];\n557:   if (explicit.length > 0) {\n558:     return [...new Set(explicit)];\n559:   }\n560: \n561:   return [...new Set([\n562:     result.provenance_source,\n563:     result.provenanceSource,\n564:     result.source_kind,\n565:     result.sourceKind,\n566:   ].map(normalizePublicationProvenanceEntry).filter((entry): entry is string => entry !== null))];\n567: }\n568: \n569: function applyPublicationGateToResponse(response: MCPResponse): MCPResponse {\n570:   const parsed = parseResponseEnvelope(response);\n571:   if (!parsed) {\n572:     return response;\n573:   }\n574: \n575:   const data = parsed.envelope.data && typeof parsed.envelope.data === 'object'\n576:     ? parsed.envelope.data as Record<string, unknown>\n577:     : null;\n578:   const results = Array.isArray(data?.results)\n579:     ? data.results as Array<Record<string, unknown>>\n580:     : null;\n581: \n582:   if (!data || !results) {\n583:     return response;\n584:   }\n585: \n586:   data.results = results.map((result) => {\n587:     if (!hasPublicationContractFields(result)) {\n588:       return result;\n589:     }\n590: \n591:     const provenance = resolvePublicationProvenance(result);\n592:     const resultWithProvenance = provenance.length > 0\n593:       ? { ...result, provenance }\n594:       : result;\n595:     const gateResult = evaluatePublicationGate({\n596:       certainty: result.certainty,\n597:       methodologyStatus: result.methodologyStatus as 'provisional' | 'published' | null | undefined,\n598:       schemaVersion: result.schemaVersion as string | null | undefined,\n599:       provenance,\n600:       multiplierAuthorityFields: result.multiplierAuthorityFields as Record<string, unknown> | null | undefined,\n601:     });\n602: \n603:     return gateResult.publishable\n604:       ? {\n605:         ...resultWithProvenance,\n606:         publishable: true,\n607:       }\n608:       : {\n609:         ...resultWithProvenance,\n610:         publishable: false,\n611:         exclusionReason: gateResult.exclusionReason,\n612:       };\n613:   });\n614: \n615:   parsed.envelope.data = data;\n616:   return replaceResponseEnvelope(response, parsed.firstEntry, parsed.envelope);\n617: }\n618: \n619: // summarizeGraphWalkDiagnostics, buildEvalChannelPayloads — now imported from lib/telemetry/eval-channel-tracking.ts\n620: \n621: // filterByMinQualityScore, resolveQualityThreshold, buildCacheArgs,\n622: // resolveArtifactRoutingQuery, applyArtifactRouting — now imported from lib/search/search-utils.ts\n623: // CacheArgsInput — now imported from lib/search/search-utils.ts\n624: // parseNullableInt, collapseAndReassembleChunkResults — now imported from lib/search/chunk-reassembly.ts\n625: \n626: /* ───────────────────────────────────────────────────────────────\n627:    3. CONFIGURATION\n628: ──────────────────────────────────────────────────────────────── */\n629: \n630: // Sections 3–5 (STATE_PRIORITY, MAX_DEEP_QUERY_VARIANTS, buildDeepQueryVariants,\n631: // StrengthenOnAccess, applyTestingEffect, filterByMemoryState) removed in\n632: // These were only used by the legacy V1 pipeline.\n633: // The V2 4-stage pipeline handles state filtering (Stage 4), testing effect, and\n634: // Query expansion through its own stages.\n635: \n636: /* ───────────────────────────────────────────────────────────────\n637:    6. SESSION DEDUPLICATION UTILITIES\n638: ──────────────────────────────────────────────────────────────── */\n639: \n640: function stampFinalRankScores(results: Array<Record<string, unknown>>): void {\n641:   const total = results.length;\n642:   results.forEach((result, index) => {\n643:     result.finalRankScore = calculateFinalRankScore(total, index);\n644:   });\n645: }\n646: \n647: function calculateFinalRankScore(total: number, index: number): number | null {\n648:   return total > 0 ? (total - index) / total : null;\n649: }\n650: \n651: function applyFolderBoostRanking(results: SessionAwareResult[], folderBoost: FolderBoost | undefined): boolean {\n652:   if (!folderBoost || !folderBoost.folder || folderBoost.factor <= 1) {\n653:     return false;\n654:   }\n655: \n656:   let boostedCount = 0;\n657:   for (const r of results) {\n658:     const raw = r as Record<string, unknown>;\n659:     const filePath = raw.file_path as string | undefined;\n660:     if (filePath && filePath.includes(folderBoost.folder)) {\n661:       if (typeof raw.similarity === 'number') {\n662:         raw.similarity = Math.min(raw.similarity * folderBoost.factor, 1.0);\n663:         boostedCount++;\n664:       }\n665:     }\n666:   }\n667: \n668:   if (boostedCount === 0) {\n669:     return false;\n670:   }\n671: \n672:   results.sort((a, b) => {\n673:     const sa = ((a as Record<string, unknown>).similarity as number | undefined) ?? 0;\n674:     const sb = ((b as Record<string, unknown>).similarity as number | undefined) ?? 0;\n675:     return sb - sa;\n676:   });\n677:   return true;\n678: }\n679: \n680: function isPlainRecord(value: unknown): value is Record<string, unknown> {\n681:   return typeof value === 'object' && value !== null && !Array.isArray(value);\n682: }\n683: \n684: function documentKey(document: unknown): string | null {\n685:   if (!isPlainRecord(document) || typeof document.path !== 'string') {\n686:     return null;\n687:   }\n688:   const anchor = typeof document.anchor === 'string' ? document.anchor : '';\n689:   return `${document.path}\\u0000${anchor}`;\n690: }\n691: \n692: function resultDocumentKey(result: Record<string, unknown>): string | null {\n693:   const whyRanked = isPlainRecord(result.why_ranked) ? result.why_ranked : null;\n694:   const fromWhyRanked = whyRanked ? documentKey(whyRanked.document) : null;\n695:   if (fromWhyRanked !== null) {\n696:     return fromWhyRanked;\n697:   }\n698: \n699:   const filePath = result.filePath ?? result.file_path;\n700:   return typeof filePath === 'string' ? `${filePath}\\u0000` : null;\n701: }\n702: \n703: function warningStillApplies(warning: unknown, returnedDocumentKeys: Set<string>): boolean {\n704:   if (!isPlainRecord(warning) || !Array.isArray(warning.documents)) {\n705:     return true;\n706:   }\n707:   const keys = warning.documents.map(documentKey);\n708:   if (keys.length !== 2 || keys.some((key) => key === null)) {\n709:     return true;\n710:   }\n711:   return keys.every((key) => returnedDocumentKeys.has(key as string));\n712: }\n713: \n714: function reconcilePostFormatResultSet(data: Record<string, unknown>, results: Array<Record<string, unknown>>): void {\n715:   const total = results.length;\n716:   results.forEach((result, index) => {\n717:     if (isPlainRecord(result.why_ranked)) {\n718:       result.why_ranked.rank = index + 1;\n719:       if (result.why_ranked.scoreSource === 'finalRank') {\n720:         result.why_ranked.effectiveScore = calculateFinalRankScore(total, index);\n721:       }\n722:     }\n723:   });\n724: \n725:   data.results = results;\n726:   data.count = results.length;\n727: \n728:   const returnedDocumentKeys = new Set(\n729:     results\n730:       .map(resultDocumentKey)\n731:       .filter((key): key is string => key !== null),\n732:   );\n733: \n734:   for (const key of ['inlineWarnings', 'retrievalWarnings']) {\n735:     const warnings = data[key];\n736:     if (!Array.isArray(warnings)) {\n737:       continue;\n738:     }\n739:     const retained = warnings.filter((warning) => warningStillApplies(warning, returnedDocumentKeys));\n740:     if (retained.length > 0) {\n741:       data[key] = retained;\n742:     } else {\n743:       delete data[key];\n744:     }\n745:   }\n746: }\n747: \n748: function applySessionDedup(results: MemorySearchRow[], sessionId: string, enableDedup: boolean): DedupResult {\n749:   if (!enableDedup || !sessionId || !sessionManager.isEnabled()) {\n750:     return {\n751:       results,\n752:       dedupStats: { enabled: false, sessionId: null }\n753:     };\n754:   }\n755: \n756:   const { filtered, dedupStats } = sessionManager.filterSearchResults(sessionId, results as Parameters<typeof sessionManager.filterSearchResults>[1]);\n757: \n758:   if (filtered.length > 0) {\n759:     sessionManager.markResultsSent(sessionId, filtered as Parameters<typeof sessionManager.markResultsSent>[1]);\n760:   }\n761: \n762:   return {\n763:     results: filtered as MemorySearchRow[],\n764:     dedupStats: {\n765:       ...dedupStats,\n766:       sessionId\n767:     }\n768:   };\n769: }\n770: \n771: // Sections 7–9 (applyCrossEncoderReranking, applyIntentWeightsToResults,\n772: // ShouldApplyPostSearchIntentWeighting, postSearchPipeline) removed in\n773: // These were only used by the legacy V1 pipeline\n774: // Path. The V2 4-stage pipeline handles all equivalent functionality.\n775: \n776: /* ───────────────────────────────────────────────────────────────\n777:    10. MAIN HANDLER\n778: ──────────────────────────────────────────────────────────────── */\n779: \n780: /** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n781:  * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n782:  * @returns MCP response with ranked search results\n783:  */\n784: async function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n785:   await ensureMemoryRuntimeInitialized('handler:memory_search');\n786:   const _searchStartTime = Date.now();\n787:   resetLastLexicalCapabilitySnapshot();\n788:   // Check for external database updates before processing\n789:   await checkDatabaseUpdated();\n790: \n791:   const {\n792:     cursor,\n793:     query,\n794:     concepts,\n795:     specFolder,\n796:     folderBoost,\n797:     tenantId,\n798:     userId,\n799:     agentId,\n800:     limit: rawLimit = 10,\n801:     tier,\n802:     contextType,\n803:     useDecay: useDecay = true,\n804:     includeContiguity: includeContiguity = false,\n805:     includeConstitutional: includeConstitutional = true,\n806:     includeContent: includeContent = false,\n807:     anchors,\n808:     bypassCache: bypassCache = false,\n809:     sessionId: rawSessionId,\n810:     enableDedup: enableDedup = true,\n811:     intent: explicitIntent,\n812:     autoDetectIntent: autoDetectIntent = true,\n813:     minState,  // No default — memoryState column not yet in schema; defaulting to 'WARM' filters all rows\n814:     applyStateLimits: applyStateLimits = false,\n815:     rerank = true, // Enable reranking by default for better result quality\n816:     applyLengthPenalty: applyLengthPenalty = true,\n817:     trackAccess: trackAccess = false, // opt-in, off by default\n818:     includeArchived: includeArchivedRequested = false, // compatibility-only after Gate B cleanup\n819:     enableSessionBoost: enableSessionBoost = isSessionBoostEnabled(),\n820:     enableCausalBoost: enableCausalBoost = isCausalBoostEnabled(),\n821:     minQualityScore,\n822:     min_quality_score,\n823:     mode,\n824:     includeTrace: includeTraceArg = false,\n825:     sessionTransition,\n826:     profile,\n827:     retrievalLevel: retrievalLevel = 'auto',\n828:   } = args;\n829:   const includeTraceByFlag = process.env.SPECKIT_RESPONSE_TRACE === 'true';\n830:   const includeTrace = includeTraceByFlag || includeTraceArg === true;\n831:   const includeArchived = false;\n832: \n833:   // Validate any caller-supplied sessionId through the server-side session\n834:   // manager to prevent IDOR: a caller must not read or mutate another\n835:   // session's sent-memory dedup state by forging an arbitrary session id.\n836:   // Omitting sessionId stays unchanged (downstream treats it as no-session).\n837:   let sessionId: string | undefined = rawSessionId;\n838:   if (rawSessionId) {\n839:     const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n840:       tenantId,\n841:       userId,\n842:       agentId,\n843:     });\n844:     if (trustedSession.error) {\n845:       return createMCPErrorResponse({\n846:         tool: 'memory_search',\n847:         error: trustedSession.error,\n848:         code: 'E_SESSION_SCOPE',\n849:         details: { requestedSessionId: rawSessionId },\n850:         recovery: {\n851:           hint: 'Omit sessionId to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n852:         },\n853:       });\n854:     }\n855:     sessionId = trustedSession.effectiveSessionId;\n856:   }\n857: \n858:   const normalizedScope = normalizeScopeContext({ tenantId, userId, agentId, sessionId });\n859:   const progressiveScopeKey = JSON.stringify({\n860:     tenantId: normalizedScope.tenantId ?? null,\n861:     userId: normalizedScope.userId ?? null,\n862:     agentId: normalizedScope.agentId ?? null,\n863:     sessionId: normalizedScope.sessionId ?? null,\n864:   });\n865: \n866:   // Validate at least one search input is provided (moved from schema superRefine for GPT compatibility)\n867:   const hasCursor = typeof cursor === 'string' && cursor.trim().length > 0;\n868:   const hasQuery = typeof query === 'string' && query.trim().length > 0;\n869:   const hasConcepts = Array.isArray(concepts) && concepts.length >= 2;\n870:   if (!hasCursor && !hasQuery && !hasConcepts) {\n871:     return { content: [{ type: 'text', text: JSON.stringify({ error: 'Either \"query\" (string), \"concepts\" (array with 2-5 items), or \"cursor\" (string) is required.' }) }] };\n872:   }\n873: \n874:   if (hasCursor) {\n875:     const resolved = resolveCursor(cursor.trim(), undefined, { scopeKey: progressiveScopeKey });\n876:     if (!resolved) {\n877:       return createMCPErrorResponse({\n878:         tool: 'memory_search',\n879:         error: 'Cursor is invalid, expired, or out of scope',\n880:         code: 'E_VALIDATION',\n881:         details: { parameter: 'cursor' },\n882:         recovery: {\n883:           hint: 'Retry the original search to generate a fresh continuation cursor',\n884:         },\n885:       });\n886:     }\n887: \n888:     const snippetResults = extractSnippets(resolved.results);\n889:     return createMCPSuccessResponse({\n890:       tool: 'memory_search',\n891:       summary: `Returned ${snippetResults.length} continuation results`,\n892:       data: {\n893:         count: snippetResults.length,\n894:         results: snippetResults,\n895:         continuation: resolved.continuation,\n896:       },\n897:       startTime: _searchStartTime,\n898:       cacheHit: false,\n899:     });\n900:   }\n901: \n902:   const qualityThreshold = resolveQualityThreshold(minQualityScore, min_quality_score);\n903: \n904:   // Validate numeric limit parameter\n905:   const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n906:     ? Math.min(Math.floor(rawLimit), 100)\n907:     : 10;\n908: \n909:   // Validate query first with proper error handling\n910:   let normalizedQuery: string | null = null;\n911:   if (query !== undefined) {\n912:     try {\n913:       normalizedQuery = validateQuery(query);\n914:     } catch (validationError: unknown) {\n915:       if (!concepts || !Array.isArray(concepts) || concepts.length < 2) {\n916:         const message = toErrorMessage(validationError);\n917:         return createMCPErrorResponse({\n918:           tool: 'memory_search',\n919:           error: message,\n920:           code: 'E_VALIDATION',\n921:           details: { parameter: 'query' },\n922:           recovery: {\n923:             hint: 'Provide a valid query string or use concepts array instead'\n924:           }\n925:         });\n926:       }\n927:       normalizedQuery = null;\n928:     }\n929:   }\n930: \n931:   const hasValidQuery = normalizedQuery !== null;\n932:   const hasValidConcepts = Array.isArray(concepts) && concepts.length >= 2;\n933:   const effectiveQuery = normalizedQuery ?? (hasValidConcepts ? concepts.join(', ') : '');\n934:   const searchDecisionRequestId = `memory_search-${_searchStartTime}`;\n935:   let searchDecisionEnvelope: SearchDecisionEnvelope | null = null;\n936: \n937:   if (!hasValidQuery && !hasValidConcepts) {\n938:     return createMCPErrorResponse({\n939:       tool: 'memory_search',\n940:       error: 'Either query (string), concepts (array of 2-5 strings), or cursor (string) is required',\n941:       code: 'E_VALIDATION',\n942:       details: { parameter: 'query' },\n943:       recovery: {\n944:         hint: 'Provide a query string, concepts array with 2-5 entries, or a continuation cursor'\n945:       }\n946:     });\n947:   }\n948: \n949:   if (specFolder !== undefined && typeof specFolder !== 'string') {\n950:     return createMCPErrorResponse({\n951:       tool: 'memory_search',\n952:       error: 'specFolder must be a string',\n953:       code: 'E_VALIDATION',\n954:       details: { parameter: 'specFolder' },\n955:       recovery: {\n956:         hint: 'Provide specFolder as a string path'\n957:       }\n958:     });\n959:   }\n960: \n961:   // Eval logger — capture query at pipeline entry (fail-safe)\n962:   let _evalQueryId = 0;\n963:   let _evalRunId = 0;\n964:   try {\n965:     const evalEntry = logSearchQuery({\n966:       query: effectiveQuery,\n967:       intent: explicitIntent ?? null,\n968:       specFolder: specFolder ?? null,\n969:     });\n970:     _evalQueryId = evalEntry.queryId;\n971:     _evalRunId = evalEntry.evalRunId;\n972:   } catch (_error: unknown) { /* eval logging must never break search */ }\n973: \n974:   const artifactRoutingQuery = resolveArtifactRoutingQuery(\n975:     normalizedQuery,\n976:     hasValidConcepts ? concepts : undefined\n977:   );\n978:   let artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder);\n979:   let queryPlan: QueryPlan;\n980:   try {\n981:     queryPlan = routeQuery(effectiveQuery).queryPlan;\n982:   } catch (_error: unknown) {\n983:     queryPlan = createEmptyQueryPlan({\n984:       complexity: 'unknown',\n985:       selectedChannels: ['vector', 'fts', 'bm25', 'graph', 'degree'],\n986:       fallbackPolicy: {\n987:         mode: 'telemetry_only',\n988:         reason: 'QueryPlan telemetry fallback after routeQuery failure',\n989:       },\n990:     });\n991:   }\n992: \n993:   // Intent-aware retrieval\n994:   let detectedIntent: string | null = null;\n995:   let intentConfidence = 0;\n996:   let intentWeights: IntentWeights | null = null;\n997: \n998:   if (explicitIntent) {\n999:     if (intentClassifier.isValidIntent(explicitIntent)) {\n1000:       detectedIntent = explicitIntent;\n1001:       intentConfidence = 1.0;\n1002:       intentWeights = intentClassifier.getIntentWeights(explicitIntent);\n1003:     } else {\n1004:       console.warn(`[memory-search] Invalid intent '${explicitIntent}', using auto-detection`);\n1005:     }\n1006:   }\n1007: \n1008:   if (!detectedIntent && autoDetectIntent && hasValidQuery) {\n1009:     const classification: IntentClassification = intentClassifier.classifyIntent(normalizedQuery!);\n1010:     detectedIntent = classification.intent;\n1011:     intentConfidence = classification.confidence;\n1012:     intentWeights = intentClassifier.getIntentWeights(classification.intent as IntentType);\n1013: \n1014:     if (classification.fallback) {\n1015:       console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (fallback: ${classification.reason})`);\n1016:     } else {\n1017:       console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (confidence: ${intentConfidence.toFixed(2)})`);\n1018:     }\n1019:   }\n1020: \n1021:   // FIX RC3-B: Intent confidence floor — override low-confidence auto-detections to \"understand\"\n1022:   const INTENT_CONFIDENCE_FLOOR = parseFloat(process.env.SPECKIT_INTENT_CONFIDENCE_FLOOR || '0.25');\n1023:   if (detectedIntent && intentConfidence < INTENT_CONFIDENCE_FLOOR && !explicitIntent) {\n1024:     console.error(`[memory-search] Intent confidence ${intentConfidence.toFixed(3)} below floor ${INTENT_CONFIDENCE_FLOOR}, overriding '${detectedIntent}' → 'understand'`);\n1025:     detectedIntent = 'understand';\n1026:     intentConfidence = 1.0;\n1027:     intentWeights = intentClassifier.getIntentWeights('understand' as IntentType);\n1028:   }\n1029: \n1030:   // Phase C: Intent-to-profile auto-routing.\n1031:   // Explicit caller `profile` always takes precedence; auto-detect fills in when absent.\n1032:   let effectiveProfile: string | undefined = profile;\n1033:   if (!effectiveProfile && detectedIntent && isIntentAutoProfileEnabled()) {\n1034:     try {\n1035:       const autoProfile = intentClassifier.getProfileForIntent(detectedIntent as IntentType);\n1036:       if (autoProfile) {\n1037:         effectiveProfile = autoProfile;\n1038:         console.error(`[memory-search] Intent-to-profile auto-routing: '${detectedIntent}' → profile '${autoProfile}'`);\n1039:       }\n1040:     } catch (_autoProfileErr: unknown) {\n1041:       // Auto-profile is best-effort — never breaks search\n1042:     }\n1043:   }\n1044:   const adaptiveFusionIntent = effectiveProfile === 'resume'\n1045:     ? 'continuity'\n1046:     : detectedIntent;\n1047: \n1048:   // Re-run artifact routing with detected intent for fallback coverage\n1049:   if (detectedIntent && artifactRouting?.detectedClass === 'unknown' && artifactRouting?.confidence === 0) {\n1050:     artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder, detectedIntent);\n1051:   }\n1052: \n1053:   // Create retrieval trace at pipeline entry\n1054:   const trace = createTrace(\n1055:     effectiveQuery,\n1056:     sessionId,\n1057:     detectedIntent || undefined\n1058:   );\n1059: \n1060:   // When causal boost is enabled, fold the causal-edges generation\n1061:   // counter into the cache key so causal-edge mutations naturally invalidate\n1062:   // the affected memory_search entries on the next lookup. We deliberately\n1063:   // keep the generation OFF the key when the caller has not opted into causal\n1064:   // boost — otherwise unrelated callers would suffer needless cache misses.\n1065:   const causalEdgesGenerationForCache = enableCausalBoost\n1066:     ? causalEdges.getCausalEdgesGeneration()\n1067:     : undefined;\n1068: \n1069:   // Build cache key args\n1070:   const cacheArgs = buildCacheArgs({\n1071:     normalizedQuery,\n1072:     hasValidConcepts,\n1073:     concepts,\n1074:     specFolder,\n1075:     tenantId: normalizedScope.tenantId,\n1076:     userId: normalizedScope.userId,\n1077:     agentId: normalizedScope.agentId,\n1078:     limit,\n1079:     mode,\n1080:     tier,\n1081:     contextType,\n1082:     useDecay,\n1083:     includeArchived,\n1084:     qualityThreshold,\n1085:     applyStateLimits,\n1086:     includeContiguity,\n1087:     includeConstitutional,\n1088:     includeContent,\n1089:     anchors,\n1090:     detectedIntent,\n1091:     adaptiveFusionIntent,\n1092:     minState: minState ?? '',\n1093:     rerank,\n1094:     applyLengthPenalty,\n1095:     sessionId,\n1096:     enableSessionBoost,\n1097:     enableCausalBoost,\n1098:     includeTrace,\n1099:     cacheVersion: CANONICAL_READER_CACHE_VERSION,\n1100:     causalEdgesGeneration: causalEdgesGenerationForCache,\n1101:   });\n1102: \n1103:   let _evalChannelPayloads: EvalChannelPayload[] = [];\n1104:   const cacheKey = toolCache.generateCacheKey('memory_search', cacheArgs);\n1105:   const cacheEnabled = toolCache.isEnabled() && !bypassCache;\n1106:   const cachedPayload = cacheEnabled\n1107:     ? toolCache.get<SearchCachePayload>(cacheKey)\n1108:     : null;\n1109: \n1110:   let responseToReturn: MCPResponse;\n1111:   let goalRefinementPayload: Record<string, unknown> | null = null;\n1112: \n1113:   if (cachedPayload) {\n1114:     responseToReturn = buildSearchResponseFromPayload(cachedPayload, _searchStartTime, true);\n1115:   } else {\n1116:     // V2 pipeline is the only path (legacy V1 removed from the runtime pipeline)\n1117:     const pipelineConfig: PipelineConfig = {\n1118:       query: effectiveQuery,\n1119:       concepts: hasValidConcepts ? concepts : undefined,\n1120:       searchType: (hasValidConcepts && concepts!.length >= 2)\n1121:         ? 'multi-concept'\n1122:         : 'hybrid',\n1123:       mode,\n1124:       limit,\n1125:       specFolder,\n1126:       tenantId: normalizedScope.tenantId,\n1127:       userId: normalizedScope.userId,\n1128:       agentId: normalizedScope.agentId,\n1129:       tier,\n1130:       contextType,\n1131:       includeArchived,\n1132:       includeConstitutional,\n1133:       includeContent,\n1134:       anchors,\n1135:       qualityThreshold,\n1136:       minState: minState ?? '',\n1137:       applyStateLimits,\n1138:       useDecay,\n1139:       rerank,\n1140:       applyLengthPenalty,\n1141:       sessionId,\n1142:       enableDedup,\n1143:       enableSessionBoost,\n1144:       enableCausalBoost,\n1145:       trackAccess,\n1146:       detectedIntent,\n1147:       adaptiveFusionIntent,\n1148:       intentConfidence,\n1149:       intentWeights: toIntentWeightsConfig(intentWeights),\n1150:       artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n1151:       queryPlan,\n1152:       trace,\n1153:     };\n1154: \n1155:     const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n1156:     let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n1157: \n1158:     // Community search fallback — inject community members on weak results\n1159:     let communityFallbackApplied = false;\n1160:     const shouldRunCommunitySearch = (\n1161:       isDualRetrievalEnabled() &&\n1162:       isCommunitySearchFallbackEnabled() &&\n1163:       effectiveQuery.length > 0 &&\n1164:       (retrievalLevel === 'global' || retrievalLevel === 'auto')\n1165:     );\n1166:     if (shouldRunCommunitySearch) {\n1167:       const isWeakResult = resultsForFormatting.length === 0 ||\n1168:         (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n1169:       if (isWeakResult) {\n1170:         try {\n1171:           const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n1172:           if (communityResults.totalMemberIds.length > 0) {\n1173:             // Fetch the actual memory rows for community member IDs\n1174:             const memberIds = communityResults.totalMemberIds.slice(0, 20);\n1175:             const placeholders = memberIds.map(() => '?').join(', ');\n1176:             const db = requireDb();\n1177:             const rawMemberRows = db.prepare(`\n1178:               SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n1179:                      importance_tier, context_type, quality_score, created_at,\n1180:                      tenant_id, user_id, agent_id\n1181:               FROM memory_index\n1182:               WHERE id IN (${placeholders})\n1183:             `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n1184: \n1185:             // Apply governed retrieval scope to the community fallback so it cannot\n1186:             // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n1187:             // sessionId is deliberately excluded — it is a dedup/continuity key, not\n1188:             // a row-access boundary. Unscoped (single-user) callers are unaffected.\n1189:             const hasGovernanceScope = Boolean(\n1190:               normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n1191:             );\n1192:             const memberRows = hasGovernanceScope\n1193:               ? filterRowsByScope(rawMemberRows, {\n1194:                   tenantId: normalizedScope.tenantId,\n1195:                   userId: normalizedScope.userId,\n1196:                   agentId: normalizedScope.agentId,\n1197:                 })\n1198:               : rawMemberRows;\n1199: \n1200:             if (memberRows.length > 0) {\n1201:               // Calibrate score from community match quality, bounded below pipeline threshold\n1202:               const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n1203:               const avgMatchScore = communityResults.results.length > 0\n1204:                 ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n1205:                 : 0.5;\n1206:               const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n1207:               // Mark community-sourced results and assign calibrated score\n1208:               const communityRows = memberRows.map((row) => ({\n1209:                 ...row,\n1210:                 similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n1211:                 score: calibratedScore,\n1212:                 _communityFallback: true,\n1213:               }));\n1214:               // Merge: append community results not already in pipeline results\n1215:               const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n1216:               const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n1217:               if (newRows.length > 0) {\n1218:                 resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n1219:                 communityFallbackApplied = true;\n1220:               }\n1221:             }\n1222:           }\n1223:         } catch (err: unknown) {\n1224:           const msg = err instanceof Error ? err.message : String(err);\n1225:           console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n1226:         }\n1227:       }\n1228:     }\n1229: \n1230:     const folderBoostRankingApplied = applyFolderBoostRanking(resultsForFormatting, folderBoost);\n1231: \n1232:     // Eval channel attribution should reflect the retrieval pipeline output\n1233:     // before canonical source filtering drops rows for response formatting.\n1234:     _evalChannelPayloads = buildEvalChannelPayloads(\n1235:       pipelineResult.results as unknown as Array<Record<string, unknown>>,\n1236:     );\n1237: \n1238:     const canonicalFilter = filterCanonicalSourceRows(resultsForFormatting);\n1239:     resultsForFormatting = canonicalFilter.results;\n1240:     const avgScore = computeAverageScore(resultsForFormatting as Array<Record<string, unknown>>);\n1241:     const requestQualityLabel = pipelineResult.metadata.stage4.evidenceGapDetected ? 'gap' : 'weak';\n1242:     const qualityGapRouting = routeQuery(effectiveQuery, undefined, {\n1243:       quality: requestQualityLabel,\n1244:       avgScore,\n1245:     });\n1246:     const qualityFallback = qualityGapRouting.qualityFallback;\n1247:     if (qualityFallback.engaged) {\n1248:       queryPlan = qualityGapRouting.queryPlan;\n1249:     }\n1250: \n1251:     if (sessionId && isSessionRetrievalStateEnabled()) {\n1252:       const activeGoal = effectiveQuery.trim().length > 0 ? effectiveQuery : null;\n1253:       if (activeGoal) {\n1254:         retrievalSessionStateManager.updateGoal(sessionId, activeGoal);\n1255:       }\n1256:       if (Array.isArray(anchors) && anchors.length > 0) {\n1257:         retrievalSessionStateManager.setAnchors(sessionId, anchors);\n1258:       }\n1259: \n1260:       const goalRefinement = refineForGoal(resultsForFormatting, sessionId);\n1261:       resultsForFormatting = goalRefinement.results as SessionAwareResult[];\n1262:       goalRefinementPayload = {\n1263:         activeGoal: goalRefinement.metadata.activeGoal,\n1264:         applied: goalRefinement.metadata.refined,\n1265:         boostedCount: goalRefinement.metadata.boostedCount,\n1266:       };\n1267:     }\n1268: \n1269:     if (folderBoostRankingApplied) {\n1270:       stampFinalRankScores(resultsForFormatting);\n1271:     }\n1272: \n1273:     // Build extra data from pipeline metadata for response formatting\n1274:     const lexicalCapability = getLastLexicalCapabilitySnapshot();\n1275:     if (lexicalCapability) {\n1276:       console.error(\n1277:         `[memory-search] Lexical capability path '${lexicalCapability.lexicalPath}' (fallbackState: ${lexicalCapability.fallbackState})`\n1278:       );\n1279:     }\n1280: \n1281:     const extraData: Record<string, unknown> = {\n1282:       stateStats: pipelineResult.annotations.stateStats,\n1283:       featureFlags: {\n1284:         ...pipelineResult.annotations.featureFlags,\n1285:       },\n1286:       pipelineMetadata: pipelineResult.metadata,\n1287:       qualityGapFallback: qualityFallback,\n1288:     };\n1289:     if (lexicalCapability) {\n1290:       extraData.lexicalPath = lexicalCapability.lexicalPath;\n1291:       extraData.fallbackState = lexicalCapability.fallbackState;\n1292:     }\n1293: \n1294:     if (pipelineResult.annotations.evidenceGapWarning) {\n1295:       extraData.evidenceGapWarning = pipelineResult.annotations.evidenceGapWarning;\n1296:     }\n1297: \n1298:     if (detectedIntent) {\n1299:       extraData.intent = {\n1300:         type: detectedIntent,\n1301:         confidence: intentConfidence,\n1302:         description: intentClassifier.getIntentDescription(detectedIntent as IntentType),\n1303:         weightsApplied: pipelineResult.metadata.stage2.intentWeightsApplied,\n1304:       };\n1305:     }\n1306: \n1307:     if (artifactRouting) {\n1308:       extraData.artifactRouting = artifactRouting;\n1309:       extraData.artifact_routing = artifactRouting;\n1310:     }\n1311: \n1312:     if (pipelineResult.metadata.stage2.feedbackSignalsApplied === 'applied') {\n1313:       extraData.feedbackSignals = { applied: true };\n1314:       extraData.feedback_signals = { applied: true };\n1315:     }\n1316: \n1317:     if (pipelineResult.metadata.stage2.graphContribution) {\n1318:       extraData.graphContribution = pipelineResult.metadata.stage2.graphContribution;\n1319:       extraData.graph_contribution = pipelineResult.metadata.stage2.graphContribution;\n1320:     }\n1321: \n1322:     if (pipelineResult.metadata.stage3.rerankApplied) {\n1323:       extraData.rerankMetadata = {\n1324:         reranking_enabled: true,\n1325:         reranking_requested: true,\n1326:         reranking_applied: true,\n1327:       };\n1328:     }\n1329: \n1330:     if (pipelineResult.metadata.stage3.chunkReassemblyStats.chunkParents > 0) {\n1331:       extraData.chunkReassembly = pipelineResult.metadata.stage3.chunkReassemblyStats;\n1332:       extraData.chunk_reassembly = pipelineResult.metadata.stage3.chunkReassemblyStats;\n1333:     }\n1334:     extraData.sourceContract = {\n1335:       version: CANONICAL_READER_CACHE_VERSION,\n1336:       archivedTierEnabled: false,\n1337:       legacyFallbackEnabled: false,\n1338:       includeArchivedCompatibility: includeArchivedRequested === true ? 'ignored' : 'not_requested',\n1339:       preferredDocumentTypes: ['spec_doc', 'continuity'],\n1340:       retainedResults: canonicalFilter.stats.retained,\n1341:       droppedNonCanonicalResults: canonicalFilter.stats.dropped,\n1342:       countsBySourceKind: canonicalFilter.stats.bySourceKind,\n1343:     };\n1344: \n1345:     if (includeTrace && pipelineResult.trace) {\n1346:       extraData.retrievalTrace = pipelineResult.trace;\n1347:       extraData.vectorDegradation = buildVectorDegradationSignal(vectorIndex.isVectorSearchAvailable());\n1348:       extraData.vector_degradation = extraData.vectorDegradation;\n1349:     }\n1350:     const degradedReadiness = mapGraphReadinessToTelemetry(\n1351:       getGraphReadinessSnapshotFromMarker(),\n1352:     );\n1353:     searchDecisionEnvelope = buildSearchDecisionEnvelope({\n1354:       requestId: searchDecisionRequestId,\n1355:       tenantId: normalizedScope.tenantId,\n1356:       userId: normalizedScope.userId,\n1357:       agentId: normalizedScope.agentId,\n1358:       queryPlan,\n1359:       trustTreeInput: {\n1360:         responsePolicy: {\n1361:           state: 'live',\n1362:           decision: 'memory_search_response',\n1363:         },\n1364:       },\n1365:       degradedReadiness,\n1366:       pipelineTiming: pipelineResult.metadata.timing,\n1367:       timestamp: new Date(_searchStartTime).toISOString(),\n1368:       latencyMs: Date.now() - _searchStartTime,\n1369:     });\n1370:     extraData.searchDecisionEnvelope = searchDecisionEnvelope;\n1371:     extraData.search_decision_envelope = searchDecisionEnvelope;\n1372:     try {\n1373:       const adaptiveShadow = buildAdaptiveShadowProposal(\n1374:         requireDb(),\n1375:         effectiveQuery,\n1376:         resultsForFormatting as Array<Record<string, unknown> & { id: number }>,\n1377:       );\n1378:       if (adaptiveShadow) {\n1379:         extraData.adaptiveShadow = adaptiveShadow;\n1380:         extraData.adaptive_shadow = adaptiveShadow;\n1381:       }\n1382:     } catch (_error: unknown) {\n\n(Output capped at 50 KB. Showing lines 1-1382. Use offset=1383 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Search\n// ───────────────────────────────────────────────────────────────\n/* ───────────────────────────────────────────────────────────────\n   1. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\nimport * as intentClassifier from '../lib/search/intent-classifier.js';\n// TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\nimport { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\nimport { searchCommunities } from '../lib/search/community-search.js';\n// 4-stage pipeline architecture\nimport { executePipeline } from '../lib/search/pipeline/index.js';\nimport type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\nimport type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\nimport { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Search\n// ───────────────────────────────────────────────────────────────\n/* ───────────────────────────────────────────────────────────────\n   1. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\nimport * as intentClassifier from '../lib/search/intent-classifier.js';\n// TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\nimport { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\nimport { searchCommunities } from '../lib/search/community-search.js';\n// 4-stage pipeline architecture\nimport { executePipeline } from '../lib/search/pipeline/index.js';\nimport type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\nimport type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\nimport { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n// Artifact-class routing (spec/plan/tasks/checklist/memory)\nimport { getStrategyForQuery } from '../lib/search/artifact-routing.js';\nimport { routeQuery } from '../lib/search/query-router.js';\nimport { createEmptyQueryPlan, type QueryPlan } from '../lib/query/query-plan.js';\nimport { getGraphReadinessSnapshotFromMarker } from '../lib/code-graph-boundary.js';\nimport { mapGraphReadinessToTelemetry } from '../lib/search/graph-readiness-mapper.js';\nimport {\n  buildSearchDecisionEnvelope,\n  type SearchDecisionEnvelope,\n} from '../lib/search/search-decision-envelope.js';\nimport { recordSearchDecision } from '../lib/search/decision-audit.js';\n// Chunk reassembly (extracted from this file)\nimport { collapseAndReassembleChunkResults } from '../lib/search/chunk-reassembly.js';\n// Search utilities (extracted from this file)\nimport {\n  filterByMinQualityScore,\n  resolveQualityThreshold,\n  buildCacheArgs,\n  resolveRowContextType,\n  resolveArtifactRoutingQuery,\n  applyArtifactRouting,\n} from '../lib/search/search-utils.js';\n// CacheArgsInput used internally by buildCacheArgs (lib/search/search-utils.ts)\n// Eval channel tracking (extracted from this file)\nimport {\n  collectEvalChannelsFromRow,\n  buildEvalChannelPayloads,\n  summarizeGraphWalkDiagnostics,\n} from '../lib/telemetry/eval-channel-tracking.js';\nimport type { EvalChannelPayload } from '../lib/telemetry/eval-channel-tracking.js';\n\n// Eval logger — fail-safe, no-op when SPECKIT_EVAL_LOGGING !== \"true\"\nimport { logSearchQuery, logChannelResult, logFinalResult } from '../lib/eval/eval-logger.js';\nimport {\n  logFeedbackEvents,\n  isImplicitFeedbackLogEnabled,\n} from '../lib/feedback/feedback-ledger.js';\nimport type { FeedbackEvent } from '../lib/feedback/feedback-ledger.js';\nimport { trackQueryAndDetect, logResultCited } from '../lib/feedback/query-flow-tracker.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { validateQuery, requireDb, toErrorMessage } from '../utils/index.js';\n\n// Response envelope + formatters\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { formatSearchResults } from '../formatters/index.js';\n\n// Shared handler types\nimport type { MCPResponse, IntentClassification } from './types.js';\n\n// Retrieval trace contracts (C136-08)\nimport { createTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { buildAdaptiveShadowProposal } from '../lib/cognitive/adaptive-ranking.js';\nimport { normalizeScopeContext, filterRowsByScope } from '../lib/governance/scope-governance.js';\nimport {\n  attachSessionTransitionTrace,\n  type SessionTransitionTrace,\n} from '../lib/search/session-transition.js';\n\n// Mode-Aware Response Shape\nimport {\n  applyProfileToEnvelope,\n  isResponseProfileEnabled,\n} from '../lib/response/profile-formatters.js';\nimport {\n  buildProgressiveResponse,\n  extractSnippets,\n  isProgressiveDisclosureEnabled,\n  resolveCursor,\n} from '../lib/search/progressive-disclosure.js';\nimport {\n  SPEC_DOCUMENT_FILENAMES,\n  canClassifyAsSpecDocument,\n  normalizeSpecPath,\n} from '../lib/config/spec-doc-paths.js';\nimport {\n  getLastLexicalCapabilitySnapshot,\n  resetLastLexicalCapabilitySnapshot,\n} from '../lib/search/sqlite-fts.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { LexicalCapabilitySnapshot } from '../lib/search/sqlite-fts.js';\nimport { buildVectorDegradationSignal } from '../lib/observability/retrieval-observability.js';\nimport { evaluatePublicationGate } from '../lib/context/publication-gate.js';\nimport {\n  deduplicateResults as deduplicateWithSessionState,\n  isSessionRetrievalStateEnabled,\n  manager as retrievalSessionStateManager,\n  refineForGoal,\n} from '../lib/search/session-state.js';\n\n// Type imports for casting\nimport type { IntentType, IntentWeights as IntentClassifierWeights } from '../lib/search/intent-classifier.js';\nimport type { RawSearchResult } from '../formatters/index.js';\n// RoutingResult, WeightedResult — now used internally by lib/search/search-utils.ts\n\n// Feature catalog: Semantic and lexical search (memory_search)\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Quality-aware 3-tier search fallback\n\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Internal search result row — enriched DB row used within this handler.\n * NOT the same as the canonical SearchResult in shared/types.ts.\n * Self-contained: uses local types instead of the deprecated MemoryRow/MemoryRecord shapes.\n * This can migrate to MemoryDbRow & Record<string, unknown> later without changing the handler contract.\n */\ninterface MemorySearchRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  attentionScore?: number;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n}\n\ninterface DedupResult {\n  results: MemorySearchRow[];\n  dedupStats: Record<string, unknown>;\n}\n\ninterface FolderBoost {\n  folder: string;\n  factor: number;\n}\n\ninterface SearchCachePayload {\n  summary: string;\n  data: Record<string, unknown>;\n  hints: string[];\n}\n\ntype SessionAwareResult = Record<string, unknown> & {\n  id: number | string;\n  score?: number;\n  content?: string;\n};\n\ntype CanonicalSourceKind = 'spec_doc' | 'continuity' | 'constitutional';\n\ninterface CanonicalSourceStats {\n  retained: number;\n  dropped: number;\n  bySourceKind: Record<CanonicalSourceKind, number>;\n}\n\nconst CONTINUITY_ANCHOR_ID = '_memory.continuity';\nconst CANONICAL_READER_CACHE_VERSION = 'gate-d-reader-ready-v1';\nconst CANONICAL_SPEC_DOC_DOCUMENT_TYPES = new Set([\n  'spec',\n  'plan',\n  'tasks',\n  'checklist',\n  'decision_record',\n  'implementation_summary',\n  'research',\n  'handover',\n  'graph_metadata',\n  'spec_doc',\n]);\nconst NON_CANONICAL_DOCUMENT_TYPES = new Set([\n  'memory',\n  'scratch',\n]);\n\nfunction normalizeDocumentType(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim().toLowerCase();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction resolveAnchorId(row: Record<string, unknown>): string | null {\n  const value = row.anchor_id ?? row.anchorId;\n  return typeof value === 'string' && value.trim().length > 0\n    ? value.trim()\n    : null;\n}\n\nfunction resolveFilePath(row: Record<string, unknown>): string | null {\n  const value = row.file_path ?? row.filePath;\n  return typeof value === 'string' && value.trim().length > 0\n    ? value\n    : null;\n}\n\nfunction resolveCanonicalSourceKind(row: Record<string, unknown>): CanonicalSourceKind | null {\n  const documentType = normalizeDocumentType(row.document_type ?? row.documentType);\n  const importanceTier = normalizeDocumentType(row.importance_tier ?? row.importanceTier);\n  const anchorId = resolveAnchorId(row);\n\n  if (importanceTier === 'constitutional' || documentType === 'constitutional') {\n    return 'constitutional';\n  }\n\n  if (anchorId === CONTINUITY_ANCHOR_ID || documentType === 'continuity') {\n    return 'continuity';\n  }\n\n  if (documentType && CANONICAL_SPEC_DOC_DOCUMENT_TYPES.has(documentType)) {\n    return 'spec_doc';\n  }\n\n  if (documentType && NON_CANONICAL_DOCUMENT_TYPES.has(documentType)) {\n    return null;\n  }\n\n  const filePath = resolveFilePath(row);\n  if (!filePath) {\n    return null;\n  }\n  const normalizedPath = normalizeSpecPath(filePath);\n  const basename = normalizedPath.split('/').filter(Boolean).pop() ?? '';\n\n  if (\n    basename.length > 0 &&\n    SPEC_DOCUMENT_FILENAMES.has(basename) &&\n    canClassifyAsSpecDocument(normalizedPath)\n  ) {\n    return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n  }\n\n  return null;\n}\n\nfunction filterCanonicalSourceRows<T extends SessionAwareResult>(\n  results: T[],\n): { results: T[]; stats: CanonicalSourceStats } {\n  const stats: CanonicalSourceStats = {\n    retained: 0,\n    dropped: 0,\n    bySourceKind: {\n      spec_doc: 0,\n      continuity: 0,\n      constitutional: 0,\n    },\n  };\n\n  const filtered: T[] = [];\n  for (const result of results) {\n    const sourceKind = resolveCanonicalSourceKind(result);\n    if (!sourceKind) {\n      stats.dropped += 1;\n      continue;\n    }\n\n    filtered.push({\n      ...result,\n      canonicalSource: sourceKind,\n      canonicalSourceType: sourceKind,\n      documentType: sourceKind,\n    });\n    stats.retained += 1;\n    stats.bySourceKind[sourceKind] += 1;\n  }\n\n  return { results: filtered, stats };\n}\n\n// ChunkReassemblyResult — now imported from lib/search/chunk-reassembly.ts\n\ntype IntentWeights = IntentClassifierWeights;\n\nfunction toIntentWeightsConfig(weights: IntentWeights | null): IntentWeightsConfig | null {\n  if (!weights) return null;\n  return {\n    similarity: weights.similarity,\n    importance: weights.importance,\n    recency: weights.recency,\n  };\n}\n\n// EvalChannelPayload — now imported from lib/telemetry/eval-channel-tracking.ts\n\ninterface SearchArgs {\n  cursor?: string;\n  query?: string;\n  concepts?: string[];\n  specFolder?: string;\n  folderBoost?: FolderBoost;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n  tier?: string;\n  contextType?: string;\n  useDecay?: boolean;\n  includeContiguity?: boolean;\n  includeConstitutional?: boolean;\n  includeContent?: boolean;\n  anchors?: string[];\n  bypassCache?: boolean;\n  sessionId?: string;\n  enableDedup?: boolean;\n  intent?: string;\n  autoDetectIntent?: boolean;\n  minState?: string;\n  applyStateLimits?: boolean;\n  rerank?: boolean;\n  applyLengthPenalty?: boolean;\n  trackAccess?: boolean; // opt-in access tracking (default false)\n  includeArchived?: boolean; // Include archived memories in search (default false)\n  enableSessionBoost?: boolean;\n  enableCausalBoost?: boolean;\n  minQualityScore?: number;\n  min_quality_score?: number;\n  mode?: string; // \"deep\" mode enables query expansion for multi-query RAG\n  includeTrace?: boolean;\n  sessionTransition?: SessionTransitionTrace;\n  /** Presentation profile ('quick'|'research'|'resume'|'debug'). Default: full response. */\n  profile?: string;\n  /** Dual-level retrieval — 'local' (entity), 'global' (community), 'auto' (local + fallback). */\n  retrievalLevel?: 'local' | 'global' | 'auto';\n}\n\n// resolveRowContextType — now imported from lib/search/search-utils.ts\n// resolveEvalScore, collectEvalChannelsFromRow — now imported from lib/telemetry/eval-channel-tracking.ts\n\nfunction attachTelemetryMeta(\n  response: MCPResponse,\n  telemetryPayload: Record<string, unknown>,\n): MCPResponse {\n  const firstEntry = response?.content?.[0];\n  if (!firstEntry || typeof firstEntry.text !== 'string') {\n    return response;\n  }\n\n  try {\n    const envelope = JSON.parse(firstEntry.text) as Record<string, unknown>;\n    const meta = envelope.meta && typeof envelope.meta === 'object'\n      ? envelope.meta as Record<string, unknown>\n      : {};\n    envelope.meta = {\n      ...meta,\n      _telemetry: telemetryPayload,\n    };\n\n    return {\n      ...response,\n      content: [{ ...firstEntry, text: JSON.stringify(envelope, null, 2) }],\n    };\n  } catch (error: unknown) {\n    const message = toErrorMessage(error);\n    console.warn('[memory-search] Failed to attach telemetry payload:', message);\n    return response;\n  }\n}\n\nfunction extractResponseResults(response: MCPResponse): Array<Record<string, unknown>> {\n  const firstEntry = response?.content?.[0];\n  if (!firstEntry || typeof firstEntry.text !== 'string') {\n    return [];\n  }\n\n  try {\n    const envelope = JSON.parse(firstEntry.text) as Record<string, unknown>;\n    const data = envelope.data && typeof envelope.data === 'object'\n      ? envelope.data as Record<string, unknown>\n      : null;\n    return Array.isArray(data?.results)\n      ? data.results as Array<Record<string, unknown>>\n      : [];\n  } catch {\n    return [];\n  }\n}\n\nfunction extractSearchCachePayload(response: MCPResponse): SearchCachePayload | null {\n  const firstEntry = response?.content?.[0];\n  if (!firstEntry || typeof firstEntry.text !== 'string') {\n    return null;\n  }\n\n  try {\n    const envelope = JSON.parse(firstEntry.text) as Record<string, unknown>;\n    const summary = typeof envelope.summary === 'string' ? envelope.summary : null;\n    const data = envelope.data && typeof envelope.data === 'object'\n      ? envelope.data as Record<string, unknown>\n      : null;\n    const hints = Array.isArray(envelope.hints)\n      ? envelope.hints.filter((hint): hint is string => typeof hint === 'string')\n      : [];\n\n    if (!summary || !data) {\n      return null;\n    }\n\n    return { summary, data, hints };\n  } catch {\n    return null;\n  }\n}\n\nfunction parseResponseEnvelope(\n  response: MCPResponse,\n): { firstEntry: { type: 'text'; text: string }; envelope: Record<string, unknown> } | null {\n  const firstEntry = response?.content?.[0];\n  if (!firstEntry || firstEntry.type !== 'text' || typeof firstEntry.text !== 'string') {\n    return null;\n  }\n\n  try {\n    return {\n      firstEntry,\n      envelope: JSON.parse(firstEntry.text) as Record<string, unknown>,\n    };\n  } catch {\n    return null;\n  }\n}\n\nfunction replaceResponseEnvelope(\n  response: MCPResponse,\n  firstEntry: { type: 'text'; text: string },\n  envelope: Record<string, unknown>,\n): MCPResponse {\n  return {\n    ...response,\n    content: [{ ...firstEntry, text: JSON.stringify(envelope, null, 2) }],\n  };\n}\n\nfunction buildSessionStatePayload(sessionId: string): Record<string, unknown> {\n  const session = retrievalSessionStateManager.getOrCreate(sessionId);\n  return {\n    activeGoal: session.activeGoal,\n    seenResultIds: Array.from(session.seenResultIds),\n    openQuestions: [...session.openQuestions],\n    preferredAnchors: [...session.preferredAnchors],\n  };\n}\n\nfunction buildSearchResponseFromPayload(\n  payload: SearchCachePayload,\n  startTime: number,\n  cacheHit: boolean,\n): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_search',\n    summary: payload.summary,\n    data: payload.data,\n    hints: payload.hints,\n    startTime,\n    cacheHit,\n  });\n}\n\nfunction resolveSearchScore(result: Record<string, unknown>): number | null {\n  const candidate = result.score ?? result.similarity ?? result.averageSimilarity ?? result.intentAdjustedScore;\n  if (typeof candidate !== 'number' || !Number.isFinite(candidate)) {\n    return null;\n  }\n  return candidate > 1 ? candidate / 100 : candidate;\n}\n\nfunction computeAverageScore(results: Array<Record<string, unknown>>): number {\n  const scores = results\n    .map(resolveSearchScore)\n    .filter((score): score is number => score !== null);\n  if (scores.length === 0) return 0;\n  return scores.reduce((sum, score) => sum + score, 0) / scores.length;\n}\n\nfunction attachLexicalCapabilityMetadata(\n  response: MCPResponse,\n  snapshot: LexicalCapabilitySnapshot | null,\n): MCPResponse {\n  const parsed = parseResponseEnvelope(response);\n  if (!parsed) {\n    return response;\n  }\n\n  const data = parsed.envelope.data && typeof parsed.envelope.data === 'object'\n    ? parsed.envelope.data as Record<string, unknown>\n    : {};\n\n  if (typeof data.lexicalPath !== 'string' && snapshot) {\n    data.lexicalPath = snapshot.lexicalPath;\n  }\n  if (typeof data.fallbackState !== 'string' && snapshot) {\n    data.fallbackState = snapshot.fallbackState;\n  }\n\n  parsed.envelope.data = data;\n  return replaceResponseEnvelope(response, parsed.firstEntry, parsed.envelope);\n}\n\nfunction hasPublicationContractFields(result: Record<string, unknown>): boolean {\n  return [\n    'certainty',\n    'methodologyStatus',\n    'schemaVersion',\n    'provenance',\n    'multiplierAuthorityFields',\n  ].some((field) => Object.prototype.hasOwnProperty.call(result, field));\n}\n\nfunction normalizePublicationProvenanceEntry(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction resolvePublicationProvenance(result: Record<string, unknown>): string[] {\n  const explicit = Array.isArray(result.provenance)\n    ? result.provenance\n        .map(normalizePublicationProvenanceEntry)\n        .filter((entry): entry is string => entry !== null)\n    : [];\n  if (explicit.length > 0) {\n    return [...new Set(explicit)];\n  }\n\n  return [...new Set([\n    result.provenance_source,\n    result.provenanceSource,\n    result.source_kind,\n    result.sourceKind,\n  ].map(normalizePublicationProvenanceEntry).filter((entry): entry is string => entry !== null))];\n}\n\nfunction applyPublicationGateToResponse(response: MCPResponse): MCPResponse {\n  const parsed = parseResponseEnvelope(response);\n  if (!parsed) {\n    return response;\n  }\n\n  const data = parsed.envelope.data && typeof parsed.envelope.data === 'object'\n    ? parsed.envelope.data as Record<string, unknown>\n    : null;\n  const results = Array.isArray(data?.results)\n    ? data.results as Array<Record<string, unknown>>\n    : null;\n\n  if (!data || !results) {\n    return response;\n  }\n\n  data.results = results.map((result) => {\n    if (!hasPublicationContractFields(result)) {\n      return result;\n    }\n\n    const provenance = resolvePublicationProvenance(result);\n    const resultWithProvenance = provenance.length > 0\n      ? { ...result, provenance }\n      : result;\n    const gateResult = evaluatePublicationGate({\n      certainty: result.certainty,\n      methodologyStatus: result.methodologyStatus as 'provisional' | 'published' | null | undefined,\n      schemaVersion: result.schemaVersion as string | null | undefined,\n      provenance,\n      multiplierAuthorityFields: result.multiplierAuthorityFields as Record<string, unknown> | null | undefined,\n    });\n\n    return gateResult.publishable\n      ? {\n        ...resultWithProvenance,\n        publishable: true,\n      }\n      : {\n        ...resultWithProvenance,\n        publishable: false,\n        exclusionReason: gateResult.exclusionReason,\n      };\n  });\n\n  parsed.envelope.data = data;\n  return replaceResponseEnvelope(response, parsed.firstEntry, parsed.envelope);\n}\n\n// summarizeGraphWalkDiagnostics, buildEvalChannelPayloads — now imported from lib/telemetry/eval-channel-tracking.ts\n\n// filterByMinQualityScore, resolveQualityThreshold, buildCacheArgs,\n// resolveArtifactRoutingQuery, applyArtifactRouting — now imported from lib/search/search-utils.ts\n// CacheArgsInput — now imported from lib/search/search-utils.ts\n// parseNullableInt, collapseAndReassembleChunkResults — now imported from lib/search/chunk-reassembly.ts\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Sections 3–5 (STATE_PRIORITY, MAX_DEEP_QUERY_VARIANTS, buildDeepQueryVariants,\n// StrengthenOnAccess, applyTestingEffect, filterByMemoryState) removed in\n// These were only used by the legacy V1 pipeline.\n// The V2 4-stage pipeline handles state filtering (Stage 4), testing effect, and\n// Query expansion through its own stages.\n\n/* ───────────────────────────────────────────────────────────────\n   6. SESSION DEDUPLICATION UTILITIES\n──────────────────────────────────────────────────────────────── */\n\nfunction stampFinalRankScores(results: Array<Record<string, unknown>>): void {\n  const total = results.length;\n  results.forEach((result, index) => {\n    result.finalRankScore = calculateFinalRankScore(total, index);\n  });\n}\n\nfunction calculateFinalRankScore(total: number, index: number): number | null {\n  return total > 0 ? (total - index) / total : null;\n}\n\nfunction applyFolderBoostRanking(results: SessionAwareResult[], folderBoost: FolderBoost | undefined): boolean {\n  if (!folderBoost || !folderBoost.folder || folderBoost.factor <= 1) {\n    return false;\n  }\n\n  let boostedCount = 0;\n  for (const r of results) {\n    const raw = r as Record<string, unknown>;\n    const filePath = raw.file_path as string | undefined;\n    if (filePath && filePath.includes(folderBoost.folder)) {\n      if (typeof raw.similarity === 'number') {\n        raw.similarity = Math.min(raw.similarity * folderBoost.factor, 1.0);\n        boostedCount++;\n      }\n    }\n  }\n\n  if (boostedCount === 0) {\n    return false;\n  }\n\n  results.sort((a, b) => {\n    const sa = ((a as Record<string, unknown>).similarity as number | undefined) ?? 0;\n    const sb = ((b as Record<string, unknown>).similarity as number | undefined) ?? 0;\n    return sb - sa;\n  });\n  return true;\n}\n\nfunction isPlainRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === 'object' && value !== null && !Array.isArray(value);\n}\n\nfunction documentKey(document: unknown): string | null {\n  if (!isPlainRecord(document) || typeof document.path !== 'string') {\n    return null;\n  }\n  const anchor = typeof document.anchor === 'string' ? document.anchor : '';\n  return `${document.path}\\u0000${anchor}`;\n}\n\nfunction resultDocumentKey(result: Record<string, unknown>): string | null {\n  const whyRanked = isPlainRecord(result.why_ranked) ? result.why_ranked : null;\n  const fromWhyRanked = whyRanked ? documentKey(whyRanked.document) : null;\n  if (fromWhyRanked !== null) {\n    return fromWhyRanked;\n  }\n\n  const filePath = result.filePath ?? result.file_path;\n  return typeof filePath === 'string' ? `${filePath}\\u0000` : null;\n}\n\nfunction warningStillApplies(warning: unknown, returnedDocumentKeys: Set<string>): boolean {\n  if (!isPlainRecord(warning) || !Array.isArray(warning.documents)) {\n    return true;\n  }\n  const keys = warning.documents.map(documentKey);\n  if (keys.length !== 2 || keys.some((key) => key === null)) {\n    return true;\n  }\n  return keys.every((key) => returnedDocumentKeys.has(key as string));\n}\n\nfunction reconcilePostFormatResultSet(data: Record<string, unknown>, results: Array<Record<string, unknown>>): void {\n  const total = results.length;\n  results.forEach((result, index) => {\n    if (isPlainRecord(result.why_ranked)) {\n      result.why_ranked.rank = index + 1;\n      if (result.why_ranked.scoreSource === 'finalRank') {\n        result.why_ranked.effectiveScore = calculateFinalRankScore(total, index);\n      }\n    }\n  });\n\n  data.results = results;\n  data.count = results.length;\n\n  const returnedDocumentKeys = new Set(\n    results\n      .map(resultDocumentKey)\n      .filter((key): key is string => key !== null),\n  );\n\n  for (const key of ['inlineWarnings', 'retrievalWarnings']) {\n    const warnings = data[key];\n    if (!Array.isArray(warnings)) {\n      continue;\n    }\n    const retained = warnings.filter((warning) => warningStillApplies(warning, returnedDocumentKeys));\n    if (retained.length > 0) {\n      data[key] = retained;\n    } else {\n      delete data[key];\n    }\n  }\n}\n\nfunction applySessionDedup(results: MemorySearchRow[], sessionId: string, enableDedup: boolean): DedupResult {\n  if (!enableDedup || !sessionId || !sessionManager.isEnabled()) {\n    return {\n      results,\n      dedupStats: { enabled: false, sessionId: null }\n    };\n  }\n\n  const { filtered, dedupStats } = sessionManager.filterSearchResults(sessionId, results as Parameters<typeof sessionManager.filterSearchResults>[1]);\n\n  if (filtered.length > 0) {\n    sessionManager.markResultsSent(sessionId, filtered as Parameters<typeof sessionManager.markResultsSent>[1]);\n  }\n\n  return {\n    results: filtered as MemorySearchRow[],\n    dedupStats: {\n      ...dedupStats,\n      sessionId\n    }\n  };\n}\n\n// Sections 7–9 (applyCrossEncoderReranking, applyIntentWeightsToResults,\n// ShouldApplyPostSearchIntentWeighting, postSearchPipeline) removed in\n// These were only used by the legacy V1 pipeline\n// Path. The V2 4-stage pipeline handles all equivalent functionality.\n\n/* ───────────────────────────────────────────────────────────────\n   10. MAIN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n * @returns MCP response with ranked search results\n */\nasync function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_search');\n  const _searchStartTime = Date.now();\n  resetLastLexicalCapabilitySnapshot();\n  // Check for external database updates before processing\n  await checkDatabaseUpdated();\n\n  const {\n    cursor,\n    query,\n    concepts,\n    specFolder,\n    folderBoost,\n    tenantId,\n    userId,\n    agentId,\n    limit: rawLimit = 10,\n    tier,\n    contextType,\n    useDecay: useDecay = true,\n    includeContiguity: includeContiguity = false,\n    includeConstitutional: includeConstitutional = true,\n    includeContent: includeContent = false,\n    anchors,\n    bypassCache: bypassCache = false,\n    sessionId: rawSessionId,\n    enableDedup: enableDedup = true,\n    intent: explicitIntent,\n    autoDetectIntent: autoDetectIntent = true,\n    minState,  // No default — memoryState column not yet in schema; defaulting to 'WARM' filters all rows\n    applyStateLimits: applyStateLimits = false,\n    rerank = true, // Enable reranking by default for better result quality\n    applyLengthPenalty: applyLengthPenalty = true,\n    trackAccess: trackAccess = false, // opt-in, off by default\n    includeArchived: includeArchivedRequested = false, // compatibility-only after Gate B cleanup\n    enableSessionBoost: enableSessionBoost = isSessionBoostEnabled(),\n    enableCausalBoost: enableCausalBoost = isCausalBoostEnabled(),\n    minQualityScore,\n    min_quality_score,\n    mode,\n    includeTrace: includeTraceArg = false,\n    sessionTransition,\n    profile,\n    retrievalLevel: retrievalLevel = 'auto',\n  } = args;\n  const includeTraceByFlag = process.env.SPECKIT_RESPONSE_TRACE === 'true';\n  const includeTrace = includeTraceByFlag || includeTraceArg === true;\n  const includeArchived = false;\n\n  // Validate any caller-supplied sessionId through the server-side session\n  // manager to prevent IDOR: a caller must not read or mutate another\n  // session's sent-memory dedup state by forging an arbitrary session id.\n  // Omitting sessionId stays unchanged (downstream treats it as no-session).\n  let sessionId: string | undefined = rawSessionId;\n  if (rawSessionId) {\n    const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n      tenantId,\n      userId,\n      agentId,\n    });\n    if (trustedSession.error) {\n      return createMCPErrorResponse({\n        tool: 'memory_search',\n        error: trustedSession.error,\n        code: 'E_SESSION_SCOPE',\n        details: { requestedSessionId: rawSessionId },\n        recovery: {\n          hint: 'Omit sessionId to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n        },\n      });\n    }\n    sessionId = trustedSession.effectiveSessionId;\n  }\n\n  const normalizedScope = normalizeScopeContext({ tenantId, userId, agentId, sessionId });\n  const progressiveScopeKey = JSON.stringify({\n    tenantId: normalizedScope.tenantId ?? null,\n    userId: normalizedScope.userId ?? null,\n    agentId: normalizedScope.agentId ?? null,\n    sessionId: normalizedScope.sessionId ?? null,\n  });\n\n  // Validate at least one search input is provided (moved from schema superRefine for GPT compatibility)\n  const hasCursor = typeof cursor === 'string' && cursor.trim().length > 0;\n  const hasQuery = typeof query === 'string' && query.trim().length > 0;\n  const hasConcepts = Array.isArray(concepts) && concepts.length >= 2;\n  if (!hasCursor && !hasQuery && !hasConcepts) {\n    return { content: [{ type: 'text', text: JSON.stringify({ error: 'Either \"query\" (string), \"concepts\" (array with 2-5 items), or \"cursor\" (string) is required.' }) }] };\n  }\n\n  if (hasCursor) {\n    const resolved = resolveCursor(cursor.trim(), undefined, { scopeKey: progressiveScopeKey });\n    if (!resolved) {\n      return createMCPErrorResponse({\n        tool: 'memory_search',\n        error: 'Cursor is invalid, expired, or out of scope',\n        code: 'E_VALIDATION',\n        details: { parameter: 'cursor' },\n        recovery: {\n          hint: 'Retry the original search to generate a fresh continuation cursor',\n        },\n      });\n    }\n\n    const snippetResults = extractSnippets(resolved.results);\n    return createMCPSuccessResponse({\n      tool: 'memory_search',\n      summary: `Returned ${snippetResults.length} continuation results`,\n      data: {\n        count: snippetResults.length,\n        results: snippetResults,\n        continuation: resolved.continuation,\n      },\n      startTime: _searchStartTime,\n      cacheHit: false,\n    });\n  }\n\n  const qualityThreshold = resolveQualityThreshold(minQualityScore, min_quality_score);\n\n  // Validate numeric limit parameter\n  const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n    ? Math.min(Math.floor(rawLimit), 100)\n    : 10;\n\n  // Validate query first with proper error handling\n  let normalizedQuery: string | null = null;\n  if (query !== undefined) {\n    try {\n      normalizedQuery = validateQuery(query);\n    } catch (validationError: unknown) {\n      if (!concepts || !Array.isArray(concepts) || concepts.length < 2) {\n        const message = toErrorMessage(validationError);\n        return createMCPErrorResponse({\n          tool: 'memory_search',\n          error: message,\n          code: 'E_VALIDATION',\n          details: { parameter: 'query' },\n          recovery: {\n            hint: 'Provide a valid query string or use concepts array instead'\n          }\n        });\n      }\n      normalizedQuery = null;\n    }\n  }\n\n  const hasValidQuery = normalizedQuery !== null;\n  const hasValidConcepts = Array.isArray(concepts) && concepts.length >= 2;\n  const effectiveQuery = normalizedQuery ?? (hasValidConcepts ? concepts.join(', ') : '');\n  const searchDecisionRequestId = `memory_search-${_searchStartTime}`;\n  let searchDecisionEnvelope: SearchDecisionEnvelope | null = null;\n\n  if (!hasValidQuery && !hasValidConcepts) {\n    return createMCPErrorResponse({\n      tool: 'memory_search',\n      error: 'Either query (string), concepts (array of 2-5 strings), or cursor (string) is required',\n      code: 'E_VALIDATION',\n      details: { parameter: 'query' },\n      recovery: {\n        hint: 'Provide a query string, concepts array with 2-5 entries, or a continuation cursor'\n      }\n    });\n  }\n\n  if (specFolder !== undefined && typeof specFolder !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_search',\n      error: 'specFolder must be a string',\n      code: 'E_VALIDATION',\n      details: { parameter: 'specFolder' },\n      recovery: {\n        hint: 'Provide specFolder as a string path'\n      }\n    });\n  }\n\n  // Eval logger — capture query at pipeline entry (fail-safe)\n  let _evalQueryId = 0;\n  let _evalRunId = 0;\n  try {\n    const evalEntry = logSearchQuery({\n      query: effectiveQuery,\n      intent: explicitIntent ?? null,\n      specFolder: specFolder ?? null,\n    });\n    _evalQueryId = evalEntry.queryId;\n    _evalRunId = evalEntry.evalRunId;\n  } catch (_error: unknown) { /* eval logging must never break search */ }\n\n  const artifactRoutingQuery = resolveArtifactRoutingQuery(\n    normalizedQuery,\n    hasValidConcepts ? concepts : undefined\n  );\n  let artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder);\n  let queryPlan: QueryPlan;\n  try {\n    queryPlan = routeQuery(effectiveQuery).queryPlan;\n  } catch (_error: unknown) {\n    queryPlan = createEmptyQueryPlan({\n      complexity: 'unknown',\n      selectedChannels: ['vector', 'fts', 'bm25', 'graph', 'degree'],\n      fallbackPolicy: {\n        mode: 'telemetry_only',\n        reason: 'QueryPlan telemetry fallback after routeQuery failure',\n      },\n    });\n  }\n\n  // Intent-aware retrieval\n  let detectedIntent: string | null = null;\n  let intentConfidence = 0;\n  let intentWeights: IntentWeights | null = null;\n\n  if (explicitIntent) {\n    if (intentClassifier.isValidIntent(explicitIntent)) {\n      detectedIntent = explicitIntent;\n      intentConfidence = 1.0;\n      intentWeights = intentClassifier.getIntentWeights(explicitIntent);\n    } else {\n      console.warn(`[memory-search] Invalid intent '${explicitIntent}', using auto-detection`);\n    }\n  }\n\n  if (!detectedIntent && autoDetectIntent && hasValidQuery) {\n    const classification: IntentClassification = intentClassifier.classifyIntent(normalizedQuery!);\n    detectedIntent = classification.intent;\n    intentConfidence = classification.confidence;\n    intentWeights = intentClassifier.getIntentWeights(classification.intent as IntentType);\n\n    if (classification.fallback) {\n      console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (fallback: ${classification.reason})`);\n    } else {\n      console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (confidence: ${intentConfidence.toFixed(2)})`);\n    }\n  }\n\n  // FIX RC3-B: Intent confidence floor — override low-confidence auto-detections to \"understand\"\n  const INTENT_CONFIDENCE_FLOOR = parseFloat(process.env.SPECKIT_INTENT_CONFIDENCE_FLOOR || '0.25');\n  if (detectedIntent && intentConfidence < INTENT_CONFIDENCE_FLOOR && !explicitIntent) {\n    console.error(`[memory-search] Intent confidence ${intentConfidence.toFixed(3)} below floor ${INTENT_CONFIDENCE_FLOOR}, overriding '${detectedIntent}' → 'understand'`);\n    detectedIntent = 'understand';\n    intentConfidence = 1.0;\n    intentWeights = intentClassifier.getIntentWeights('understand' as IntentType);\n  }\n\n  // Phase C: Intent-to-profile auto-routing.\n  // Explicit caller `profile` always takes precedence; auto-detect fills in when absent.\n  let effectiveProfile: string | undefined = profile;\n  if (!effectiveProfile && detectedIntent && isIntentAutoProfileEnabled()) {\n    try {\n      const autoProfile = intentClassifier.getProfileForIntent(detectedIntent as IntentType);\n      if (autoProfile) {\n        effectiveProfile = autoProfile;\n        console.error(`[memory-search] Intent-to-profile auto-routing: '${detectedIntent}' → profile '${autoProfile}'`);\n      }\n    } catch (_autoProfileErr: unknown) {\n      // Auto-profile is best-effort — never breaks search\n    }\n  }\n  const adaptiveFusionIntent = effectiveProfile === 'resume'\n    ? 'continuity'\n    : detectedIntent;\n\n  // Re-run artifact routing with detected intent for fallback coverage\n  if (detectedIntent && artifactRouting?.detectedClass === 'unknown' && artifactRouting?.confidence === 0) {\n    artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder, detectedIntent);\n  }\n\n  // Create retrieval trace at pipeline entry\n  const trace = createTrace(\n    effectiveQuery,\n    sessionId,\n    detectedIntent || undefined\n  );\n\n  // When causal boost is enabled, fold the causal-edges generation\n  // counter into the cache key so causal-edge mutations naturally invalidate\n  // the affected memory_search entries on the next lookup. We deliberately\n  // keep the generation OFF the key when the caller has not opted into causal\n  // boost — otherwise unrelated callers would suffer needless cache misses.\n  const causalEdgesGenerationForCache = enableCausalBoost\n    ? causalEdges.getCausalEdgesGeneration()\n    : undefined;\n\n  // Build cache key args\n  const cacheArgs = buildCacheArgs({\n    normalizedQuery,\n    hasValidConcepts,\n    concepts,\n    specFolder,\n    tenantId: normalizedScope.tenantId,\n    userId: normalizedScope.userId,\n    agentId: normalizedScope.agentId,\n    limit,\n    mode,\n    tier,\n    contextType,\n    useDecay,\n    includeArchived,\n    qualityThreshold,\n    applyStateLimits,\n    includeContiguity,\n    includeConstitutional,\n    includeContent,\n    anchors,\n    detectedIntent,\n    adaptiveFusionIntent,\n    minState: minState ?? '',\n    rerank,\n    applyLengthPenalty,\n    sessionId,\n    enableSessionBoost,\n    enableCausalBoost,\n    includeTrace,\n    cacheVersion: CANONICAL_READER_CACHE_VERSION,\n    causalEdgesGeneration: causalEdgesGenerationForCache,\n  });\n\n  let _evalChannelPayloads: EvalChannelPayload[] = [];\n  const cacheKey = toolCache.generateCacheKey('memory_search', cacheArgs);\n  const cacheEnabled = toolCache.isEnabled() && !bypassCache;\n  const cachedPayload = cacheEnabled\n    ? toolCache.get<SearchCachePayload>(cacheKey)\n    : null;\n\n  let responseToReturn: MCPResponse;\n  let goalRefinementPayload: Record<string, unknown> | null = null;\n\n  if (cachedPayload) {\n    responseToReturn = buildSearchResponseFromPayload(cachedPayload, _searchStartTime, true);\n  } else {\n    // V2 pipeline is the only path (legacy V1 removed from the runtime pipeline)\n    const pipelineConfig: PipelineConfig = {\n      query: effectiveQuery,\n      concepts: hasValidConcepts ? concepts : undefined,\n      searchType: (hasValidConcepts && concepts!.length >= 2)\n        ? 'multi-concept'\n        : 'hybrid',\n      mode,\n      limit,\n      specFolder,\n      tenantId: normalizedScope.tenantId,\n      userId: normalizedScope.userId,\n      agentId: normalizedScope.agentId,\n      tier,\n      contextType,\n      includeArchived,\n      includeConstitutional,\n      includeContent,\n      anchors,\n      qualityThreshold,\n      minState: minState ?? '',\n      applyStateLimits,\n      useDecay,\n      rerank,\n      applyLengthPenalty,\n      sessionId,\n      enableDedup,\n      enableSessionBoost,\n      enableCausalBoost,\n      trackAccess,\n      detectedIntent,\n      adaptiveFusionIntent,\n      intentConfidence,\n      intentWeights: toIntentWeightsConfig(intentWeights),\n      artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n      queryPlan,\n      trace,\n    };\n\n    const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n    let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n\n    // Community search fallback — inject community members on weak results\n    let communityFallbackApplied = false;\n    const shouldRunCommunitySearch = (\n      isDualRetrievalEnabled() &&\n      isCommunitySearchFallbackEnabled() &&\n      effectiveQuery.length > 0 &&\n      (retrievalLevel === 'global' || retrievalLevel === 'auto')\n    );\n    if (shouldRunCommunitySearch) {\n      const isWeakResult = resultsForFormatting.length === 0 ||\n        (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n      if (isWeakResult) {\n        try {\n          const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n          if (communityResults.totalMemberIds.length > 0) {\n            // Fetch the actual memory rows for community member IDs\n            const memberIds = communityResults.totalMemberIds.slice(0, 20);\n            const placeholders = memberIds.map(() => '?').join(', ');\n            const db = requireDb();\n            const rawMemberRows = db.prepare(`\n              SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n                     importance_tier, context_type, quality_score, created_at,\n                     tenant_id, user_id, agent_id\n              FROM memory_index\n              WHERE id IN (${placeholders})\n            `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n\n            // Apply governed retrieval scope to the community fallback so it cannot\n            // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n            // sessionId is deliberately excluded — it is a dedup/continuity key, not\n            // a row-access boundary. Unscoped (single-user) callers are unaffected.\n            const hasGovernanceScope = Boolean(\n              normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n            );\n            const memberRows = hasGovernanceScope\n              ? filterRowsByScope(rawMemberRows, {\n                  tenantId: normalizedScope.tenantId,\n                  userId: normalizedScope.userId,\n                  agentId: normalizedScope.agentId,\n                })\n              : rawMemberRows;\n\n            if (memberRows.length > 0) {\n              // Calibrate score from community match quality, bounded below pipeline threshold\n              const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n              const avgMatchScore = communityResults.results.length > 0\n                ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n                : 0.5;\n              const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n              // Mark community-sourced results and assign calibrated score\n              const communityRows = memberRows.map((row) => ({\n                ...row,\n                similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n                score: calibratedScore,\n                _communityFallback: true,\n              }));\n              // Merge: append community results not already in pipeline results\n              const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n              const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n              if (newRows.length > 0) {\n                resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n                communityFallbackApplied = true;\n              }\n            }\n          }\n        } catch (err: unknown) {\n          const msg = err instanceof Error ? err.message : String(err);\n          console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n        }\n      }\n    }\n\n    const folderBoostRankingApplied = applyFolderBoostRanking(resultsForFormatting, folderBoost);\n\n    // Eval channel attribution should reflect the retrieval pipeline output\n    // before canonical source filtering drops rows for response formatting.\n    _evalChannelPayloads = buildEvalChannelPayloads(\n      pipelineResult.results as unknown as Array<Record<string, unknown>>,\n    );\n\n    const canonicalFilter = filterCanonicalSourceRows(resultsForFormatting);\n    resultsForFormatting = canonicalFilter.results;\n    const avgScore = computeAverageScore(resultsForFormatting as Array<Record<string, unknown>>);\n    const requestQualityLabel = pipelineResult.metadata.stage4.evidenceGapDetected ? 'gap' : 'weak';\n    const qualityGapRouting = routeQuery(effectiveQuery, undefined, {\n      quality: requestQualityLabel,\n      avgScore,\n    });\n    const qualityFallback = qualityGapRouting.qualityFallback;\n    if (qualityFallback.engaged) {\n      queryPlan = qualityGapRouting.queryPlan;\n    }\n\n    if (sessionId && isSessionRetrievalStateEnabled()) {\n      const activeGoal = effectiveQuery.trim().length > 0 ? effectiveQuery : null;\n      if (activeGoal) {\n        retrievalSessionStateManager.updateGoal(sessionId, activeGoal);\n      }\n      if (Array.isArray(anchors) && anchors.length > 0) {\n        retrievalSessionStateManager.setAnchors(sessionId, anchors);\n      }\n\n      const goalRefinement = refineForGoal(resultsForFormatting, sessionId);\n      resultsForFormatting = goalRefinement.results as SessionAwareResult[];\n      goalRefinementPayload = {\n        activeGoal: goalRefinement.metadata.activeGoal,\n        applied: goalRefinement.metadata.refined,\n        boostedCount: goalRefinement.metadata.boostedCount,\n      };\n    }\n\n    if (folderBoostRankingApplied) {\n      stampFinalRankScores(resultsForFormatting);\n    }\n\n    // Build extra data from pipeline metadata for response formatting\n    const lexicalCapability = getLastLexicalCapabilitySnapshot();\n    if (lexicalCapability) {\n      console.error(\n        `[memory-search] Lexical capability path '${lexicalCapability.lexicalPath}' (fallbackState: ${lexicalCapability.fallbackState})`\n      );\n    }\n\n    const extraData: Record<string, unknown> = {\n      stateStats: pipelineResult.annotations.stateStats,\n      featureFlags: {\n        ...pipelineResult.annotations.featureFlags,\n      },\n      pipelineMetadata: pipelineResult.metadata,\n      qualityGapFallback: qualityFallback,\n    };\n    if (lexicalCapability) {\n      extraData.lexicalPath = lexicalCapability.lexicalPath;\n      extraData.fallbackState = lexicalCapability.fallbackState;\n    }\n\n    if (pipelineResult.annotations.evidenceGapWarning) {\n      extraData.evidenceGapWarning = pipelineResult.annotations.evidenceGapWarning;\n    }\n\n    if (detectedIntent) {\n      extraData.intent = {\n        type: detectedIntent,\n        confidence: intentConfidence,\n        description: intentClassifier.getIntentDescription(detectedIntent as IntentType),\n        weightsApplied: pipelineResult.metadata.stage2.intentWeightsApplied,\n      };\n    }\n\n    if (artifactRouting) {\n      extraData.artifactRouting = artifactRouting;\n      extraData.artifact_routing = artifactRouting;\n    }\n\n    if (pipelineResult.metadata.stage2.feedbackSignalsApplied === 'applied') {\n      extraData.feedbackSignals = { applied: true };\n      extraData.feedback_signals = { applied: true };\n    }\n\n    if (pipelineResult.metadata.stage2.graphContribution) {\n      extraData.graphContribution = pipelineResult.metadata.stage2.graphContribution;\n      extraData.graph_contribution = pipelineResult.metadata.stage2.graphContribution;\n    }\n\n    if (pipelineResult.metadata.stage3.rerankApplied) {\n      extraData.rerankMetadata = {\n        reranking_enabled: true,\n        reranking_requested: true,\n        reranking_applied: true,\n      };\n    }\n\n    if (pipelineResult.metadata.stage3.chunkReassemblyStats.chunkParents > 0) {\n      extraData.chunkReassembly = pipelineResult.metadata.stage3.chunkReassemblyStats;\n      extraData.chunk_reassembly = pipelineResult.metadata.stage3.chunkReassemblyStats;\n    }\n    extraData.sourceContract = {\n      version: CANONICAL_READER_CACHE_VERSION,\n      archivedTierEnabled: false,\n      legacyFallbackEnabled: false,\n      includeArchivedCompatibility: includeArchivedRequested === true ? 'ignored' : 'not_requested',\n      preferredDocumentTypes: ['spec_doc', 'continuity'],\n      retainedResults: canonicalFilter.stats.retained,\n      droppedNonCanonicalResults: canonicalFilter.stats.dropped,\n      countsBySourceKind: canonicalFilter.stats.bySourceKind,\n    };\n\n    if (includeTrace && pipelineResult.trace) {\n      extraData.retrievalTrace = pipelineResult.trace;\n      extraData.vectorDegradation = buildVectorDegradationSignal(vectorIndex.isVectorSearchAvailable());\n      extraData.vector_degradation = extraData.vectorDegradation;\n    }\n    const degradedReadiness = mapGraphReadinessToTelemetry(\n      getGraphReadinessSnapshotFromMarker(),\n    );\n    searchDecisionEnvelope = buildSearchDecisionEnvelope({\n      requestId: searchDecisionRequestId,\n      tenantId: normalizedScope.tenantId,\n      userId: normalizedScope.userId,\n      agentId: normalizedScope.agentId,\n      queryPlan,\n      trustTreeInput: {\n        responsePolicy: {\n          state: 'live',\n          decision: 'memory_search_response',\n        },\n      },\n      degradedReadiness,\n      pipelineTiming: pipelineResult.metadata.timing,\n      timestamp: new Date(_searchStartTime).toISOString(),\n      latencyMs: Date.now() - _searchStartTime,\n    });\n    extraData.searchDecisionEnvelope = searchDecisionEnvelope;\n    extraData.search_decision_envelope = searchDecisionEnvelope;\n    try {\n      const adaptiveShadow = buildAdaptiveShadowProposal(\n        requireDb(),\n        effectiveQuery,\n        resultsForFormatting as Array<Record<string, unknown> & { id: number }>,\n      );\n      if (adaptiveShadow) {\n        extraData.adaptiveShadow = adaptiveShadow;\n        extraData.adaptive_shadow = adaptiveShadow;\n      }\n    } catch (_error: unknown) {","lineStart":1,"lineEnd":1382,"totalLines":1383,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781763777867,"end":1781763777872}},"metadata":{"openai":{"itemId":"fc_0d5b12e0056d81cf016a338ec1bf8c819182e2d7a4f208adb5"}},"id":"prt_ed965a5440016JsqSGxJkDk83l","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96570b6001iiEKAma30bzCSA"}}
{"type":"tool_use","timestamp":1781763777884,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_O6aPZZWpMsAHkzVdN0FCtxtZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Orchestrator\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-stage pipeline execution with per-stage error handling and timeouts.\n5: //\n6: // Each stage is wrapped in try/catch with withTimeout().\n7: // Stage 1 is mandatory (throws on failure — no candidates = no results).\n8: // Stages 2-4 fall back to previous stage output with degraded metadata.\n9: // Timing is recorded for latency observability.\n10: //\n11: // I/O CONTRACT:\n12: // Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n13: // Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n14: // Key invariants:\n15: //     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n16: //     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n17: //     - Stage metadata for all four stages is included for observability\n18: //     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n19: // Side effects:\n20: //     - Delegates to each stage; see individual stage modules for their side effects\n21: \n22: import type {\n23:   PipelineConfig,\n24:   PipelineResult,\n25:   Stage1Output,\n26:   Stage2Output,\n27:   Stage3Output,\n28:   Stage4Output,\n29:   Stage4ReadonlyRow,\n30:   SignalStatus,\n31: } from './types.js';\n32: \n33: import { executeStage1 } from './stage1-candidate-gen.js';\n34: import { executeStage2 } from './stage2-fusion.js';\n35: import { executeStage3 } from './stage3-rerank.js';\n36: import { executeStage4 } from './stage4-filter.js';\n37: import { MemoryError, withTimeout } from '../../errors/core.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: 4-stage pipeline refactor\n41: \n42: \n43: /** Per-stage timeout in milliseconds. */\n44: const STAGE_TIMEOUT_MS = 10_000;\n45: \n46: /**\n47:  * Execute the 4-stage retrieval pipeline with per-stage error handling.\n48:  *\n49:  * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n50:  * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n51:  * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n52:  * Stage 4: Filter + Annotate — falls back to unfiltered results\n53:  *\n54:  * @param config Pipeline configuration derived from search args\n55:  * @returns Pipeline result with stage metadata and timing\n56:  */\n57: export async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n58:   const timing: Record<string, number> = {};\n59:   const pipelineStart = Date.now();\n60:   let degraded = false;\n61: \n62:   // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n63:   let stage1Result: Stage1Output;\n64:   try {\n65:     const t0 = Date.now();\n66:     stage1Result = await withTimeout(\n67:       executeStage1({ config }),\n68:       STAGE_TIMEOUT_MS,\n69:       'Stage 1: Candidate Generation',\n70:     );\n71:     timing.stage1 = Date.now() - t0;\n72:   } catch (err) {\n73:     throw new MemoryError(\n74:       'PIPELINE_STAGE1_FAILED',\n75:       `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n76:       { cause: err instanceof Error ? err.message : String(err) },\n77:     );\n78:   }\n79: \n80:   // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n81:   let stage2Result: Stage2Output;\n82:   try {\n83:     const t0 = Date.now();\n84:     stage2Result = await withTimeout(\n85:       executeStage2({\n86:         candidates: stage1Result.candidates,\n87:         config,\n88:         stage1Metadata: stage1Result.metadata,\n89:       }),\n90:       STAGE_TIMEOUT_MS,\n91:       'Stage 2: Fusion',\n92:     );\n93:     timing.stage2 = Date.now() - t0;\n94:   } catch (err) {\n95:     const msg = err instanceof Error ? err.message : String(err);\n96:     console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n97:     degraded = true;\n98:     stage2Result = {\n99:       scored: stage1Result.candidates,\n100:       metadata: {\n101:         sessionBoostApplied: 'failed' as SignalStatus,\n102:         causalBoostApplied: 'failed' as SignalStatus,\n103:         intentWeightsApplied: 'failed' as SignalStatus,\n104:         artifactRoutingApplied: 'failed' as SignalStatus,\n105:         feedbackSignalsApplied: 'failed' as SignalStatus,\n106:         qualityFiltered: 0,\n107:         durationMs: 0,\n108:       },\n109:     };\n110:     timing.stage2 = 0;\n111:   }\n112: \n113:   // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n114:   let stage3Result: Stage3Output;\n115:   try {\n116:     const t0 = Date.now();\n117:     stage3Result = await withTimeout(\n118:       executeStage3({\n119:         scored: stage2Result.scored,\n120:         config,\n121:       }),\n122:       STAGE_TIMEOUT_MS,\n123:       'Stage 3: Rerank',\n124:     );\n125:     timing.stage3 = Date.now() - t0;\n126:   } catch (err) {\n127:     const msg = err instanceof Error ? err.message : String(err);\n128:     console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n129:     degraded = true;\n130:     stage3Result = {\n131:       reranked: stage2Result.scored,\n132:       metadata: {\n133:         rerankApplied: false,\n134:         chunkReassemblyStats: {\n135:           collapsedChunkHits: 0,\n136:           chunkParents: 0,\n137:           reassembled: 0,\n138:           fallback: 0,\n139:         },\n140:         durationMs: 0,\n141:       },\n142:     };\n143:     timing.stage3 = 0;\n144:   }\n145: \n146:   // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n147:   let stage4Result: Stage4Output;\n148:   try {\n149:     const t0 = Date.now();\n150:     stage4Result = await withTimeout(\n151:       executeStage4({\n152:         results: stage3Result.reranked as Stage4ReadonlyRow[],\n153:         config,\n154:         stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n155:       }),\n156:       STAGE_TIMEOUT_MS,\n157:       'Stage 4: Filter',\n158:     );\n159:     timing.stage4 = Date.now() - t0;\n160:   } catch (err) {\n161:     const msg = err instanceof Error ? err.message : String(err);\n162:     console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n163:     degraded = true;\n164:     stage4Result = {\n165:       final: stage3Result.reranked as Stage4ReadonlyRow[],\n166:       metadata: {\n167:         stateFiltered: 0,\n168:         constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n169:         evidenceGapDetected: false,\n170:         durationMs: 0,\n171:       },\n172:       annotations: {\n173:         stateStats: {},\n174:         featureFlags: {},\n175:       },\n176:     };\n177:     timing.stage4 = 0;\n178:   }\n179: \n180:   timing.total = Date.now() - pipelineStart;\n181: \n182:   return {\n183:     results: stage4Result.final,\n184:     metadata: {\n185:       stage1: stage1Result.metadata,\n186:       stage2: stage2Result.metadata,\n187:       stage3: stage3Result.metadata,\n188:       stage4: stage4Result.metadata,\n189:       timing,\n190:       degraded: degraded || undefined,\n191:     },\n192:     annotations: stage4Result.annotations,\n193:     trace: config.trace,\n194:   };\n195: }\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects\n\nimport type {\n  PipelineConfig,\n  PipelineResult,\n  Stage1Output,\n  Stage2Output,\n  Stage3Output,\n  Stage4Output,\n  Stage4ReadonlyRow,\n  SignalStatus,\n} from './types.js';\n\nimport { executeStage1 } from './stage1-candidate-gen.js';\nimport { executeStage2 } from './stage2-fusion.js';\nimport { executeStage3 } from './stage3-rerank.js';\nimport { executeStage4 } from './stage4-filter.js';\nimport { MemoryError, withTimeout } from '../../errors/core.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: 4-stage pipeline refactor\n\n\n/** Per-stage timeout in milliseconds. */\nconst STAGE_TIMEOUT_MS = 10_000;\n\n/**\n * Execute the 4-stage retrieval pipeline with per-stage error handling.\n *\n * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n * Stage 4: Filter + Annotate — falls back to unfiltered results\n *\n * @param config Pipeline configuration derived from search args\n * @returns Pipeline result with stage metadata and timing\n */\nexport async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n  const timing: Record<string, number> = {};\n  const pipelineStart = Date.now();\n  let degraded = false;\n\n  // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n  let stage1Result: Stage1Output;\n  try {\n    const t0 = Date.now();\n    stage1Result = await withTimeout(\n      executeStage1({ config }),\n      STAGE_TIMEOUT_MS,\n      'Stage 1: Candidate Generation',\n    );\n    timing.stage1 = Date.now() - t0;\n  } catch (err) {\n    throw new MemoryError(\n      'PIPELINE_STAGE1_FAILED',\n      `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n      { cause: err instanceof Error ? err.message : String(err) },\n    );\n  }\n\n  // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n  let stage2Result: Stage2Output;\n  try {\n    const t0 = Date.now();\n    stage2Result = await withTimeout(\n      executeStage2({\n        candidates: stage1Result.candidates,\n        config,\n        stage1Metadata: stage1Result.metadata,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 2: Fusion',\n    );\n    timing.stage2 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n    degraded = true;\n    stage2Result = {\n      scored: stage1Result.candidates,\n      metadata: {\n        sessionBoostApplied: 'failed' as SignalStatus,\n        causalBoostApplied: 'failed' as SignalStatus,\n        intentWeightsApplied: 'failed' as SignalStatus,\n        artifactRoutingApplied: 'failed' as SignalStatus,\n        feedbackSignalsApplied: 'failed' as SignalStatus,\n        qualityFiltered: 0,\n        durationMs: 0,\n      },\n    };\n    timing.stage2 = 0;\n  }\n\n  // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n  let stage3Result: Stage3Output;\n  try {\n    const t0 = Date.now();\n    stage3Result = await withTimeout(\n      executeStage3({\n        scored: stage2Result.scored,\n        config,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 3: Rerank',\n    );\n    timing.stage3 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n    degraded = true;\n    stage3Result = {\n      reranked: stage2Result.scored,\n      metadata: {\n        rerankApplied: false,\n        chunkReassemblyStats: {\n          collapsedChunkHits: 0,\n          chunkParents: 0,\n          reassembled: 0,\n          fallback: 0,\n        },\n        durationMs: 0,\n      },\n    };\n    timing.stage3 = 0;\n  }\n\n  // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n  let stage4Result: Stage4Output;\n  try {\n    const t0 = Date.now();\n    stage4Result = await withTimeout(\n      executeStage4({\n        results: stage3Result.reranked as Stage4ReadonlyRow[],\n        config,\n        stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 4: Filter',\n    );\n    timing.stage4 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n    degraded = true;\n    stage4Result = {\n      final: stage3Result.reranked as Stage4ReadonlyRow[],\n      metadata: {\n        stateFiltered: 0,\n        constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n        evidenceGapDetected: false,\n        durationMs: 0,\n      },\n      annotations: {\n        stateStats: {},\n        featureFlags: {},\n      },\n    };\n    timing.stage4 = 0;\n  }\n\n  timing.total = Date.now() - pipelineStart;\n\n  return {\n    results: stage4Result.final,\n    metadata: {\n      stage1: stage1Result.metadata,\n      stage2: stage2Result.metadata,\n      stage3: stage3Result.metadata,\n      stage4: stage4Result.metadata,\n      timing,\n      degraded: degraded || undefined,\n    },\n    annotations: stage4Result.annotations,\n    trace: config.trace,\n  };\n}","lineStart":1,"lineEnd":195,"totalLines":195,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","time":{"start":1781763777859,"end":1781763777876}},"metadata":{"openai":{"itemId":"fc_0d5b12e0056d81cf016a338ec1bf848191b5b1b234400d7a98"}},"id":"prt_ed965a541001UlT5zDPs6Q0bqg","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96570b6001iiEKAma30bzCSA"}}
{"type":"tool_use","timestamp":1781763777885,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_DZNDeU7Vfszx1y5VCX4rHeJW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage2 Fusion\n3: // ───────────────────────────────────────────────────────────────\n4: // the rollout: 4-Stage Retrieval Pipeline\n5: //\n6: // I/O CONTRACT:\n7: // Input:  Stage2Input { candidates: PipelineRow[], config, stage1Metadata }\n8: // Output: Stage2Output { scored: PipelineRow[], metadata }\n9: // Key invariants:\n10: //     - Every score modification in the pipeline happens exactly once here\n11: //     - Intent weights are NEVER applied to hybrid results (G2 double-weighting guard)\n12: //     - scored is sorted descending by effective composite score on exit\n13: // Side effects:\n14: //     - FSRS write-back to memory_index (when trackAccess=true) — DB write\n15: //     - Learned trigger and negative-feedback reads from DB\n16: //\n17: // PURPOSE: Single point for ALL scoring signals. Intent weights are\n18: // Applied ONCE here only — this is the architectural guard against\n19: // The G2 double-weighting recurrence bug.\n20: //\n21: // SIGNAL APPLICATION ORDER (must not be reordered — 13 steps):\n22: // 1.  Session boost           — working-memory attention amplification\n23: // 1a. Recency fusion          — time-decay bonus for recent memories\n24: // 2.  Causal boost            — graph-traversal neighbor amplification\n25: // 2a. Co-activation spreading — spreading activation from top-N seeds\n26: // 2b. Community co-retrieval  — N2c inject community co-members\n27: // 2c. Graph signals           — N2a momentum + N2b causal depth\n28: // 3.  Testing effect          — FSRS strengthening write-back (trackAccess)\n29: // 4.  Intent weights          — non-hybrid search post-scoring adjustment\n30: // 5.  Artifact routing        — class-based weight boosts\n31: // 6.  Feedback signals        — learned trigger boosts + negative demotions\n32: // 6a. Retrieval rescue        — default-on trigger/sibling/backfill rescue layer\n33: // 7.  Artifact limiting       — result count cap from routing strategy\n34: // 8.  Anchor metadata         — extract named ANCHOR sections (annotation)\n35: // 9.  Validation metadata     — spec quality signals enrichment + quality scoring\n36: //\n37: // Hybrid search already applies intent-aware scoring\n38: // Internally (RRF / RSF fusion). Post-search intent weighting is\n39: // Therefore ONLY applied for non-hybrid search types (vector,\n40: // Multi-concept). Applying it to hybrid results would double-count.\n41: //\n42: // SCORE AUDIT CONTRACT: Stage 2 writes the fused `score` field (steps 1-7).\n43: // Stage 3 (rerank) MAY overwrite `score` with the reranked value and MUST\n44: // preserve the original in `stage2Score` for auditability (see F2.02 fix).\n45: // Stage 4 (filter) MUST NOT mutate any score fields — it is read-only.\n46: \n47: import type Database from 'better-sqlite3';\n48: import path from 'path';\n49: import { readFile } from 'fs/promises';\n50: \n51: import { resolveEffectiveScore } from './types.js';\n52: import type { Stage2Input, Stage2Output, PipelineRow, IntentWeightsConfig, ArtifactRoutingConfig } from './types.js';\n53: \n54: import * as sessionBoost from '../session-boost.js';\n55: import * as causalBoost from '../causal-boost.js';\n56: import {\n57:   isEnabled as isCoActivationEnabled,\n58:   spreadActivation,\n59:   getRelatedMemoryCounts,\n60:   resolveCoActivationBoostFactor,\n61: } from '../../cognitive/co-activation.js';\n62: import type { SpreadResult } from '../../cognitive/co-activation.js';\n63: import { ensureAdaptiveTables, getAdaptiveMode } from '../../cognitive/adaptive-ranking.js';\n64: import * as fsrsScheduler from '../../cognitive/fsrs-scheduler.js';\n65: import { queryLearnedTriggers } from '../learned-feedback.js';\n66: import { applyNegativeFeedback, getNegativeFeedbackStats } from '../../scoring/negative-feedback.js';\n67: import {\n68:   isNegativeFeedbackEnabled,\n69:   isCommunityDetectionEnabled,\n70:   isGraphCalibrationProfileEnabled,\n71:   isGraphSignalsEnabled,\n72:   isUsageRankingEnabled,\n73:   resolveGraphWalkRolloutState,\n74:   isLearnedStage2CombinerEnabled,\n75:   isResultProvenanceEnabled,\n76: } from '../search-flags.js';\n77: import { applyGraphContributionCalibration } from '../graph-calibration.js';\n78: import { shadowScore, extractFeatureVector, loadModel } from '@spec-kit/shared/ranking/learned-combiner';\n79: import type { LearnedModel } from '@spec-kit/shared/ranking/learned-combiner';\n80: import { getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\n81: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n82: import { requireDb } from '../../../utils/db-helpers.js';\n83: import { computeRecencyScore } from '../../scoring/folder-scoring.js';\n84: import { enrichResultsWithAnchorMetadata } from '../anchor-metadata.js';\n85: import { enrichResultsWithValidationMetadata } from '../validation-metadata.js';\n86: // Stage 2b enrichment extracted for decomposition clarity\n87: import { executeStage2bEnrichment } from './stage2b-enrichment.js';\n88: import { applyCommunityBoost } from '../../graph/community-detection.js';\n89: import { applyGraphSignals } from '../../graph/graph-signals.js';\n90: import { computeUsageBoost } from '../../graph/usage-ranking-signal.js';\n91: import { ensureUsageColumn } from '../../graph/usage-tracking.js';\n92: import { isGraphUnifiedEnabled } from '../graph-flags.js';\n93: import { resolveFusionIntentContract } from '../search-utils.js';\n94: import { sortDeterministicRows } from './ranking-contract.js';\n95: import { applyRetrievalRescueLayer, isRetrievalRescueEnabled } from '../rerank/retrieval-rescue.js';\n96: import { createLogger } from '../../utils/logger.js';\n97: \n98: // Feature catalog: 4-stage pipeline architecture\n99: // Feature catalog: MPAB chunk-to-memory aggregation\n100: \n101: \n102: // -- Internal type aliases --\n103: \n104: /** A row with a resolved numeric base score for internal use. */\n105: interface ScoredRow extends PipelineRow {\n106:   intentAdjustedScore?: number;\n107: }\n108: \n109: /** Result of the strengthenOnAccess FSRS write-back. */\n110: interface StrengthenResult {\n111:   stability: number;\n112:   difficulty: number;\n113: }\n114: \n115: interface ValidationMetadataLike {\n116:   qualityScore?: number;\n117:   specLevel?: number;\n118:   completionStatus?: 'complete' | 'partial' | 'unknown';\n119:   hasChecklist?: boolean;\n120: }\n121: \n122: // -- Constants --\n123: \n124: /** Number of top results used as seeds for co-activation spreading. */\n125: const SPREAD_ACTIVATION_TOP_N = 5;\n126: const DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH = path.join('models', 'learned-stage2-combiner.json');\n127: const logger = createLogger('stage2-fusion');\n128: \n129: /** Recency fusion weight — controls how much recency score contributes to the fused score.\n130:  *  Env-tunable via SPECKIT_RECENCY_FUSION_WEIGHT (default 0.07). */\n131: const RECENCY_FUSION_WEIGHT = parseFloat(process.env.SPECKIT_RECENCY_FUSION_WEIGHT || '') || 0.07;\n132: \n133: /** Recency fusion cap — maximum bonus a candidate can receive from recency fusion.\n134:  *  Env-tunable via SPECKIT_RECENCY_FUSION_CAP (default 0.10). */\n135: const RECENCY_FUSION_CAP = parseFloat(process.env.SPECKIT_RECENCY_FUSION_CAP || '') || 0.10;\n136: \n137: const MIN_VALIDATION_MULTIPLIER = 0.8;\n138: const MAX_VALIDATION_MULTIPLIER = 1.2;\n139: \n140: type LearnedStage2ModelCacheEntry = {\n141:   path: string;\n142:   model: LearnedModel | null;\n143: };\n144: \n145: let cachedLearnedStage2Model: LearnedStage2ModelCacheEntry | null = null;\n146: let learnedStage2ModelLoadPromise: Promise<LearnedStage2ModelCacheEntry> | null = null;\n147: let learnedStage2ModelLoadPromisePath: string | null = null;\n148: \n149: function clampMultiplier(value: number): number {\n150:   if (!Number.isFinite(value)) return 1;\n151:   if (value < MIN_VALIDATION_MULTIPLIER) return MIN_VALIDATION_MULTIPLIER;\n152:   if (value > MAX_VALIDATION_MULTIPLIER) return MAX_VALIDATION_MULTIPLIER;\n153:   return value;\n154: }\n155: \n156: function isShadowLearningModelLoadEnabled(): boolean {\n157:   return process.env.SPECKIT_SHADOW_LEARNING?.toLowerCase().trim() === 'true';\n158: }\n159: \n160: // Learned blend weight. Reads SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT\n161: // (default 0.0 → identical to today's shadow-only behavior). Clamped to\n162: // [0, 0.05] so promotion stays a small guarded blend, never a flip. The\n163: // bound is intentional: even when opted in, the manual combiner remains the\n164: // dominant signal (>=95%) and the learned model acts as a tiebreaker, not a\n165: // steering wheel. NaN, negative, and out-of-range values clamp to the bound.\n166: const MAX_LEARNED_BLEND_WEIGHT = 0.05;\n167: let warnedLearnedBlendClamp = false;\n168: \n169: function resolveLearnedBlendWeight(env: NodeJS.ProcessEnv = process.env): number {\n170:   const raw = env.SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT;\n171:   if (raw === undefined || raw === '') return 0;\n172:   const parsed = Number.parseFloat(raw);\n173:   if (!Number.isFinite(parsed)) return 0;\n174:   if (parsed <= 0) return 0;\n175:   if (parsed > MAX_LEARNED_BLEND_WEIGHT) {\n176:     if (!warnedLearnedBlendClamp) {\n177:       warnedLearnedBlendClamp = true;\n178:       console.warn(\n179:         `[stage2-fusion] SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT=${raw} exceeds the ${MAX_LEARNED_BLEND_WEIGHT} guard; clamping. Promotion is a small guarded blend, not a flip.`\n180:       );\n181:     }\n182:     return MAX_LEARNED_BLEND_WEIGHT;\n183:   }\n184:   return parsed;\n185: }\n186: \n187: function resolveLearnedStage2ModelPath(): string {\n188:   const configured = process.env.SPECKIT_LEARNED_STAGE2_MODEL?.trim();\n189:   if (!configured) {\n190:     return path.resolve(process.cwd(), DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH);\n191:   }\n192:   if (path.isAbsolute(configured)) {\n193:     return configured;\n194:   }\n195:   return path.resolve(process.cwd(), configured);\n196: }\n197: \n198: async function loadPersistedLearnedStage2Model(): Promise<LearnedModel | null> {\n199:   if (!isShadowLearningModelLoadEnabled()) {\n200:     return null;\n201:   }\n202: \n203:   const modelPath = resolveLearnedStage2ModelPath();\n204:   if (cachedLearnedStage2Model?.path === modelPath) {\n205:     return cachedLearnedStage2Model.model;\n206:   }\n207: \n208:   if (learnedStage2ModelLoadPromise && learnedStage2ModelLoadPromisePath === modelPath) {\n209:     return (await learnedStage2ModelLoadPromise).model;\n210:   }\n211: \n212:   if (learnedStage2ModelLoadPromisePath !== modelPath) {\n213:     learnedStage2ModelLoadPromise = null;\n214:     learnedStage2ModelLoadPromisePath = null;\n215:   }\n216: \n217:   learnedStage2ModelLoadPromisePath = modelPath;\n218:   learnedStage2ModelLoadPromise = (async (): Promise<LearnedStage2ModelCacheEntry> => {\n219:     try {\n220:       const json = await readFile(modelPath, 'utf8');\n221:       const model = loadModel(json);\n222:       if (!model) {\n223:         console.warn(`[stage2-fusion] learned stage2 model at ${modelPath} is invalid; shadow scoring will use manual-only fallback`);\n224:       }\n225:       const entry = { path: modelPath, model };\n226:       cachedLearnedStage2Model = entry;\n227:       return entry;\n228:     } catch (err: unknown) {\n229:       const entry = { path: modelPath, model: null };\n230:       cachedLearnedStage2Model = entry;\n231: \n232:       const code = typeof err === 'object' && err !== null && 'code' in err\n233:         ? String((err as { code?: unknown }).code)\n234:         : '';\n235:       if (code !== 'ENOENT') {\n236:         const message = err instanceof Error ? err.message : String(err);\n237:         console.warn(`[stage2-fusion] learned stage2 model load failed: ${message}`);\n238:       }\n239:       return entry;\n240:     } finally {\n241:       learnedStage2ModelLoadPromise = null;\n242:       learnedStage2ModelLoadPromisePath = null;\n243:     }\n244:   })();\n245: \n246:   return (await learnedStage2ModelLoadPromise).model;\n247: }\n248: \n249: /**\n250:  * Apply validation-signal scoring at the Stage 2 single scoring point.\n251:  *\n252:  * Uses quality metadata extracted from spec artifacts to apply a bounded\n253:  * multiplier over the current composite score. This keeps integrated\n254:  * in ranking while preserving score stability.\n255:  */\n256: function applyValidationSignalScoring(results: PipelineRow[]): PipelineRow[] {\n257:   if (!Array.isArray(results) || results.length === 0) return results;\n258: \n259:   const adjusted = results.map((row) => {\n260:     const metadata = row.validationMetadata as ValidationMetadataLike | undefined;\n261:     if (!metadata || typeof metadata !== 'object') return row;\n262: \n263:     const baseScore = resolveBaseScore(row);\n264:     const quality = typeof metadata.qualityScore === 'number' && Number.isFinite(metadata.qualityScore)\n265:       ? Math.max(0, Math.min(1, metadata.qualityScore))\n266:       : 0.5;\n267: \n268:     const qualityFactor = 0.9 + (quality * 0.2); // [0.9, 1.1]\n269:     const specLevelBonus = typeof metadata.specLevel === 'number' && Number.isFinite(metadata.specLevel)\n270:       ? Math.max(0, Math.min(0.06, (metadata.specLevel - 1) * 0.02))\n271:       : 0;\n272: \n273:     const completionBonus = metadata.completionStatus === 'complete'\n274:       ? 0.04\n275:       : metadata.completionStatus === 'partial'\n276:         ? 0.015\n277:         : 0;\n278: \n279:     const checklistBonus = metadata.hasChecklist ? 0.01 : 0;\n280:     const multiplier = clampMultiplier(qualityFactor + specLevelBonus + completionBonus + checklistBonus);\n281:     const scored = Math.min(1, Math.max(0, baseScore * multiplier));\n282: \n283:     if (scored === baseScore) return row;\n284:     return withSyncedScoreAliases(row, scored);\n285:   });\n286: \n287:   return sortDeterministicRows(adjusted as Array<PipelineRow & { id: number }>);\n288: }\n289: \n290: // -- Internal helpers --\n291: \n292: /**\n293:  * Replaced with shared resolveEffectiveScore()\n294:  * from types.ts. The shared function uses the correct fallback chain:\n295:  * intentAdjustedScore → rrfScore → score → similarity/100, all clamped to [0,1].\n296:  * This alias ensures all call sites use the shared implementation.\n297:  */\n298: const resolveBaseScore = resolveEffectiveScore;\n299: \n300: function withSyncedScoreAliases(row: PipelineRow, score: number): PipelineRow {\n301:   // F2.03 fix: Clamp to [0,1] so downstream consumers never see raw boosted values > 1.\n302:   const clamped = Math.max(0, Math.min(1, score));\n303:   return {\n304:     ...row,\n305:     score: clamped,\n306:     rrfScore: clamped,\n307:     intentAdjustedScore: clamped,\n308:     // Preserve attentionScore — it is set by the attention-decay module and\n309:     // must not be overwritten with the fusion/ranking score.\n310:   };\n311: }\n312: \n313: function syncScoreAliasesInPlace(rows: PipelineRow[]): void {\n314:   for (const row of rows) {\n315:     if (typeof row.score !== 'number' || !Number.isFinite(row.score)) continue;\n316:     // F2.03 fix: Clamp to [0,1] during in-place sync.\n317:     const clamped = Math.max(0, Math.min(1, row.score));\n318:     row.score = clamped;\n319:     row.rrfScore = clamped;\n320:     row.intentAdjustedScore = clamped;\n321:     // Preserve attentionScore — it is set by the attention-decay module and\n322:     // must not be overwritten with the fusion/ranking score.\n323:   }\n324: }\n325: \n326: type GraphContributionKey = 'causalDelta' | 'coActivationDelta' | 'communityDelta' | 'graphSignalDelta';\n327: \n328: function withGraphContribution(\n329:   row: PipelineRow,\n330:   key: GraphContributionKey,\n331:   delta: number,\n332:   source: string,\n333:   injected: boolean = false,\n334: ): PipelineRow {\n335:   const current = (row.graphContribution && typeof row.graphContribution === 'object')\n336:     ? row.graphContribution as Record<string, unknown>\n337:     : {};\n338:   const sources = Array.isArray(current.sources)\n339:     ? current.sources.filter((value): value is string => typeof value === 'string')\n340:     : [];\n341:   const nextSources = sources.includes(source) ? sources : [...sources, source];\n342:   const currentValue = typeof current[key] === 'number' && Number.isFinite(current[key]) ? current[key] : 0;\n343:   const totalDelta = ['causalDelta', 'coActivationDelta', 'communityDelta', 'graphSignalDelta']\n344:     .reduce((sum, field) => {\n345:       const existing = field === key ? currentValue + delta : current[field];\n346:       return sum + (typeof existing === 'number' && Number.isFinite(existing) ? existing : 0);\n347:     }, 0);\n348:   return {\n349:     ...row,\n350:     graphContribution: {\n351:       ...current,\n352:       [key]: currentValue + delta,\n353:       totalDelta,\n354:       sources: nextSources,\n355:       injected: current.injected === true || injected,\n356:     },\n357:   };\n358: }\n359: \n360: function countGraphContribution(rows: PipelineRow[], key: GraphContributionKey): number {\n361:   return rows.filter((row) => {\n362:     const graphContribution = row.graphContribution as Record<string, unknown> | undefined;\n363:     return typeof graphContribution?.[key] === 'number' && Math.abs(graphContribution[key] as number) > 0;\n364:   }).length;\n365: }\n366: \n367: function countGraphInjected(rows: PipelineRow[]): number {\n368:   return rows.filter((row) => {\n369:     const graphContribution = row.graphContribution as Record<string, unknown> | undefined;\n370:     return graphContribution?.injected === true;\n371:   }).length;\n372: }\n373: \n374: function resolveGraphContributionValue(\n375:   graphContribution: Record<string, unknown> | undefined,\n376:   key: GraphContributionKey,\n377: ): number {\n378:   const value = graphContribution?.[key];\n379:   return typeof value === 'number' && Number.isFinite(value) ? value : 0;\n380: }\n381: \n382: function resolveRowDocumentType(row: PipelineRow): string | undefined {\n383:   const candidate = row.documentType ?? row.document_type;\n384:   return typeof candidate === 'string' && candidate.length > 0 ? candidate : undefined;\n385: }\n386: \n387: function applyGraphCalibrationProfileToResults(results: PipelineRow[]): PipelineRow[] {\n388:   return results.map((row) => {\n389:     const graphContribution = row.graphContribution as Record<string, unknown> | undefined;\n390:     const originalSignals = {\n391:       causalDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'causalDelta')),\n392:       coActivationDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'coActivationDelta')),\n393:       graphSignalDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'graphSignalDelta')),\n394:       communityDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'communityDelta')),\n395:     };\n396:     const originalTotalDelta = Object.values(originalSignals).reduce((sum, value) => sum + value, 0);\n397: \n398:     if (originalTotalDelta === 0) {\n399:       return row;\n400:     }\n401: \n402:     const calibrated = applyGraphContributionCalibration(originalSignals);\n403:     const calibratedTotalDelta =\n404:       calibrated.causalDelta +\n405:       calibrated.coActivationDelta +\n406:       calibrated.communityDelta +\n407:       calibrated.graphSignalDelta;\n408: \n409:     const adjustedScore = resolveBaseScore(row)\n410:       - originalTotalDelta\n411:       + calibratedTotalDelta;\n412: \n413:     const calibratedRow = withSyncedScoreAliases(row, adjustedScore);\n414: \n415:     return {\n416:       ...calibratedRow,\n417:       graphContribution: {\n418:         ...(graphContribution ?? {}),\n419:         causalDelta: calibrated.causalDelta,\n420:         coActivationDelta: calibrated.coActivationDelta,\n421:         graphSignalDelta: calibrated.graphSignalDelta,\n422:         communityDelta: calibrated.communityDelta,\n423:         totalDelta: calibratedTotalDelta,\n424:       },\n425:     };\n426:   });\n427: }\n428: \n429: /**\n430:  * Populate graphEvidence provenance on each result that received\n431:  * a graph-based boost. Extracts contributing causal edges, co-activation edges,\n432:  * and community membership from the database. Gated behind SPECKIT_RESULT_PROVENANCE.\n433:  *\n434:  * Fail-open: returns results unchanged on any error.\n435:  */\n436: function populateGraphEvidence(results: PipelineRow[]): PipelineRow[] {\n437:   if (!isResultProvenanceEnabled()) return results;\n438:   if (!Array.isArray(results) || results.length === 0) return results;\n439: \n440:   let db: Database.Database | null = null;\n441:   try {\n442:     db = requireDb();\n443:   } catch (_err: unknown) {\n444:     return results;\n445:   }\n446: \n447:   // Collect IDs of results that received any graph-based contribution\n448:   const graphBoostedIds: number[] = [];\n449:   for (const row of results) {\n450:     const gc = row.graphContribution as Record<string, unknown> | undefined;\n451:     if (!gc) continue;\n452:     const totalDelta = typeof gc.totalDelta === 'number' ? gc.totalDelta : 0;\n453:     if (totalDelta > 0 || gc.injected === true) {\n454:       graphBoostedIds.push(row.id);\n455:     }\n456:   }\n457: \n458:   if (graphBoostedIds.length === 0) return results;\n459: \n460:   // Batch-fetch contributing causal edges for all boosted IDs\n461:   const edgeMap = new Map<number, Array<{ sourceId: number; targetId: number; relation: string; strength: number }>>();\n462:   try {\n463:     const placeholders = graphBoostedIds.map(() => '?').join(', ');\n464:     const edgeRows = (db.prepare(`\n465:       SELECT source_id, target_id, relation, COALESCE(strength, 1.0) AS strength\n466:       FROM causal_edges\n467:       WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n468:     `) as Database.Statement).all(\n469:       ...graphBoostedIds.map(String),\n470:       ...graphBoostedIds.map(String),\n471:     ) as Array<{ source_id: number; target_id: number; relation: string; strength: number }>;\n472: \n473:     for (const edge of edgeRows) {\n474:       const sourceId = typeof edge.source_id === 'number' ? edge.source_id : Number(edge.source_id);\n475:       const targetId = typeof edge.target_id === 'number' ? edge.target_id : Number(edge.target_id);\n476:       if (!Number.isFinite(sourceId) || !Number.isFinite(targetId)) continue;\n477: \n478:       const entry = {\n479:         sourceId,\n480:         targetId,\n481:         relation: typeof edge.relation === 'string' ? edge.relation : 'unknown',\n482:         strength: typeof edge.strength === 'number' && Number.isFinite(edge.strength) ? edge.strength : 1.0,\n483:       };\n484: \n485:       // Associate edge with both source and target if they are in the boosted set\n486:       const boostedIdSet = new Set(graphBoostedIds);\n487:       for (const id of [sourceId, targetId]) {\n488:         if (boostedIdSet.has(id)) {\n489:           const existing = edgeMap.get(id) ?? [];\n490:           existing.push(entry);\n491:           edgeMap.set(id, existing);\n492:         }\n493:       }\n494:     }\n495:   } catch (err: unknown) {\n496:     const message = err instanceof Error ? err.message : String(err);\n497:     console.warn(`[stage2-fusion] provenance edge fetch failed: ${message}`);\n498:   }\n499: \n500:   // Batch-fetch community memberships for boosted IDs\n501:   const communityMap = new Map<number, Array<{ communityId: number; summary?: string }>>();\n502:   try {\n503:     const placeholders = graphBoostedIds.map(() => '?').join(', ');\n504:     const communityRows = (db.prepare(`\n505:       SELECT cm.memory_id, cm.community_id, c.summary\n506:       FROM community_members cm\n507:       LEFT JOIN communities c ON c.id = cm.community_id\n508:       WHERE cm.memory_id IN (${placeholders})\n509:     `) as Database.Statement).all(\n510:       ...graphBoostedIds.map(String),\n511:     ) as Array<{ memory_id: number; community_id: number; summary?: string }>;\n512: \n513:     for (const row of communityRows) {\n514:       const memoryId = typeof row.memory_id === 'number' ? row.memory_id : Number(row.memory_id);\n515:       if (!Number.isFinite(memoryId)) continue;\n516:       const existing = communityMap.get(memoryId) ?? [];\n517:       existing.push({\n518:         communityId: typeof row.community_id === 'number' ? row.community_id : Number(row.community_id),\n519:         summary: typeof row.summary === 'string' ? row.summary : undefined,\n520:       });\n521:       communityMap.set(memoryId, existing);\n522:     }\n523:   } catch (err: unknown) {\n524:     // Community tables may not exist — fail-open\n525:     const message = err instanceof Error ? err.message : String(err);\n526:     console.warn(`[stage2-fusion] provenance community fetch failed (non-fatal): ${message}`);\n527:   }\n528: \n529:   // Attach graphEvidence to each boosted result\n530:   return results.map((row) => {\n531:     const gc = row.graphContribution as Record<string, unknown> | undefined;\n532:     if (!gc) return row;\n533:     const totalDelta = typeof gc.totalDelta === 'number' ? gc.totalDelta : 0;\n534:     if (totalDelta <= 0 && gc.injected !== true) return row;\n535: \n536:     const edges = edgeMap.get(row.id) ?? [];\n537:     const communities = communityMap.get(row.id) ?? [];\n538: \n539:     // Build boost factors from the graph contribution deltas\n540:     const boostFactors: Array<{ type: string; delta: number }> = [];\n541:     const causalDelta = typeof gc.causalDelta === 'number' ? gc.causalDelta : 0;\n542:     const coActivationDelta = typeof gc.coActivationDelta === 'number' ? gc.coActivationDelta : 0;\n543:     const communityDelta = typeof gc.communityDelta === 'number' ? gc.communityDelta : 0;\n544:     const graphSignalDelta = typeof gc.graphSignalDelta === 'number' ? gc.graphSignalDelta : 0;\n545: \n546:     if (causalDelta !== 0) boostFactors.push({ type: 'causal', delta: causalDelta });\n547:     if (coActivationDelta !== 0) boostFactors.push({ type: 'co-activation', delta: coActivationDelta });\n548:     if (communityDelta !== 0) boostFactors.push({ type: 'community', delta: communityDelta });\n549:     if (graphSignalDelta !== 0) boostFactors.push({ type: 'graph-signals', delta: graphSignalDelta });\n550: \n551:     return {\n552:       ...row,\n553:       graphEvidence: {\n554:         edges,\n555:         communities,\n556:         boostFactors,\n557:       },\n558:     };\n559:   });\n560: }\n561: \n562: /**\n563:  * Write an FSRS strengthening update for a single memory access.\n564:  *\n565:  * Mirrors the `strengthenOnAccess` logic from the legacy memory-search\n566:  * handler. Uses GRADE_GOOD with a difficulty bonus inversely proportional\n567:  * to current retrievability, so low-retrievability memories receive the\n568:  * largest stability boost.\n569:  *\n570:  * @param db             - Active SQLite connection\n571:  * @param memoryId       - ID of the memory being strengthened\n572:  * @param retrievability - Current retrievability R(t) in [0, 1]\n573:  */\n574: function strengthenOnAccess(\n575:   db: Database.Database,\n576:   memoryId: number,\n577:   retrievability: number\n578: ): StrengthenResult | null {\n579:   if (typeof memoryId !== 'number' || !Number.isFinite(memoryId)) return null;\n580: \n581:   const clampedR = (typeof retrievability === 'number' && retrievability >= 0 && retrievability <= 1)\n582:     ? retrievability\n583:     : 0.9;\n584: \n585:   try {\n586:     const memory = db.prepare(\n587:       'SELECT stability, difficulty, review_count FROM memory_index WHERE id = ?'\n588:     ).get(memoryId) as Record<string, unknown> | undefined;\n589: \n590:     if (!memory) return null;\n591: \n592:     const grade = fsrsScheduler.GRADE_GOOD;\n593:     const difficultyBonus = Math.max(0, (0.9 - clampedR) * 0.5);\n594: \n595:     const newStability = fsrsScheduler.updateStability(\n596:       (memory.stability as number) || fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n597:       (memory.difficulty as number) || fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n598:       grade,\n599:       clampedR\n600:     ) * (1 + difficultyBonus);\n601: \n602:     db.prepare(`\n603:       UPDATE memory_index\n604:       SET stability = ?,\n605:           last_review = CURRENT_TIMESTAMP,\n606:           review_count = review_count + 1,\n607:           access_count = access_count + 1,\n608:           last_accessed = ?\n609:       WHERE id = ?\n610:     `).run(newStability, Date.now(), memoryId);\n611: \n612:     return { stability: newStability, difficulty: (memory.difficulty as number) || fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY };\n613:   } catch (err: unknown) {\n614:     const message = err instanceof Error ? err.message : String(err);\n615:     console.warn(`[stage2-fusion] strengthenOnAccess failed for id ${memoryId}: ${message}`);\n616:     return null;\n617:   }\n618: }\n619: \n620: // -- Exported internal functions (also exposed via __testables) --\n621: \n622: /**\n623:  * Apply intent-based weights to search results.\n624:  *\n625:  * G2 PREVENTION: This function is ONLY called for non-hybrid search types.\n626:  * Hybrid search (RRF / RSF) already incorporates intent-weighted signals\n627:  * during fusion. Calling this on hybrid results would double-count intent.\n628:  *\n629:  * Weight combination:\n630:  *   intentScore = similarity * w.similarity + importance * w.importance + recency * w.recency\n631:  *\n632:  * Similarity is normalised from the raw 0–100 scale to 0–1 before the\n633:  * weighted combination so all three dimensions operate on the same scale.\n634:  * Results are sorted descending by intentAdjustedScore.\n635:  *\n636:  * @param results - Pipeline rows to score\n637:  * @param weights - Intent weight configuration {similarity, importance, recency}\n638:  * @returns New array sorted by intentAdjustedScore descending\n639:  */\n640: function applyIntentWeightsToResults(\n641:   results: PipelineRow[],\n642:   weights: IntentWeightsConfig\n643: ): PipelineRow[] {\n644:   if (!Array.isArray(results) || results.length === 0) return results;\n645:   if (!weights) return results;\n646: \n647:   const scored: ScoredRow[] = results.map((row) => {\n648:     // Normalise similarity from 0–100 to 0–1 for proper weight combination\n649:     const similarityRaw = typeof row.similarity === 'number' && Number.isFinite(row.similarity)\n650:       ? row.similarity\n651:       : resolveBaseScore(row) * 100; // fall back to base score rescaled\n652: \n653:     const similarity = Math.max(0, Math.min(1, similarityRaw / 100));\n654:     const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n655:       ? row.importance_weight\n656:       : 0.5;\n657: \n658:     // Recency: use created_at as the timestamp (ISO string stored in DB)\n659:     const recencyTimestamp = (row.created_at as string | undefined) ?? '';\n660:     const importanceTier = (row.importance_tier as string | undefined) ?? 'normal';\n661:     const recency = computeRecencyScore(recencyTimestamp, importanceTier);\n662: \n663:     const intentScore =\n664:       similarity * weights.similarity +\n665:       importance * weights.importance +\n666:       recency * weights.recency;\n667: \n668:     return {\n669:       ...row,\n670:       intentAdjustedScore: intentScore,\n671:     };\n672:   });\n673: \n674:   return scored.sort((a, b) => {\n675:     const aScore = typeof a.intentAdjustedScore === 'number' ? a.intentAdjustedScore : 0;\n676:     const bScore = typeof b.intentAdjustedScore === 'number' ? b.intentAdjustedScore : 0;\n677:     if (bScore === aScore) return (a.id ?? 0) - (b.id ?? 0);\n678:     return bScore - aScore;\n679:   });\n680: }\n681: \n682: /**\n683:  * Apply artifact routing weight boosts to results.\n684:  *\n685:  * When the routing system detected a known artifact class with non-zero\n686:  * confidence, the class strategy's `boostFactor` is applied to the\n687:  * current composite score (`score`, then `rrfScore`, then `similarity`).\n688:  * Results are re-sorted by score descending after boosting.\n689:  *\n690:  * @param results       - Pipeline rows to boost\n691:  * @param routingResult - Artifact routing configuration from Stage 1\n692:  * @returns New array with updated scores, sorted descending\n693:  */\n694: function applyArtifactRouting(\n695:   results: PipelineRow[],\n696:   routingResult: ArtifactRoutingConfig\n697: ): PipelineRow[] {\n698:   if (!Array.isArray(results) || results.length === 0) return results;\n699:   if (!routingResult || routingResult.confidence <= 0) return results;\n700: \n701:   // Obtain boostFactor from the strategy object (passed through config)\n702:   const strategy = routingResult.strategy as { boostFactor?: number; maxResults?: number };\n703:   const boostFactor = typeof strategy?.boostFactor === 'number'\n704:     ? Math.max(0, Math.min(2, strategy.boostFactor))\n705:     : 1.0;\n706: \n707:   if (boostFactor === 1.0) {\n708:     // No boost; still re-sort for consistency\n709:     return sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n710:   }\n711: \n712:   const boosted = results.map((row) => {\n713:     const baseScore = resolveBaseScore(row);\n714:     const boostedScore = baseScore * boostFactor;\n715:     return {\n716:       ...withSyncedScoreAliases(row, boostedScore),\n717:       artifactBoostApplied: boostFactor,\n718:     };\n719:   });\n720: \n721:   return sortDeterministicRows(boosted as Array<PipelineRow & { id: number }>);\n722: }\n723: \n724: /**\n725:  * Apply feedback signals — learned trigger boosts and negative feedback demotions.\n726:  *\n727:  * Learned triggers: each memory that matches the query's learned terms receives\n728:  * a proportional boost to its score (capped at 1.0). The boost magnitude uses\n729:  * `match.weight` directly because queryLearnedTriggers already applies the\n730:  * configured learned-trigger weighting (0.7x).\n731:  *\n732:  * Negative feedback: memories with wasUseful=false validations receive a\n733:  * confidence-multiplier demotion. The multiplier is batch-loaded from the DB\n734:  * then applied via applyNegativeFeedback. Feature-gated via\n735:  * SPECKIT_NEGATIVE_FEEDBACK env var.\n736:  *\n737:  * @param results - Pipeline rows to adjust\n738:  * @param query   - Original search query (used for learned trigger matching)\n739:  * @returns New array with feedback-adjusted scores\n740:  */\n741: function applyFeedbackSignals(\n742:   results: PipelineRow[],\n743:   query: string\n744: ): PipelineRow[] {\n745:   if (!Array.isArray(results) || results.length === 0) return results;\n746: \n747:   let db: Database.Database | null = null;\n748:   try {\n749:     db = requireDb();\n750:   } catch (error: unknown) {\n751:     if (error instanceof Error) {\n752:       // DB not available — skip feedback signals gracefully\n753:       return results;\n754:     }\n755:     // DB not available — skip feedback signals gracefully\n756:     return results;\n757:   }\n758: \n759:   // -- Learned trigger boosts --\n760:   let learnedBoostMap = new Map<number, number>();\n761:   try {\n762:     const learnedMatches = queryLearnedTriggers(query, db as Parameters<typeof queryLearnedTriggers>[1]);\n763:     for (const match of learnedMatches) {\n764:       const boost = match.weight;\n765:       const existing = learnedBoostMap.get(match.memoryId) ?? 0;\n766:       learnedBoostMap.set(match.memoryId, Math.max(existing, boost));\n767:     }\n768:   } catch (err: unknown) {\n769:     const message = err instanceof Error ? err.message : String(err);\n770:     console.warn(`[stage2-fusion] learned trigger query failed: ${message}`);\n771:     learnedBoostMap = new Map();\n772:   }\n773: \n774:   // -- Negative feedback stats (batch load) --\n775:   let negativeFeedbackStats = new Map<number, { negativeCount: number; lastNegativeAt: number | null }>();\n776:   if (isNegativeFeedbackEnabled()) {\n777:     try {\n778:       const memoryIds = results.map((r) => r.id);\n779:       negativeFeedbackStats = getNegativeFeedbackStats(db as Parameters<typeof getNegativeFeedbackStats>[0], memoryIds);\n780:     } catch (err: unknown) {\n781:       const message = err instanceof Error ? err.message : String(err);\n782:       console.warn(`[stage2-fusion] negative feedback stats failed: ${message}`);\n783:     }\n784:   }\n785: \n786:   // -- Apply combined adjustments --\n787:   return results.map((row) => {\n788:     let currentScore = resolveBaseScore(row);\n789: \n790:     // Apply learned trigger boost (additive to base score, capped at 1.0)\n791:     const learnedBoost = learnedBoostMap.get(row.id) ?? 0;\n792:     if (learnedBoost > 0) {\n793:       currentScore = Math.min(1.0, currentScore + learnedBoost);\n794:     }\n795: \n796:     // Apply negative feedback demotion (multiplicative confidence multiplier)\n797:     if (isNegativeFeedbackEnabled()) {\n798:       const negStats = negativeFeedbackStats.get(row.id);\n799:       if (negStats && negStats.negativeCount > 0) {\n800:         currentScore = applyNegativeFeedback(\n801:           currentScore,\n802:           negStats.negativeCount,\n803:           negStats.lastNegativeAt\n804:         );\n805:       }\n806:     }\n807: \n808:     if (currentScore === resolveBaseScore(row)) return row;\n809: \n810:     return withSyncedScoreAliases(row, currentScore);\n811:   });\n812: }\n813: \n814: function applyUsageRankingBoost(\n815:   db: Database.Database,\n816:   results: PipelineRow[],\n817: ): PipelineRow[] {\n818:   if (!isUsageRankingEnabled() || !Array.isArray(results) || results.length === 0) {\n819:     return results;\n820:   }\n821: \n822:   try {\n823:     ensureUsageColumn(db);\n824:     const resultIds = results\n825:       .map((row) => row.id)\n826:       .filter((id): id is number => typeof id === 'number' && Number.isFinite(id));\n827: \n828:     if (resultIds.length === 0) {\n829:       return results;\n830:     }\n831: \n832:     const placeholders = resultIds.map(() => '?').join(',');\n833:     const usageRows = db.prepare(`\n834:       SELECT id, COALESCE(access_count, 0) AS access_count\n835:       FROM memory_index\n836:       WHERE id IN (${placeholders})\n837:     `).all(...resultIds) as Array<{ id: number; access_count: number }>;\n838: \n839:     if (usageRows.length === 0) {\n840:       return results;\n841:     }\n842: \n843:     const maxAccess = usageRows.reduce((currentMax, row) =>\n844:       Math.max(currentMax, Number.isFinite(row.access_count) ? row.access_count : 0), 0);\n845: \n846:     if (maxAccess <= 0) {\n847:       return results;\n848:     }\n849: \n850:     const usageMap = new Map(usageRows.map((row) => [row.id, row.access_count]));\n851:     const boosted = results.map((row) => {\n852:       const accessCount = usageMap.get(row.id) ?? 0;\n853:       const usageBoost = computeUsageBoost(accessCount, maxAccess);\n854: \n855:       if (usageBoost <= 0) {\n856:         return row;\n857:       }\n858: \n859:       return {\n860:         ...withSyncedScoreAliases(row, resolveBaseScore(row) + usageBoost),\n861:         usageBoost,\n862:       };\n863:     });\n864: \n865:     return sortDeterministicRows(boosted as Array<PipelineRow & { id: number }>);\n866:   } catch (err: unknown) {\n867:     const message = err instanceof Error ? err.message : String(err);\n868:     console.warn(`[stage2-fusion] usage ranking failed: ${message}`);\n869:     return results;\n870:   }\n871: }\n872: \n873: /**\n874:  * Apply FSRS testing effect (strengthening write-back) for all accessed memories.\n875:  *\n876:  * Called only when `trackAccess` is true (explicit opt-in to avoid\n877:  * unintended write side-effects during read-only searches).\n878:  *\n879:  * For each result, the current retrievability R(t) is computed from the stored\n880:  * stability and last_review fields, then `strengthenOnAccess` fires an FSRS\n881:  * GRADE_GOOD update — increasing stability proportional to how much the memory\n882:  * needed the review.\n883:  *\n884:  * Errors per-row are caught and logged; they do not abort the full set.\n885:  *\n886:  * @param db      - Active SQLite database connection\n887:  * @param results - Pipeline rows that were accessed\n888:  */\n889: function applyTestingEffect(\n890:   db: Database.Database,\n891:   results: PipelineRow[]\n892: ): void {\n893:   if (!db || !Array.isArray(results) || results.length === 0) return;\n894: \n895:   for (const row of results) {\n896:     try {\n897:       const lastReview = (row.last_review as string | undefined | null) || (row.created_at as string | undefined);\n898:       if (!lastReview) continue;\n899: \n900:       const stability = typeof row.stability === 'number' && Number.isFinite(row.stability)\n901:         ? row.stability\n902:         : fsrsScheduler.DEFAULT_INITIAL_STABILITY;\n903: \n904:       const elapsedDays = fsrsScheduler.calculateElapsedDays(lastReview);\n905:       const currentR = fsrsScheduler.calculateRetrievability(\n906:         stability,\n907:         Math.max(0, elapsedDays)\n908:       );\n909: \n910:       strengthenOnAccess(db, row.id, currentR);\n911:     } catch (err: unknown) {\n912:       const message = err instanceof Error ? err.message : String(err);\n913:       console.warn(`[stage2-fusion] applyTestingEffect failed for id ${row.id}: ${message}`);\n914:     }\n915:   }\n916: }\n917: \n918: function recordAdaptiveAccessSignals(\n919:   db: Database.Database,\n920:   results: PipelineRow[],\n921:   query: string | undefined\n922: ): void {\n923:   if (!db || !Array.isArray(results) || results.length === 0) return;\n924: \n925:   if (getAdaptiveMode() === 'disabled') return;\n926: \n927:   ensureAdaptiveTables(db);\n928:   const insertAdaptiveSignal = db.prepare(`\n929:     INSERT INTO adaptive_signal_events (memory_id, signal_type, signal_value, query, actor, metadata)\n930:     VALUES (?, ?, ?, ?, ?, ?)\n931:   `);\n932:   const writeAdaptiveSignals = db.transaction((accessedResults: PipelineRow[]) => {\n933:     for (const result of accessedResults) {\n934:       insertAdaptiveSignal.run(\n935:         result.id,\n936:         'access',\n937:         1.0,\n938:         query || '',\n939:         '',\n940:         '{}',\n941:       );\n942:     }\n943:   });\n944: \n945:   try {\n946:     writeAdaptiveSignals(results);\n947:   } catch (err: unknown) {\n948:     // Adaptive signal capture must never block the core search pipeline.\n949:     console.warn('[stage2-fusion] adaptive access signal write failed:', (err as Error)?.message ?? err);\n950:   }\n951: }\n952: \n953: // -- Main Stage 2 entry point --\n954: \n955: /**\n956:  * Execute Stage 2: Fusion + Signal Integration.\n957:  *\n958:  * This is the SINGLE authoritative point where all scoring signals are\n959:  * applied. The ordering is fixed and must not be changed without updating\n960:  * the architectural documentation (see types.ts Stage2 comment block).\n961:  *\n962:  * Signal application order (13 steps):\n963:  *   1.  Session boost      (hybrid only — working memory attention)\n964:  *   1a. Recency fusion     (all types — time-decay bonus)\n965:  *   2.  Causal boost       (hybrid only — graph-traversal amplification)\n966:  *   2a. Co-activation      (spreading activation from top-N seeds)\n967:  *   2b. Community boost    (N2c — inject co-members)\n968:  *   2c. Graph signals      (N2a+N2b — momentum + depth)\n969:  *   3.  Testing effect     (all types, when trackAccess = true)\n970:  *   4.  Intent weights     (non-hybrid only — G2 prevention)\n971:  *   5.  Artifact routing   (all types, when routing confidence > 0)\n972:  *   6.  Feedback signals   (all types — learned triggers + negative feedback)\n973:  *   7.  Artifact limiting  (trim to strategy.maxResults if routing active)\n974:  *   8.  Anchor metadata    (annotation — no score mutation)\n975:  *   9.  Validation metadata (spec quality signals + quality scoring)\n976:  *\n977:  * @param input - Stage 2 input containing candidates and pipeline config\n978:  * @returns Stage 2 output with scored results and per-signal metadata\n979:  */\n980: export async function executeStage2(input: Stage2Input): Promise<Stage2Output> {\n981:   const { candidates, config } = input;\n982:   const start = Date.now();\n983: \n984:   const metadata: Stage2Output['metadata'] & { communityBoostApplied?: boolean; graphSignalsApplied?: boolean } = {\n985:     sessionBoostApplied: 'off',\n986:     causalBoostApplied: 'off',\n987:     intentWeightsApplied: 'off',\n988:     artifactRoutingApplied: 'off',\n989:     feedbackSignalsApplied: 'off',\n990:     graphContribution: {\n991:       killSwitchActive: !isGraphUnifiedEnabled(),\n992:       causalBoosted: 0,\n993:       coActivationBoosted: 0,\n994:       communityInjected: 0,\n995:       graphSignalsBoosted: 0,\n996:       totalGraphInjected: 0,\n997:       rolloutState: resolveGraphWalkRolloutState(),\n998:     },\n999:     qualityFiltered: 0,\n1000:     durationMs: 0,\n1001:   };\n1002: \n1003:   // FIX #3: Deep clone candidates so in-place mutations (e.g., syncScoreAliasesInPlace)\n1004:   // cannot corrupt the original Stage 1 output. A shallow copy ([...candidates]) shares\n1005:   // the same row objects, creating a race condition if the orchestrator's timeout fallback\n1006:   // uses the original Stage 1 candidates array.\n1007:   let results: PipelineRow[] = candidates.map(row => ({ ...row }));\n1008:   const isHybrid = config.searchType === 'hybrid';\n1009: \n1010:   // -- 1. Session boost --\n1011:   // Only for hybrid search type — session attention signals are most meaningful\n1012:   // When the full hybrid result set is available for ordering.\n1013:   if (isHybrid && config.enableSessionBoost && config.sessionId) {\n1014:     try {\n1015:       const { results: boosted, metadata: sbMeta } = sessionBoost.applySessionBoost(\n1016:         results,\n1017:         config.sessionId\n1018:       );\n1019:       results = boosted as PipelineRow[];\n1020:       // FIX #4: Sync aliases immediately after session boost score mutations\n1021:       // so rrfScore/intentAdjustedScore are not stale for subsequent steps.\n1022:       syncScoreAliasesInPlace(results);\n1023:       metadata.sessionBoostApplied = sbMeta.applied ? 'applied' : 'enabled';\n1024:     } catch (err: unknown) {\n1025:       const message = err instanceof Error ? err.message : String(err);\n1026:       console.warn(`[stage2-fusion] session boost failed: ${message}`);\n1027:       metadata.sessionBoostApplied = 'failed';\n1028:     }\n1029:   }\n1030: \n1031:   // -- 1a. Recency fusion --\n1032:   // Applies a time-decay bonus to each candidate based on its created_at timestamp.\n1033:   // Uses computeRecencyScore (already imported but previously unused in hybrid path).\n1034:   // Bonus is capped at RECENCY_FUSION_CAP and clamped to keep score in [0, 1].\n1035:   try {\n1036:     let recencyBoostedCount = 0;\n1037:     const fusionIntent = resolveFusionIntentContract({\n1038:       detectedIntent: config.detectedIntent,\n1039:       adaptiveFusionIntent: config.adaptiveFusionIntent,\n1040:       query: config.query,\n1041:     });\n1042:     const adaptiveRecencyEnabled = Boolean(fusionIntent) && isAdaptiveFusionEnabled();\n1043:     results = results.map((row) => {\n1044:       const recencyTimestamp = (row.created_at as string | undefined) ?? '';\n1045:       const importanceTier = (row.importance_tier as string | undefined) ?? 'normal';\n1046:       if (!recencyTimestamp) return row;\n1047: \n1048:       const recencyScore = computeRecencyScore(recencyTimestamp, importanceTier);\n1049:       const recencyWeight = adaptiveRecencyEnabled && fusionIntent\n1050:         ? getAdaptiveWeights(fusionIntent, resolveRowDocumentType(row)).recencyWeight\n1051:         : RECENCY_FUSION_WEIGHT;\n1052:       const bonus = Math.min(RECENCY_FUSION_CAP, recencyScore * recencyWeight);\n1053:       if (bonus <= 0) return row;\n1054: \n1055:       const baseScore = resolveBaseScore(row);\n1056:       const boostedScore = Math.min(1.0, baseScore + bonus);\n1057:       if (boostedScore === baseScore) return row;\n1058: \n1059:       recencyBoostedCount++;\n1060:       return withSyncedScoreAliases(row, boostedScore);\n1061:     });\n1062:     if (recencyBoostedCount > 0) {\n1063:       syncScoreAliasesInPlace(results);\n1064:       (metadata as Record<string, unknown>).recencyFusionApplied = true;\n1065:       (metadata as Record<string, unknown>).recencyFusionBoosted = recencyBoostedCount;\n1066:     }\n1067:   } catch (err: unknown) {\n1068:     const message = err instanceof Error ? err.message : String(err);\n1069:     console.warn(`[stage2-fusion] recency fusion failed: ${message}`);\n1070:   }\n1071: \n1072:   // -- 2. Causal boost --\n1073:   // Only for hybrid search type — causal graph traversal is seeded from the\n1074:   // Top results after session boost has re-ordered them.\n1075:   if (isHybrid && config.enableCausalBoost && isGraphUnifiedEnabled()) {\n1076:     try {\n1077:       const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n1078:       const { results: boosted, metadata: cbMeta } = causalBoost.applyCausalBoost(results);\n1079:       results = (boosted as PipelineRow[]).map((row) => {\n1080:         const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n1081:         const next = resolveBaseScore(row);\n1082:         return next !== previous\n1083:           ? withGraphContribution(row, 'causalDelta', next - previous, 'causal', row.injectedByCausalBoost === true)\n1084:           : row;\n1085:       });\n1086:       // FIX #4: Sync aliases immediately after causal boost score mutations.\n1087:       syncScoreAliasesInPlace(results);\n1088:       metadata.causalBoostApplied = cbMeta.applied ? 'applied' : 'enabled';\n1089:     } catch (err: unknown) {\n1090:       const message = err instanceof Error ? err.message : String(err);\n1091:       console.warn(`[stage2-fusion] causal boost failed: ${message}`);\n1092:       metadata.causalBoostApplied = 'failed';\n1093:     }\n1094:   }\n1095: \n1096:   // -- 2a. Co-activation spreading --\n1097:   // Gated behind SPECKIT_COACTIVATION flag. Takes the top-N results as seeds,\n1098:   // Performs spreading activation traversal, and boosts scores of results that\n1099:   // Appear in the co-activation graph. Matches V1 hybrid-search behavior.\n1100:   if (isCoActivationEnabled() && isGraphUnifiedEnabled()) {\n1101:     try {\n1102:       const topIds = results\n1103:         .slice(0, SPREAD_ACTIVATION_TOP_N)\n1104:         .map(r => r.id)\n1105:         .filter((id): id is number => typeof id === 'number');\n1106: \n1107:       if (topIds.length > 0) {\n1108:         const spreadResults: SpreadResult[] = spreadActivation(topIds);\n1109:         if (spreadResults.length > 0) {\n1110:           const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n1111:           const relatedCounts = getRelatedMemoryCounts([...new Set(spreadResults.map((result) => result.id))]);\n1112:           results = results.map((row) => {\n1113:             const boost = spreadMap.get(row.id);\n1114:             if (boost !== undefined) {\n1115:               const baseScore = resolveBaseScore(row);\n1116:               // fan-effect divisor: dampen hub nodes proportionally to their\n1117:               // fan-out degree so no single hub dominates the top-N results.\n1118:               // Uses the same sqrt scaling as co-activation.ts boostScore().\n1119:               const relatedCount = typeof row.id === 'number' ? (relatedCounts.get(row.id) ?? 0) : 0;\n1120:               const fanDivisor = Math.sqrt(Math.max(1, relatedCount));\n1121:               const updated = withSyncedScoreAliases(row, baseScore + (boost * resolveCoActivationBoostFactor()) / fanDivisor);\n1122:               return withGraphContribution(updated, 'coActivationDelta', resolveBaseScore(updated) - baseScore, 'co-activation');\n1123:             }\n1124:             return row;\n1125:           });\n1126:           // Re-sort after co-activation boost to ensure boosted results\n1127:           // Are promoted to their correct position in the ranking\n1128:           results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n1129:           (metadata as Record<string, unknown>).coActivationApplied = true;\n1130:         }\n1131:       }\n1132:     } catch (err: unknown) {\n1133:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1134:       const message = err instanceof Error ? err.message : String(err);\n1135:       console.warn(`[stage2-fusion] co-activation spreading failed: ${message}`);\n1136:     }\n1137:   }\n1138: \n1139:   // -- 2b. Community co-retrieval (N2c) --\n1140:   // Inject community co-members into result set before graph signals\n1141:   // So injected rows also receive momentum/depth adjustments.\n1142:   if (isCommunityDetectionEnabled() && isGraphUnifiedEnabled()) {\n1143:     const beforeCommunityIds = new Set(results.map((row) => row.id));\n1144:     try {\n1145:       const db = requireDb();\n1146:       const boosted = applyCommunityBoost(results, db);\n1147:       if (boosted.length > results.length) {\n1148:         results = (boosted as PipelineRow[]).map((row) => beforeCommunityIds.has(row.id)\n1149:           ? row\n1150:           : withGraphContribution(row, 'communityDelta', 0, 'community', true));\n1151:         (metadata as Record<string, unknown>).communityBoostApplied = true;\n1152:       }\n1153:     } catch (err: unknown) {\n1154:       const message = err instanceof Error ? err.message : String(err);\n1155:       console.warn(`[stage2-fusion] community boost failed: ${message}`);\n1156:     }\n1157: \n1158:     const injectedIds = results\n1159:       .filter((row) => !beforeCommunityIds.has(row.id) && typeof row.id === 'number')\n1160:       .map((row) => row.id);\n1161:     if (injectedIds.length > 0) {\n1162:       try {\n1163:         const db = requireDb();\n1164:         const placeholders = injectedIds.map(() => '?').join(',');\n1165:         const stateRows = db.prepare(\n1166:           `SELECT id, memory_state FROM memory_index WHERE id IN (${placeholders})`\n1167:         ).all(...injectedIds) as Array<{ id: number; memory_state?: string }>;\n1168:         const stateMap = new Map(stateRows.map((row) => [row.id, row.memory_state]));\n1169:         const injectedIdSet = new Set(injectedIds);\n1170:         for (const row of results) {\n1171:           const rowId = typeof row.id === 'number' ? row.id : null;\n1172:           if (rowId === null || !injectedIdSet.has(rowId)) {\n1173:             continue;\n1174:           }\n1175:           const hydratedState = stateMap.get(rowId);\n1176:           if (typeof hydratedState === 'string') {\n1177:             row.memoryState = hydratedState;\n1178:           }\n1179:         }\n1180:       } catch (err: unknown) {\n1181:         console.warn('[stage2] Community state hydration failed:', err instanceof Error ? err.message : err);\n1182:       }\n1183:     }\n1184:   }\n1185: \n1186:   // -- 2c. Graph signals (N2a + N2b) --\n1187:   // Additive score adjustments for graph momentum and causal depth.\n1188:   if (isGraphSignalsEnabled() && isGraphUnifiedEnabled()) {\n1189:     try {\n1190:       const db = requireDb();\n1191:       const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n1192:       const signaled = applyGraphSignals(results, db, {\n1193:         rolloutState: resolveGraphWalkRolloutState(),\n1194:       });\n1195:       results = (signaled as PipelineRow[]).map((row) => {\n1196:         const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n1197:         const next = resolveBaseScore(row);\n1198:         return next !== previous\n1199:           ? withGraphContribution(row, 'graphSignalDelta', next - previous, 'graph-signals')\n1200:           : row;\n1201:       });\n1202:       // FIX #4: Sync aliases immediately after graph signal score mutations.\n1203:       syncScoreAliasesInPlace(results);\n1204:       if (isGraphCalibrationProfileEnabled()) {\n1205:         results = applyGraphCalibrationProfileToResults(results);\n1206:         syncScoreAliasesInPlace(results);\n1207:       }\n1208:       (metadata as Record<string, unknown>).graphSignalsApplied = true;\n1209:     } catch (err: unknown) {\n1210:       const message = err instanceof Error ? err.message : String(err);\n1211:       console.warn(`[stage2-fusion] graph signals failed: ${message}`);\n1212:     }\n1213:   }\n1214: \n1215:   // -- 2d. Usage-weighted ranking --\n1216:   if (isUsageRankingEnabled()) {\n1217:     try {\n1218:       const db = requireDb();\n1219:       results = applyUsageRankingBoost(db, results);\n1220:     } catch (err: unknown) {\n1221:       const message = err instanceof Error ? err.message : String(err);\n1222:       console.warn(`[stage2-fusion] usage ranking skipped (db unavailable): ${message}`);\n1223:     }\n1224:   }\n1225: \n1226:   // -- 2e. Graph evidence provenance --\n1227:   // Populate graphEvidence on results that received graph-based boosts.\n1228:   // Gated behind SPECKIT_RESULT_PROVENANCE. Fail-open.\n1229:   try {\n1230:     results = populateGraphEvidence(results);\n1231:   } catch (err: unknown) {\n1232:     const message = err instanceof Error ? err.message : String(err);\n1233:     console.warn(`[stage2-fusion] graph evidence provenance failed: ${message}`);\n1234:   }\n1235: \n1236:   // -- 3. Testing effect (FSRS write-back) --\n1237:   // Only when explicitly opted in via trackAccess.\n1238:   // Write-back is fire-and-forget; errors per-row are swallowed inside\n1239:   // ApplyTestingEffect so they never abort the pipeline.\n1240:   if (config.trackAccess) {\n1241:     try {\n1242:       const db = requireDb();\n1243:       applyTestingEffect(db, results);\n1244:       recordAdaptiveAccessSignals(db, results, config.query);\n1245:     } catch (err: unknown) {\n\n(Output capped at 50 KB. Showing lines 1-1245. Use offset=1246 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage2 Fusion\n// ───────────────────────────────────────────────────────────────\n// the rollout: 4-Stage Retrieval Pipeline\n//\n// I/O CONTRACT:\n// Input:  Stage2Input { candidates: PipelineRow[], config, stage1Metadata }\n// Output: Stage2Output { scored: PipelineRow[], metadata }\n// Key invariants:\n//     - Every score modification in the pipeline happens exactly once here\n//     - Intent weights are NEVER applied to hybrid results (G2 double-weighting guard)\n//     - scored is sorted descending by effective composite score on exit\n// Side effects:\n//     - FSRS write-back to memory_index (when trackAccess=true) — DB write\n//     - Learned trigger and negative-feedback reads from DB\n//\n// PURPOSE: Single point for ALL scoring signals. Intent weights are\n// Applied ONCE here only — this is the architectural guard against\n// The G2 double-weighting recurrence bug.\n//","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage2 Fusion\n// ───────────────────────────────────────────────────────────────\n// the rollout: 4-Stage Retrieval Pipeline\n//\n// I/O CONTRACT:\n// Input:  Stage2Input { candidates: PipelineRow[], config, stage1Metadata }\n// Output: Stage2Output { scored: PipelineRow[], metadata }\n// Key invariants:\n//     - Every score modification in the pipeline happens exactly once here\n//     - Intent weights are NEVER applied to hybrid results (G2 double-weighting guard)\n//     - scored is sorted descending by effective composite score on exit\n// Side effects:\n//     - FSRS write-back to memory_index (when trackAccess=true) — DB write\n//     - Learned trigger and negative-feedback reads from DB\n//\n// PURPOSE: Single point for ALL scoring signals. Intent weights are\n// Applied ONCE here only — this is the architectural guard against\n// The G2 double-weighting recurrence bug.\n//\n// SIGNAL APPLICATION ORDER (must not be reordered — 13 steps):\n// 1.  Session boost           — working-memory attention amplification\n// 1a. Recency fusion          — time-decay bonus for recent memories\n// 2.  Causal boost            — graph-traversal neighbor amplification\n// 2a. Co-activation spreading — spreading activation from top-N seeds\n// 2b. Community co-retrieval  — N2c inject community co-members\n// 2c. Graph signals           — N2a momentum + N2b causal depth\n// 3.  Testing effect          — FSRS strengthening write-back (trackAccess)\n// 4.  Intent weights          — non-hybrid search post-scoring adjustment\n// 5.  Artifact routing        — class-based weight boosts\n// 6.  Feedback signals        — learned trigger boosts + negative demotions\n// 6a. Retrieval rescue        — default-on trigger/sibling/backfill rescue layer\n// 7.  Artifact limiting       — result count cap from routing strategy\n// 8.  Anchor metadata         — extract named ANCHOR sections (annotation)\n// 9.  Validation metadata     — spec quality signals enrichment + quality scoring\n//\n// Hybrid search already applies intent-aware scoring\n// Internally (RRF / RSF fusion). Post-search intent weighting is\n// Therefore ONLY applied for non-hybrid search types (vector,\n// Multi-concept). Applying it to hybrid results would double-count.\n//\n// SCORE AUDIT CONTRACT: Stage 2 writes the fused `score` field (steps 1-7).\n// Stage 3 (rerank) MAY overwrite `score` with the reranked value and MUST\n// preserve the original in `stage2Score` for auditability (see F2.02 fix).\n// Stage 4 (filter) MUST NOT mutate any score fields — it is read-only.\n\nimport type Database from 'better-sqlite3';\nimport path from 'path';\nimport { readFile } from 'fs/promises';\n\nimport { resolveEffectiveScore } from './types.js';\nimport type { Stage2Input, Stage2Output, PipelineRow, IntentWeightsConfig, ArtifactRoutingConfig } from './types.js';\n\nimport * as sessionBoost from '../session-boost.js';\nimport * as causalBoost from '../causal-boost.js';\nimport {\n  isEnabled as isCoActivationEnabled,\n  spreadActivation,\n  getRelatedMemoryCounts,\n  resolveCoActivationBoostFactor,\n} from '../../cognitive/co-activation.js';\nimport type { SpreadResult } from '../../cognitive/co-activation.js';\nimport { ensureAdaptiveTables, getAdaptiveMode } from '../../cognitive/adaptive-ranking.js';\nimport * as fsrsScheduler from '../../cognitive/fsrs-scheduler.js';\nimport { queryLearnedTriggers } from '../learned-feedback.js';\nimport { applyNegativeFeedback, getNegativeFeedbackStats } from '../../scoring/negative-feedback.js';\nimport {\n  isNegativeFeedbackEnabled,\n  isCommunityDetectionEnabled,\n  isGraphCalibrationProfileEnabled,\n  isGraphSignalsEnabled,\n  isUsageRankingEnabled,\n  resolveGraphWalkRolloutState,\n  isLearnedStage2CombinerEnabled,\n  isResultProvenanceEnabled,\n} from '../search-flags.js';\nimport { applyGraphContributionCalibration } from '../graph-calibration.js';\nimport { shadowScore, extractFeatureVector, loadModel } from '@spec-kit/shared/ranking/learned-combiner';\nimport type { LearnedModel } from '@spec-kit/shared/ranking/learned-combiner';\nimport { getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/db-helpers.js';\nimport { computeRecencyScore } from '../../scoring/folder-scoring.js';\nimport { enrichResultsWithAnchorMetadata } from '../anchor-metadata.js';\nimport { enrichResultsWithValidationMetadata } from '../validation-metadata.js';\n// Stage 2b enrichment extracted for decomposition clarity\nimport { executeStage2bEnrichment } from './stage2b-enrichment.js';\nimport { applyCommunityBoost } from '../../graph/community-detection.js';\nimport { applyGraphSignals } from '../../graph/graph-signals.js';\nimport { computeUsageBoost } from '../../graph/usage-ranking-signal.js';\nimport { ensureUsageColumn } from '../../graph/usage-tracking.js';\nimport { isGraphUnifiedEnabled } from '../graph-flags.js';\nimport { resolveFusionIntentContract } from '../search-utils.js';\nimport { sortDeterministicRows } from './ranking-contract.js';\nimport { applyRetrievalRescueLayer, isRetrievalRescueEnabled } from '../rerank/retrieval-rescue.js';\nimport { createLogger } from '../../utils/logger.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: MPAB chunk-to-memory aggregation\n\n\n// -- Internal type aliases --\n\n/** A row with a resolved numeric base score for internal use. */\ninterface ScoredRow extends PipelineRow {\n  intentAdjustedScore?: number;\n}\n\n/** Result of the strengthenOnAccess FSRS write-back. */\ninterface StrengthenResult {\n  stability: number;\n  difficulty: number;\n}\n\ninterface ValidationMetadataLike {\n  qualityScore?: number;\n  specLevel?: number;\n  completionStatus?: 'complete' | 'partial' | 'unknown';\n  hasChecklist?: boolean;\n}\n\n// -- Constants --\n\n/** Number of top results used as seeds for co-activation spreading. */\nconst SPREAD_ACTIVATION_TOP_N = 5;\nconst DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH = path.join('models', 'learned-stage2-combiner.json');\nconst logger = createLogger('stage2-fusion');\n\n/** Recency fusion weight — controls how much recency score contributes to the fused score.\n *  Env-tunable via SPECKIT_RECENCY_FUSION_WEIGHT (default 0.07). */\nconst RECENCY_FUSION_WEIGHT = parseFloat(process.env.SPECKIT_RECENCY_FUSION_WEIGHT || '') || 0.07;\n\n/** Recency fusion cap — maximum bonus a candidate can receive from recency fusion.\n *  Env-tunable via SPECKIT_RECENCY_FUSION_CAP (default 0.10). */\nconst RECENCY_FUSION_CAP = parseFloat(process.env.SPECKIT_RECENCY_FUSION_CAP || '') || 0.10;\n\nconst MIN_VALIDATION_MULTIPLIER = 0.8;\nconst MAX_VALIDATION_MULTIPLIER = 1.2;\n\ntype LearnedStage2ModelCacheEntry = {\n  path: string;\n  model: LearnedModel | null;\n};\n\nlet cachedLearnedStage2Model: LearnedStage2ModelCacheEntry | null = null;\nlet learnedStage2ModelLoadPromise: Promise<LearnedStage2ModelCacheEntry> | null = null;\nlet learnedStage2ModelLoadPromisePath: string | null = null;\n\nfunction clampMultiplier(value: number): number {\n  if (!Number.isFinite(value)) return 1;\n  if (value < MIN_VALIDATION_MULTIPLIER) return MIN_VALIDATION_MULTIPLIER;\n  if (value > MAX_VALIDATION_MULTIPLIER) return MAX_VALIDATION_MULTIPLIER;\n  return value;\n}\n\nfunction isShadowLearningModelLoadEnabled(): boolean {\n  return process.env.SPECKIT_SHADOW_LEARNING?.toLowerCase().trim() === 'true';\n}\n\n// Learned blend weight. Reads SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT\n// (default 0.0 → identical to today's shadow-only behavior). Clamped to\n// [0, 0.05] so promotion stays a small guarded blend, never a flip. The\n// bound is intentional: even when opted in, the manual combiner remains the\n// dominant signal (>=95%) and the learned model acts as a tiebreaker, not a\n// steering wheel. NaN, negative, and out-of-range values clamp to the bound.\nconst MAX_LEARNED_BLEND_WEIGHT = 0.05;\nlet warnedLearnedBlendClamp = false;\n\nfunction resolveLearnedBlendWeight(env: NodeJS.ProcessEnv = process.env): number {\n  const raw = env.SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT;\n  if (raw === undefined || raw === '') return 0;\n  const parsed = Number.parseFloat(raw);\n  if (!Number.isFinite(parsed)) return 0;\n  if (parsed <= 0) return 0;\n  if (parsed > MAX_LEARNED_BLEND_WEIGHT) {\n    if (!warnedLearnedBlendClamp) {\n      warnedLearnedBlendClamp = true;\n      console.warn(\n        `[stage2-fusion] SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT=${raw} exceeds the ${MAX_LEARNED_BLEND_WEIGHT} guard; clamping. Promotion is a small guarded blend, not a flip.`\n      );\n    }\n    return MAX_LEARNED_BLEND_WEIGHT;\n  }\n  return parsed;\n}\n\nfunction resolveLearnedStage2ModelPath(): string {\n  const configured = process.env.SPECKIT_LEARNED_STAGE2_MODEL?.trim();\n  if (!configured) {\n    return path.resolve(process.cwd(), DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH);\n  }\n  if (path.isAbsolute(configured)) {\n    return configured;\n  }\n  return path.resolve(process.cwd(), configured);\n}\n\nasync function loadPersistedLearnedStage2Model(): Promise<LearnedModel | null> {\n  if (!isShadowLearningModelLoadEnabled()) {\n    return null;\n  }\n\n  const modelPath = resolveLearnedStage2ModelPath();\n  if (cachedLearnedStage2Model?.path === modelPath) {\n    return cachedLearnedStage2Model.model;\n  }\n\n  if (learnedStage2ModelLoadPromise && learnedStage2ModelLoadPromisePath === modelPath) {\n    return (await learnedStage2ModelLoadPromise).model;\n  }\n\n  if (learnedStage2ModelLoadPromisePath !== modelPath) {\n    learnedStage2ModelLoadPromise = null;\n    learnedStage2ModelLoadPromisePath = null;\n  }\n\n  learnedStage2ModelLoadPromisePath = modelPath;\n  learnedStage2ModelLoadPromise = (async (): Promise<LearnedStage2ModelCacheEntry> => {\n    try {\n      const json = await readFile(modelPath, 'utf8');\n      const model = loadModel(json);\n      if (!model) {\n        console.warn(`[stage2-fusion] learned stage2 model at ${modelPath} is invalid; shadow scoring will use manual-only fallback`);\n      }\n      const entry = { path: modelPath, model };\n      cachedLearnedStage2Model = entry;\n      return entry;\n    } catch (err: unknown) {\n      const entry = { path: modelPath, model: null };\n      cachedLearnedStage2Model = entry;\n\n      const code = typeof err === 'object' && err !== null && 'code' in err\n        ? String((err as { code?: unknown }).code)\n        : '';\n      if (code !== 'ENOENT') {\n        const message = err instanceof Error ? err.message : String(err);\n        console.warn(`[stage2-fusion] learned stage2 model load failed: ${message}`);\n      }\n      return entry;\n    } finally {\n      learnedStage2ModelLoadPromise = null;\n      learnedStage2ModelLoadPromisePath = null;\n    }\n  })();\n\n  return (await learnedStage2ModelLoadPromise).model;\n}\n\n/**\n * Apply validation-signal scoring at the Stage 2 single scoring point.\n *\n * Uses quality metadata extracted from spec artifacts to apply a bounded\n * multiplier over the current composite score. This keeps integrated\n * in ranking while preserving score stability.\n */\nfunction applyValidationSignalScoring(results: PipelineRow[]): PipelineRow[] {\n  if (!Array.isArray(results) || results.length === 0) return results;\n\n  const adjusted = results.map((row) => {\n    const metadata = row.validationMetadata as ValidationMetadataLike | undefined;\n    if (!metadata || typeof metadata !== 'object') return row;\n\n    const baseScore = resolveBaseScore(row);\n    const quality = typeof metadata.qualityScore === 'number' && Number.isFinite(metadata.qualityScore)\n      ? Math.max(0, Math.min(1, metadata.qualityScore))\n      : 0.5;\n\n    const qualityFactor = 0.9 + (quality * 0.2); // [0.9, 1.1]\n    const specLevelBonus = typeof metadata.specLevel === 'number' && Number.isFinite(metadata.specLevel)\n      ? Math.max(0, Math.min(0.06, (metadata.specLevel - 1) * 0.02))\n      : 0;\n\n    const completionBonus = metadata.completionStatus === 'complete'\n      ? 0.04\n      : metadata.completionStatus === 'partial'\n        ? 0.015\n        : 0;\n\n    const checklistBonus = metadata.hasChecklist ? 0.01 : 0;\n    const multiplier = clampMultiplier(qualityFactor + specLevelBonus + completionBonus + checklistBonus);\n    const scored = Math.min(1, Math.max(0, baseScore * multiplier));\n\n    if (scored === baseScore) return row;\n    return withSyncedScoreAliases(row, scored);\n  });\n\n  return sortDeterministicRows(adjusted as Array<PipelineRow & { id: number }>);\n}\n\n// -- Internal helpers --\n\n/**\n * Replaced with shared resolveEffectiveScore()\n * from types.ts. The shared function uses the correct fallback chain:\n * intentAdjustedScore → rrfScore → score → similarity/100, all clamped to [0,1].\n * This alias ensures all call sites use the shared implementation.\n */\nconst resolveBaseScore = resolveEffectiveScore;\n\nfunction withSyncedScoreAliases(row: PipelineRow, score: number): PipelineRow {\n  // F2.03 fix: Clamp to [0,1] so downstream consumers never see raw boosted values > 1.\n  const clamped = Math.max(0, Math.min(1, score));\n  return {\n    ...row,\n    score: clamped,\n    rrfScore: clamped,\n    intentAdjustedScore: clamped,\n    // Preserve attentionScore — it is set by the attention-decay module and\n    // must not be overwritten with the fusion/ranking score.\n  };\n}\n\nfunction syncScoreAliasesInPlace(rows: PipelineRow[]): void {\n  for (const row of rows) {\n    if (typeof row.score !== 'number' || !Number.isFinite(row.score)) continue;\n    // F2.03 fix: Clamp to [0,1] during in-place sync.\n    const clamped = Math.max(0, Math.min(1, row.score));\n    row.score = clamped;\n    row.rrfScore = clamped;\n    row.intentAdjustedScore = clamped;\n    // Preserve attentionScore — it is set by the attention-decay module and\n    // must not be overwritten with the fusion/ranking score.\n  }\n}\n\ntype GraphContributionKey = 'causalDelta' | 'coActivationDelta' | 'communityDelta' | 'graphSignalDelta';\n\nfunction withGraphContribution(\n  row: PipelineRow,\n  key: GraphContributionKey,\n  delta: number,\n  source: string,\n  injected: boolean = false,\n): PipelineRow {\n  const current = (row.graphContribution && typeof row.graphContribution === 'object')\n    ? row.graphContribution as Record<string, unknown>\n    : {};\n  const sources = Array.isArray(current.sources)\n    ? current.sources.filter((value): value is string => typeof value === 'string')\n    : [];\n  const nextSources = sources.includes(source) ? sources : [...sources, source];\n  const currentValue = typeof current[key] === 'number' && Number.isFinite(current[key]) ? current[key] : 0;\n  const totalDelta = ['causalDelta', 'coActivationDelta', 'communityDelta', 'graphSignalDelta']\n    .reduce((sum, field) => {\n      const existing = field === key ? currentValue + delta : current[field];\n      return sum + (typeof existing === 'number' && Number.isFinite(existing) ? existing : 0);\n    }, 0);\n  return {\n    ...row,\n    graphContribution: {\n      ...current,\n      [key]: currentValue + delta,\n      totalDelta,\n      sources: nextSources,\n      injected: current.injected === true || injected,\n    },\n  };\n}\n\nfunction countGraphContribution(rows: PipelineRow[], key: GraphContributionKey): number {\n  return rows.filter((row) => {\n    const graphContribution = row.graphContribution as Record<string, unknown> | undefined;\n    return typeof graphContribution?.[key] === 'number' && Math.abs(graphContribution[key] as number) > 0;\n  }).length;\n}\n\nfunction countGraphInjected(rows: PipelineRow[]): number {\n  return rows.filter((row) => {\n    const graphContribution = row.graphContribution as Record<string, unknown> | undefined;\n    return graphContribution?.injected === true;\n  }).length;\n}\n\nfunction resolveGraphContributionValue(\n  graphContribution: Record<string, unknown> | undefined,\n  key: GraphContributionKey,\n): number {\n  const value = graphContribution?.[key];\n  return typeof value === 'number' && Number.isFinite(value) ? value : 0;\n}\n\nfunction resolveRowDocumentType(row: PipelineRow): string | undefined {\n  const candidate = row.documentType ?? row.document_type;\n  return typeof candidate === 'string' && candidate.length > 0 ? candidate : undefined;\n}\n\nfunction applyGraphCalibrationProfileToResults(results: PipelineRow[]): PipelineRow[] {\n  return results.map((row) => {\n    const graphContribution = row.graphContribution as Record<string, unknown> | undefined;\n    const originalSignals = {\n      causalDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'causalDelta')),\n      coActivationDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'coActivationDelta')),\n      graphSignalDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'graphSignalDelta')),\n      communityDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'communityDelta')),\n    };\n    const originalTotalDelta = Object.values(originalSignals).reduce((sum, value) => sum + value, 0);\n\n    if (originalTotalDelta === 0) {\n      return row;\n    }\n\n    const calibrated = applyGraphContributionCalibration(originalSignals);\n    const calibratedTotalDelta =\n      calibrated.causalDelta +\n      calibrated.coActivationDelta +\n      calibrated.communityDelta +\n      calibrated.graphSignalDelta;\n\n    const adjustedScore = resolveBaseScore(row)\n      - originalTotalDelta\n      + calibratedTotalDelta;\n\n    const calibratedRow = withSyncedScoreAliases(row, adjustedScore);\n\n    return {\n      ...calibratedRow,\n      graphContribution: {\n        ...(graphContribution ?? {}),\n        causalDelta: calibrated.causalDelta,\n        coActivationDelta: calibrated.coActivationDelta,\n        graphSignalDelta: calibrated.graphSignalDelta,\n        communityDelta: calibrated.communityDelta,\n        totalDelta: calibratedTotalDelta,\n      },\n    };\n  });\n}\n\n/**\n * Populate graphEvidence provenance on each result that received\n * a graph-based boost. Extracts contributing causal edges, co-activation edges,\n * and community membership from the database. Gated behind SPECKIT_RESULT_PROVENANCE.\n *\n * Fail-open: returns results unchanged on any error.\n */\nfunction populateGraphEvidence(results: PipelineRow[]): PipelineRow[] {\n  if (!isResultProvenanceEnabled()) return results;\n  if (!Array.isArray(results) || results.length === 0) return results;\n\n  let db: Database.Database | null = null;\n  try {\n    db = requireDb();\n  } catch (_err: unknown) {\n    return results;\n  }\n\n  // Collect IDs of results that received any graph-based contribution\n  const graphBoostedIds: number[] = [];\n  for (const row of results) {\n    const gc = row.graphContribution as Record<string, unknown> | undefined;\n    if (!gc) continue;\n    const totalDelta = typeof gc.totalDelta === 'number' ? gc.totalDelta : 0;\n    if (totalDelta > 0 || gc.injected === true) {\n      graphBoostedIds.push(row.id);\n    }\n  }\n\n  if (graphBoostedIds.length === 0) return results;\n\n  // Batch-fetch contributing causal edges for all boosted IDs\n  const edgeMap = new Map<number, Array<{ sourceId: number; targetId: number; relation: string; strength: number }>>();\n  try {\n    const placeholders = graphBoostedIds.map(() => '?').join(', ');\n    const edgeRows = (db.prepare(`\n      SELECT source_id, target_id, relation, COALESCE(strength, 1.0) AS strength\n      FROM causal_edges\n      WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n    `) as Database.Statement).all(\n      ...graphBoostedIds.map(String),\n      ...graphBoostedIds.map(String),\n    ) as Array<{ source_id: number; target_id: number; relation: string; strength: number }>;\n\n    for (const edge of edgeRows) {\n      const sourceId = typeof edge.source_id === 'number' ? edge.source_id : Number(edge.source_id);\n      const targetId = typeof edge.target_id === 'number' ? edge.target_id : Number(edge.target_id);\n      if (!Number.isFinite(sourceId) || !Number.isFinite(targetId)) continue;\n\n      const entry = {\n        sourceId,\n        targetId,\n        relation: typeof edge.relation === 'string' ? edge.relation : 'unknown',\n        strength: typeof edge.strength === 'number' && Number.isFinite(edge.strength) ? edge.strength : 1.0,\n      };\n\n      // Associate edge with both source and target if they are in the boosted set\n      const boostedIdSet = new Set(graphBoostedIds);\n      for (const id of [sourceId, targetId]) {\n        if (boostedIdSet.has(id)) {\n          const existing = edgeMap.get(id) ?? [];\n          existing.push(entry);\n          edgeMap.set(id, existing);\n        }\n      }\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] provenance edge fetch failed: ${message}`);\n  }\n\n  // Batch-fetch community memberships for boosted IDs\n  const communityMap = new Map<number, Array<{ communityId: number; summary?: string }>>();\n  try {\n    const placeholders = graphBoostedIds.map(() => '?').join(', ');\n    const communityRows = (db.prepare(`\n      SELECT cm.memory_id, cm.community_id, c.summary\n      FROM community_members cm\n      LEFT JOIN communities c ON c.id = cm.community_id\n      WHERE cm.memory_id IN (${placeholders})\n    `) as Database.Statement).all(\n      ...graphBoostedIds.map(String),\n    ) as Array<{ memory_id: number; community_id: number; summary?: string }>;\n\n    for (const row of communityRows) {\n      const memoryId = typeof row.memory_id === 'number' ? row.memory_id : Number(row.memory_id);\n      if (!Number.isFinite(memoryId)) continue;\n      const existing = communityMap.get(memoryId) ?? [];\n      existing.push({\n        communityId: typeof row.community_id === 'number' ? row.community_id : Number(row.community_id),\n        summary: typeof row.summary === 'string' ? row.summary : undefined,\n      });\n      communityMap.set(memoryId, existing);\n    }\n  } catch (err: unknown) {\n    // Community tables may not exist — fail-open\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] provenance community fetch failed (non-fatal): ${message}`);\n  }\n\n  // Attach graphEvidence to each boosted result\n  return results.map((row) => {\n    const gc = row.graphContribution as Record<string, unknown> | undefined;\n    if (!gc) return row;\n    const totalDelta = typeof gc.totalDelta === 'number' ? gc.totalDelta : 0;\n    if (totalDelta <= 0 && gc.injected !== true) return row;\n\n    const edges = edgeMap.get(row.id) ?? [];\n    const communities = communityMap.get(row.id) ?? [];\n\n    // Build boost factors from the graph contribution deltas\n    const boostFactors: Array<{ type: string; delta: number }> = [];\n    const causalDelta = typeof gc.causalDelta === 'number' ? gc.causalDelta : 0;\n    const coActivationDelta = typeof gc.coActivationDelta === 'number' ? gc.coActivationDelta : 0;\n    const communityDelta = typeof gc.communityDelta === 'number' ? gc.communityDelta : 0;\n    const graphSignalDelta = typeof gc.graphSignalDelta === 'number' ? gc.graphSignalDelta : 0;\n\n    if (causalDelta !== 0) boostFactors.push({ type: 'causal', delta: causalDelta });\n    if (coActivationDelta !== 0) boostFactors.push({ type: 'co-activation', delta: coActivationDelta });\n    if (communityDelta !== 0) boostFactors.push({ type: 'community', delta: communityDelta });\n    if (graphSignalDelta !== 0) boostFactors.push({ type: 'graph-signals', delta: graphSignalDelta });\n\n    return {\n      ...row,\n      graphEvidence: {\n        edges,\n        communities,\n        boostFactors,\n      },\n    };\n  });\n}\n\n/**\n * Write an FSRS strengthening update for a single memory access.\n *\n * Mirrors the `strengthenOnAccess` logic from the legacy memory-search\n * handler. Uses GRADE_GOOD with a difficulty bonus inversely proportional\n * to current retrievability, so low-retrievability memories receive the\n * largest stability boost.\n *\n * @param db             - Active SQLite connection\n * @param memoryId       - ID of the memory being strengthened\n * @param retrievability - Current retrievability R(t) in [0, 1]\n */\nfunction strengthenOnAccess(\n  db: Database.Database,\n  memoryId: number,\n  retrievability: number\n): StrengthenResult | null {\n  if (typeof memoryId !== 'number' || !Number.isFinite(memoryId)) return null;\n\n  const clampedR = (typeof retrievability === 'number' && retrievability >= 0 && retrievability <= 1)\n    ? retrievability\n    : 0.9;\n\n  try {\n    const memory = db.prepare(\n      'SELECT stability, difficulty, review_count FROM memory_index WHERE id = ?'\n    ).get(memoryId) as Record<string, unknown> | undefined;\n\n    if (!memory) return null;\n\n    const grade = fsrsScheduler.GRADE_GOOD;\n    const difficultyBonus = Math.max(0, (0.9 - clampedR) * 0.5);\n\n    const newStability = fsrsScheduler.updateStability(\n      (memory.stability as number) || fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n      (memory.difficulty as number) || fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n      grade,\n      clampedR\n    ) * (1 + difficultyBonus);\n\n    db.prepare(`\n      UPDATE memory_index\n      SET stability = ?,\n          last_review = CURRENT_TIMESTAMP,\n          review_count = review_count + 1,\n          access_count = access_count + 1,\n          last_accessed = ?\n      WHERE id = ?\n    `).run(newStability, Date.now(), memoryId);\n\n    return { stability: newStability, difficulty: (memory.difficulty as number) || fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY };\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] strengthenOnAccess failed for id ${memoryId}: ${message}`);\n    return null;\n  }\n}\n\n// -- Exported internal functions (also exposed via __testables) --\n\n/**\n * Apply intent-based weights to search results.\n *\n * G2 PREVENTION: This function is ONLY called for non-hybrid search types.\n * Hybrid search (RRF / RSF) already incorporates intent-weighted signals\n * during fusion. Calling this on hybrid results would double-count intent.\n *\n * Weight combination:\n *   intentScore = similarity * w.similarity + importance * w.importance + recency * w.recency\n *\n * Similarity is normalised from the raw 0–100 scale to 0–1 before the\n * weighted combination so all three dimensions operate on the same scale.\n * Results are sorted descending by intentAdjustedScore.\n *\n * @param results - Pipeline rows to score\n * @param weights - Intent weight configuration {similarity, importance, recency}\n * @returns New array sorted by intentAdjustedScore descending\n */\nfunction applyIntentWeightsToResults(\n  results: PipelineRow[],\n  weights: IntentWeightsConfig\n): PipelineRow[] {\n  if (!Array.isArray(results) || results.length === 0) return results;\n  if (!weights) return results;\n\n  const scored: ScoredRow[] = results.map((row) => {\n    // Normalise similarity from 0–100 to 0–1 for proper weight combination\n    const similarityRaw = typeof row.similarity === 'number' && Number.isFinite(row.similarity)\n      ? row.similarity\n      : resolveBaseScore(row) * 100; // fall back to base score rescaled\n\n    const similarity = Math.max(0, Math.min(1, similarityRaw / 100));\n    const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n      ? row.importance_weight\n      : 0.5;\n\n    // Recency: use created_at as the timestamp (ISO string stored in DB)\n    const recencyTimestamp = (row.created_at as string | undefined) ?? '';\n    const importanceTier = (row.importance_tier as string | undefined) ?? 'normal';\n    const recency = computeRecencyScore(recencyTimestamp, importanceTier);\n\n    const intentScore =\n      similarity * weights.similarity +\n      importance * weights.importance +\n      recency * weights.recency;\n\n    return {\n      ...row,\n      intentAdjustedScore: intentScore,\n    };\n  });\n\n  return scored.sort((a, b) => {\n    const aScore = typeof a.intentAdjustedScore === 'number' ? a.intentAdjustedScore : 0;\n    const bScore = typeof b.intentAdjustedScore === 'number' ? b.intentAdjustedScore : 0;\n    if (bScore === aScore) return (a.id ?? 0) - (b.id ?? 0);\n    return bScore - aScore;\n  });\n}\n\n/**\n * Apply artifact routing weight boosts to results.\n *\n * When the routing system detected a known artifact class with non-zero\n * confidence, the class strategy's `boostFactor` is applied to the\n * current composite score (`score`, then `rrfScore`, then `similarity`).\n * Results are re-sorted by score descending after boosting.\n *\n * @param results       - Pipeline rows to boost\n * @param routingResult - Artifact routing configuration from Stage 1\n * @returns New array with updated scores, sorted descending\n */\nfunction applyArtifactRouting(\n  results: PipelineRow[],\n  routingResult: ArtifactRoutingConfig\n): PipelineRow[] {\n  if (!Array.isArray(results) || results.length === 0) return results;\n  if (!routingResult || routingResult.confidence <= 0) return results;\n\n  // Obtain boostFactor from the strategy object (passed through config)\n  const strategy = routingResult.strategy as { boostFactor?: number; maxResults?: number };\n  const boostFactor = typeof strategy?.boostFactor === 'number'\n    ? Math.max(0, Math.min(2, strategy.boostFactor))\n    : 1.0;\n\n  if (boostFactor === 1.0) {\n    // No boost; still re-sort for consistency\n    return sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n  }\n\n  const boosted = results.map((row) => {\n    const baseScore = resolveBaseScore(row);\n    const boostedScore = baseScore * boostFactor;\n    return {\n      ...withSyncedScoreAliases(row, boostedScore),\n      artifactBoostApplied: boostFactor,\n    };\n  });\n\n  return sortDeterministicRows(boosted as Array<PipelineRow & { id: number }>);\n}\n\n/**\n * Apply feedback signals — learned trigger boosts and negative feedback demotions.\n *\n * Learned triggers: each memory that matches the query's learned terms receives\n * a proportional boost to its score (capped at 1.0). The boost magnitude uses\n * `match.weight` directly because queryLearnedTriggers already applies the\n * configured learned-trigger weighting (0.7x).\n *\n * Negative feedback: memories with wasUseful=false validations receive a\n * confidence-multiplier demotion. The multiplier is batch-loaded from the DB\n * then applied via applyNegativeFeedback. Feature-gated via\n * SPECKIT_NEGATIVE_FEEDBACK env var.\n *\n * @param results - Pipeline rows to adjust\n * @param query   - Original search query (used for learned trigger matching)\n * @returns New array with feedback-adjusted scores\n */\nfunction applyFeedbackSignals(\n  results: PipelineRow[],\n  query: string\n): PipelineRow[] {\n  if (!Array.isArray(results) || results.length === 0) return results;\n\n  let db: Database.Database | null = null;\n  try {\n    db = requireDb();\n  } catch (error: unknown) {\n    if (error instanceof Error) {\n      // DB not available — skip feedback signals gracefully\n      return results;\n    }\n    // DB not available — skip feedback signals gracefully\n    return results;\n  }\n\n  // -- Learned trigger boosts --\n  let learnedBoostMap = new Map<number, number>();\n  try {\n    const learnedMatches = queryLearnedTriggers(query, db as Parameters<typeof queryLearnedTriggers>[1]);\n    for (const match of learnedMatches) {\n      const boost = match.weight;\n      const existing = learnedBoostMap.get(match.memoryId) ?? 0;\n      learnedBoostMap.set(match.memoryId, Math.max(existing, boost));\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] learned trigger query failed: ${message}`);\n    learnedBoostMap = new Map();\n  }\n\n  // -- Negative feedback stats (batch load) --\n  let negativeFeedbackStats = new Map<number, { negativeCount: number; lastNegativeAt: number | null }>();\n  if (isNegativeFeedbackEnabled()) {\n    try {\n      const memoryIds = results.map((r) => r.id);\n      negativeFeedbackStats = getNegativeFeedbackStats(db as Parameters<typeof getNegativeFeedbackStats>[0], memoryIds);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] negative feedback stats failed: ${message}`);\n    }\n  }\n\n  // -- Apply combined adjustments --\n  return results.map((row) => {\n    let currentScore = resolveBaseScore(row);\n\n    // Apply learned trigger boost (additive to base score, capped at 1.0)\n    const learnedBoost = learnedBoostMap.get(row.id) ?? 0;\n    if (learnedBoost > 0) {\n      currentScore = Math.min(1.0, currentScore + learnedBoost);\n    }\n\n    // Apply negative feedback demotion (multiplicative confidence multiplier)\n    if (isNegativeFeedbackEnabled()) {\n      const negStats = negativeFeedbackStats.get(row.id);\n      if (negStats && negStats.negativeCount > 0) {\n        currentScore = applyNegativeFeedback(\n          currentScore,\n          negStats.negativeCount,\n          negStats.lastNegativeAt\n        );\n      }\n    }\n\n    if (currentScore === resolveBaseScore(row)) return row;\n\n    return withSyncedScoreAliases(row, currentScore);\n  });\n}\n\nfunction applyUsageRankingBoost(\n  db: Database.Database,\n  results: PipelineRow[],\n): PipelineRow[] {\n  if (!isUsageRankingEnabled() || !Array.isArray(results) || results.length === 0) {\n    return results;\n  }\n\n  try {\n    ensureUsageColumn(db);\n    const resultIds = results\n      .map((row) => row.id)\n      .filter((id): id is number => typeof id === 'number' && Number.isFinite(id));\n\n    if (resultIds.length === 0) {\n      return results;\n    }\n\n    const placeholders = resultIds.map(() => '?').join(',');\n    const usageRows = db.prepare(`\n      SELECT id, COALESCE(access_count, 0) AS access_count\n      FROM memory_index\n      WHERE id IN (${placeholders})\n    `).all(...resultIds) as Array<{ id: number; access_count: number }>;\n\n    if (usageRows.length === 0) {\n      return results;\n    }\n\n    const maxAccess = usageRows.reduce((currentMax, row) =>\n      Math.max(currentMax, Number.isFinite(row.access_count) ? row.access_count : 0), 0);\n\n    if (maxAccess <= 0) {\n      return results;\n    }\n\n    const usageMap = new Map(usageRows.map((row) => [row.id, row.access_count]));\n    const boosted = results.map((row) => {\n      const accessCount = usageMap.get(row.id) ?? 0;\n      const usageBoost = computeUsageBoost(accessCount, maxAccess);\n\n      if (usageBoost <= 0) {\n        return row;\n      }\n\n      return {\n        ...withSyncedScoreAliases(row, resolveBaseScore(row) + usageBoost),\n        usageBoost,\n      };\n    });\n\n    return sortDeterministicRows(boosted as Array<PipelineRow & { id: number }>);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] usage ranking failed: ${message}`);\n    return results;\n  }\n}\n\n/**\n * Apply FSRS testing effect (strengthening write-back) for all accessed memories.\n *\n * Called only when `trackAccess` is true (explicit opt-in to avoid\n * unintended write side-effects during read-only searches).\n *\n * For each result, the current retrievability R(t) is computed from the stored\n * stability and last_review fields, then `strengthenOnAccess` fires an FSRS\n * GRADE_GOOD update — increasing stability proportional to how much the memory\n * needed the review.\n *\n * Errors per-row are caught and logged; they do not abort the full set.\n *\n * @param db      - Active SQLite database connection\n * @param results - Pipeline rows that were accessed\n */\nfunction applyTestingEffect(\n  db: Database.Database,\n  results: PipelineRow[]\n): void {\n  if (!db || !Array.isArray(results) || results.length === 0) return;\n\n  for (const row of results) {\n    try {\n      const lastReview = (row.last_review as string | undefined | null) || (row.created_at as string | undefined);\n      if (!lastReview) continue;\n\n      const stability = typeof row.stability === 'number' && Number.isFinite(row.stability)\n        ? row.stability\n        : fsrsScheduler.DEFAULT_INITIAL_STABILITY;\n\n      const elapsedDays = fsrsScheduler.calculateElapsedDays(lastReview);\n      const currentR = fsrsScheduler.calculateRetrievability(\n        stability,\n        Math.max(0, elapsedDays)\n      );\n\n      strengthenOnAccess(db, row.id, currentR);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] applyTestingEffect failed for id ${row.id}: ${message}`);\n    }\n  }\n}\n\nfunction recordAdaptiveAccessSignals(\n  db: Database.Database,\n  results: PipelineRow[],\n  query: string | undefined\n): void {\n  if (!db || !Array.isArray(results) || results.length === 0) return;\n\n  if (getAdaptiveMode() === 'disabled') return;\n\n  ensureAdaptiveTables(db);\n  const insertAdaptiveSignal = db.prepare(`\n    INSERT INTO adaptive_signal_events (memory_id, signal_type, signal_value, query, actor, metadata)\n    VALUES (?, ?, ?, ?, ?, ?)\n  `);\n  const writeAdaptiveSignals = db.transaction((accessedResults: PipelineRow[]) => {\n    for (const result of accessedResults) {\n      insertAdaptiveSignal.run(\n        result.id,\n        'access',\n        1.0,\n        query || '',\n        '',\n        '{}',\n      );\n    }\n  });\n\n  try {\n    writeAdaptiveSignals(results);\n  } catch (err: unknown) {\n    // Adaptive signal capture must never block the core search pipeline.\n    console.warn('[stage2-fusion] adaptive access signal write failed:', (err as Error)?.message ?? err);\n  }\n}\n\n// -- Main Stage 2 entry point --\n\n/**\n * Execute Stage 2: Fusion + Signal Integration.\n *\n * This is the SINGLE authoritative point where all scoring signals are\n * applied. The ordering is fixed and must not be changed without updating\n * the architectural documentation (see types.ts Stage2 comment block).\n *\n * Signal application order (13 steps):\n *   1.  Session boost      (hybrid only — working memory attention)\n *   1a. Recency fusion     (all types — time-decay bonus)\n *   2.  Causal boost       (hybrid only — graph-traversal amplification)\n *   2a. Co-activation      (spreading activation from top-N seeds)\n *   2b. Community boost    (N2c — inject co-members)\n *   2c. Graph signals      (N2a+N2b — momentum + depth)\n *   3.  Testing effect     (all types, when trackAccess = true)\n *   4.  Intent weights     (non-hybrid only — G2 prevention)\n *   5.  Artifact routing   (all types, when routing confidence > 0)\n *   6.  Feedback signals   (all types — learned triggers + negative feedback)\n *   7.  Artifact limiting  (trim to strategy.maxResults if routing active)\n *   8.  Anchor metadata    (annotation — no score mutation)\n *   9.  Validation metadata (spec quality signals + quality scoring)\n *\n * @param input - Stage 2 input containing candidates and pipeline config\n * @returns Stage 2 output with scored results and per-signal metadata\n */\nexport async function executeStage2(input: Stage2Input): Promise<Stage2Output> {\n  const { candidates, config } = input;\n  const start = Date.now();\n\n  const metadata: Stage2Output['metadata'] & { communityBoostApplied?: boolean; graphSignalsApplied?: boolean } = {\n    sessionBoostApplied: 'off',\n    causalBoostApplied: 'off',\n    intentWeightsApplied: 'off',\n    artifactRoutingApplied: 'off',\n    feedbackSignalsApplied: 'off',\n    graphContribution: {\n      killSwitchActive: !isGraphUnifiedEnabled(),\n      causalBoosted: 0,\n      coActivationBoosted: 0,\n      communityInjected: 0,\n      graphSignalsBoosted: 0,\n      totalGraphInjected: 0,\n      rolloutState: resolveGraphWalkRolloutState(),\n    },\n    qualityFiltered: 0,\n    durationMs: 0,\n  };\n\n  // FIX #3: Deep clone candidates so in-place mutations (e.g., syncScoreAliasesInPlace)\n  // cannot corrupt the original Stage 1 output. A shallow copy ([...candidates]) shares\n  // the same row objects, creating a race condition if the orchestrator's timeout fallback\n  // uses the original Stage 1 candidates array.\n  let results: PipelineRow[] = candidates.map(row => ({ ...row }));\n  const isHybrid = config.searchType === 'hybrid';\n\n  // -- 1. Session boost --\n  // Only for hybrid search type — session attention signals are most meaningful\n  // When the full hybrid result set is available for ordering.\n  if (isHybrid && config.enableSessionBoost && config.sessionId) {\n    try {\n      const { results: boosted, metadata: sbMeta } = sessionBoost.applySessionBoost(\n        results,\n        config.sessionId\n      );\n      results = boosted as PipelineRow[];\n      // FIX #4: Sync aliases immediately after session boost score mutations\n      // so rrfScore/intentAdjustedScore are not stale for subsequent steps.\n      syncScoreAliasesInPlace(results);\n      metadata.sessionBoostApplied = sbMeta.applied ? 'applied' : 'enabled';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] session boost failed: ${message}`);\n      metadata.sessionBoostApplied = 'failed';\n    }\n  }\n\n  // -- 1a. Recency fusion --\n  // Applies a time-decay bonus to each candidate based on its created_at timestamp.\n  // Uses computeRecencyScore (already imported but previously unused in hybrid path).\n  // Bonus is capped at RECENCY_FUSION_CAP and clamped to keep score in [0, 1].\n  try {\n    let recencyBoostedCount = 0;\n    const fusionIntent = resolveFusionIntentContract({\n      detectedIntent: config.detectedIntent,\n      adaptiveFusionIntent: config.adaptiveFusionIntent,\n      query: config.query,\n    });\n    const adaptiveRecencyEnabled = Boolean(fusionIntent) && isAdaptiveFusionEnabled();\n    results = results.map((row) => {\n      const recencyTimestamp = (row.created_at as string | undefined) ?? '';\n      const importanceTier = (row.importance_tier as string | undefined) ?? 'normal';\n      if (!recencyTimestamp) return row;\n\n      const recencyScore = computeRecencyScore(recencyTimestamp, importanceTier);\n      const recencyWeight = adaptiveRecencyEnabled && fusionIntent\n        ? getAdaptiveWeights(fusionIntent, resolveRowDocumentType(row)).recencyWeight\n        : RECENCY_FUSION_WEIGHT;\n      const bonus = Math.min(RECENCY_FUSION_CAP, recencyScore * recencyWeight);\n      if (bonus <= 0) return row;\n\n      const baseScore = resolveBaseScore(row);\n      const boostedScore = Math.min(1.0, baseScore + bonus);\n      if (boostedScore === baseScore) return row;\n\n      recencyBoostedCount++;\n      return withSyncedScoreAliases(row, boostedScore);\n    });\n    if (recencyBoostedCount > 0) {\n      syncScoreAliasesInPlace(results);\n      (metadata as Record<string, unknown>).recencyFusionApplied = true;\n      (metadata as Record<string, unknown>).recencyFusionBoosted = recencyBoostedCount;\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] recency fusion failed: ${message}`);\n  }\n\n  // -- 2. Causal boost --\n  // Only for hybrid search type — causal graph traversal is seeded from the\n  // Top results after session boost has re-ordered them.\n  if (isHybrid && config.enableCausalBoost && isGraphUnifiedEnabled()) {\n    try {\n      const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n      const { results: boosted, metadata: cbMeta } = causalBoost.applyCausalBoost(results);\n      results = (boosted as PipelineRow[]).map((row) => {\n        const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n        const next = resolveBaseScore(row);\n        return next !== previous\n          ? withGraphContribution(row, 'causalDelta', next - previous, 'causal', row.injectedByCausalBoost === true)\n          : row;\n      });\n      // FIX #4: Sync aliases immediately after causal boost score mutations.\n      syncScoreAliasesInPlace(results);\n      metadata.causalBoostApplied = cbMeta.applied ? 'applied' : 'enabled';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] causal boost failed: ${message}`);\n      metadata.causalBoostApplied = 'failed';\n    }\n  }\n\n  // -- 2a. Co-activation spreading --\n  // Gated behind SPECKIT_COACTIVATION flag. Takes the top-N results as seeds,\n  // Performs spreading activation traversal, and boosts scores of results that\n  // Appear in the co-activation graph. Matches V1 hybrid-search behavior.\n  if (isCoActivationEnabled() && isGraphUnifiedEnabled()) {\n    try {\n      const topIds = results\n        .slice(0, SPREAD_ACTIVATION_TOP_N)\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (topIds.length > 0) {\n        const spreadResults: SpreadResult[] = spreadActivation(topIds);\n        if (spreadResults.length > 0) {\n          const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n          const relatedCounts = getRelatedMemoryCounts([...new Set(spreadResults.map((result) => result.id))]);\n          results = results.map((row) => {\n            const boost = spreadMap.get(row.id);\n            if (boost !== undefined) {\n              const baseScore = resolveBaseScore(row);\n              // fan-effect divisor: dampen hub nodes proportionally to their\n              // fan-out degree so no single hub dominates the top-N results.\n              // Uses the same sqrt scaling as co-activation.ts boostScore().\n              const relatedCount = typeof row.id === 'number' ? (relatedCounts.get(row.id) ?? 0) : 0;\n              const fanDivisor = Math.sqrt(Math.max(1, relatedCount));\n              const updated = withSyncedScoreAliases(row, baseScore + (boost * resolveCoActivationBoostFactor()) / fanDivisor);\n              return withGraphContribution(updated, 'coActivationDelta', resolveBaseScore(updated) - baseScore, 'co-activation');\n            }\n            return row;\n          });\n          // Re-sort after co-activation boost to ensure boosted results\n          // Are promoted to their correct position in the ranking\n          results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n          (metadata as Record<string, unknown>).coActivationApplied = true;\n        }\n      }\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] co-activation spreading failed: ${message}`);\n    }\n  }\n\n  // -- 2b. Community co-retrieval (N2c) --\n  // Inject community co-members into result set before graph signals\n  // So injected rows also receive momentum/depth adjustments.\n  if (isCommunityDetectionEnabled() && isGraphUnifiedEnabled()) {\n    const beforeCommunityIds = new Set(results.map((row) => row.id));\n    try {\n      const db = requireDb();\n      const boosted = applyCommunityBoost(results, db);\n      if (boosted.length > results.length) {\n        results = (boosted as PipelineRow[]).map((row) => beforeCommunityIds.has(row.id)\n          ? row\n          : withGraphContribution(row, 'communityDelta', 0, 'community', true));\n        (metadata as Record<string, unknown>).communityBoostApplied = true;\n      }\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] community boost failed: ${message}`);\n    }\n\n    const injectedIds = results\n      .filter((row) => !beforeCommunityIds.has(row.id) && typeof row.id === 'number')\n      .map((row) => row.id);\n    if (injectedIds.length > 0) {\n      try {\n        const db = requireDb();\n        const placeholders = injectedIds.map(() => '?').join(',');\n        const stateRows = db.prepare(\n          `SELECT id, memory_state FROM memory_index WHERE id IN (${placeholders})`\n        ).all(...injectedIds) as Array<{ id: number; memory_state?: string }>;\n        const stateMap = new Map(stateRows.map((row) => [row.id, row.memory_state]));\n        const injectedIdSet = new Set(injectedIds);\n        for (const row of results) {\n          const rowId = typeof row.id === 'number' ? row.id : null;\n          if (rowId === null || !injectedIdSet.has(rowId)) {\n            continue;\n          }\n          const hydratedState = stateMap.get(rowId);\n          if (typeof hydratedState === 'string') {\n            row.memoryState = hydratedState;\n          }\n        }\n      } catch (err: unknown) {\n        console.warn('[stage2] Community state hydration failed:', err instanceof Error ? err.message : err);\n      }\n    }\n  }\n\n  // -- 2c. Graph signals (N2a + N2b) --\n  // Additive score adjustments for graph momentum and causal depth.\n  if (isGraphSignalsEnabled() && isGraphUnifiedEnabled()) {\n    try {\n      const db = requireDb();\n      const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n      const signaled = applyGraphSignals(results, db, {\n        rolloutState: resolveGraphWalkRolloutState(),\n      });\n      results = (signaled as PipelineRow[]).map((row) => {\n        const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n        const next = resolveBaseScore(row);\n        return next !== previous\n          ? withGraphContribution(row, 'graphSignalDelta', next - previous, 'graph-signals')\n          : row;\n      });\n      // FIX #4: Sync aliases immediately after graph signal score mutations.\n      syncScoreAliasesInPlace(results);\n      if (isGraphCalibrationProfileEnabled()) {\n        results = applyGraphCalibrationProfileToResults(results);\n        syncScoreAliasesInPlace(results);\n      }\n      (metadata as Record<string, unknown>).graphSignalsApplied = true;\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] graph signals failed: ${message}`);\n    }\n  }\n\n  // -- 2d. Usage-weighted ranking --\n  if (isUsageRankingEnabled()) {\n    try {\n      const db = requireDb();\n      results = applyUsageRankingBoost(db, results);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] usage ranking skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 2e. Graph evidence provenance --\n  // Populate graphEvidence on results that received graph-based boosts.\n  // Gated behind SPECKIT_RESULT_PROVENANCE. Fail-open.\n  try {\n    results = populateGraphEvidence(results);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] graph evidence provenance failed: ${message}`);\n  }\n\n  // -- 3. Testing effect (FSRS write-back) --\n  // Only when explicitly opted in via trackAccess.\n  // Write-back is fire-and-forget; errors per-row are swallowed inside\n  // ApplyTestingEffect so they never abort the pipeline.\n  if (config.trackAccess) {\n    try {\n      const db = requireDb();\n      applyTestingEffect(db, results);\n      recordAdaptiveAccessSignals(db, results, config.query);\n    } catch (err: unknown) {","lineStart":1,"lineEnd":1245,"totalLines":1246,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","time":{"start":1781763777856,"end":1781763777877}},"metadata":{"openai":{"itemId":"fc_0d5b12e0056d81cf016a338ec1bf7c8191b6f89d1dc6f2f546"}},"id":"prt_ed965a539001qOM9wiMDzPdL7J","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96570b6001iiEKAma30bzCSA"}}
{"type":"tool_use","timestamp":1781763777896,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_2shAHY8ULllBJ99AJypjQhOI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Hybrid Search\n3: // ───────────────────────────────────────────────────────────────\n4: // Combines vector, FTS, and BM25 search with fallback\n5: \n6: // 1. IMPORTS\n7: \n8: // Local\n9: import {\n10:   getIndex,\n11:   isBm25Enabled,\n12:   shouldUseSqliteLexicalEngine,\n13: } from './bm25-index.js';\n14: import { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\n15: import { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\n16: import { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\n17: import { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\n18: import { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\n19: import { fts5Bm25Search } from './sqlite-fts.js';\n20: import { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';\n21: import {\n22:   isMMREnabled,\n23:   isSearchFallbackEnabled,\n24:   isDocscoreAggregationEnabled,\n25:   isDegreeBoostEnabled,\n26:   isContextHeadersEnabled,\n27:   isArchivedRetrievalIncludedByDefault,\n28:   isCosineTopnReorderEnabled,\n29: } from './search-flags.js';\n30: import { resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n31: import { computeDegreeScores } from './graph-search-fn.js';\n32: import type { GraphSearchFn } from './search-types.js';\n33: \n34: // Feature catalog: Hybrid search pipeline\n35: \n36: export type { GraphSearchFn } from './search-types.js';\n37: \n38: import { routeQuery } from './query-router.js';\n39: import { isComplexityRouterEnabled } from './query-classifier.js';\n40: import { enforceChannelRepresentation } from './channel-enforcement.js';\n41: import {\n42:   truncateByConfidence,\n43:   isConfidenceTruncationEnabled,\n44:   DEFAULT_MIN_RESULTS,\n45:   GAP_THRESHOLD_MULTIPLIER,\n46: } from './confidence-truncation.js';\n47: import {\n48:   getDynamicTokenBudget,\n49:   isDynamicTokenBudgetEnabled,\n50:   DEFAULT_TOKEN_BUDGET_CONFIG,\n51: } from './dynamic-token-budget.js';\n52: import {\n53:   buildProgressiveResponse,\n54:   DEFAULT_PAGE_SIZE,\n55: } from './progressive-disclosure.js';\n56: import type {\n57:   ProgressiveResponse,\n58:   DisclosureResult,\n59: } from './progressive-disclosure.js';\n60: import { resolveFusionIntentContract } from './search-utils.js';\n61: import { ensureDescriptionCache, getSpecsBasePaths } from './folder-discovery.js';\n62: import {\n63:   isFolderScoringEnabled,\n64:   lookupFolders,\n65:   computeFolderRelevanceScores,\n66:   enrichResultsWithFolderScores,\n67:   twoPhaseRetrieval,\n68: } from './folder-relevance.js';\n69: import { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n70: \n71: import { collapseAndReassembleChunkResults } from '../scoring/mpab-aggregation.js';\n72: \n73: // Type-only\n74: import type Database from 'better-sqlite3';\n75: import type { SpreadResult } from '../cognitive/co-activation.js';\n76: import type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\n77: import type { FusionResult } from '@spec-kit/shared/algorithms/rrf-fusion';\n78: import type { ChannelName } from './query-router.js';\n79: import type { EnforcementResult } from './channel-enforcement.js';\n80: import type { TruncationResult } from './confidence-truncation.js';\n81: \n82: // 2. INTERFACES\n83: \n84: type VectorSearchFn = (\n85:   embedding: Float32Array | number[],\n86:   options: Record<string, unknown>\n87: ) => Array<Record<string, unknown>>;\n88: \n89: interface HybridSearchOptions {\n90:   limit?: number;\n91:   specFolder?: string;\n92:   minSimilarity?: number;\n93:   useBm25?: boolean;\n94:   useFts?: boolean;\n95:   useVector?: boolean;\n96:   useGraph?: boolean;\n97:   includeArchived?: boolean;\n98:   includeContent?: boolean;\n99:   /**\n100:    * Evaluation-only mode.\n101:    * When true, preserve the requested top-K window by bypassing confidence\n102:    * truncation and token-budget truncation without changing live defaults.\n103:    */\n104:   evaluationMode?: boolean;\n105:   /** Classified query intent for adaptive fusion weight selection (e.g. 'understand', 'fix_bug'). */\n106:   intent?: string;\n107:   /** Optional trigger phrases for query-classifier trigger-match routing path. */\n108:   triggerPhrases?: string[];\n109:   /**\n110:    * Internal fallback override: when true, bypass complexity routing and\n111:    * enable all retrieval channels for this search call.\n112:    */\n113:   forceAllChannels?: boolean;\n114:   /**\n115:    * Internal raw-candidate mode used by the Stage 1 pipeline.\n116:    * When true, stop after channel collection and return pre-fusion candidates.\n117:    */\n118:   skipFusion?: boolean;\n119:   /**\n120:    * Internal pipeline handoff mode.\n121:    * When true, return immediately after adaptive/RRF fusion so Stage 2/3 can\n122:    * apply the remaining pipeline scoring and aggregation steps.\n123:    */\n124:   stopAfterFusion?: boolean;\n125: }\n126: \n127: interface HybridSearchResult {\n128:   id: number | string;\n129:   /**\n130:    * Normalized relevance score (0-1). Semantics depend on `source`:\n131:    * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n132:    * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n133:    * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n134:    * - `'graph'` — graph traversal relevance\n135:    *\n136:    * After hybrid merge, all source scores are min-max normalized to 0-1 within\n137:    * their source group to ensure fair cross-method comparison.\n138:    */\n139:   score: number;\n140:   source: string;\n141:   title?: string;\n142:   [key: string]: unknown;\n143: }\n144: \n145: type HardExclusionSource = 'archived-tier' | 'deprecated-tier';\n146: type HardExclusionClassification = 'intended' | 'silent-risk' | 'unclassified';\n147: \n148: interface HardExclusionPredicate {\n149:   id: string;\n150:   source: HardExclusionSource;\n151:   channel: string;\n152:   predicate: string;\n153:   defaultApplied: boolean;\n154:   classification: HardExclusionClassification;\n155: }\n156: \n157: const HARD_EXCLUSION_PREDICATES: readonly HardExclusionPredicate[] = Object.freeze([\n158:   {\n159:     id: 'includeArchived-default',\n160:     source: 'archived-tier',\n161:     channel: 'vector/fts',\n162:     predicate: 'includeArchived defaults to false',\n163:     defaultApplied: true,\n164:     classification: 'intended',\n165:   },\n166:   {\n167:     id: 'fts-deprecated-tier',\n168:     source: 'deprecated-tier',\n169:     channel: 'fts',\n170:     predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n171:     defaultApplied: true,\n172:     classification: 'silent-risk',\n173:   },\n174:   {\n175:     id: 'bm25-deprecated-tier',\n176:     source: 'deprecated-tier',\n177:     channel: 'bm25',\n178:     predicate: \"importance_tier != 'deprecated'\",\n179:     defaultApplied: true,\n180:     classification: 'silent-risk',\n181:   },\n182:   {\n183:     id: 'trigger-deprecated-tier',\n184:     source: 'deprecated-tier',\n185:     channel: 'trigger',\n186:     predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n187:     defaultApplied: true,\n188:     classification: 'silent-risk',\n189:   },\n190:   {\n191:     id: 'structural-deprecated-archived-tier',\n192:     source: 'deprecated-tier',\n193:     channel: 'structural',\n194:     predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n195:     defaultApplied: true,\n196:     classification: 'silent-risk',\n197:   },\n198: ]);\n199: \n200: /** Return recall-path exclusion metadata without executing or changing search. */\n201: function getHardExclusionPredicates(): HardExclusionPredicate[] {\n202:   return HARD_EXCLUSION_PREDICATES.map((predicate) => ({ ...predicate }));\n203: }\n204: \n205: type Bm25MemoryMetadata = {\n206:   specFolder: string | null;\n207:   importanceTier: string | null;\n208: };\n209: \n210: /** Non-enumerable shadow metadata attached to result arrays via Object.defineProperty. */\n211: interface ShadowMetaArray {\n212:   _s4shadow?: unknown;\n213:   _s4attribution?: unknown;\n214:   _degradation?: unknown;\n215: }\n216: \n217: /** Normalize a fused RRF result to the HybridSearchResult contract. */\n218: function toHybridResult(result: FusionResult): HybridSearchResult {\n219:   const sourceCandidate = (result as { source?: unknown }).source;\n220:   const primarySource = result.sources[0] ?? 'hybrid';\n221:   const scoreCandidate = (result as { score?: unknown }).score;\n222: \n223:   return {\n224:     ...result,\n225:     id: result.id,\n226:     score: typeof scoreCandidate === 'number' ? scoreCandidate : result.rrfScore,\n227:     source: typeof sourceCandidate === 'string' ? sourceCandidate : primarySource,\n228:   };\n229: }\n230: \n231: // PIPELINE METADATA\n232: \n233: /**\n234:  * Optional metadata about pipeline stages attached to enhanced search results.\n235:  * Only populated when the corresponding feature flags are enabled.\n236:  */\n237: interface Sprint3PipelineMeta {\n238:   /** Query complexity routing result (SPECKIT_COMPLEXITY_ROUTER). */\n239:   routing?: {\n240:     tier: string;\n241:     channels: string[];\n242:     skippedChannels: string[];\n243:     featureFlagEnabled: boolean;\n244:     confidence: string;\n245:     features: Record<string, unknown>;\n246:   };\n247:   /** Channel enforcement result (SPECKIT_CHANNEL_MIN_REP). */\n248:   enforcement?: { applied: boolean; promotedCount: number; underRepresentedChannels: string[] };\n249:   /** Confidence truncation result (SPECKIT_CONFIDENCE_TRUNCATION). */\n250:   truncation?: {\n251:     truncated: boolean;\n252:     originalCount: number;\n253:     truncatedCount: number;\n254:     medianGap: number;\n255:     cutoffGap: number;\n256:     cutoffIndex: number;\n257:     thresholdMultiplier: number;\n258:     minResultsGuaranteed: number;\n259:     featureFlagEnabled: boolean;\n260:   };\n261:   /** Dynamic token budget result (SPECKIT_DYNAMIC_TOKEN_BUDGET). */\n262:   tokenBudget?: {\n263:     tier: string;\n264:     budget: number;\n265:     applied: boolean;\n266:     featureFlagEnabled: boolean;\n267:     configValues: Record<string, number>;\n268:     headerOverhead: number;\n269:     adjustedBudget: number;\n270:   };\n271: }\n272: \n273: // 4. PI-A2: DEGRADATION TYPES\n274: \n275: /** Fallback tier in the 3-tier degradation chain. */\n276: type FallbackTier = 1 | 2 | 3;\n277: \n278: /** Why degradation was triggered at a given tier. */\n279: interface DegradationTrigger {\n280:   reason: 'low_quality' | 'insufficient_results' | 'both';\n281:   topScore: number;\n282:   resultCount: number;\n283:   relativeGap?: number;\n284: }\n285: \n286: /** Record of a single degradation event during tiered fallback. */\n287: interface DegradationEvent {\n288:   tier: FallbackTier;\n289:   trigger: DegradationTrigger;\n290:   resultCountBefore: number;\n291:   resultCountAfter: number;\n292: }\n293: \n294: /**\n295:  * Absolute quality floor for degradation checks.\n296:  *\n297:  * Raw RRF scores are typically small decimals (often <0.05), so a\n298:  * high fixed threshold causes false degradations. Use a conservative floor and\n299:  * pair it with a relative-gap check to avoid score-scale coupling.\n300:  */\n301: const DEGRADATION_QUALITY_THRESHOLD = 0.02;\n302: \n303: /** Minimum relative separation between top-1 and top-2 scores. */\n304: const DEGRADATION_MIN_RELATIVE_GAP = 0.2;\n305: \n306: /** Minimum result count: must have >= this many results to stay at current tier. */\n307: const DEGRADATION_MIN_RESULTS = 3;\n308: \n309: // 5. MODULE STATE\n310: \n311: /** Default result limit when none is specified by the caller. */\n312: const DEFAULT_LIMIT = 20;\n313: /** Primary vector similarity floor for hybrid fallback passes (percentage units). */\n314: const PRIMARY_FALLBACK_MIN_SIMILARITY = 30;\n315: /** Secondary vector similarity floor for adaptive retry passes (percentage units). */\n316: const SECONDARY_FALLBACK_MIN_SIMILARITY = 17;\n317: /** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\n318: const TIERED_FALLBACK_MIN_SIMILARITY = 10;\n319: \n320: /** Minimum MMR candidates required for diversity reranking to be worthwhile. */\n321: const MMR_MIN_CANDIDATES = 2;\n322: \n323: /** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\n324: const MMR_DEFAULT_LAMBDA = 0.7;\n325: \n326: /** Number of top results used as seeds for co-activation spreading. */\n327: const SPREAD_ACTIVATION_TOP_N = 5;\n328: \n329: /** Maximum contextual tree header length prepended to content (including brackets). */\n330: const CONTEXT_HEADER_MAX_CHARS = 100;\n331: /** Header/content separator characters added during contextual tree injection. */\n332: const CONTEXT_HEADER_SEPARATOR_CHARS = 1;\n333: /** Reserved token overhead per contextual header, calibrated to max header length. */\n334: const CONTEXT_HEADER_TOKEN_OVERHEAD = Math.ceil(\n335:   (CONTEXT_HEADER_MAX_CHARS + CONTEXT_HEADER_SEPARATOR_CHARS) / 4\n336: );\n337: \n338: let db: Database.Database | null = null;\n339: let vectorSearchFn: VectorSearchFn | null = null;\n340: let graphSearchFn: GraphSearchFn | null = null;\n341: let enrichFusedResultsObserver: (() => void) | null = null;\n342: \n343: // 6. GRAPH CHANNEL METRICS\n344: \n345: interface GraphChannelMetrics {\n346:   totalQueries: number;\n347:   graphHits: number;\n348:   graphResultCount: number;\n349:   graphOnlyResults: number;\n350:   graphMultiSourceResults: number;\n351:   multiSourceResults: number;\n352:   degreeQueries: number;\n353:   degreeHits: number;\n354:   degreeResultCount: number;\n355: }\n356: \n357: const graphMetrics: GraphChannelMetrics = {\n358:   totalQueries: 0,\n359:   graphHits: 0,\n360:   graphResultCount: 0,\n361:   graphOnlyResults: 0,\n362:   graphMultiSourceResults: 0,\n363:   multiSourceResults: 0,\n364:   degreeQueries: 0,\n365:   degreeHits: 0,\n366:   degreeResultCount: 0,\n367: };\n368: \n369: /**\n370:  * Return current graph channel metrics for health check reporting.\n371:  * graphHitRate is computed as graphHits / totalQueries.\n372:  */\n373: function getGraphMetrics(): GraphChannelMetrics & { graphHitRate: number; degreeHitRate: number } {\n374:   return {\n375:     ...graphMetrics,\n376:     graphHitRate: graphMetrics.totalQueries > 0\n377:       ? graphMetrics.graphHits / graphMetrics.totalQueries\n378:       : 0,\n379:     degreeHitRate: graphMetrics.degreeQueries > 0\n380:       ? graphMetrics.degreeHits / graphMetrics.degreeQueries\n381:       : 0,\n382:   };\n383: }\n384: \n385: /** Reset all graph channel metrics counters to zero. */\n386: function resetGraphMetrics(): void {\n387:   graphMetrics.totalQueries = 0;\n388:   graphMetrics.graphHits = 0;\n389:   graphMetrics.graphResultCount = 0;\n390:   graphMetrics.graphOnlyResults = 0;\n391:   graphMetrics.graphMultiSourceResults = 0;\n392:   graphMetrics.multiSourceResults = 0;\n393:   graphMetrics.degreeQueries = 0;\n394:   graphMetrics.degreeHits = 0;\n395:   graphMetrics.degreeResultCount = 0;\n396: }\n397: \n398: // 7. INITIALIZATION\n399: \n400: /**\n401:  * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n402:  * @param database - The better-sqlite3 database instance for FTS and graph queries.\n403:  * @param vectorFn - Optional vector search function for semantic similarity.\n404:  * @param graphFn - Optional graph search function for causal/structural retrieval.\n405:  */\n406: function init(\n407:   database: Database.Database,\n408:   vectorFn: VectorSearchFn | null = null,\n409:   graphFn: GraphSearchFn | null = null\n410: ): void {\n411:   db = database;\n412:   vectorSearchFn = vectorFn;\n413:   graphSearchFn = graphFn;\n414: }\n415: \n416: // 8. BM25 SEARCH\n417: \n418: /**\n419:  * Search the BM25 index with optional spec folder filtering.\n420:  * @param query - The search query string.\n421:  * @param options - Optional limit and specFolder filter.\n422:  * @returns Array of BM25-scored results tagged with source 'bm25'.\n423:  */\n424: function bm25Search(\n425:   query: string,\n426:   options: { limit?: number; specFolder?: string } = {}\n427: ): HybridSearchResult[] {\n428:   if (!isBm25Enabled()) {\n429:     console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n430:     return [];\n431:   }\n432: \n433:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n434: \n435:   try {\n436:     if (shouldUseSqliteLexicalEngine(db)) {\n437:       return ftsSearch(query, {\n438:         limit,\n439:         specFolder,\n440:       }).map((result) => ({\n441:         ...result,\n442:         bm25_score: result.score,\n443:         source: 'bm25',\n444:         sources: Array.from(new Set([\n445:           ...(\n446:             Array.isArray((result as Record<string, unknown>).sources)\n447:               ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n448:               : []\n449:           ),\n450:           'fts',\n451:           'bm25',\n452:         ])),\n453:       }));\n454:     }\n455: \n456:     // Spec-folder scope can only be resolved from DB metadata; fail closed before\n457:     // searching when the DB is unavailable rather than over-fetching the whole\n458:     // corpus and then discarding it.\n459:     if (specFolder && !db) {\n460:       console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n461:       return [];\n462:     }\n463: \n464:     const index = getIndex();\n465:     const candidateLimit = (specFolder || db)\n466:       ? index.getStats().documentCount\n467:       : limit;\n468:     // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n469:     // candidate set whenever those filters can remove otherwise top-ranked hits.\n470:     const results = index.search(query, candidateLimit);\n471: \n472:     // BM25 document IDs are stringified\n473:     // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n474:     // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n475: \n476:     // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n477:     // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n478:     // resolution returns [] rather than leaking unscoped BM25 candidates.\n479:     let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n480:     if (results.length > 0) {\n481:       if (!db) {\n482:         if (specFolder) {\n483:           const error = new Error('Database unavailable for spec-folder scope lookup');\n484:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n485:           return [];\n486:         }\n487:       } else {\n488:         try {\n489:           const ids = results.map((r: { id: string }) => Number(r.id));\n490:           memoryMetadataMap = new Map();\n491:           // Resolve metadata in bounded batches. The candidate set can now be\n492:           // corpus-sized (over-fetch for scope/tier filtering), and a single\n493:           // IN (...) with one bind per id would exceed SQLite's parameter limit\n494:           // and throw — which the catch below turns into an empty result.\n495:           const METADATA_BATCH = 500;\n496:           for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n497:             const batch = ids.slice(offset, offset + METADATA_BATCH);\n498:             const placeholders = batch.map(() => '?').join(',');\n499:             const rows = db.prepare(\n500:               `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n501:             ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n502:             for (const row of rows) {\n503:               memoryMetadataMap.set(row.id, {\n504:                 specFolder: row.spec_folder,\n505:                 importanceTier: row.importance_tier,\n506:               });\n507:             }\n508:           }\n509:         } catch (error: unknown) {\n510:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n511:           return [];\n512:         }\n513:       }\n514: \n515:       // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n516:       // is still null after the resolution block, something unexpected happened.\n517:       // Fail closed rather than falling through to unscoped results.\n518:       if (specFolder && !memoryMetadataMap) {\n519:         const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n520:         console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n521:         return [];\n522:       }\n523:     }\n524: \n525:     const excludeCold = !isArchivedRetrievalIncludedByDefault();\n526:     return results\n527:       .filter((r: { id: string }) => {\n528:         const metadata = memoryMetadataMap?.get(Number(r.id));\n529:         // Cold/deprecated rows are included by default (FSRS ranks them lower);\n530:         // only drop them when archived retrieval is disabled.\n531:         if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n532:         if (!specFolder) return true;\n533:         if (!metadata) return false;\n534:         const folder = metadata.specFolder;\n535:         if (!folder) return false;\n536:         return folder === specFolder || folder.startsWith(specFolder + '/');\n537:       })\n538:       .slice(0, limit)\n539:       .map((r: { id: string; score: number }) => ({\n540:         ...r,\n541:         source: 'bm25',\n542:       }));\n543:   } catch (error: unknown) {\n544:     const msg = error instanceof Error ? error.message : String(error);\n545:     console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n546:     return [];\n547:   }\n548: }\n549: \n550: /**\n551:  * Check whether the BM25 index is populated and available for search.\n552:  * @returns True if the BM25 index exists and contains at least one document.\n553:  */\n554: function isBm25Available(): boolean {\n555:   if (!isBm25Enabled()) {\n556:     return false;\n557:   }\n558: \n559:   try {\n560:     const index = getIndex();\n561:     return index.getStats().documentCount > 0;\n562:   } catch (_err: unknown) {\n563:     // Swallow index-not-initialized errors; caller treats absence as unavailable\n564:     return false;\n565:   }\n566: }\n567: \n568: // 9. FTS SEARCH\n569: \n570: /**\n571:  * Check whether the FTS5 full-text search table exists in the database.\n572:  * @returns True if the memory_fts table exists in the connected database.\n573:  */\n574: function isFtsAvailable(): boolean {\n575:   if (!db) {\n576:     console.warn('[hybrid-search] db not initialized — isFtsAvailable returning false');\n577:     return false;\n578:   }\n579: \n580:   try {\n581:     const result = (db.prepare(`\n582:       SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n583:     `) as Database.Statement).get() as { name: string } | undefined;\n584:     return !!result;\n585:   } catch (_err: unknown) {\n586:     // Swallow DB errors; caller treats absence as unavailable\n587:     return false;\n588:   }\n589: }\n590: \n591: /**\n592:  * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n593:  * @param query - The search query string.\n594:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n595:  * @returns Array of FTS-scored results tagged with source 'fts'.\n596:  */\n597: function ftsSearch(\n598:   query: string,\n599:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n600: ): HybridSearchResult[] {\n601:   if (!db || !isFtsAvailable()) {\n602:     console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n603:     return [];\n604:   }\n605: \n606:   const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n607: \n608:   try {\n609:     // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n610:     // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n611:     // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n612:     // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n613:     const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n614: \n615:     return bm25Results.map(row => ({\n616:       ...row,\n617:       id: row.id as number,\n618:       score: row.fts_score || 0,\n619:       source: 'fts',\n620:     }));\n621:   } catch (error: unknown) {\n622:     const msg = error instanceof Error ? error.message : String(error);\n623:     console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n624:     return [];\n625:   }\n626: }\n627: \n628: // 10. COMBINED LEXICAL SEARCH\n629: \n630: /**\n631:  * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n632:  * @param query - The search query string.\n633:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n634:  * @returns Deduplicated array of merged results sorted by score descending.\n635:  */\n636: function combinedLexicalSearch(\n637:   query: string,\n638:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n639: ): HybridSearchResult[] {\n640:   const ftsResults = ftsSearch(query, options);\n641:   const bm25Results = bm25Search(query, options);\n642: \n643:   // Merge by canonical ID, prefer FTS scores.\n644:   // CanonicalResultId() prevents duplicate rows when one channel emits\n645:   // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n646:   const merged = new Map<string, HybridSearchResult>();\n647: \n648:   for (const r of ftsResults) {\n649:     merged.set(canonicalResultId(r.id), r);\n650:   }\n651: \n652:   for (const r of bm25Results) {\n653:     const canonicalId = canonicalResultId(r.id);\n654:     if (!merged.has(canonicalId)) {\n655:       merged.set(canonicalId, r);\n656:     }\n657:   }\n658: \n659:   return Array.from(merged.values())\n660:     .sort((a, b) => b.score - a.score)\n661:     .slice(0, options.limit || DEFAULT_LIMIT);\n662: }\n663: \n664: function normalizeTriggerText(value: string): string {\n665:   return value\n666:     .toLowerCase()\n667:     .replace(/[^a-z0-9]+/g, ' ')\n668:     .replace(/\\s+/g, ' ')\n669:     .trim();\n670: }\n671: \n672: function triggerQueryTokens(query: string): string[] {\n673:   return Array.from(new Set(\n674:     normalizeTriggerText(query)\n675:       .split(/\\s+/)\n676:       .filter((token) => token.length >= 2)\n677:   ));\n678: }\n679: \n680: function computeTriggerMatchScore(query: string, phrase: string): number {\n681:   const normalizedQuery = normalizeTriggerText(query);\n682:   const normalizedPhrase = normalizeTriggerText(phrase);\n683:   if (!normalizedQuery || !normalizedPhrase) return 0;\n684:   if (normalizedPhrase === normalizedQuery) return 1.0;\n685: \n686:   const queryTokens = triggerQueryTokens(normalizedQuery);\n687:   const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n688:   if (phraseTokens.size < 2) return 0;\n689:   if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n690:   if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n691:   if (queryTokens.length === 0) return 0;\n692:   const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n693:   const coverage = overlap / queryTokens.length;\n694:   return coverage >= 0.8 ? coverage * 0.75 : 0;\n695: }\n696: \n697: function timestampBoost(value: unknown): number {\n698:   if (typeof value !== 'string' || value.length === 0) return 0;\n699:   const parsed = Date.parse(value);\n700:   if (!Number.isFinite(parsed)) return 0;\n701:   const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n702:   return 1 / (1 + ageDays / 30);\n703: }\n704: \n705: function exactTriggerSearch(\n706:   query: string,\n707:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n708: ): HybridSearchResult[] {\n709:   if (!db) return [];\n710: \n711:   const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n712:   if (tokens.length === 0) return [];\n713: \n714:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n715:   const normalizedQuery = normalizeTriggerText(query);\n716:   const exactPhraseLike = `%${normalizedQuery}%`;\n717:   const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n718:   const conditions = [\n719:     `m.trigger_phrases IS NOT NULL`,\n720:     `m.trigger_phrases != ''`,\n721:     `m.trigger_phrases != '[]'`,\n722:     // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n723:     // them below hot memories); the hard exclusion only applies when archived\n724:     // retrieval is disabled.\n725:     ...(isArchivedRetrievalIncludedByDefault()\n726:       ? []\n727:       : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n728:     `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n729:     `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n730:   ];\n731:   const params: unknown[] = tokens.map((token) => `%${token}%`);\n732: \n733:   if (specFolder) {\n734:     conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n735:     params.push(specFolder, specFolderLikePattern(specFolder));\n736:   }\n737: \n738:   try {\n739:     const rows = db.prepare(`\n740:       SELECT m.*\n741:       FROM memory_index m\n742:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n743:       WHERE ${conditions.join(' AND ')}\n744:       ORDER BY\n745:         CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n746:         COALESCE(m.updated_at, m.created_at, '') DESC\n747:       LIMIT ${candidateLimit}\n748:     `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n749: \n750:     return rows\n751:       .map((row): HybridSearchResult | null => {\n752:         const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n753:         const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n754:         if (matchScore <= 0) return null;\n755: \n756:         const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n757:           ? Math.max(0, Math.min(1, row.importance_weight))\n758:           : 0.5;\n759:         const recency = timestampBoost(row.updated_at ?? row.created_at);\n760:         const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n761: \n762:         return {\n763:           ...row,\n764:           id: row.id as number,\n765:           score,\n766:           triggerScore: matchScore,\n767:           source: 'trigger',\n768:         };\n769:       })\n770:       .filter((row): row is HybridSearchResult => row !== null)\n771:       .sort((a, b) => {\n772:         const scoreDelta = b.score - a.score;\n773:         if (scoreDelta !== 0) return scoreDelta;\n774:         const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n775:         const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n776:         return bTime - aTime;\n777:       })\n778:       .slice(0, limit);\n779:   } catch (error: unknown) {\n780:     const msg = error instanceof Error ? error.message : String(error);\n781:     console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n782:     return [];\n783:   }\n784: }\n785: \n786: type RawChannelList = {\n787:   source: string;\n788:   results: Array<{ id: number | string; [key: string]: unknown }>;\n789: };\n790: \n791: function resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n792:   if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n793:     return result.score;\n794:   }\n795:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n796:     return result.similarity / 100;\n797:   }\n798:   return 0;\n799: }\n800: \n801: function getCandidateSources(result: HybridSearchResult): string[] {\n802:   const sourceList = (result as { sources?: unknown }).sources;\n803:   if (Array.isArray(sourceList)) {\n804:     return sourceList.filter((value): value is string => typeof value === 'string');\n805:   }\n806:   return typeof result.source === 'string' && result.source.length > 0\n807:     ? [result.source]\n808:     : [];\n809: }\n810: \n811: function getCandidateSourceScores(result: HybridSearchResult): Record<string, number> {\n812:   const sourceScores = (result as { sourceScores?: unknown }).sourceScores;\n813:   if (sourceScores && typeof sourceScores === 'object' && !Array.isArray(sourceScores)) {\n814:     const normalizedScores: Record<string, number> = {};\n815:     for (const [source, score] of Object.entries(sourceScores as Record<string, unknown>)) {\n816:       if (typeof score === 'number' && Number.isFinite(score)) {\n817:         normalizedScores[source] = score;\n818:       }\n819:     }\n820:     return normalizedScores;\n821:   }\n822: \n823:   const fallbackScores: Record<string, number> = {};\n824:   const resultScore = typeof result.score === 'number' && Number.isFinite(result.score)\n825:     ? result.score\n826:     : 0;\n827:   for (const source of getCandidateSources(result)) {\n828:     fallbackScores[source] = resultScore;\n829:   }\n830:   return fallbackScores;\n831: }\n832: \n833: function mergeRawCandidate(\n834:   existing: HybridSearchResult | undefined,\n835:   incoming: HybridSearchResult\n836: ): HybridSearchResult {\n837:   if (!existing) {\n838:     const sources = getCandidateSources(incoming);\n839:     const channelCount = sources.length;\n840:     return {\n841:       ...incoming,\n842:       sources,\n843:       channelCount,\n844:       sourceScores: getCandidateSourceScores(incoming),\n845:       channelAttribution: sources,\n846:     };\n847:   }\n848: \n849:   const existingScore = typeof existing.score === 'number' && Number.isFinite(existing.score)\n850:     ? existing.score\n851:     : 0;\n852:   const incomingScore = typeof incoming.score === 'number' && Number.isFinite(incoming.score)\n853:     ? incoming.score\n854:     : 0;\n855:   const primary = incomingScore > existingScore ? incoming : existing;\n856:   const secondary = primary === incoming ? existing : incoming;\n857:   const sources = Array.from(new Set([\n858:     ...getCandidateSources(existing),\n859:     ...getCandidateSources(incoming),\n860:   ]));\n861:   const channelCount = sources.length;\n862:   const crossChannelBonus = Math.min(0.06, 0.02 * Math.max(0, channelCount - 1));\n863:   const mergedScore = Math.max(0, Math.min(1, Math.max(existingScore, incomingScore) + crossChannelBonus));\n864: \n865:   return {\n866:     ...(secondary ?? {}),\n867:     ...primary,\n868:     score: mergedScore,\n869:     source: typeof primary.source === 'string' ? primary.source : (sources[0] ?? 'hybrid'),\n870:     sources,\n871:     channelCount,\n872:     sourceScores: {\n873:       ...getCandidateSourceScores(existing),\n874:       ...getCandidateSourceScores(incoming),\n875:     },\n876:     channelAttribution: sources,\n877:   };\n878: }\n879: \n880: function collectCandidatesFromLists(\n881:   lists: RawChannelList[],\n882:   limit?: number\n883: ): HybridSearchResult[] {\n884:   const deduped = new Map<string, HybridSearchResult>();\n885: \n886:   for (const list of lists) {\n887:     if (!Array.isArray(list.results) || list.results.length === 0) continue;\n888: \n889:     const scored = list.results.map((result) => {\n890:       const rawScore = resolveRawCandidateScore(result as { score?: unknown; similarity?: unknown });\n891:       return { result, rawScore };\n892:     });\n893: \n894:     let min = Infinity;\n895:     let max = -Infinity;\n896:     for (const { rawScore } of scored) {\n897:       if (rawScore < min) min = rawScore;\n898:       if (rawScore > max) max = rawScore;\n899:     }\n900:     const range = max - min;\n901: \n902:     for (const { result, rawScore } of scored) {\n903:       const normalizedScore = range > 0 ? (rawScore - min) / range : (rawScore > 0 ? 1.0 : 0);\n904:       const candidate: HybridSearchResult = {\n905:         ...result,\n906:         id: result.id,\n907:         source: list.source,\n908:         score: normalizedScore,\n909:         sources: [list.source],\n910:         sourceScores: { [list.source]: normalizedScore },\n911:         channelAttribution: [list.source],\n912:       };\n913:       const key = canonicalResultId(candidate.id);\n914:       deduped.set(key, mergeRawCandidate(deduped.get(key), candidate));\n915:     }\n916:   }\n917: \n918:   return applyResultLimit(\n919:     Array.from(deduped.values()).sort((a, b) => {\n920:       const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n921:       const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n922:       return bScore - aScore;\n923:     }),\n924:     limit\n925:   );\n926: }\n927: \n928: function mergeRawCandidateSets(\n929:   existing: HybridSearchResult[],\n930:   incoming: HybridSearchResult[],\n931:   limit?: number\n932: ): HybridSearchResult[] {\n933:   const merged = new Map<string, HybridSearchResult>();\n934: \n935:   for (const result of [...existing, ...incoming]) {\n936:     const key = canonicalResultId(result.id);\n937:     merged.set(key, mergeRawCandidate(merged.get(key), result));\n938:   }\n939: \n940:   return applyResultLimit(\n941:     Array.from(merged.values()).sort((a, b) => {\n942:       const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n943:       const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n944:       return bScore - aScore;\n945:     }),\n946:     limit\n947:   );\n948: }\n949: \n950: function getAllowedChannels(options: HybridSearchOptions): Set<ChannelName> {\n951:   const allowed = new Set<ChannelName>(['vector', 'fts', 'graph', 'degree']);\n952: \n953:   if (isBm25Enabled()) {\n954:     allowed.add('bm25');\n955:   }\n956: \n957:   if (options.useVector === false) allowed.delete('vector');\n958:   if (options.useBm25 === false) allowed.delete('bm25');\n959:   if (options.useFts === false) allowed.delete('fts');\n960:   if (options.useGraph === false) {\n961:     allowed.delete('graph');\n962:     allowed.delete('degree');\n963:   }\n964: \n965:   return allowed;\n966: }\n967: \n968: function applyAllowedChannelOverrides(\n969:   options: HybridSearchOptions,\n970:   allowedChannels: Set<ChannelName>,\n971:   overrides: Partial<HybridSearchOptions> = {}\n972: ): HybridSearchOptions {\n973:   return {\n974:     ...options,\n975:     ...overrides,\n976:     useVector: allowedChannels.has('vector'),\n977:     useBm25: allowedChannels.has('bm25'),\n978:     useFts: allowedChannels.has('fts'),\n979:     useGraph: allowedChannels.has('graph'),\n980:   };\n981: }\n982: \n983: type FallbackPlanKind = 'adaptive' | 'tiered';\n984: type FallbackStageName = 'primary' | 'retry';\n985: \n986: interface FallbackPlanStage {\n987:   stage: FallbackStageName;\n988:   options: HybridSearchOptions;\n989:   results: HybridSearchResult[];\n990:   execution: HybridFusionExecution | null;\n991:   trigger?: 'empty' | DegradationTrigger;\n992: }\n993: \n994: interface FallbackPlanExecution {\n995:   allowedChannels: Set<ChannelName>;\n996:   stages: FallbackPlanStage[];\n997: }\n998: \n999: interface HybridFusionExecution {\n1000:   evaluationMode: boolean;\n1001:   intent: string;\n1002:   lists: Array<{\n1003:     source: string;\n1004:     results: Array<{ id: number | string; [key: string]: unknown }>;\n1005:     weight?: number;\n1006:   }>;\n1007:   routeResult: ReturnType<typeof routeQuery>;\n1008:   budgetResult: ReturnType<typeof getDynamicTokenBudget>;\n1009:   s3meta: Sprint3PipelineMeta;\n1010:   fusedResults: HybridSearchResult[];\n1011:   vectorEmbeddingCache: Map<number, Float32Array>;\n1012: }\n1013: \n1014: function resolveAdaptiveDocumentType(\n1015:   lists: Array<{ results: Array<Record<string, unknown>> }>,\n1016: ): string | undefined {\n1017:   const counts = new Map<string, number>();\n1018:   for (const list of lists) {\n1019:     for (const result of list.results.slice(0, 3)) {\n1020:       const candidate = result.documentType ?? result.document_type;\n1021:       if (typeof candidate !== 'string' || candidate.length === 0) {\n1022:         continue;\n1023:       }\n1024:       counts.set(candidate, (counts.get(candidate) ?? 0) + 1);\n1025:     }\n1026:   }\n1027: \n1028:   let topType: string | undefined;\n1029:   let topCount = 0;\n1030:   for (const [documentType, count] of counts) {\n1031:     if (count > topCount) {\n1032:       topType = documentType;\n1033:       topCount = count;\n1034:     }\n1035:   }\n1036: \n1037:   return topType;\n1038: }\n1039: \n1040: function markFallbackRetry(results: HybridSearchResult[]): HybridSearchResult[] {\n1041:   for (const result of results) {\n1042:     (result as Record<string, unknown>).fallbackRetry = true;\n1043:   }\n1044: \n1045:   return results;\n1046: }\n1047: \n1048: function toEmbeddingBufferView(value: unknown): Float32Array | null {\n1049:   if (value instanceof Float32Array) {\n1050:     return value;\n1051:   }\n1052: \n1053:   if (Array.isArray(value)) {\n1054:     const asNumbers = value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));\n1055:     return asNumbers ? new Float32Array(value) : null;\n1056:   }\n1057: \n1058:   if (Buffer.isBuffer(value)) {\n1059:     return new Float32Array(value.buffer, value.byteOffset, value.byteLength / 4);\n1060:   }\n1061: \n1062:   return null;\n1063: }\n1064: \n1065: async function executeFallbackPlan(\n1066:   query: string,\n1067:   embedding: Float32Array | number[] | null,\n1068:   options: HybridSearchOptions = {},\n1069:   planKind: FallbackPlanKind,\n1070:   overrides: Partial<HybridSearchOptions> = {}\n1071: ): Promise<FallbackPlanExecution> {\n1072:   const allowedChannels = getAllowedChannels(options);\n1073:   const stages: FallbackPlanStage[] = [];\n1074: \n1075:   const primaryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1076:     minSimilarity: options.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY,\n1077:     ...overrides,\n1078:   });\n1079:   const primaryExecution = await collectAndFuseHybridResults(query, embedding, primaryOptions);\n1080:   const primaryResults = primaryExecution\n1081:     ? applyResultLimit(primaryExecution.fusedResults, primaryOptions.limit)\n1082:     : await hybridSearch(query, embedding, primaryOptions);\n1083:   stages.push({\n1084:     stage: 'primary',\n1085:     options: primaryOptions,\n1086:     results: primaryResults,\n1087:     execution: primaryExecution,\n1088:   });\n1089: \n1090:   if (planKind === 'tiered') {\n1091:     const trigger = checkDegradation(primaryResults);\n1092:     if (!trigger) {\n1093:       return { allowedChannels, stages };\n1094:     }\n1095: \n1096:     const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1097:       ...overrides,\n1098:       minSimilarity: TIERED_FALLBACK_MIN_SIMILARITY,\n1099:       forceAllChannels: true,\n1100:     });\n1101:     const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n1102:     const retryResults = retryExecution\n1103:       ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n1104:       : await hybridSearch(query, embedding, retryOptions);\n1105:     stages.push({\n1106:       stage: 'retry',\n1107:       options: retryOptions,\n1108:       results: retryResults,\n1109:       execution: retryExecution,\n1110:       trigger,\n1111:     });\n1112:     return { allowedChannels, stages };\n1113:   }\n1114: \n1115:   const primaryMinSimilarity = primaryOptions.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY;\n1116:   if (primaryResults.length === 0 && primaryMinSimilarity >= SECONDARY_FALLBACK_MIN_SIMILARITY) {\n1117:     const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1118:       ...overrides,\n1119:       minSimilarity: SECONDARY_FALLBACK_MIN_SIMILARITY,\n1120:     });\n1121:     const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n1122:     const retryResultsBase = retryExecution\n1123:       ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n1124:       : await hybridSearch(query, embedding, retryOptions);\n1125:     const retryResults = retryResultsBase.length > 0\n1126:       ? markFallbackRetry(retryResultsBase)\n1127:       : retryResultsBase;\n1128:     stages.push({\n1129:       stage: 'retry',\n1130:       options: retryOptions,\n1131:       results: retryResults,\n1132:       execution: retryExecution,\n1133:       trigger: 'empty',\n1134:     });\n1135:   }\n1136: \n1137:   return { allowedChannels, stages };\n1138: }\n1139: \n1140: // 11. HYBRID SEARCH\n1141: \n1142: /**\n1143:  * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n1144:  * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n1145:  * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n1146:  * Retained as internal fallback only.\n1147:  */\n1148: async function hybridSearch(\n1149:   query: string,\n1150:   embedding: Float32Array | number[] | null,\n1151:   options: HybridSearchOptions = {}\n1152: ): Promise<HybridSearchResult[]> {\n1153:   const {\n1154:     limit = DEFAULT_LIMIT,\n1155:     specFolder,\n1156:     minSimilarity = 0,\n1157:     useBm25 = isBm25Enabled(),\n1158:     useFts = true,\n1159:     useVector = true,\n1160:     useGraph = true,\n1161:     includeArchived = false,\n1162:   } = options;\n1163: \n1164:   const results: HybridSearchResult[] = [];\n1165: \n1166:   // Vector search\n1167:   if (useVector && embedding && vectorSearchFn) {\n1168:     try {\n1169:       const vectorResults = vectorSearchFn(embedding, {\n1170:         limit,\n1171:         specFolder,\n1172:         minSimilarity,\n1173:         includeConstitutional: false, // Handler manages constitutional separately\n1174:         includeArchived,\n1175:       });\n1176:       for (const r of vectorResults) {\n1177:         results.push({\n1178:           ...r,\n1179:           id: r.id as number,\n1180:           score: (r.similarity as number) || 0,\n1181:           source: 'vector',\n1182:         });\n1183:       }\n1184:     } catch (error: unknown) {\n1185:       const msg = error instanceof Error ? error.message : String(error);\n1186:       console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n1187:     }\n1188:   }\n1189: \n1190:   // FTS search\n1191:   if (useFts) {\n1192:     const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n1193:     results.push(...ftsResults);\n1194:   }\n1195: \n1196:   // BM25 search\n1197:   if (useBm25) {\n1198:     const bm25Results = bm25Search(query, { limit, specFolder });\n1199:     results.push(...bm25Results);\n1200:   }\n1201: \n1202:   // Graph search\n1203:   if (useGraph && graphSearchFn) {\n1204:     try {\n1205:       graphMetrics.totalQueries++;\n1206:       const graphResults = graphSearchFn(query, { limit, specFolder });\n1207:       for (const r of graphResults) {\n1208:         results.push({\n1209:           ...r,\n1210:           id: r.id as number | string,\n1211:           score: (r.score as number) || 0,\n1212:           source: 'graph',\n1213:         });\n1214:       }\n1215:       if (graphResults.length > 0) {\n1216:         graphMetrics.graphHits++;\n1217:         graphMetrics.graphResultCount += graphResults.length;\n1218:       }\n1219:     } catch (error: unknown) {\n1220:       const msg = error instanceof Error ? error.message : String(error);\n1221:       console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n1222:     }\n1223:   }\n1224: \n1225:   // Normalize scores per source before merging so one method's raw scale\n1226:   // Does not dominate others during final ranking.\n1227:   const bySource = new Map<string, HybridSearchResult[]>();\n1228:   for (const r of results) {\n1229:     const src = r.source || 'unknown';\n1230:     if (!bySource.has(src)) bySource.set(src, []);\n1231:     bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n1232:   }\n1233: \n1234:   const normalized: HybridSearchResult[] = [];\n1235:   for (const [, group] of bySource) {\n1236:     if (group.length === 0) continue;\n1237:     const scores = group.map(r => r.score);\n1238:     let min = Infinity;\n1239:     let max = -Infinity;\n1240:     for (const s of scores) {\n1241:       if (s < min) min = s;\n1242:       if (s > max) max = s;\n1243:     }\n1244:     const range = max - min;\n1245:     for (const r of group) {\n1246:       normalized.push({\n1247:         ...r,\n1248:         score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n1249:       });\n1250:     }\n1251:   }\n1252: \n1253:   // Deduplicate by ID (keep highest normalized score)\n1254:   // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n1255:   // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n1256:   // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n1257:   // Field and downstream consumers would need to be updated accordingly.\n1258:   const deduped = new Map<string, HybridSearchResult>();\n1259:   for (const r of normalized) {\n1260:     const canonicalId = canonicalResultId(r.id);\n1261:     const existing = deduped.get(canonicalId);\n1262:     if (!existing || r.score > existing.score) {\n1263:       deduped.set(canonicalId, r);\n1264:     }\n1265:   }\n1266: \n1267:   return Array.from(deduped.values())\n1268:     .sort((a, b) => b.score - a.score)\n1269:     .slice(0, limit);\n1270: }\n1271: \n1272: /**\n1273:  * Enhanced hybrid search with RRF fusion.\n1274:  * All search channels use synchronous better-sqlite3; sequential execution\n1275:  * is correct — Promise.all would add overhead without achieving parallelism.\n1276:  */\n1277: async function hybridSearchEnhanced(\n1278:   query: string,\n1279:   embedding: Float32Array | number[] | null,\n1280:   options: HybridSearchOptions = {}\n1281: ): Promise<HybridSearchResult[]> {\n1282:   const execution = await collectAndFuseHybridResults(query, embedding, options);\n1283:   if (execution) {\n1284:     if (options.stopAfterFusion) {\n1285:       return applyResultLimit(execution.fusedResults, options.limit);\n1286:     }\n1287: \n1288:     return enrichFusedResults(query, execution, options);\n1289:   }\n1290: \n1291:   return hybridSearch(query, embedding, options);\n1292: }\n1293: \n1294: async function collectAndFuseHybridResults(\n1295:   query: string,\n1296:   embedding: Float32Array | number[] | null,\n1297:   options: HybridSearchOptions = {}\n1298: ): Promise<HybridFusionExecution | null> {\n1299:   try {\n1300:     const evaluationMode = options.evaluationMode === true;\n1301:     const lists: HybridFusionExecution['lists'] = [];\n1302: \n1303:     // Pipeline metadata collector (populated by flag-gated stages)\n1304:     const s3meta: Sprint3PipelineMeta = {};\n1305: \n1306:     // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n1307:     // When enabled, classifies query complexity and restricts channels to a\n1308:     // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n1309:     const routeResult = routeQuery(query, options.triggerPhrases);\n1310:     const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n1311:     const activeChannels = options.forceAllChannels\n1312:       ? new Set<ChannelName>(allPossibleChannels)\n1313:       : new Set<ChannelName>(routeResult.channels);\n1314: \n1315:     // Respect explicit caller channel disables across both the primary route and\n1316:     // every fallback tier. useGraph=false also disables the dependent degree lane.\n1317:     const allowedChannels = getAllowedChannels(options);\n1318:     for (const channel of allPossibleChannels) {\n1319:       if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n1320:     }\n1321: \n1322:     const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n1323: \n1324:     if (skippedChannels.length > 0) {\n1325:       s3meta.routing = {\n1326:         tier: routeResult.tier,\n1327:         channels: routeResult.channels,\n1328:         skippedChannels,\n1329:         featureFlagEnabled: isComplexityRouterEnabled(),\n1330:         confidence: routeResult.classification.confidence,\n1331:         features: routeResult.classification.features as Record<string, unknown>,\n1332:       };\n1333:     }\n1334: \n1335:     // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n1336:     // Compute tier-aware budget early so it's available for downstream truncation.\n1337:     // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n1338:     // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n1339:     const lowSignalQuery =\n1340:       routeResult.classification.confidence === 'low' ||\n1341:       routeResult.classification.confidence === 'fallback';\n1342:     const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n1343:       lowSignal: lowSignalQuery,\n1344:     });\n1345:     if (budgetResult.applied && !evaluationMode) {\n1346:       s3meta.tokenBudget = {\n1347:         tier: budgetResult.tier,\n1348:         budget: budgetResult.budget,\n1349:         applied: budgetResult.applied,\n1350:         featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n1351:         configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n1352:         // headerOverhead and adjustedBudget are patched in below after they are computed\n1353:         headerOverhead: 0,\n1354:         adjustedBudget: budgetResult.budget,\n1355:       };\n1356:     }\n1357: \n1358:     // Channel results collected independently, merged after all complete\n1359:     let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n1360:     let ftsChannelResults: HybridSearchResult[] = [];\n1361:     let bm25ChannelResults: HybridSearchResult[] = [];\n1362:     let triggerChannelResults: HybridSearchResult[] = [];\n1363:     const vectorEmbeddingCache = new Map<number, Float32Array>();\n1364: \n1365:     // All channels use synchronous better-sqlite3; sequential execution\n1366:     // Is correct — Promise.all adds overhead without parallelism.\n1367: \n1368:     // Vector channel — gated by query-complexity routing\n1369:     if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n1370:       try {\n1371:         const vectorResults = vectorSearchFn(embedding, {\n1372:           limit: options.limit || DEFAULT_LIMIT,\n1373:           specFolder: options.specFolder,\n1374:           minSimilarity: options.minSimilarity || 0,\n1375:           includeConstitutional: false,\n1376:           includeArchived: options.includeArchived || false,\n1377:           includeEmbeddings: true,\n1378:         });\n1379:         semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n1380:           ...r,\n1381:           id: r.id as number | string,\n1382:           source: 'vector',\n1383:         }));\n1384:         for (const result of semanticResults) {\n1385:           if (typeof result.id !== 'number') continue;\n1386:           const embeddingCandidate = toEmbeddingBufferView(\n1387:             (result as Record<string, unknown>).embedding\n1388:             ?? (result as Record<string, unknown>).embeddingBuffer\n1389:           );\n1390:           if (embeddingCandidate) {\n1391:             vectorEmbeddingCache.set(result.id, embeddingCandidate);\n1392:           }\n1393:         }\n1394:         lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n1395:       } catch (_err: unknown) {\n1396:         // Non-critical — vector channel failure does not block pipeline\n1397:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1398:       }\n1399:     }\n1400: \n1401:     // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n1402:     if (activeChannels.has('fts')) {\n1403:       ftsChannelResults = ftsSearch(query, options);\n1404:       if (ftsChannelResults.length > 0) {\n1405:         // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n1406:         // flooding top-K with noisy lexical matches despite its exact-match value.\n1407:         lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n1408:       }\n1409:     }\n1410: \n1411:     // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n1412:     if (activeChannels.has('bm25')) {\n1413:       bm25ChannelResults = bm25Search(query, options);\n1414:       if (bm25ChannelResults.length > 0) {\n1415:         // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n1416:         // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n1417:         lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n1418:       }\n1419:     }\n1420: \n1421:     triggerChannelResults = exactTriggerSearch(query, options);\n1422:     if (triggerChannelResults.length > 0) {\n1423:       lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n1424:     }\n1425: \n1426:     // Graph channel — gated by query-complexity routing\n1427:     const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n1428:     if (useGraph && graphSearchFn) {\n1429:       try {\n1430:         graphMetrics.totalQueries++; // counted only if channel executes\n1431:         const graphResults = graphSearchFn(query, {\n1432:           limit: options.limit || DEFAULT_LIMIT,\n1433:           specFolder: options.specFolder,\n1434:           intent: options.intent,\n1435:         });\n1436:         if (graphResults.length > 0) {\n1437:           graphMetrics.graphHits++;\n1438:           graphMetrics.graphResultCount += graphResults.length;\n1439:           lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n1440:             ...r,\n1441:             id: r.id as number | string,\n1442:           })), weight: 0.5 });\n1443:         }\n1444:       } catch (_err: unknown) {\n1445:         // Non-critical — graph channel failure does not block pipeline\n\n(Output capped at 50 KB. Showing lines 1-1445. Use offset=1446 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Hybrid Search\n// ───────────────────────────────────────────────────────────────\n// Combines vector, FTS, and BM25 search with fallback\n\n// 1. IMPORTS\n\n// Local\nimport {\n  getIndex,\n  isBm25Enabled,\n  shouldUseSqliteLexicalEngine,\n} from './bm25-index.js';\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\nimport { fts5Bm25Search } from './sqlite-fts.js';\nimport { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Hybrid Search\n// ───────────────────────────────────────────────────────────────\n// Combines vector, FTS, and BM25 search with fallback\n\n// 1. IMPORTS\n\n// Local\nimport {\n  getIndex,\n  isBm25Enabled,\n  shouldUseSqliteLexicalEngine,\n} from './bm25-index.js';\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\nimport { fts5Bm25Search } from './sqlite-fts.js';\nimport { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';\nimport {\n  isMMREnabled,\n  isSearchFallbackEnabled,\n  isDocscoreAggregationEnabled,\n  isDegreeBoostEnabled,\n  isContextHeadersEnabled,\n  isArchivedRetrievalIncludedByDefault,\n  isCosineTopnReorderEnabled,\n} from './search-flags.js';\nimport { resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport { computeDegreeScores } from './graph-search-fn.js';\nimport type { GraphSearchFn } from './search-types.js';\n\n// Feature catalog: Hybrid search pipeline\n\nexport type { GraphSearchFn } from './search-types.js';\n\nimport { routeQuery } from './query-router.js';\nimport { isComplexityRouterEnabled } from './query-classifier.js';\nimport { enforceChannelRepresentation } from './channel-enforcement.js';\nimport {\n  truncateByConfidence,\n  isConfidenceTruncationEnabled,\n  DEFAULT_MIN_RESULTS,\n  GAP_THRESHOLD_MULTIPLIER,\n} from './confidence-truncation.js';\nimport {\n  getDynamicTokenBudget,\n  isDynamicTokenBudgetEnabled,\n  DEFAULT_TOKEN_BUDGET_CONFIG,\n} from './dynamic-token-budget.js';\nimport {\n  buildProgressiveResponse,\n  DEFAULT_PAGE_SIZE,\n} from './progressive-disclosure.js';\nimport type {\n  ProgressiveResponse,\n  DisclosureResult,\n} from './progressive-disclosure.js';\nimport { resolveFusionIntentContract } from './search-utils.js';\nimport { ensureDescriptionCache, getSpecsBasePaths } from './folder-discovery.js';\nimport {\n  isFolderScoringEnabled,\n  lookupFolders,\n  computeFolderRelevanceScores,\n  enrichResultsWithFolderScores,\n  twoPhaseRetrieval,\n} from './folder-relevance.js';\nimport { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n\nimport { collapseAndReassembleChunkResults } from '../scoring/mpab-aggregation.js';\n\n// Type-only\nimport type Database from 'better-sqlite3';\nimport type { SpreadResult } from '../cognitive/co-activation.js';\nimport type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport type { FusionResult } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport type { ChannelName } from './query-router.js';\nimport type { EnforcementResult } from './channel-enforcement.js';\nimport type { TruncationResult } from './confidence-truncation.js';\n\n// 2. INTERFACES\n\ntype VectorSearchFn = (\n  embedding: Float32Array | number[],\n  options: Record<string, unknown>\n) => Array<Record<string, unknown>>;\n\ninterface HybridSearchOptions {\n  limit?: number;\n  specFolder?: string;\n  minSimilarity?: number;\n  useBm25?: boolean;\n  useFts?: boolean;\n  useVector?: boolean;\n  useGraph?: boolean;\n  includeArchived?: boolean;\n  includeContent?: boolean;\n  /**\n   * Evaluation-only mode.\n   * When true, preserve the requested top-K window by bypassing confidence\n   * truncation and token-budget truncation without changing live defaults.\n   */\n  evaluationMode?: boolean;\n  /** Classified query intent for adaptive fusion weight selection (e.g. 'understand', 'fix_bug'). */\n  intent?: string;\n  /** Optional trigger phrases for query-classifier trigger-match routing path. */\n  triggerPhrases?: string[];\n  /**\n   * Internal fallback override: when true, bypass complexity routing and\n   * enable all retrieval channels for this search call.\n   */\n  forceAllChannels?: boolean;\n  /**\n   * Internal raw-candidate mode used by the Stage 1 pipeline.\n   * When true, stop after channel collection and return pre-fusion candidates.\n   */\n  skipFusion?: boolean;\n  /**\n   * Internal pipeline handoff mode.\n   * When true, return immediately after adaptive/RRF fusion so Stage 2/3 can\n   * apply the remaining pipeline scoring and aggregation steps.\n   */\n  stopAfterFusion?: boolean;\n}\n\ninterface HybridSearchResult {\n  id: number | string;\n  /**\n   * Normalized relevance score (0-1). Semantics depend on `source`:\n   * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n   * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n   * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n   * - `'graph'` — graph traversal relevance\n   *\n   * After hybrid merge, all source scores are min-max normalized to 0-1 within\n   * their source group to ensure fair cross-method comparison.\n   */\n  score: number;\n  source: string;\n  title?: string;\n  [key: string]: unknown;\n}\n\ntype HardExclusionSource = 'archived-tier' | 'deprecated-tier';\ntype HardExclusionClassification = 'intended' | 'silent-risk' | 'unclassified';\n\ninterface HardExclusionPredicate {\n  id: string;\n  source: HardExclusionSource;\n  channel: string;\n  predicate: string;\n  defaultApplied: boolean;\n  classification: HardExclusionClassification;\n}\n\nconst HARD_EXCLUSION_PREDICATES: readonly HardExclusionPredicate[] = Object.freeze([\n  {\n    id: 'includeArchived-default',\n    source: 'archived-tier',\n    channel: 'vector/fts',\n    predicate: 'includeArchived defaults to false',\n    defaultApplied: true,\n    classification: 'intended',\n  },\n  {\n    id: 'fts-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'fts',\n    predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'bm25-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'bm25',\n    predicate: \"importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'trigger-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'trigger',\n    predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'structural-deprecated-archived-tier',\n    source: 'deprecated-tier',\n    channel: 'structural',\n    predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n]);\n\n/** Return recall-path exclusion metadata without executing or changing search. */\nfunction getHardExclusionPredicates(): HardExclusionPredicate[] {\n  return HARD_EXCLUSION_PREDICATES.map((predicate) => ({ ...predicate }));\n}\n\ntype Bm25MemoryMetadata = {\n  specFolder: string | null;\n  importanceTier: string | null;\n};\n\n/** Non-enumerable shadow metadata attached to result arrays via Object.defineProperty. */\ninterface ShadowMetaArray {\n  _s4shadow?: unknown;\n  _s4attribution?: unknown;\n  _degradation?: unknown;\n}\n\n/** Normalize a fused RRF result to the HybridSearchResult contract. */\nfunction toHybridResult(result: FusionResult): HybridSearchResult {\n  const sourceCandidate = (result as { source?: unknown }).source;\n  const primarySource = result.sources[0] ?? 'hybrid';\n  const scoreCandidate = (result as { score?: unknown }).score;\n\n  return {\n    ...result,\n    id: result.id,\n    score: typeof scoreCandidate === 'number' ? scoreCandidate : result.rrfScore,\n    source: typeof sourceCandidate === 'string' ? sourceCandidate : primarySource,\n  };\n}\n\n// PIPELINE METADATA\n\n/**\n * Optional metadata about pipeline stages attached to enhanced search results.\n * Only populated when the corresponding feature flags are enabled.\n */\ninterface Sprint3PipelineMeta {\n  /** Query complexity routing result (SPECKIT_COMPLEXITY_ROUTER). */\n  routing?: {\n    tier: string;\n    channels: string[];\n    skippedChannels: string[];\n    featureFlagEnabled: boolean;\n    confidence: string;\n    features: Record<string, unknown>;\n  };\n  /** Channel enforcement result (SPECKIT_CHANNEL_MIN_REP). */\n  enforcement?: { applied: boolean; promotedCount: number; underRepresentedChannels: string[] };\n  /** Confidence truncation result (SPECKIT_CONFIDENCE_TRUNCATION). */\n  truncation?: {\n    truncated: boolean;\n    originalCount: number;\n    truncatedCount: number;\n    medianGap: number;\n    cutoffGap: number;\n    cutoffIndex: number;\n    thresholdMultiplier: number;\n    minResultsGuaranteed: number;\n    featureFlagEnabled: boolean;\n  };\n  /** Dynamic token budget result (SPECKIT_DYNAMIC_TOKEN_BUDGET). */\n  tokenBudget?: {\n    tier: string;\n    budget: number;\n    applied: boolean;\n    featureFlagEnabled: boolean;\n    configValues: Record<string, number>;\n    headerOverhead: number;\n    adjustedBudget: number;\n  };\n}\n\n// 4. PI-A2: DEGRADATION TYPES\n\n/** Fallback tier in the 3-tier degradation chain. */\ntype FallbackTier = 1 | 2 | 3;\n\n/** Why degradation was triggered at a given tier. */\ninterface DegradationTrigger {\n  reason: 'low_quality' | 'insufficient_results' | 'both';\n  topScore: number;\n  resultCount: number;\n  relativeGap?: number;\n}\n\n/** Record of a single degradation event during tiered fallback. */\ninterface DegradationEvent {\n  tier: FallbackTier;\n  trigger: DegradationTrigger;\n  resultCountBefore: number;\n  resultCountAfter: number;\n}\n\n/**\n * Absolute quality floor for degradation checks.\n *\n * Raw RRF scores are typically small decimals (often <0.05), so a\n * high fixed threshold causes false degradations. Use a conservative floor and\n * pair it with a relative-gap check to avoid score-scale coupling.\n */\nconst DEGRADATION_QUALITY_THRESHOLD = 0.02;\n\n/** Minimum relative separation between top-1 and top-2 scores. */\nconst DEGRADATION_MIN_RELATIVE_GAP = 0.2;\n\n/** Minimum result count: must have >= this many results to stay at current tier. */\nconst DEGRADATION_MIN_RESULTS = 3;\n\n// 5. MODULE STATE\n\n/** Default result limit when none is specified by the caller. */\nconst DEFAULT_LIMIT = 20;\n/** Primary vector similarity floor for hybrid fallback passes (percentage units). */\nconst PRIMARY_FALLBACK_MIN_SIMILARITY = 30;\n/** Secondary vector similarity floor for adaptive retry passes (percentage units). */\nconst SECONDARY_FALLBACK_MIN_SIMILARITY = 17;\n/** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\nconst TIERED_FALLBACK_MIN_SIMILARITY = 10;\n\n/** Minimum MMR candidates required for diversity reranking to be worthwhile. */\nconst MMR_MIN_CANDIDATES = 2;\n\n/** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\nconst MMR_DEFAULT_LAMBDA = 0.7;\n\n/** Number of top results used as seeds for co-activation spreading. */\nconst SPREAD_ACTIVATION_TOP_N = 5;\n\n/** Maximum contextual tree header length prepended to content (including brackets). */\nconst CONTEXT_HEADER_MAX_CHARS = 100;\n/** Header/content separator characters added during contextual tree injection. */\nconst CONTEXT_HEADER_SEPARATOR_CHARS = 1;\n/** Reserved token overhead per contextual header, calibrated to max header length. */\nconst CONTEXT_HEADER_TOKEN_OVERHEAD = Math.ceil(\n  (CONTEXT_HEADER_MAX_CHARS + CONTEXT_HEADER_SEPARATOR_CHARS) / 4\n);\n\nlet db: Database.Database | null = null;\nlet vectorSearchFn: VectorSearchFn | null = null;\nlet graphSearchFn: GraphSearchFn | null = null;\nlet enrichFusedResultsObserver: (() => void) | null = null;\n\n// 6. GRAPH CHANNEL METRICS\n\ninterface GraphChannelMetrics {\n  totalQueries: number;\n  graphHits: number;\n  graphResultCount: number;\n  graphOnlyResults: number;\n  graphMultiSourceResults: number;\n  multiSourceResults: number;\n  degreeQueries: number;\n  degreeHits: number;\n  degreeResultCount: number;\n}\n\nconst graphMetrics: GraphChannelMetrics = {\n  totalQueries: 0,\n  graphHits: 0,\n  graphResultCount: 0,\n  graphOnlyResults: 0,\n  graphMultiSourceResults: 0,\n  multiSourceResults: 0,\n  degreeQueries: 0,\n  degreeHits: 0,\n  degreeResultCount: 0,\n};\n\n/**\n * Return current graph channel metrics for health check reporting.\n * graphHitRate is computed as graphHits / totalQueries.\n */\nfunction getGraphMetrics(): GraphChannelMetrics & { graphHitRate: number; degreeHitRate: number } {\n  return {\n    ...graphMetrics,\n    graphHitRate: graphMetrics.totalQueries > 0\n      ? graphMetrics.graphHits / graphMetrics.totalQueries\n      : 0,\n    degreeHitRate: graphMetrics.degreeQueries > 0\n      ? graphMetrics.degreeHits / graphMetrics.degreeQueries\n      : 0,\n  };\n}\n\n/** Reset all graph channel metrics counters to zero. */\nfunction resetGraphMetrics(): void {\n  graphMetrics.totalQueries = 0;\n  graphMetrics.graphHits = 0;\n  graphMetrics.graphResultCount = 0;\n  graphMetrics.graphOnlyResults = 0;\n  graphMetrics.graphMultiSourceResults = 0;\n  graphMetrics.multiSourceResults = 0;\n  graphMetrics.degreeQueries = 0;\n  graphMetrics.degreeHits = 0;\n  graphMetrics.degreeResultCount = 0;\n}\n\n// 7. INITIALIZATION\n\n/**\n * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n * @param database - The better-sqlite3 database instance for FTS and graph queries.\n * @param vectorFn - Optional vector search function for semantic similarity.\n * @param graphFn - Optional graph search function for causal/structural retrieval.\n */\nfunction init(\n  database: Database.Database,\n  vectorFn: VectorSearchFn | null = null,\n  graphFn: GraphSearchFn | null = null\n): void {\n  db = database;\n  vectorSearchFn = vectorFn;\n  graphSearchFn = graphFn;\n}\n\n// 8. BM25 SEARCH\n\n/**\n * Search the BM25 index with optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit and specFolder filter.\n * @returns Array of BM25-scored results tagged with source 'bm25'.\n */\nfunction bm25Search(\n  query: string,\n  options: { limit?: number; specFolder?: string } = {}\n): HybridSearchResult[] {\n  if (!isBm25Enabled()) {\n    console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n\n  try {\n    if (shouldUseSqliteLexicalEngine(db)) {\n      return ftsSearch(query, {\n        limit,\n        specFolder,\n      }).map((result) => ({\n        ...result,\n        bm25_score: result.score,\n        source: 'bm25',\n        sources: Array.from(new Set([\n          ...(\n            Array.isArray((result as Record<string, unknown>).sources)\n              ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n              : []\n          ),\n          'fts',\n          'bm25',\n        ])),\n      }));\n    }\n\n    // Spec-folder scope can only be resolved from DB metadata; fail closed before\n    // searching when the DB is unavailable rather than over-fetching the whole\n    // corpus and then discarding it.\n    if (specFolder && !db) {\n      console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n      return [];\n    }\n\n    const index = getIndex();\n    const candidateLimit = (specFolder || db)\n      ? index.getStats().documentCount\n      : limit;\n    // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n    // candidate set whenever those filters can remove otherwise top-ranked hits.\n    const results = index.search(query, candidateLimit);\n\n    // BM25 document IDs are stringified\n    // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n    // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n\n    // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n    // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n    // resolution returns [] rather than leaking unscoped BM25 candidates.\n    let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n    if (results.length > 0) {\n      if (!db) {\n        if (specFolder) {\n          const error = new Error('Database unavailable for spec-folder scope lookup');\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      } else {\n        try {\n          const ids = results.map((r: { id: string }) => Number(r.id));\n          memoryMetadataMap = new Map();\n          // Resolve metadata in bounded batches. The candidate set can now be\n          // corpus-sized (over-fetch for scope/tier filtering), and a single\n          // IN (...) with one bind per id would exceed SQLite's parameter limit\n          // and throw — which the catch below turns into an empty result.\n          const METADATA_BATCH = 500;\n          for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n            const batch = ids.slice(offset, offset + METADATA_BATCH);\n            const placeholders = batch.map(() => '?').join(',');\n            const rows = db.prepare(\n              `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n            ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n            for (const row of rows) {\n              memoryMetadataMap.set(row.id, {\n                specFolder: row.spec_folder,\n                importanceTier: row.importance_tier,\n              });\n            }\n          }\n        } catch (error: unknown) {\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      }\n\n      // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n      // is still null after the resolution block, something unexpected happened.\n      // Fail closed rather than falling through to unscoped results.\n      if (specFolder && !memoryMetadataMap) {\n        const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n        console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n        return [];\n      }\n    }\n\n    const excludeCold = !isArchivedRetrievalIncludedByDefault();\n    return results\n      .filter((r: { id: string }) => {\n        const metadata = memoryMetadataMap?.get(Number(r.id));\n        // Cold/deprecated rows are included by default (FSRS ranks them lower);\n        // only drop them when archived retrieval is disabled.\n        if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n        if (!specFolder) return true;\n        if (!metadata) return false;\n        const folder = metadata.specFolder;\n        if (!folder) return false;\n        return folder === specFolder || folder.startsWith(specFolder + '/');\n      })\n      .slice(0, limit)\n      .map((r: { id: string; score: number }) => ({\n        ...r,\n        source: 'bm25',\n      }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check whether the BM25 index is populated and available for search.\n * @returns True if the BM25 index exists and contains at least one document.\n */\nfunction isBm25Available(): boolean {\n  if (!isBm25Enabled()) {\n    return false;\n  }\n\n  try {\n    const index = getIndex();\n    return index.getStats().documentCount > 0;\n  } catch (_err: unknown) {\n    // Swallow index-not-initialized errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n// 9. FTS SEARCH\n\n/**\n * Check whether the FTS5 full-text search table exists in the database.\n * @returns True if the memory_fts table exists in the connected database.\n */\nfunction isFtsAvailable(): boolean {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — isFtsAvailable returning false');\n    return false;\n  }\n\n  try {\n    const result = (db.prepare(`\n      SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n    `) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch (_err: unknown) {\n    // Swallow DB errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n/**\n * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Array of FTS-scored results tagged with source 'fts'.\n */\nfunction ftsSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db || !isFtsAvailable()) {\n    console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n\n  try {\n    // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n    // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n    // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n    // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n    const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n\n    return bm25Results.map(row => ({\n      ...row,\n      id: row.id as number,\n      score: row.fts_score || 0,\n      source: 'fts',\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n    return [];\n  }\n}\n\n// 10. COMBINED LEXICAL SEARCH\n\n/**\n * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Deduplicated array of merged results sorted by score descending.\n */\nfunction combinedLexicalSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  const ftsResults = ftsSearch(query, options);\n  const bm25Results = bm25Search(query, options);\n\n  // Merge by canonical ID, prefer FTS scores.\n  // CanonicalResultId() prevents duplicate rows when one channel emits\n  // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const r of ftsResults) {\n    merged.set(canonicalResultId(r.id), r);\n  }\n\n  for (const r of bm25Results) {\n    const canonicalId = canonicalResultId(r.id);\n    if (!merged.has(canonicalId)) {\n      merged.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(merged.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, options.limit || DEFAULT_LIMIT);\n}\n\nfunction normalizeTriggerText(value: string): string {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction triggerQueryTokens(query: string): string[] {\n  return Array.from(new Set(\n    normalizeTriggerText(query)\n      .split(/\\s+/)\n      .filter((token) => token.length >= 2)\n  ));\n}\n\nfunction computeTriggerMatchScore(query: string, phrase: string): number {\n  const normalizedQuery = normalizeTriggerText(query);\n  const normalizedPhrase = normalizeTriggerText(phrase);\n  if (!normalizedQuery || !normalizedPhrase) return 0;\n  if (normalizedPhrase === normalizedQuery) return 1.0;\n\n  const queryTokens = triggerQueryTokens(normalizedQuery);\n  const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n  if (phraseTokens.size < 2) return 0;\n  if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n  if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n  if (queryTokens.length === 0) return 0;\n  const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n  const coverage = overlap / queryTokens.length;\n  return coverage >= 0.8 ? coverage * 0.75 : 0;\n}\n\nfunction timestampBoost(value: unknown): number {\n  if (typeof value !== 'string' || value.length === 0) return 0;\n  const parsed = Date.parse(value);\n  if (!Number.isFinite(parsed)) return 0;\n  const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n  return 1 / (1 + ageDays / 30);\n}\n\nfunction exactTriggerSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db) return [];\n\n  const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n  if (tokens.length === 0) return [];\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n  const normalizedQuery = normalizeTriggerText(query);\n  const exactPhraseLike = `%${normalizedQuery}%`;\n  const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n  const conditions = [\n    `m.trigger_phrases IS NOT NULL`,\n    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE ${conditions.join(' AND ')}\n      ORDER BY\n        CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n        COALESCE(m.updated_at, m.created_at, '') DESC\n      LIMIT ${candidateLimit}\n    `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n\n    return rows\n      .map((row): HybridSearchResult | null => {\n        const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n        const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n        if (matchScore <= 0) return null;\n\n        const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n          ? Math.max(0, Math.min(1, row.importance_weight))\n          : 0.5;\n        const recency = timestampBoost(row.updated_at ?? row.created_at);\n        const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n\n        return {\n          ...row,\n          id: row.id as number,\n          score,\n          triggerScore: matchScore,\n          source: 'trigger',\n        };\n      })\n      .filter((row): row is HybridSearchResult => row !== null)\n      .sort((a, b) => {\n        const scoreDelta = b.score - a.score;\n        if (scoreDelta !== 0) return scoreDelta;\n        const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n        const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n        return bTime - aTime;\n      })\n      .slice(0, limit);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n    return [];\n  }\n}\n\ntype RawChannelList = {\n  source: string;\n  results: Array<{ id: number | string; [key: string]: unknown }>;\n};\n\nfunction resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n    return result.score;\n  }\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n    return result.similarity / 100;\n  }\n  return 0;\n}\n\nfunction getCandidateSources(result: HybridSearchResult): string[] {\n  const sourceList = (result as { sources?: unknown }).sources;\n  if (Array.isArray(sourceList)) {\n    return sourceList.filter((value): value is string => typeof value === 'string');\n  }\n  return typeof result.source === 'string' && result.source.length > 0\n    ? [result.source]\n    : [];\n}\n\nfunction getCandidateSourceScores(result: HybridSearchResult): Record<string, number> {\n  const sourceScores = (result as { sourceScores?: unknown }).sourceScores;\n  if (sourceScores && typeof sourceScores === 'object' && !Array.isArray(sourceScores)) {\n    const normalizedScores: Record<string, number> = {};\n    for (const [source, score] of Object.entries(sourceScores as Record<string, unknown>)) {\n      if (typeof score === 'number' && Number.isFinite(score)) {\n        normalizedScores[source] = score;\n      }\n    }\n    return normalizedScores;\n  }\n\n  const fallbackScores: Record<string, number> = {};\n  const resultScore = typeof result.score === 'number' && Number.isFinite(result.score)\n    ? result.score\n    : 0;\n  for (const source of getCandidateSources(result)) {\n    fallbackScores[source] = resultScore;\n  }\n  return fallbackScores;\n}\n\nfunction mergeRawCandidate(\n  existing: HybridSearchResult | undefined,\n  incoming: HybridSearchResult\n): HybridSearchResult {\n  if (!existing) {\n    const sources = getCandidateSources(incoming);\n    const channelCount = sources.length;\n    return {\n      ...incoming,\n      sources,\n      channelCount,\n      sourceScores: getCandidateSourceScores(incoming),\n      channelAttribution: sources,\n    };\n  }\n\n  const existingScore = typeof existing.score === 'number' && Number.isFinite(existing.score)\n    ? existing.score\n    : 0;\n  const incomingScore = typeof incoming.score === 'number' && Number.isFinite(incoming.score)\n    ? incoming.score\n    : 0;\n  const primary = incomingScore > existingScore ? incoming : existing;\n  const secondary = primary === incoming ? existing : incoming;\n  const sources = Array.from(new Set([\n    ...getCandidateSources(existing),\n    ...getCandidateSources(incoming),\n  ]));\n  const channelCount = sources.length;\n  const crossChannelBonus = Math.min(0.06, 0.02 * Math.max(0, channelCount - 1));\n  const mergedScore = Math.max(0, Math.min(1, Math.max(existingScore, incomingScore) + crossChannelBonus));\n\n  return {\n    ...(secondary ?? {}),\n    ...primary,\n    score: mergedScore,\n    source: typeof primary.source === 'string' ? primary.source : (sources[0] ?? 'hybrid'),\n    sources,\n    channelCount,\n    sourceScores: {\n      ...getCandidateSourceScores(existing),\n      ...getCandidateSourceScores(incoming),\n    },\n    channelAttribution: sources,\n  };\n}\n\nfunction collectCandidatesFromLists(\n  lists: RawChannelList[],\n  limit?: number\n): HybridSearchResult[] {\n  const deduped = new Map<string, HybridSearchResult>();\n\n  for (const list of lists) {\n    if (!Array.isArray(list.results) || list.results.length === 0) continue;\n\n    const scored = list.results.map((result) => {\n      const rawScore = resolveRawCandidateScore(result as { score?: unknown; similarity?: unknown });\n      return { result, rawScore };\n    });\n\n    let min = Infinity;\n    let max = -Infinity;\n    for (const { rawScore } of scored) {\n      if (rawScore < min) min = rawScore;\n      if (rawScore > max) max = rawScore;\n    }\n    const range = max - min;\n\n    for (const { result, rawScore } of scored) {\n      const normalizedScore = range > 0 ? (rawScore - min) / range : (rawScore > 0 ? 1.0 : 0);\n      const candidate: HybridSearchResult = {\n        ...result,\n        id: result.id,\n        source: list.source,\n        score: normalizedScore,\n        sources: [list.source],\n        sourceScores: { [list.source]: normalizedScore },\n        channelAttribution: [list.source],\n      };\n      const key = canonicalResultId(candidate.id);\n      deduped.set(key, mergeRawCandidate(deduped.get(key), candidate));\n    }\n  }\n\n  return applyResultLimit(\n    Array.from(deduped.values()).sort((a, b) => {\n      const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n      const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n      return bScore - aScore;\n    }),\n    limit\n  );\n}\n\nfunction mergeRawCandidateSets(\n  existing: HybridSearchResult[],\n  incoming: HybridSearchResult[],\n  limit?: number\n): HybridSearchResult[] {\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const result of [...existing, ...incoming]) {\n    const key = canonicalResultId(result.id);\n    merged.set(key, mergeRawCandidate(merged.get(key), result));\n  }\n\n  return applyResultLimit(\n    Array.from(merged.values()).sort((a, b) => {\n      const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n      const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n      return bScore - aScore;\n    }),\n    limit\n  );\n}\n\nfunction getAllowedChannels(options: HybridSearchOptions): Set<ChannelName> {\n  const allowed = new Set<ChannelName>(['vector', 'fts', 'graph', 'degree']);\n\n  if (isBm25Enabled()) {\n    allowed.add('bm25');\n  }\n\n  if (options.useVector === false) allowed.delete('vector');\n  if (options.useBm25 === false) allowed.delete('bm25');\n  if (options.useFts === false) allowed.delete('fts');\n  if (options.useGraph === false) {\n    allowed.delete('graph');\n    allowed.delete('degree');\n  }\n\n  return allowed;\n}\n\nfunction applyAllowedChannelOverrides(\n  options: HybridSearchOptions,\n  allowedChannels: Set<ChannelName>,\n  overrides: Partial<HybridSearchOptions> = {}\n): HybridSearchOptions {\n  return {\n    ...options,\n    ...overrides,\n    useVector: allowedChannels.has('vector'),\n    useBm25: allowedChannels.has('bm25'),\n    useFts: allowedChannels.has('fts'),\n    useGraph: allowedChannels.has('graph'),\n  };\n}\n\ntype FallbackPlanKind = 'adaptive' | 'tiered';\ntype FallbackStageName = 'primary' | 'retry';\n\ninterface FallbackPlanStage {\n  stage: FallbackStageName;\n  options: HybridSearchOptions;\n  results: HybridSearchResult[];\n  execution: HybridFusionExecution | null;\n  trigger?: 'empty' | DegradationTrigger;\n}\n\ninterface FallbackPlanExecution {\n  allowedChannels: Set<ChannelName>;\n  stages: FallbackPlanStage[];\n}\n\ninterface HybridFusionExecution {\n  evaluationMode: boolean;\n  intent: string;\n  lists: Array<{\n    source: string;\n    results: Array<{ id: number | string; [key: string]: unknown }>;\n    weight?: number;\n  }>;\n  routeResult: ReturnType<typeof routeQuery>;\n  budgetResult: ReturnType<typeof getDynamicTokenBudget>;\n  s3meta: Sprint3PipelineMeta;\n  fusedResults: HybridSearchResult[];\n  vectorEmbeddingCache: Map<number, Float32Array>;\n}\n\nfunction resolveAdaptiveDocumentType(\n  lists: Array<{ results: Array<Record<string, unknown>> }>,\n): string | undefined {\n  const counts = new Map<string, number>();\n  for (const list of lists) {\n    for (const result of list.results.slice(0, 3)) {\n      const candidate = result.documentType ?? result.document_type;\n      if (typeof candidate !== 'string' || candidate.length === 0) {\n        continue;\n      }\n      counts.set(candidate, (counts.get(candidate) ?? 0) + 1);\n    }\n  }\n\n  let topType: string | undefined;\n  let topCount = 0;\n  for (const [documentType, count] of counts) {\n    if (count > topCount) {\n      topType = documentType;\n      topCount = count;\n    }\n  }\n\n  return topType;\n}\n\nfunction markFallbackRetry(results: HybridSearchResult[]): HybridSearchResult[] {\n  for (const result of results) {\n    (result as Record<string, unknown>).fallbackRetry = true;\n  }\n\n  return results;\n}\n\nfunction toEmbeddingBufferView(value: unknown): Float32Array | null {\n  if (value instanceof Float32Array) {\n    return value;\n  }\n\n  if (Array.isArray(value)) {\n    const asNumbers = value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));\n    return asNumbers ? new Float32Array(value) : null;\n  }\n\n  if (Buffer.isBuffer(value)) {\n    return new Float32Array(value.buffer, value.byteOffset, value.byteLength / 4);\n  }\n\n  return null;\n}\n\nasync function executeFallbackPlan(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {},\n  planKind: FallbackPlanKind,\n  overrides: Partial<HybridSearchOptions> = {}\n): Promise<FallbackPlanExecution> {\n  const allowedChannels = getAllowedChannels(options);\n  const stages: FallbackPlanStage[] = [];\n\n  const primaryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n    minSimilarity: options.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY,\n    ...overrides,\n  });\n  const primaryExecution = await collectAndFuseHybridResults(query, embedding, primaryOptions);\n  const primaryResults = primaryExecution\n    ? applyResultLimit(primaryExecution.fusedResults, primaryOptions.limit)\n    : await hybridSearch(query, embedding, primaryOptions);\n  stages.push({\n    stage: 'primary',\n    options: primaryOptions,\n    results: primaryResults,\n    execution: primaryExecution,\n  });\n\n  if (planKind === 'tiered') {\n    const trigger = checkDegradation(primaryResults);\n    if (!trigger) {\n      return { allowedChannels, stages };\n    }\n\n    const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n      ...overrides,\n      minSimilarity: TIERED_FALLBACK_MIN_SIMILARITY,\n      forceAllChannels: true,\n    });\n    const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n    const retryResults = retryExecution\n      ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n      : await hybridSearch(query, embedding, retryOptions);\n    stages.push({\n      stage: 'retry',\n      options: retryOptions,\n      results: retryResults,\n      execution: retryExecution,\n      trigger,\n    });\n    return { allowedChannels, stages };\n  }\n\n  const primaryMinSimilarity = primaryOptions.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY;\n  if (primaryResults.length === 0 && primaryMinSimilarity >= SECONDARY_FALLBACK_MIN_SIMILARITY) {\n    const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n      ...overrides,\n      minSimilarity: SECONDARY_FALLBACK_MIN_SIMILARITY,\n    });\n    const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n    const retryResultsBase = retryExecution\n      ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n      : await hybridSearch(query, embedding, retryOptions);\n    const retryResults = retryResultsBase.length > 0\n      ? markFallbackRetry(retryResultsBase)\n      : retryResultsBase;\n    stages.push({\n      stage: 'retry',\n      options: retryOptions,\n      results: retryResults,\n      execution: retryExecution,\n      trigger: 'empty',\n    });\n  }\n\n  return { allowedChannels, stages };\n}\n\n// 11. HYBRID SEARCH\n\n/**\n * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n * Retained as internal fallback only.\n */\nasync function hybridSearch(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,\n    useGraph = true,\n    includeArchived = false,\n  } = options;\n\n  const results: HybridSearchResult[] = [];\n\n  // Vector search\n  if (useVector && embedding && vectorSearchFn) {\n    try {\n      const vectorResults = vectorSearchFn(embedding, {\n        limit,\n        specFolder,\n        minSimilarity,\n        includeConstitutional: false, // Handler manages constitutional separately\n        includeArchived,\n      });\n      for (const r of vectorResults) {\n        results.push({\n          ...r,\n          id: r.id as number,\n          score: (r.similarity as number) || 0,\n          source: 'vector',\n        });\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n    }\n  }\n\n  // FTS search\n  if (useFts) {\n    const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n    results.push(...ftsResults);\n  }\n\n  // BM25 search\n  if (useBm25) {\n    const bm25Results = bm25Search(query, { limit, specFolder });\n    results.push(...bm25Results);\n  }\n\n  // Graph search\n  if (useGraph && graphSearchFn) {\n    try {\n      graphMetrics.totalQueries++;\n      const graphResults = graphSearchFn(query, { limit, specFolder });\n      for (const r of graphResults) {\n        results.push({\n          ...r,\n          id: r.id as number | string,\n          score: (r.score as number) || 0,\n          source: 'graph',\n        });\n      }\n      if (graphResults.length > 0) {\n        graphMetrics.graphHits++;\n        graphMetrics.graphResultCount += graphResults.length;\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n    }\n  }\n\n  // Normalize scores per source before merging so one method's raw scale\n  // Does not dominate others during final ranking.\n  const bySource = new Map<string, HybridSearchResult[]>();\n  for (const r of results) {\n    const src = r.source || 'unknown';\n    if (!bySource.has(src)) bySource.set(src, []);\n    bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n  }\n\n  const normalized: HybridSearchResult[] = [];\n  for (const [, group] of bySource) {\n    if (group.length === 0) continue;\n    const scores = group.map(r => r.score);\n    let min = Infinity;\n    let max = -Infinity;\n    for (const s of scores) {\n      if (s < min) min = s;\n      if (s > max) max = s;\n    }\n    const range = max - min;\n    for (const r of group) {\n      normalized.push({\n        ...r,\n        score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n      });\n    }\n  }\n\n  // Deduplicate by ID (keep highest normalized score)\n  // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n  // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n  // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n  // Field and downstream consumers would need to be updated accordingly.\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const r of normalized) {\n    const canonicalId = canonicalResultId(r.id);\n    const existing = deduped.get(canonicalId);\n    if (!existing || r.score > existing.score) {\n      deduped.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(deduped.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, limit);\n}\n\n/**\n * Enhanced hybrid search with RRF fusion.\n * All search channels use synchronous better-sqlite3; sequential execution\n * is correct — Promise.all would add overhead without achieving parallelism.\n */\nasync function hybridSearchEnhanced(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const execution = await collectAndFuseHybridResults(query, embedding, options);\n  if (execution) {\n    if (options.stopAfterFusion) {\n      return applyResultLimit(execution.fusedResults, options.limit);\n    }\n\n    return enrichFusedResults(query, execution, options);\n  }\n\n  return hybridSearch(query, embedding, options);\n}\n\nasync function collectAndFuseHybridResults(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridFusionExecution | null> {\n  try {\n    const evaluationMode = options.evaluationMode === true;\n    const lists: HybridFusionExecution['lists'] = [];\n\n    // Pipeline metadata collector (populated by flag-gated stages)\n    const s3meta: Sprint3PipelineMeta = {};\n\n    // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n    // When enabled, classifies query complexity and restricts channels to a\n    // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n    const routeResult = routeQuery(query, options.triggerPhrases);\n    const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n    const activeChannels = options.forceAllChannels\n      ? new Set<ChannelName>(allPossibleChannels)\n      : new Set<ChannelName>(routeResult.channels);\n\n    // Respect explicit caller channel disables across both the primary route and\n    // every fallback tier. useGraph=false also disables the dependent degree lane.\n    const allowedChannels = getAllowedChannels(options);\n    for (const channel of allPossibleChannels) {\n      if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n    }\n\n    const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n\n    if (skippedChannels.length > 0) {\n      s3meta.routing = {\n        tier: routeResult.tier,\n        channels: routeResult.channels,\n        skippedChannels,\n        featureFlagEnabled: isComplexityRouterEnabled(),\n        confidence: routeResult.classification.confidence,\n        features: routeResult.classification.features as Record<string, unknown>,\n      };\n    }\n\n    // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n    // Compute tier-aware budget early so it's available for downstream truncation.\n    // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n    // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n    const lowSignalQuery =\n      routeResult.classification.confidence === 'low' ||\n      routeResult.classification.confidence === 'fallback';\n    const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n      lowSignal: lowSignalQuery,\n    });\n    if (budgetResult.applied && !evaluationMode) {\n      s3meta.tokenBudget = {\n        tier: budgetResult.tier,\n        budget: budgetResult.budget,\n        applied: budgetResult.applied,\n        featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n        configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n        // headerOverhead and adjustedBudget are patched in below after they are computed\n        headerOverhead: 0,\n        adjustedBudget: budgetResult.budget,\n      };\n    }\n\n    // Channel results collected independently, merged after all complete\n    let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n    let ftsChannelResults: HybridSearchResult[] = [];\n    let bm25ChannelResults: HybridSearchResult[] = [];\n    let triggerChannelResults: HybridSearchResult[] = [];\n    const vectorEmbeddingCache = new Map<number, Float32Array>();\n\n    // All channels use synchronous better-sqlite3; sequential execution\n    // Is correct — Promise.all adds overhead without parallelism.\n\n    // Vector channel — gated by query-complexity routing\n    if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n      try {\n        const vectorResults = vectorSearchFn(embedding, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          minSimilarity: options.minSimilarity || 0,\n          includeConstitutional: false,\n          includeArchived: options.includeArchived || false,\n          includeEmbeddings: true,\n        });\n        semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n          ...r,\n          id: r.id as number | string,\n          source: 'vector',\n        }));\n        for (const result of semanticResults) {\n          if (typeof result.id !== 'number') continue;\n          const embeddingCandidate = toEmbeddingBufferView(\n            (result as Record<string, unknown>).embedding\n            ?? (result as Record<string, unknown>).embeddingBuffer\n          );\n          if (embeddingCandidate) {\n            vectorEmbeddingCache.set(result.id, embeddingCandidate);\n          }\n        }\n        lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n      } catch (_err: unknown) {\n        // Non-critical — vector channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n    if (activeChannels.has('fts')) {\n      ftsChannelResults = ftsSearch(query, options);\n      if (ftsChannelResults.length > 0) {\n        // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n        // flooding top-K with noisy lexical matches despite its exact-match value.\n        lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n      }\n    }\n\n    // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n    if (activeChannels.has('bm25')) {\n      bm25ChannelResults = bm25Search(query, options);\n      if (bm25ChannelResults.length > 0) {\n        // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n        // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n        lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n      }\n    }\n\n    triggerChannelResults = exactTriggerSearch(query, options);\n    if (triggerChannelResults.length > 0) {\n      lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n    }\n\n    // Graph channel — gated by query-complexity routing\n    const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n    if (useGraph && graphSearchFn) {\n      try {\n        graphMetrics.totalQueries++; // counted only if channel executes\n        const graphResults = graphSearchFn(query, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          intent: options.intent,\n        });\n        if (graphResults.length > 0) {\n          graphMetrics.graphHits++;\n          graphMetrics.graphResultCount += graphResults.length;\n          lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n            ...r,\n            id: r.id as number | string,\n          })), weight: 0.5 });\n        }\n      } catch (_err: unknown) {\n        // Non-critical — graph channel failure does not block pipeline","lineStart":1,"lineEnd":1445,"totalLines":1446,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781763777880,"end":1781763777892}},"metadata":{"openai":{"itemId":"fc_0d5b12e0056d81cf016a338ec1bf948191a0a5bae55c5424a2"}},"id":"prt_ed965a556001LsQh3k4cRhr6ci","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96570b6001iiEKAma30bzCSA"}}
{"type":"tool_use","timestamp":1781763777896,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_LSMPpGM0KWtDRWni5TZv4MUc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25 Index\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: import { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\n6: import {\n7:   normalizeLexicalQueryTokens,\n8:   sanitizeFTS5Query,\n9:   sanitizeQueryTokens,\n10:   simpleStem,\n11:   STOP_WORDS,\n12:   tokenize,\n13: } from './lexical-normalizer.js';\n14: import type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\n15: import { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n16: \n17: // ───────────────────────────────────────────────────────────────\n18: // 1. INTERFACES\n19: \n20: // ───────────────────────────────────────────────────────────────\n21: interface BM25SearchResult {\n22:   id: string;\n23:   /**\n24:    * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n25:    * Higher = better lexical match. Not directly comparable to vector similarity\n26:    * scores; use min-max normalization or RRF when combining with other methods.\n27:    */\n28:   score: number;\n29: }\n30: \n31: interface BM25Stats {\n32:   documentCount: number;\n33:   termCount: number;\n34:   avgDocLength: number;\n35: }\n36: \n37: interface BM25DocumentSource {\n38:   title?: string | null;\n39:   content_text?: string | null;\n40:   trigger_phrases?: string | string[] | null;\n41:   file_path?: string | null;\n42: }\n43: \n44: /* ───────────────────────────────────────────────────────────────\n45:    1B. CONSTANTS & FEATURE FLAG\n46:    ──────────────────────────────────────────────────────────────── */\n47: \n48: const DEFAULT_K1 = 1.2;\n49: const DEFAULT_B = 0.75;\n50: const BM25_WARMUP_BATCH_SIZE = 250;\n51: const PACKED_POSTING_CHUNK_SIZE = 128;\n52: const PACKED_POSTING_FIELD_WIDTH = 4;\n53: const PACKED_POSTING_MAX_BYTE_TF = 0xff;\n54: const PACKED_POSTING_MAX_NARROW_TF = 0xffff;\n55: const PACKED_POSTING_MAX_NARROW_DOC_ID = 0xffff;\n56: const PACKED_POSTING_MAX_NARROW_TERM_ID = 0xffff;\n57: const PACKED_POSTING_TITLE_OFFSET = 0;\n58: const PACKED_POSTING_TRIGGER_OFFSET = 1;\n59: const PACKED_POSTING_PATH_OFFSET = 2;\n60: const PACKED_POSTING_BODY_OFFSET = 3;\n61: const BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n62: const BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\n63: const BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\n64: type Bm25Engine = typeof BM25_ENGINE_VALUES[number];\n65: type InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\n66: type BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n67: \n68: const BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\n69: const BM25_ENGINE_LOGGED = new Set<string>();\n70: \n71: /**\n72:  * Field weight multipliers for weighted BM25 scoring.\n73:  * When indexing a document composed of multiple fields, multiply\n74:  * each field's token scores by the appropriate weight before\n75:  * accumulating the total document score.\n76:  *\n77:  * These weights are shared by the FTS5 path and the packed in-memory\n78:  * fallback so both lexical lanes preserve the same field-priority intent.\n79:  *\n80:  * title:           10.0 — exact title matches are the strongest signal\n81:  * trigger_phrases:  5.0 — curated keywords next most important\n82:  * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n83:  * body:             1.0 — baseline weight for full body / content_text\n84:  */\n85: const BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n86: \n87: const BM25_FIELD_WEIGHTS: Record<string, number> = {\n88:   title: BM25_FTS5_WEIGHTS[0],\n89:   trigger_phrases: BM25_FTS5_WEIGHTS[1],\n90:   content_generic: BM25_FTS5_WEIGHTS[2],\n91:   body: BM25_FTS5_WEIGHTS[3],\n92: };\n93: \n94: type BM25FieldWeights = Record<BM25FieldName, number>;\n95: \n96: interface BM25DocumentFields {\n97:   title?: string | null;\n98:   trigger_phrases?: string | string[] | null;\n99:   content_generic?: string | null;\n100:   body?: string | null;\n101: }\n102: \n103: interface BM25SearchOptions {\n104:   fieldWeights?: Partial<BM25FieldWeights>;\n105: }\n106: \n107: interface LegacyDocumentRecord {\n108:   tokens: string[];\n109:   termFreq: Map<string, number>;\n110: }\n111: \n112: interface PackedDocumentRecord {\n113:   numericId: number;\n114:   id: string;\n115:   length: number;\n116:   termIds: Uint16Array | Uint32Array;\n117: }\n118: \n119: type PackedFieldTfWidth = 1 | 2 | 4;\n120: \n121: interface PackedPostingStore {\n122:   docIdChunks: Array<Uint16Array | Uint32Array>;\n123:   fieldTfChunks: Array<Uint8Array | Uint16Array | Uint32Array>;\n124:   length: number;\n125:   sorted: boolean;\n126:   wideDocIds: boolean;\n127:   fieldTfWidth: PackedFieldTfWidth;\n128: }\n129: \n130: type PackedPostingMutable = PackedPostingStore;\n131: type PackedPostingList = PackedPostingStore;\n132: \n133: interface PackedPostingEntry {\n134:   docId: number;\n135:   titleTf: number;\n136:   triggerTf: number;\n137:   pathTf: number;\n138:   bodyTf: number;\n139: }\n140: \n141: type Bm25TokenInterns = Map<number, string[]>;\n142: \n143: /**\n144:  * Check whether the in-memory BM25 index is enabled.\n145:  *\n146:  * @returns `true` when BM25 indexing/search is enabled for the current process.\n147:  * @example\n148:  * ```ts\n149:  * if (isBm25Enabled()) {\n150:  *   getIndex();\n151:  * }\n152:  * ```\n153:  */\n154: function isBm25Enabled(): boolean {\n155:   const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n156:   if (!value) return true; // enabled by default\n157:   if (BM25_DISABLED_VALUES.has(value)) return false;\n158:   return BM25_ENABLED_VALUES.has(value);\n159: }\n160: \n161: // ───────────────────────────────────────────────────────────────\n162: // 2. HELPERS\n163: \n164: // ───────────────────────────────────────────────────────────────\n165: /**\n166:  * Count token frequency occurrences for BM25 scoring.\n167:  *\n168:  * @param tokens - Normalized tokens produced by {@link tokenize}.\n169:  * @returns A frequency map keyed by token text.\n170:  * @example\n171:  * ```ts\n172:  * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n173:  * // 2\n174:  * ```\n175:  */\n176: function getTermFrequencies(tokens: string[]): Map<string, number> {\n177:   const freq = new Map<string, number>();\n178:   for (const token of tokens) {\n179:     freq.set(token, (freq.get(token) || 0) + 1);\n180:   }\n181:   return freq;\n182: }\n183: \n184: function stemNormalizedToken(word: string): string {\n185:   let stem = word;\n186:   let suffixRemoved = false;\n187: \n188:   if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n189:   else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n190:   else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n191:   else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n192:   else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n193:   else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n194: \n195:   if (suffixRemoved && stem.length >= 3) {\n196:     const last = stem[stem.length - 1];\n197:     if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n198:       stem = stem.slice(0, -1);\n199:     }\n200:   }\n201: \n202:   return stem;\n203: }\n204: \n205: function bm25ContentNeedsNormalization(content: string): boolean {\n206:   return (\n207:     content.trim() !== content ||\n208:     content.startsWith('---') ||\n209:     content.includes('<!--') ||\n210:     content.includes('```') ||\n211:     content.includes('|') ||\n212:     /(?:^|\\n)\\s*(?:[-*]\\s+|\\d+\\.\\s+|#{1,6}\\s+)/.test(content) ||\n213:     /\\n{3,}/.test(content)\n214:   );\n215: }\n216: \n217: function normalizeContentForBM25IfNeeded(content: string): string {\n218:   return bm25ContentNeedsNormalization(content) ? normalizeContentForBM25(content) : content;\n219: }\n220: \n221: function hashBm25TokenSpan(text: string, start: number, end: number): number {\n222:   let hash = 2166136261;\n223:   for (let i = start; i < end; i += 1) {\n224:     let code = text.charCodeAt(i);\n225:     if (code >= 65 && code <= 90) {\n226:       code += 32;\n227:     }\n228:     hash ^= code;\n229:     hash = Math.imul(hash, 16777619);\n230:   }\n231:   return hash >>> 0;\n232: }\n233: \n234: function equalsBm25TokenSpan(candidate: string, text: string, start: number, end: number): boolean {\n235:   if (candidate.length !== end - start) {\n236:     return false;\n237:   }\n238: \n239:   for (let i = start; i < end; i += 1) {\n240:     let code = text.charCodeAt(i);\n241:     if (code >= 65 && code <= 90) {\n242:       code += 32;\n243:     }\n244:     if (candidate.charCodeAt(i - start) !== code) {\n245:       return false;\n246:     }\n247:   }\n248: \n249:   return true;\n250: }\n251: \n252: function internBm25Token(\n253:   text: string,\n254:   start: number,\n255:   end: number,\n256:   hasUppercase: boolean,\n257:   interns?: Bm25TokenInterns\n258: ): string {\n259:   if (!interns) {\n260:     return hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n261:   }\n262: \n263:   const hash = hashBm25TokenSpan(text, start, end);\n264:   const bucket = interns.get(hash);\n265:   if (bucket) {\n266:     for (const candidate of bucket) {\n267:       if (equalsBm25TokenSpan(candidate, text, start, end)) {\n268:         return candidate;\n269:       }\n270:     }\n271:   }\n272: \n273:   const token = hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n274:   if (bucket) {\n275:     bucket.push(token);\n276:   } else {\n277:     interns.set(hash, [token]);\n278:   }\n279:   return token;\n280: }\n281: \n282: function visitBm25Tokens(text: string, visitor: (token: string) => void, interns?: Bm25TokenInterns): void {\n283:   if (!text || typeof text !== 'string') return;\n284: \n285:   let tokenStart = -1;\n286:   let hasUppercase = false;\n287:   const flush = (tokenEnd: number) => {\n288:     if (tokenStart < 0) return;\n289:     if (tokenEnd - tokenStart >= 2) {\n290:       const token = internBm25Token(text, tokenStart, tokenEnd, hasUppercase, interns);\n291:       if (!STOP_WORDS.has(token)) {\n292:         visitor(stemNormalizedToken(token));\n293:       }\n294:     }\n295:     tokenStart = -1;\n296:     hasUppercase = false;\n297:   };\n298: \n299:   for (let i = 0; i < text.length; i += 1) {\n300:     const code = text.charCodeAt(i);\n301:     if (code >= 65 && code <= 90) {\n302:       if (tokenStart < 0) tokenStart = i;\n303:       hasUppercase = true;\n304:     } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n305:       if (tokenStart < 0) tokenStart = i;\n306:     } else if (tokenStart >= 0) {\n307:       flush(i);\n308:     }\n309:   }\n310: \n311:   flush(text.length);\n312: }\n313: \n314: function visitBm25FieldValue(\n315:   value: BM25DocumentFields[BM25FieldName],\n316:   visitor: (token: string) => void,\n317:   interns?: Bm25TokenInterns\n318: ): void {\n319:   if (Array.isArray(value)) {\n320:     for (const entry of value) {\n321:       visitBm25Tokens(entry, visitor, interns);\n322:     }\n323:     return;\n324:   }\n325: \n326:   visitBm25Tokens(value ?? '', visitor, interns);\n327: }\n328: \n329: function hasBm25DocumentText(fields: BM25DocumentFields): boolean {\n330:   for (const fieldName of BM25_FIELD_NAMES) {\n331:     const value = fields[fieldName];\n332:     if (Array.isArray(value)) {\n333:       if (value.some((entry) => typeof entry === 'string' && entry.trim().length > 0)) {\n334:         return true;\n335:       }\n336:     } else if (typeof value === 'string' && value.trim().length > 0) {\n337:       return true;\n338:     }\n339:   }\n340:   return false;\n341: }\n342: \n343: function normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n344:   if (Array.isArray(triggerPhrases)) {\n345:     return triggerPhrases\n346:       .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n347:       .join(' ');\n348:   }\n349: \n350:   if (typeof triggerPhrases !== 'string') {\n351:     return '';\n352:   }\n353: \n354:   const trimmed = triggerPhrases.trim();\n355:   if (!trimmed) {\n356:     return '';\n357:   }\n358: \n359:   try {\n360:     const parsed = JSON.parse(trimmed) as unknown;\n361:     if (Array.isArray(parsed)) {\n362:       return parsed\n363:         .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n364:         .join(' ');\n365:     }\n366:   } catch {\n367:     // Fall back to raw string when the database value is not JSON.\n368:   }\n369: \n370:   return trimmed;\n371: }\n372: \n373: function resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n374:   return {\n375:     title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n376:     trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n377:     content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n378:     body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n379:   };\n380: }\n381: \n382: function emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n383:   const key = `${engine}:${reason}`;\n384:   if (BM25_ENGINE_LOGGED.has(key)) {\n385:     return;\n386:   }\n387:   BM25_ENGINE_LOGGED.add(key);\n388:   // stderr keeps stdout clean for JSON-RPC frames under stdio transport.\n389:   console.warn(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n390: }\n391: \n392: function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n393:   const configured = resolveBm25Engine();\n394:   if (configured === 'legacy-inmemory') {\n395:     emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n396:     return 'legacy-inmemory';\n397:   }\n398: \n399:   if (configured === 'sqlite') {\n400:     emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n401:     return 'packed-inmemory';\n402:   }\n403: \n404:   if (configured === 'packed-inmemory') {\n405:     emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n406:     return 'packed-inmemory';\n407:   }\n408: \n409:   emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n410:   return 'packed-inmemory';\n411: }\n412: \n413: function buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n414:   return {\n415:     title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n416:     body: typeof row.content_text === 'string' && row.content_text.trim()\n417:       ? normalizeContentForBM25IfNeeded(row.content_text)\n418:       : '',\n419:     trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n420:     content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n421:   };\n422: }\n423: \n424: function buildBm25DocumentText(row: BM25DocumentSource): string {\n425:   const textParts: string[] = [];\n426: \n427:   if (typeof row.title === 'string' && row.title.trim()) {\n428:     textParts.push(row.title.trim());\n429:   }\n430: \n431:   if (typeof row.content_text === 'string' && row.content_text.trim()) {\n432:     textParts.push(normalizeContentForBM25IfNeeded(row.content_text));\n433:   }\n434: \n435:   const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n436:   if (triggerPhrases) {\n437:     textParts.push(triggerPhrases);\n438:   }\n439: \n440:   if (typeof row.file_path === 'string' && row.file_path.trim()) {\n441:     textParts.push(row.file_path.trim());\n442:   }\n443: \n444:   return textParts.join(' ').trim();\n445: }\n446: \n447: // ───────────────────────────────────────────────────────────────\n448: // 3. BM25 INDEX CLASS\n449: \n450: // ───────────────────────────────────────────────────────────────\n451: class BM25Index {\n452:   private k1: number;\n453:   private b: number;\n454:   private engine: InMemoryBm25Engine;\n455:   private documents: Map<string, LegacyDocumentRecord>;\n456:   private packedDocuments: Map<string, PackedDocumentRecord>;\n457:   private packedDocIds: Array<string | undefined>;\n458:   private packedFreeNumericIds: number[];\n459:   private packedDocNumbersById: Map<string, number>;\n460:   private packedMutablePostings: Map<string, PackedPostingMutable>;\n461:   private packedPostings: Map<string, PackedPostingList>;\n462:   private packedDirtyTerms: Set<string>;\n463:   private packedTokenInterns: Bm25TokenInterns;\n464:   private packedTermIdsByToken: Map<string, number>;\n465:   private packedTermsById: string[];\n466:   private packedScratchPositions: Int32Array;\n467:   private packedScratchTermIds: number[];\n468:   private packedScratchTotalTfs: number[];\n469:   private packedScratchTitleTfs: number[];\n470:   private packedScratchTriggerTfs: number[];\n471:   private packedScratchPathTfs: number[];\n472:   private packedScratchBodyTfs: number[];\n473:   private documentFreq: Map<string, number>;\n474:   private totalDocLength: number;\n475:   private warmupHandle: ReturnType<typeof setTimeout> | null;\n476:   private warmupGeneration: number;\n477: \n478:   constructor(\n479:     k1: number = DEFAULT_K1,\n480:     b: number = DEFAULT_B,\n481:     engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n482:   ) {\n483:     this.k1 = k1;\n484:     this.b = b;\n485:     this.engine = engine;\n486:     this.documents = new Map();\n487:     this.packedDocuments = new Map();\n488:     this.packedDocIds = [];\n489:     this.packedFreeNumericIds = [];\n490:     this.packedDocNumbersById = new Map();\n491:     this.packedMutablePostings = new Map();\n492:     this.packedPostings = new Map();\n493:     this.packedDirtyTerms = new Set();\n494:     this.packedTokenInterns = new Map();\n495:     this.packedTermIdsByToken = new Map();\n496:     this.packedTermsById = [];\n497:     this.packedScratchPositions = new Int32Array(16_384);\n498:     this.packedScratchPositions.fill(-1);\n499:     this.packedScratchTermIds = [];\n500:     this.packedScratchTotalTfs = [];\n501:     this.packedScratchTitleTfs = [];\n502:     this.packedScratchTriggerTfs = [];\n503:     this.packedScratchPathTfs = [];\n504:     this.packedScratchBodyTfs = [];\n505:     this.documentFreq = new Map();\n506:     this.totalDocLength = 0;\n507:     this.warmupHandle = null;\n508:     this.warmupGeneration = 0;\n509:   }\n510: \n511:   addDocument(id: string, text: string): void {\n512:     if (this.engine === 'packed-inmemory') {\n513:       this.addDocumentFields(id, { body: text });\n514:       return;\n515:     }\n516: \n517:     const tokens = tokenize(text);\n518:     const termFreq = getTermFrequencies(tokens);\n519: \n520:     if (this.documents.has(id)) {\n521:       this.removeDocument(id);\n522:     }\n523: \n524:     this.documents.set(id, { tokens, termFreq });\n525:     this.totalDocLength += tokens.length;\n526: \n527:     // Update document frequency\n528:     for (const term of termFreq.keys()) {\n529:       this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n530:     }\n531:   }\n532: \n533:   addDocumentFields(id: string, fields: BM25DocumentFields): void {\n534:     if (this.engine === 'legacy-inmemory') {\n535:       this.addDocument(id, this.joinDocumentFields(fields));\n536:       return;\n537:     }\n538: \n539:     if (this.packedDocuments.has(id)) {\n540:       this.removeDocument(id);\n541:     }\n542: \n543:     this.collectPackedTermFrequencies(fields);\n544:     try {\n545:       let length = 0;\n546:       for (const totalTf of this.packedScratchTotalTfs) {\n547:         length += totalTf;\n548:       }\n549:       if (length === 0) {\n550:         return;\n551:       }\n552: \n553:       const numericId = this.getPackedNumericId(id);\n554:       this.packedDocuments.set(id, {\n555:         numericId,\n556:         id,\n557:         length,\n558:         termIds: this.createPackedDocumentTermIds(),\n559:       });\n560:       this.totalDocLength += length;\n561: \n562:       for (let i = 0; i < this.packedScratchTermIds.length; i += 1) {\n563:         const term = this.packedTermsById[this.packedScratchTermIds[i]];\n564:         const postings = this.ensurePackedMutablePostings(term);\n565:         this.setPackedMutablePosting(\n566:           postings,\n567:           numericId,\n568:           this.packedScratchTitleTfs[i],\n569:           this.packedScratchTriggerTfs[i],\n570:           this.packedScratchPathTfs[i],\n571:           this.packedScratchBodyTfs[i]\n572:         );\n573:         this.packedDirtyTerms.add(term);\n574:         this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n575:       }\n576:     } finally {\n577:       this.clearPackedFrequencyScratch();\n578:     }\n579:   }\n580: \n581:   removeDocument(id: string): boolean {\n582:     if (this.engine === 'packed-inmemory') {\n583:       return this.removePackedDocument(id);\n584:     }\n585: \n586:     const doc = this.documents.get(id);\n587:     if (!doc) return false;\n588: \n589:     this.totalDocLength -= doc.tokens.length;\n590: \n591:     for (const term of doc.termFreq.keys()) {\n592:       const count = this.documentFreq.get(term) || 0;\n593:       if (count <= 1) {\n594:         this.documentFreq.delete(term);\n595:       } else {\n596:         this.documentFreq.set(term, count - 1);\n597:       }\n598:     }\n599: \n600:     this.documents.delete(id);\n601:     return true;\n602:   }\n603: \n604:   calculateIdf(term: string): number {\n605:     const n = this.getDocumentCount();\n606:     const df = this.documentFreq.get(term) || 0;\n607:     if (df === 0 || n === 0) return 0;\n608:     return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n609:   }\n610: \n611:   calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n612:     if (this.engine === 'packed-inmemory') {\n613:       return this.calculatePackedScore(queryTokens, docId, options);\n614:     }\n615: \n616:     const doc = this.documents.get(docId);\n617:     if (!doc) return 0;\n618: \n619:     const avgDl = this.getAverageDocumentLength();\n620:     const dl = doc.tokens.length;\n621: \n622:     let score = 0;\n623:     for (const term of queryTokens) {\n624:       const tf = doc.termFreq.get(term) || 0;\n625:       if (tf === 0) continue;\n626: \n627:       const idf = this.calculateIdf(term);\n628:       const numerator = tf * (this.k1 + 1);\n629:       const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n630:       score += idf * (numerator / denominator);\n631:     }\n632: \n633:     return score;\n634:   }\n635: \n636:   search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n637:     const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n638:     if (queryTokens.length === 0) return [];\n639: \n640:     if (this.engine === 'packed-inmemory') {\n641:       return this.searchPacked(queryTokens, limit, options);\n642:     }\n643: \n644:     const results: BM25SearchResult[] = [];\n645: \n646:     for (const [id] of this.documents) {\n647:       const score = this.calculateScore(queryTokens, id);\n648:       if (score > 0) {\n649:         results.push({ id, score });\n650:       }\n651:     }\n652: \n653:     return results\n654:       .sort((a, b) => b.score - a.score)\n655:       .slice(0, limit);\n656:   }\n657: \n658:   getStats(): BM25Stats {\n659:     return {\n660:       documentCount: this.getDocumentCount(),\n661:       termCount: this.documentFreq.size,\n662:       avgDocLength: this.getAverageDocumentLength(),\n663:     };\n664:   }\n665: \n666:   clear(): void {\n667:     this.cancelWarmup();\n668:     this.documents.clear();\n669:     this.packedDocuments.clear();\n670:     this.packedDocIds = [];\n671:     this.packedFreeNumericIds = [];\n672:     this.packedDocNumbersById.clear();\n673:     this.packedMutablePostings.clear();\n674:     this.packedPostings.clear();\n675:     this.packedDirtyTerms.clear();\n676:     this.packedTokenInterns.clear();\n677:     this.packedTermIdsByToken.clear();\n678:     this.packedTermsById = [];\n679:     this.packedScratchPositions.fill(-1);\n680:     this.clearPackedFrequencyScratch();\n681:     this.documentFreq.clear();\n682:     this.totalDocLength = 0;\n683:   }\n684: \n685:   addDocuments(docs: Array<{ id: string; text: string }>): void {\n686:     for (const doc of docs) {\n687:       this.addDocument(doc.id, doc.text);\n688:     }\n689:   }\n690: \n691:   finalizePackedPostings(): void {\n692:     if (this.engine === 'legacy-inmemory') {\n693:       return;\n694:     }\n695: \n696:     for (const term of Array.from(this.packedDirtyTerms)) {\n697:       this.getPackedPosting(term);\n698:     }\n699:     this.packedMutablePostings.clear();\n700:   }\n701: \n702:   /**\n703:    * Incrementally synchronize changed rows from the database into the in-memory index.\n704:    */\n705:   syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n706:     const normalizedIds = Array.from(\n707:       new Set(\n708:         rowIds\n709:           .map((rowId) => Number(rowId))\n710:           .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n711:       )\n712:     );\n713: \n714:     if (normalizedIds.length === 0) {\n715:       return 0;\n716:     }\n717: \n718:     try {\n719:       const placeholders = normalizedIds.map(() => '?').join(', ');\n720:       const rows = (database.prepare(\n721:         `SELECT id, title, content_text, trigger_phrases, file_path\n722:          FROM memory_index\n723:          WHERE id IN (${placeholders})`\n724:       ) as Database.Statement).all(...normalizedIds) as Array<{\n725:         id: number;\n726:         title: string | null;\n727:         content_text: string | null;\n728:         trigger_phrases: string | null;\n729:         file_path: string | null;\n730:       }>;\n731: \n732:       const activeRowMap = new Map<number, typeof rows[number]>();\n733:       for (const row of rows) {\n734:         activeRowMap.set(row.id, row);\n735:       }\n736: \n737:       for (const rowId of normalizedIds) {\n738:         const row = activeRowMap.get(rowId);\n739:         if (!row) {\n740:           this.removeDocument(String(rowId));\n741:           continue;\n742:         }\n743: \n744:         const fields = buildBm25DocumentFields(row);\n745:         if (hasBm25DocumentText(fields)) {\n746:           this.addDocumentFields(String(row.id), fields);\n747:         } else {\n748:           this.removeDocument(String(row.id));\n749:         }\n750:       }\n751: \n752:       return normalizedIds.length;\n753:     } catch (error: unknown) {\n754:       const msg = error instanceof Error ? error.message : String(error);\n755:       console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n756:       return 0;\n757:     }\n758:   }\n759: \n760:   /**\n761:    * Defer full startup warmup into batched row-ID syncs so process\n762:    * initialization is not blocked by a monolithic in-memory rebuild.\n763:    */\n764:   rebuildFromDatabase(database: Database.Database): number {\n765:     this.clear();\n766: \n767:     try {\n768:       const rows = (database.prepare(\n769:         `SELECT id\n770:          FROM memory_index\n771:          ORDER BY id`\n772:       ) as Database.Statement).all() as Array<{ id: number }>;\n773: \n774:       const pendingIds = rows.map((row) => row.id);\n775:       if (pendingIds.length === 0) {\n776:         return 0;\n777:       }\n778: \n779:       const warmupGeneration = ++this.warmupGeneration;\n780:       const processBatch = () => {\n781:         if (warmupGeneration !== this.warmupGeneration) {\n782:           return;\n783:         }\n784: \n785:         const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n786:         if (batchIds.length === 0) {\n787:           this.finalizePackedPostings();\n788:           this.warmupHandle = null;\n789:           return;\n790:         }\n791: \n792:         this.syncChangedRows(database, batchIds);\n793: \n794:         if (pendingIds.length > 0) {\n795:           this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n796:         } else {\n797:           // The queue drains on the last non-empty batch, so the empty-batch\n798:           // finalize above never runs on this path. Finalize here too, or the\n799:           // whole corpus stays in mutable number[] postings and the packed\n800:           // engine's RAM bound is lost until every term is searched.\n801:           this.finalizePackedPostings();\n802:           this.warmupHandle = null;\n803:         }\n804:       };\n805: \n806:       this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n807:       return pendingIds.length;\n808:     } catch (error: unknown) {\n809:       const msg = error instanceof Error ? error.message : String(error);\n810:       console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n811:       return 0;\n812:     }\n813:   }\n814: \n815:   cancelWarmup(): void {\n816:     this.warmupGeneration += 1;\n817:     if (this.warmupHandle) {\n818:       clearRegisteredTimer(this.warmupHandle);\n819:       this.warmupHandle = null;\n820:     }\n821:   }\n822: \n823:   private getDocumentCount(): number {\n824:     return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n825:   }\n826: \n827:   private getAverageDocumentLength(): number {\n828:     const documentCount = this.getDocumentCount();\n829:     return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n830:   }\n831: \n832:   private joinDocumentFields(fields: BM25DocumentFields): string {\n833:     const parts: string[] = [];\n834:     for (const fieldName of BM25_FIELD_NAMES) {\n835:       const value = fields[fieldName];\n836:       if (Array.isArray(value)) {\n837:         parts.push(value.join(' '));\n838:       } else if (typeof value === 'string' && value.trim()) {\n839:         parts.push(value.trim());\n840:       }\n841:     }\n842:     return parts.join(' ').trim();\n843:   }\n844: \n845:   private getPackedNumericId(id: string): number {\n846:     const existing = this.packedDocNumbersById.get(id);\n847:     if (existing !== undefined) {\n848:       return existing;\n849:     }\n850: \n851:     // Reuse a slot freed by a prior removal before extending, so packedDocIds is\n852:     // bounded by the live document count rather than cumulative write volume.\n853:     const recycled = this.packedFreeNumericIds.pop();\n854:     const numericId = recycled ?? this.packedDocIds.length;\n855:     this.packedDocIds[numericId] = id;\n856:     this.packedDocNumbersById.set(id, numericId);\n857:     return numericId;\n858:   }\n859: \n860:   private collectPackedTermFrequencies(fields: BM25DocumentFields): void {\n861:     for (const fieldName of BM25_FIELD_NAMES) {\n862:       visitBm25FieldValue(\n863:         fields[fieldName],\n864:         (token) => this.recordPackedTokenFrequency(token, fieldName),\n865:         this.packedTokenInterns\n866:       );\n867:     }\n868:   }\n869: \n870:   private recordPackedTokenFrequency(token: string, fieldName: BM25FieldName): void {\n871:     const termId = this.getPackedTermId(token);\n872:     let scratchIndex = this.packedScratchPositions[termId];\n873:     if (scratchIndex < 0) {\n874:       scratchIndex = this.packedScratchTermIds.length;\n875:       this.packedScratchPositions[termId] = scratchIndex;\n876:       this.packedScratchTermIds.push(termId);\n877:       this.packedScratchTotalTfs.push(0);\n878:       this.packedScratchTitleTfs.push(0);\n879:       this.packedScratchTriggerTfs.push(0);\n880:       this.packedScratchPathTfs.push(0);\n881:       this.packedScratchBodyTfs.push(0);\n882:     }\n883: \n884:     this.packedScratchTotalTfs[scratchIndex] += 1;\n885:     if (fieldName === 'title') this.packedScratchTitleTfs[scratchIndex] += 1;\n886:     else if (fieldName === 'trigger_phrases') this.packedScratchTriggerTfs[scratchIndex] += 1;\n887:     else if (fieldName === 'content_generic') this.packedScratchPathTfs[scratchIndex] += 1;\n888:     else this.packedScratchBodyTfs[scratchIndex] += 1;\n889:   }\n890: \n891:   private getPackedTermId(token: string): number {\n892:     const existing = this.packedTermIdsByToken.get(token);\n893:     if (existing !== undefined) {\n894:       return existing;\n895:     }\n896: \n897:     const termId = this.packedTermsById.length;\n898:     this.packedTermIdsByToken.set(token, termId);\n899:     this.packedTermsById.push(token);\n900:     this.ensurePackedScratchPositionCapacity(termId + 1);\n901:     return termId;\n902:   }\n903: \n904:   private ensurePackedScratchPositionCapacity(minimum: number): void {\n905:     if (this.packedScratchPositions.length >= minimum) {\n906:       return;\n907:     }\n908: \n909:     let capacity = this.packedScratchPositions.length;\n910:     while (capacity < minimum) {\n911:       capacity *= 2;\n912:     }\n913: \n914:     const next = new Int32Array(capacity);\n915:     next.fill(-1);\n916:     next.set(this.packedScratchPositions);\n917:     this.packedScratchPositions = next;\n918:   }\n919: \n920:   private clearPackedFrequencyScratch(): void {\n921:     for (const termId of this.packedScratchTermIds) {\n922:       this.packedScratchPositions[termId] = -1;\n923:     }\n924:     this.packedScratchTermIds.length = 0;\n925:     this.packedScratchTotalTfs.length = 0;\n926:     this.packedScratchTitleTfs.length = 0;\n927:     this.packedScratchTriggerTfs.length = 0;\n928:     this.packedScratchPathTfs.length = 0;\n929:     this.packedScratchBodyTfs.length = 0;\n930:   }\n931: \n932:   private createPackedDocumentTermIds(): Uint16Array | Uint32Array {\n933:     for (const termId of this.packedScratchTermIds) {\n934:       if (termId > PACKED_POSTING_MAX_NARROW_TERM_ID) {\n935:         return Uint32Array.from(this.packedScratchTermIds);\n936:       }\n937:     }\n938: \n939:     return Uint16Array.from(this.packedScratchTermIds);\n940:   }\n941: \n942:   private removePackedDocument(id: string): boolean {\n943:     const doc = this.packedDocuments.get(id);\n944:     if (!doc) return false;\n945: \n946:     this.totalDocLength -= doc.length;\n947: \n948:     for (const termId of doc.termIds) {\n949:       const term = this.packedTermsById[termId];\n950:       const postings = this.ensurePackedMutablePostings(term);\n951:       this.deletePackedMutablePosting(postings, doc.numericId);\n952:       this.packedDirtyTerms.add(term);\n953: \n954:       const count = this.documentFreq.get(term) || 0;\n955:       if (count <= 1) {\n956:         this.documentFreq.delete(term);\n957:         this.packedMutablePostings.delete(term);\n958:         this.packedPostings.delete(term);\n959:       } else {\n960:         this.documentFreq.set(term, count - 1);\n961:       }\n962:     }\n963: \n964:     this.packedDocuments.delete(id);\n965:     this.packedDocIds[doc.numericId] = undefined;\n966:     this.packedFreeNumericIds.push(doc.numericId);\n967:     this.packedDocNumbersById.delete(id);\n968:     return true;\n969:   }\n970: \n971:   private getPackedPosting(term: string): PackedPostingList | undefined {\n972:     if (!this.packedDirtyTerms.has(term)) {\n973:       return this.packedPostings.get(term);\n974:     }\n975: \n976:     const mutable = this.packedMutablePostings.get(term);\n977:     if (!mutable || mutable.length === 0) {\n978:       this.packedDirtyTerms.delete(term);\n979:       this.packedPostings.delete(term);\n980:       return undefined;\n981:     }\n982: \n983:     this.sortPackedMutablePosting(mutable);\n984:     this.packedPostings.set(term, mutable);\n985:     this.packedMutablePostings.delete(term);\n986:     this.packedDirtyTerms.delete(term);\n987:     return mutable;\n988:   }\n989: \n990:   private ensurePackedMutablePostings(term: string): PackedPostingMutable {\n991:     const existing = this.packedMutablePostings.get(term);\n992:     if (existing) {\n993:       return existing;\n994:     }\n995: \n996:     const packed = this.packedPostings.get(term);\n997:     if (packed) {\n998:       this.packedPostings.delete(term);\n999:       this.packedMutablePostings.set(term, packed);\n1000:       return packed;\n1001:     }\n1002: \n1003:     const hydrated = this.createPackedMutablePosting();\n1004:     this.packedMutablePostings.set(term, hydrated);\n1005:     return hydrated;\n1006:   }\n1007: \n1008:   private createPackedMutablePosting(): PackedPostingMutable {\n1009:     return {\n1010:       docIdChunks: [],\n1011:       fieldTfChunks: [],\n1012:       length: 0,\n1013:       sorted: true,\n1014:       wideDocIds: false,\n1015:       fieldTfWidth: 1,\n1016:     };\n1017:   }\n1018: \n1019:   private ensurePackedDocIdChunk(\n1020:     postings: PackedPostingMutable,\n1021:     index: number\n1022:   ): Uint16Array | Uint32Array {\n1023:     const chunkIndex = Math.floor(index / PACKED_POSTING_CHUNK_SIZE);\n1024:     let chunk = postings.docIdChunks[chunkIndex];\n1025:     if (!chunk) {\n1026:       chunk = postings.wideDocIds\n1027:         ? new Uint32Array(PACKED_POSTING_CHUNK_SIZE)\n1028:         : new Uint16Array(PACKED_POSTING_CHUNK_SIZE);\n1029:       postings.docIdChunks[chunkIndex] = chunk;\n1030:     }\n1031:     return chunk;\n1032:   }\n1033: \n1034:   private ensurePackedFieldTfChunk(\n1035:     postings: PackedPostingMutable,\n1036:     index: number\n1037:   ): Uint8Array | Uint16Array | Uint32Array {\n1038:     const chunkIndex = Math.floor(index / PACKED_POSTING_CHUNK_SIZE);\n1039:     let chunk = postings.fieldTfChunks[chunkIndex];\n1040:     if (!chunk) {\n1041:       const length = PACKED_POSTING_CHUNK_SIZE * PACKED_POSTING_FIELD_WIDTH;\n1042:       chunk = this.createPackedFieldTfChunk(length, postings.fieldTfWidth);\n1043:       postings.fieldTfChunks[chunkIndex] = chunk;\n1044:     }\n1045:     return chunk;\n1046:   }\n1047: \n1048:   private createPackedFieldTfChunk(\n1049:     length: number,\n1050:     width: PackedFieldTfWidth\n1051:   ): Uint8Array | Uint16Array | Uint32Array {\n1052:     if (width === 1) return new Uint8Array(length);\n1053:     if (width === 2) return new Uint16Array(length);\n1054:     return new Uint32Array(length);\n1055:   }\n1056: \n1057:   private requiredPackedFieldTfWidth(\n1058:     titleTf: number,\n1059:     triggerTf: number,\n1060:     pathTf: number,\n1061:     bodyTf: number\n1062:   ): PackedFieldTfWidth {\n1063:     if (\n1064:       titleTf > PACKED_POSTING_MAX_NARROW_TF ||\n1065:       triggerTf > PACKED_POSTING_MAX_NARROW_TF ||\n1066:       pathTf > PACKED_POSTING_MAX_NARROW_TF ||\n1067:       bodyTf > PACKED_POSTING_MAX_NARROW_TF\n1068:     ) {\n1069:       return 4;\n1070:     }\n1071: \n1072:     if (\n1073:       titleTf > PACKED_POSTING_MAX_BYTE_TF ||\n1074:       triggerTf > PACKED_POSTING_MAX_BYTE_TF ||\n1075:       pathTf > PACKED_POSTING_MAX_BYTE_TF ||\n1076:       bodyTf > PACKED_POSTING_MAX_BYTE_TF\n1077:     ) {\n1078:       return 2;\n1079:     }\n1080: \n1081:     return 1;\n1082:   }\n1083: \n1084:   private ensurePackedDocIdWidth(postings: PackedPostingMutable, docId: number): void {\n1085:     if (postings.wideDocIds || docId <= PACKED_POSTING_MAX_NARROW_DOC_ID) {\n1086:       return;\n1087:     }\n1088: \n1089:     for (let i = 0; i < postings.docIdChunks.length; i += 1) {\n1090:       const chunk = postings.docIdChunks[i];\n1091:       if (!chunk) continue;\n1092:       const widened = new Uint32Array(chunk.length);\n1093:       widened.set(chunk);\n1094:       postings.docIdChunks[i] = widened;\n1095:     }\n1096:     postings.wideDocIds = true;\n1097:   }\n1098: \n1099:   private ensurePackedFieldTfWidth(\n1100:     postings: PackedPostingMutable,\n1101:     titleTf: number,\n1102:     triggerTf: number,\n1103:     pathTf: number,\n1104:     bodyTf: number\n1105:   ): void {\n1106:     const requiredWidth = this.requiredPackedFieldTfWidth(\n1107:       titleTf,\n1108:       triggerTf,\n1109:       pathTf,\n1110:       bodyTf\n1111:     );\n1112:     if (postings.fieldTfWidth >= requiredWidth) {\n1113:       return;\n1114:     }\n1115: \n1116:     for (let i = 0; i < postings.fieldTfChunks.length; i += 1) {\n1117:       const chunk = postings.fieldTfChunks[i];\n1118:       if (!chunk) continue;\n1119:       const widened = this.createPackedFieldTfChunk(chunk.length, requiredWidth);\n1120:       widened.set(chunk);\n1121:       postings.fieldTfChunks[i] = widened;\n1122:     }\n1123:     postings.fieldTfWidth = requiredWidth;\n1124:   }\n1125: \n1126:   private getPackedPostingDocId(postings: PackedPostingList, index: number): number {\n1127:     const chunk = postings.docIdChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n1128:     return chunk[index % PACKED_POSTING_CHUNK_SIZE];\n1129:   }\n1130: \n1131:   private getPackedPostingFieldTf(\n1132:     postings: PackedPostingList,\n1133:     index: number,\n1134:     fieldOffset: number\n1135:   ): number {\n1136:     const chunk = postings.fieldTfChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n1137:     const offset = (index % PACKED_POSTING_CHUNK_SIZE) * PACKED_POSTING_FIELD_WIDTH +\n1138:       fieldOffset;\n1139:     return chunk[offset];\n1140:   }\n1141: \n1142:   private getPackedMutableEntry(\n1143:     postings: PackedPostingMutable,\n1144:     index: number\n1145:   ): PackedPostingEntry {\n1146:     const docIdChunk = postings.docIdChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n1147:     const fieldTfChunk = postings.fieldTfChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n1148:     const docOffset = index % PACKED_POSTING_CHUNK_SIZE;\n1149:     const fieldOffset = docOffset * PACKED_POSTING_FIELD_WIDTH;\n1150:     return {\n1151:       docId: docIdChunk[docOffset],\n1152:       titleTf: fieldTfChunk[fieldOffset + PACKED_POSTING_TITLE_OFFSET],\n1153:       triggerTf: fieldTfChunk[fieldOffset + PACKED_POSTING_TRIGGER_OFFSET],\n1154:       pathTf: fieldTfChunk[fieldOffset + PACKED_POSTING_PATH_OFFSET],\n1155:       bodyTf: fieldTfChunk[fieldOffset + PACKED_POSTING_BODY_OFFSET],\n1156:     };\n1157:   }\n1158: \n1159:   private setPackedMutableEntry(\n1160:     postings: PackedPostingMutable,\n1161:     index: number,\n1162:     entry: PackedPostingEntry\n1163:   ): void {\n1164:     this.ensurePackedDocIdWidth(postings, entry.docId);\n1165:     this.ensurePackedFieldTfWidth(\n1166:       postings,\n1167:       entry.titleTf,\n1168:       entry.triggerTf,\n1169:       entry.pathTf,\n1170:       entry.bodyTf\n1171:     );\n1172:     const docIdChunk = this.ensurePackedDocIdChunk(postings, index);\n1173:     const fieldTfChunk = this.ensurePackedFieldTfChunk(postings, index);\n1174:     const docOffset = index % PACKED_POSTING_CHUNK_SIZE;\n1175:     const fieldOffset = docOffset * PACKED_POSTING_FIELD_WIDTH;\n1176:     docIdChunk[docOffset] = entry.docId;\n1177:     fieldTfChunk[fieldOffset + PACKED_POSTING_TITLE_OFFSET] = entry.titleTf;\n1178:     fieldTfChunk[fieldOffset + PACKED_POSTING_TRIGGER_OFFSET] = entry.triggerTf;\n1179:     fieldTfChunk[fieldOffset + PACKED_POSTING_PATH_OFFSET] = entry.pathTf;\n1180:     fieldTfChunk[fieldOffset + PACKED_POSTING_BODY_OFFSET] = entry.bodyTf;\n1181:   }\n1182: \n1183:   private appendPackedMutableEntry(\n1184:     postings: PackedPostingMutable,\n1185:     entry: PackedPostingEntry\n1186:   ): void {\n1187:     const lastDocId = postings.length > 0\n1188:       ? this.getPackedPostingDocId(postings, postings.length - 1)\n1189:       : -1;\n1190:     if (lastDocId > entry.docId) {\n1191:       postings.sorted = false;\n1192:     }\n1193:     this.setPackedMutableEntry(postings, postings.length, entry);\n1194:     postings.length += 1;\n1195:   }\n1196: \n1197:   private setPackedMutablePosting(\n1198:     postings: PackedPostingMutable,\n1199:     numericId: number,\n1200:     titleTf: number,\n1201:     triggerTf: number,\n1202:     pathTf: number,\n1203:     bodyTf: number\n1204:   ): void {\n1205:     let existingIndex = -1;\n1206:     for (let i = 0; i < postings.length; i += 1) {\n1207:       if (this.getPackedPostingDocId(postings, i) === numericId) {\n1208:         existingIndex = i;\n1209:         break;\n1210:       }\n1211:     }\n1212:     if (existingIndex >= 0) {\n1213:       this.setPackedMutableEntry(postings, existingIndex, {\n1214:         docId: numericId,\n1215:         titleTf,\n1216:         triggerTf,\n1217:         pathTf,\n1218:         bodyTf,\n1219:       });\n1220:       return;\n1221:     }\n1222: \n1223:     this.appendPackedMutableEntry(postings, {\n1224:       docId: numericId,\n1225:       titleTf,\n1226:       triggerTf,\n1227:       pathTf,\n1228:       bodyTf,\n1229:     });\n1230:   }\n1231: \n1232:   private deletePackedMutablePosting(postings: PackedPostingMutable, numericId: number): void {\n1233:     let index = -1;\n1234:     for (let i = 0; i < postings.length; i += 1) {\n1235:       if (this.getPackedPostingDocId(postings, i) === numericId) {\n1236:         index = i;\n1237:         break;\n1238:       }\n1239:     }\n1240:     if (index < 0) {\n1241:       return;\n1242:     }\n1243:     if (index < postings.length - 1) {\n1244:       for (let i = index + 1; i < postings.length; i += 1) {\n1245:         this.setPackedMutableEntry(\n1246:           postings,\n1247:           i - 1,\n1248:           this.getPackedMutableEntry(postings, i)\n1249:         );\n1250:       }\n1251:     }\n1252:     postings.length -= 1;\n1253:   }\n1254: \n1255:   private sortPackedMutablePosting(postings: PackedPostingMutable): void {\n1256:     if (postings.sorted) {\n1257:       return;\n1258:     }\n1259: \n1260:     for (let i = 1; i < postings.length; i += 1) {\n1261:       const entry = this.getPackedMutableEntry(postings, i);\n1262:       let j = i - 1;\n1263: \n1264:       while (j >= 0 && this.getPackedPostingDocId(postings, j) > entry.docId) {\n1265:         this.setPackedMutableEntry(\n1266:           postings,\n1267:           j + 1,\n1268:           this.getPackedMutableEntry(postings, j)\n1269:         );\n1270:         j -= 1;\n1271:       }\n1272: \n1273:       this.setPackedMutableEntry(postings, j + 1, entry);\n1274:     }\n1275: \n1276:     postings.sorted = true;\n1277:   }\n1278: \n1279:   private calculatePackedScore(\n1280:     queryTokens: string[],\n1281:     docId: string,\n1282:     options: BM25SearchOptions\n1283:   ): number {\n1284:     const doc = this.packedDocuments.get(docId);\n1285:     if (!doc) return 0;\n1286: \n1287:     const weights = resolveBm25FieldWeights(options.fieldWeights);\n1288:     const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n1289:     let score = 0;\n1290: \n1291:     for (const term of queryTokens) {\n1292:       const postings = this.getPackedPosting(term);\n1293:       if (!postings) continue;\n1294:       const postingIndex = this.findPackedPostingIndex(postings, doc.numericId);\n1295:       if (postingIndex < 0) continue;\n1296: \n1297:       const weightedTf = this.calculateWeightedPostingFrequency(postings, postingIndex, weights);\n1298:       if (weightedTf <= 0) continue;\n1299: \n1300:       const idf = this.calculateIdf(term);\n1301:       score += this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n1302:     }\n1303: \n1304:     return score;\n1305:   }\n1306: \n1307:   private searchPacked(\n1308:     queryTokens: string[],\n1309:     limit: number,\n1310:     options: BM25SearchOptions\n1311:   ): BM25SearchResult[] {\n1312:     const weights = resolveBm25FieldWeights(options.fieldWeights);\n1313:     const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n1314:     const scores = new Map<number, number>();\n1315: \n1316:     for (const term of queryTokens) {\n1317:       const postings = this.getPackedPosting(term);\n1318:       if (!postings) continue;\n1319: \n1320:       const idf = this.calculateIdf(term);\n1321:       for (let i = 0; i < postings.length; i += 1) {\n1322:         const numericId = this.getPackedPostingDocId(postings, i);\n1323:         const id = this.packedDocIds[numericId];\n1324:         if (!id) continue;\n1325:         const doc = this.packedDocuments.get(id);\n1326:         if (!doc) continue;\n1327: \n1328:         const weightedTf = this.calculateWeightedPostingFrequency(postings, i, weights);\n1329:         if (weightedTf <= 0) continue;\n1330: \n1331:         const termScore = this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n1332:         scores.set(numericId, (scores.get(numericId) || 0) + termScore);\n1333:       }\n1334:     }\n1335: \n1336:     return Array.from(scores.entries())\n1337:       .map(([numericId, score]) => ({ id: this.packedDocIds[numericId], score }))\n1338:       .filter((result): result is BM25SearchResult => typeof result.id === 'string' && result.score > 0)\n1339:       .sort((a, b) => b.score - a.score)\n1340:       .slice(0, limit);\n1341:   }\n1342: \n1343:   private calculateWeightedPostingFrequency(\n1344:     postings: PackedPostingList,\n1345:     index: number,\n1346:     weights: BM25FieldWeights\n1347:   ): number {\n1348:     const titleTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_TITLE_OFFSET);\n1349:     const triggerTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_TRIGGER_OFFSET);\n1350:     const pathTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_PATH_OFFSET);\n1351:     const bodyTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_BODY_OFFSET);\n1352: \n1353:     return (\n1354:       titleTf * weights.title +\n1355:       triggerTf * weights.trigger_phrases +\n1356:       pathTf * weights.content_generic +\n1357:       bodyTf * weights.body\n1358:     );\n1359:   }\n1360: \n1361:   private findPackedPostingIndex(postings: PackedPostingList, numericId: number): number {\n1362:     let low = 0;\n1363:     let high = postings.length - 1;\n1364:     while (low <= high) {\n1365:       const mid = Math.floor((low + high) / 2);\n1366:       const value = this.getPackedPostingDocId(postings, mid);\n1367:       if (value === numericId) return mid;\n1368:       if (value < numericId) {\n1369:         low = mid + 1;\n1370:       } else {\n1371:         high = mid - 1;\n1372:       }\n1373:     }\n1374:     return -1;\n1375:   }\n1376: \n1377:   private calculateBm25TermScore(tf: number, dl: number, avgDl: number, idf: number): number {\n1378:     const numerator = tf * (this.k1 + 1);\n1379:     const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / avgDl));\n1380:     return idf * (numerator / denominator);\n1381:   }\n1382: }\n1383: \n1384: // ───────────────────────────────────────────────────────────────\n1385: // 4. SINGLETON\n1386: \n1387: // ───────────────────────────────────────────────────────────────\n1388: let indexInstance: BM25Index | null = null;\n1389: \n1390: /**\n1391:  * Retrieve the shared in-memory BM25 index singleton.\n1392:  *\n1393:  * @returns The process-wide {@link BM25Index} instance.\n1394:  * @example\n1395:  * ```ts\n1396:  * const index = getIndex();\n1397:  * index.addDocument('123', 'memory search');\n1398:  * ```\n1399:  */\n1400: function getIndex(): BM25Index {\n1401:   if (!indexInstance) {\n1402:     indexInstance = new BM25Index();\n1403:   }\n1404:   return indexInstance;\n1405: }\n1406: \n1407: /**\n1408:  * Reset the shared BM25 index singleton.\n1409:  *\n1410:  * @returns Nothing.\n1411:  * @example\n1412:  * ```ts\n1413:  * resetIndex();\n1414:  * ```\n1415:  */\n1416: function resetIndex(): void {\n1417:   indexInstance?.cancelWarmup();\n1418:   indexInstance = null;\n1419: }\n1420: \n1421: // ───────────────────────────────────────────────────────────────\n1422: // 5. LEXICAL ENGINE ROUTING\n1423: \n1424: // ───────────────────────────────────────────────────────────────\n1425: function resolveBm25Engine(): Bm25Engine {\n1426:   const value = process.env.SPECKIT_BM25_ENGINE?.trim().toLowerCase();\n1427:   if (!value) {\n1428:     return 'auto';\n1429:   }\n1430: \n1431:   if ((BM25_ENGINE_VALUES as readonly string[]).includes(value)) {\n1432:     return value as Bm25Engine;\n1433:   }\n1434: \n1435:   console.warn(`[bm25-index] Unsupported SPECKIT_BM25_ENGINE=${value}; falling back to auto`);\n1436:   return 'auto';\n1437: }\n1438: \n1439: function isMemoryFtsAvailable(database: Database.Database | null | undefined): boolean {\n1440:   if (!database) {\n1441:     return false;\n1442:   }\n1443: \n1444:   try {\n1445:     const result = (database.prepare(\n1446:       `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n1447:     ) as Database.Statement).get() as { name: string } | undefined;\n1448:     return !!result;\n1449:   } catch {\n1450:     return false;\n1451:   }\n1452: }\n1453: \n1454: function shouldWarmInMemoryBm25(database: Database.Database | null | undefined): boolean {\n1455:   if (!isBm25Enabled()) {\n1456:     return false;\n1457:   }\n1458: \n1459:   const engine = resolveBm25Engine();\n1460:   emitBm25EngineSelection(engine, 'warmup routing');\n1461:   if (engine === 'sqlite') {\n1462:     if (!isMemoryFtsAvailable(database)) {\n1463:       throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table; JS BM25 warmup is disabled in sqlite mode');\n1464:     }\n1465:     return false;\n1466:   }\n1467: \n1468:   if (engine === 'auto') {\n1469:     return !isMemoryFtsAvailable(database);\n1470:   }\n1471: \n1472:   if (engine === 'packed-inmemory') {\n1473:     return true;\n1474:   }\n1475: \n1476:   return true;\n1477: }\n1478: \n1479: function shouldUseSqliteLexicalEngine(database: Database.Database | null | undefined): boolean {\n1480:   const engine = resolveBm25Engine();\n1481:   emitBm25EngineSelection(engine, 'lexical routing');\n1482:   if (engine === 'sqlite') {\n1483:     if (!isMemoryFtsAvailable(database)) {\n1484:       throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table for lexical BM25 search');\n1485:     }\n1486:     return true;\n1487:   }\n1488: \n1489:   if (engine === 'auto') {\n1490:     return isMemoryFtsAvailable(database);\n1491:   }\n1492: \n1493:   return false;\n1494: }\n1495: \n1496: function getBm25EngineStatus(database: Database.Database | null | undefined = null): {\n1497:   lexical_engine: Bm25Engine;\n1498:   fts5_available: boolean;\n1499:   warms_in_memory_bm25: boolean;\n1500:   bm25_enabled: boolean;\n1501: } {\n1502:   const lexical_engine = resolveBm25Engine();\n1503:   const fts5_available = isMemoryFtsAvailable(database);\n1504:   let warms_in_memory_bm25 = false;\n1505: \n1506:   try {\n1507:     warms_in_memory_bm25 = shouldWarmInMemoryBm25(database);\n1508:   } catch {\n1509:     warms_in_memory_bm25 = false;\n1510:   }\n1511: \n1512:   return {\n1513:     lexical_engine,\n1514:     fts5_available,\n1515:     warms_in_memory_bm25,\n1516:     bm25_enabled: isBm25Enabled(),\n1517:   };\n1518: }\n1519: \n1520: // ───────────────────────────────────────────────────────────────\n1521: // 6. EXPORTS\n1522: \n1523: // ───────────────────────────────────────────────────────────────\n1524: export {\n1525:   BM25Index,\n1526:   getIndex,\n1527:   resetIndex,\n1528:   tokenize,\n1529:   simpleStem,\n1530:   getTermFrequencies,\n1531:   isBm25Enabled,\n1532:   resolveBm25Engine,\n1533:   isMemoryFtsAvailable,\n1534:   shouldWarmInMemoryBm25,\n1535:   shouldUseSqliteLexicalEngine,\n1536:   getBm25EngineStatus,\n1537:   sanitizeQueryTokens,\n1538:   sanitizeFTS5Query,\n1539:   normalizeLexicalQueryTokens,\n1540:   buildBm25DocumentText,\n1541:   buildBm25DocumentFields,\n1542:   DEFAULT_K1,\n1543:   DEFAULT_B,\n1544:   BM25_FTS5_WEIGHTS,\n1545:   BM25_FIELD_WEIGHTS,\n1546: };\n1547: \n1548: export type {\n1549:   BM25SearchResult,\n1550:   BM25Stats,\n1551:   BM25DocumentSource,\n1552:   BM25DocumentFields,\n1553:   BM25FieldWeights,\n1554:   BM25SearchOptions,\n1555:   Bm25Engine,\n1556:   InMemoryBm25Engine,\n1557:   NormalizedLexicalQueryTokens,\n1558: };\n\n(End of file - total 1558 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface BM25SearchResult {\n  id: string;\n  /**\n   * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n   * Higher = better lexical match. Not directly comparable to vector similarity\n   * scores; use min-max normalization or RRF when combining with other methods.\n   */\n  score: number;\n}\n\ninterface BM25Stats {\n  documentCount: number;\n  termCount: number;\n  avgDocLength: number;\n}\n\ninterface BM25DocumentSource {\n  title?: string | null;\n  content_text?: string | null;\n  trigger_phrases?: string | string[] | null;\n  file_path?: string | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1B. CONSTANTS & FEATURE FLAG\n   ──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_K1 = 1.2;\nconst DEFAULT_B = 0.75;\nconst BM25_WARMUP_BATCH_SIZE = 250;\nconst PACKED_POSTING_CHUNK_SIZE = 128;\nconst PACKED_POSTING_FIELD_WIDTH = 4;\nconst PACKED_POSTING_MAX_BYTE_TF = 0xff;\nconst PACKED_POSTING_MAX_NARROW_TF = 0xffff;\nconst PACKED_POSTING_MAX_NARROW_DOC_ID = 0xffff;\nconst PACKED_POSTING_MAX_NARROW_TERM_ID = 0xffff;\nconst PACKED_POSTING_TITLE_OFFSET = 0;\nconst PACKED_POSTING_TRIGGER_OFFSET = 1;\nconst PACKED_POSTING_PATH_OFFSET = 2;\nconst PACKED_POSTING_BODY_OFFSET = 3;\nconst BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\nconst BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\nconst BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\ntype Bm25Engine = typeof BM25_ENGINE_VALUES[number];\ntype InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\ntype BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n\nconst BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\nconst BM25_ENGINE_LOGGED = new Set<string>();\n\n/**\n * Field weight multipliers for weighted BM25 scoring.\n * When indexing a document composed of multiple fields, multiply\n * each field's token scores by the appropriate weight before\n * accumulating the total document score.\n *\n * These weights are shared by the FTS5 path and the packed in-memory\n * fallback so both lexical lanes preserve the same field-priority intent.\n *\n * title:           10.0 — exact title matches are the strongest signal\n * trigger_phrases:  5.0 — curated keywords next most important\n * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n * body:             1.0 — baseline weight for full body / content_text\n */\nconst BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n\nconst BM25_FIELD_WEIGHTS: Record<string, number> = {\n  title: BM25_FTS5_WEIGHTS[0],\n  trigger_phrases: BM25_FTS5_WEIGHTS[1],\n  content_generic: BM25_FTS5_WEIGHTS[2],\n  body: BM25_FTS5_WEIGHTS[3],\n};\n\ntype BM25FieldWeights = Record<BM25FieldName, number>;\n\ninterface BM25DocumentFields {\n  title?: string | null;\n  trigger_phrases?: string | string[] | null;\n  content_generic?: string | null;\n  body?: string | null;\n}\n\ninterface BM25SearchOptions {\n  fieldWeights?: Partial<BM25FieldWeights>;\n}\n\ninterface LegacyDocumentRecord {\n  tokens: string[];\n  termFreq: Map<string, number>;\n}\n\ninterface PackedDocumentRecord {\n  numericId: number;\n  id: string;\n  length: number;\n  termIds: Uint16Array | Uint32Array;\n}\n\ntype PackedFieldTfWidth = 1 | 2 | 4;\n\ninterface PackedPostingStore {\n  docIdChunks: Array<Uint16Array | Uint32Array>;\n  fieldTfChunks: Array<Uint8Array | Uint16Array | Uint32Array>;\n  length: number;\n  sorted: boolean;\n  wideDocIds: boolean;\n  fieldTfWidth: PackedFieldTfWidth;\n}\n\ntype PackedPostingMutable = PackedPostingStore;\ntype PackedPostingList = PackedPostingStore;\n\ninterface PackedPostingEntry {\n  docId: number;\n  titleTf: number;\n  triggerTf: number;\n  pathTf: number;\n  bodyTf: number;\n}\n\ntype Bm25TokenInterns = Map<number, string[]>;\n\n/**\n * Check whether the in-memory BM25 index is enabled.\n *\n * @returns `true` when BM25 indexing/search is enabled for the current process.\n * @example\n * ```ts\n * if (isBm25Enabled()) {\n *   getIndex();\n * }\n * ```\n */\nfunction isBm25Enabled(): boolean {\n  const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n  if (!value) return true; // enabled by default\n  if (BM25_DISABLED_VALUES.has(value)) return false;\n  return BM25_ENABLED_VALUES.has(value);\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. HELPERS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Count token frequency occurrences for BM25 scoring.\n *\n * @param tokens - Normalized tokens produced by {@link tokenize}.\n * @returns A frequency map keyed by token text.\n * @example\n * ```ts\n * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n * // 2\n * ```\n */\nfunction getTermFrequencies(tokens: string[]): Map<string, number> {\n  const freq = new Map<string, number>();\n  for (const token of tokens) {\n    freq.set(token, (freq.get(token) || 0) + 1);\n  }\n  return freq;\n}\n\nfunction stemNormalizedToken(word: string): string {\n  let stem = word;\n  let suffixRemoved = false;\n\n  if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n  else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n  else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n\n  if (suffixRemoved && stem.length >= 3) {\n    const last = stem[stem.length - 1];\n    if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n      stem = stem.slice(0, -1);\n    }\n  }\n\n  return stem;\n}\n\nfunction bm25ContentNeedsNormalization(content: string): boolean {\n  return (\n    content.trim() !== content ||\n    content.startsWith('---') ||\n    content.includes('<!--') ||\n    content.includes('```') ||\n    content.includes('|') ||\n    /(?:^|\\n)\\s*(?:[-*]\\s+|\\d+\\.\\s+|#{1,6}\\s+)/.test(content) ||\n    /\\n{3,}/.test(content)\n  );\n}\n\nfunction normalizeContentForBM25IfNeeded(content: string): string {\n  return bm25ContentNeedsNormalization(content) ? normalizeContentForBM25(content) : content;\n}\n\nfunction hashBm25TokenSpan(text: string, start: number, end: number): number {\n  let hash = 2166136261;\n  for (let i = start; i < end; i += 1) {\n    let code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      code += 32;\n    }\n    hash ^= code;\n    hash = Math.imul(hash, 16777619);\n  }\n  return hash >>> 0;\n}\n\nfunction equalsBm25TokenSpan(candidate: string, text: string, start: number, end: number): boolean {\n  if (candidate.length !== end - start) {\n    return false;\n  }\n\n  for (let i = start; i < end; i += 1) {\n    let code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      code += 32;\n    }\n    if (candidate.charCodeAt(i - start) !== code) {\n      return false;\n    }\n  }\n\n  return true;\n}\n\nfunction internBm25Token(\n  text: string,\n  start: number,\n  end: number,\n  hasUppercase: boolean,\n  interns?: Bm25TokenInterns\n): string {\n  if (!interns) {\n    return hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n  }\n\n  const hash = hashBm25TokenSpan(text, start, end);\n  const bucket = interns.get(hash);\n  if (bucket) {\n    for (const candidate of bucket) {\n      if (equalsBm25TokenSpan(candidate, text, start, end)) {\n        return candidate;\n      }\n    }\n  }\n\n  const token = hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n  if (bucket) {\n    bucket.push(token);\n  } else {\n    interns.set(hash, [token]);\n  }\n  return token;\n}\n\nfunction visitBm25Tokens(text: string, visitor: (token: string) => void, interns?: Bm25TokenInterns): void {\n  if (!text || typeof text !== 'string') return;\n\n  let tokenStart = -1;\n  let hasUppercase = false;\n  const flush = (tokenEnd: number) => {\n    if (tokenStart < 0) return;\n    if (tokenEnd - tokenStart >= 2) {\n      const token = internBm25Token(text, tokenStart, tokenEnd, hasUppercase, interns);\n      if (!STOP_WORDS.has(token)) {\n        visitor(stemNormalizedToken(token));\n      }\n    }\n    tokenStart = -1;\n    hasUppercase = false;\n  };\n\n  for (let i = 0; i < text.length; i += 1) {\n    const code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      if (tokenStart < 0) tokenStart = i;\n      hasUppercase = true;\n    } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n      if (tokenStart < 0) tokenStart = i;\n    } else if (tokenStart >= 0) {\n      flush(i);\n    }\n  }\n\n  flush(text.length);\n}\n\nfunction visitBm25FieldValue(\n  value: BM25DocumentFields[BM25FieldName],\n  visitor: (token: string) => void,\n  interns?: Bm25TokenInterns\n): void {\n  if (Array.isArray(value)) {\n    for (const entry of value) {\n      visitBm25Tokens(entry, visitor, interns);\n    }\n    return;\n  }\n\n  visitBm25Tokens(value ?? '', visitor, interns);\n}\n\nfunction hasBm25DocumentText(fields: BM25DocumentFields): boolean {\n  for (const fieldName of BM25_FIELD_NAMES) {\n    const value = fields[fieldName];\n    if (Array.isArray(value)) {\n      if (value.some((entry) => typeof entry === 'string' && entry.trim().length > 0)) {\n        return true;\n      }\n    } else if (typeof value === 'string' && value.trim().length > 0) {\n      return true;\n    }\n  }\n  return false;\n}\n\nfunction normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n  if (Array.isArray(triggerPhrases)) {\n    return triggerPhrases\n      .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n      .join(' ');\n  }\n\n  if (typeof triggerPhrases !== 'string') {\n    return '';\n  }\n\n  const trimmed = triggerPhrases.trim();\n  if (!trimmed) {\n    return '';\n  }\n\n  try {\n    const parsed = JSON.parse(trimmed) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed\n        .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n        .join(' ');\n    }\n  } catch {\n    // Fall back to raw string when the database value is not JSON.\n  }\n\n  return trimmed;\n}\n\nfunction resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n  return {\n    title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n    trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n    content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n    body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n  };\n}\n\nfunction emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n  const key = `${engine}:${reason}`;\n  if (BM25_ENGINE_LOGGED.has(key)) {\n    return;\n  }\n  BM25_ENGINE_LOGGED.add(key);\n  // stderr keeps stdout clean for JSON-RPC frames under stdio transport.\n  console.warn(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n}\n\nfunction resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n  const configured = resolveBm25Engine();\n  if (configured === 'legacy-inmemory') {\n    emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n    return 'legacy-inmemory';\n  }\n\n  if (configured === 'sqlite') {\n    emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n    return 'packed-inmemory';\n  }\n\n  if (configured === 'packed-inmemory') {\n    emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n    return 'packed-inmemory';\n  }\n\n  emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n  return 'packed-inmemory';\n}\n\nfunction buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n  return {\n    title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n    body: typeof row.content_text === 'string' && row.content_text.trim()\n      ? normalizeContentForBM25IfNeeded(row.content_text)\n      : '',\n    trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n    content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n  };\n}\n\nfunction buildBm25DocumentText(row: BM25DocumentSource): string {\n  const textParts: string[] = [];\n\n  if (typeof row.title === 'string' && row.title.trim()) {\n    textParts.push(row.title.trim());\n  }\n\n  if (typeof row.content_text === 'string' && row.content_text.trim()) {\n    textParts.push(normalizeContentForBM25IfNeeded(row.content_text));\n  }\n\n  const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n  if (triggerPhrases) {\n    textParts.push(triggerPhrases);\n  }\n\n  if (typeof row.file_path === 'string' && row.file_path.trim()) {\n    textParts.push(row.file_path.trim());\n  }\n\n  return textParts.join(' ').trim();\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. BM25 INDEX CLASS\n\n// ───────────────────────────────────────────────────────────────\nclass BM25Index {\n  private k1: number;\n  private b: number;\n  private engine: InMemoryBm25Engine;\n  private documents: Map<string, LegacyDocumentRecord>;\n  private packedDocuments: Map<string, PackedDocumentRecord>;\n  private packedDocIds: Array<string | undefined>;\n  private packedFreeNumericIds: number[];\n  private packedDocNumbersById: Map<string, number>;\n  private packedMutablePostings: Map<string, PackedPostingMutable>;\n  private packedPostings: Map<string, PackedPostingList>;\n  private packedDirtyTerms: Set<string>;\n  private packedTokenInterns: Bm25TokenInterns;\n  private packedTermIdsByToken: Map<string, number>;\n  private packedTermsById: string[];\n  private packedScratchPositions: Int32Array;\n  private packedScratchTermIds: number[];\n  private packedScratchTotalTfs: number[];\n  private packedScratchTitleTfs: number[];\n  private packedScratchTriggerTfs: number[];\n  private packedScratchPathTfs: number[];\n  private packedScratchBodyTfs: number[];\n  private documentFreq: Map<string, number>;\n  private totalDocLength: number;\n  private warmupHandle: ReturnType<typeof setTimeout> | null;\n  private warmupGeneration: number;\n\n  constructor(\n    k1: number = DEFAULT_K1,\n    b: number = DEFAULT_B,\n    engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n  ) {\n    this.k1 = k1;\n    this.b = b;\n    this.engine = engine;\n    this.documents = new Map();\n    this.packedDocuments = new Map();\n    this.packedDocIds = [];\n    this.packedFreeNumericIds = [];\n    this.packedDocNumbersById = new Map();\n    this.packedMutablePostings = new Map();\n    this.packedPostings = new Map();\n    this.packedDirtyTerms = new Set();\n    this.packedTokenInterns = new Map();\n    this.packedTermIdsByToken = new Map();\n    this.packedTermsById = [];\n    this.packedScratchPositions = new Int32Array(16_384);\n    this.packedScratchPositions.fill(-1);\n    this.packedScratchTermIds = [];\n    this.packedScratchTotalTfs = [];\n    this.packedScratchTitleTfs = [];\n    this.packedScratchTriggerTfs = [];\n    this.packedScratchPathTfs = [];\n    this.packedScratchBodyTfs = [];\n    this.documentFreq = new Map();\n    this.totalDocLength = 0;\n    this.warmupHandle = null;\n    this.warmupGeneration = 0;\n  }\n\n  addDocument(id: string, text: string): void {\n    if (this.engine === 'packed-inmemory') {\n      this.addDocumentFields(id, { body: text });\n      return;\n    }\n\n    const tokens = tokenize(text);\n    const termFreq = getTermFrequencies(tokens);\n\n    if (this.documents.has(id)) {\n      this.removeDocument(id);\n    }\n\n    this.documents.set(id, { tokens, termFreq });\n    this.totalDocLength += tokens.length;\n\n    // Update document frequency\n    for (const term of termFreq.keys()) {\n      this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n    }\n  }\n\n  addDocumentFields(id: string, fields: BM25DocumentFields): void {\n    if (this.engine === 'legacy-inmemory') {\n      this.addDocument(id, this.joinDocumentFields(fields));\n      return;\n    }\n\n    if (this.packedDocuments.has(id)) {\n      this.removeDocument(id);\n    }\n\n    this.collectPackedTermFrequencies(fields);\n    try {\n      let length = 0;\n      for (const totalTf of this.packedScratchTotalTfs) {\n        length += totalTf;\n      }\n      if (length === 0) {\n        return;\n      }\n\n      const numericId = this.getPackedNumericId(id);\n      this.packedDocuments.set(id, {\n        numericId,\n        id,\n        length,\n        termIds: this.createPackedDocumentTermIds(),\n      });\n      this.totalDocLength += length;\n\n      for (let i = 0; i < this.packedScratchTermIds.length; i += 1) {\n        const term = this.packedTermsById[this.packedScratchTermIds[i]];\n        const postings = this.ensurePackedMutablePostings(term);\n        this.setPackedMutablePosting(\n          postings,\n          numericId,\n          this.packedScratchTitleTfs[i],\n          this.packedScratchTriggerTfs[i],\n          this.packedScratchPathTfs[i],\n          this.packedScratchBodyTfs[i]\n        );\n        this.packedDirtyTerms.add(term);\n        this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n      }\n    } finally {\n      this.clearPackedFrequencyScratch();\n    }\n  }\n\n  removeDocument(id: string): boolean {\n    if (this.engine === 'packed-inmemory') {\n      return this.removePackedDocument(id);\n    }\n\n    const doc = this.documents.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.tokens.length;\n\n    for (const term of doc.termFreq.keys()) {\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.documents.delete(id);\n    return true;\n  }\n\n  calculateIdf(term: string): number {\n    const n = this.getDocumentCount();\n    const df = this.documentFreq.get(term) || 0;\n    if (df === 0 || n === 0) return 0;\n    return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n  }\n\n  calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n    if (this.engine === 'packed-inmemory') {\n      return this.calculatePackedScore(queryTokens, docId, options);\n    }\n\n    const doc = this.documents.get(docId);\n    if (!doc) return 0;\n\n    const avgDl = this.getAverageDocumentLength();\n    const dl = doc.tokens.length;\n\n    let score = 0;\n    for (const term of queryTokens) {\n      const tf = doc.termFreq.get(term) || 0;\n      if (tf === 0) continue;\n\n      const idf = this.calculateIdf(term);\n      const numerator = tf * (this.k1 + 1);\n      const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n      score += idf * (numerator / denominator);\n    }\n\n    return score;\n  }\n\n  search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n    const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n    if (queryTokens.length === 0) return [];\n\n    if (this.engine === 'packed-inmemory') {\n      return this.searchPacked(queryTokens, limit, options);\n    }\n\n    const results: BM25SearchResult[] = [];\n\n    for (const [id] of this.documents) {\n      const score = this.calculateScore(queryTokens, id);\n      if (score > 0) {\n        results.push({ id, score });\n      }\n    }\n\n    return results\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  getStats(): BM25Stats {\n    return {\n      documentCount: this.getDocumentCount(),\n      termCount: this.documentFreq.size,\n      avgDocLength: this.getAverageDocumentLength(),\n    };\n  }\n\n  clear(): void {\n    this.cancelWarmup();\n    this.documents.clear();\n    this.packedDocuments.clear();\n    this.packedDocIds = [];\n    this.packedFreeNumericIds = [];\n    this.packedDocNumbersById.clear();\n    this.packedMutablePostings.clear();\n    this.packedPostings.clear();\n    this.packedDirtyTerms.clear();\n    this.packedTokenInterns.clear();\n    this.packedTermIdsByToken.clear();\n    this.packedTermsById = [];\n    this.packedScratchPositions.fill(-1);\n    this.clearPackedFrequencyScratch();\n    this.documentFreq.clear();\n    this.totalDocLength = 0;\n  }\n\n  addDocuments(docs: Array<{ id: string; text: string }>): void {\n    for (const doc of docs) {\n      this.addDocument(doc.id, doc.text);\n    }\n  }\n\n  finalizePackedPostings(): void {\n    if (this.engine === 'legacy-inmemory') {\n      return;\n    }\n\n    for (const term of Array.from(this.packedDirtyTerms)) {\n      this.getPackedPosting(term);\n    }\n    this.packedMutablePostings.clear();\n  }\n\n  /**\n   * Incrementally synchronize changed rows from the database into the in-memory index.\n   */\n  syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n    const normalizedIds = Array.from(\n      new Set(\n        rowIds\n          .map((rowId) => Number(rowId))\n          .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n      )\n    );\n\n    if (normalizedIds.length === 0) {\n      return 0;\n    }\n\n    try {\n      const placeholders = normalizedIds.map(() => '?').join(', ');\n      const rows = (database.prepare(\n        `SELECT id, title, content_text, trigger_phrases, file_path\n         FROM memory_index\n         WHERE id IN (${placeholders})`\n      ) as Database.Statement).all(...normalizedIds) as Array<{\n        id: number;\n        title: string | null;\n        content_text: string | null;\n        trigger_phrases: string | null;\n        file_path: string | null;\n      }>;\n\n      const activeRowMap = new Map<number, typeof rows[number]>();\n      for (const row of rows) {\n        activeRowMap.set(row.id, row);\n      }\n\n      for (const rowId of normalizedIds) {\n        const row = activeRowMap.get(rowId);\n        if (!row) {\n          this.removeDocument(String(rowId));\n          continue;\n        }\n\n        const fields = buildBm25DocumentFields(row);\n        if (hasBm25DocumentText(fields)) {\n          this.addDocumentFields(String(row.id), fields);\n        } else {\n          this.removeDocument(String(row.id));\n        }\n      }\n\n      return normalizedIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n      return 0;\n    }\n  }\n\n  /**\n   * Defer full startup warmup into batched row-ID syncs so process\n   * initialization is not blocked by a monolithic in-memory rebuild.\n   */\n  rebuildFromDatabase(database: Database.Database): number {\n    this.clear();\n\n    try {\n      const rows = (database.prepare(\n        `SELECT id\n         FROM memory_index\n         ORDER BY id`\n      ) as Database.Statement).all() as Array<{ id: number }>;\n\n      const pendingIds = rows.map((row) => row.id);\n      if (pendingIds.length === 0) {\n        return 0;\n      }\n\n      const warmupGeneration = ++this.warmupGeneration;\n      const processBatch = () => {\n        if (warmupGeneration !== this.warmupGeneration) {\n          return;\n        }\n\n        const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n        if (batchIds.length === 0) {\n          this.finalizePackedPostings();\n          this.warmupHandle = null;\n          return;\n        }\n\n        this.syncChangedRows(database, batchIds);\n\n        if (pendingIds.length > 0) {\n          this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n        } else {\n          // The queue drains on the last non-empty batch, so the empty-batch\n          // finalize above never runs on this path. Finalize here too, or the\n          // whole corpus stays in mutable number[] postings and the packed\n          // engine's RAM bound is lost until every term is searched.\n          this.finalizePackedPostings();\n          this.warmupHandle = null;\n        }\n      };\n\n      this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n      return pendingIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n      return 0;\n    }\n  }\n\n  cancelWarmup(): void {\n    this.warmupGeneration += 1;\n    if (this.warmupHandle) {\n      clearRegisteredTimer(this.warmupHandle);\n      this.warmupHandle = null;\n    }\n  }\n\n  private getDocumentCount(): number {\n    return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n  }\n\n  private getAverageDocumentLength(): number {\n    const documentCount = this.getDocumentCount();\n    return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n  }\n\n  private joinDocumentFields(fields: BM25DocumentFields): string {\n    const parts: string[] = [];\n    for (const fieldName of BM25_FIELD_NAMES) {\n      const value = fields[fieldName];\n      if (Array.isArray(value)) {\n        parts.push(value.join(' '));\n      } else if (typeof value === 'string' && value.trim()) {\n        parts.push(value.trim());\n      }\n    }\n    return parts.join(' ').trim();\n  }\n\n  private getPackedNumericId(id: string): number {\n    const existing = this.packedDocNumbersById.get(id);\n    if (existing !== undefined) {\n      return existing;\n    }\n\n    // Reuse a slot freed by a prior removal before extending, so packedDocIds is\n    // bounded by the live document count rather than cumulative write volume.\n    const recycled = this.packedFreeNumericIds.pop();\n    const numericId = recycled ?? this.packedDocIds.length;\n    this.packedDocIds[numericId] = id;\n    this.packedDocNumbersById.set(id, numericId);\n    return numericId;\n  }\n\n  private collectPackedTermFrequencies(fields: BM25DocumentFields): void {\n    for (const fieldName of BM25_FIELD_NAMES) {\n      visitBm25FieldValue(\n        fields[fieldName],\n        (token) => this.recordPackedTokenFrequency(token, fieldName),\n        this.packedTokenInterns\n      );\n    }\n  }\n\n  private recordPackedTokenFrequency(token: string, fieldName: BM25FieldName): void {\n    const termId = this.getPackedTermId(token);\n    let scratchIndex = this.packedScratchPositions[termId];\n    if (scratchIndex < 0) {\n      scratchIndex = this.packedScratchTermIds.length;\n      this.packedScratchPositions[termId] = scratchIndex;\n      this.packedScratchTermIds.push(termId);\n      this.packedScratchTotalTfs.push(0);\n      this.packedScratchTitleTfs.push(0);\n      this.packedScratchTriggerTfs.push(0);\n      this.packedScratchPathTfs.push(0);\n      this.packedScratchBodyTfs.push(0);\n    }\n\n    this.packedScratchTotalTfs[scratchIndex] += 1;\n    if (fieldName === 'title') this.packedScratchTitleTfs[scratchIndex] += 1;\n    else if (fieldName === 'trigger_phrases') this.packedScratchTriggerTfs[scratchIndex] += 1;\n    else if (fieldName === 'content_generic') this.packedScratchPathTfs[scratchIndex] += 1;\n    else this.packedScratchBodyTfs[scratchIndex] += 1;\n  }\n\n  private getPackedTermId(token: string): number {\n    const existing = this.packedTermIdsByToken.get(token);\n    if (existing !== undefined) {\n      return existing;\n    }\n\n    const termId = this.packedTermsById.length;\n    this.packedTermIdsByToken.set(token, termId);\n    this.packedTermsById.push(token);\n    this.ensurePackedScratchPositionCapacity(termId + 1);\n    return termId;\n  }\n\n  private ensurePackedScratchPositionCapacity(minimum: number): void {\n    if (this.packedScratchPositions.length >= minimum) {\n      return;\n    }\n\n    let capacity = this.packedScratchPositions.length;\n    while (capacity < minimum) {\n      capacity *= 2;\n    }\n\n    const next = new Int32Array(capacity);\n    next.fill(-1);\n    next.set(this.packedScratchPositions);\n    this.packedScratchPositions = next;\n  }\n\n  private clearPackedFrequencyScratch(): void {\n    for (const termId of this.packedScratchTermIds) {\n      this.packedScratchPositions[termId] = -1;\n    }\n    this.packedScratchTermIds.length = 0;\n    this.packedScratchTotalTfs.length = 0;\n    this.packedScratchTitleTfs.length = 0;\n    this.packedScratchTriggerTfs.length = 0;\n    this.packedScratchPathTfs.length = 0;\n    this.packedScratchBodyTfs.length = 0;\n  }\n\n  private createPackedDocumentTermIds(): Uint16Array | Uint32Array {\n    for (const termId of this.packedScratchTermIds) {\n      if (termId > PACKED_POSTING_MAX_NARROW_TERM_ID) {\n        return Uint32Array.from(this.packedScratchTermIds);\n      }\n    }\n\n    return Uint16Array.from(this.packedScratchTermIds);\n  }\n\n  private removePackedDocument(id: string): boolean {\n    const doc = this.packedDocuments.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.length;\n\n    for (const termId of doc.termIds) {\n      const term = this.packedTermsById[termId];\n      const postings = this.ensurePackedMutablePostings(term);\n      this.deletePackedMutablePosting(postings, doc.numericId);\n      this.packedDirtyTerms.add(term);\n\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n        this.packedMutablePostings.delete(term);\n        this.packedPostings.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.packedDocuments.delete(id);\n    this.packedDocIds[doc.numericId] = undefined;\n    this.packedFreeNumericIds.push(doc.numericId);\n    this.packedDocNumbersById.delete(id);\n    return true;\n  }\n\n  private getPackedPosting(term: string): PackedPostingList | undefined {\n    if (!this.packedDirtyTerms.has(term)) {\n      return this.packedPostings.get(term);\n    }\n\n    const mutable = this.packedMutablePostings.get(term);\n    if (!mutable || mutable.length === 0) {\n      this.packedDirtyTerms.delete(term);\n      this.packedPostings.delete(term);\n      return undefined;\n    }\n\n    this.sortPackedMutablePosting(mutable);\n    this.packedPostings.set(term, mutable);\n    this.packedMutablePostings.delete(term);\n    this.packedDirtyTerms.delete(term);\n    return mutable;\n  }\n\n  private ensurePackedMutablePostings(term: string): PackedPostingMutable {\n    const existing = this.packedMutablePostings.get(term);\n    if (existing) {\n      return existing;\n    }\n\n    const packed = this.packedPostings.get(term);\n    if (packed) {\n      this.packedPostings.delete(term);\n      this.packedMutablePostings.set(term, packed);\n      return packed;\n    }\n\n    const hydrated = this.createPackedMutablePosting();\n    this.packedMutablePostings.set(term, hydrated);\n    return hydrated;\n  }\n\n  private createPackedMutablePosting(): PackedPostingMutable {\n    return {\n      docIdChunks: [],\n      fieldTfChunks: [],\n      length: 0,\n      sorted: true,\n      wideDocIds: false,\n      fieldTfWidth: 1,\n    };\n  }\n\n  private ensurePackedDocIdChunk(\n    postings: PackedPostingMutable,\n    index: number\n  ): Uint16Array | Uint32Array {\n    const chunkIndex = Math.floor(index / PACKED_POSTING_CHUNK_SIZE);\n    let chunk = postings.docIdChunks[chunkIndex];\n    if (!chunk) {\n      chunk = postings.wideDocIds\n        ? new Uint32Array(PACKED_POSTING_CHUNK_SIZE)\n        : new Uint16Array(PACKED_POSTING_CHUNK_SIZE);\n      postings.docIdChunks[chunkIndex] = chunk;\n    }\n    return chunk;\n  }\n\n  private ensurePackedFieldTfChunk(\n    postings: PackedPostingMutable,\n    index: number\n  ): Uint8Array | Uint16Array | Uint32Array {\n    const chunkIndex = Math.floor(index / PACKED_POSTING_CHUNK_SIZE);\n    let chunk = postings.fieldTfChunks[chunkIndex];\n    if (!chunk) {\n      const length = PACKED_POSTING_CHUNK_SIZE * PACKED_POSTING_FIELD_WIDTH;\n      chunk = this.createPackedFieldTfChunk(length, postings.fieldTfWidth);\n      postings.fieldTfChunks[chunkIndex] = chunk;\n    }\n    return chunk;\n  }\n\n  private createPackedFieldTfChunk(\n    length: number,\n    width: PackedFieldTfWidth\n  ): Uint8Array | Uint16Array | Uint32Array {\n    if (width === 1) return new Uint8Array(length);\n    if (width === 2) return new Uint16Array(length);\n    return new Uint32Array(length);\n  }\n\n  private requiredPackedFieldTfWidth(\n    titleTf: number,\n    triggerTf: number,\n    pathTf: number,\n    bodyTf: number\n  ): PackedFieldTfWidth {\n    if (\n      titleTf > PACKED_POSTING_MAX_NARROW_TF ||\n      triggerTf > PACKED_POSTING_MAX_NARROW_TF ||\n      pathTf > PACKED_POSTING_MAX_NARROW_TF ||\n      bodyTf > PACKED_POSTING_MAX_NARROW_TF\n    ) {\n      return 4;\n    }\n\n    if (\n      titleTf > PACKED_POSTING_MAX_BYTE_TF ||\n      triggerTf > PACKED_POSTING_MAX_BYTE_TF ||\n      pathTf > PACKED_POSTING_MAX_BYTE_TF ||\n      bodyTf > PACKED_POSTING_MAX_BYTE_TF\n    ) {\n      return 2;\n    }\n\n    return 1;\n  }\n\n  private ensurePackedDocIdWidth(postings: PackedPostingMutable, docId: number): void {\n    if (postings.wideDocIds || docId <= PACKED_POSTING_MAX_NARROW_DOC_ID) {\n      return;\n    }\n\n    for (let i = 0; i < postings.docIdChunks.length; i += 1) {\n      const chunk = postings.docIdChunks[i];\n      if (!chunk) continue;\n      const widened = new Uint32Array(chunk.length);\n      widened.set(chunk);\n      postings.docIdChunks[i] = widened;\n    }\n    postings.wideDocIds = true;\n  }\n\n  private ensurePackedFieldTfWidth(\n    postings: PackedPostingMutable,\n    titleTf: number,\n    triggerTf: number,\n    pathTf: number,\n    bodyTf: number\n  ): void {\n    const requiredWidth = this.requiredPackedFieldTfWidth(\n      titleTf,\n      triggerTf,\n      pathTf,\n      bodyTf\n    );\n    if (postings.fieldTfWidth >= requiredWidth) {\n      return;\n    }\n\n    for (let i = 0; i < postings.fieldTfChunks.length; i += 1) {\n      const chunk = postings.fieldTfChunks[i];\n      if (!chunk) continue;\n      const widened = this.createPackedFieldTfChunk(chunk.length, requiredWidth);\n      widened.set(chunk);\n      postings.fieldTfChunks[i] = widened;\n    }\n    postings.fieldTfWidth = requiredWidth;\n  }\n\n  private getPackedPostingDocId(postings: PackedPostingList, index: number): number {\n    const chunk = postings.docIdChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n    return chunk[index % PACKED_POSTING_CHUNK_SIZE];\n  }\n\n  private getPackedPostingFieldTf(\n    postings: PackedPostingList,\n    index: number,\n    fieldOffset: number\n  ): number {\n    const chunk = postings.fieldTfChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n    const offset = (index % PACKED_POSTING_CHUNK_SIZE) * PACKED_POSTING_FIELD_WIDTH +\n      fieldOffset;\n    return chunk[offset];\n  }\n\n  private getPackedMutableEntry(\n    postings: PackedPostingMutable,\n    index: number\n  ): PackedPostingEntry {\n    const docIdChunk = postings.docIdChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n    const fieldTfChunk = postings.fieldTfChunks[Math.floor(index / PACKED_POSTING_CHUNK_SIZE)];\n    const docOffset = index % PACKED_POSTING_CHUNK_SIZE;\n    const fieldOffset = docOffset * PACKED_POSTING_FIELD_WIDTH;\n    return {\n      docId: docIdChunk[docOffset],\n      titleTf: fieldTfChunk[fieldOffset + PACKED_POSTING_TITLE_OFFSET],\n      triggerTf: fieldTfChunk[fieldOffset + PACKED_POSTING_TRIGGER_OFFSET],\n      pathTf: fieldTfChunk[fieldOffset + PACKED_POSTING_PATH_OFFSET],\n      bodyTf: fieldTfChunk[fieldOffset + PACKED_POSTING_BODY_OFFSET],\n    };\n  }\n\n  private setPackedMutableEntry(\n    postings: PackedPostingMutable,\n    index: number,\n    entry: PackedPostingEntry\n  ): void {\n    this.ensurePackedDocIdWidth(postings, entry.docId);\n    this.ensurePackedFieldTfWidth(\n      postings,\n      entry.titleTf,\n      entry.triggerTf,\n      entry.pathTf,\n      entry.bodyTf\n    );\n    const docIdChunk = this.ensurePackedDocIdChunk(postings, index);\n    const fieldTfChunk = this.ensurePackedFieldTfChunk(postings, index);\n    const docOffset = index % PACKED_POSTING_CHUNK_SIZE;\n    const fieldOffset = docOffset * PACKED_POSTING_FIELD_WIDTH;\n    docIdChunk[docOffset] = entry.docId;\n    fieldTfChunk[fieldOffset + PACKED_POSTING_TITLE_OFFSET] = entry.titleTf;\n    fieldTfChunk[fieldOffset + PACKED_POSTING_TRIGGER_OFFSET] = entry.triggerTf;\n    fieldTfChunk[fieldOffset + PACKED_POSTING_PATH_OFFSET] = entry.pathTf;\n    fieldTfChunk[fieldOffset + PACKED_POSTING_BODY_OFFSET] = entry.bodyTf;\n  }\n\n  private appendPackedMutableEntry(\n    postings: PackedPostingMutable,\n    entry: PackedPostingEntry\n  ): void {\n    const lastDocId = postings.length > 0\n      ? this.getPackedPostingDocId(postings, postings.length - 1)\n      : -1;\n    if (lastDocId > entry.docId) {\n      postings.sorted = false;\n    }\n    this.setPackedMutableEntry(postings, postings.length, entry);\n    postings.length += 1;\n  }\n\n  private setPackedMutablePosting(\n    postings: PackedPostingMutable,\n    numericId: number,\n    titleTf: number,\n    triggerTf: number,\n    pathTf: number,\n    bodyTf: number\n  ): void {\n    let existingIndex = -1;\n    for (let i = 0; i < postings.length; i += 1) {\n      if (this.getPackedPostingDocId(postings, i) === numericId) {\n        existingIndex = i;\n        break;\n      }\n    }\n    if (existingIndex >= 0) {\n      this.setPackedMutableEntry(postings, existingIndex, {\n        docId: numericId,\n        titleTf,\n        triggerTf,\n        pathTf,\n        bodyTf,\n      });\n      return;\n    }\n\n    this.appendPackedMutableEntry(postings, {\n      docId: numericId,\n      titleTf,\n      triggerTf,\n      pathTf,\n      bodyTf,\n    });\n  }\n\n  private deletePackedMutablePosting(postings: PackedPostingMutable, numericId: number): void {\n    let index = -1;\n    for (let i = 0; i < postings.length; i += 1) {\n      if (this.getPackedPostingDocId(postings, i) === numericId) {\n        index = i;\n        break;\n      }\n    }\n    if (index < 0) {\n      return;\n    }\n    if (index < postings.length - 1) {\n      for (let i = index + 1; i < postings.length; i += 1) {\n        this.setPackedMutableEntry(\n          postings,\n          i - 1,\n          this.getPackedMutableEntry(postings, i)\n        );\n      }\n    }\n    postings.length -= 1;\n  }\n\n  private sortPackedMutablePosting(postings: PackedPostingMutable): void {\n    if (postings.sorted) {\n      return;\n    }\n\n    for (let i = 1; i < postings.length; i += 1) {\n      const entry = this.getPackedMutableEntry(postings, i);\n      let j = i - 1;\n\n      while (j >= 0 && this.getPackedPostingDocId(postings, j) > entry.docId) {\n        this.setPackedMutableEntry(\n          postings,\n          j + 1,\n          this.getPackedMutableEntry(postings, j)\n        );\n        j -= 1;\n      }\n\n      this.setPackedMutableEntry(postings, j + 1, entry);\n    }\n\n    postings.sorted = true;\n  }\n\n  private calculatePackedScore(\n    queryTokens: string[],\n    docId: string,\n    options: BM25SearchOptions\n  ): number {\n    const doc = this.packedDocuments.get(docId);\n    if (!doc) return 0;\n\n    const weights = resolveBm25FieldWeights(options.fieldWeights);\n    const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n    let score = 0;\n\n    for (const term of queryTokens) {\n      const postings = this.getPackedPosting(term);\n      if (!postings) continue;\n      const postingIndex = this.findPackedPostingIndex(postings, doc.numericId);\n      if (postingIndex < 0) continue;\n\n      const weightedTf = this.calculateWeightedPostingFrequency(postings, postingIndex, weights);\n      if (weightedTf <= 0) continue;\n\n      const idf = this.calculateIdf(term);\n      score += this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n    }\n\n    return score;\n  }\n\n  private searchPacked(\n    queryTokens: string[],\n    limit: number,\n    options: BM25SearchOptions\n  ): BM25SearchResult[] {\n    const weights = resolveBm25FieldWeights(options.fieldWeights);\n    const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n    const scores = new Map<number, number>();\n\n    for (const term of queryTokens) {\n      const postings = this.getPackedPosting(term);\n      if (!postings) continue;\n\n      const idf = this.calculateIdf(term);\n      for (let i = 0; i < postings.length; i += 1) {\n        const numericId = this.getPackedPostingDocId(postings, i);\n        const id = this.packedDocIds[numericId];\n        if (!id) continue;\n        const doc = this.packedDocuments.get(id);\n        if (!doc) continue;\n\n        const weightedTf = this.calculateWeightedPostingFrequency(postings, i, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n        scores.set(numericId, (scores.get(numericId) || 0) + termScore);\n      }\n    }\n\n    return Array.from(scores.entries())\n      .map(([numericId, score]) => ({ id: this.packedDocIds[numericId], score }))\n      .filter((result): result is BM25SearchResult => typeof result.id === 'string' && result.score > 0)\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  private calculateWeightedPostingFrequency(\n    postings: PackedPostingList,\n    index: number,\n    weights: BM25FieldWeights\n  ): number {\n    const titleTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_TITLE_OFFSET);\n    const triggerTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_TRIGGER_OFFSET);\n    const pathTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_PATH_OFFSET);\n    const bodyTf = this.getPackedPostingFieldTf(postings, index, PACKED_POSTING_BODY_OFFSET);\n\n    return (\n      titleTf * weights.title +\n      triggerTf * weights.trigger_phrases +\n      pathTf * weights.content_generic +\n      bodyTf * weights.body\n    );\n  }\n\n  private findPackedPostingIndex(postings: PackedPostingList, numericId: number): number {\n    let low = 0;\n    let high = postings.length - 1;\n    while (low <= high) {\n      const mid = Math.floor((low + high) / 2);\n      const value = this.getPackedPostingDocId(postings, mid);\n      if (value === numericId) return mid;\n      if (value < numericId) {\n        low = mid + 1;\n      } else {\n        high = mid - 1;\n      }\n    }\n    return -1;\n  }\n\n  private calculateBm25TermScore(tf: number, dl: number, avgDl: number, idf: number): number {\n    const numerator = tf * (this.k1 + 1);\n    const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / avgDl));\n    return idf * (numerator / denominator);\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. SINGLETON\n\n// ───────────────────────────────────────────────────────────────\nlet indexInstance: BM25Index | null = null;\n\n/**\n * Retrieve the shared in-memory BM25 index singleton.\n *\n * @returns The process-wide {@link BM25Index} instance.\n * @example\n * ```ts\n * const index = getIndex();\n * index.addDocument('123', 'memory search');\n * ```\n */\nfunction getIndex(): BM25Index {\n  if (!indexInstance) {\n    indexInstance = new BM25Index();\n  }\n  return indexInstance;\n}\n\n/**\n * Reset the shared BM25 index singleton.\n *\n * @returns Nothing.\n * @example\n * ```ts\n * resetIndex();\n * ```\n */\nfunction resetIndex(): void {\n  indexInstance?.cancelWarmup();\n  indexInstance = null;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 5. LEXICAL ENGINE ROUTING\n\n// ───────────────────────────────────────────────────────────────\nfunction resolveBm25Engine(): Bm25Engine {\n  const value = process.env.SPECKIT_BM25_ENGINE?.trim().toLowerCase();\n  if (!value) {\n    return 'auto';\n  }\n\n  if ((BM25_ENGINE_VALUES as readonly string[]).includes(value)) {\n    return value as Bm25Engine;\n  }\n\n  console.warn(`[bm25-index] Unsupported SPECKIT_BM25_ENGINE=${value}; falling back to auto`);\n  return 'auto';\n}\n\nfunction isMemoryFtsAvailable(database: Database.Database | null | undefined): boolean {\n  if (!database) {\n    return false;\n  }\n\n  try {\n    const result = (database.prepare(\n      `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n    ) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch {\n    return false;\n  }\n}\n\nfunction shouldWarmInMemoryBm25(database: Database.Database | null | undefined): boolean {\n  if (!isBm25Enabled()) {\n    return false;\n  }\n\n  const engine = resolveBm25Engine();\n  emitBm25EngineSelection(engine, 'warmup routing');\n  if (engine === 'sqlite') {\n    if (!isMemoryFtsAvailable(database)) {\n      throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table; JS BM25 warmup is disabled in sqlite mode');\n    }\n    return false;\n  }\n\n  if (engine === 'auto') {\n    return !isMemoryFtsAvailable(database);\n  }\n\n  if (engine === 'packed-inmemory') {\n    return true;\n  }\n\n  return true;\n}\n\nfunction shouldUseSqliteLexicalEngine(database: Database.Database | null | undefined): boolean {\n  const engine = resolveBm25Engine();\n  emitBm25EngineSelection(engine, 'lexical routing');\n  if (engine === 'sqlite') {\n    if (!isMemoryFtsAvailable(database)) {\n      throw new Error('SPECKIT_BM25_ENGINE=sqlite requires the memory_fts table for lexical BM25 search');\n    }\n    return true;\n  }\n\n  if (engine === 'auto') {\n    return isMemoryFtsAvailable(database);\n  }\n\n  return false;\n}\n\nfunction getBm25EngineStatus(database: Database.Database | null | undefined = null): {\n  lexical_engine: Bm25Engine;\n  fts5_available: boolean;\n  warms_in_memory_bm25: boolean;\n  bm25_enabled: boolean;\n} {\n  const lexical_engine = resolveBm25Engine();\n  const fts5_available = isMemoryFtsAvailable(database);\n  let warms_in_memory_bm25 = false;\n\n  try {\n    warms_in_memory_bm25 = shouldWarmInMemoryBm25(database);\n  } catch {\n    warms_in_memory_bm25 = false;\n  }\n\n  return {\n    lexical_engine,\n    fts5_available,\n    warms_in_memory_bm25,\n    bm25_enabled: isBm25Enabled(),\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 6. EXPORTS\n\n// ───────────────────────────────────────────────────────────────\nexport {\n  BM25Index,\n  getIndex,\n  resetIndex,\n  tokenize,\n  simpleStem,\n  getTermFrequencies,\n  isBm25Enabled,\n  resolveBm25Engine,\n  isMemoryFtsAvailable,\n  shouldWarmInMemoryBm25,\n  shouldUseSqliteLexicalEngine,\n  getBm25EngineStatus,\n  sanitizeQueryTokens,\n  sanitizeFTS5Query,\n  normalizeLexicalQueryTokens,\n  buildBm25DocumentText,\n  buildBm25DocumentFields,\n  DEFAULT_K1,\n  DEFAULT_B,\n  BM25_FTS5_WEIGHTS,\n  BM25_FIELD_WEIGHTS,\n};\n\nexport type {\n  BM25SearchResult,\n  BM25Stats,\n  BM25DocumentSource,\n  BM25DocumentFields,\n  BM25FieldWeights,\n  BM25SearchOptions,\n  Bm25Engine,\n  InMemoryBm25Engine,\n  NormalizedLexicalQueryTokens,\n};","lineStart":1,"lineEnd":1558,"totalLines":1558,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781763777882,"end":1781763777894}},"metadata":{"openai":{"itemId":"fc_0d5b12e0056d81cf016a338ec1bf988191a8c1fadfffd90399"}},"id":"prt_ed965a5590011oDynBD3Jjhmrm","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96570b6001iiEKAma30bzCSA"}}
