ly removed,\n1656:         so a misclick or buggy client can be undone for ``retention_days``\n1657:         days. After that window the row is gone for good — including its\n1658:         embedding, entity links, and idempotency response cache lines\n1659:         (cascaded by their FKs to ``memories.id``).\n1660:         \"\"\"\n1661:         async with get_session() as session:\n1662:             params: dict = {\n1663:                 \"tenant_id\": tenant_id,\n1664:                 \"retention_days\": retention_days,\n1665:                 \"batch_size\": batch_size,\n1666:             }\n1667:             fleet_clause = \"\"\n1668:             if fleet_id:\n1669:                 fleet_clause = \"AND fleet_id = :fleet_id\"\n\n(Showing lines 1580-1669 of 4754. Use offset=1670 to continue.)\n</content>","metadata":{"preview":"    ) -> int:\n        async with get_session() as session:\n            params: dict = {\"tenant_id\": tenant_id, \"batch_size\": batch_size}\n            fleet_clause = \"\"\n            if fleet_id:\n                fleet_clause = \"AND fleet_id = :fleet_id\"\n                params[\"fleet_id\"] = fleet_id\n\n            result = await session.execute(\n                text(f\"\"\"\n                UPDATE memories SET status = 'outdated'\n                WHERE id IN (\n                    SELECT id FROM memories\n                    WHERE tenant_id = :tenant_id\n                      {fleet_clause}\n                      AND ts_valid_end < NOW()\n                      AND status = 'active'\n                      AND deleted_at IS NULL\n                    LIMIT :batch_size\n                )","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"    ) -> int:\n        async with get_session() as session:\n            params: dict = {\"tenant_id\": tenant_id, \"batch_size\": batch_size}\n            fleet_clause = \"\"\n            if fleet_id:\n                fleet_clause = \"AND fleet_id = :fleet_id\"\n                params[\"fleet_id\"] = fleet_id\n\n            result = await session.execute(\n                text(f\"\"\"\n                UPDATE memories SET status = 'outdated'\n                WHERE id IN (\n                    SELECT id FROM memories\n                    WHERE tenant_id = :tenant_id\n                      {fleet_clause}\n                      AND ts_valid_end < NOW()\n                      AND status = 'active'\n                      AND deleted_at IS NULL\n                    LIMIT :batch_size\n                )\n                RETURNING id\n            \"\"\"),\n                params,\n            )\n            return len(result.all())\n\n    async def memory_archive_stale(\n        self,\n        tenant_id: str,\n        fleet_id: str | None = None,\n        stale_days: int = 90,\n        max_weight: float = 0.3,\n        batch_size: int = 500,\n    ) -> int:\n        async with get_session() as session:\n            params: dict = {\n                \"tenant_id\": tenant_id,\n                \"stale_days\": stale_days,\n                \"max_weight\": max_weight,\n                \"batch_size\": batch_size,\n            }\n            fleet_clause = \"\"\n            if fleet_id:\n                fleet_clause = \"AND fleet_id = :fleet_id\"\n                params[\"fleet_id\"] = fleet_id\n\n            result = await session.execute(\n                text(f\"\"\"\n                UPDATE memories SET status = 'archived'\n                WHERE id IN (\n                    SELECT id FROM memories\n                    WHERE tenant_id = :tenant_id\n                      {fleet_clause}\n                      AND created_at < NOW() - INTERVAL '1 day' * :stale_days\n                      AND recall_count = 0\n                      AND weight < :max_weight\n                      AND status = 'active'\n                      AND deleted_at IS NULL\n                    LIMIT :batch_size\n                )\n                RETURNING id\n            \"\"\"),\n                params,\n            )\n            return len(result.all())\n\n    async def memory_purge_soft_deleted(\n        self,\n        tenant_id: str,\n        fleet_id: str | None = None,\n        retention_days: int = MEMORY_RETENTION_MAX_DAYS,\n        batch_size: int = 500,\n    ) -> int:\n        \"\"\"Hard-delete soft-deleted memories whose ``deleted_at`` is older\n        than ``retention_days``. Soft-deletes (CAURA-656) keeps rows\n        addressable for a grace period before they're physically removed,\n        so a misclick or buggy client can be undone for ``retention_days``\n        days. After that window the row is gone for good — including its\n        embedding, entity links, and idempotency response cache lines\n        (cascaded by their FKs to ``memories.id``).\n        \"\"\"\n        async with get_session() as session:\n            params: dict = {\n                \"tenant_id\": tenant_id,\n                \"retention_days\": retention_days,\n                \"batch_size\": batch_size,\n            }\n            fleet_clause = \"\"\n            if fleet_id:\n                fleet_clause = \"AND fleet_id = :fleet_id\"","lineStart":1580,"lineEnd":1669,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780729336592,"end":1780729336601}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872a08191a4936ea87830dc28"}},"id":"prt_e9bbd52c7001fOwFVvWTcDllln","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336655,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_PW1T2rZnCeKiEyIimXsO2sKy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/lifecycle_audit.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/lifecycle_audit.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Per-fanout audit row for OSS scheduled lifecycle operations (CAURA-655).\n2: \n3: One row is pre-published in the core-api fanout endpoint with\n4: ``status='pending'`` before the per-org Pub/Sub message goes out. The\n5: core-worker consumer flips it to ``in_progress`` on receipt and to\n6: ``success`` / ``failure`` on completion. DLQ'd or never-consumed\n7: messages remain observable as ``pending`` rows past their expected\n8: finish time.\n9: \n10: ``org_id`` is ``text`` and unconstrained — pure-OSS deployments key by\n11: the standalone tenant id, enterprise deployments by the real org id.\n12: Same shape as ``organization_settings.org_id`` (CAURA-654).\n13: \"\"\"\n14: \n15: from datetime import datetime\n16: \n17: from sqlalchemy import BigInteger, DateTime, Index, Text, text\n18: from sqlalchemy.dialects.postgresql import JSONB\n19: from sqlalchemy.orm import Mapped, mapped_column\n20: \n21: from common.models.base import Base\n22: \n23: \n24: class LifecycleAudit(Base):\n25:     __tablename__ = \"lifecycle_audit\"\n26:     __table_args__ = (\n27:         Index(\n28:             \"idx_lifecycle_audit_org_action_started\",\n29:             \"org_id\",\n30:             \"action\",\n31:             text(\"started_at DESC\"),\n32:         ),\n33:         # Partial index for the CAURA-657 dedup-gate query. Only\n34:         # successful rows are indexed (status='success' partial),\n35:         # keeping the index small while matching the dedup query\n36:         # ordering exactly.\n37:         Index(\n38:             \"idx_lifecycle_audit_dedup_gate\",\n39:             \"org_id\",\n40:             \"action\",\n41:             text(\"finished_at DESC\"),\n42:             postgresql_where=text(\"status = 'success'\"),\n43:         ),\n44:     )\n45: \n46:     id: Mapped[int] = mapped_column(BigInteger, primary_key=True, autoincrement=True)\n47:     org_id: Mapped[str] = mapped_column(Text, nullable=False)\n48:     action: Mapped[str] = mapped_column(Text, nullable=False)\n49:     triggered_by: Mapped[str] = mapped_column(Text, nullable=False)\n50:     started_at: Mapped[datetime] = mapped_column(\n51:         DateTime(timezone=True), nullable=False, server_default=text(\"now()\")\n52:     )\n53:     finished_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n54:     status: Mapped[str] = mapped_column(\n55:         Text, nullable=False, server_default=text(\"'pending'\")\n56:     )\n57:     stats: Mapped[dict | None] = mapped_column(JSONB)\n58:     error_message: Mapped[str | None] = mapped_column(Text)\n\n(End of file - total 58 lines)\n</content>","metadata":{"preview":"\"\"\"Per-fanout audit row for OSS scheduled lifecycle operations (CAURA-655).\n\nOne row is pre-published in the core-api fanout endpoint with\n``status='pending'`` before the per-org Pub/Sub message goes out. The\ncore-worker consumer flips it to ``in_progress`` on receipt and to\n``success`` / ``failure`` on completion. DLQ'd or never-consumed\nmessages remain observable as ``pending`` rows past their expected\nfinish time.\n\n``org_id`` is ``text`` and unconstrained — pure-OSS deployments key by\nthe standalone tenant id, enterprise deployments by the real org id.\nSame shape as ``organization_settings.org_id`` (CAURA-654).\n\"\"\"\n\nfrom datetime import datetime\n\nfrom sqlalchemy import BigInteger, DateTime, Index, Text, text\nfrom sqlalchemy.dialects.postgresql import JSONB\nfrom sqlalchemy.orm import Mapped, mapped_column\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/lifecycle_audit.py","text":"\"\"\"Per-fanout audit row for OSS scheduled lifecycle operations (CAURA-655).\n\nOne row is pre-published in the core-api fanout endpoint with\n``status='pending'`` before the per-org Pub/Sub message goes out. The\ncore-worker consumer flips it to ``in_progress`` on receipt and to\n``success`` / ``failure`` on completion. DLQ'd or never-consumed\nmessages remain observable as ``pending`` rows past their expected\nfinish time.\n\n``org_id`` is ``text`` and unconstrained — pure-OSS deployments key by\nthe standalone tenant id, enterprise deployments by the real org id.\nSame shape as ``organization_settings.org_id`` (CAURA-654).\n\"\"\"\n\nfrom datetime import datetime\n\nfrom sqlalchemy import BigInteger, DateTime, Index, Text, text\nfrom sqlalchemy.dialects.postgresql import JSONB\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.models.base import Base\n\n\nclass LifecycleAudit(Base):\n    __tablename__ = \"lifecycle_audit\"\n    __table_args__ = (\n        Index(\n            \"idx_lifecycle_audit_org_action_started\",\n            \"org_id\",\n            \"action\",\n            text(\"started_at DESC\"),\n        ),\n        # Partial index for the CAURA-657 dedup-gate query. Only\n        # successful rows are indexed (status='success' partial),\n        # keeping the index small while matching the dedup query\n        # ordering exactly.\n        Index(\n            \"idx_lifecycle_audit_dedup_gate\",\n            \"org_id\",\n            \"action\",\n            text(\"finished_at DESC\"),\n            postgresql_where=text(\"status = 'success'\"),\n        ),\n    )\n\n    id: Mapped[int] = mapped_column(BigInteger, primary_key=True, autoincrement=True)\n    org_id: Mapped[str] = mapped_column(Text, nullable=False)\n    action: Mapped[str] = mapped_column(Text, nullable=False)\n    triggered_by: Mapped[str] = mapped_column(Text, nullable=False)\n    started_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), nullable=False, server_default=text(\"now()\")\n    )\n    finished_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    status: Mapped[str] = mapped_column(\n        Text, nullable=False, server_default=text(\"'pending'\")\n    )\n    stats: Mapped[dict | None] = mapped_column(JSONB)\n    error_message: Mapped[str | None] = mapped_column(Text)","lineStart":1,"lineEnd":58,"totalLines":58,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/lifecycle_audit.py","time":{"start":1780729336649,"end":1780729336654}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872ac81918d9aaeb16f229959"}},"id":"prt_e9bbd531b001aRtwZUVe3aP305","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336719,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_0A3huvlZBs3aoWiice2f7Hoa","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Consumers for ``memclaw.lifecycle.<action>-requested`` topics\n2: (CAURA-655 archive ops, CAURA-656 purge, CAURA-657 pipeline ops).\n3: \n4: Lives in ``common/`` rather than under either service so the same code\n5: runs in both deployments. Two registration entry points reflect the\n6: split between SQL-only and pipeline-machinery ops:\n7: \n8: * :func:`register_archive_consumers` — archive + purge ops. Subscriber\n9:   is core-worker on SaaS; in OSS standalone core-api also subscribes\n10:   (no separate worker process).\n11: * :func:`register_pipeline_consumers` — crystallize + entity-link.\n12:   Subscriber is ALWAYS core-api because the consumer needs core-api's\n13:   pipeline machinery (run_crystallization, build_full_entity_linking_pipeline).\n14: \n15: The handler delegates the storage round-trips it needs (run the\n16: primitive, finalise the audit row, optionally check the dedup gate)\n17: to a small adapter the host service supplies. Per-action ops bind\n18: their own primitive callable + payload class at registration time so\n19: the dispatch never branches on a string.\n20: \"\"\"\n21: \n22: from __future__ import annotations\n23: \n24: import logging\n25: from collections.abc import Awaitable, Callable\n26: from functools import partial\n27: from typing import Protocol\n28: \n29: from pydantic import ValidationError\n30: \n31: from common.events.base import Event\n32: from common.events.factory import get_event_bus\n33: from common.events.lifecycle_archive_request import (\n34:     LifecycleArchiveRequest,\n35:     LifecycleRequestBase,\n36: )\n37: from common.events.lifecycle_purge_request import LifecyclePurgeRequest\n38: from common.events.topics import Topics\n39: \n40: logger = logging.getLogger(__name__)\n41: \n42: \n43: class ArchiveStorageAdapter(Protocol):\n44:     \"\"\"Methods the SQL-only lifecycle consumers (archive + purge) need.\"\"\"\n45: \n46:     async def archive_expired(self, *, org_id: str, fleet_id: str | None) -> int: ...\n47: \n48:     async def archive_stale(self, *, org_id: str, fleet_id: str | None) -> int: ...\n49: \n50:     async def purge_soft_deleted(\n51:         self, *, org_id: str, fleet_id: str | None, retention_days: int\n52:     ) -> int: ...\n53: \n54:     async def update_lifecycle_audit_row(\n55:         self,\n56:         audit_id: int,\n57:         *,\n58:         status: str,\n59:         stats: dict | None = None,\n60:         error_message: str | None = None,\n61:     ) -> None: ...\n62: \n63: \n64: class PipelineStorageAdapter(Protocol):\n65:     \"\"\"Methods the LLM-heavy lifecycle consumers (crystallize +\n66:     entity-link) need. Wider than :class:`ArchiveStorageAdapter` —\n67:     adds the dedup gate (``has_recent_lifecycle_success``) plus the\n68:     two pipeline primitives. Both consumers live in core-api because\n69:     they need its pipeline machinery; this protocol exists so the\n70:     handler module stays free of core-api imports.\n71:     \"\"\"\n72: \n73:     async def crystallize(self, *, org_id: str, fleet_id: str | None) -> int: ...\n74: \n75:     async def entity_link(self, *, org_id: str, fleet_id: str | None) -> int: ...\n76: \n77:     async def insights(self, *, org_id: str, fleet_id: str | None) -> int: ...\n78: \n79:     async def has_recent_lifecycle_success(\n80:         self, *, org_id: str, action: str, since_hours: int\n81:     ) -> bool: ...\n82: \n83:     async def update_lifecycle_audit_row(\n84:         self,\n85:         audit_id: int,\n86:         *,\n87:         status: str,\n88:         stats: dict | None = None,\n89:         error_message: str | None = None,\n90:     ) -> None: ...\n91: \n92: \n93: # Back-compat alias so existing core-api/core-worker adapter code that\n94: # imports ``LifecycleStorageAdapter`` keeps type-checking. The shared\n95: # object on both sides actually implements both protocols today; the\n96: # split is at the registration boundary, not the adapter side.\n97: LifecycleStorageAdapter = ArchiveStorageAdapter\n98: \n99: \n100: # Pipeline ops dedup window. Cron fires daily, so 23 hours catches\n101: # \"fired twice within an hour due to a redeploy\" while still letting\n102: # the legitimate next-day tick through.\n103: _PIPELINE_DEDUP_WINDOW_HOURS = 23\n104: \n105: \n106: # Callable parameters are contravariant: an op that accepts a\n107: # ``LifecycleArchiveRequest`` (subclass) is NOT assignable to a\n108: # ``Callable[[LifecycleRequestBase], ...]``. Use ``...`` so the\n109: # registered closures (each with its own subclass-typed argument)\n110: # satisfy the alias without a ``# type: ignore``. ``_run_action``\n111: # never inspects ``run_op``'s parameter type itself — the caller\n112: # always passes the correctly-shaped request — so the looser alias\n113: # carries no runtime risk.\n114: _OpFn = Callable[..., Awaitable[int]]\n115: \n116: \n117: async def _run_action(\n118:     event: Event,\n119:     *,\n120:     adapter: ArchiveStorageAdapter | PipelineStorageAdapter,\n121:     payload_cls: type[LifecycleRequestBase],\n122:     run_op: _OpFn,\n123:     stats_key: str,\n124:     action: str,\n125:     dedup_window_hours: int | None = None,\n126: ) -> None:\n127:     \"\"\"Shared body for every lifecycle action — bound to a specific\n128:     primitive at registration time so this function never branches on\n129:     a string. SQL ops are naturally idempotent so Pub/Sub redelivery\n130:     is safe; each delivery attempt updates the SAME audit row (the\n131:     row id rides in the payload, pre-created by the fanout endpoint).\n132: \n133:     ``dedup_window_hours`` is set for pipeline ops only (CAURA-657):\n134:     if a successful run for the same org+action exists within the\n135:     window, this delivery is a no-op (audit row marked success with\n136:     ``stats.skipped`` so observers can distinguish \"did the work\" from\n137:     \"skipped because already done\"). Filtering on ``finished_at``\n138:     naturally excludes the in-progress row pre-published moments ago.\n139:     \"\"\"\n140:     try:\n141:         request = payload_cls(**event.payload)\n142:     except ValidationError:\n143:         logger.exception(\n144:             \"dropping malformed lifecycle-request payload\",\n145:             extra={\n146:                 \"event_type\": event.event_type,\n147:                 \"event_id\": str(event.event_id),\n148:                 \"dropped\": True,\n149:             },\n150:         )\n151:         return\n152: \n153:     audit_id = request.audit_id\n154:     org_id = request.org_id\n155:     triggered_by = request.triggered_by\n156: \n157:     # Dedup gate (pipeline ops only). Runs BEFORE the in_progress mark\n158:     # so the audit row's life cycle stays clean — pending → success\n159:     # with skipped=true, no in_progress flicker.\n160:     if dedup_window_hours is not None:\n161:         try:\n162:             already_done = await adapter.has_recent_lifecycle_success(  # type: ignore[union-attr]\n163:                 org_id=org_id, action=action, since_hours=dedup_window_hours\n164:             )\n165:         except Exception:\n166:             # Failed dedup check shouldn't block the op — better to run\n167:             # twice than skip a legitimate request because the gate\n168:             # endpoint flaked. Log and proceed.\n169:             logger.warning(\n170:                 \"lifecycle dedup check failed; proceeding without skip\",\n171:                 exc_info=True,\n172:                 extra={\"audit_id\": audit_id, \"action\": action},\n173:             )\n174:             already_done = False\n175:         if already_done:\n176:             # Same best-effort treatment as the in_progress mark\n177:             # below: the skip record is observability data, and a\n178:             # raise here would nack the message into a redeliver\n179:             # loop that re-checks the gate, fails the same write,\n180:             # and eventually DLQs a legitimate skip.\n181:             try:\n182:                 await adapter.update_lifecycle_audit_row(\n183:                     audit_id,\n184:                     status=\"success\",\n185:                     stats={\"skipped\": True, \"reason\": \"recent_success\"},\n186:                 )\n187:             except Exception:\n188:                 logger.warning(\n189:                     \"lifecycle audit skip update failed; acking anyway\",\n190:                     exc_info=True,\n191:                     extra={\"audit_id\": audit_id, \"action\": action},\n192:                 )\n193:             logger.info(\n194:                 \"lifecycle %s skipped — recent successful run exists\",\n195:                 action,\n196:                 extra={\n197:                     \"audit_id\": audit_id,\n198:                     \"org_id\": org_id,\n199:                     \"triggered_by\": triggered_by,\n200:                 },\n201:             )\n202:             return\n203: \n204:     # Best-effort in_progress mark: 404 means the audit row was pruned\n205:     # between fanout and consume. Continue anyway so the primitive\n206:     # still runs — dropping would silently skip an op the operator\n207:     # asked for.\n208:     try:\n209:         await adapter.update_lifecycle_audit_row(audit_id, status=\"in_progress\")\n210:     except Exception:\n211:         logger.warning(\n212:             \"lifecycle audit in_progress update failed; continuing\",\n213:             exc_info=True,\n214:             extra={\"audit_id\": audit_id, \"action\": action},\n215:         )\n216: \n217:     try:\n218:         count = await run_op(request)\n219:     except Exception as exc:\n220:         # Wrap the failure update in its own guard: if it raises, the\n221:         # outer ``raise`` below would never run and the original op\n222:         # exception would be silently replaced by the audit error,\n223:         # leaving the row stuck in ``in_progress`` indistinguishable\n224:         # from a crashed worker.\n225:         try:\n226:             await adapter.update_lifecycle_audit_row(\n227:                 audit_id,\n228:                 status=\"failure\",\n229:                 error_message=str(exc)[:500],\n230:             )\n231:         except Exception:\n232:             logger.warning(\n233:                 \"lifecycle audit failure update failed; row stuck in_progress\",\n234:                 exc_info=True,\n235:                 extra={\"audit_id\": audit_id, \"action\": action},\n236:             )\n237:         # Re-raise so the bus nacks → Pub/Sub redelivers (subject to\n238:         # max-delivery-attempts → DLQ). The ``failure`` row above is\n239:         # the durable record (when the update succeeded).\n240:         raise\n241: \n242:     await adapter.update_lifecycle_audit_row(\n243:         audit_id,\n244:         status=\"success\",\n245:         stats={stats_key: count},\n246:     )\n247: \n248:     logger.info(\n249:         \"lifecycle %s processed\",\n250:         action,\n251:         extra={\n252:             \"audit_id\": audit_id,\n253:             \"org_id\": org_id,\n254:             \"triggered_by\": triggered_by,\n255:             stats_key: count,\n256:         },\n257:     )\n258: \n259: \n260: def register_archive_consumers(adapter: ArchiveStorageAdapter) -> None:\n\n(Showing lines 1-260 of 378. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"Consumers for ``memclaw.lifecycle.<action>-requested`` topics\n(CAURA-655 archive ops, CAURA-656 purge, CAURA-657 pipeline ops).\n\nLives in ``common/`` rather than under either service so the same code\nruns in both deployments. Two registration entry points reflect the\nsplit between SQL-only and pipeline-machinery ops:\n\n* :func:`register_archive_consumers` — archive + purge ops. Subscriber\n  is core-worker on SaaS; in OSS standalone core-api also subscribes\n  (no separate worker process).\n* :func:`register_pipeline_consumers` — crystallize + entity-link.\n  Subscriber is ALWAYS core-api because the consumer needs core-api's\n  pipeline machinery (run_crystallization, build_full_entity_linking_pipeline).\n\nThe handler delegates the storage round-trips it needs (run the\nprimitive, finalise the audit row, optionally check the dedup gate)\nto a small adapter the host service supplies. Per-action ops bind\ntheir own primitive callable + payload class at registration time so\nthe dispatch never branches on a string.\n\"\"\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py","text":"\"\"\"Consumers for ``memclaw.lifecycle.<action>-requested`` topics\n(CAURA-655 archive ops, CAURA-656 purge, CAURA-657 pipeline ops).\n\nLives in ``common/`` rather than under either service so the same code\nruns in both deployments. Two registration entry points reflect the\nsplit between SQL-only and pipeline-machinery ops:\n\n* :func:`register_archive_consumers` — archive + purge ops. Subscriber\n  is core-worker on SaaS; in OSS standalone core-api also subscribes\n  (no separate worker process).\n* :func:`register_pipeline_consumers` — crystallize + entity-link.\n  Subscriber is ALWAYS core-api because the consumer needs core-api's\n  pipeline machinery (run_crystallization, build_full_entity_linking_pipeline).\n\nThe handler delegates the storage round-trips it needs (run the\nprimitive, finalise the audit row, optionally check the dedup gate)\nto a small adapter the host service supplies. Per-action ops bind\ntheir own primitive callable + payload class at registration time so\nthe dispatch never branches on a string.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections.abc import Awaitable, Callable\nfrom functools import partial\nfrom typing import Protocol\n\nfrom pydantic import ValidationError\n\nfrom common.events.base import Event\nfrom common.events.factory import get_event_bus\nfrom common.events.lifecycle_archive_request import (\n    LifecycleArchiveRequest,\n    LifecycleRequestBase,\n)\nfrom common.events.lifecycle_purge_request import LifecyclePurgeRequest\nfrom common.events.topics import Topics\n\nlogger = logging.getLogger(__name__)\n\n\nclass ArchiveStorageAdapter(Protocol):\n    \"\"\"Methods the SQL-only lifecycle consumers (archive + purge) need.\"\"\"\n\n    async def archive_expired(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def archive_stale(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def purge_soft_deleted(\n        self, *, org_id: str, fleet_id: str | None, retention_days: int\n    ) -> int: ...\n\n    async def update_lifecycle_audit_row(\n        self,\n        audit_id: int,\n        *,\n        status: str,\n        stats: dict | None = None,\n        error_message: str | None = None,\n    ) -> None: ...\n\n\nclass PipelineStorageAdapter(Protocol):\n    \"\"\"Methods the LLM-heavy lifecycle consumers (crystallize +\n    entity-link) need. Wider than :class:`ArchiveStorageAdapter` —\n    adds the dedup gate (``has_recent_lifecycle_success``) plus the\n    two pipeline primitives. Both consumers live in core-api because\n    they need its pipeline machinery; this protocol exists so the\n    handler module stays free of core-api imports.\n    \"\"\"\n\n    async def crystallize(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def entity_link(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def insights(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def has_recent_lifecycle_success(\n        self, *, org_id: str, action: str, since_hours: int\n    ) -> bool: ...\n\n    async def update_lifecycle_audit_row(\n        self,\n        audit_id: int,\n        *,\n        status: str,\n        stats: dict | None = None,\n        error_message: str | None = None,\n    ) -> None: ...\n\n\n# Back-compat alias so existing core-api/core-worker adapter code that\n# imports ``LifecycleStorageAdapter`` keeps type-checking. The shared\n# object on both sides actually implements both protocols today; the\n# split is at the registration boundary, not the adapter side.\nLifecycleStorageAdapter = ArchiveStorageAdapter\n\n\n# Pipeline ops dedup window. Cron fires daily, so 23 hours catches\n# \"fired twice within an hour due to a redeploy\" while still letting\n# the legitimate next-day tick through.\n_PIPELINE_DEDUP_WINDOW_HOURS = 23\n\n\n# Callable parameters are contravariant: an op that accepts a\n# ``LifecycleArchiveRequest`` (subclass) is NOT assignable to a\n# ``Callable[[LifecycleRequestBase], ...]``. Use ``...`` so the\n# registered closures (each with its own subclass-typed argument)\n# satisfy the alias without a ``# type: ignore``. ``_run_action``\n# never inspects ``run_op``'s parameter type itself — the caller\n# always passes the correctly-shaped request — so the looser alias\n# carries no runtime risk.\n_OpFn = Callable[..., Awaitable[int]]\n\n\nasync def _run_action(\n    event: Event,\n    *,\n    adapter: ArchiveStorageAdapter | PipelineStorageAdapter,\n    payload_cls: type[LifecycleRequestBase],\n    run_op: _OpFn,\n    stats_key: str,\n    action: str,\n    dedup_window_hours: int | None = None,\n) -> None:\n    \"\"\"Shared body for every lifecycle action — bound to a specific\n    primitive at registration time so this function never branches on\n    a string. SQL ops are naturally idempotent so Pub/Sub redelivery\n    is safe; each delivery attempt updates the SAME audit row (the\n    row id rides in the payload, pre-created by the fanout endpoint).\n\n    ``dedup_window_hours`` is set for pipeline ops only (CAURA-657):\n    if a successful run for the same org+action exists within the\n    window, this delivery is a no-op (audit row marked success with\n    ``stats.skipped`` so observers can distinguish \"did the work\" from\n    \"skipped because already done\"). Filtering on ``finished_at``\n    naturally excludes the in-progress row pre-published moments ago.\n    \"\"\"\n    try:\n        request = payload_cls(**event.payload)\n    except ValidationError:\n        logger.exception(\n            \"dropping malformed lifecycle-request payload\",\n            extra={\n                \"event_type\": event.event_type,\n                \"event_id\": str(event.event_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    audit_id = request.audit_id\n    org_id = request.org_id\n    triggered_by = request.triggered_by\n\n    # Dedup gate (pipeline ops only). Runs BEFORE the in_progress mark\n    # so the audit row's life cycle stays clean — pending → success\n    # with skipped=true, no in_progress flicker.\n    if dedup_window_hours is not None:\n        try:\n            already_done = await adapter.has_recent_lifecycle_success(  # type: ignore[union-attr]\n                org_id=org_id, action=action, since_hours=dedup_window_hours\n            )\n        except Exception:\n            # Failed dedup check shouldn't block the op — better to run\n            # twice than skip a legitimate request because the gate\n            # endpoint flaked. Log and proceed.\n            logger.warning(\n                \"lifecycle dedup check failed; proceeding without skip\",\n                exc_info=True,\n                extra={\"audit_id\": audit_id, \"action\": action},\n            )\n            already_done = False\n        if already_done:\n            # Same best-effort treatment as the in_progress mark\n            # below: the skip record is observability data, and a\n            # raise here would nack the message into a redeliver\n            # loop that re-checks the gate, fails the same write,\n            # and eventually DLQs a legitimate skip.\n            try:\n                await adapter.update_lifecycle_audit_row(\n                    audit_id,\n                    status=\"success\",\n                    stats={\"skipped\": True, \"reason\": \"recent_success\"},\n                )\n            except Exception:\n                logger.warning(\n                    \"lifecycle audit skip update failed; acking anyway\",\n                    exc_info=True,\n                    extra={\"audit_id\": audit_id, \"action\": action},\n                )\n            logger.info(\n                \"lifecycle %s skipped — recent successful run exists\",\n                action,\n                extra={\n                    \"audit_id\": audit_id,\n                    \"org_id\": org_id,\n                    \"triggered_by\": triggered_by,\n                },\n            )\n            return\n\n    # Best-effort in_progress mark: 404 means the audit row was pruned\n    # between fanout and consume. Continue anyway so the primitive\n    # still runs — dropping would silently skip an op the operator\n    # asked for.\n    try:\n        await adapter.update_lifecycle_audit_row(audit_id, status=\"in_progress\")\n    except Exception:\n        logger.warning(\n            \"lifecycle audit in_progress update failed; continuing\",\n            exc_info=True,\n            extra={\"audit_id\": audit_id, \"action\": action},\n        )\n\n    try:\n        count = await run_op(request)\n    except Exception as exc:\n        # Wrap the failure update in its own guard: if it raises, the\n        # outer ``raise`` below would never run and the original op\n        # exception would be silently replaced by the audit error,\n        # leaving the row stuck in ``in_progress`` indistinguishable\n        # from a crashed worker.\n        try:\n            await adapter.update_lifecycle_audit_row(\n                audit_id,\n                status=\"failure\",\n                error_message=str(exc)[:500],\n            )\n        except Exception:\n            logger.warning(\n                \"lifecycle audit failure update failed; row stuck in_progress\",\n                exc_info=True,\n                extra={\"audit_id\": audit_id, \"action\": action},\n            )\n        # Re-raise so the bus nacks → Pub/Sub redelivers (subject to\n        # max-delivery-attempts → DLQ). The ``failure`` row above is\n        # the durable record (when the update succeeded).\n        raise\n\n    await adapter.update_lifecycle_audit_row(\n        audit_id,\n        status=\"success\",\n        stats={stats_key: count},\n    )\n\n    logger.info(\n        \"lifecycle %s processed\",\n        action,\n        extra={\n            \"audit_id\": audit_id,\n            \"org_id\": org_id,\n            \"triggered_by\": triggered_by,\n            stats_key: count,\n        },\n    )\n\n\ndef register_archive_consumers(adapter: ArchiveStorageAdapter) -> None:","lineStart":1,"lineEnd":260,"totalLines":378,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py","time":{"start":1780729336714,"end":1780729336717}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872b88191a6c9c5c58977147e"}},"id":"prt_e9bbd5352001o4XZ7yGK6nk7p8","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336753,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_OXa7eTNO05YGYgk6MTXdNwOc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/schema.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/schema.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Enrichment Pydantic schemas — moved from\n2: ``core_api.services.memory_enrichment`` (CAURA-595).\n3: \n4: * :class:`AtomicFact` — one self-contained claim broken out of multi-fact\n5:   content.\n6: * :class:`EnrichmentResult` — the full validated enrichment payload the\n7:   service returns. Fields mirror the JSON the LLM is prompted to\n8:   produce in :data:`common.enrichment._prompts.ENRICHMENT_PROMPT`.\n9: \n10: Renamed from the legacy ``MemoryEnrichment`` class (kept as a re-export\n11: in ``core_api.services.memory_enrichment``) so that the type's role in\n12: the new event-bus payloads is unambiguous: it's the *result* of\n13: enrichment, distinct from the ``MemoryEnrichRequest`` event payload.\n14: \"\"\"\n15: \n16: from __future__ import annotations\n17: \n18: import re\n19: \n20: from pydantic import BaseModel, field_validator\n21: \n22: from common.enrichment.constants import MemoryType\n23: \n24: \n25: # A8 — number of tags retained after normalisation. Mirrors the cap\n26: # the prompt asks the LLM to respect; the validator enforces it\n27: # regardless of LLM output.\n28: _TAGS_MAX = 5\n29: \n30: # Multi-character whitespace / underscore runs collapse to a single\n31: # hyphen so ``code review`` / ``code  review`` / ``code_review`` /\n32: # ``code__review`` all normalise to ``code-review``.\n33: _TAG_SEPARATOR_RE = re.compile(r\"[\\s_]+\")\n34: \n35: \n36: def _normalize_tag(raw: object) -> str:\n37:     \"\"\"Apply the A8 tag normalisation: coerce-to-str, lowercase,\n38:     collapse internal whitespace / underscores to a single hyphen,\n39:     strip leading/trailing hyphens. Returns the normalised tag, or\n40:     the empty string if nothing remains (caller drops empties).\"\"\"\n41:     if raw is None:\n42:         return \"\"\n43:     s = str(raw).strip().lower()\n44:     if not s:\n45:         return \"\"\n46:     s = _TAG_SEPARATOR_RE.sub(\"-\", s)\n47:     return s.strip(\"-\")\n48: \n49: \n50: class AtomicFact(BaseModel):\n51:     \"\"\"One atomic fact extracted from a multi-fact turn.\n52: \n53:     Populated by the enricher when a single piece of content carries 2+\n54:     distinct claims that would each be searched by different queries.\n55:     Each fact becomes its own child memory with its own embedding,\n56:     title-less but hint-enriched.\n57:     \"\"\"\n58: \n59:     content: str\n60:     suggested_type: MemoryType = MemoryType.FACT\n61:     retrieval_hint: str = \"\"\n62: \n63: \n64: class EnrichmentResult(BaseModel):\n65:     \"\"\"Validated LLM enrichment output.\n66: \n67:     Mirrors the JSON schema in :data:`ENRICHMENT_PROMPT` field-for-field.\n68:     ``llm_ms`` is filled in by the service after the LLM call returns;\n69:     everything else is populated from the LLM's JSON response (with\n70:     defaults for the heuristic fallback path).\n71:     \"\"\"\n72: \n73:     memory_type: MemoryType = MemoryType.FACT\n74:     weight: float = 0.7\n75:     title: str = \"\"\n76:     summary: str = \"\"\n77:     tags: list[str] = []\n78:     status: str = \"active\"\n79: \n80:     @field_validator(\"tags\", mode=\"before\")\n81:     @classmethod\n82:     def _normalize_tags(cls, raw):\n83:         \"\"\"A8 — defensive normalisation against LLM drift.\n84: \n85:         Lowercases, collapses whitespace / underscores to hyphens,\n86:         dedupes (preserves first-seen order), drops empties, caps at\n87:         ``_TAGS_MAX`` (5). Runs even when the LLM ignored the prompt's\n88:         format guidance, so downstream tag-joins see stable keys.\n89:         \"\"\"\n90:         if not isinstance(raw, list):\n91:             return []\n92:         seen: set[str] = set()\n93:         normalised: list[str] = []\n94:         for item in raw:\n95:             tag = _normalize_tag(item)\n96:             if not tag or tag in seen:\n97:                 continue\n98:             seen.add(tag)\n99:             normalised.append(tag)\n100:             if len(normalised) >= _TAGS_MAX:\n101:                 break\n102:         return normalised\n103: \n104:     ts_valid_start: str | None = None\n105:     ts_valid_end: str | None = None\n106:     contains_pii: bool = False\n107:     pii_types: list[str] = []\n108:     retrieval_hint: str = \"\"\n109:     atomic_facts: list[AtomicFact] | None = None\n110:     llm_ms: int = 0\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"\"\"\"Enrichment Pydantic schemas — moved from\n``core_api.services.memory_enrichment`` (CAURA-595).\n\n* :class:`AtomicFact` — one self-contained claim broken out of multi-fact\n  content.\n* :class:`EnrichmentResult` — the full validated enrichment payload the\n  service returns. Fields mirror the JSON the LLM is prompted to\n  produce in :data:`common.enrichment._prompts.ENRICHMENT_PROMPT`.\n\nRenamed from the legacy ``MemoryEnrichment`` class (kept as a re-export\nin ``core_api.services.memory_enrichment``) so that the type's role in\nthe new event-bus payloads is unambiguous: it's the *result* of\nenrichment, distinct from the ``MemoryEnrichRequest`` event payload.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\n\nfrom pydantic import BaseModel, field_validator","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/schema.py","text":"\"\"\"Enrichment Pydantic schemas — moved from\n``core_api.services.memory_enrichment`` (CAURA-595).\n\n* :class:`AtomicFact` — one self-contained claim broken out of multi-fact\n  content.\n* :class:`EnrichmentResult` — the full validated enrichment payload the\n  service returns. Fields mirror the JSON the LLM is prompted to\n  produce in :data:`common.enrichment._prompts.ENRICHMENT_PROMPT`.\n\nRenamed from the legacy ``MemoryEnrichment`` class (kept as a re-export\nin ``core_api.services.memory_enrichment``) so that the type's role in\nthe new event-bus payloads is unambiguous: it's the *result* of\nenrichment, distinct from the ``MemoryEnrichRequest`` event payload.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\n\nfrom pydantic import BaseModel, field_validator\n\nfrom common.enrichment.constants import MemoryType\n\n\n# A8 — number of tags retained after normalisation. Mirrors the cap\n# the prompt asks the LLM to respect; the validator enforces it\n# regardless of LLM output.\n_TAGS_MAX = 5\n\n# Multi-character whitespace / underscore runs collapse to a single\n# hyphen so ``code review`` / ``code  review`` / ``code_review`` /\n# ``code__review`` all normalise to ``code-review``.\n_TAG_SEPARATOR_RE = re.compile(r\"[\\s_]+\")\n\n\ndef _normalize_tag(raw: object) -> str:\n    \"\"\"Apply the A8 tag normalisation: coerce-to-str, lowercase,\n    collapse internal whitespace / underscores to a single hyphen,\n    strip leading/trailing hyphens. Returns the normalised tag, or\n    the empty string if nothing remains (caller drops empties).\"\"\"\n    if raw is None:\n        return \"\"\n    s = str(raw).strip().lower()\n    if not s:\n        return \"\"\n    s = _TAG_SEPARATOR_RE.sub(\"-\", s)\n    return s.strip(\"-\")\n\n\nclass AtomicFact(BaseModel):\n    \"\"\"One atomic fact extracted from a multi-fact turn.\n\n    Populated by the enricher when a single piece of content carries 2+\n    distinct claims that would each be searched by different queries.\n    Each fact becomes its own child memory with its own embedding,\n    title-less but hint-enriched.\n    \"\"\"\n\n    content: str\n    suggested_type: MemoryType = MemoryType.FACT\n    retrieval_hint: str = \"\"\n\n\nclass EnrichmentResult(BaseModel):\n    \"\"\"Validated LLM enrichment output.\n\n    Mirrors the JSON schema in :data:`ENRICHMENT_PROMPT` field-for-field.\n    ``llm_ms`` is filled in by the service after the LLM call returns;\n    everything else is populated from the LLM's JSON response (with\n    defaults for the heuristic fallback path).\n    \"\"\"\n\n    memory_type: MemoryType = MemoryType.FACT\n    weight: float = 0.7\n    title: str = \"\"\n    summary: str = \"\"\n    tags: list[str] = []\n    status: str = \"active\"\n\n    @field_validator(\"tags\", mode=\"before\")\n    @classmethod\n    def _normalize_tags(cls, raw):\n        \"\"\"A8 — defensive normalisation against LLM drift.\n\n        Lowercases, collapses whitespace / underscores to hyphens,\n        dedupes (preserves first-seen order), drops empties, caps at\n        ``_TAGS_MAX`` (5). Runs even when the LLM ignored the prompt's\n        format guidance, so downstream tag-joins see stable keys.\n        \"\"\"\n        if not isinstance(raw, list):\n            return []\n        seen: set[str] = set()\n        normalised: list[str] = []\n        for item in raw:\n            tag = _normalize_tag(item)\n            if not tag or tag in seen:\n                continue\n            seen.add(tag)\n            normalised.append(tag)\n            if len(normalised) >= _TAGS_MAX:\n                break\n        return normalised\n\n    ts_valid_start: str | None = None\n    ts_valid_end: str | None = None\n    contains_pii: bool = False\n    pii_types: list[str] = []\n    retrieval_hint: str = \"\"\n    atomic_facts: list[AtomicFact] | None = None\n    llm_ms: int = 0","lineStart":1,"lineEnd":110,"totalLines":110,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/schema.py","time":{"start":1780729336735,"end":1780729336752}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872c08191806931681178fff8"}},"id":"prt_e9bbd5396001p27CZdjE834LST","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336786,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_cr0RU0TCKEZxaxTDNkqbwdoa","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/audit.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/audit.py</path>\n<type>file</type>\n<content>\n1: import uuid\n2: from datetime import datetime\n3: \n4: from sqlalchemy import DateTime, Text, text\n5: from sqlalchemy.dialects.postgresql import JSONB\n6: from sqlalchemy.orm import Mapped, mapped_column\n7: \n8: from common.models.base import Base\n9: \n10: \n11: class AuditLog(Base):\n12:     __tablename__ = \"audit_log\"\n13: \n14:     id: Mapped[uuid.UUID] = mapped_column(\n15:         primary_key=True, server_default=text(\"gen_random_uuid()\")\n16:     )\n17:     tenant_id: Mapped[str] = mapped_column(Text, nullable=False)\n18:     agent_id: Mapped[str | None] = mapped_column(Text)\n19:     action: Mapped[str] = mapped_column(Text, nullable=False)\n20:     resource_type: Mapped[str] = mapped_column(Text, nullable=False)\n21:     resource_id: Mapped[uuid.UUID | None] = mapped_column()\n22:     detail: Mapped[dict | None] = mapped_column(JSONB)\n23:     created_at: Mapped[datetime] = mapped_column(\n24:         DateTime(timezone=True), server_default=text(\"now()\")\n25:     )\n\n(End of file - total 25 lines)\n</content>","metadata":{"preview":"import uuid\nfrom datetime import datetime\n\nfrom sqlalchemy import DateTime, Text, text\nfrom sqlalchemy.dialects.postgresql import JSONB\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.models.base import Base\n\n\nclass AuditLog(Base):\n    __tablename__ = \"audit_log\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False)\n    agent_id: Mapped[str | None] = mapped_column(Text)\n    action: Mapped[str] = mapped_column(Text, nullable=False)\n    resource_type: Mapped[str] = mapped_column(Text, nullable=False)","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/audit.py","text":"import uuid\nfrom datetime import datetime\n\nfrom sqlalchemy import DateTime, Text, text\nfrom sqlalchemy.dialects.postgresql import JSONB\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.models.base import Base\n\n\nclass AuditLog(Base):\n    __tablename__ = \"audit_log\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False)\n    agent_id: Mapped[str | None] = mapped_column(Text)\n    action: Mapped[str] = mapped_column(Text, nullable=False)\n    resource_type: Mapped[str] = mapped_column(Text, nullable=False)\n    resource_id: Mapped[uuid.UUID | None] = mapped_column()\n    detail: Mapped[dict | None] = mapped_column(JSONB)\n    created_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), server_default=text(\"now()\")\n    )","lineStart":1,"lineEnd":25,"totalLines":25,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/audit.py","time":{"start":1780729336778,"end":1780729336783}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872d88191b386772e07433dc0"}},"id":"prt_e9bbd53c9001Tn0pkI4MQ6VOms","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336786,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_2qaZTDTOMRfLc1ALeDplIkU4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/entity.py","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/entity.py</path>\n<type>file</type>\n<content>\n1: import uuid\n2: \n3: from pgvector.sqlalchemy import Vector\n4: from sqlalchemy import Float, ForeignKey, Index, Text, text\n5: from sqlalchemy.dialects.postgresql import JSONB, TSVECTOR\n6: from sqlalchemy.orm import Mapped, mapped_column\n7: \n8: from common.constants import VECTOR_DIM\n9: from common.models.base import Base\n10: \n11: \n12: class Entity(Base):\n13:     __tablename__ = \"entities\"\n14: \n15:     id: Mapped[uuid.UUID] = mapped_column(\n16:         primary_key=True, server_default=text(\"gen_random_uuid()\")\n17:     )\n18:     tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n19:     fleet_id: Mapped[str | None] = mapped_column(Text)\n20:     entity_type: Mapped[str] = mapped_column(Text, nullable=False)\n21:     canonical_name: Mapped[str] = mapped_column(Text, nullable=False)\n22:     attributes: Mapped[dict | None] = mapped_column(JSONB)\n23:     name_embedding = mapped_column(Vector(VECTOR_DIM))\n24:     search_vector = mapped_column(TSVECTOR)\n25: \n26: \n27: class Relation(Base):\n28:     __tablename__ = \"relations\"\n29: \n30:     id: Mapped[uuid.UUID] = mapped_column(\n31:         primary_key=True, server_default=text(\"gen_random_uuid()\")\n32:     )\n33:     tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n34:     fleet_id: Mapped[str | None] = mapped_column(Text)\n35:     from_entity_id: Mapped[uuid.UUID] = mapped_column(\n36:         ForeignKey(\"entities.id\", ondelete=\"CASCADE\"), nullable=False\n37:     )\n38:     relation_type: Mapped[str] = mapped_column(Text, nullable=False)\n39:     to_entity_id: Mapped[uuid.UUID] = mapped_column(\n40:         ForeignKey(\"entities.id\", ondelete=\"CASCADE\"), nullable=False\n41:     )\n42:     weight: Mapped[float] = mapped_column(Float, server_default=text(\"1.0\"))\n43:     evidence_memory_id: Mapped[uuid.UUID | None] = mapped_column(\n44:         ForeignKey(\"memories.id\", ondelete=\"SET NULL\")\n45:     )\n46: \n47:     __table_args__ = (\n48:         Index(\"ix_relations_from\", \"from_entity_id\"),\n49:         Index(\"ix_relations_to\", \"to_entity_id\"),\n50:     )\n51: \n52: \n53: class MemoryEntityLink(Base):\n54:     __tablename__ = \"memory_entity_links\"\n55: \n56:     memory_id: Mapped[uuid.UUID] = mapped_column(\n57:         ForeignKey(\"memories.id\", ondelete=\"CASCADE\"), primary_key=True\n58:     )\n59:     entity_id: Mapped[uuid.UUID] = mapped_column(\n60:         ForeignKey(\"entities.id\", ondelete=\"CASCADE\"), primary_key=True\n61:     )\n62:     role: Mapped[str] = mapped_column(Text, nullable=False)\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"import uuid\n\nfrom pgvector.sqlalchemy import Vector\nfrom sqlalchemy import Float, ForeignKey, Index, Text, text\nfrom sqlalchemy.dialects.postgresql import JSONB, TSVECTOR\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.constants import VECTOR_DIM\nfrom common.models.base import Base\n\n\nclass Entity(Base):\n    __tablename__ = \"entities\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)\n    entity_type: Mapped[str] = mapped_column(Text, nullable=False)","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/entity.py","text":"import uuid\n\nfrom pgvector.sqlalchemy import Vector\nfrom sqlalchemy import Float, ForeignKey, Index, Text, text\nfrom sqlalchemy.dialects.postgresql import JSONB, TSVECTOR\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.constants import VECTOR_DIM\nfrom common.models.base import Base\n\n\nclass Entity(Base):\n    __tablename__ = \"entities\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)\n    entity_type: Mapped[str] = mapped_column(Text, nullable=False)\n    canonical_name: Mapped[str] = mapped_column(Text, nullable=False)\n    attributes: Mapped[dict | None] = mapped_column(JSONB)\n    name_embedding = mapped_column(Vector(VECTOR_DIM))\n    search_vector = mapped_column(TSVECTOR)\n\n\nclass Relation(Base):\n    __tablename__ = \"relations\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)\n    from_entity_id: Mapped[uuid.UUID] = mapped_column(\n        ForeignKey(\"entities.id\", ondelete=\"CASCADE\"), nullable=False\n    )\n    relation_type: Mapped[str] = mapped_column(Text, nullable=False)\n    to_entity_id: Mapped[uuid.UUID] = mapped_column(\n        ForeignKey(\"entities.id\", ondelete=\"CASCADE\"), nullable=False\n    )\n    weight: Mapped[float] = mapped_column(Float, server_default=text(\"1.0\"))\n    evidence_memory_id: Mapped[uuid.UUID | None] = mapped_column(\n        ForeignKey(\"memories.id\", ondelete=\"SET NULL\")\n    )\n\n    __table_args__ = (\n        Index(\"ix_relations_from\", \"from_entity_id\"),\n        Index(\"ix_relations_to\", \"to_entity_id\"),\n    )\n\n\nclass MemoryEntityLink(Base):\n    __tablename__ = \"memory_entity_links\"\n\n    memory_id: Mapped[uuid.UUID] = mapped_column(\n        ForeignKey(\"memories.id\", ondelete=\"CASCADE\"), primary_key=True\n    )\n    entity_id: Mapped[uuid.UUID] = mapped_column(\n        ForeignKey(\"entities.id\", ondelete=\"CASCADE\"), primary_key=True\n    )\n    role: Mapped[str] = mapped_column(Text, nullable=False)","lineStart":1,"lineEnd":62,"totalLines":62,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/entity.py","time":{"start":1780729336774,"end":1780729336785}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872c8819187b677982d4cf10a"}},"id":"prt_e9bbd53a1001CMjmyrqmZwZa1I","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336787,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_q5V9PFbNedKtbm8ZWm3H8MPJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","offset":230,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md</path>\n<type>file</type>\n<content>\n230: \n231: ```bash\n232: # Point at whichever URL hosts your MemClaw API\n233: export MEMCLAW_URL=https://memclaw.net          # managed\n234: # or:  export MEMCLAW_URL=http://localhost:8000  # self-hosted\n235: export MEMCLAW_KEY=your-key                      # `standalone` works in self-hosted standalone mode\n236: export MEMCLAW_FLEET=my-fleet\n237: \n238: curl -sf -H \"X-API-Key: $MEMCLAW_KEY\" \\\n239:   \"$MEMCLAW_URL/api/v1/install-plugin?fleet_id=$MEMCLAW_FLEET&api_url=$MEMCLAW_URL\" | bash\n240: \n241: # Restart the gateway to load the plugin\n242: openclaw gateway restart\n243: ```\n244: \n245: The plugin claims the OpenClaw `memory` slot (replacing `memory-core`) and exposes the same 12 MCP tools. Full setup, agent prompts, and trust levels: [static/docs/integration-guide.md](static/docs/integration-guide.md).\n246: \n247: ---\n248: \n249: ## Features\n250: \n251: ### Governance\n252: \n253: - **Tenant isolation** — row-level database separation per tenant; PII auto-detected and quarantined before it can cross fleet boundaries\n254: - **Visibility scopes** — every memory is stamped at write time: `scope_agent` (private), `scope_team` (fleet-wide, default), or `scope_org` (cross-fleet). Cross-fleet recall is permissioned, not open\n255: - **Agent trust tiers** — four levels control cross-fleet reads, writes, and deletes. Agents are either provisioned atomically via `POST /admin/agent-keys/provision` (recommended — mints key + row + trust + fleet in one call) or auto-registered on first write (legacy fallback)\n256: - **Full audit log** — every write, delete, and transition logged with tenant and scope context\n257: \n258: ### Memory Pipeline\n259: \n260: - **Single-pass LLM enrichment** — every write auto-classifies into one of 14 memory types, generates title/summary/tags, scores importance, flags PII, and extracts entities — from a single `content` field\n261: - **Hybrid search** — pgvector semantic similarity + full-text keyword matching + knowledge graph expansion (up to 2 hops), ranked by composite score of similarity, importance, freshness, and graph boost\n262: - **Live knowledge graph** — people, orgs, locations, and concepts extracted into entities and relations on every write. Semantic entity resolution (>0.85 cosine) auto-merges duplicates\n263: - **Contradiction detection** — RDF triple comparison + LLM semantic analysis detects conflicting memories and automatically supersedes them, with full contradiction chain tracking\n264: \n265: ### Self-Improving Memory\n266: \n267: - **Outcome-based learning (Karpathy Loop)** — agents report success/failure after acting on recalled memories; the system reinforces what works and auto-generates preventive `rule`-type memories on failure\n268: - **Crystallization** — LLM merges near-duplicate memories into canonical atomic facts with full provenance; 8-status lifecycle automation retires stale data\n269: - **Per-agent retrieval tuning** — each agent optimizes its own retrieval profile (top_k, min_similarity, graph_max_hops, blend weights) from feedback, so search quality compounds with every interaction\n270: \n271: ### Integrations\n272: \n273: - **MCP server** — built-in [Model Context Protocol](https://modelcontextprotocol.io) at `/mcp` (Streamable HTTP). Connect Claude Desktop, Claude Code, Cursor, Windsurf, or any MCP client with a URL and API key\n274: - **Multi-provider LLM** — primary + fallback provider chain per tenant (OpenAI, Gemini, Anthropic, OpenRouter) with platform defaults for zero-config tenants\n275: - **Document store** — structured JSONB collections alongside semantic memories for exact-field lookups (customer records, config, task lists)\n276: \n277: ---\n278: \n279: ## Performance\n280: \n281: Benchmarked against the two most-cited public agent-memory benchmarks. Methodology and operator-scale context live in [`docs/performance.md`](docs/performance.md); the full write-up is on the blog.\n282: \n283: |  | LoCoMo | LongMemEval | Search latency |\n284: |---|---|---|---|\n285: | Accuracy (LLM-judge) | **77.6%** | **72.5%** | — |\n286: | Token savings vs full context | **96.6%** | **98.2%** | — |\n287: | Latency | — | — | **23 ms p50 · 27 ms p95** |\n288: \n289: Accuracy sits inside the leading cluster across the field (Mem0, Zep, MemClaw — scores cluster in a narrow band). The axes we push hardest are latency and token efficiency, because those are the ones that compound as agent count grows — a few hundred ms of search latency disappears behind one LLM call, but bills millions of times a day across a fleet.\n290: \n291: > Single-agent benchmarks can't measure cross-agent recall, outcome propagation between agents, fleet-scoped visibility, or governance-aware retrieval. Those are the questions that decide whether a memory system is *deployable* inside a company. See [`docs/performance.md`](docs/performance.md#what-these-benchmarks-cant-measure).\n292: \n293: Source: [Fast, Token-Efficient, and Built for Fleets](https://memclaw.net/blog/memclaw-benchmarks) (2026-04-19).\n294: \n295: ---\n296: \n297: ## MCP (Model Context Protocol)\n298: \n299: Add MemClaw to any MCP client with one config block.\n300: \n301: **Self-hosted** (localhost):\n302: \n303: ```json\n304: {\n305:   \"mcpServers\": {\n306:     \"memclaw\": {\n307:       \"url\": \"http://localhost:8000/mcp\",\n308:       \"headers\": { \"X-API-Key\": \"standalone\" }\n309:     }\n\n(Showing lines 230-309 of 965. Use offset=310 to continue.)\n</content>","metadata":{"preview":"\n```bash\n# Point at whichever URL hosts your MemClaw API\nexport MEMCLAW_URL=https://memclaw.net          # managed\n# or:  export MEMCLAW_URL=http://localhost:8000  # self-hosted\nexport MEMCLAW_KEY=your-key                      # `standalone` works in self-hosted standalone mode\nexport MEMCLAW_FLEET=my-fleet\n\ncurl -sf -H \"X-API-Key: $MEMCLAW_KEY\" \\\n  \"$MEMCLAW_URL/api/v1/install-plugin?fleet_id=$MEMCLAW_FLEET&api_url=$MEMCLAW_URL\" | bash\n\n# Restart the gateway to load the plugin\nopenclaw gateway restart\n```\n\nThe plugin claims the OpenClaw `memory` slot (replacing `memory-core`) and exposes the same 12 MCP tools. Full setup, agent prompts, and trust levels: [static/docs/integration-guide.md](static/docs/integration-guide.md).\n\n---\n\n## Features","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","text":"\n```bash\n# Point at whichever URL hosts your MemClaw API\nexport MEMCLAW_URL=https://memclaw.net          # managed\n# or:  export MEMCLAW_URL=http://localhost:8000  # self-hosted\nexport MEMCLAW_KEY=your-key                      # `standalone` works in self-hosted standalone mode\nexport MEMCLAW_FLEET=my-fleet\n\ncurl -sf -H \"X-API-Key: $MEMCLAW_KEY\" \\\n  \"$MEMCLAW_URL/api/v1/install-plugin?fleet_id=$MEMCLAW_FLEET&api_url=$MEMCLAW_URL\" | bash\n\n# Restart the gateway to load the plugin\nopenclaw gateway restart\n```\n\nThe plugin claims the OpenClaw `memory` slot (replacing `memory-core`) and exposes the same 12 MCP tools. Full setup, agent prompts, and trust levels: [static/docs/integration-guide.md](static/docs/integration-guide.md).\n\n---\n\n## Features\n\n### Governance\n\n- **Tenant isolation** — row-level database separation per tenant; PII auto-detected and quarantined before it can cross fleet boundaries\n- **Visibility scopes** — every memory is stamped at write time: `scope_agent` (private), `scope_team` (fleet-wide, default), or `scope_org` (cross-fleet). Cross-fleet recall is permissioned, not open\n- **Agent trust tiers** — four levels control cross-fleet reads, writes, and deletes. Agents are either provisioned atomically via `POST /admin/agent-keys/provision` (recommended — mints key + row + trust + fleet in one call) or auto-registered on first write (legacy fallback)\n- **Full audit log** — every write, delete, and transition logged with tenant and scope context\n\n### Memory Pipeline\n\n- **Single-pass LLM enrichment** — every write auto-classifies into one of 14 memory types, generates title/summary/tags, scores importance, flags PII, and extracts entities — from a single `content` field\n- **Hybrid search** — pgvector semantic similarity + full-text keyword matching + knowledge graph expansion (up to 2 hops), ranked by composite score of similarity, importance, freshness, and graph boost\n- **Live knowledge graph** — people, orgs, locations, and concepts extracted into entities and relations on every write. Semantic entity resolution (>0.85 cosine) auto-merges duplicates\n- **Contradiction detection** — RDF triple comparison + LLM semantic analysis detects conflicting memories and automatically supersedes them, with full contradiction chain tracking\n\n### Self-Improving Memory\n\n- **Outcome-based learning (Karpathy Loop)** — agents report success/failure after acting on recalled memories; the system reinforces what works and auto-generates preventive `rule`-type memories on failure\n- **Crystallization** — LLM merges near-duplicate memories into canonical atomic facts with full provenance; 8-status lifecycle automation retires stale data\n- **Per-agent retrieval tuning** — each agent optimizes its own retrieval profile (top_k, min_similarity, graph_max_hops, blend weights) from feedback, so search quality compounds with every interaction\n\n### Integrations\n\n- **MCP server** — built-in [Model Context Protocol](https://modelcontextprotocol.io) at `/mcp` (Streamable HTTP). Connect Claude Desktop, Claude Code, Cursor, Windsurf, or any MCP client with a URL and API key\n- **Multi-provider LLM** — primary + fallback provider chain per tenant (OpenAI, Gemini, Anthropic, OpenRouter) with platform defaults for zero-config tenants\n- **Document store** — structured JSONB collections alongside semantic memories for exact-field lookups (customer records, config, task lists)\n\n---\n\n## Performance\n\nBenchmarked against the two most-cited public agent-memory benchmarks. Methodology and operator-scale context live in [`docs/performance.md`](docs/performance.md); the full write-up is on the blog.\n\n|  | LoCoMo | LongMemEval | Search latency |\n|---|---|---|---|\n| Accuracy (LLM-judge) | **77.6%** | **72.5%** | — |\n| Token savings vs full context | **96.6%** | **98.2%** | — |\n| Latency | — | — | **23 ms p50 · 27 ms p95** |\n\nAccuracy sits inside the leading cluster across the field (Mem0, Zep, MemClaw — scores cluster in a narrow band). The axes we push hardest are latency and token efficiency, because those are the ones that compound as agent count grows — a few hundred ms of search latency disappears behind one LLM call, but bills millions of times a day across a fleet.\n\n> Single-agent benchmarks can't measure cross-agent recall, outcome propagation between agents, fleet-scoped visibility, or governance-aware retrieval. Those are the questions that decide whether a memory system is *deployable* inside a company. See [`docs/performance.md`](docs/performance.md#what-these-benchmarks-cant-measure).\n\nSource: [Fast, Token-Efficient, and Built for Fleets](https://memclaw.net/blog/memclaw-benchmarks) (2026-04-19).\n\n---\n\n## MCP (Model Context Protocol)\n\nAdd MemClaw to any MCP client with one config block.\n\n**Self-hosted** (localhost):\n\n```json\n{\n  \"mcpServers\": {\n    \"memclaw\": {\n      \"url\": \"http://localhost:8000/mcp\",\n      \"headers\": { \"X-API-Key\": \"standalone\" }\n    }","lineStart":230,"lineEnd":309,"totalLines":965,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","time":{"start":1780729336776,"end":1780729336787}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872d08191b185496ec9623512"}},"id":"prt_e9bbd53c7001BRWpyuWpAgjnel","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"tool_use","timestamp":1780729336794,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_jcwIBAtDEWBYOjKMXee9P9Xb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/suppression_handlers.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/suppression_handlers.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Consumer for ``memclaw.org.suppression-changed`` (CAURA-694).\n2: \n3: Lives in ``common/`` so the same code can run in core-worker (the\n4: default SaaS subscriber) or in core-api (if a future OSS-standalone\n5: deployment grows a subscriber rather than ignoring the topic).\n6: \n7: The handler delegates the storage round-trip to a small adapter the\n8: host service supplies; this module never imports core-api / core-worker\n9: storage code. Each event covers a list of tenant_ids — we iterate and\n10: call the adapter once per tenant_id. Per-tenant failures are logged\n11: but the message is acked only if every tenant succeeded; a single\n12: failure re-raises so Pub/Sub redelivers (DLQ on max-delivery exhaustion).\n13: \n14: Re-raising on partial failure (vs. ack-with-warning) is the safer\n15: trade-off here: missing a suppression write opens an authz hole —\n16: better to retry until the row lands or DLQs to on-call.\n17: \"\"\"\n18: \n19: from __future__ import annotations\n20: \n21: import logging\n22: \n23: from pydantic import ValidationError\n24: \n25: from common.events.base import Event\n26: from common.events.factory import get_event_bus\n27: from common.events.org_suppression_event import OrgSuppressionEvent\n28: from common.events.topics import Topics\n29: \n30: logger = logging.getLogger(__name__)\n31: \n32: \n33: class SuppressionStorageAdapter:\n34:     \"\"\"Protocol-shaped adapter the host service implements.\n35: \n36:     A bare base (rather than ``typing.Protocol``) so the import doesn't\n37:     pull a circular dep into common, and so a test fake can subclass\n38:     and override just the one method. The handler treats this as a\n39:     duck-typed callable surface — the runtime check is the\n40:     ``set_tenant_suppression`` lookup itself.\n41:     \"\"\"\n42: \n43:     async def set_tenant_suppression(\n44:         self, *, tenant_id: str, action: str, updated_by: str | None\n45:     ) -> None:\n46:         raise NotImplementedError\n47: \n48: \n49: async def _handle_suppression_changed(\n50:     event: Event, *, adapter: SuppressionStorageAdapter\n51: ) -> None:\n52:     \"\"\"Subscriber for ``memclaw.org.suppression-changed``.\n53: \n54:     Iterates the tenant_ids in the payload and upserts each into the\n55:     suppression mirror via the adapter. Any per-tenant failure raises\n56:     so Pub/Sub redelivers (and DLQs after the configured max-delivery\n57:     attempts in CAURA-695). A malformed payload is dropped (no\n58:     redelivery) because no number of retries will make it parse.\n59:     \"\"\"\n60:     try:\n61:         # ``model_validate`` is the idiomatic Pydantic v2 entry point and\n62:         # is marginally more defensive than ``OrgSuppressionEvent(**…)``\n63:         # — it raises ``ValidationError`` for both bad shapes and\n64:         # unexpected input types (the kwargs splat raises ``TypeError``\n65:         # on a non-dict, which would skip this except block). Bot\n66:         # review round 2 on PR #244 (suggestion).\n67:         payload = OrgSuppressionEvent.model_validate(event.payload)\n68:     except ValidationError:\n69:         logger.exception(\n70:             \"dropping malformed org-suppression payload\",\n71:             extra={\n72:                 \"event_type\": event.event_type,\n73:                 \"event_id\": str(event.event_id),\n74:                 \"dropped\": True,\n75:             },\n76:         )\n77:         return\n78: \n79:     # Propagate the correlation_id from the envelope to the audit\n80:     # ``updated_by`` field — without a separate identity carrier on the\n81:     # event, the correlation id is the best causal link back to the\n82:     # platform-admin-api request that triggered the publish.\n83:     updated_by = event.correlation_id or \"core-worker\"\n84: \n85:     for tenant_id in payload.tenant_ids:\n86:         try:\n87:             await adapter.set_tenant_suppression(\n88:                 tenant_id=tenant_id,\n89:                 action=payload.action,\n90:                 updated_by=updated_by,\n91:             )\n92:         except Exception:\n93:             logger.exception(\n94:                 \"suppression upsert failed; will redeliver\",\n95:                 extra={\n96:                     \"event_id\": str(event.event_id),\n97:                     \"tenant_id\": tenant_id,\n98:                     \"action\": payload.action,\n99:                 },\n100:             )\n101:             # Re-raise so the bus nacks the message → redelivered (subject\n102:             # to max-delivery-attempts → DLQ). Acking on partial failure\n103:             # would leave the suppression mirror inconsistent with the\n104:             # enterprise authoritative state.\n105:             raise\n106: \n107:     logger.info(\n108:         \"org suppression mirrored\",\n109:         extra={\n110:             \"event_id\": str(event.event_id),\n111:             \"action\": payload.action,\n112:             \"tenants_updated\": len(payload.tenant_ids),\n113:         },\n114:     )\n115: \n116: \n117: def register_suppression_consumer(adapter: SuppressionStorageAdapter) -> None:\n118:     \"\"\"Wire :func:`_handle_suppression_changed` against\n119:     ``Topics.Org.SUPPRESSION_CHANGED`` on the active event bus.\n120: \n121:     Called once at startup by core-worker (SaaS). OSS standalone has no\n122:     publisher today; calling this in pure OSS is harmless — the\n123:     subscription just sits idle.\n124:     \"\"\"\n125:     bus = get_event_bus()\n126: \n127:     async def _bound(event: Event) -> None:\n128:         await _handle_suppression_changed(event, adapter=adapter)\n129: \n130:     bus.subscribe(Topics.Org.SUPPRESSION_CHANGED, _bound)\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"\"\"\"Consumer for ``memclaw.org.suppression-changed`` (CAURA-694).\n\nLives in ``common/`` so the same code can run in core-worker (the\ndefault SaaS subscriber) or in core-api (if a future OSS-standalone\ndeployment grows a subscriber rather than ignoring the topic).\n\nThe handler delegates the storage round-trip to a small adapter the\nhost service supplies; this module never imports core-api / core-worker\nstorage code. Each event covers a list of tenant_ids — we iterate and\ncall the adapter once per tenant_id. Per-tenant failures are logged\nbut the message is acked only if every tenant succeeded; a single\nfailure re-raises so Pub/Sub redelivers (DLQ on max-delivery exhaustion).\n\nRe-raising on partial failure (vs. ack-with-warning) is the safer\ntrade-off here: missing a suppression write opens an authz hole —\nbetter to retry until the row lands or DLQs to on-call.\n\"\"\"\n\nfrom __future__ import annotations\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/suppression_handlers.py","text":"\"\"\"Consumer for ``memclaw.org.suppression-changed`` (CAURA-694).\n\nLives in ``common/`` so the same code can run in core-worker (the\ndefault SaaS subscriber) or in core-api (if a future OSS-standalone\ndeployment grows a subscriber rather than ignoring the topic).\n\nThe handler delegates the storage round-trip to a small adapter the\nhost service supplies; this module never imports core-api / core-worker\nstorage code. Each event covers a list of tenant_ids — we iterate and\ncall the adapter once per tenant_id. Per-tenant failures are logged\nbut the message is acked only if every tenant succeeded; a single\nfailure re-raises so Pub/Sub redelivers (DLQ on max-delivery exhaustion).\n\nRe-raising on partial failure (vs. ack-with-warning) is the safer\ntrade-off here: missing a suppression write opens an authz hole —\nbetter to retry until the row lands or DLQs to on-call.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\n\nfrom pydantic import ValidationError\n\nfrom common.events.base import Event\nfrom common.events.factory import get_event_bus\nfrom common.events.org_suppression_event import OrgSuppressionEvent\nfrom common.events.topics import Topics\n\nlogger = logging.getLogger(__name__)\n\n\nclass SuppressionStorageAdapter:\n    \"\"\"Protocol-shaped adapter the host service implements.\n\n    A bare base (rather than ``typing.Protocol``) so the import doesn't\n    pull a circular dep into common, and so a test fake can subclass\n    and override just the one method. The handler treats this as a\n    duck-typed callable surface — the runtime check is the\n    ``set_tenant_suppression`` lookup itself.\n    \"\"\"\n\n    async def set_tenant_suppression(\n        self, *, tenant_id: str, action: str, updated_by: str | None\n    ) -> None:\n        raise NotImplementedError\n\n\nasync def _handle_suppression_changed(\n    event: Event, *, adapter: SuppressionStorageAdapter\n) -> None:\n    \"\"\"Subscriber for ``memclaw.org.suppression-changed``.\n\n    Iterates the tenant_ids in the payload and upserts each into the\n    suppression mirror via the adapter. Any per-tenant failure raises\n    so Pub/Sub redelivers (and DLQs after the configured max-delivery\n    attempts in CAURA-695). A malformed payload is dropped (no\n    redelivery) because no number of retries will make it parse.\n    \"\"\"\n    try:\n        # ``model_validate`` is the idiomatic Pydantic v2 entry point and\n        # is marginally more defensive than ``OrgSuppressionEvent(**…)``\n        # — it raises ``ValidationError`` for both bad shapes and\n        # unexpected input types (the kwargs splat raises ``TypeError``\n        # on a non-dict, which would skip this except block). Bot\n        # review round 2 on PR #244 (suggestion).\n        payload = OrgSuppressionEvent.model_validate(event.payload)\n    except ValidationError:\n        logger.exception(\n            \"dropping malformed org-suppression payload\",\n            extra={\n                \"event_type\": event.event_type,\n                \"event_id\": str(event.event_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    # Propagate the correlation_id from the envelope to the audit\n    # ``updated_by`` field — without a separate identity carrier on the\n    # event, the correlation id is the best causal link back to the\n    # platform-admin-api request that triggered the publish.\n    updated_by = event.correlation_id or \"core-worker\"\n\n    for tenant_id in payload.tenant_ids:\n        try:\n            await adapter.set_tenant_suppression(\n                tenant_id=tenant_id,\n                action=payload.action,\n                updated_by=updated_by,\n            )\n        except Exception:\n            logger.exception(\n                \"suppression upsert failed; will redeliver\",\n                extra={\n                    \"event_id\": str(event.event_id),\n                    \"tenant_id\": tenant_id,\n                    \"action\": payload.action,\n                },\n            )\n            # Re-raise so the bus nacks the message → redelivered (subject\n            # to max-delivery-attempts → DLQ). Acking on partial failure\n            # would leave the suppression mirror inconsistent with the\n            # enterprise authoritative state.\n            raise\n\n    logger.info(\n        \"org suppression mirrored\",\n        extra={\n            \"event_id\": str(event.event_id),\n            \"action\": payload.action,\n            \"tenants_updated\": len(payload.tenant_ids),\n        },\n    )\n\n\ndef register_suppression_consumer(adapter: SuppressionStorageAdapter) -> None:\n    \"\"\"Wire :func:`_handle_suppression_changed` against\n    ``Topics.Org.SUPPRESSION_CHANGED`` on the active event bus.\n\n    Called once at startup by core-worker (SaaS). OSS standalone has no\n    publisher today; calling this in pure OSS is harmless — the\n    subscription just sits idle.\n    \"\"\"\n    bus = get_event_bus()\n\n    async def _bound(event: Event) -> None:\n        await _handle_suppression_changed(event, adapter=adapter)\n\n    bus.subscribe(Topics.Org.SUPPRESSION_CHANGED, _bound)","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/suppression_handlers.py","time":{"start":1780729336784,"end":1780729336793}},"metadata":{"openai":{"itemId":"fc_056f1fa028e2fdd7016a23c5f872e08191b5862a6cbae56922"}},"id":"prt_e9bbd53cb001bugTN3cz94oGxi","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV"}}
{"type":"step_finish","timestamp":1780729337331,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"id":"prt_e9bbd55ea001xFtzofZpDAJL7a","reason":"tool-calls","snapshot":"","messageID":"msg_e9bbd14ea001MO0H8tiJVCVwAV","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","type":"step-finish","tokens":{"total":39162,"input":6155,"output":649,"reasoning":102,"cache":{"write":0,"read":32256}},"cost":0}}
{"type":"step_start","timestamp":1780729339483,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"id":"prt_e9bbd5e5a001JeQV9HG8uUJfuX","messageID":"msg_e9bbd5844001hpaweERShUnEId","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","snapshot":"373a83fe6e5cc30ee24177fd4b55989cf7c00f84","type":"step-start"}}
{"type":"tool_use","timestamp":1780729350312,"sessionID":"ses_164436567ffeteXLf4I1Mx29cA","part":{"type":"tool","tool":"read","callID":"call_cAT91eZvcLY424QwTpDYYuvE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","offset":1646,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py</path>\n<type>file</type>\n<content>\n1646:     async def memory_purge_soft_deleted(\n1647:         self,\n1648:         tenant_id: str,\n1649:         fleet_id: str | None = None,\n1650:         retention_days: int = MEMORY_RETENTION_MAX_DAYS,\n1651:         batch_size: int = 500,\n1652:     ) -> int:\n1653:         \"\"\"Hard-delete soft-deleted memories whose ``deleted_at`` is older\n1654:         than ``retention_days``. Soft-deletes (CAURA-656) keeps rows\n1655:         addressable for a grace period before they're physically removed,\n1656:         so a misclick or buggy client can be undone for ``retention_days``\n1657:         days. After that window the row is gone for good — including its\n1658:         embedding, entity links, and idempotency response cache lines\n1659:         (cascaded by their FKs to ``memories.id``).\n1660:         \"\"\"\n1661:         async with get_session() as session:\n1662:             params: dict = {\n1663:                 \"tenant_id\": tenant_id,\n1664:                 \"retention_days\": retention_days,\n1665:                 \"batch_size\": batch_size,\n1666:             }\n1667:             fleet_clause = \"\"\n1668:             if fleet_id:\n1669:                 fleet_clause = \"AND fleet_id = :fleet_id\"\n1670:                 params[\"fleet_id\"] = fleet_id\n1671: \n1672:             result = await session.execute(\n1673:                 text(f\"\"\"\n1674:                 DELETE FROM memories\n1675:                 WHERE id IN (\n1676:                     SELECT id FROM memories\n1677:                     WHERE tenant_id = :tenant_id\n1678:                       {fleet_clause}\n1679:                       AND deleted_at IS NOT NULL\n1680:                       AND deleted_at < NOW() - INTERVAL '1 day' * :retention_days\n1681:                     LIMIT :batch_size\n1682:                 )\n1683:                 RETURNING id\n1684:             \"\"\"),\n1685:                 params,\n1686:             )\n1687:             return len(result.all())\n1688: \n1689:     async def purge_tenant_data(self, tenant_id: str) -> dict[str, int]:\n1690:         \"\"\"Permanently delete EVERY row scoped to ``tenant_id`` across the\n1691:         OSS schema — the hard side of organization deletion (CAURA-689).\n1692: \n1693:         Runs in one transaction, children-before-parents, so a foreign key\n1694:         never blocks a delete and a mid-purge failure rolls back cleanly.\n1695:         Tables without their own ``tenant_id`` (``memory_entity_links``)\n1696:         are removed by the CASCADE from ``memories`` / ``entities``;\n1697:         ``organization_settings*`` are keyed by ``org_id`` (== tenant id in\n1698:         OSS). ``lifecycle_audit`` is intentionally retained as the audit\n1699:         trail. Returns per-table deleted counts.\n1700: \n1701:         Idempotent: re-running on an already-purged tenant deletes nothing\n1702:         and returns zeros, so a retried org hard-delete is safe.\n1703: \n1704:         The enterprise ``enterprise.*`` rows (org, tenants, keys, …) are\n1705:         purged separately by platform-storage-api; this owns the OSS\n1706:         ``public.*`` schema only.\n1707:         \"\"\"\n1708:         counts: dict[str, int] = {}\n1709:         async with get_session() as session:\n1710:             # One DELETE per table in the declared children-before-parents\n1711:             # order (so a foreign key never blocks a delete) and one rowcount\n1712:             # per table (the per-table breakdown is a reported feature). The\n1713:             # two groups differ only in the scoping column: most tables carry\n1714:             # ``tenant_id``; ``organization_settings*`` carry ``org_id``.\n1715:             for tables, column in (\n1716:                 (_PURGE_TENANT_TABLES, \"tenant_id\"),\n1717:                 (_PURGE_ORG_KEYED_TABLES, \"org_id\"),\n1718:             ):\n1719:                 for table_name in tables:\n1720:                     # Schema-qualify (public.) so an irreversible hard-delete\n1721:                     # can't be redirected by a non-default search_path.\n1722:                     result = await session.execute(\n1723:                         text(f\"DELETE FROM public.{table_name} WHERE {column} = :tid\"),\n1724:                         {\"tid\": tenant_id},\n1725:                     )\n1726:                     counts[table_name] = result.rowcount  # type: ignore[attr-defined]\n1727:         return counts\n1728: \n1729:     async def count_tenant_data(self, tenant_id: str) -> dict[str, int]:\n1730:         \"\"\"Per-table row count for a ``tenant_id`` across the OSS schema\n1731:         (CAURA-696). Mirrors ``purge_tenant_data``'s table set + column\n1732:         layout so the preview is an accurate forecast of what the\n1733:         purge would delete — adding a new table to the purge list\n1734:         means adding it here too (one source of truth would be nice\n1735:         but the two ops have different read/write modes, so we\n1736:         accept the parallel constants and call out the invariant in\n1737:         comments on both).\n1738: \n1739:         Cheap, read-only: one ``SELECT count(*)`` per table, all\n1740:         keyed off the same indexed ``tenant_id`` / ``org_id``\n1741:         columns. Reports zeros for tables with no rows so the caller\n1742:         gets the full breakdown without a follow-up round-trip.\n1743:         \"\"\"\n1744:         counts: dict[str, int] = {}\n1745:         async with get_read_session() as session:\n1746:             for tables, column in (\n1747:                 (_PURGE_TENANT_TABLES, \"tenant_id\"),\n1748:                 (_PURGE_ORG_KEYED_TABLES, \"org_id\"),\n1749:             ):\n1750:                 for table_name in tables:\n1751:                     # Schema-qualify (``public.``) for the same reason\n1752:                     # ``purge_tenant_data`` does — a non-default\n1753:                     # ``search_path`` could otherwise target the wrong\n1754:                     # rows / mask drift between preview and purge.\n1755:                     result = await session.execute(\n1756:                         text(f\"SELECT count(*) FROM public.{table_name} WHERE {column} = :tid\"),\n1757:                         {\"tid\": tenant_id},\n1758:                     )\n1759:                     counts[table_name] = int(result.scalar() or 0)\n1760:         return counts\n1761: \n1762:     async def purge_fleet_data(self, tenant_id: str, fleet_id: str) -> dict[str, int]:\n1763:         \"\"\"Permanently delete every row scoped to ``(tenant_id, fleet_id)``\n1764:         across the fleet-scoped OSS tables — the per-fleet analogue of\n1765:         ``purge_tenant_data`` for test-tenant hygiene (run-scoped fleet\n\n(Showing lines 1646-1765 of 4754. Use offset=1766 to continue.)\n</content>","metadata":{"preview":"    async def memory_purge_soft_deleted(\n        self,\n        tenant_id: str,\n        fleet_id: str | None = None,\n        retention_days: int = MEMORY_RETENTION_MAX_DAYS,\n        batch_size: int = 500,\n    ) -> int:\n        \"\"\"Hard-delete soft-deleted memories whose ``deleted_at`` is older\n        than ``retention_days``. Soft-deletes (CAURA-656) keeps rows\n        addressable for a grace period before they're physically removed,\n        so a misclick or buggy client can be undone for ``retention_days``\n        days. After that window the row is gone for good — including its\n        embedding, entity links, and idempotency response cache lines\n        (cascaded by their FKs to ``memories.id``).\n        \"\"\"\n        async with get_session() as session:\n            params: dict = {\n                \"tenant_id\": tenant_id,\n                \"retention_days\": retention_days,\n                \"batch_size\": batch_size,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"    async def memory_purge_soft_deleted(\n        self,\n        tenant_id: str,\n        fleet_id: str | None = None,\n        retention_days: int = MEMORY_RETENTION_MAX_DAYS,\n        batch_size: int = 500,\n    ) -> int:\n        \"\"\"Hard-delete soft-deleted memories whose ``deleted_at`` is older\n        than ``retention_days``. Soft-deletes (CAURA-656) keeps rows\n        addressable for a grace period before they're physically removed,\n        so a misclick or buggy client can be undone for ``retention_days``\n        days. After that window the row is gone for good — including its\n        embedding, entity links, and idempotency response cache lines\n        (cascaded by their FKs to ``memories.id``).\n        \"\"\"\n        async with get_session() as session:\n            params: dict = {\n                \"tenant_id\": tenant_id,\n                \"retention_days\": retention_days,\n                \"batch_size\": batch_size,\n            }\n            fleet_clause = \"\"\n            if fleet_id:\n                fleet_clause = \"AND fleet_id = :fleet_id\"\n                params[\"fleet_id\"] = fleet_id\n\n            result = await session.execute(\n                text(f\"\"\"\n                DELETE FROM memories\n                WHERE id IN (\n                    SELECT id FROM memories\n                    WHERE tenant_id = :tenant_id\n                      {fleet_clause}\n                      AND deleted_at IS NOT NULL\n                      AND deleted_at < NOW() - INTERVAL '1 day' * :retention_days\n                    LIMIT :batch_size\n                )\n                RETURNING id\n            \"\"\"),\n                params,\n            )\n            return len(result.all())\n\n    async def purge_tenant_data(self, tenant_id: str) -> dict[str, int]:\n        \"\"\"Permanently delete EVERY row scoped to ``tenant_id`` across the\n        OSS schema — the hard side of organization deletion (CAURA-689).\n\n        Runs in one transaction, children-before-parents, so a foreign key\n        never blocks a delete and a mid-purge failure rolls back cleanly.\n        Tables without their own ``tenant_id`` (``memory_entity_links``)\n        are removed by the CASCADE from ``memories`` / ``entities``;\n        ``organization_settings*`` are keyed by ``org_id`` (== tenant id in\n        OSS). ``lifecycle_audit`` is intentionally retained as the audit\n        trail. Returns per-table deleted counts.\n\n        Idempotent: re-running on an already-purged tenant deletes nothing\n        and returns zeros, so a retried org hard-delete is safe.\n\n        The enterprise ``enterprise.*`` rows (org, tenants, keys, …) are\n        purged separately by platform-storage-api; this owns the OSS\n        ``public.*`` schema only.\n        \"\"\"\n        counts: dict[str, int] = {}\n        async with get_session() as session:\n            # One DELETE per table in the declared children-before-parents\n            # order (so a foreign key never blocks a delete) and one rowcount\n            # per table (the per-table breakdown is a reported feature). The\n            # two groups differ only in the scoping column: most tables carry\n            # ``tenant_id``; ``organization_settings*`` carry ``org_id``.\n            for tables, column in (\n                (_PURGE_TENANT_TABLES, \"tenant_id\"),\n                (_PURGE_ORG_KEYED_TABLES, \"org_id\"),\n            ):\n                for table_name in tables:\n                    # Schema-qualify (public.) so an irreversible hard-delete\n                    # can't be redirected by a non-default search_path.\n                    result = await session.execute(\n                        text(f\"DELETE FROM public.{table_name} WHERE {column} = :tid\"),\n                        {\"tid\": tenant_id},\n                    )\n                    counts[table_name] = result.rowcount  # type: ignore[attr-defined]\n        return counts\n\n    async def count_tenant_data(self, tenant_id: str) -> dict[str, int]:\n        \"\"\"Per-table row count for a ``tenant_id`` across the OSS schema\n        (CAURA-696). Mirrors ``purge_tenant_data``'s table set + column\n        layout so the preview is an accurate forecast of what the\n        purge would delete — adding a new table to the purge list\n        means adding it here too (one source of truth would be nice\n        but the two ops have different read/write modes, so we\n        accept the parallel constants and call out the invariant in\n        comments on both).\n\n        Cheap, read-only: one ``SELECT count(*)`` per table, all\n        keyed off the same indexed ``tenant_id`` / ``org_id``\n        columns. Reports zeros for tables with no rows so the caller\n        gets the full breakdown without a follow-up round-trip.\n        \"\"\"\n        counts: dict[str, int] = {}\n        async with get_read_session() as session:\n            for tables, column in (\n                (_PURGE_TENANT_TABLES, \"tenant_id\"),\n                (_PURGE_ORG_KEYED_TABLES, \"org_id\"),\n            ):\n                for table_name in tables:\n                    # Schema-qualify (``public.``) for the same reason\n                    # ``purge_tenant_data`` does — a non-default\n                    # ``search_path`` could otherwise target the wrong\n                    # rows / mask drift between preview and purge.\n                    result = await session.execute(\n                        text(f\"SELECT count(*) FROM public.{table_name} WHERE {column} = :tid\"),\n                        {\"tid\": tenant_id},\n                    )\n                    counts[table_name] = int(result.scalar() or 0)\n        return counts\n\n    async def purge_fleet_data(self, tenant_id: str, fleet_id: str) -> dict[str, int]:\n        \"\"\"Permanently delete every row scoped to ``(tenant_id, fleet_id)``\n        across the fleet-scoped OSS tables — the per-fleet analogue of\n        ``purge_tenant_data`` for test-tenant hygiene (run-scoped fleet","lineStart":1646,"lineEnd":1765,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780729350291,"end":1780729350311}},"metadata":{"openai":{"itemId":"fc_0795be3f59c2504f016a23c60643b08191998b5b2c140b02e2"}},"id":"prt_e9bbd8890001bcjPE4s5fsFG53","sessionID":"ses_164436567ffeteXLf4I1Mx29cA","messageID":"msg_e9bbd5844001hpaweERShUnEId"}}
