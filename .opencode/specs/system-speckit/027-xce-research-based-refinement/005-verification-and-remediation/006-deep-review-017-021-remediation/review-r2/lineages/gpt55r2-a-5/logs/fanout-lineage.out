s effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"  const sql = `\n    SELECT sub.*,\n           ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n    FROM (\n      SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n             ${decay_expr} as effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n\n  return [...constitutional_results, ...regular_results];","lineStart":446,"lineEnd":470,"totalLines":1742,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781762591687,"end":1781762591691}},"metadata":{"openai":{"itemId":"fc_06effadad741c