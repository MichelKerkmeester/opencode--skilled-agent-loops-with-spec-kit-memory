const fs=require('fs'), cp=require('child_process'), path=require('path');
const files=['.claude/settings.local.json','.codex/settings.json','.gemini/settings.json'];
for (const file of files){
  const json=JSON.parse(fs.readFileSync(file,'utf8'));
  for (const [event,entries] of Object.entries(json.hooks||{})){
    for (const entry of entries){
      for (const hook of entry.hooks||[]){
        const cmd=hook.command || '';
        const bin=(cmd.match(/&&\\s+(["'^'"\\s]+)\\s+/)||cmd.match(/"'^([''^'"\\s]+)/)||[])[1];
        const scripts=[...cmd.matchAll(/(?:node|\\/opt\\/homebrew\\/bin\\/node)\\s+(["'^'"'\"\\s]+)/g)].map(m=>m[1]);
        let binOk='unknown';
        if (bin) { try { cp.execFileSync('bash',['-lc',"'`command -v ${JSON.stringify(bin)} >/dev/null`]); binOk='"'yes'; } catch { binOk='no'; } }
        console.log(JSON.stringify({file,event,type:hook.type,timeout:hook.timeout,async:hook.async||false,bin,binOk,scripts:scripts.map(s=>({path:s,exists:fs.existsSync(s)})),command:cmd}));
      }
    }
  }
}
NODE
