tead\n78:   // of emitting U+FFFD replacement chars on the partial sequence.\n79:   const decoder = new StringDecoder('utf8');\n80:   return {\n81:     push(chunk) {\n82:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n83:       let newlineIndex = buffer.indexOf('\\n');\n84:       while (newlineIndex !== -1) {\n85:         const frame = buffer.slice(0, newlineIndex);\n86:         buffer = buffer.slice(newlineIndex + 1);\n87:         newlineIndex = buffer.indexOf('\\n');\n88:         if (frame.trim().length === 0) continue;\n89:         onFrame(frame);\n90:       }\n91:     },\n92:     discard() {\n93:       buffer = '';\n94:       decoder.end();\n95:     },\n96:     buffered() {\n97:       return buffer;\n98:     },\n99:   };\n100: }\n101: \n102: function parseFrame(frame) {\n103:   try {\n104:     const parsed = JSON.parse(String(frame).trim());\n105:     return parsed && typeof parsed === 'object' ? parsed : null;\n106:   } catch {\n107:     return null;\n108:   }\n109: }\n110: \n111: function hasOwn(object, key) {\n112:   return Object.prototype.hasOwnProperty.call(object, key);\n113: }\n114: \n115: function hasRequestId(parsed) {\n116:   return parsed !== null && hasOwn(parsed, 'id');\n117: }\n118: \n119: function isResponseFrame(parsed) {\n120:   return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n121: }\n122: \n123: // Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n124: // (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n125: // servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n126: // tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\n127: function createClassifyFrame(options = {}) {\n128:   const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n129:   const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n130:   return function classify(frame) {\n131:     const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n132:     if (!parsed || typeof parsed.method !== 'string') return false;\n133:     if (parsed.method !== 'tools/call') {\n134:       return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n135:     }\n136:     const toolName = parsed.params && typeof parsed.params === 'object'\n137:       ? parsed.params.name\n138:       : undefined;\n139:     if (typeof toolName !== 'string') return false;\n140:     if (unsafe.has(toolName)) return false;\n141:     if (replayable.has(toolName)) return true;\n142:     return false;\n143:   };\n144: }\n145: \n146: // Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n147: // commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n148: // active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n149: // collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n150: // index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n151: // on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n152: // idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n153: // lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\n154: const classifyFrame = createClassifyFrame();\n155: \n156: function createPendingRequestsTracker(classify = classifyFrame) {\n157:   const pendingRequests = new Map();\n158:   let cachedInitialize = null;\n159:   let cachedInitializeId = null;\n\n(Showing lines 30-159 of 853. Use offset=160 to continue.)\n</content>","metadata":{"preview":"  message: 'backend protocol version changed; client reconnect required',\n  data: { retryable: false },\n});\nconst REPLAYABLE_TOOL_NAMES = new Set([\n  'memory_search',\n  'memory_context',\n  'memory_match_triggers',\n  'memory_quick_search',\n  'memory_save',\n  'session_bootstrap',\n  'session_health',\n  'session_resume',\n  'session_status',\n  'memory_stats',\n  'memory_status',\n  'checkpoint_list',\n  'embedder_health',\n]);\nconst UNSAFE_TOOL_NAMES = new Set([\n  'memory_delete',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","text":"  message: 'backend protocol version changed; client reconnect required',\n  data: { retryable: false },\n});\nconst REPLAYABLE_TOOL_NAMES = new Set([\n  'memory_search',\n  'memory_context',\n  'memory_match_triggers',\n  'memory_quick_search',\n  'memory_save',\n  'session_bootstrap',\n  'session_health',\n  'session_resume',\n  'session_status',\n  'memory_stats',\n  'memory_status',\n  'checkpoint_list',\n  'embedder_health',\n]);\nconst UNSAFE_TOOL_NAMES = new Set([\n  'memory_delete',\n  'memory_bulk_delete',\n  'memory_update',\n  'checkpoint_restore',\n  'checkpoint_delete',\n  'embedder_set',\n  'memory_retention_sweep',\n  'memory_ingest_start',\n  'memory_ingest_cancel',\n]);\nconst REPLAYABLE_PROTOCOL_METHODS = new Set([\n  'initialize',\n  'ping',\n]);\n\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nfunction defaultConnect(connectionOptions) {\n  return net.createConnection(connectionOptions);\n}\n\nfunction defaultLog(message) {\n  process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n}\n\nfunction createFrameSplitter(onFrame) {\n  let buffer = '';\n  // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n  // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n  // of emitting U+FFFD replacement chars on the partial sequence.\n  const decoder = new StringDecoder('utf8');\n  return {\n    push(chunk) {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        onFrame(frame);\n      }\n    },\n    discard() {\n      buffer = '';\n      decoder.end();\n    },\n    buffered() {\n      return buffer;\n    },\n  };\n}\n\nfunction parseFrame(frame) {\n  try {\n    const parsed = JSON.parse(String(frame).trim());\n    return parsed && typeof parsed === 'object' ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction hasOwn(object, key) {\n  return Object.prototype.hasOwnProperty.call(object, key);\n}\n\nfunction hasRequestId(parsed) {\n  return parsed !== null && hasOwn(parsed, 'id');\n}\n\nfunction isResponseFrame(parsed) {\n  return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n}\n\n// Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n// (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n// servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n// tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\nfunction createClassifyFrame(options = {}) {\n  const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n  const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n  return function classify(frame) {\n    const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n    if (!parsed || typeof parsed.method !== 'string') return false;\n    if (parsed.method !== 'tools/call') {\n      return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n    }\n    const toolName = parsed.params && typeof parsed.params === 'object'\n      ? parsed.params.name\n      : undefined;\n    if (typeof toolName !== 'string') return false;\n    if (unsafe.has(toolName)) return false;\n    if (replayable.has(toolName)) return true;\n    return false;\n  };\n}\n\n// Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n// commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n// active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n// collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n// index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n// on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n// idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n// lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\nconst classifyFrame = createClassifyFrame();\n\nfunction createPendingRequestsTracker(classify = classifyFrame) {\n  const pendingRequests = new Map();\n  let cachedInitialize = null;\n  let cachedInitializeId = null;","lineStart":30,"lineEnd":159,"totalLines":853,"truncated":true}},"title":".opencode/bin/lib/launcher-session-proxy.cjs","time":{"start":1781763191997,"end":1781763192005}},"metadata":{"openai":{"itemId":"fc_081f2e3f85cd21d9016a338c7792b4819197e0b990fe694293"}},"id":"prt_ed95cb41e001rTj5L1i7vR6y1j","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95c8b620012uQ3jDF2EWt3q3"}}
