{"type":"tool_use","timestamp":1781761494695,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_h83B08Wovg3o6nSxLDn5zYA1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":180,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n180:           fs.renameSync(target, rotated);\n181:         } catch {\n182:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n183:         }\n184:       }\n185:     } catch (statErr) {\n186:       if (statErr.code !== 'ENOENT') throw statErr;\n187:     }\n188:     fs.appendFileSync(target, line, { mode: 0o600 });\n189:   } catch (error) {\n190:     if (target && isDurableWriteUnavailable(error)) {\n191:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n192:       return;\n193:     }\n194:     // Logging must never break the launcher.\n195:   }\n196: }\n197: \n198: // Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n199: // When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n200: // (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n201: // not tear the shared backend out from under other sessions. A fresh session that finds the released\n202: // daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n203: // it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n204: // writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n205: // killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n206: // sweeper bounds any leak.\n207: function daemonReelectionEnabled(env = process.env) {\n208:   return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n209: }\n210: function contextServerSpawnIo(reelectionEnabled) {\n211:   return reelectionEnabled\n212:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n213:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n214: }\n215: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n216:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n217: }\n218: \n219: function cleanupTmpFile(tmpPath) {\n220:   try {\n221:     fs.unlinkSync(tmpPath);\n222:   } catch (error) {\n223:     if (error.code !== 'ENOENT') {\n224:       // Best-effort cleanup only; the original durable-write failure is more useful.\n225:     }\n226:   }\n227: }\n228: \n229: function writeAtomicJsonFile(targetPath, payload, operation) {\n230:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n231:   const tmp = `${currentPath}.tmp.${process.pid}`;\n232:   try {\n233:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n234:     fs.renameSync(tmp, currentPath);\n235:     return true;\n236:   } catch (error) {\n237:     cleanupTmpFile(tmp);\n238:     if (isDurableWriteUnavailable(error)) {\n239:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n240:       return false;\n241:     }\n242:     throw error;\n243:   }\n244: }\n245: \n246: function loadProjectEnvFiles() {\n247:   for (const fname of ['.env.local', '.env']) {\n248:     const p = path.join(root, fname);\n249:     if (fs.existsSync(p)) {\n250:       const n = loadEnvFile(p);\n251:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n252:     }\n253:   }\n254: }\n255: \n256: function parsePositiveInteger(value, fallback) {\n257:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n258:   const parsed = Number.parseInt(String(value).trim(), 10);\n259:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n260: }\n261: \n262: function loadBridgeModule() {\n263:   try {\n264:     return require('./lib/launcher-ipc-bridge.cjs');\n265:   } catch (error) {\n266:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n267:     return {\n268:       async maybeBridgeLeaseHolder({ leaseResult }) {\n269:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n270:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n271:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n272:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n273:         return { action: 'report', reason: 'bridge-module-missing' };\n274:       },\n275:     };\n276:   }\n277: }\n278: \n279: function resolveSessionProxySocketPath() {\n280:   const { getIpcSocketPath } = loadBridgeModule();\n281:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n282: }\n283: \n284: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n285: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n286: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n287: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n288: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n289: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n290: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n291: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n292:   const createProxy = options.createProxy ?? createSessionProxy;\n293:   const sessionProxy = createProxy({\n294:     socketPath,\n295:     stdin: options.stdin ?? process.stdin,\n296:     stdout: options.stdout ?? process.stdout,\n297:     log,\n298:   });\n299:   return sessionProxy.start();\n300: }\n301: \n302: function refreshPaths() {\n303:   skillsDir = path.join(opencodeDir, 'skills');\n304:   legacySkillDir = path.join(opencodeDir, 'skill');\n305:   kitDir = path.join(skillsDir, 'system-spec-kit');\n306:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n307:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n308:   stateFile = path.join(dbDir, PID_FILE_NAME);\n309:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n310: }\n311: \n312: function exists(p) {\n313:   return fs.existsSync(p);\n314: }\n315: \n316: function writeState(payload) {\n317:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n318:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n319: }\n320: \n321: function resolvedDbDir() {\n322:   return canonicalizePath(dbDir);\n323: }\n324: \n325: // Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n326: // daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n327: // resolved against cwd, else the default DB dir) so both sides agree on the path\n328: // even under a test fake-root that sets SPEC_KIT_DB_DIR.\n329: function maintenanceMarkerDir() {\n330:   const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n331:   if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n332:   return resolvedDbDir();\n333: }\n334: \n335: function leasePath() {\n336:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n337: }\n338: \n339: function ownerLeasePath() {\n340:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n341: }\n342: \n343: function legacyLeasePaths() {\n344:   return [\n345:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n346:   ].map(canonicalizePath);\n347: }\n348: \n349: function readLeaseFile(filePath = leasePath()) {\n350:   try {\n351:     const raw = fs.readFileSync(filePath, 'utf8');\n352:     const parsed = JSON.parse(raw);\n353:     if (typeof parsed.pid === 'number') return parsed;\n354:   } catch {\n355:     // Missing or corrupt lease files are treated as no active lease.\n356:   }\n357:   return null;\n358: }\n359: \n\n(Showing lines 180-359 of 1882. Use offset=360 to continue.)\n</content>","metadata":{"preview":"          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n// (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n// not tear the shared backend out from under other sessions. A fresh session that finds the released\n// daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n// it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n// writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n// killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n// sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-spec-kit');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n  canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\n// Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n// daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n// resolved against cwd, else the default DB dir) so both sides agree on the path\n// even under a test fake-root that sets SPEC_KIT_DB_DIR.\nfunction maintenanceMarkerDir() {\n  const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n  return resolvedDbDir();\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n","lineStart":180,"lineEnd":359,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781761494680,"end":1781761494693}},"metadata":{"openai":{"itemId":"fc_0c3452ad4142cdcd016a3385d693f48191b909063f0441e18d"}},"id":"prt_ed942ce9700156v3bOXCCNrY18","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed9429209001TfpZFoKNoHfTkZ"}}
{"type":"tool_use","timestamp":1781761494695,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_tnwnj8mCbhNpnClDGlAbnNU4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1450,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1450:   childProcess.on('error', (error) => {\n1451:     log(error.stack || error.message);\n1452:     process.exit(1);\n1453:   });\n1454:   if (rssBreachSelfExitInProgress) {\n1455:     rssBreachSelfExitInProgress = false;\n1456:   }\n1457:   return true;\n1458: }\n1459: \n1460: // Pure decision for the exit-86 flow (exported for tests). A lease whose\n1461: // owner is THIS launcher is NOT a bridge target: in supervised mode the\n1462: // pid-lease records the launcher's own pid, so after its child exits 86 the\n1463: // lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n1464: // our own dead socket and route into a self-reap. Only a DIFFERENT live\n1465: // owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n1466: // standalone save mid-run) owns the database lock, so retry in place.\n1467: function decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n1468:   if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n1469:   if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };\n1470:   if (attempt <= maxRetries) return { action: 'retry', backoffMs: 2000 * 2 ** (attempt - 1) };\n1471:   return { action: 'report', reason: 'db-lock-held' };\n1472: }\n1473: \n1474: // The daemon refused to become a second writer on a database another live\n1475: // process holds. Prefer bridging to that owner; when the holder is not a\n1476: // bridgeable daemon (e.g. a maintenance script mid-run), retry the launch a\n1477: // few times so a short-lived holder can finish, then report and exit clean.\n1478: async function handleDbLockHeldChildExit() {\n1479:   dbLockHeldRetries += 1;\n1480:   const leaseResult = isLeaseHeld();\n1481:   const decision = decideDbLockHeldAction({\n1482:     leaseHeld: leaseResult.held,\n1483:     leaseOwnerPid: leaseResult.ownerPid,\n1484:     selfPid: process.pid,\n1485:     attempt: dbLockHeldRetries,\n1486:     maxRetries: DB_LOCK_HELD_MAX_RETRIES,\n1487:   });\n1488:   if (decision.action === 'bridge') {\n1489:     log(`context-server exited: database single-writer lock held; bridging to live owner pid=${leaseResult.ownerPid}`);\n1490:     await bridgeOrReportLeaseHeldAndExit(leaseResult);\n1491:     return;\n1492:   }\n1493:   if (decision.action === 'retry') {\n1494:     log(`database single-writer lock held by a non-bridgeable holder; retrying launch in ${decision.backoffMs}ms (attempt ${dbLockHeldRetries}/${DB_LOCK_HELD_MAX_RETRIES})`);\n1495:     if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1496:     supervisorRelaunchTimer = setTimeout(() => {\n1497:       // Abort if the owning runtime vanished (shutdown in progress, or the launcher\n1498:       // was reparented to init without a SIGTERM) — same guard as the primary\n1499:       // backoff-relaunch path, so neither relaunches a daemon under a disposed session.\n1500:       if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) return;\n1501:       launchServer();\n1502:     }, decision.backoffMs);\n1503:     if (supervisorRelaunchTimer.unref) supervisorRelaunchTimer.unref();\n1504:     return;\n1505:   }\n1506:   log('database single-writer lock still held after launch retries; reporting and exiting');\n1507:   writeLeaseHeldJsonRpcError(\n1508:     { ownerPid: leaseResult.ownerPid ?? 'unknown', startedAt: leaseResult.startedAt ?? new Date().toISOString() },\n1509:     decision.reason,\n1510:   );\n1511:   clearAllLeaseFiles();\n1512:   process.exit(0);\n1513: }\n1514: \n1515: async function shutdownLauncherForSignal(signal) {\n1516:   if (launcherShutdownInProgress) return;\n1517:   launcherShutdownInProgress = true;\n1518:   if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n1519:   if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1520:   clearOwnerLeaseHeartbeat();\n1521:   hfControl.clearTimers();\n1522:   await hfControl.stopDemandListener();\n1523: \n1524:   // Re-election release path (on by default): release the detached context-server for a live secondary to adopt\n1525:   // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n1526:   // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n1527:   // flag is off this branch is skipped and the original kill path below runs unchanged.\n1528:   if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n1529:     const releasedModelServer = hfControl.getChild();\n1530:     if (isChildRunning(releasedModelServer)) {\n1531:       hfControl.reapProcessTree(releasedModelServer.pid);\n1532:       releasedModelServer.kill(signal);\n1533:       // Escalate to SIGKILL if the non-adoptable model-server does not exit within the grace window,\n1534:       // so the release path does not leave a wedged sidecar behind on its way out.\n1535:       const exited = await waitForChildExit(releasedModelServer, RESPAWN_REAP_GRACE_MS);\n1536:       if (!exited && isChildRunning(releasedModelServer)) {\n1537:         releasedModelServer.kill('SIGKILL');\n1538:       }\n1539:     }\n1540:     log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n1541:     // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n1542:     // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n1543:     process.removeListener('exit', clearAllLeaseFiles);\n1544:     clearOwnerLeaseFile();\n1545:     process.exit(0);\n1546:     return;\n1547:   }\n1548: \n1549:   const children = [];\n1550:   if (isChildRunning(childProcess)) {\n1551:     children.push({ child: childProcess, label: 'context-server' });\n1552:   }\n1553:   const modelServerChild = hfControl.getChild();\n1554:   if (isChildRunning(modelServerChild)) {\n1555:     children.push({ child: modelServerChild, label: 'hf-model-server' });\n1556:   }\n1557: \n1558:   if (children.length === 0) {\n1559:     clearAllLeaseFiles();\n1560:     process.exit(128);\n1561:     return;\n1562:   }\n1563: \n1564:   for (const { child, label } of children) {\n1565:     if (label === 'hf-model-server') {\n1566:       hfControl.reapProcessTree(child.pid);\n1567:     }\n1568:     child.kill(signal);\n1569:   }\n1570: \n1571:   const exited = await Promise.race([\n1572:     Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n1573:     sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n1574:   ]);\n1575:   if (!exited) {\n1576:     for (const { child } of children) {\n1577:       if (isChildRunning(child)) child.kill('SIGKILL');\n1578:     }\n1579:   }\n1580:   clearAllLeaseFiles();\n1581:   process.exit(128);\n1582: }\n1583: \n1584: function installSignalHandlers() {\n1585:   for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n1586:     process.on(signal, () => {\n1587:       void shutdownLauncherForSignal(signal).catch((error) => {\n1588:         log(error.stack || error.message);\n1589:         clearAllLeaseFiles();\n1590:         process.exit(128);\n1591:       });\n1592:     });\n1593:   }\n1594:   process.on('uncaughtException', (err) => {\n1595:     try {\n1596:       clearAllLeaseFiles();\n1597:     } catch {\n1598:       // Preserve default uncaughtException crash behavior.\n1599:     }\n1600:     throw err;\n1601:   });\n1602: }\n1603: \n1604: async function main() {\n1605:   loadProjectEnvFiles();\n1606:   const started = now();\n1607:   const actions = [];\n1608:   let lockHeld = false;\n1609:   let staleRespawnLock = null;\n\n(Showing lines 1450-1609 of 1882. Use offset=1610 to continue.)\n</content>","metadata":{"preview":"  childProcess.on('error', (error) => {\n    log(error.stack || error.message);\n    process.exit(1);\n  });\n  if (rssBreachSelfExitInProgress) {\n    rssBreachSelfExitInProgress = false;\n  }\n  return true;\n}\n\n// Pure decision for the exit-86 flow (exported for tests). A lease whose\n// owner is THIS launcher is NOT a bridge target: in supervised mode the\n// pid-lease records the launcher's own pid, so after its child exits 86 the\n// lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n// our own dead socket and route into a self-reap. Only a DIFFERENT live\n// owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n// standalone save mid-run) owns the database lock, so retry in place.\nfunction decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n  if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n  if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"  childProcess.on('error', (error) => {\n    log(error.stack || error.message);\n    process.exit(1);\n  });\n  if (rssBreachSelfExitInProgress) {\n    rssBreachSelfExitInProgress = false;\n  }\n  return true;\n}\n\n// Pure decision for the exit-86 flow (exported for tests). A lease whose\n// owner is THIS launcher is NOT a bridge target: in supervised mode the\n// pid-lease records the launcher's own pid, so after its child exits 86 the\n// lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n// our own dead socket and route into a self-reap. Only a DIFFERENT live\n// owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n// standalone save mid-run) owns the database lock, so retry in place.\nfunction decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n  if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n  if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };\n  if (attempt <= maxRetries) return { action: 'retry', backoffMs: 2000 * 2 ** (attempt - 1) };\n  return { action: 'report', reason: 'db-lock-held' };\n}\n\n// The daemon refused to become a second writer on a database another live\n// process holds. Prefer bridging to that owner; when the holder is not a\n// bridgeable daemon (e.g. a maintenance script mid-run), retry the launch a\n// few times so a short-lived holder can finish, then report and exit clean.\nasync function handleDbLockHeldChildExit() {\n  dbLockHeldRetries += 1;\n  const leaseResult = isLeaseHeld();\n  const decision = decideDbLockHeldAction({\n    leaseHeld: leaseResult.held,\n    leaseOwnerPid: leaseResult.ownerPid,\n    selfPid: process.pid,\n    attempt: dbLockHeldRetries,\n    maxRetries: DB_LOCK_HELD_MAX_RETRIES,\n  });\n  if (decision.action === 'bridge') {\n    log(`context-server exited: database single-writer lock held; bridging to live owner pid=${leaseResult.ownerPid}`);\n    await bridgeOrReportLeaseHeldAndExit(leaseResult);\n    return;\n  }\n  if (decision.action === 'retry') {\n    log(`database single-writer lock held by a non-bridgeable holder; retrying launch in ${decision.backoffMs}ms (attempt ${dbLockHeldRetries}/${DB_LOCK_HELD_MAX_RETRIES})`);\n    if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = setTimeout(() => {\n      // Abort if the owning runtime vanished (shutdown in progress, or the launcher\n      // was reparented to init without a SIGTERM) — same guard as the primary\n      // backoff-relaunch path, so neither relaunches a daemon under a disposed session.\n      if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) return;\n      launchServer();\n    }, decision.backoffMs);\n    if (supervisorRelaunchTimer.unref) supervisorRelaunchTimer.unref();\n    return;\n  }\n  log('database single-writer lock still held after launch retries; reporting and exiting');\n  writeLeaseHeldJsonRpcError(\n    { ownerPid: leaseResult.ownerPid ?? 'unknown', startedAt: leaseResult.startedAt ?? new Date().toISOString() },\n    decision.reason,\n  );\n  clearAllLeaseFiles();\n  process.exit(0);\n}\n\nasync function shutdownLauncherForSignal(signal) {\n  if (launcherShutdownInProgress) return;\n  launcherShutdownInProgress = true;\n  if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n  if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n  clearOwnerLeaseHeartbeat();\n  hfControl.clearTimers();\n  await hfControl.stopDemandListener();\n\n  // Re-election release path (on by default): release the detached context-server for a live secondary to adopt\n  // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n  // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n  // flag is off this branch is skipped and the original kill path below runs unchanged.\n  if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n    const releasedModelServer = hfControl.getChild();\n    if (isChildRunning(releasedModelServer)) {\n      hfControl.reapProcessTree(releasedModelServer.pid);\n      releasedModelServer.kill(signal);\n      // Escalate to SIGKILL if the non-adoptable model-server does not exit within the grace window,\n      // so the release path does not leave a wedged sidecar behind on its way out.\n      const exited = await waitForChildExit(releasedModelServer, RESPAWN_REAP_GRACE_MS);\n      if (!exited && isChildRunning(releasedModelServer)) {\n        releasedModelServer.kill('SIGKILL');\n      }\n    }\n    log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n    // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n    // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n    process.removeListener('exit', clearAllLeaseFiles);\n    clearOwnerLeaseFile();\n    process.exit(0);\n    return;\n  }\n\n  const children = [];\n  if (isChildRunning(childProcess)) {\n    children.push({ child: childProcess, label: 'context-server' });\n  }\n  const modelServerChild = hfControl.getChild();\n  if (isChildRunning(modelServerChild)) {\n    children.push({ child: modelServerChild, label: 'hf-model-server' });\n  }\n\n  if (children.length === 0) {\n    clearAllLeaseFiles();\n    process.exit(128);\n    return;\n  }\n\n  for (const { child, label } of children) {\n    if (label === 'hf-model-server') {\n      hfControl.reapProcessTree(child.pid);\n    }\n    child.kill(signal);\n  }\n\n  const exited = await Promise.race([\n    Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n    sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n  ]);\n  if (!exited) {\n    for (const { child } of children) {\n      if (isChildRunning(child)) child.kill('SIGKILL');\n    }\n  }\n  clearAllLeaseFiles();\n  process.exit(128);\n}\n\nfunction installSignalHandlers() {\n  for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n    process.on(signal, () => {\n      void shutdownLauncherForSignal(signal).catch((error) => {\n        log(error.stack || error.message);\n        clearAllLeaseFiles();\n        process.exit(128);\n      });\n    });\n  }\n  process.on('uncaughtException', (err) => {\n    try {\n      clearAllLeaseFiles();\n    } catch {\n      // Preserve default uncaughtException crash behavior.\n    }\n    throw err;\n  });\n}\n\nasync function main() {\n  loadProjectEnvFiles();\n  const started = now();\n  const actions = [];\n  let lockHeld = false;\n  let staleRespawnLock = null;","lineStart":1450,"lineEnd":1609,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781761494682,"end":1781761494694}},"metadata":{"openai":{"itemId":"fc_0c3452ad4142cdcd016a3385d694008191b71b079df26e7884"}},"id":"prt_ed942ce99001t4ziZP9rXBqHld","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed9429209001TfpZFoKNoHfTkZ"}}
{"type":"tool_use","timestamp":1781761494697,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_TzfOyitABZOVqaQzxZ9l4oj1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1560,"limit":190},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1560:       } catch (_error: unknown) {\n1561:         // Non-fatal: startup scan must continue even if invalidation hooks fail.\n1562:       }\n1563:     }\n1564: \n1565:     // Log atomicity metrics for monitoring\n1566:     const metrics = transactionManager.getMetrics();\n1567:     if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n1568:       console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n1569:     }\n1570:   } catch (error: unknown) {\n1571:     const message = error instanceof Error ? error.message : String(error);\n1572:     console.error(`[context-server] Startup scan error: ${message}`);\n1573:   } finally {\n1574:     startupScanInProgress = false;\n1575:   }\n1576: }\n1577: \n1578: /* ───────────────────────────────────────────────────────────────\n1579:    7. GRACEFUL SHUTDOWN\n1580: ──────────────────────────────────────────────────────────────── */\n1581: \n1582: let shuttingDown = false;\n1583: // Hoist transport to module scope so shutdown handlers can close it\n1584: let transport: StdioServerTransport | null = null;\n1585: let transportConnectedAt: string | null = null;\n1586: let fileWatcher: FSWatcher | null = null;\n1587: let ipcBridge: IpcSocketServerHandle | null = null;\n1588: let launcherIdleMonitor: LauncherIdleMonitor | null = null;\n1589: \n1590: /** Maximum time (ms) to wait for async cleanup before force-exiting. */\n1591: const SHUTDOWN_DEADLINE_MS = 5000;\n1592: \n1593: /**\n1594:  * Exit code telling the launcher \"another live process holds the database\n1595:  * single-writer lock\": bridge to that owner instead of counting this exit\n1596:  * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n1597:  * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n1598:  * mk-spec-memory-launcher.cjs.\n1599:  */\n1600: const EXIT_DB_LOCK_HELD = 86;\n1601: \n1602: export const __testables = {\n1603:   runCleanupStep,\n1604:   runAsyncCleanupStep,\n1605:   main: () => main(),\n1606:   getBootFtsIntegrityHealth,\n1607:   runCheckpointNeedsRebuildRepair,\n1608:   normalizeGraphFilePath,\n1609:   extractFilePathsFromToolArgs,\n1610: };\n1611: \n1612: async function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n1613:   if (shuttingDown) return;\n1614:   shuttingDown = true;\n1615:   console.error(`[context-server] ${reason}`);\n1616: \n1617:   runCleanupStep('sessionManager', () => sessionManager.shutdown());\n1618:   runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n1619:   // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n1620:   // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n1621:   // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n1622:   runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n1623:   runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n1624:   runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n1625:   runCleanupStep('accessTracker', () => accessTracker.reset());\n1626:   runCleanupStep('toolCache', () => toolCache.shutdown());\n1627:   runCleanupStep('launcherIdleMonitor', () => {\n1628:     if (launcherIdleMonitor) {\n1629:       launcherIdleMonitor.stop();\n1630:       launcherIdleMonitor = null;\n1631:     }\n1632:   });\n1633: \n1634:   let deadlineTimer: NodeJS.Timeout | undefined;\n1635:   const cleanup = (async () => {\n1636:     // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n1637:     // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n1638:     // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n1639:     await runAsyncCleanupStep('startupScan', async () => {\n1640:       if (startupScanPromise) await startupScanPromise;\n1641:     });\n1642:     // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n1643:     // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n1644:     // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n1645:     // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n1646:     // at rest and defeating the durability guarantee. closeDb() is\n1647:     // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n1648:     // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n1649:     // small even if a pathologically slow drain starves this step.\n1650:     await runAsyncCleanupStep('fileWatcher', async () => {\n1651:       if (fileWatcher) {\n1652:         await fileWatcher.close();\n1653:         fileWatcher = null;\n1654:       }\n1655:     });\n1656:     // Fence the ingest worker before closeDb for the same reason as the file\n1657:     // watcher above: the worker writes through the DB and would otherwise reopen\n1658:     // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n1659:     await runAsyncCleanupStep('ingestWorker', async () => {\n1660:       await stopIngestWorker();\n1661:     });\n1662:     runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n1663:     // Close MCP transport on shutdown\n1664:     runCleanupStep('transport', () => {\n1665:       if (transport) {\n1666:         transport.close();\n1667:         transport = null;\n1668:         transportConnectedAt = null;\n1669:       }\n1670:     });\n1671:     await runAsyncCleanupStep('ipcBridge', async () => {\n1672:       if (ipcBridge) {\n1673:         await ipcBridge.close();\n1674:         ipcBridge = null;\n1675:       }\n1676:     });\n1677:     await runAsyncCleanupStep('shutdownHooks', async () => {\n1678:       await runShutdownHooks();\n1679:     });\n1680:     runCleanupStep('registeredTimers', () => clearAllTimers());\n1681:   })();\n1682: \n1683:   const timedOut = await Promise.race([\n1684:     cleanup.then(() => false),\n1685:     new Promise<boolean>((resolve) => {\n1686:       deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n1687:     }),\n1688:   ]);\n1689: \n1690:   if (deadlineTimer) {\n1691:     clearRegisteredTimer(deadlineTimer);\n1692:   }\n1693: \n1694:   if (timedOut) {\n1695:     console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n1696:   }\n1697: \n1698:   process.exit(exitCode);\n1699: }\n1700: \n1701: /** Remove indexed rows for watcher delete and rename events. */\n1702: async function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n1703:   const database = vectorIndex.getDb();\n1704:   if (!database) {\n1705:     return;\n1706:   }\n1707: \n1708:   const canonicalPath = getCanonicalPathKey(filePath);\n1709:   let rows: Array<{ id: number; spec_folder: string | null }> = [];\n1710: \n1711:   try {\n1712:     rows = database.prepare(`\n1713:       SELECT id, spec_folder\n1714:       FROM memory_index\n1715:       WHERE canonical_file_path = ? OR file_path = ?\n1716:       ORDER BY id ASC\n1717:     `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n1718:   } catch (_error: unknown) {\n1719:     rows = database.prepare(`\n1720:       SELECT id, spec_folder\n1721:       FROM memory_index\n1722:       WHERE file_path = ?\n1723:       ORDER BY id ASC\n1724:     `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n1725:   }\n1726: \n1727:   let deletedCount = 0;\n1728:   for (const row of rows) {\n1729:     if (typeof row.id === 'number') {\n1730:       if (vectorIndex.deleteMemory(row.id)) {\n1731:         deletedCount += 1;\n1732:         // Record DELETE history only after confirmed deletion.\n1733:         try {\n1734:           recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n1735:         } catch (_histErr: unknown) {\n1736:           // History recording is best-effort in file-watcher path\n1737:         }\n1738:       }\n1739:     }\n1740:   }\n1741: \n1742:   if (deletedCount > 0) {\n1743:     try {\n1744:       runPostMutationHooks('delete', { filePath, deletedCount });\n1745:     } catch (_error: unknown) {\n1746:       // Non-throwing by design: file-watcher path must not crash the server.\n1747:     }\n1748:   }\n1749: }\n\n(Showing lines 1560-1749 of 2341. Use offset=1750 to continue.)\n</content>","metadata":{"preview":"      } catch (_error: unknown) {\n        // Non-fatal: startup scan must continue even if invalidation hooks fail.\n      }\n    }\n\n    // Log atomicity metrics for monitoring\n    const metrics = transactionManager.getMetrics();\n    if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n      console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Startup scan error: ${message}`);\n  } finally {\n    startupScanInProgress = false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. GRACEFUL SHUTDOWN","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"      } catch (_error: unknown) {\n        // Non-fatal: startup scan must continue even if invalidation hooks fail.\n      }\n    }\n\n    // Log atomicity metrics for monitoring\n    const metrics = transactionManager.getMetrics();\n    if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n      console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Startup scan error: ${message}`);\n  } finally {\n    startupScanInProgress = false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. GRACEFUL SHUTDOWN\n──────────────────────────────────────────────────────────────── */\n\nlet shuttingDown = false;\n// Hoist transport to module scope so shutdown handlers can close it\nlet transport: StdioServerTransport | null = null;\nlet transportConnectedAt: string | null = null;\nlet fileWatcher: FSWatcher | null = null;\nlet ipcBridge: IpcSocketServerHandle | null = null;\nlet launcherIdleMonitor: LauncherIdleMonitor | null = null;\n\n/** Maximum time (ms) to wait for async cleanup before force-exiting. */\nconst SHUTDOWN_DEADLINE_MS = 5000;\n\n/**\n * Exit code telling the launcher \"another live process holds the database\n * single-writer lock\": bridge to that owner instead of counting this exit\n * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n * mk-spec-memory-launcher.cjs.\n */\nconst EXIT_DB_LOCK_HELD = 86;\n\nexport const __testables = {\n  runCleanupStep,\n  runAsyncCleanupStep,\n  main: () => main(),\n  getBootFtsIntegrityHealth,\n  runCheckpointNeedsRebuildRepair,\n  normalizeGraphFilePath,\n  extractFilePathsFromToolArgs,\n};\n\nasync function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  console.error(`[context-server] ${reason}`);\n\n  runCleanupStep('sessionManager', () => sessionManager.shutdown());\n  runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n  // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n  // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n  // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n  runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n  runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n  runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n  runCleanupStep('accessTracker', () => accessTracker.reset());\n  runCleanupStep('toolCache', () => toolCache.shutdown());\n  runCleanupStep('launcherIdleMonitor', () => {\n    if (launcherIdleMonitor) {\n      launcherIdleMonitor.stop();\n      launcherIdleMonitor = null;\n    }\n  });\n\n  let deadlineTimer: NodeJS.Timeout | undefined;\n  const cleanup = (async () => {\n    // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n    // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n    // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n    await runAsyncCleanupStep('startupScan', async () => {\n      if (startupScanPromise) await startupScanPromise;\n    });\n    // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n    // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n    // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n    // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n    // at rest and defeating the durability guarantee. closeDb() is\n    // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n    // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n    // small even if a pathologically slow drain starves this step.\n    await runAsyncCleanupStep('fileWatcher', async () => {\n      if (fileWatcher) {\n        await fileWatcher.close();\n        fileWatcher = null;\n      }\n    });\n    // Fence the ingest worker before closeDb for the same reason as the file\n    // watcher above: the worker writes through the DB and would otherwise reopen\n    // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n    await runAsyncCleanupStep('ingestWorker', async () => {\n      await stopIngestWorker();\n    });\n    runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n    // Close MCP transport on shutdown\n    runCleanupStep('transport', () => {\n      if (transport) {\n        transport.close();\n        transport = null;\n        transportConnectedAt = null;\n      }\n    });\n    await runAsyncCleanupStep('ipcBridge', async () => {\n      if (ipcBridge) {\n        await ipcBridge.close();\n        ipcBridge = null;\n      }\n    });\n    await runAsyncCleanupStep('shutdownHooks', async () => {\n      await runShutdownHooks();\n    });\n    runCleanupStep('registeredTimers', () => clearAllTimers());\n  })();\n\n  const timedOut = await Promise.race([\n    cleanup.then(() => false),\n    new Promise<boolean>((resolve) => {\n      deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n    }),\n  ]);\n\n  if (deadlineTimer) {\n    clearRegisteredTimer(deadlineTimer);\n  }\n\n  if (timedOut) {\n    console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n  }\n\n  process.exit(exitCode);\n}\n\n/** Remove indexed rows for watcher delete and rename events. */\nasync function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return;\n  }\n\n  const canonicalPath = getCanonicalPathKey(filePath);\n  let rows: Array<{ id: number; spec_folder: string | null }> = [];\n\n  try {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE canonical_file_path = ? OR file_path = ?\n      ORDER BY id ASC\n    `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n  } catch (_error: unknown) {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE file_path = ?\n      ORDER BY id ASC\n    `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n  }\n\n  let deletedCount = 0;\n  for (const row of rows) {\n    if (typeof row.id === 'number') {\n      if (vectorIndex.deleteMemory(row.id)) {\n        deletedCount += 1;\n        // Record DELETE history only after confirmed deletion.\n        try {\n          recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n        } catch (_histErr: unknown) {\n          // History recording is best-effort in file-watcher path\n        }\n      }\n    }\n  }\n\n  if (deletedCount > 0) {\n    try {\n      runPostMutationHooks('delete', { filePath, deletedCount });\n    } catch (_error: unknown) {\n      // Non-throwing by design: file-watcher path must not crash the server.\n    }\n  }\n}","lineStart":1560,"lineEnd":1749,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781761494676,"end":1781761494695}},"metadata":{"openai":{"itemId":"fc_0c3452ad4142cdcd016a3385d693a88191a6992b5898052cca"}},"id":"prt_ed942ce7b0011IbD6ij0KTLZFd","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed9429209001TfpZFoKNoHfTkZ"}}
