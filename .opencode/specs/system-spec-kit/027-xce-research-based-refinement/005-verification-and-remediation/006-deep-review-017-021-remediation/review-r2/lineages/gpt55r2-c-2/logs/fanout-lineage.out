om,\n290:       path: ['confirm'],\n291:       message: 'confirm:true is required for every memory_delete mutation',\n292:     });\n293:   }\n294: \n295:   if (value.id === undefined && value.specFolder === undefined) {\n296:     ctx.addIssue({\n297:       code: z.ZodIssueCode.custom,\n298:       path: ['id'],\n299:       message: 'Either id or specFolder is required',\n300:     });\n301:   }\n302: });\n303: \n304: const memoryUpdateSchema = getSchema({\n305:   id: positiveInt,\n306:   title: z.string().optional(),\n307:   triggerPhrases: optionalStringArray,\n308:   importanceWeight: boundedNumber(0, 1).optional(),\n309:   importanceTier: importanceTierEnum.optional(),\n310:   allowPartialUpdate: z.boolean().optional(),\n311: });\n312: \n313: const memoryValidateSchema = getSchema({\n314:   id: positiveInt,\n315:   wasUseful: z.boolean(),\n316:   queryId: z.string().optional(),\n317:   queryTerms: optionalStringArray,\n318:   resultRank: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n319:   totalResultsShown: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n320:   searchMode: z.string().optional(),\n321:   intent: z.string().optional(),\n322:   sessionId: z.string().optional(),\n323:   notes: z.string().optional(),\n324: });\n325: \n326: export const memoryBulkDeleteSchema = getSchema({\n327:   tier: importanceTierEnum,\n328:   specFolder: optionalPathString(),\n329:   confirm: z.literal(true),\n330:   olderThanDays: safeNumericPreprocess\n331:     .pipe(z.number().int().min(MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS))\n332:     .optional(),\n333:   skipCheckpoint: z.boolean().optional(),\n334: });\n335: \n336: export const memoryRetentionSweepSchema = getSchema({\n337:   dryRun: z.boolean().optional(),\n338: });\n339: \n340: export const memoryEmbeddingReconcileSchema = getSchema({\n341:   mode: z.enum(['dry-run', 'apply']).optional(),\n342:   activeOnly: z.boolean().optional(),\n343:   resetMissing: z.boolean().optional(),\n344:   missingFailureScope: z.enum(['retry-retention']).optional(),\n345:   maskedFailedPolicy: z.enum(['reconcile']).optional(),\n346:   providerFailurePolicy: z.enum(['report-only']).optional(),\n347:   requireActiveShard: z.boolean().optional(),\n348:   repairSuccessCoverage: z.boolean().optional(),\n349: });\n350: \n351: const memoryListSchema = getSchema({\n352:   limit: positiveIntMax(100).optional(),\n353:   offset: safeNumericPreprocess.pipe(z.number().int().min(0)).optional(),\n354:   specFolder: optionalPathString(),\n355:   sortBy: z.enum(['created_at', 'updated_at', 'importance_weight']).optional(),\n356:   includeChunks: z.boolean().optional(),\n357: });\n358: \n359: const memoryStatsSchema = getSchema({\n360:   folderRanking: z.enum(['count', 'recency', 'importance', 'composite']).optional(),\n361:   excludePatterns: optionalStringArray,\n362:   includeScores: z.boolean().optional(),\n363:   includeArchived: z.boolean().optional(),\n364:   limit: positiveIntMax(100).optional(),\n365: });\n366: \n367: const memoryHealthSchema = getSchema({\n368:   reportMode: z.enum(['full', 'divergent_aliases']).optional(),\n369:   includeFullReport: z.boolean().optional(),\n370:   limit: positiveIntMax(200).optional(),\n371:   specFolder: optionalPathString(),\n372:   autoRepair: z.boolean().optional(),\n373:   confirmed: z.boolean().optional(),\n374:   cleanFiles: z.boolean().optional(),\n375: });\n376: \n377: const checkpointCreateSchema = getSchema({\n378:   name: z.string().min(1),\n379:   includeEmbeddings: z.boolean().optional(),\n380:   specFolder: optionalPathString(),\n\n(Showing lines 261-380 of 818. Use offset=381 to continue.)\n</content>","metadata":{"preview":"  provenanceActor: z.string().optional(),\n  governedAt: z.string().optional(),\n  retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n  deleteAfter: z.string().optional(),\n});\n\nconst governanceSchemaFields = {\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  sessionId: z.string().optional(),\n  provenanceSource: z.string().optional(),\n  provenanceActor: z.string().optional(),\n  governedAt: z.string().optional(),\n  retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n  deleteAfter: z.string().optional(),\n};\n\n// Destructive delete: every mutation path requires `confirm: true`.\n// Branch 1 requires `id` + `confirm` (single-record delete).","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","text":"  provenanceActor: z.string().optional(),\n  governedAt: z.string().optional(),\n  retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n  deleteAfter: z.string().optional(),\n});\n\nconst governanceSchemaFields = {\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  sessionId: z.string().optional(),\n  provenanceSource: z.string().optional(),\n  provenanceActor: z.string().optional(),\n  governedAt: z.string().optional(),\n  retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n  deleteAfter: z.string().optional(),\n};\n\n// Destructive delete: every mutation path requires `confirm: true`.\n// Branch 1 requires `id` + `confirm` (single-record delete).\n// Branch 2 requires `specFolder` + `confirm` (bulk folder delete).\nconst memoryDeleteSchema = getSchema({\n  id: positiveInt.optional().describe('Memory ID to delete (required unless specFolder + confirm provided for bulk)'),\n  specFolder: optionalPathString().describe('Spec folder scope for bulk delete (requires confirm: true)'),\n  confirm: z.literal(true).optional().describe('Must be true for every delete mutation'),\n}).superRefine((value, ctx) => {\n  if (value.confirm !== true) {\n    ctx.addIssue({\n      code: z.ZodIssueCode.custom,\n      path: ['confirm'],\n      message: 'confirm:true is required for every memory_delete mutation',\n    });\n  }\n\n  if (value.id === undefined && value.specFolder === undefined) {\n    ctx.addIssue({\n      code: z.ZodIssueCode.custom,\n      path: ['id'],\n      message: 'Either id or specFolder is required',\n    });\n  }\n});\n\nconst memoryUpdateSchema = getSchema({\n  id: positiveInt,\n  title: z.string().optional(),\n  triggerPhrases: optionalStringArray,\n  importanceWeight: boundedNumber(0, 1).optional(),\n  importanceTier: importanceTierEnum.optional(),\n  allowPartialUpdate: z.boolean().optional(),\n});\n\nconst memoryValidateSchema = getSchema({\n  id: positiveInt,\n  wasUseful: z.boolean(),\n  queryId: z.string().optional(),\n  queryTerms: optionalStringArray,\n  resultRank: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n  totalResultsShown: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n  searchMode: z.string().optional(),\n  intent: z.string().optional(),\n  sessionId: z.string().optional(),\n  notes: z.string().optional(),\n});\n\nexport const memoryBulkDeleteSchema = getSchema({\n  tier: importanceTierEnum,\n  specFolder: optionalPathString(),\n  confirm: z.literal(true),\n  olderThanDays: safeNumericPreprocess\n    .pipe(z.number().int().min(MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS))\n    .optional(),\n  skipCheckpoint: z.boolean().optional(),\n});\n\nexport const memoryRetentionSweepSchema = getSchema({\n  dryRun: z.boolean().optional(),\n});\n\nexport const memoryEmbeddingReconcileSchema = getSchema({\n  mode: z.enum(['dry-run', 'apply']).optional(),\n  activeOnly: z.boolean().optional(),\n  resetMissing: z.boolean().optional(),\n  missingFailureScope: z.enum(['retry-retention']).optional(),\n  maskedFailedPolicy: z.enum(['reconcile']).optional(),\n  providerFailurePolicy: z.enum(['report-only']).optional(),\n  requireActiveShard: z.boolean().optional(),\n  repairSuccessCoverage: z.boolean().optional(),\n});\n\nconst memoryListSchema = getSchema({\n  limit: positiveIntMax(100).optional(),\n  offset: safeNumericPreprocess.pipe(z.number().int().min(0)).optional(),\n  specFolder: optionalPathString(),\n  sortBy: z.enum(['created_at', 'updated_at', 'importance_weight']).optional(),\n  includeChunks: z.boolean().optional(),\n});\n\nconst memoryStatsSchema = getSchema({\n  folderRanking: z.enum(['count', 'recency', 'importance', 'composite']).optional(),\n  excludePatterns: optionalStringArray,\n  includeScores: z.boolean().optional(),\n  includeArchived: z.boolean().optional(),\n  limit: positiveIntMax(100).optional(),\n});\n\nconst memoryHealthSchema = getSchema({\n  reportMode: z.enum(['full', 'divergent_aliases']).optional(),\n  includeFullReport: z.boolean().optional(),\n  limit: positiveIntMax(200).optional(),\n  specFolder: optionalPathString(),\n  autoRepair: z.boolean().optional(),\n  confirmed: z.boolean().optional(),\n  cleanFiles: z.boolean().optional(),\n});\n\nconst checkpointCreateSchema = getSchema({\n  name: z.string().min(1),\n  includeEmbeddings: z.boolean().optional(),\n  specFolder: optionalPathString(),","lineStart":261,"lineEnd":380,"totalLines":818,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","time":{"start":1781761574528,"end":1781761574535}},"metadata":{"openai":{"itemId":"fc_0634ab167471e5d0016a3386251e308191a7bc2d6636f52022"}},"id":"prt_ed94400fa001DK1f2GnzTfIF7o","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943f1e600189O0zxqbJ1Exct"}}
