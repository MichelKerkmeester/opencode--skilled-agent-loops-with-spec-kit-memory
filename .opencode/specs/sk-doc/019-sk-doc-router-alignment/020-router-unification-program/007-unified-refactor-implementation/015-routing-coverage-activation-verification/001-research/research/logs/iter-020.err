   824	  if (launcherLease.held && !launcherLease.staleReclaimable) {
   825	    clearOwnerLeaseFile();
   826	    await bridgeOrReportLeaseHeld(launcherLease);
   827	    return true;
   828	  }
   829	  if (launcherLease.staleReclaimable) {
   830	    log('staleReclaimed: true');
   831	    const staleLease = readLeaseFile();
   832	    const staleChildPid = Number.isInteger(staleLease?.childPid) && staleLease.childPid > 0
   833	      ? staleLease.childPid
   834	      : null;
   835	    if (staleChildPid && processLiveness(staleChildPid) !== 'dead') {
   836	      const staleChildLeaseResult = {
   837	        held: true,
   838	        ownerPid: staleChildPid,
   839	        staleReclaimable: false,
   840	        startedAt: staleLease.startedAt ?? new Date(0).toISOString(),
   841	        legacyPath: null,
   842	        socketPath: typeof staleLease.socketPath === 'string' ? staleLease.socketPath : null,
   843	      };
   844	      if (socketPathUsable(staleChildLeaseResult.socketPath)) {
   845	        const decision = await bridgeOrReportLeaseHeld(staleChildLeaseResult);
   846	        if (decision?.action === 'bridge' || decision?.action === 'respawn') {
   847	          return true;
   848	        }
   849	        if (decision?.reason !== 'no-bridge-socket') {
   850	          clearOwnerLeaseFile();
   851	          return true;
   852	        }
   853	      }
   854	      scheduleBootstrapReap(staleChildPid);
   855	      log(`stale launcher lease recorded live childPid=${staleChildPid}; deferring reap until bootstrap lock is held`);
   856	    } else if (staleChildPid) {
   857	      scheduleBootstrapReap(staleChildPid);
