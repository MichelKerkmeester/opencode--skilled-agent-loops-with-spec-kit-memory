   171	function scoreFixture(fixture, outputPath) {
   172	  if (!fs.existsSync(outputPath)) {
   173	    return {
   174	      id: fixture.id,
   175	      outputPath,
   176	      score: 0,
   177	      maxScore: 100,
   178	      passed: false,
   179	      missingHeadings: fixture.requiredHeadings || [],
   180	      missingPatterns: fixture.requiredPatterns || [],
   181	      forbiddenMatches: [],
   182	      failureModes: ['missing-output'],
   183	    };
   184	  }
   185	
   186	  const content = fs.readFileSync(outputPath, 'utf8');
   187	  const missingHeadings = (fixture.requiredHeadings || []).filter((heading) => !content.includes(heading));
   188	  const patternRegexes = compilePatterns(fixture.requiredPatterns);
   189	  const missingPatterns = patternRegexes
   190	    .map((regex, index) => ({ regex, source: fixture.requiredPatterns[index] }))
   191	    .filter((entry) => !safeRegexTest(entry.regex, content))
   192	    .map((entry) => entry.source);
   193	  const forbiddenRegexes = compilePatterns(fixture.forbiddenPatterns);
   194	  const forbiddenMatches = forbiddenRegexes
   195	    .map((regex, index) => ({ regex, source: fixture.forbiddenPatterns[index] }))
   196	    .filter((entry) => safeRegexTest(entry.regex, content))
   197	    .map((entry) => entry.source);
   198	
   199	  const headingScore =
   200	    (fixture.requiredHeadings || []).length === 0
   201	      ? 45
   202	      : Math.round(45 * (((fixture.requiredHeadings || []).length - missingHeadings.length) / (fixture.requiredHeadings || []).length));
   203	  const patternScore =
   204	    (fixture.requiredPatterns || []).length === 0
   205	      ? 35
   206	      : Math.round(35 * (((fixture.requiredPatterns || []).length - missingPatterns.length) / (fixture.requiredPatterns || []).length));
   207	  const cleanScore =
   208	    (fixture.forbiddenPatterns || []).length === 0
   209	      ? 20
   210	      : Math.round(20 * (((fixture.forbiddenPatterns || []).length - forbiddenMatches.length) / (fixture.forbiddenPatterns || []).length));
   211	
   212	  const score = headingScore + patternScore + cleanScore;
   213	  const failureModes = [];
   214	  if (missingHeadings.length > 0) {
   215	    failureModes.push('missing-headings');
   216	  }
   217	  if (missingPatterns.length > 0) {
   218	    failureModes.push('missing-required-patterns');
   219	  }
   220	  if (forbiddenMatches.length > 0) {
   221	    failureModes.push('forbidden-patterns');
   222	  }
   223	
   224	  return {
   225	    id: fixture.id,
   226	    outputPath,
   227	    score,
   228	    maxScore: 100,
   229	    passed: failureModes.length === 0,
   230	    missingHeadings,
   231	    missingPatterns,
   232	    forbiddenMatches,
   233	    failureModes,
   234	  };
   235	}
   236	
   237	function aggregateFailureModes(fixtures) {
   238	  const counts = {};
   239	  for (const fixture of fixtures) {
   240	    for (const mode of fixture.failureModes || []) {
   241	      counts[mode] = (counts[mode] || 0) + 1;
   242	    }
   243	  }
   244	  return Object.entries(counts)
   245	    .sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0]))
   246	    .map(([mode]) => mode);
   247	}
