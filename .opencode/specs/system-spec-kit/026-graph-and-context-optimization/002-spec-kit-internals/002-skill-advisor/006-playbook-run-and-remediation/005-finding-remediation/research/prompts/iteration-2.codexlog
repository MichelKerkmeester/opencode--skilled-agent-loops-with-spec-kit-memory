   690	def _load_skill_graph_sqlite() -> Optional[Dict[str, Any]]:
   691	    """Load compiled-equivalent skill graph data from SQLite."""
   692	    if not os.path.exists(SKILL_GRAPH_SQLITE_PATH):
   693	        return None
   694	
   695	    try:
   696	        with sqlite3.connect(SKILL_GRAPH_SQLITE_PATH) as connection:
   697	            connection.row_factory = sqlite3.Row
   698	
   699	            node_rows = connection.execute(
   700	                "SELECT id, family, intent_signals, derived FROM skill_nodes ORDER BY id ASC"
   701	            ).fetchall()
   702	            if not node_rows:
   703	                return None
   704	
   705	            edge_rows = connection.execute(
   706	                """
   707	                SELECT source_id, target_id, edge_type, weight
   708	                FROM skill_edges
   709	                ORDER BY source_id ASC, edge_type ASC, target_id ASC
   710	                """
   711	            ).fetchall()
   712	
   713	            schema_row = connection.execute(
   714	                "SELECT version FROM schema_version LIMIT 1"
   715	            ).fetchone()
   716	            generated_at_row = connection.execute(
   717	                "SELECT value FROM skill_graph_metadata WHERE key = 'last_scan_timestamp'"
   718	            ).fetchone()
   719	            # T-SGC-02 / R45-003: durable topology-warning payload.
   720	            topology_warnings_row = connection.execute(
   721	                "SELECT value FROM skill_graph_metadata WHERE key = 'topology_warnings'"
   722	            ).fetchone()
   723	    except sqlite3.Error:
   724	        return None
   725	
   726	    try:
   727	        families: Dict[str, List[str]] = {}
   728	        adjacency: Dict[str, Dict[str, Dict[str, float]]] = {}
   729	        signals: Dict[str, List[str]] = {}
   730	        conflicts: Set[tuple[str, str]] = set()
   731	
   732	        for node_row in node_rows:
   733	            skill_id = str(node_row["id"])
   734	            family = str(node_row["family"])
   735	            families.setdefault(family, []).append(skill_id)
   736	
   737	            raw_signals = node_row["intent_signals"]
   738	            if raw_signals:
   739	                _extend_signal_map(signals, skill_id, json.loads(raw_signals))
   740	
   741	            raw_derived = node_row["derived"]
   742	            if raw_derived:
   743	                parsed_derived = json.loads(raw_derived)
   744	                if isinstance(parsed_derived, dict):
   745	                    _extend_signal_map(signals, skill_id, parsed_derived.get("trigger_phrases"))
   746	
   747	        for edge_row in edge_rows:
   748	            source_id = str(edge_row["source_id"])
   749	            target_id = str(edge_row["target_id"])
   750	            edge_type = str(edge_row["edge_type"])
   751	            weight = float(edge_row["weight"])
   752	
   753	            if edge_type == "conflicts_with":
   754	                conflicts.add(tuple(sorted((source_id, target_id))))
   755	                continue
   756	
   757	            if edge_type not in GRAPH_ADJACENCY_EDGE_TYPES:
   758	                continue
   759	
   760	            adjacency.setdefault(source_id, {}).setdefault(edge_type, {})[target_id] = weight

