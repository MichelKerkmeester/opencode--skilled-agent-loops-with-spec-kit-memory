us":"pending","priority":"medium"}],"truncated":false},"title":"5 todos","time":{"start":1781756687436,"end":1781756687438}},"metadata":{"openai":{"itemId":"fc_06a034a006a6babc016a33730f16f88191934e2b325702095f"}},"id":"prt_ed8f972ff001GMjGyZTX6zNnqQ","sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","messageID":"msg_ed8f930ef001dwm1MWMshoc5eM"}}
