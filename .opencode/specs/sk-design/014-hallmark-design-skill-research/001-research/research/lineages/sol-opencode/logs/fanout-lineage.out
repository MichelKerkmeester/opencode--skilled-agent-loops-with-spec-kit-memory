folders)\n  // and no matching packet for current target → allocate next pt-NN\n  const subfolder = allocateShortSubfolder(rootDir, path.basename(resolved));\n  return {\n    rootDir,\n    subfolder,\n    artifactDir: path.join(rootDir, subfolder),\n    artifactArchiveRoot: path.join(artifactArchiveRoot, subfolder),\n  };\n}\n\nmodule.exports = {\n  resolveArtifactRoot,\n  allocateShortSubfolder,\n  normalizeSpecFolderReference,\n};","lineStart":321,"lineEnd":362,"totalLines":362,"truncated":false}},"title":".opencode/skills/system-spec-kit/shared/review-research-paths.cjs","time":{"start":1784525319108,"end":1784525319113}},"metadata":{"openai":{"itemId":"fc_0bae694cd7a847e9016a5db20449648191b468d4dcb83c50f8"}},"id":"prt_f7dff60b7001hc21F0FkPpCSBX","sessionID":"ses_08202bafbffe7aMYl1BZMs5SAo","messageID":"msg_f7dff51d80012Z9dc3DpPSvebG"}}
