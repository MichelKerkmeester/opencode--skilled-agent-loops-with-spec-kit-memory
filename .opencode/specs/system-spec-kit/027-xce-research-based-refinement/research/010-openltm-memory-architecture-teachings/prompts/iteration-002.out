            const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n1741:             (result as Record<string, unknown>).score = boostedScore;\n1742:             if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n1743:             if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n1744:           }\n1745:         }\n1746:       }\n1747:       // Re-sort after co-activation boost to ensure boosted results\n1748:       // Are promoted to their correct position in the ranking\n1749:       reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n1750:     } catch (err: unknown) {\n1751:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1752:       console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n1753:     }\n1754:   }\n1755: \n1756:   // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n1757:   if (db && isFolderScoringEnabled() && reranked.length > 0) {\n1758:     try {\n1759:       const numericIds = reranked\n1760:         .map(r => r.id)\n1761:         .filter((id): id is number => typeof id === 'number');\n1762: \n1763:       if (numericIds.length > 0) {\n1764:         const folderMap = lookupFolders(db, numericIds);\n1765:         if (folderMap.size > 0) {\n1766:           const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n1767:           const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n1768:           const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n1769:           const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n1770: \n1771:           const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n1772:           const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n1773:           reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n1774:         }\n1775:       }\n1776:     } catch (_folderErr: unknown) {\n1777:       // Folder scoring is optional and must not break retrieval\n1778:     }\n1779:   }\n\n(Showing lines 1710-1779 of 2756. Use offset=1780 to continue.)\n</content>","metadata":{"preview":"              source: 'vector',\n            };\n          });\n\n          // Merge: diversified embedded rows first (MMR-ordered), then\n          // non-embedded rows in their original relative order.\n          reranked = [...diversifiedRows, ...nonEmbeddedRows];\n        }\n      } catch (embErr: unknown) {\n        const msg = embErr instanceof Error ? embErr.message : String(embErr);\n        console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n      }\n    }\n  }\n\n  // Co-activation spreading — enrich with temporal neighbors\n  const topIds = reranked\n    .slice(0, SPREAD_ACTIVATION_TOP_N)\n    .map(r => r.id)\n    .filter((id): id is number => typeof id === 'number');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"              source: 'vector',\n            };\n          });\n\n          // Merge: diversified embedded rows first (MMR-ordered), then\n          // non-embedded rows in their original relative order.\n          reranked = [...diversifiedRows, ...nonEmbeddedRows];\n        }\n      } catch (embErr: unknown) {\n        const msg = embErr instanceof Error ? embErr.message : String(embErr);\n        console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n      }\n    }\n  }\n\n  // Co-activation spreading — enrich with temporal neighbors\n  const topIds = reranked\n    .slice(0, SPREAD_ACTIVATION_TOP_N)\n    .map(r => r.id)\n    .filter((id): id is number => typeof id === 'number');\n  if (topIds.length > 0) {\n    try {\n      const spreadResults: SpreadResult[] = spreadActivation(topIds);\n      // Boost scores of results that appear in co-activation graph\n      if (spreadResults.length > 0) {\n        const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n        for (const result of reranked) {\n          const boost = spreadMap.get(result.id as number);\n          if (boost !== undefined) {\n            // Update all score aliases so downstream consumers see the boost.\n            const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n            (result as Record<string, unknown>).score = boostedScore;\n            if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n            if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n          }\n        }\n      }\n      // Re-sort after co-activation boost to ensure boosted results\n      // Are promoted to their correct position in the ranking\n      reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n  if (db && isFolderScoringEnabled() && reranked.length > 0) {\n    try {\n      const numericIds = reranked\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length > 0) {\n        const folderMap = lookupFolders(db, numericIds);\n        if (folderMap.size > 0) {\n          const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n          const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n          const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n          const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n\n          const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n          const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n          reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n        }\n      }\n    } catch (_folderErr: unknown) {\n      // Folder scoring is optional and must not break retrieval\n    }\n  }","lineStart":1710,"lineEnd":1779,"totalLines":2756,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1780925328501,"end":1780925328527}},"metadata":{"openai":{"itemId":"fc_0752ecbcaf7741ea016a26c38ff410819192d90b9b0bc9369f"}},"id":"prt_ea76bec6a001pepG2JWfgbI4hw","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76bc38f001t8Qxft3dTEc5w7"}}
