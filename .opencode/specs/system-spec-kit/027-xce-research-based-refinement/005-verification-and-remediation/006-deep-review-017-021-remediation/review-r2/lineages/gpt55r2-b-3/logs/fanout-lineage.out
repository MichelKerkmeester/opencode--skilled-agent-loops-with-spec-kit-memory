{"type":"tool_use","timestamp":1781761986607,"sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","part":{"type":"tool","tool":"read","callID":"call_J8b28KBTWIUxwir0yCxoOr6A","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Save Handler\n3: // ───────────────────────────────────────────────────────────────\n4: /* --- 1. DEPENDENCIES --- */\n5: \n6: // Node built-ins\n7: import { createHash, randomUUID } from 'node:crypto';\n8: import * as fs from 'node:fs';\n9: import path from 'path';\n10: \n11: // Shared packages\n12: import { validateFilePath } from '@spec-kit/shared/utils/path-security';\n13: import {\n14:   evaluateMemorySufficiency,\n15:   MEMORY_SUFFICIENCY_REJECTION_CODE,\n16:   type MemorySufficiencyResult,\n17: } from '@spec-kit/shared/parsing/memory-sufficiency';\n18: import {\n19:   validateMemoryTemplateContract,\n20:   type MemoryTemplateContractResult,\n21: } from '@spec-kit/shared/parsing/memory-template-contract';\n22: import {\n23:   evaluateSpecDocHealth,\n24:   type SpecDocHealthResult,\n25: } from '@spec-kit/shared/parsing/spec-doc-health';\n26: \n27: // Internal modules\n28: import { ALLOWED_BASE_PATHS, checkDatabaseUpdated } from '../core/index.js';\n29: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n30: import { scrubSecretsDetailed } from '../lib/parsing/secret-scrubber.js';\n31: import { createFilePathValidator } from '../utils/validators.js';\n32: import * as memoryParser from '../lib/parsing/memory-parser.js';\n33: import * as transactionManager from '../lib/storage/transaction-manager.js';\n34: import * as checkpoints from '../lib/storage/checkpoints.js';\n35: import * as preflight from '../lib/validation/preflight.js';\n36: import { requireDb } from '../utils/index.js';\n37: import type { MCPResponse } from './types.js';\n38: import { createAppendOnlyMemoryRecord, recordLineageVersion, retirePredecessorForActiveReindex } from '../lib/storage/lineage-state.js';\n39: import { determineAction } from '../lib/storage/reconsolidation.js';\n40: import * as causalEdges from '../lib/storage/causal-edges.js';\n41: \n42: import { runQualityGate, isQualityGateEnabled } from '../lib/validation/save-quality-gate.js';\n43: import {\n44:   isPostInsertEnrichmentEnabled,\n45:   isPostInsertEnrichmentAsync,\n46:   isSaveQualityGateEnabled,\n47:   isSaveReconsolidationEnabled,\n48:   resolveSavePlannerMode,\n49: } from '../lib/search/search-flags.js';\n50: \n51: import { getCanonicalPathKey, resolveCanonicalPath } from '../lib/utils/canonical-path.js';\n52: import { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../lib/utils/index-scope.js';\n53: import { findSimilarMemories } from './pe-gating.js';\n54: import { runPostMutationHooks } from './mutation-hooks.js';\n55: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n56: import { indexChunkedMemoryFile, shouldUseChunkedIndexing } from './chunking-orchestrator.js';\n57: import { applyPostInsertMetadata } from './save/db-helpers.js';\n58: import {\n59:   createMemoryRecord,\n60:   findSamePathExistingMemory,\n61:   type CreateRecordIdentityHints,\n62:   type MemoryScopeMatch,\n63: } from './save/create-record.js';\n64: import {\n65:   buildGovernanceLogicalKey,\n66:   buildGovernancePostInsertFields,\n67:   ensureGovernanceRuntime,\n68:   recordGovernanceAudit,\n69:   recordTierDowngradeAudit,\n70:   validateGovernedIngest,\n71:   type GovernanceDecision,\n72: } from '../lib/governance/scope-governance.js';\n73: import { delete_memory_from_database } from '../lib/search/vector-index-mutations.js';\n74: import {\n75:   runQualityLoop,\n76: } from './quality-loop.js';\n77: import type {\n78:   QualityLoopResult,\n79: } from './quality-loop.js';\n80: \n81: // O2-5/O2-12: V-rule validation (previously only in workflow path)\n82: import {\n83:   validateMemoryQualityContent,\n84:   determineValidationDisposition,\n85: } from './v-rule-bridge.js';\n86: \n87: // Save pipeline modules\n88: import type {\n89:   IndexResult,\n90:   RouteCategory,\n91:   MergeModeHint,\n92:   SaveArgs,\n93:   AtomicSaveParams,\n94:   AtomicSaveOptions,\n95:   AtomicSaveResult,\n96:   PlannerAdvisory,\n97:   PlannerBlocker,\n98:   PlannerFollowUpAction,\n99:   PlannerRouteTarget,\n100: } from './save/index.js';\n101: import { checkExistingRow, checkContentHashDedup } from './save/dedup.js';\n102: import { generateOrCacheEmbedding, persistPendingEmbeddingCacheWrite } from './save/embedding-pipeline.js';\n103: import { evaluateAndApplyPeDecision } from './save/pe-orchestration.js';\n104: import {\n105:   findScopeFilteredCandidates,\n106:   getRequestedScope,\n107:   runReconsolidationIfEnabled,\n108: } from './save/reconsolidation-bridge.js';\n109: import {\n110:   runPostInsertEnrichmentIfEnabled,\n111:   runPostInsertEnrichment,\n112:   shouldRunPostInsertEnrichment,\n113:   buildDeferredEnrichmentResult,\n114: } from './save/post-insert.js';\n115: import type { PostInsertEnrichmentResult } from './save/post-insert.js';\n116: import {\n117:   markEnrichmentPending,\n118:   needsEnrichmentRepair,\n119:   POST_INSERT_ENRICHMENT_VERSION,\n120:   recordEnrichmentResult,\n121:   repairEnrichmentOnReplay,\n122: } from './save/enrichment-state.js';\n123: import {\n124:   buildIndexResult,\n125:   buildPlannerResponse,\n126:   buildSaveResponse,\n127:   classifySaveErrorCode,\n128:   extractSaveErrorDetails,\n129:   serializePlannerAdvisory,\n130:   serializePlannerBlocker,\n131:   serializePlannerFollowUpAction,\n132:   serializePlannerProposedEdit,\n133:   serializePlannerRouteTarget,\n134: } from './save/response-builder.js';\n135: import type {\n136:   IndexingOrigin,\n137:   ReconsolidationFailureReason,\n138:   ReconsolidationOperationState,\n139: } from './save/types.js';\n140: import { atomicIndexMemory } from './save/atomic-index-memory.js';\n141: import { createMCPErrorResponse } from '../lib/response/envelope.js';\n142: import {\n143:   buildTier3Prompt,\n144:   createContentRouter,\n145:   getTier3Contract,\n146:   isTier3RoutingEnabled,\n147:   InMemoryRouterCache,\n148:   TIER2_FALLBACK_PENALTY,\n149:   TIER3_THRESHOLD,\n150:   type RoutingDecision,\n151:   type Tier3ClassifierInput,\n152:   type Tier3RawResponse,\n153: } from '../lib/routing/content-router.js';\n154: import { anchorMergeOperation } from '../lib/merge/anchor-merge-operation.js';\n155: import {\n156:   readThinContinuityRecord,\n157:   upsertThinContinuityInMarkdown,\n158:   type ThinContinuityRecord,\n159: } from '../lib/continuity/thin-continuity-record.js';\n160: import {\n161:   runSpecDocStructureRule,\n162:   type ContaminationPlan,\n163:   type MergePlan,\n164:   type PostSavePlan,\n165: } from '../lib/validation/spec-doc-structure.js';\n166: import { detectSpecLevelFromParsed } from './handler-utils.js';\n167: import { createStatediffAction } from '../lib/storage/statediff.js';\n168: import {\n169:   applyWriteProvenance,\n170:   persistSourceKind,\n171:   type SourceKind,\n172:   type WriteProvenanceContext,\n173: } from '../lib/storage/write-provenance.js';\n174: import {\n175:   deleteIdempotencyReceiptByKey,\n176:   extractMemoryIdFromResponse,\n177:   isMemoryIdempotencyEnabled,\n178:   lookupIdempotencyReceipt,\n179:   lookupIdempotencyReceiptByKey,\n180:   markResponseWithReceiptStoreConflict,\n181:   shouldStoreMemorySaveReceipt,\n182:   storeIdempotencyReceipt,\n183:   type IdempotencyReceiptKey,\n184: } from '../lib/storage/idempotency-receipts.js';\n185: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n186: \n187: // Extracted sub-modules\n188: import { withSpecFolderLock } from './save/spec-folder-mutex.js';\n189: import { buildParsedMemoryEvidenceSnapshot } from './save/markdown-evidence-builder.js';\n190: import {\n191:   applyInsufficiencyMetadata,\n192:   buildInsufficiencyRejectionResult,\n193:   buildTemplateContractRejectionResult,\n194:   buildDryRunSummary,\n195:   buildPlannerAdvisory,\n196:   buildPlannerBlocker,\n197: } from './save/validation-responses.js';\n198: \n199: import { markMemorySuperseded } from './pe-gating.js';\n200: import { resolveMemoryReference } from './causal-links-processor.js';\n201: import { refreshAutoEntitiesForMemory } from '../lib/extraction/entity-extractor.js';\n202: \n203: // Feature catalog: Memory indexing (memory_save)\n204: // Feature catalog: Verify-fix-verify memory quality loop\n205: // Feature catalog: Dry-run preflight for memory_save\n206: // Feature catalog: Prediction-error save arbitration\n207: \n208: \n209: // Create local path validator\n210: const validateFilePathLocal = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\n211: const MANUAL_FALLBACK_SOURCE_CLASSIFICATION = 'manual-fallback' as const;\n212: export const MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE = 'E_MEMORY_INDEX_SCOPE_EXCLUDED';\n213: const ROUTED_CONTINUITY_ANCHOR_ID = '_memory.continuity';\n214: const tier3RoutingCache = new InMemoryRouterCache();\n215: \n216: function emitPostInsertEnrichmentSubscribers(memoryId: number, sourceOperation: string): void {\n217:   try {\n218:     runPostMutationHooks(sourceOperation, {\n219:       memoryId,\n220:       statediffActions: [createStatediffAction('upsert', {\n221:         target: 'graph_edge',\n222:         key: String(memoryId),\n223:         sourceOperation,\n224:       })],\n225:     });\n226:   } catch (err: unknown) {\n227:     const message = err instanceof Error ? err.message : String(err);\n228:     console.warn(`[memory-save] Post-insert enrichment subscriber dispatch failed: ${message}`);\n229:   }\n230: }\n231: \n232: async function repairReplayEnrichmentIfNeeded(\n233:   database: Parameters<typeof needsEnrichmentRepair>[0],\n234:   memoryId: number | undefined,\n235:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n236: ): Promise<void> {\n237:   if (memoryId == null || !needsEnrichmentRepair(database, memoryId)) {\n238:     return;\n239:   }\n240: \n241:   await repairEnrichmentOnReplay({\n242:     database,\n243:     parsed,\n244:     plannerMode: 'full-auto',\n245:   }, memoryId);\n246: }\n247: \n248: interface PreparedParsedMemory {\n249:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n250:   validation: ReturnType<typeof memoryParser.validateParsedMemory>;\n251:   qualityLoopResult: QualityLoopResult;\n252:   sufficiencyResult: MemorySufficiencyResult;\n253:   templateContract: MemoryTemplateContractResult;\n254:   specDocHealth: SpecDocHealthResult | null;\n255:   finalizedFileContent: string | null;\n256:   sourceClassification: 'template-generated' | typeof MANUAL_FALLBACK_SOURCE_CLASSIFICATION;\n257: }\n258: \n259: function createIndexScopeExcludedResponse(\n260:   requestId: string,\n261:   canonicalPath: string,\n262:   originalPath: string,\n263: ): MCPResponse {\n264:   return createMCPErrorResponse({\n265:     tool: 'memory_save',\n266:     error: `Memory indexing excluded for path: ${canonicalPath}`,\n267:     code: MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE,\n268:     details: {\n269:       requestId,\n270:       canonicalPath,\n271:       filePath: originalPath,\n272:     },\n273:     recovery: {\n274:       hint: 'Move the file into an indexable spec folder or constitutional rule path before retrying.',\n275:       actions: ['Verify the path is not under z_future/ or external/'],\n276:       severity: 'warning',\n277:     },\n278:   });\n279: }\n280: \n281: type ParsedMemoryWithIndexHints = ReturnType<typeof memoryParser.parseMemoryFile> & {\n282:   _skipIndex?: boolean;\n283:   _vRuleIndexBlockIds?: string[];\n284: };\n285: \n286: interface RoutedSaveOptions extends CreateRecordIdentityHints {\n287:   routeAs?: RouteCategory;\n288:   mergeModeHint?: MergeModeHint;\n289: }\n290: \n291: interface RoutedRecordIdentity {\n292:   targetDocPath: string;\n293:   canonicalFilePath: string;\n294:   targetAnchorId: string | null;\n295:   routeAs: RouteCategory | null;\n296:   continuitySourceKey: string | null;\n297: }\n298: \n299: type CanonicalPacketLevel = 'L1' | 'L2' | 'L3' | 'L3+';\n300: type CanonicalPacketKind = 'feature' | 'phase' | 'remediation' | 'research' | 'unknown';\n301: \n302: interface CanonicalAtomicValidatorPlan {\n303:   folder: string;\n304:   level: string;\n305:   mergePlan: MergePlan | null;\n306:   contaminationPlan: ContaminationPlan | null;\n307:   postSavePlan: PostSavePlan | null;\n308: }\n309: \n310: interface CanonicalAtomicPrepared {\n311:   preparedMemory: PreparedParsedMemory;\n312:   routing: RoutedSaveOptions;\n313:   validatorPlan: CanonicalAtomicValidatorPlan | null;\n314: }\n315: \n316: const STANDARD_MEMORY_TEMPLATE_MARKERS = [\n317:   '## continue session',\n318:   '## recovery hints',\n319:   '<!-- memory metadata -->',\n320: ];\n321: const CANONICAL_SPEC_DOCUMENT_TYPES = new Set([\n322:   'spec',\n323:   'plan',\n324:   'tasks',\n325:   'checklist',\n326:   'decision_record',\n327:   'implementation_summary',\n328:   'research',\n329:   'handover',\n330:   'resource_map',\n331: ]);\n332: const ROUTE_CATEGORIES = new Set<RouteCategory>([\n333:   'narrative_progress',\n334:   'narrative_delivery',\n335:   'decision',\n336:   'handover_state',\n337:   'research_finding',\n338:   'task_update',\n339:   'metadata_only',\n340:   'drop',\n341: ]);\n342: \n343: class VRuleUnavailableError extends Error {\n344:   constructor(message: string) {\n345:     super(message);\n346:     this.name = 'VRuleUnavailableError';\n347:   }\n348: }\n349: \n350: function isVRuleUnavailableResult(value: unknown): value is {\n351:   passed: false;\n352:   status: 'error' | 'warning';\n353:   message: string;\n354:   _unavailable: true;\n355: } {\n356:   return typeof value === 'object'\n357:     && value !== null\n358:     && 'passed' in value\n359:     && (value as { passed?: unknown }).passed === false\n360:     && 'status' in value\n361:     && typeof (value as { status?: unknown }).status === 'string'\n362:     && 'message' in value\n363:     && typeof (value as { message?: unknown }).message === 'string';\n364: }\n365: \n366: function classifyMemorySaveSource(\n367:   content: string,\n368: ): 'template-generated' | typeof MANUAL_FALLBACK_SOURCE_CLASSIFICATION {\n369:   const normalizedContent = content.toLowerCase();\n370:   const hasAnyStandardMarker = STANDARD_MEMORY_TEMPLATE_MARKERS.some((marker) => normalizedContent.includes(marker));\n371:   return hasAnyStandardMarker ? 'template-generated' : MANUAL_FALLBACK_SOURCE_CLASSIFICATION;\n372: }\n373: \n374: // Files that are structural metadata for graph traversal and continuity, not\n375: // semantic-search corpus. The memory-sufficiency gate is built around markdown\n376: // anchors and prose evidence; pure-JSON structural files cannot satisfy it by\n377: // construction. We exempt them from the sufficiency floor so they index with\n378: // whatever flattened text the indexer produces — graph traversal already reads\n379: // these files directly from disk for parent/child/status, so the embedding is\n380: // best-effort, not load-bearing.\n381: const STRUCTURAL_METADATA_FILENAMES = new Set<string>(['graph-metadata.json']);\n382: \n383: function isStructuralMetadataFile(filePath: string): boolean {\n384:   return STRUCTURAL_METADATA_FILENAMES.has(path.basename(filePath));\n385: }\n386: \n387: function shouldBypassTemplateContract(\n388:   sourceClassification: PreparedParsedMemory['sourceClassification'],\n389:   sufficiencyResult: MemorySufficiencyResult,\n390:   templateContract: MemoryTemplateContractResult,\n391:   specDocHealth?: SpecDocHealthResult | null,\n392:   documentType?: string,\n393: ): boolean {\n394:   const isValidCanonicalSpecDoc = Boolean(\n395:     documentType\n396:       && CANONICAL_SPEC_DOCUMENT_TYPES.has(documentType)\n397:       && specDocHealth?.pass === true,\n398:   );\n399: \n400:   return sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION\n401:     && sufficiencyResult.pass\n402:     && !templateContract.valid\n403:     && (\n404:       isValidCanonicalSpecDoc\n405:       || (\n406:         sufficiencyResult.evidenceCounts.primary === 0\n407:         && sufficiencyResult.evidenceCounts.support >= 3\n408:         && sufficiencyResult.evidenceCounts.anchors >= 1\n409:       )\n410:     );\n411: }\n412: \n413: function buildQualityLoopMetadata(\n414:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n415:   database: ReturnType<typeof requireDb>,\n416: ): Record<string, unknown> {\n417:   return {\n418:     title: parsed.title ?? '',\n419:     triggerPhrases: parsed.triggerPhrases,\n420:     specFolder: parsed.specFolder,\n421:     contextType: parsed.contextType,\n422:     importanceTier: parsed.importanceTier,\n423:     causalLinks: parsed.causalLinks,\n424:     filePath: parsed.filePath,\n425:     lastModified: parsed.lastModified,\n426:     resolveReference: (reference: string) => resolveMemoryReference(database, reference) !== null,\n427:   };\n428: }\n429: \n430: function prepareParsedMemoryForIndexing(\n431:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n432:   database: ReturnType<typeof requireDb>,\n433:   options: {\n434:     emitEvalMetrics?: boolean;\n435:     qualityLoopMode?: 'advisory' | 'full-auto';\n436:   } = {},\n437: ): PreparedParsedMemory {\n438:   // Resolve to the canonical path before applying memory-index governance.\n439:   const canonicalFilePath = resolveCanonicalPath(path.resolve(parsed.filePath));\n440:   if (!shouldIndexForMemory(canonicalFilePath)) {\n441:     throw new Error(`Memory indexing excluded for path: ${parsed.filePath}`);\n442:   }\n443:   if (parsed.importanceTier === 'constitutional' && !isIndexableConstitutionalMemoryPath(canonicalFilePath)) {\n444:     console.warn('[memory-save] importance_tier=constitutional rejected for non-constitutional path; downgrading to important', {\n445:       file_path: parsed.filePath,\n446:     });\n447:     try {\n448:       recordTierDowngradeAudit(database, {\n449:         logicalKey: buildGovernanceLogicalKey(parsed.specFolder, canonicalFilePath, null),\n450:         requestedTier: 'constitutional',\n451:         nextTier: 'important',\n452:         source: 'memory_save',\n453:         filePath: parsed.filePath,\n454:         canonicalFilePath,\n455:       });\n456:     } catch (error: unknown) {\n457:       console.warn(\n458:         '[memory-save] governance_audit insert failed for tier downgrade:',\n459:         error instanceof Error ? error.message : String(error),\n460:       );\n461:     }\n462:     parsed.importanceTier = 'important';\n463:   }\n464: \n465:   const validation = memoryParser.validateParsedMemory(parsed);\n466:   if (validation.warnings && validation.warnings.length > 0) {\n467:     console.warn(`[memory] Warning for ${path.basename(parsed.filePath)}:`);\n468:     validation.warnings.forEach((warning: string) => console.warn(`[memory]   - ${warning}`));\n469:   }\n470: \n471:   // O2-5/O2-12: Run V-rule validation (previously only in workflow path)\n472:   const vRuleResult = validateMemoryQualityContent(parsed.content, { filePath: parsed.filePath });\n473:   if (isVRuleUnavailableResult(vRuleResult) && vRuleResult.status === 'error') {\n474:     throw new VRuleUnavailableError(vRuleResult.message);\n475:   }\n476:   if (vRuleResult && '_unavailable' in vRuleResult) {\n477:     validation.warnings.push('V-rule validator module unavailable — quality gate bypassed. Save proceeds without V-rule enforcement.');\n478:   }\n479:   if (vRuleResult && !isVRuleUnavailableResult(vRuleResult) && !vRuleResult.valid) {\n480:     const vRuleDisposition = determineValidationDisposition(\n481:       vRuleResult.failedRules,\n482:       parsed.memoryTypeSource || null,\n483:     );\n484:     if (vRuleDisposition && vRuleDisposition.disposition === 'abort_write') {\n485:       const failedRuleIds = vRuleDisposition.blockingRuleIds;\n486:       console.error(`[memory-save] V-rule hard block for ${path.basename(parsed.filePath)}: ${failedRuleIds.join(', ')}`);\n487:       // Return early with a rejected quality loop result so callers see the block\n488:       const rejectScore = { total: 0, breakdown: { triggers: 0, anchors: 0, budget: 0, coherence: 0 }, issues: [`V-rule hard block: ${failedRuleIds.join(', ')}`] };\n489:       return {\n490:         parsed,\n491:         validation,\n492:         qualityLoopResult: {\n493:           passed: false,\n494:           score: rejectScore,\n495:           attempts: 0,\n496:           fixes: [],\n497:           rejected: true,\n498:           rejectionReason: `V-rule hard block: ${failedRuleIds.join(', ')}`,\n499:         },\n500:         sufficiencyResult: {\n501:           pass: false,\n502:           rejectionCode: MEMORY_SUFFICIENCY_REJECTION_CODE,\n503:           score: 0,\n504:           reasons: [`V-rule hard block: ${failedRuleIds.join(', ')}`],\n505:           evidenceCounts: { primary: 0, support: 0, total: 0, semanticChars: 0, uniqueWords: 0, anchors: 0, triggerPhrases: 0 },\n506:         },\n507:         templateContract: { valid: true, violations: [], missingAnchors: [], unexpectedTemplateArtifacts: [] } as MemoryTemplateContractResult,\n508:         specDocHealth: null,\n509:         finalizedFileContent: null,\n510:         sourceClassification: 'template-generated',\n511:       };\n512:     }\n513:     if (vRuleDisposition && vRuleDisposition.disposition === 'write_skip_index') {\n514:       console.warn(`[memory-save] V-rule index block for ${path.basename(parsed.filePath)}: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n515:       validation.warnings.push(`V-rule index block: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n516:       // F07-002: Flag to skip indexing for write_skip_index disposition\n517:       const parsedWithIndexHints = parsed as ParsedMemoryWithIndexHints;\n518:       parsedWithIndexHints._skipIndex = true;\n519:       parsedWithIndexHints._vRuleIndexBlockIds = vRuleDisposition.indexBlockingRuleIds;\n520:     }\n521:   }\n522: \n523:   const qualityLoopResult = runQualityLoop(parsed.content, buildQualityLoopMetadata(parsed, database), {\n524:     emitEvalMetrics: options.emitEvalMetrics,\n525:     mode: options.qualityLoopMode ?? 'advisory',\n526:   });\n527:   parsed.qualityScore = qualityLoopResult.score.total;\n528:   parsed.qualityFlags = Array.from(new Set([\n529:     ...(parsed.qualityFlags ?? []),\n530:     ...qualityLoopResult.score.issues,\n531:   ]));\n532:   if (qualityLoopResult.fixedTriggerPhrases) {\n533:     parsed.triggerPhrases = qualityLoopResult.fixedTriggerPhrases;\n534:   }\n535:   const finalizedFileContent = qualityLoopResult.fixedContent\n536:     && qualityLoopResult.passed\n537:     ? qualityLoopResult.fixedContent\n538:     : null;\n539:   if (finalizedFileContent) {\n540:     parsed.content = finalizedFileContent;\n541:     parsed.contentHash = memoryParser.computeContentHash(parsed.content);\n542:   }\n543: \n544:   const sourceClassification = classifyMemorySaveSource(parsed.content);\n545:   if (sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION) {\n546:     const warning = 'Manual fallback save mode detected; standard generate-context template markers are missing.';\n547:     console.warn(`[memory-save] ${warning} ${path.basename(parsed.filePath)}`);\n548:     validation.warnings.push(warning);\n549:   }\n550: \n551:   const sufficiencyResult = evaluateMemorySufficiency(\n552:     {\n553:       ...buildParsedMemoryEvidenceSnapshot(parsed),\n554:       sourceClassification,\n555:     },\n556:   );\n557:   applyInsufficiencyMetadata(parsed, sufficiencyResult);\n558:   const templateContract = validateMemoryTemplateContract(parsed.content);\n559: \n560:   // Non-blocking spec doc health annotation\n561:   // Canonical saves land directly in the spec folder (e.g. .../NNN-name/decision-record.md),\n562:   // so the immediate parent is usually the spec folder itself.\n563:   let specDocHealth: SpecDocHealthResult | null = null;\n564:   if (parsed.specFolder && parsed.filePath) {\n565:     try {\n566:       const absFilePath = path.resolve(parsed.filePath);\n567:       const immediateParent = path.dirname(absFilePath);\n568:       const candidates = [immediateParent, path.dirname(immediateParent)];\n569:       for (const candidate of candidates) {\n570:         if (fs.existsSync(path.join(candidate, 'spec.md'))) {\n571:           specDocHealth = evaluateSpecDocHealth(candidate);\n572:           break;\n573:         }\n574:       }\n575:     } catch (error: unknown) {\n576:       const message = error instanceof Error ? error.message : String(error);\n577:       console.warn(\n578:         `[memory-save] spec-doc-health annotation skipped for ${path.basename(parsed.filePath)}: ${message}`\n579:       );\n580:     }\n581:   }\n582: \n583:   return {\n584:     parsed,\n585:     validation,\n586:     qualityLoopResult,\n587:     sufficiencyResult,\n588:     templateContract,\n589:     specDocHealth,\n590:     finalizedFileContent,\n591:     sourceClassification,\n592:   };\n593: }\n594: \n595: async function finalizeMemoryFileContent(\n596:   filePath: string,\n597:   content: string,\n598: ): Promise<void> {\n599:   const backupPath = `${filePath}.${randomUUID().slice(0, 8)}.bak`;\n600:   const tempPath = `${filePath}.${randomUUID().slice(0, 8)}.tmp`;\n601:   let backupCreated = false;\n602:   let tempCreated = false;\n603: \n604:   try {\n605:     try {\n606:       await fs.promises.copyFile(filePath, backupPath);\n607:       backupCreated = true;\n608:     } catch (backupErr: unknown) {\n609:       const errCode = typeof backupErr === 'object' && backupErr !== null && 'code' in backupErr\n610:         ? String((backupErr as NodeJS.ErrnoException).code)\n611:         : '';\n612:       if (errCode !== 'ENOENT') {\n613:         throw backupErr;\n614:       }\n615:     }\n616: \n617:     await fs.promises.writeFile(tempPath, content, 'utf-8');\n618:     tempCreated = true;\n619:     await fs.promises.rename(tempPath, filePath);\n620:     tempCreated = false;\n621:   } catch (writeErr: unknown) {\n622:     if (tempCreated) {\n623:       try {\n624:         await fs.promises.unlink(tempPath);\n625:       } catch {\n626:         // Best-effort cleanup only.\n627:       }\n628:     }\n629:     if (backupCreated) {\n630:       try {\n631:         await fs.promises.copyFile(backupPath, filePath);\n632:       } catch (restoreErr: unknown) {\n633:         console.warn(\n634:           '[memory-save] Auto-fix file restore failed after finalize error:',\n635:           restoreErr instanceof Error ? restoreErr.message : String(restoreErr),\n636:         );\n637:       }\n638:     }\n639:     throw writeErr;\n640:   } finally {\n641:     if (tempCreated) {\n642:       try {\n643:         await fs.promises.unlink(tempPath);\n644:       } catch {\n645:         // Best-effort cleanup only.\n646:       }\n647:     }\n648:     if (backupCreated) {\n649:       try {\n650:         await fs.promises.unlink(backupPath);\n651:       } catch {\n652:         // Best-effort cleanup only.\n653:       }\n654:     }\n655:   }\n656: }\n657: \n658: function appendResultWarning<T extends Record<string, unknown>>(result: T, warning: string | null): T {\n659:   if (!warning) {\n660:     return result;\n661:   }\n662: \n663:   const r = result as Record<string, unknown>;\n664:   const warnings = Array.isArray(r.warnings)\n665:     ? [...(r.warnings as string[])]\n666:     : [];\n667:   warnings.push(warning);\n668:   r.warnings = warnings;\n669:   return result;\n670: }\n671: \n672: class SaveTimeReconsolidationAbort extends Error {\n673:   readonly result: {\n674:     status: 'failed';\n675:     reason: ReconsolidationFailureReason;\n676:     warnings?: string[];\n677:     persistedState?: ReconsolidationOperationState;\n678:   };\n679: \n680:   constructor(result: SaveTimeReconsolidationAbort['result']) {\n681:     super(result.reason);\n682:     this.name = 'SaveTimeReconsolidationAbort';\n683:     this.result = result;\n684:   }\n685: }\n686: \n687: function buildSaveTimeReconsolidationFailureResult(args: {\n688:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n689:   validation: { warnings: string[] };\n690:   reconWarnings: string[];\n691:   failure: SaveTimeReconsolidationAbort['result'];\n692:   message?: string;\n693: }): IndexResult {\n694:   const warnings = [\n695:     ...args.validation.warnings,\n696:     ...args.reconWarnings,\n697:     ...(args.failure.warnings ?? []),\n698:   ];\n699: \n700:   return {\n701:     status: 'error',\n702:     id: 0,\n703:     specFolder: args.parsed.specFolder,\n704:     title: args.parsed.title ?? '',\n705:     triggerPhrases: args.parsed.triggerPhrases,\n706:     contextType: args.parsed.contextType,\n707:     importanceTier: args.parsed.importanceTier,\n708:     memoryType: args.parsed.memoryType,\n709:     memoryTypeSource: args.parsed.memoryTypeSource,\n710:     qualityScore: args.parsed.qualityScore,\n711:     qualityFlags: args.parsed.qualityFlags,\n712:     warnings,\n713:     error: args.message ?? `Save-time reconsolidation failed: ${args.failure.reason}`,\n714:     message: args.message ?? `Save-time reconsolidation failed: ${args.failure.reason}`,\n715:     saveTimeReconsolidation: args.failure,\n716:   };\n717: }\n718: \n719: function recordCrossPathPeSupersedes(\n720:   database: ReturnType<typeof requireDb>,\n721:   memoryId: number,\n722:   supersededMemoryId: number | null,\n723:   samePathMemoryId: number | null,\n724:   reason: string | null | undefined,\n725: ): void {\n726:   if (supersededMemoryId == null || supersededMemoryId === samePathMemoryId) {\n727:     return;\n728:   }\n729: \n730:   causalEdges.init(database);\n731:   const evidence = reason && reason.trim().length > 0\n732:     ? reason.trim()\n733:     : 'Prediction-error contradiction across different file paths';\n734:   causalEdges.insertEdge(\n735:     String(memoryId),\n736:     String(supersededMemoryId),\n737:     causalEdges.RELATION_TYPES.SUPERSEDES,\n738:     1.0,\n739:     evidence,\n740:     true,\n741:     'auto',\n742:   );\n743: }\n744: \n745: interface ChunkedInsertTracker {\n746:   parentId: number | null;\n747:   childIds: Set<number>;\n748: }\n749: \n750: function createChunkedInsertTracker(): ChunkedInsertTracker {\n751:   return {\n752:     parentId: null,\n753:     childIds: new Set<number>(),\n754:   };\n755: }\n756: \n757: function trackChunkedInsert(\n758:   tracker: ChunkedInsertTracker,\n759:   memoryId: number,\n760:   fields: Record<string, unknown>,\n761: ): void {\n762:   if (typeof fields.chunk_index === 'number') {\n763:     tracker.childIds.add(memoryId);\n764:     return;\n765:   }\n766: \n767:   if (tracker.parentId == null) {\n768:     tracker.parentId = memoryId;\n769:   }\n770: }\n771: \n772: function rollbackCreatedChunkTree(\n773:   database: ReturnType<typeof requireDb>,\n774:   tracker: ChunkedInsertTracker,\n775: ): { attempted: boolean; cleaned: boolean; error?: string } {\n776:   if (tracker.parentId == null) {\n777:     return { attempted: false, cleaned: false };\n778:   }\n779: \n780:   const childIds = new Set<number>(tracker.childIds);\n781:   try {\n782:     const persistedChildRows = database.prepare(`\n783:       SELECT id\n784:       FROM memory_index\n785:       WHERE parent_id = ?\n786:     `).all(tracker.parentId) as Array<{ id: number }>;\n787:     for (const row of persistedChildRows) {\n788:       childIds.add(row.id);\n789:     }\n790:   } catch {\n791:     // Best-effort lookup only. Tracked IDs remain authoritative for cleanup.\n792:   }\n793: \n794:   const cleanupErrors: string[] = [];\n795:   for (const childId of childIds) {\n796:     try {\n797:       if (!delete_memory_from_database(database, childId)) {\n798:         cleanupErrors.push(`Chunk ${childId} was not deleted`);\n799:       }\n800:     } catch (error: unknown) {\n801:       cleanupErrors.push(`Chunk ${childId} cleanup failed: ${getAtomicSaveErrorMessage(error)}`);\n802:     }\n803:   }\n804: \n805:   try {\n806:     if (!delete_memory_from_database(database, tracker.parentId)) {\n807:       cleanupErrors.push(`Parent ${tracker.parentId} was not deleted`);\n808:     }\n809:   } catch (error: unknown) {\n810:     cleanupErrors.push(`Parent ${tracker.parentId} cleanup failed: ${getAtomicSaveErrorMessage(error)}`);\n811:   }\n812: \n813:   if (cleanupErrors.length > 0) {\n814:     return {\n815:       attempted: true,\n816:       cleaned: false,\n817:       error: cleanupErrors.join('; '),\n818:     };\n819:   }\n820: \n821:   return { attempted: true, cleaned: true };\n822: }\n823: \n824: function captureAtomicSaveOriginalState(filePath: string): { existed: boolean; content: string | null } {\n825:   if (!fs.existsSync(filePath)) {\n826:     return { existed: false, content: null };\n827:   }\n828: \n829:   return {\n830:     existed: true,\n831:     content: fs.readFileSync(filePath, 'utf-8'),\n832:   };\n833: }\n834: \n835: function getAtomicSaveErrorMessage(error: unknown): string {\n836:   return error instanceof Error ? error.message : String(error);\n837: }\n838: \n839: function deleteAtomicSaveFile(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n840:   const existed = fs.existsSync(filePath);\n841:   if (!existed) {\n842:     return { deleted: false, existed: false };\n843:   }\n844: \n845:   try {\n846:     fs.unlinkSync(filePath);\n847:     return { deleted: true, existed: true };\n848:   } catch (error: unknown) {\n849:     return {\n850:       deleted: false,\n851:       existed: true,\n852:       error: getAtomicSaveErrorMessage(error),\n853:     };\n854:   }\n855: }\n856: \n857: function restoreAtomicSaveOriginalState(\n858:   filePath: string,\n859:   originalState: { existed: boolean; content: string | null },\n860: ): { restored: boolean; error?: string } {\n861:   try {\n862:     if (!originalState.existed) {\n863:       const deleteResult = deleteAtomicSaveFile(filePath);\n864:       if (!deleteResult.existed || deleteResult.deleted) {\n865:         return { restored: true };\n866:       }\n867:       return {\n868:         restored: false,\n869:         error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n870:       };\n871:     }\n872: \n873:     if (typeof originalState.content !== 'string') {\n874:       return { restored: false, error: 'Original file content is unavailable for rollback' };\n875:     }\n876: \n877:     fs.mkdirSync(path.dirname(filePath), { recursive: true });\n878:     fs.writeFileSync(filePath, originalState.content, 'utf-8');\n879:     return { restored: true };\n880:   } catch (error: unknown) {\n881:     return {\n882:       restored: false,\n883:       error: getAtomicSaveErrorMessage(error),\n884:     };\n885:   }\n886: }\n887: \n888: function cleanupAtomicSavePendingFile(\n889:   pendingPath: string,\n890: ): { cleaned: boolean; existed: boolean; error?: string } {\n891:   try {\n892:     const deleteResult = deleteAtomicSaveFile(pendingPath);\n893:     if (!deleteResult.existed || deleteResult.deleted) {\n894:       return {\n895:         cleaned: true,\n896:         existed: deleteResult.existed,\n897:       };\n898:     }\n899:     return {\n900:       cleaned: false,\n901:       existed: deleteResult.existed,\n902:       error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n903:     };\n904:   } catch (error: unknown) {\n905:     return {\n906:       cleaned: false,\n907:       existed: true,\n908:       error: getAtomicSaveErrorMessage(error),\n909:     };\n910:   }\n911: }\n912: \n913: function applyRoutedSaveHints(\n914:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n915:   routing: RoutedSaveOptions,\n916: ): ReturnType<typeof memoryParser.parseMemoryFile> {\n917:   const parsedWithHints = parsed as ParsedMemoryWithIndexHints & Record<string, unknown>;\n918:   if (routing.targetDocPath) {\n919:     parsedWithHints.targetDocPath = routing.targetDocPath;\n920:     parsedWithHints.target_doc_path = routing.targetDocPath;\n921:   }\n922:   if (routing.targetAnchorId) {\n923:     parsedWithHints.targetAnchorId = routing.targetAnchorId;\n924:     parsedWithHints.target_anchor_id = routing.targetAnchorId;\n925:     parsedWithHints.anchorId = routing.targetAnchorId;\n926:     parsedWithHints.anchor_id = routing.targetAnchorId;\n927:   }\n928:   if (routing.routeAs) {\n929:     parsedWithHints.routeAs = routing.routeAs;\n930:     parsedWithHints.route_as = routing.routeAs;\n931:   }\n932:   if (routing.continuitySourceKey) {\n933:     parsedWithHints.continuitySourceKey = routing.continuitySourceKey;\n934:     parsedWithHints.continuity_source_key = routing.continuitySourceKey;\n935:   }\n936:   return parsedWithHints;\n937: }\n938: \n939: function buildRoutedSaveOptions(\n940:   filePath: string,\n941:   routeAs?: RouteCategory,\n942:   mergeModeHint?: MergeModeHint,\n943:   targetAnchorId?: string,\n944: ): RoutedSaveOptions | undefined {\n945:   if (!routeAs && !mergeModeHint && !targetAnchorId) {\n946:     return undefined;\n947:   }\n948: \n949:   return {\n950:     targetDocPath: filePath,\n951:     ...(routeAs ? { routeAs } : {}),\n952:     ...(mergeModeHint ? { mergeModeHint } : {}),\n953:     ...(targetAnchorId ? { targetAnchorId } : {}),\n954:   };\n955: }\n956: \n957: function shouldUseCanonicalRouting(_params: Pick<AtomicSaveParams, 'routeAs' | 'mergeModeHint' | 'targetAnchorId'>): boolean {\n958:   // Test-only bypass: allows the atomic-save failure-injection suite\n959:   // to exercise the legacy prepareParsedMemoryForIndexing path without\n960:   // setting up full Tier 3 classifier fixtures.\n961:   if (process.env.SPECKIT_TEST_DISABLE_CANONICAL_ROUTING === 'true') return false;\n962:   return true; // Canonical routing is always enabled (Tier 3 LLM routing on by default)\n963: }\n964: \n965: function pickRoutedIdentityValue(value: unknown): string | null {\n966:   return typeof value === 'string' && value.trim().length > 0 ? value.trim() : null;\n967: }\n968: \n969: function pickRouteCategory(value: unknown): RouteCategory | null {\n970:   const normalized = pickRoutedIdentityValue(value);\n971:   if (!normalized || !ROUTE_CATEGORIES.has(normalized as RouteCategory)) {\n972:     return null;\n973:   }\n974:   return normalized as RouteCategory;\n975: }\n976: \n977: function isMergeModeHint(value: unknown): value is MergeModeHint {\n978:   return value === 'append-as-paragraph'\n979:     || value === 'insert-new-adr'\n980:     || value === 'append-table-row'\n981:     || value === 'update-in-place'\n982:     || value === 'append-section';\n983: }\n984: \n985: function resolveRoutedRecordIdentity(\n986:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n987:   routedFilePath: string,\n988:   routing: RoutedSaveOptions,\n989: ): RoutedRecordIdentity {\n990:   const routedRecord = parsed as unknown as Record<string, unknown>;\n991:   const routeAs = pickRouteCategory(routing.routeAs ?? routedRecord.routeAs ?? routedRecord.route_as);\n992:   const continuitySourceKey = pickRoutedIdentityValue(\n993:     routing.continuitySourceKey\n994:     ?? routedRecord.continuitySourceKey\n995:     ?? routedRecord.continuity_source_key\n996:     ?? routedRecord.sourceKey\n997:     ?? routedRecord.source_key,\n998:   );\n999:   const explicitTargetAnchorId = pickRoutedIdentityValue(\n1000:     routing.targetAnchorId\n1001:     ?? routedRecord.targetAnchorId\n1002:     ?? routedRecord.target_anchor_id\n1003:     ?? routedRecord.anchorId\n1004:     ?? routedRecord.anchor_id,\n1005:   );\n1006: \n1007:   return {\n1008:     targetDocPath: routing.targetDocPath ?? routedFilePath,\n1009:     canonicalFilePath: routing.canonicalFilePath ?? getCanonicalPathKey(routing.targetDocPath ?? routedFilePath),\n1010:     targetAnchorId: explicitTargetAnchorId ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? ROUTED_CONTINUITY_ANCHOR_ID : null),\n1011:     routeAs,\n1012:     continuitySourceKey,\n1013:   };\n1014: }\n1015: \n1016: function toCanonicalPacketLevel(level: number | null): CanonicalPacketLevel {\n1017:   if (level === 1) return 'L1';\n1018:   if (level === 2) return 'L2';\n1019:   if (level === 3) return 'L3';\n1020:   return 'L3+';\n1021: }\n1022: \n1023: function toValidatorLevel(packetLevel: CanonicalPacketLevel): string {\n1024:   return packetLevel.replace(/^L/u, '');\n1025: }\n1026: \n1027: function normalizeForFingerprint(content: string): string {\n1028:   return content\n1029:     .replace(/\\r\\n/g, '\\n')\n1030:     .replace(/[ \\t]+$/gm, '');\n1031: }\n1032: \n1033: function buildContinuityFingerprint(content: string): string {\n1034:   return `sha256:${createHash('sha256').update(normalizeForFingerprint(content), 'utf8').digest('hex')}`;\n1035: }\n1036: \n1037: function normalizePhaseAnchor(value: string | null | undefined): string | null {\n1038:   if (typeof value !== 'string') {\n1039:     return null;\n1040:   }\n1041:   const trimmed = value.trim();\n1042:   const match = trimmed.match(/^phase(?:[\\s_-]+)?(\\d+)$/iu);\n1043:   return match ? `phase-${match[1]}` : null;\n1044: }\n1045: \n1046: function inferPhaseAnchorFromText(text: string): string | null {\n1047:   const match = text.match(/\\bphase(?:[\\s_-]+)?(\\d+)\\b/iu);\n1048:   return match ? `phase-${match[1]}` : null;\n1049: }\n1050: \n1051: function inferPhaseAnchorFromSpecFolder(specFolder: string): string | null {\n1052:   return inferPhaseAnchorFromText(specFolder.replace(/\\//g, ' '));\n1053: }\n1054: \n1055: function deriveLikelyPhaseAnchorForCanonicalRouting(params: {\n1056:   routingChunkText: string;\n1057:   specFolder: string;\n1058:   targetAnchorId?: string;\n1059: }): string | null {\n1060:   return normalizePhaseAnchor(params.targetAnchorId)\n1061:     ?? inferPhaseAnchorFromText(params.routingChunkText)\n1062:     ?? inferPhaseAnchorFromSpecFolder(params.specFolder);\n1063: }\n1064: \n1065: function stripMarkdownFrontmatter(markdown: string): string {\n1066:   return markdown.replace(/^(?:\\uFEFF)?---\\r?\\n[\\s\\S]*?\\r?\\n---(?:\\r?\\n)?/u, '');\n1067: }\n1068: \n1069: function normalizeRoutingChunkText(markdown: string): string {\n1070:   return stripMarkdownFrontmatter(markdown)\n1071:     .replace(/<!--[\\s\\S]*?-->/g, ' ')\n1072:     .replace(/\\r\\n/g, '\\n')\n1073:     .replace(/\\n{3,}/g, '\\n\\n')\n1074:     .trim();\n1075: }\n1076: \n1077: function extractFrontmatterScalar(markdown: string, key: string): string | null {\n1078:   const frontmatterMatch = markdown.match(/^(?:\\uFEFF)?---\\r?\\n([\\s\\S]*?)\\r?\\n---(?:\\r?\\n)?/u);\n1079:   if (!frontmatterMatch?.[1]) {\n1080:     return null;\n1081:   }\n1082: \n1083:   const escapedKey = key.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n1084:   const scalarMatch = frontmatterMatch[1].match(\n1085:     new RegExp(`^\\\\s*${escapedKey}:\\\\s*[\"']?([^\"'\\r\\n]+)[\"']?\\\\s*$`, 'imu'),\n1086:   );\n1087:   return scalarMatch?.[1]?.trim() ?? null;\n1088: }\n1089: \n1090: function hasNumericSpecFolderName(folderPath: string): boolean {\n1091:   return /^\\d{3}(?:[-_].+)?$/u.test(path.basename(folderPath));\n1092: }\n1093: \n1094: function hasChildSpecFolders(specFolderAbsolute: string): boolean {\n1095:   try {\n1096:     const entries = fs.readdirSync(specFolderAbsolute, { withFileTypes: true });\n1097:     return entries.some((entry) => {\n1098:       if (!entry.isDirectory() || !hasNumericSpecFolderName(entry.name)) {\n1099:         return false;\n1100:       }\n1101:       return fs.existsSync(path.join(specFolderAbsolute, entry.name, 'spec.md'));\n1102:     });\n1103:   } catch {\n1104:     return false;\n1105:   }\n1106: }\n1107: \n1108: function deriveCanonicalPacketKind(\n1109:   specFolderAbsolute: string,\n1110:   specFolderKey: string,\n1111: ): CanonicalPacketKind {\n1112:   const specMdPath = path.join(specFolderAbsolute, 'spec.md');\n1113:   let specContent = '';\n1114:   try {\n1115:     specContent = fs.readFileSync(specMdPath, 'utf8');\n1116:   } catch {\n1117:     specContent = '';\n1118:   }\n1119: \n1120:   const packetType = extractFrontmatterScalar(specContent, 'type')?.toLowerCase() ?? '';\n1121:   const title = extractFrontmatterScalar(specContent, 'title')?.toLowerCase() ?? '';\n1122:   const description = extractFrontmatterScalar(specContent, 'description')?.toLowerCase() ?? '';\n1123:   const folderName = path.basename(specFolderAbsolute).toLowerCase();\n1124:   const semanticHint = `${folderName} ${title} ${description}`;\n1125: \n1126:   if (packetType === 'research') {\n1127:     return 'research';\n1128:   }\n1129:   if (/\\bremediation\\b/u.test(semanticHint)) {\n1130:     return 'remediation';\n1131:   }\n1132: \n1133:   const parentFolder = path.dirname(specFolderAbsolute);\n1134:   const hasNumericParentPacket = hasNumericSpecFolderName(parentFolder)\n1135:     && fs.existsSync(path.join(parentFolder, 'spec.md'));\n1136:   if (!hasChildSpecFolders(specFolderAbsolute) && hasNumericParentPacket) {\n1137:     return 'phase';\n1138:   }\n1139: \n1140:   const normalizedSpecFolder = specFolderKey.replace(/^specs\\//u, '');\n1141:   const depth = normalizedSpecFolder.split('/').filter(Boolean).length;\n1142:   if (depth <= 2) {\n1143:     return 'feature';\n1144:   }\n1145: \n1146:   return hasNumericParentPacket ? 'phase' : 'feature';\n1147: }\n1148: \n1149: function getTier3RoutingEndpoint(): string | null {\n1150:   const endpoint = process.env.LLM_REFORMULATION_ENDPOINT?.trim();\n1151:   return endpoint ? endpoint.replace(/\\/+$/u, '') : null;\n1152: }\n1153: \n1154: function extractTier3MessageText(content: unknown): string | null {\n1155:   if (typeof content === 'string') {\n1156:     const trimmed = content.trim();\n1157:     return trimmed.length > 0 ? trimmed : null;\n1158:   }\n1159:   if (Array.isArray(content)) {\n1160:     const text = content\n1161:       .map((entry) => {\n1162:         if (!entry || typeof entry !== 'object') {\n1163:           return '';\n1164:         }\n1165:         const textValue = (entry as { text?: unknown }).text;\n1166:         return typeof textValue === 'string' ? textValue : '';\n1167:       })\n1168:       .join('')\n1169:       .trim();\n1170:     return text.length > 0 ? text : null;\n1171:   }\n1172:   return null;\n1173: }\n1174: \n1175: function isTier3RawResponseShape(parsed: unknown): parsed is Tier3RawResponse {\n1176:   if (!parsed || typeof parsed !== 'object') {\n1177:     return false;\n1178:   }\n1179: \n1180:   const record = parsed as Record<string, unknown>;\n1181:   return typeof record.category === 'string'\n1182:     && typeof record.confidence === 'number'\n1183:     && typeof record.target_doc === 'string'\n1184:     && typeof record.target_anchor === 'string'\n1185:     && typeof record.merge_mode === 'string'\n1186:     && typeof record.reasoning === 'string';\n1187: }\n1188: \n1189: function parseTier3ClassifierResponse(rawText: string): Tier3RawResponse | null {\n1190:   try {\n1191:     const parsed = JSON.parse(rawText) as Record<string, unknown>;\n1192:     if (!parsed || typeof parsed !== 'object') {\n1193:       return null;\n1194:     }\n1195:     return isTier3RawResponseShape(parsed) ? parsed : null;\n1196:   } catch {\n1197:     return null;\n1198:   }\n1199: }\n1200: \n1201: async function classifyWithTier3Llm(input: Tier3ClassifierInput): Promise<Tier3RawResponse | null> {\n1202:   const endpoint = getTier3RoutingEndpoint();\n1203:   if (!endpoint) {\n1204:     return null;\n1205:   }\n1206: \n1207:   const apiKey = process.env.LLM_REFORMULATION_API_KEY?.trim() ?? '';\n1208:   const contract = getTier3Contract();\n1209:   const prompt = buildTier3Prompt(input);\n1210:   const controller = new AbortController();\n1211:   const timeoutId = setTimeout(() => controller.abort(), contract.timeoutMs);\n1212: \n1213:   try {\n1214:     const response = await fetch(`${endpoint}/chat/completions`, {\n1215:       method: 'POST',\n1216:       headers: {\n1217:         'Content-Type': 'application/json',\n1218:         ...(apiKey ? { Authorization: `Bearer ${apiKey}` } : {}),\n1219:       },\n1220:       body: JSON.stringify({\n1221:         model: contract.model,\n1222:         messages: [\n1223:           { role: 'system', content: prompt.system },\n1224:           { role: 'user', content: prompt.user },\n1225:         ],\n1226:         reasoning_effort: contract.reasoningEffort,\n1227:         temperature: contract.temperature,\n1228:         max_tokens: contract.maxOutputTokens,\n1229:         response_format: { type: 'json_object' },\n1230:       }),\n1231:       signal: controller.signal,\n1232:     });\n1233: \n1234:     clearTimeout(timeoutId);\n1235: \n1236:     if (!response.ok) {\n1237:       return null;\n1238:     }\n1239: \n1240:     const data = await response.json() as {\n1241:       choices?: Array<{\n1242:         message?: {\n1243:           content?: unknown;\n1244:         };\n1245:       }>;\n1246:     };\n1247:     const rawText = extractTier3MessageText(data.choices?.[0]?.message?.content);\n1248:     return rawText ? parseTier3ClassifierResponse(rawText) : null;\n1249:   } catch {\n1250:     clearTimeout(timeoutId);\n1251:     return null;\n1252:   }\n1253: }\n1254: \n1255: function buildCanonicalRouter(options: { tier3Enabled?: boolean } = {}) {\n1256:   return createContentRouter({\n1257:     classifyWithTier3: classifyWithTier3Llm,\n1258:     cache: tier3RoutingCache,\n1259:     tier3Enabled: options.tier3Enabled,\n1260:   });\n1261: }\n1262: \n1263: function collapseInlineWhitespace(value: string): string {\n1264:   return value.replace(/\\s+/g, ' ').trim();\n1265: }\n1266: \n1267: function clipInlineText(value: string, maxLength = 96): string {\n1268:   const normalized = collapseInlineWhitespace(value);\n1269:   return normalized.length <= maxLength ? normalized : `${normalized.slice(0, maxLength - 3).trimEnd()}...`;\n1270: }\n1271: \n1272: function extractParagraphs(markdown: string): string[] {\n1273:   return normalizeRoutingChunkText(markdown)\n1274:     .split(/\\n\\s*\\n/g)\n1275:     .map((entry) => collapseInlineWhitespace(entry))\n1276:     .filter(Boolean);\n1277: }\n1278: \n1279: function extractListItems(markdown: string): string[] {\n1280:   return normalizeRoutingChunkText(markdown)\n1281:     .split(/\\r?\\n/g)\n1282:     .map((line) => line.match(/^\\s*(?:[-*+]|\\d+\\.)\\s+(.+)$/u)?.[1] ?? '')\n1283:     .map((line) => clipInlineText(line, 120))\n1284:     .filter(Boolean);\n1285: }\n1286: \n1287: function resolveSpecFolderAbsoluteFromFilePath(filePath: string, specFolder: string): string {\n1288:   const normalizedFilePath = filePath.replace(/\\\\/g, '/');\n1289:   const normalizedSpecFolder = specFolder.replace(/^specs\\//u, '');\n1290:   const markers = [\n1291:     `/specs/${normalizedSpecFolder}/`,\n1292:     `/specs/${specFolder}/`,\n1293:   ];\n1294: \n1295:   for (const marker of markers) {\n1296:     const markerIndex = normalizedFilePath.lastIndexOf(marker);\n1297:     if (markerIndex >= 0) {\n1298:       return path.normalize(`${normalizedFilePath.slice(0, markerIndex)}${marker.slice(0, -1)}`);\n1299:     }\n1300:   }\n1301: \n1302:   return path.resolve(path.dirname(filePath), '..');\n1303: }\n1304: \n1305: function resolveMetadataHostDocPath(specFolderAbsolute: string): string {\n1306:   const implementationSummaryPath = path.join(specFolderAbsolute, 'implementation-summary.md');\n1307:   if (fs.existsSync(implementationSummaryPath)) {\n1308:     return implementationSummaryPath;\n1309:   }\n1310: \n1311:   return path.join(specFolderAbsolute, 'spec.md');\n1312: }\n1313: \n1314: function resolveCanonicalTargetDocPath(\n1315:   specFolderAbsolute: string,\n1316:   routedDocPath: string,\n1317: ): string {\n1318:   if (routedDocPath === 'spec-frontmatter' || routedDocPath === 'implementation-summary.md') {\n1319:     return resolveMetadataHostDocPath(specFolderAbsolute);\n1320:   }\n1321:   return path.join(specFolderAbsolute, routedDocPath);\n1322: }\n1323: \n1324: function clampRoutingConfidence(value: number): number {\n1325:   return Math.min(1, Math.max(0, value));\n1326: }\n1327: \n1328: function selectTier2FailOpenFallback(\n1329:   specFolderAbsolute: string,\n1330:   decision: RoutingDecision,\n1331: ): {\n1332:   category: RouteCategory;\n1333:   confidence: number;\n1334:   targetDocPath: string;\n1335:   routedDocPath: string;\n1336:   targetAnchorId: string;\n1337:   mergeMode: RoutingDecision['target']['mergeMode'];\n1338:   warningMessage: string;\n1339: } | null {\n1340:   if (decision.tierUsed !== 3) {\n1341:     return null;\n1342:   }\n1343: \n1344:   for (const hit of decision.tier2TopK) {\n1345:     if (hit.category === 'drop') {\n1346:       continue;\n1347:     }\n1348:     const fallbackConfidence = clampRoutingConfidence(hit.similarity - TIER2_FALLBACK_PENALTY);\n1349:     if (fallbackConfidence < TIER3_THRESHOLD) {\n1350:       continue;\n1351:     }\n1352: \n1353:     const targetDocPath = resolveCanonicalTargetDocPath(specFolderAbsolute, hit.target_doc);\n1354:     if (!fs.existsSync(targetDocPath)) {\n1355:       continue;\n1356:     }\n1357: \n1358:     return {\n1359:       category: hit.category as RouteCategory,\n1360:       confidence: fallbackConfidence,\n1361:       targetDocPath,\n1362:       routedDocPath: hit.target_doc,\n1363:       targetAnchorId: hit.target_anchor,\n1364:       mergeMode: hit.merge_intent,\n1365:       warningMessage: `Tier 3 routing was unusable; fell back to Tier 2 prototype match ${hit.category}.`,\n1366:     };\n1367:   }\n1368: \n1369:   return null;\n1370: }\n1371: \n1372: function buildFallbackContinuityRecord(params: {\n1373:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n1374:   routeCategory: RouteCategory;\n1375:   targetDocPath: string;\n1376:   specFolderAbsolute: string;\n1377:   currentContent: string;\n1378: }): ThinContinuityRecord {\n1379:   const { parsed, routeCategory, targetDocPath, specFolderAbsolute, currentContent } = params;\n1380:   const relativeTargetPath = path.relative(specFolderAbsolute, targetDocPath).replace(/\\\\/g, '/');\n1381:   const absoluteSpecFolder = specFolderAbsolute.replace(/\\\\/g, '/');\n1382:   const packetPointerFromPath = absoluteSpecFolder.includes('/specs/')\n1383:     ? absoluteSpecFolder.split('/specs/')[1]\n1384:     : parsed.specFolder.replace(/^specs\\//u, '');\n1385:   const title = clipInlineText(parsed.title ?? (normalizeRoutingChunkText(currentContent) || 'Updated canonical continuity'));\n1386:   const nextActionByRoute: Record<RouteCategory, string> = {\n1387:     narrative_progress: 'Review routed update',\n1388:     narrative_delivery: 'Verify delivery route',\n1389:     decision: 'Review ADR follow-up',\n1390:     handover_state: 'Resume routed handover',\n1391:     research_finding: 'Review cited finding',\n1392:     task_update: 'Verify task alignment',\n1393:     metadata_only: 'Refresh continuity',\n1394:     drop: 'Inspect refused route',\n1395:   };\n1396: \n1397:   return {\n1398:     packet_pointer: packetPointerFromPath,\n1399:     last_updated_at: new Date().toISOString().replace(/\\.\\d{3}Z$/u, 'Z'),\n1400:     last_updated_by: 'memory-save',\n1401:     recent_action: title,\n1402:     next_safe_action: nextActionByRoute[routeCategory],\n1403:     blockers: [],\n1404:     key_files: relativeTargetPath ? [relativeTargetPath] : [],\n1405:     session_dedup: {\n1406:       fingerprint: buildContinuityFingerprint(currentContent),\n1407:       session_id: 'memory-save',\n1408:       parent_session_id: null,\n1409:     },\n1410:     completion_pct: 0,\n1411:     open_questions: [],\n1412:     answered_questions: [],\n1413:   };\n1414: }\n1415: \n1416: function buildCanonicalMergePayload(params: {\n1417:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n1418:   routeCategory: RouteCategory;\n1419:   mergeMode: MergeModeHint;\n1420:   content: string;\n1421: }): Record<string, unknown> {\n1422:   const { parsed, routeCategory, mergeMode, content } = params;\n1423:   const paragraphs = extractParagraphs(content);\n1424:   const firstParagraph = paragraphs[0] ?? clipInlineText(content, 160);\n1425:   const secondParagraph = paragraphs[1] ?? firstParagraph;\n1426:   const listItems = extractListItems(content);\n1427: \n1428:   switch (mergeMode) {\n1429:     case 'append-as-paragraph':\n1430:       return { paragraph: firstParagraph };\n1431:     case 'append-section':\n1432:       return {\n1433:         title: clipInlineText(parsed.title ?? `${routeCategory.replace(/_/g, ' ')} update`, 72),\n1434:         body: normalizeRoutingChunkText(content) || firstParagraph,\n1435:       };\n1436:     case 'insert-new-adr':\n1437:       return {\n1438:         title: clipInlineText(parsed.title ?? 'Captured canonical decision', 80),\n1439:         context: firstParagraph,\n1440:         decision: secondParagraph,\n1441:         consequences: listItems.slice(0, 3),\n1442:       };\n1443:     case 'update-in-place': {\n1444:       const targetId = content.match(/\\b(?:T\\d{3}|CHK-\\d{3})\\b/u)?.[0];\n1445:       if (!targetId) {\n1446:         throw new Error(`Canonical task update could not find a target task/checklist id in routed content.`);\n1447:       }\n1448:       const checked = /\\[[xX]\\]/u.test(content)\n1449:         ? true\n1450:         : (/\\[[ ]\\]/u.test(content) ? false : undefined);\n1451:       return {\n1452:         targetId,\n1453:         ...(checked === undefined ? {} : { checked }),\n1454:         evidence: clipInlineText(parsed.title ?? firstParagraph, 96),\n1455:       };\n1456:     }\n1457:     case 'append-table-row':\n1458:       return {\n1459:         cells: [\n1460:           clipInlineText(parsed.title ?? routeCategory, 48),\n1461:           'Updated',\n1462:           clipInlineText(firstParagraph, 96),\n1463:         ],\n1464:         dedupeColumn: 0,\n1465:       };\n1466:     default:\n1467:       return { paragraph: firstParagraph };\n1468:   }\n1469: }\n1470: \n1471: async function buildCanonicalAtomicPreparedSave(\n1472:   params: AtomicSaveParams,\n1473:   database: ReturnType<typeof requireDb>,\n1474: ): Promise<{ status: 'ready'; prepared: CanonicalAtomicPrepared; persistedContent: string; persistedFilePath: string } | { status: 'abort'; result: AtomicSaveResult }> {\n1475:   const preparedMemory = prepareParsedMemoryForIndexing(\n1476:     memoryParser.parseMemoryContent(params.file_path, params.content),\n1477:     database,\n1478:     {\n1479:       qualityLoopMode: params.plannerMode === 'full-auto' ? 'full-auto' : 'advisory',\n1480:     },\n1481:   );\n1482:   if (!preparedMemory.validation.valid) {\n1483:     return {\n1484:       status: 'abort',\n1485:       result: {\n1486:         success: false,\n1487:         filePath: params.file_path,\n1488:         status: 'error',\n1489:         summary: 'Atomic save preflight failed',\n1490:         message: 'Parsed content failed validation before canonical atomic save',\n1491:         error: `Validation failed: ${preparedMemory.validation.errors.join(', ')}`,\n1492:       },\n1493:     };\n1494:   }\n1495: \n1496:   if (preparedMemory.qualityLoopResult.fixes.length > 0 && preparedMemory.qualityLoopResult.passed && preparedMemory.qualityLoopResult.fixedContent) {\n1497:     console.error(`[memory-save] Quality loop applied ${preparedMemory.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(params.file_path)} before canonical pending-file promotion`);\n1498:   }\n1499: \n1500:   const specFolderAbsolute = resolveSpecFolderAbsoluteFromFilePath(params.file_path, preparedMemory.parsed.specFolder);\n1501:   const packetLevel = toCanonicalPacketLevel(detectSpecLevelFromParsed(path.join(specFolderAbsolute, 'spec.md')));\n1502:   const packetKind = deriveCanonicalPacketKind(specFolderAbsolute, preparedMemory.parsed.specFolder);\n1503:   const saveMode = params.routeAs ? 'route-as' : 'natural';\n1504:   const tier3Enabled = isTier3RoutingEnabled();\n1505:   const router = buildCanonicalRouter({ tier3Enabled });\n1506:   const routingChunkText = normalizeRoutingChunkText(params.content);\n1507:   const likelyPhaseAnchor = deriveLikelyPhaseAnchorForCanonicalRouting({\n1508:     routingChunkText,\n1509:     specFolder: preparedMemory.parsed.specFolder,\n1510:     targetAnchorId: params.targetAnchorId,\n1511:   });\n1512:   const decision = await router.classifyContent(\n1513:     {\n1514:       id: path.basename(params.file_path),\n1515:       text: routingChunkText,\n\n(Output capped at 50 KB. Showing lines 1-1515. Use offset=1516 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Save Handler\n// ───────────────────────────────────────────────────────────────\n/* --- 1. DEPENDENCIES --- */\n\n// Node built-ins\nimport { createHash, randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport path from 'path';\n\n// Shared packages\nimport { validateFilePath } from '@spec-kit/shared/utils/path-security';\nimport {\n  evaluateMemorySufficiency,\n  MEMORY_SUFFICIENCY_REJECTION_CODE,\n  type MemorySufficiencyResult,\n} from '@spec-kit/shared/parsing/memory-sufficiency';\nimport {\n  validateMemoryTemplateContract,\n  type MemoryTemplateContractResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Save Handler\n// ───────────────────────────────────────────────────────────────\n/* --- 1. DEPENDENCIES --- */\n\n// Node built-ins\nimport { createHash, randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport path from 'path';\n\n// Shared packages\nimport { validateFilePath } from '@spec-kit/shared/utils/path-security';\nimport {\n  evaluateMemorySufficiency,\n  MEMORY_SUFFICIENCY_REJECTION_CODE,\n  type MemorySufficiencyResult,\n} from '@spec-kit/shared/parsing/memory-sufficiency';\nimport {\n  validateMemoryTemplateContract,\n  type MemoryTemplateContractResult,\n} from '@spec-kit/shared/parsing/memory-template-contract';\nimport {\n  evaluateSpecDocHealth,\n  type SpecDocHealthResult,\n} from '@spec-kit/shared/parsing/spec-doc-health';\n\n// Internal modules\nimport { ALLOWED_BASE_PATHS, checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { scrubSecretsDetailed } from '../lib/parsing/secret-scrubber.js';\nimport { createFilePathValidator } from '../utils/validators.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as transactionManager from '../lib/storage/transaction-manager.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as preflight from '../lib/validation/preflight.js';\nimport { requireDb } from '../utils/index.js';\nimport type { MCPResponse } from './types.js';\nimport { createAppendOnlyMemoryRecord, recordLineageVersion, retirePredecessorForActiveReindex } from '../lib/storage/lineage-state.js';\nimport { determineAction } from '../lib/storage/reconsolidation.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\n\nimport { runQualityGate, isQualityGateEnabled } from '../lib/validation/save-quality-gate.js';\nimport {\n  isPostInsertEnrichmentEnabled,\n  isPostInsertEnrichmentAsync,\n  isSaveQualityGateEnabled,\n  isSaveReconsolidationEnabled,\n  resolveSavePlannerMode,\n} from '../lib/search/search-flags.js';\n\nimport { getCanonicalPathKey, resolveCanonicalPath } from '../lib/utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../lib/utils/index-scope.js';\nimport { findSimilarMemories } from './pe-gating.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { indexChunkedMemoryFile, shouldUseChunkedIndexing } from './chunking-orchestrator.js';\nimport { applyPostInsertMetadata } from './save/db-helpers.js';\nimport {\n  createMemoryRecord,\n  findSamePathExistingMemory,\n  type CreateRecordIdentityHints,\n  type MemoryScopeMatch,\n} from './save/create-record.js';\nimport {\n  buildGovernanceLogicalKey,\n  buildGovernancePostInsertFields,\n  ensureGovernanceRuntime,\n  recordGovernanceAudit,\n  recordTierDowngradeAudit,\n  validateGovernedIngest,\n  type GovernanceDecision,\n} from '../lib/governance/scope-governance.js';\nimport { delete_memory_from_database } from '../lib/search/vector-index-mutations.js';\nimport {\n  runQualityLoop,\n} from './quality-loop.js';\nimport type {\n  QualityLoopResult,\n} from './quality-loop.js';\n\n// O2-5/O2-12: V-rule validation (previously only in workflow path)\nimport {\n  validateMemoryQualityContent,\n  determineValidationDisposition,\n} from './v-rule-bridge.js';\n\n// Save pipeline modules\nimport type {\n  IndexResult,\n  RouteCategory,\n  MergeModeHint,\n  SaveArgs,\n  AtomicSaveParams,\n  AtomicSaveOptions,\n  AtomicSaveResult,\n  PlannerAdvisory,\n  PlannerBlocker,\n  PlannerFollowUpAction,\n  PlannerRouteTarget,\n} from './save/index.js';\nimport { checkExistingRow, checkContentHashDedup } from './save/dedup.js';\nimport { generateOrCacheEmbedding, persistPendingEmbeddingCacheWrite } from './save/embedding-pipeline.js';\nimport { evaluateAndApplyPeDecision } from './save/pe-orchestration.js';\nimport {\n  findScopeFilteredCandidates,\n  getRequestedScope,\n  runReconsolidationIfEnabled,\n} from './save/reconsolidation-bridge.js';\nimport {\n  runPostInsertEnrichmentIfEnabled,\n  runPostInsertEnrichment,\n  shouldRunPostInsertEnrichment,\n  buildDeferredEnrichmentResult,\n} from './save/post-insert.js';\nimport type { PostInsertEnrichmentResult } from './save/post-insert.js';\nimport {\n  markEnrichmentPending,\n  needsEnrichmentRepair,\n  POST_INSERT_ENRICHMENT_VERSION,\n  recordEnrichmentResult,\n  repairEnrichmentOnReplay,\n} from './save/enrichment-state.js';\nimport {\n  buildIndexResult,\n  buildPlannerResponse,\n  buildSaveResponse,\n  classifySaveErrorCode,\n  extractSaveErrorDetails,\n  serializePlannerAdvisory,\n  serializePlannerBlocker,\n  serializePlannerFollowUpAction,\n  serializePlannerProposedEdit,\n  serializePlannerRouteTarget,\n} from './save/response-builder.js';\nimport type {\n  IndexingOrigin,\n  ReconsolidationFailureReason,\n  ReconsolidationOperationState,\n} from './save/types.js';\nimport { atomicIndexMemory } from './save/atomic-index-memory.js';\nimport { createMCPErrorResponse } from '../lib/response/envelope.js';\nimport {\n  buildTier3Prompt,\n  createContentRouter,\n  getTier3Contract,\n  isTier3RoutingEnabled,\n  InMemoryRouterCache,\n  TIER2_FALLBACK_PENALTY,\n  TIER3_THRESHOLD,\n  type RoutingDecision,\n  type Tier3ClassifierInput,\n  type Tier3RawResponse,\n} from '../lib/routing/content-router.js';\nimport { anchorMergeOperation } from '../lib/merge/anchor-merge-operation.js';\nimport {\n  readThinContinuityRecord,\n  upsertThinContinuityInMarkdown,\n  type ThinContinuityRecord,\n} from '../lib/continuity/thin-continuity-record.js';\nimport {\n  runSpecDocStructureRule,\n  type ContaminationPlan,\n  type MergePlan,\n  type PostSavePlan,\n} from '../lib/validation/spec-doc-structure.js';\nimport { detectSpecLevelFromParsed } from './handler-utils.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport {\n  applyWriteProvenance,\n  persistSourceKind,\n  type SourceKind,\n  type WriteProvenanceContext,\n} from '../lib/storage/write-provenance.js';\nimport {\n  deleteIdempotencyReceiptByKey,\n  extractMemoryIdFromResponse,\n  isMemoryIdempotencyEnabled,\n  lookupIdempotencyReceipt,\n  lookupIdempotencyReceiptByKey,\n  markResponseWithReceiptStoreConflict,\n  shouldStoreMemorySaveReceipt,\n  storeIdempotencyReceipt,\n  type IdempotencyReceiptKey,\n} from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n\n// Extracted sub-modules\nimport { withSpecFolderLock } from './save/spec-folder-mutex.js';\nimport { buildParsedMemoryEvidenceSnapshot } from './save/markdown-evidence-builder.js';\nimport {\n  applyInsufficiencyMetadata,\n  buildInsufficiencyRejectionResult,\n  buildTemplateContractRejectionResult,\n  buildDryRunSummary,\n  buildPlannerAdvisory,\n  buildPlannerBlocker,\n} from './save/validation-responses.js';\n\nimport { markMemorySuperseded } from './pe-gating.js';\nimport { resolveMemoryReference } from './causal-links-processor.js';\nimport { refreshAutoEntitiesForMemory } from '../lib/extraction/entity-extractor.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Verify-fix-verify memory quality loop\n// Feature catalog: Dry-run preflight for memory_save\n// Feature catalog: Prediction-error save arbitration\n\n\n// Create local path validator\nconst validateFilePathLocal = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\nconst MANUAL_FALLBACK_SOURCE_CLASSIFICATION = 'manual-fallback' as const;\nexport const MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE = 'E_MEMORY_INDEX_SCOPE_EXCLUDED';\nconst ROUTED_CONTINUITY_ANCHOR_ID = '_memory.continuity';\nconst tier3RoutingCache = new InMemoryRouterCache();\n\nfunction emitPostInsertEnrichmentSubscribers(memoryId: number, sourceOperation: string): void {\n  try {\n    runPostMutationHooks(sourceOperation, {\n      memoryId,\n      statediffActions: [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: String(memoryId),\n        sourceOperation,\n      })],\n    });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[memory-save] Post-insert enrichment subscriber dispatch failed: ${message}`);\n  }\n}\n\nasync function repairReplayEnrichmentIfNeeded(\n  database: Parameters<typeof needsEnrichmentRepair>[0],\n  memoryId: number | undefined,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n): Promise<void> {\n  if (memoryId == null || !needsEnrichmentRepair(database, memoryId)) {\n    return;\n  }\n\n  await repairEnrichmentOnReplay({\n    database,\n    parsed,\n    plannerMode: 'full-auto',\n  }, memoryId);\n}\n\ninterface PreparedParsedMemory {\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n  validation: ReturnType<typeof memoryParser.validateParsedMemory>;\n  qualityLoopResult: QualityLoopResult;\n  sufficiencyResult: MemorySufficiencyResult;\n  templateContract: MemoryTemplateContractResult;\n  specDocHealth: SpecDocHealthResult | null;\n  finalizedFileContent: string | null;\n  sourceClassification: 'template-generated' | typeof MANUAL_FALLBACK_SOURCE_CLASSIFICATION;\n}\n\nfunction createIndexScopeExcludedResponse(\n  requestId: string,\n  canonicalPath: string,\n  originalPath: string,\n): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_save',\n    error: `Memory indexing excluded for path: ${canonicalPath}`,\n    code: MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE,\n    details: {\n      requestId,\n      canonicalPath,\n      filePath: originalPath,\n    },\n    recovery: {\n      hint: 'Move the file into an indexable spec folder or constitutional rule path before retrying.',\n      actions: ['Verify the path is not under z_future/ or external/'],\n      severity: 'warning',\n    },\n  });\n}\n\ntype ParsedMemoryWithIndexHints = ReturnType<typeof memoryParser.parseMemoryFile> & {\n  _skipIndex?: boolean;\n  _vRuleIndexBlockIds?: string[];\n};\n\ninterface RoutedSaveOptions extends CreateRecordIdentityHints {\n  routeAs?: RouteCategory;\n  mergeModeHint?: MergeModeHint;\n}\n\ninterface RoutedRecordIdentity {\n  targetDocPath: string;\n  canonicalFilePath: string;\n  targetAnchorId: string | null;\n  routeAs: RouteCategory | null;\n  continuitySourceKey: string | null;\n}\n\ntype CanonicalPacketLevel = 'L1' | 'L2' | 'L3' | 'L3+';\ntype CanonicalPacketKind = 'feature' | 'phase' | 'remediation' | 'research' | 'unknown';\n\ninterface CanonicalAtomicValidatorPlan {\n  folder: string;\n  level: string;\n  mergePlan: MergePlan | null;\n  contaminationPlan: ContaminationPlan | null;\n  postSavePlan: PostSavePlan | null;\n}\n\ninterface CanonicalAtomicPrepared {\n  preparedMemory: PreparedParsedMemory;\n  routing: RoutedSaveOptions;\n  validatorPlan: CanonicalAtomicValidatorPlan | null;\n}\n\nconst STANDARD_MEMORY_TEMPLATE_MARKERS = [\n  '## continue session',\n  '## recovery hints',\n  '<!-- memory metadata -->',\n];\nconst CANONICAL_SPEC_DOCUMENT_TYPES = new Set([\n  'spec',\n  'plan',\n  'tasks',\n  'checklist',\n  'decision_record',\n  'implementation_summary',\n  'research',\n  'handover',\n  'resource_map',\n]);\nconst ROUTE_CATEGORIES = new Set<RouteCategory>([\n  'narrative_progress',\n  'narrative_delivery',\n  'decision',\n  'handover_state',\n  'research_finding',\n  'task_update',\n  'metadata_only',\n  'drop',\n]);\n\nclass VRuleUnavailableError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'VRuleUnavailableError';\n  }\n}\n\nfunction isVRuleUnavailableResult(value: unknown): value is {\n  passed: false;\n  status: 'error' | 'warning';\n  message: string;\n  _unavailable: true;\n} {\n  return typeof value === 'object'\n    && value !== null\n    && 'passed' in value\n    && (value as { passed?: unknown }).passed === false\n    && 'status' in value\n    && typeof (value as { status?: unknown }).status === 'string'\n    && 'message' in value\n    && typeof (value as { message?: unknown }).message === 'string';\n}\n\nfunction classifyMemorySaveSource(\n  content: string,\n): 'template-generated' | typeof MANUAL_FALLBACK_SOURCE_CLASSIFICATION {\n  const normalizedContent = content.toLowerCase();\n  const hasAnyStandardMarker = STANDARD_MEMORY_TEMPLATE_MARKERS.some((marker) => normalizedContent.includes(marker));\n  return hasAnyStandardMarker ? 'template-generated' : MANUAL_FALLBACK_SOURCE_CLASSIFICATION;\n}\n\n// Files that are structural metadata for graph traversal and continuity, not\n// semantic-search corpus. The memory-sufficiency gate is built around markdown\n// anchors and prose evidence; pure-JSON structural files cannot satisfy it by\n// construction. We exempt them from the sufficiency floor so they index with\n// whatever flattened text the indexer produces — graph traversal already reads\n// these files directly from disk for parent/child/status, so the embedding is\n// best-effort, not load-bearing.\nconst STRUCTURAL_METADATA_FILENAMES = new Set<string>(['graph-metadata.json']);\n\nfunction isStructuralMetadataFile(filePath: string): boolean {\n  return STRUCTURAL_METADATA_FILENAMES.has(path.basename(filePath));\n}\n\nfunction shouldBypassTemplateContract(\n  sourceClassification: PreparedParsedMemory['sourceClassification'],\n  sufficiencyResult: MemorySufficiencyResult,\n  templateContract: MemoryTemplateContractResult,\n  specDocHealth?: SpecDocHealthResult | null,\n  documentType?: string,\n): boolean {\n  const isValidCanonicalSpecDoc = Boolean(\n    documentType\n      && CANONICAL_SPEC_DOCUMENT_TYPES.has(documentType)\n      && specDocHealth?.pass === true,\n  );\n\n  return sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION\n    && sufficiencyResult.pass\n    && !templateContract.valid\n    && (\n      isValidCanonicalSpecDoc\n      || (\n        sufficiencyResult.evidenceCounts.primary === 0\n        && sufficiencyResult.evidenceCounts.support >= 3\n        && sufficiencyResult.evidenceCounts.anchors >= 1\n      )\n    );\n}\n\nfunction buildQualityLoopMetadata(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  database: ReturnType<typeof requireDb>,\n): Record<string, unknown> {\n  return {\n    title: parsed.title ?? '',\n    triggerPhrases: parsed.triggerPhrases,\n    specFolder: parsed.specFolder,\n    contextType: parsed.contextType,\n    importanceTier: parsed.importanceTier,\n    causalLinks: parsed.causalLinks,\n    filePath: parsed.filePath,\n    lastModified: parsed.lastModified,\n    resolveReference: (reference: string) => resolveMemoryReference(database, reference) !== null,\n  };\n}\n\nfunction prepareParsedMemoryForIndexing(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  database: ReturnType<typeof requireDb>,\n  options: {\n    emitEvalMetrics?: boolean;\n    qualityLoopMode?: 'advisory' | 'full-auto';\n  } = {},\n): PreparedParsedMemory {\n  // Resolve to the canonical path before applying memory-index governance.\n  const canonicalFilePath = resolveCanonicalPath(path.resolve(parsed.filePath));\n  if (!shouldIndexForMemory(canonicalFilePath)) {\n    throw new Error(`Memory indexing excluded for path: ${parsed.filePath}`);\n  }\n  if (parsed.importanceTier === 'constitutional' && !isIndexableConstitutionalMemoryPath(canonicalFilePath)) {\n    console.warn('[memory-save] importance_tier=constitutional rejected for non-constitutional path; downgrading to important', {\n      file_path: parsed.filePath,\n    });\n    try {\n      recordTierDowngradeAudit(database, {\n        logicalKey: buildGovernanceLogicalKey(parsed.specFolder, canonicalFilePath, null),\n        requestedTier: 'constitutional',\n        nextTier: 'important',\n        source: 'memory_save',\n        filePath: parsed.filePath,\n        canonicalFilePath,\n      });\n    } catch (error: unknown) {\n      console.warn(\n        '[memory-save] governance_audit insert failed for tier downgrade:',\n        error instanceof Error ? error.message : String(error),\n      );\n    }\n    parsed.importanceTier = 'important';\n  }\n\n  const validation = memoryParser.validateParsedMemory(parsed);\n  if (validation.warnings && validation.warnings.length > 0) {\n    console.warn(`[memory] Warning for ${path.basename(parsed.filePath)}:`);\n    validation.warnings.forEach((warning: string) => console.warn(`[memory]   - ${warning}`));\n  }\n\n  // O2-5/O2-12: Run V-rule validation (previously only in workflow path)\n  const vRuleResult = validateMemoryQualityContent(parsed.content, { filePath: parsed.filePath });\n  if (isVRuleUnavailableResult(vRuleResult) && vRuleResult.status === 'error') {\n    throw new VRuleUnavailableError(vRuleResult.message);\n  }\n  if (vRuleResult && '_unavailable' in vRuleResult) {\n    validation.warnings.push('V-rule validator module unavailable — quality gate bypassed. Save proceeds without V-rule enforcement.');\n  }\n  if (vRuleResult && !isVRuleUnavailableResult(vRuleResult) && !vRuleResult.valid) {\n    const vRuleDisposition = determineValidationDisposition(\n      vRuleResult.failedRules,\n      parsed.memoryTypeSource || null,\n    );\n    if (vRuleDisposition && vRuleDisposition.disposition === 'abort_write') {\n      const failedRuleIds = vRuleDisposition.blockingRuleIds;\n      console.error(`[memory-save] V-rule hard block for ${path.basename(parsed.filePath)}: ${failedRuleIds.join(', ')}`);\n      // Return early with a rejected quality loop result so callers see the block\n      const rejectScore = { total: 0, breakdown: { triggers: 0, anchors: 0, budget: 0, coherence: 0 }, issues: [`V-rule hard block: ${failedRuleIds.join(', ')}`] };\n      return {\n        parsed,\n        validation,\n        qualityLoopResult: {\n          passed: false,\n          score: rejectScore,\n          attempts: 0,\n          fixes: [],\n          rejected: true,\n          rejectionReason: `V-rule hard block: ${failedRuleIds.join(', ')}`,\n        },\n        sufficiencyResult: {\n          pass: false,\n          rejectionCode: MEMORY_SUFFICIENCY_REJECTION_CODE,\n          score: 0,\n          reasons: [`V-rule hard block: ${failedRuleIds.join(', ')}`],\n          evidenceCounts: { primary: 0, support: 0, total: 0, semanticChars: 0, uniqueWords: 0, anchors: 0, triggerPhrases: 0 },\n        },\n        templateContract: { valid: true, violations: [], missingAnchors: [], unexpectedTemplateArtifacts: [] } as MemoryTemplateContractResult,\n        specDocHealth: null,\n        finalizedFileContent: null,\n        sourceClassification: 'template-generated',\n      };\n    }\n    if (vRuleDisposition && vRuleDisposition.disposition === 'write_skip_index') {\n      console.warn(`[memory-save] V-rule index block for ${path.basename(parsed.filePath)}: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n      validation.warnings.push(`V-rule index block: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n      // F07-002: Flag to skip indexing for write_skip_index disposition\n      const parsedWithIndexHints = parsed as ParsedMemoryWithIndexHints;\n      parsedWithIndexHints._skipIndex = true;\n      parsedWithIndexHints._vRuleIndexBlockIds = vRuleDisposition.indexBlockingRuleIds;\n    }\n  }\n\n  const qualityLoopResult = runQualityLoop(parsed.content, buildQualityLoopMetadata(parsed, database), {\n    emitEvalMetrics: options.emitEvalMetrics,\n    mode: options.qualityLoopMode ?? 'advisory',\n  });\n  parsed.qualityScore = qualityLoopResult.score.total;\n  parsed.qualityFlags = Array.from(new Set([\n    ...(parsed.qualityFlags ?? []),\n    ...qualityLoopResult.score.issues,\n  ]));\n  if (qualityLoopResult.fixedTriggerPhrases) {\n    parsed.triggerPhrases = qualityLoopResult.fixedTriggerPhrases;\n  }\n  const finalizedFileContent = qualityLoopResult.fixedContent\n    && qualityLoopResult.passed\n    ? qualityLoopResult.fixedContent\n    : null;\n  if (finalizedFileContent) {\n    parsed.content = finalizedFileContent;\n    parsed.contentHash = memoryParser.computeContentHash(parsed.content);\n  }\n\n  const sourceClassification = classifyMemorySaveSource(parsed.content);\n  if (sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION) {\n    const warning = 'Manual fallback save mode detected; standard generate-context template markers are missing.';\n    console.warn(`[memory-save] ${warning} ${path.basename(parsed.filePath)}`);\n    validation.warnings.push(warning);\n  }\n\n  const sufficiencyResult = evaluateMemorySufficiency(\n    {\n      ...buildParsedMemoryEvidenceSnapshot(parsed),\n      sourceClassification,\n    },\n  );\n  applyInsufficiencyMetadata(parsed, sufficiencyResult);\n  const templateContract = validateMemoryTemplateContract(parsed.content);\n\n  // Non-blocking spec doc health annotation\n  // Canonical saves land directly in the spec folder (e.g. .../NNN-name/decision-record.md),\n  // so the immediate parent is usually the spec folder itself.\n  let specDocHealth: SpecDocHealthResult | null = null;\n  if (parsed.specFolder && parsed.filePath) {\n    try {\n      const absFilePath = path.resolve(parsed.filePath);\n      const immediateParent = path.dirname(absFilePath);\n      const candidates = [immediateParent, path.dirname(immediateParent)];\n      for (const candidate of candidates) {\n        if (fs.existsSync(path.join(candidate, 'spec.md'))) {\n          specDocHealth = evaluateSpecDocHealth(candidate);\n          break;\n        }\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(\n        `[memory-save] spec-doc-health annotation skipped for ${path.basename(parsed.filePath)}: ${message}`\n      );\n    }\n  }\n\n  return {\n    parsed,\n    validation,\n    qualityLoopResult,\n    sufficiencyResult,\n    templateContract,\n    specDocHealth,\n    finalizedFileContent,\n    sourceClassification,\n  };\n}\n\nasync function finalizeMemoryFileContent(\n  filePath: string,\n  content: string,\n): Promise<void> {\n  const backupPath = `${filePath}.${randomUUID().slice(0, 8)}.bak`;\n  const tempPath = `${filePath}.${randomUUID().slice(0, 8)}.tmp`;\n  let backupCreated = false;\n  let tempCreated = false;\n\n  try {\n    try {\n      await fs.promises.copyFile(filePath, backupPath);\n      backupCreated = true;\n    } catch (backupErr: unknown) {\n      const errCode = typeof backupErr === 'object' && backupErr !== null && 'code' in backupErr\n        ? String((backupErr as NodeJS.ErrnoException).code)\n        : '';\n      if (errCode !== 'ENOENT') {\n        throw backupErr;\n      }\n    }\n\n    await fs.promises.writeFile(tempPath, content, 'utf-8');\n    tempCreated = true;\n    await fs.promises.rename(tempPath, filePath);\n    tempCreated = false;\n  } catch (writeErr: unknown) {\n    if (tempCreated) {\n      try {\n        await fs.promises.unlink(tempPath);\n      } catch {\n        // Best-effort cleanup only.\n      }\n    }\n    if (backupCreated) {\n      try {\n        await fs.promises.copyFile(backupPath, filePath);\n      } catch (restoreErr: unknown) {\n        console.warn(\n          '[memory-save] Auto-fix file restore failed after finalize error:',\n          restoreErr instanceof Error ? restoreErr.message : String(restoreErr),\n        );\n      }\n    }\n    throw writeErr;\n  } finally {\n    if (tempCreated) {\n      try {\n        await fs.promises.unlink(tempPath);\n      } catch {\n        // Best-effort cleanup only.\n      }\n    }\n    if (backupCreated) {\n      try {\n        await fs.promises.unlink(backupPath);\n      } catch {\n        // Best-effort cleanup only.\n      }\n    }\n  }\n}\n\nfunction appendResultWarning<T extends Record<string, unknown>>(result: T, warning: string | null): T {\n  if (!warning) {\n    return result;\n  }\n\n  const r = result as Record<string, unknown>;\n  const warnings = Array.isArray(r.warnings)\n    ? [...(r.warnings as string[])]\n    : [];\n  warnings.push(warning);\n  r.warnings = warnings;\n  return result;\n}\n\nclass SaveTimeReconsolidationAbort extends Error {\n  readonly result: {\n    status: 'failed';\n    reason: ReconsolidationFailureReason;\n    warnings?: string[];\n    persistedState?: ReconsolidationOperationState;\n  };\n\n  constructor(result: SaveTimeReconsolidationAbort['result']) {\n    super(result.reason);\n    this.name = 'SaveTimeReconsolidationAbort';\n    this.result = result;\n  }\n}\n\nfunction buildSaveTimeReconsolidationFailureResult(args: {\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n  validation: { warnings: string[] };\n  reconWarnings: string[];\n  failure: SaveTimeReconsolidationAbort['result'];\n  message?: string;\n}): IndexResult {\n  const warnings = [\n    ...args.validation.warnings,\n    ...args.reconWarnings,\n    ...(args.failure.warnings ?? []),\n  ];\n\n  return {\n    status: 'error',\n    id: 0,\n    specFolder: args.parsed.specFolder,\n    title: args.parsed.title ?? '',\n    triggerPhrases: args.parsed.triggerPhrases,\n    contextType: args.parsed.contextType,\n    importanceTier: args.parsed.importanceTier,\n    memoryType: args.parsed.memoryType,\n    memoryTypeSource: args.parsed.memoryTypeSource,\n    qualityScore: args.parsed.qualityScore,\n    qualityFlags: args.parsed.qualityFlags,\n    warnings,\n    error: args.message ?? `Save-time reconsolidation failed: ${args.failure.reason}`,\n    message: args.message ?? `Save-time reconsolidation failed: ${args.failure.reason}`,\n    saveTimeReconsolidation: args.failure,\n  };\n}\n\nfunction recordCrossPathPeSupersedes(\n  database: ReturnType<typeof requireDb>,\n  memoryId: number,\n  supersededMemoryId: number | null,\n  samePathMemoryId: number | null,\n  reason: string | null | undefined,\n): void {\n  if (supersededMemoryId == null || supersededMemoryId === samePathMemoryId) {\n    return;\n  }\n\n  causalEdges.init(database);\n  const evidence = reason && reason.trim().length > 0\n    ? reason.trim()\n    : 'Prediction-error contradiction across different file paths';\n  causalEdges.insertEdge(\n    String(memoryId),\n    String(supersededMemoryId),\n    causalEdges.RELATION_TYPES.SUPERSEDES,\n    1.0,\n    evidence,\n    true,\n    'auto',\n  );\n}\n\ninterface ChunkedInsertTracker {\n  parentId: number | null;\n  childIds: Set<number>;\n}\n\nfunction createChunkedInsertTracker(): ChunkedInsertTracker {\n  return {\n    parentId: null,\n    childIds: new Set<number>(),\n  };\n}\n\nfunction trackChunkedInsert(\n  tracker: ChunkedInsertTracker,\n  memoryId: number,\n  fields: Record<string, unknown>,\n): void {\n  if (typeof fields.chunk_index === 'number') {\n    tracker.childIds.add(memoryId);\n    return;\n  }\n\n  if (tracker.parentId == null) {\n    tracker.parentId = memoryId;\n  }\n}\n\nfunction rollbackCreatedChunkTree(\n  database: ReturnType<typeof requireDb>,\n  tracker: ChunkedInsertTracker,\n): { attempted: boolean; cleaned: boolean; error?: string } {\n  if (tracker.parentId == null) {\n    return { attempted: false, cleaned: false };\n  }\n\n  const childIds = new Set<number>(tracker.childIds);\n  try {\n    const persistedChildRows = database.prepare(`\n      SELECT id\n      FROM memory_index\n      WHERE parent_id = ?\n    `).all(tracker.parentId) as Array<{ id: number }>;\n    for (const row of persistedChildRows) {\n      childIds.add(row.id);\n    }\n  } catch {\n    // Best-effort lookup only. Tracked IDs remain authoritative for cleanup.\n  }\n\n  const cleanupErrors: string[] = [];\n  for (const childId of childIds) {\n    try {\n      if (!delete_memory_from_database(database, childId)) {\n        cleanupErrors.push(`Chunk ${childId} was not deleted`);\n      }\n    } catch (error: unknown) {\n      cleanupErrors.push(`Chunk ${childId} cleanup failed: ${getAtomicSaveErrorMessage(error)}`);\n    }\n  }\n\n  try {\n    if (!delete_memory_from_database(database, tracker.parentId)) {\n      cleanupErrors.push(`Parent ${tracker.parentId} was not deleted`);\n    }\n  } catch (error: unknown) {\n    cleanupErrors.push(`Parent ${tracker.parentId} cleanup failed: ${getAtomicSaveErrorMessage(error)}`);\n  }\n\n  if (cleanupErrors.length > 0) {\n    return {\n      attempted: true,\n      cleaned: false,\n      error: cleanupErrors.join('; '),\n    };\n  }\n\n  return { attempted: true, cleaned: true };\n}\n\nfunction captureAtomicSaveOriginalState(filePath: string): { existed: boolean; content: string | null } {\n  if (!fs.existsSync(filePath)) {\n    return { existed: false, content: null };\n  }\n\n  return {\n    existed: true,\n    content: fs.readFileSync(filePath, 'utf-8'),\n  };\n}\n\nfunction getAtomicSaveErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction deleteAtomicSaveFile(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n  const existed = fs.existsSync(filePath);\n  if (!existed) {\n    return { deleted: false, existed: false };\n  }\n\n  try {\n    fs.unlinkSync(filePath);\n    return { deleted: true, existed: true };\n  } catch (error: unknown) {\n    return {\n      deleted: false,\n      existed: true,\n      error: getAtomicSaveErrorMessage(error),\n    };\n  }\n}\n\nfunction restoreAtomicSaveOriginalState(\n  filePath: string,\n  originalState: { existed: boolean; content: string | null },\n): { restored: boolean; error?: string } {\n  try {\n    if (!originalState.existed) {\n      const deleteResult = deleteAtomicSaveFile(filePath);\n      if (!deleteResult.existed || deleteResult.deleted) {\n        return { restored: true };\n      }\n      return {\n        restored: false,\n        error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n      };\n    }\n\n    if (typeof originalState.content !== 'string') {\n      return { restored: false, error: 'Original file content is unavailable for rollback' };\n    }\n\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, originalState.content, 'utf-8');\n    return { restored: true };\n  } catch (error: unknown) {\n    return {\n      restored: false,\n      error: getAtomicSaveErrorMessage(error),\n    };\n  }\n}\n\nfunction cleanupAtomicSavePendingFile(\n  pendingPath: string,\n): { cleaned: boolean; existed: boolean; error?: string } {\n  try {\n    const deleteResult = deleteAtomicSaveFile(pendingPath);\n    if (!deleteResult.existed || deleteResult.deleted) {\n      return {\n        cleaned: true,\n        existed: deleteResult.existed,\n      };\n    }\n    return {\n      cleaned: false,\n      existed: deleteResult.existed,\n      error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n    };\n  } catch (error: unknown) {\n    return {\n      cleaned: false,\n      existed: true,\n      error: getAtomicSaveErrorMessage(error),\n    };\n  }\n}\n\nfunction applyRoutedSaveHints(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  routing: RoutedSaveOptions,\n): ReturnType<typeof memoryParser.parseMemoryFile> {\n  const parsedWithHints = parsed as ParsedMemoryWithIndexHints & Record<string, unknown>;\n  if (routing.targetDocPath) {\n    parsedWithHints.targetDocPath = routing.targetDocPath;\n    parsedWithHints.target_doc_path = routing.targetDocPath;\n  }\n  if (routing.targetAnchorId) {\n    parsedWithHints.targetAnchorId = routing.targetAnchorId;\n    parsedWithHints.target_anchor_id = routing.targetAnchorId;\n    parsedWithHints.anchorId = routing.targetAnchorId;\n    parsedWithHints.anchor_id = routing.targetAnchorId;\n  }\n  if (routing.routeAs) {\n    parsedWithHints.routeAs = routing.routeAs;\n    parsedWithHints.route_as = routing.routeAs;\n  }\n  if (routing.continuitySourceKey) {\n    parsedWithHints.continuitySourceKey = routing.continuitySourceKey;\n    parsedWithHints.continuity_source_key = routing.continuitySourceKey;\n  }\n  return parsedWithHints;\n}\n\nfunction buildRoutedSaveOptions(\n  filePath: string,\n  routeAs?: RouteCategory,\n  mergeModeHint?: MergeModeHint,\n  targetAnchorId?: string,\n): RoutedSaveOptions | undefined {\n  if (!routeAs && !mergeModeHint && !targetAnchorId) {\n    return undefined;\n  }\n\n  return {\n    targetDocPath: filePath,\n    ...(routeAs ? { routeAs } : {}),\n    ...(mergeModeHint ? { mergeModeHint } : {}),\n    ...(targetAnchorId ? { targetAnchorId } : {}),\n  };\n}\n\nfunction shouldUseCanonicalRouting(_params: Pick<AtomicSaveParams, 'routeAs' | 'mergeModeHint' | 'targetAnchorId'>): boolean {\n  // Test-only bypass: allows the atomic-save failure-injection suite\n  // to exercise the legacy prepareParsedMemoryForIndexing path without\n  // setting up full Tier 3 classifier fixtures.\n  if (process.env.SPECKIT_TEST_DISABLE_CANONICAL_ROUTING === 'true') return false;\n  return true; // Canonical routing is always enabled (Tier 3 LLM routing on by default)\n}\n\nfunction pickRoutedIdentityValue(value: unknown): string | null {\n  return typeof value === 'string' && value.trim().length > 0 ? value.trim() : null;\n}\n\nfunction pickRouteCategory(value: unknown): RouteCategory | null {\n  const normalized = pickRoutedIdentityValue(value);\n  if (!normalized || !ROUTE_CATEGORIES.has(normalized as RouteCategory)) {\n    return null;\n  }\n  return normalized as RouteCategory;\n}\n\nfunction isMergeModeHint(value: unknown): value is MergeModeHint {\n  return value === 'append-as-paragraph'\n    || value === 'insert-new-adr'\n    || value === 'append-table-row'\n    || value === 'update-in-place'\n    || value === 'append-section';\n}\n\nfunction resolveRoutedRecordIdentity(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  routedFilePath: string,\n  routing: RoutedSaveOptions,\n): RoutedRecordIdentity {\n  const routedRecord = parsed as unknown as Record<string, unknown>;\n  const routeAs = pickRouteCategory(routing.routeAs ?? routedRecord.routeAs ?? routedRecord.route_as);\n  const continuitySourceKey = pickRoutedIdentityValue(\n    routing.continuitySourceKey\n    ?? routedRecord.continuitySourceKey\n    ?? routedRecord.continuity_source_key\n    ?? routedRecord.sourceKey\n    ?? routedRecord.source_key,\n  );\n  const explicitTargetAnchorId = pickRoutedIdentityValue(\n    routing.targetAnchorId\n    ?? routedRecord.targetAnchorId\n    ?? routedRecord.target_anchor_id\n    ?? routedRecord.anchorId\n    ?? routedRecord.anchor_id,\n  );\n\n  return {\n    targetDocPath: routing.targetDocPath ?? routedFilePath,\n    canonicalFilePath: routing.canonicalFilePath ?? getCanonicalPathKey(routing.targetDocPath ?? routedFilePath),\n    targetAnchorId: explicitTargetAnchorId ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? ROUTED_CONTINUITY_ANCHOR_ID : null),\n    routeAs,\n    continuitySourceKey,\n  };\n}\n\nfunction toCanonicalPacketLevel(level: number | null): CanonicalPacketLevel {\n  if (level === 1) return 'L1';\n  if (level === 2) return 'L2';\n  if (level === 3) return 'L3';\n  return 'L3+';\n}\n\nfunction toValidatorLevel(packetLevel: CanonicalPacketLevel): string {\n  return packetLevel.replace(/^L/u, '');\n}\n\nfunction normalizeForFingerprint(content: string): string {\n  return content\n    .replace(/\\r\\n/g, '\\n')\n    .replace(/[ \\t]+$/gm, '');\n}\n\nfunction buildContinuityFingerprint(content: string): string {\n  return `sha256:${createHash('sha256').update(normalizeForFingerprint(content), 'utf8').digest('hex')}`;\n}\n\nfunction normalizePhaseAnchor(value: string | null | undefined): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const trimmed = value.trim();\n  const match = trimmed.match(/^phase(?:[\\s_-]+)?(\\d+)$/iu);\n  return match ? `phase-${match[1]}` : null;\n}\n\nfunction inferPhaseAnchorFromText(text: string): string | null {\n  const match = text.match(/\\bphase(?:[\\s_-]+)?(\\d+)\\b/iu);\n  return match ? `phase-${match[1]}` : null;\n}\n\nfunction inferPhaseAnchorFromSpecFolder(specFolder: string): string | null {\n  return inferPhaseAnchorFromText(specFolder.replace(/\\//g, ' '));\n}\n\nfunction deriveLikelyPhaseAnchorForCanonicalRouting(params: {\n  routingChunkText: string;\n  specFolder: string;\n  targetAnchorId?: string;\n}): string | null {\n  return normalizePhaseAnchor(params.targetAnchorId)\n    ?? inferPhaseAnchorFromText(params.routingChunkText)\n    ?? inferPhaseAnchorFromSpecFolder(params.specFolder);\n}\n\nfunction stripMarkdownFrontmatter(markdown: string): string {\n  return markdown.replace(/^(?:\\uFEFF)?---\\r?\\n[\\s\\S]*?\\r?\\n---(?:\\r?\\n)?/u, '');\n}\n\nfunction normalizeRoutingChunkText(markdown: string): string {\n  return stripMarkdownFrontmatter(markdown)\n    .replace(/<!--[\\s\\S]*?-->/g, ' ')\n    .replace(/\\r\\n/g, '\\n')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n}\n\nfunction extractFrontmatterScalar(markdown: string, key: string): string | null {\n  const frontmatterMatch = markdown.match(/^(?:\\uFEFF)?---\\r?\\n([\\s\\S]*?)\\r?\\n---(?:\\r?\\n)?/u);\n  if (!frontmatterMatch?.[1]) {\n    return null;\n  }\n\n  const escapedKey = key.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n  const scalarMatch = frontmatterMatch[1].match(\n    new RegExp(`^\\\\s*${escapedKey}:\\\\s*[\"']?([^\"'\\r\\n]+)[\"']?\\\\s*$`, 'imu'),\n  );\n  return scalarMatch?.[1]?.trim() ?? null;\n}\n\nfunction hasNumericSpecFolderName(folderPath: string): boolean {\n  return /^\\d{3}(?:[-_].+)?$/u.test(path.basename(folderPath));\n}\n\nfunction hasChildSpecFolders(specFolderAbsolute: string): boolean {\n  try {\n    const entries = fs.readdirSync(specFolderAbsolute, { withFileTypes: true });\n    return entries.some((entry) => {\n      if (!entry.isDirectory() || !hasNumericSpecFolderName(entry.name)) {\n        return false;\n      }\n      return fs.existsSync(path.join(specFolderAbsolute, entry.name, 'spec.md'));\n    });\n  } catch {\n    return false;\n  }\n}\n\nfunction deriveCanonicalPacketKind(\n  specFolderAbsolute: string,\n  specFolderKey: string,\n): CanonicalPacketKind {\n  const specMdPath = path.join(specFolderAbsolute, 'spec.md');\n  let specContent = '';\n  try {\n    specContent = fs.readFileSync(specMdPath, 'utf8');\n  } catch {\n    specContent = '';\n  }\n\n  const packetType = extractFrontmatterScalar(specContent, 'type')?.toLowerCase() ?? '';\n  const title = extractFrontmatterScalar(specContent, 'title')?.toLowerCase() ?? '';\n  const description = extractFrontmatterScalar(specContent, 'description')?.toLowerCase() ?? '';\n  const folderName = path.basename(specFolderAbsolute).toLowerCase();\n  const semanticHint = `${folderName} ${title} ${description}`;\n\n  if (packetType === 'research') {\n    return 'research';\n  }\n  if (/\\bremediation\\b/u.test(semanticHint)) {\n    return 'remediation';\n  }\n\n  const parentFolder = path.dirname(specFolderAbsolute);\n  const hasNumericParentPacket = hasNumericSpecFolderName(parentFolder)\n    && fs.existsSync(path.join(parentFolder, 'spec.md'));\n  if (!hasChildSpecFolders(specFolderAbsolute) && hasNumericParentPacket) {\n    return 'phase';\n  }\n\n  const normalizedSpecFolder = specFolderKey.replace(/^specs\\//u, '');\n  const depth = normalizedSpecFolder.split('/').filter(Boolean).length;\n  if (depth <= 2) {\n    return 'feature';\n  }\n\n  return hasNumericParentPacket ? 'phase' : 'feature';\n}\n\nfunction getTier3RoutingEndpoint(): string | null {\n  const endpoint = process.env.LLM_REFORMULATION_ENDPOINT?.trim();\n  return endpoint ? endpoint.replace(/\\/+$/u, '') : null;\n}\n\nfunction extractTier3MessageText(content: unknown): string | null {\n  if (typeof content === 'string') {\n    const trimmed = content.trim();\n    return trimmed.length > 0 ? trimmed : null;\n  }\n  if (Array.isArray(content)) {\n    const text = content\n      .map((entry) => {\n        if (!entry || typeof entry !== 'object') {\n          return '';\n        }\n        const textValue = (entry as { text?: unknown }).text;\n        return typeof textValue === 'string' ? textValue : '';\n      })\n      .join('')\n      .trim();\n    return text.length > 0 ? text : null;\n  }\n  return null;\n}\n\nfunction isTier3RawResponseShape(parsed: unknown): parsed is Tier3RawResponse {\n  if (!parsed || typeof parsed !== 'object') {\n    return false;\n  }\n\n  const record = parsed as Record<string, unknown>;\n  return typeof record.category === 'string'\n    && typeof record.confidence === 'number'\n    && typeof record.target_doc === 'string'\n    && typeof record.target_anchor === 'string'\n    && typeof record.merge_mode === 'string'\n    && typeof record.reasoning === 'string';\n}\n\nfunction parseTier3ClassifierResponse(rawText: string): Tier3RawResponse | null {\n  try {\n    const parsed = JSON.parse(rawText) as Record<string, unknown>;\n    if (!parsed || typeof parsed !== 'object') {\n      return null;\n    }\n    return isTier3RawResponseShape(parsed) ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nasync function classifyWithTier3Llm(input: Tier3ClassifierInput): Promise<Tier3RawResponse | null> {\n  const endpoint = getTier3RoutingEndpoint();\n  if (!endpoint) {\n    return null;\n  }\n\n  const apiKey = process.env.LLM_REFORMULATION_API_KEY?.trim() ?? '';\n  const contract = getTier3Contract();\n  const prompt = buildTier3Prompt(input);\n  const controller = new AbortController();\n  const timeoutId = setTimeout(() => controller.abort(), contract.timeoutMs);\n\n  try {\n    const response = await fetch(`${endpoint}/chat/completions`, {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        ...(apiKey ? { Authorization: `Bearer ${apiKey}` } : {}),\n      },\n      body: JSON.stringify({\n        model: contract.model,\n        messages: [\n          { role: 'system', content: prompt.system },\n          { role: 'user', content: prompt.user },\n        ],\n        reasoning_effort: contract.reasoningEffort,\n        temperature: contract.temperature,\n        max_tokens: contract.maxOutputTokens,\n        response_format: { type: 'json_object' },\n      }),\n      signal: controller.signal,\n    });\n\n    clearTimeout(timeoutId);\n\n    if (!response.ok) {\n      return null;\n    }\n\n    const data = await response.json() as {\n      choices?: Array<{\n        message?: {\n          content?: unknown;\n        };\n      }>;\n    };\n    const rawText = extractTier3MessageText(data.choices?.[0]?.message?.content);\n    return rawText ? parseTier3ClassifierResponse(rawText) : null;\n  } catch {\n    clearTimeout(timeoutId);\n    return null;\n  }\n}\n\nfunction buildCanonicalRouter(options: { tier3Enabled?: boolean } = {}) {\n  return createContentRouter({\n    classifyWithTier3: classifyWithTier3Llm,\n    cache: tier3RoutingCache,\n    tier3Enabled: options.tier3Enabled,\n  });\n}\n\nfunction collapseInlineWhitespace(value: string): string {\n  return value.replace(/\\s+/g, ' ').trim();\n}\n\nfunction clipInlineText(value: string, maxLength = 96): string {\n  const normalized = collapseInlineWhitespace(value);\n  return normalized.length <= maxLength ? normalized : `${normalized.slice(0, maxLength - 3).trimEnd()}...`;\n}\n\nfunction extractParagraphs(markdown: string): string[] {\n  return normalizeRoutingChunkText(markdown)\n    .split(/\\n\\s*\\n/g)\n    .map((entry) => collapseInlineWhitespace(entry))\n    .filter(Boolean);\n}\n\nfunction extractListItems(markdown: string): string[] {\n  return normalizeRoutingChunkText(markdown)\n    .split(/\\r?\\n/g)\n    .map((line) => line.match(/^\\s*(?:[-*+]|\\d+\\.)\\s+(.+)$/u)?.[1] ?? '')\n    .map((line) => clipInlineText(line, 120))\n    .filter(Boolean);\n}\n\nfunction resolveSpecFolderAbsoluteFromFilePath(filePath: string, specFolder: string): string {\n  const normalizedFilePath = filePath.replace(/\\\\/g, '/');\n  const normalizedSpecFolder = specFolder.replace(/^specs\\//u, '');\n  const markers = [\n    `/specs/${normalizedSpecFolder}/`,\n    `/specs/${specFolder}/`,\n  ];\n\n  for (const marker of markers) {\n    const markerIndex = normalizedFilePath.lastIndexOf(marker);\n    if (markerIndex >= 0) {\n      return path.normalize(`${normalizedFilePath.slice(0, markerIndex)}${marker.slice(0, -1)}`);\n    }\n  }\n\n  return path.resolve(path.dirname(filePath), '..');\n}\n\nfunction resolveMetadataHostDocPath(specFolderAbsolute: string): string {\n  const implementationSummaryPath = path.join(specFolderAbsolute, 'implementation-summary.md');\n  if (fs.existsSync(implementationSummaryPath)) {\n    return implementationSummaryPath;\n  }\n\n  return path.join(specFolderAbsolute, 'spec.md');\n}\n\nfunction resolveCanonicalTargetDocPath(\n  specFolderAbsolute: string,\n  routedDocPath: string,\n): string {\n  if (routedDocPath === 'spec-frontmatter' || routedDocPath === 'implementation-summary.md') {\n    return resolveMetadataHostDocPath(specFolderAbsolute);\n  }\n  return path.join(specFolderAbsolute, routedDocPath);\n}\n\nfunction clampRoutingConfidence(value: number): number {\n  return Math.min(1, Math.max(0, value));\n}\n\nfunction selectTier2FailOpenFallback(\n  specFolderAbsolute: string,\n  decision: RoutingDecision,\n): {\n  category: RouteCategory;\n  confidence: number;\n  targetDocPath: string;\n  routedDocPath: string;\n  targetAnchorId: string;\n  mergeMode: RoutingDecision['target']['mergeMode'];\n  warningMessage: string;\n} | null {\n  if (decision.tierUsed !== 3) {\n    return null;\n  }\n\n  for (const hit of decision.tier2TopK) {\n    if (hit.category === 'drop') {\n      continue;\n    }\n    const fallbackConfidence = clampRoutingConfidence(hit.similarity - TIER2_FALLBACK_PENALTY);\n    if (fallbackConfidence < TIER3_THRESHOLD) {\n      continue;\n    }\n\n    const targetDocPath = resolveCanonicalTargetDocPath(specFolderAbsolute, hit.target_doc);\n    if (!fs.existsSync(targetDocPath)) {\n      continue;\n    }\n\n    return {\n      category: hit.category as RouteCategory,\n      confidence: fallbackConfidence,\n      targetDocPath,\n      routedDocPath: hit.target_doc,\n      targetAnchorId: hit.target_anchor,\n      mergeMode: hit.merge_intent,\n      warningMessage: `Tier 3 routing was unusable; fell back to Tier 2 prototype match ${hit.category}.`,\n    };\n  }\n\n  return null;\n}\n\nfunction buildFallbackContinuityRecord(params: {\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n  routeCategory: RouteCategory;\n  targetDocPath: string;\n  specFolderAbsolute: string;\n  currentContent: string;\n}): ThinContinuityRecord {\n  const { parsed, routeCategory, targetDocPath, specFolderAbsolute, currentContent } = params;\n  const relativeTargetPath = path.relative(specFolderAbsolute, targetDocPath).replace(/\\\\/g, '/');\n  const absoluteSpecFolder = specFolderAbsolute.replace(/\\\\/g, '/');\n  const packetPointerFromPath = absoluteSpecFolder.includes('/specs/')\n    ? absoluteSpecFolder.split('/specs/')[1]\n    : parsed.specFolder.replace(/^specs\\//u, '');\n  const title = clipInlineText(parsed.title ?? (normalizeRoutingChunkText(currentContent) || 'Updated canonical continuity'));\n  const nextActionByRoute: Record<RouteCategory, string> = {\n    narrative_progress: 'Review routed update',\n    narrative_delivery: 'Verify delivery route',\n    decision: 'Review ADR follow-up',\n    handover_state: 'Resume routed handover',\n    research_finding: 'Review cited finding',\n    task_update: 'Verify task alignment',\n    metadata_only: 'Refresh continuity',\n    drop: 'Inspect refused route',\n  };\n\n  return {\n    packet_pointer: packetPointerFromPath,\n    last_updated_at: new Date().toISOString().replace(/\\.\\d{3}Z$/u, 'Z'),\n    last_updated_by: 'memory-save',\n    recent_action: title,\n    next_safe_action: nextActionByRoute[routeCategory],\n    blockers: [],\n    key_files: relativeTargetPath ? [relativeTargetPath] : [],\n    session_dedup: {\n      fingerprint: buildContinuityFingerprint(currentContent),\n      session_id: 'memory-save',\n      parent_session_id: null,\n    },\n    completion_pct: 0,\n    open_questions: [],\n    answered_questions: [],\n  };\n}\n\nfunction buildCanonicalMergePayload(params: {\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n  routeCategory: RouteCategory;\n  mergeMode: MergeModeHint;\n  content: string;\n}): Record<string, unknown> {\n  const { parsed, routeCategory, mergeMode, content } = params;\n  const paragraphs = extractParagraphs(content);\n  const firstParagraph = paragraphs[0] ?? clipInlineText(content, 160);\n  const secondParagraph = paragraphs[1] ?? firstParagraph;\n  const listItems = extractListItems(content);\n\n  switch (mergeMode) {\n    case 'append-as-paragraph':\n      return { paragraph: firstParagraph };\n    case 'append-section':\n      return {\n        title: clipInlineText(parsed.title ?? `${routeCategory.replace(/_/g, ' ')} update`, 72),\n        body: normalizeRoutingChunkText(content) || firstParagraph,\n      };\n    case 'insert-new-adr':\n      return {\n        title: clipInlineText(parsed.title ?? 'Captured canonical decision', 80),\n        context: firstParagraph,\n        decision: secondParagraph,\n        consequences: listItems.slice(0, 3),\n      };\n    case 'update-in-place': {\n      const targetId = content.match(/\\b(?:T\\d{3}|CHK-\\d{3})\\b/u)?.[0];\n      if (!targetId) {\n        throw new Error(`Canonical task update could not find a target task/checklist id in routed content.`);\n      }\n      const checked = /\\[[xX]\\]/u.test(content)\n        ? true\n        : (/\\[[ ]\\]/u.test(content) ? false : undefined);\n      return {\n        targetId,\n        ...(checked === undefined ? {} : { checked }),\n        evidence: clipInlineText(parsed.title ?? firstParagraph, 96),\n      };\n    }\n    case 'append-table-row':\n      return {\n        cells: [\n          clipInlineText(parsed.title ?? routeCategory, 48),\n          'Updated',\n          clipInlineText(firstParagraph, 96),\n        ],\n        dedupeColumn: 0,\n      };\n    default:\n      return { paragraph: firstParagraph };\n  }\n}\n\nasync function buildCanonicalAtomicPreparedSave(\n  params: AtomicSaveParams,\n  database: ReturnType<typeof requireDb>,\n): Promise<{ status: 'ready'; prepared: CanonicalAtomicPrepared; persistedContent: string; persistedFilePath: string } | { status: 'abort'; result: AtomicSaveResult }> {\n  const preparedMemory = prepareParsedMemoryForIndexing(\n    memoryParser.parseMemoryContent(params.file_path, params.content),\n    database,\n    {\n      qualityLoopMode: params.plannerMode === 'full-auto' ? 'full-auto' : 'advisory',\n    },\n  );\n  if (!preparedMemory.validation.valid) {\n    return {\n      status: 'abort',\n      result: {\n        success: false,\n        filePath: params.file_path,\n        status: 'error',\n        summary: 'Atomic save preflight failed',\n        message: 'Parsed content failed validation before canonical atomic save',\n        error: `Validation failed: ${preparedMemory.validation.errors.join(', ')}`,\n      },\n    };\n  }\n\n  if (preparedMemory.qualityLoopResult.fixes.length > 0 && preparedMemory.qualityLoopResult.passed && preparedMemory.qualityLoopResult.fixedContent) {\n    console.error(`[memory-save] Quality loop applied ${preparedMemory.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(params.file_path)} before canonical pending-file promotion`);\n  }\n\n  const specFolderAbsolute = resolveSpecFolderAbsoluteFromFilePath(params.file_path, preparedMemory.parsed.specFolder);\n  const packetLevel = toCanonicalPacketLevel(detectSpecLevelFromParsed(path.join(specFolderAbsolute, 'spec.md')));\n  const packetKind = deriveCanonicalPacketKind(specFolderAbsolute, preparedMemory.parsed.specFolder);\n  const saveMode = params.routeAs ? 'route-as' : 'natural';\n  const tier3Enabled = isTier3RoutingEnabled();\n  const router = buildCanonicalRouter({ tier3Enabled });\n  const routingChunkText = normalizeRoutingChunkText(params.content);\n  const likelyPhaseAnchor = deriveLikelyPhaseAnchorForCanonicalRouting({\n    routingChunkText,\n    specFolder: preparedMemory.parsed.specFolder,\n    targetAnchorId: params.targetAnchorId,\n  });\n  const decision = await router.classifyContent(\n    {\n      id: path.basename(params.file_path),\n      text: routingChunkText,","lineStart":1,"lineEnd":1515,"totalLines":1516,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781761986597,"end":1781761986605}},"metadata":{"openai":{"itemId":"fc_0d551e0e52b69abc016a3387c2815c81918b22991305adaf65"}},"id":"prt_ed94a4ff6001aD8fga2wzu8ik4","sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","messageID":"msg_ed94a0fdf0012AkOM1mWIEPE3y"}}
{"type":"tool_use","timestamp":1781761986635,"sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","part":{"type":"tool","tool":"read","callID":"call_Vxuw8FQbF03iZt6qRgx2ggQP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Atomic Index Memory\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import { randomUUID } from 'node:crypto';\n8: \n9: import * as transactionManager from '../../lib/storage/transaction-manager.js';\n10: \n11: import type {\n12:   AtomicSaveOptions,\n13:   AtomicSaveParams,\n14:   AtomicSaveResult,\n15:   IndexResult,\n16: } from './types.js';\n17: import { withSpecFolderLock } from './spec-folder-mutex.js';\n18: \n19: // Feature catalog: Memory indexing (memory_save)\n20: // Feature catalog: Atomic-save parity and partial-indexing hints\n21: \n22: interface AtomicIndexOriginalState {\n23:   existed: boolean;\n24:   content: string | null;\n25: }\n26: \n27: interface AtomicIndexPendingCleanupResult {\n28:   cleaned: boolean;\n29:   existed: boolean;\n30:   error?: string;\n31: }\n32: \n33: interface AtomicIndexRestoreResult {\n34:   restored: boolean;\n35:   error?: string;\n36: }\n37: \n38: export interface AtomicIndexReady<TPrepared = unknown> {\n39:   status: 'ready';\n40:   prepared: TPrepared;\n41:   specFolder: string;\n42:   persistedContent?: string;\n43:   persistedFilePath?: string;\n44: }\n45: \n46: export interface AtomicIndexTerminal {\n47:   status: 'abort' | 'rejected';\n48:   result: AtomicSaveResult;\n49: }\n50: \n51: export type AtomicIndexPreparation<TPrepared = unknown> =\n52:   | AtomicIndexReady<TPrepared>\n53:   | AtomicIndexTerminal;\n54: \n55: export interface AtomicIndexAttemptContext {\n56:   attempt: number;\n57:   force: boolean;\n58: }\n59: \n60: export interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n61:   params: AtomicSaveParams;\n62:   ready: AtomicIndexReady<TPrepared>;\n63:   specFolderLockAlreadyHeld: true;\n64: }\n65: \n66: export interface AtomicIndexDependencies<TPrepared = unknown> {\n67:   prepare: (\n68:     params: AtomicSaveParams,\n69:     context: AtomicIndexAttemptContext,\n70:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n71:   prepareLocked?: (\n72:     context: AtomicIndexLockedContext<TPrepared>,\n73:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n74:   indexPrepared: (\n75:     context: AtomicIndexLockedContext<TPrepared>,\n76:   ) => Promise<IndexResult> | IndexResult;\n77:   mapSuccessResult?: (\n78:     indexResult: IndexResult,\n79:     context: AtomicIndexLockedContext<TPrepared>,\n80:   ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n81:   maxIndexAttempts?: number;\n82:   getPendingPath?: (filePath: string) => string;\n83:   withSpecFolderLock?: typeof withSpecFolderLock;\n84:   captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n85:   restoreOriginalState?: (\n86:     filePath: string,\n87:     originalState: AtomicIndexOriginalState,\n88:   ) => AtomicIndexRestoreResult;\n89:   cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n90:   writePendingFile?: (pendingPath: string, content: string) => void;\n91:   promotePendingFile?: (pendingPath: string, filePath: string) => void;\n92: }\n93: \n94: function toErrorMessage(error: unknown): string {\n95:   return error instanceof Error ? error.message : String(error);\n96: }\n97: \n98: function deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n99:   const existed = fs.existsSync(filePath);\n100:   if (!existed) {\n101:     return { deleted: false, existed: false };\n102:   }\n103: \n104:   try {\n105:     fs.unlinkSync(filePath);\n106:     return { deleted: true, existed: true };\n107:   } catch (error: unknown) {\n108:     return {\n109:       deleted: false,\n110:       existed: true,\n111:       error: toErrorMessage(error),\n112:     };\n113:   }\n114: }\n115: \n116: function captureOriginalState(filePath: string): AtomicIndexOriginalState {\n117:   if (!fs.existsSync(filePath)) {\n118:     return { existed: false, content: null };\n119:   }\n120: \n121:   return {\n122:     existed: true,\n123:     content: fs.readFileSync(filePath, 'utf-8'),\n124:   };\n125: }\n126: \n127: function restoreOriginalState(\n128:   filePath: string,\n129:   originalState: AtomicIndexOriginalState,\n130: ): AtomicIndexRestoreResult {\n131:   try {\n132:     if (!originalState.existed) {\n133:       const deleteResult = deleteFileIfPresent(filePath);\n134:       if (!deleteResult.existed || deleteResult.deleted) {\n135:         return { restored: true };\n136:       }\n137:       return {\n138:         restored: false,\n139:         error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n140:       };\n141:     }\n142: \n143:     if (typeof originalState.content !== 'string') {\n144:       return { restored: false, error: 'Original file content is unavailable for rollback' };\n145:     }\n146: \n147:     fs.mkdirSync(path.dirname(filePath), { recursive: true });\n148:     fs.writeFileSync(filePath, originalState.content, 'utf-8');\n149:     return { restored: true };\n150:   } catch (error: unknown) {\n151:     return {\n152:       restored: false,\n153:       error: toErrorMessage(error),\n154:     };\n155:   }\n156: }\n157: \n158: function cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n159:   const deleteResult = deleteFileIfPresent(pendingPath);\n160:   if (!deleteResult.existed || deleteResult.deleted) {\n161:     return {\n162:       cleaned: true,\n163:       existed: deleteResult.existed,\n164:     };\n165:   }\n166:   return {\n167:     cleaned: false,\n168:     existed: deleteResult.existed,\n169:     error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n170:   };\n171: }\n172: \n173: function writePendingFile(pendingPath: string, content: string): void {\n174:   fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n175:   fs.writeFileSync(pendingPath, content, 'utf-8');\n176: }\n177: \n178: function promotePendingFile(pendingPath: string, filePath: string): void {\n179:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n180:   fs.renameSync(pendingPath, filePath);\n181: }\n182: \n183: function defaultPendingPath(filePath: string): string {\n184:   const basePendingPath = transactionManager.getPendingPath(filePath);\n185:   return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n186: }\n187: \n188: function buildRejectedResult(\n189:   filePath: string,\n190:   indexResult: IndexResult,\n191:   rollbackSucceeded: boolean,\n192:   errorMetadata: Record<string, string> | null,\n193: ): AtomicSaveResult {\n194:   return {\n195:     success: false,\n196:     filePath,\n197:     status: 'rejected',\n198:     id: indexResult.id,\n199:     specFolder: indexResult.specFolder,\n200:     title: indexResult.title,\n201:     summary: rollbackSucceeded\n202:       ? 'Atomic index rejected before file promotion'\n203:       : 'Atomic index rejected but pending file cleanup failed',\n204:     message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n205:     embeddingStatus: indexResult.embeddingStatus,\n206:     hints: [\n207:       rollbackSucceeded\n208:         ? 'Pending file was removed because the save was rejected before promotion'\n209:         : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n210:     ],\n211:     ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n212:     ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n213:   };\n214: }\n215: \n216: function buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n217:   const message = indexResult.message ?? (\n218:     indexResult.status === 'duplicate'\n219:       ? 'Memory skipped (duplicate content)'\n220:       : `Memory ${indexResult.status} successfully`\n221:   );\n222: \n223:   const hints: string[] = [];\n224:   if (indexResult.embeddingStatus === 'pending') {\n225:     hints.push('Memory will be fully indexed when embedding provider becomes available');\n226:   }\n227:   if (indexResult.embeddingStatus === 'partial') {\n228:     hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n229:   }\n230: \n231:   const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n232: \n233:   return {\n234:     success: true,\n235:     filePath,\n236:     status: indexResult.status,\n237:     id: indexResult.id,\n238:     specFolder: indexResult.specFolder,\n239:     title: indexResult.title,\n240:     summary: message,\n241:     message,\n242:     embeddingStatus: indexResult.embeddingStatus,\n243:     ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n244:       ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n245:       : {}),\n246:     ...(hints.length > 0 ? { hints } : {}),\n247:   };\n248: }\n249: \n250: function buildRetryFailureResult(\n251:   filePath: string,\n252:   indexError: Error | null,\n253:   rollbackSucceeded: boolean,\n254:   errorMetadata: Record<string, string> | null,\n255: ): AtomicSaveResult {\n256:   const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n257:   const finalErrorMetadata = errorMetadata ?? {};\n258: \n259:   return {\n260:     success: false,\n261:     filePath,\n262:     status: 'error',\n263:     summary: rollbackSucceeded\n264:       ? 'Atomic index failed after retry and restored original file state'\n265:       : 'Atomic index failed after retry and rollback was incomplete',\n266:     message: indexError?.message ?? 'Indexing failed after retry',\n267:     hints: [\n268:       rollbackSucceeded\n269:         ? 'Original file content was preserved or restored because indexing failed before completion'\n270:         : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n271:       'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n272:     ],\n273:     error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n274:     ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n275:   };\n276: }\n277: \n278: export async function atomicIndexMemory<TPrepared = unknown>(\n279:   params: AtomicSaveParams,\n280:   options: AtomicSaveOptions = {},\n281:   dependencies: AtomicIndexDependencies<TPrepared>,\n282: ): Promise<AtomicSaveResult> {\n283:   const { file_path, content } = params;\n284:   const { force = false } = options;\n285: \n286:   const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n287: \n288:   let indexResult: IndexResult | null = null;\n289:   let indexError: Error | null = null;\n290:   let restoredOriginalAfterFailure = false;\n291:   let anyPromotionAttempted = false;\n292:   let errorMetadata: Record<string, string> | null = null;\n293:   let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n294:   let lastEffectiveFilePath = file_path;\n295:   let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n296: \n297:   const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n298:     if (!entry) {\n299:       return;\n300:     }\n301:     errorMetadata = {\n302:       ...(errorMetadata ?? {}),\n303:       ...entry,\n304:     };\n305:   };\n306: \n307:   for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n308:     let promotedToFinalPath = false;\n309:     let handledFailureWhileLocked = false;\n310:     let rollbackSucceededAfterRejectedSave = false;\n311:     let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n312: \n313:     try {\n314:       const prepared = await dependencies.prepare(params, { attempt, force });\n315:       if (prepared.status !== 'ready') {\n316:         return prepared.result;\n317:       }\n318: \n319:       const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n320:       const lockedResult = await runWithLock(prepared.specFolder, async () => {\n321:         let effectiveFilePath = lastEffectiveFilePath;\n322:         let pendingPath = lastPendingPath;\n323:         let originalState: AtomicIndexOriginalState | null = null;\n324:         try {\n325:           let ready = prepared;\n326:           lockedContext = {\n327:             attempt,\n328:             force,\n329:             params,\n330:             ready,\n331:             specFolderLockAlreadyHeld: true,\n332:           };\n333: \n334:           if (dependencies.prepareLocked) {\n335:             const preparedLocked = await dependencies.prepareLocked(lockedContext);\n336:             if (preparedLocked.status !== 'ready') {\n337:               return {\n338:                 kind: 'terminal',\n339:                 result: preparedLocked.result,\n340:               } as const;\n341:             }\n342: \n343:             ready = preparedLocked;\n344:             lockedContext = {\n345:               attempt,\n346:               force,\n347:               params,\n348:               ready,\n349:               specFolderLockAlreadyHeld: true,\n350:             };\n351:           }\n352: \n353:           effectiveFilePath = ready.persistedFilePath ?? file_path;\n354:           const persistedContent = ready.persistedContent ?? content;\n355:           pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n356:           originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n357:           lastEffectiveFilePath = effectiveFilePath;\n358:           lastPendingPath = pendingPath;\n359: \n360:           (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n361: \n362:           const lockedIndexResult = await dependencies.indexPrepared(lockedContext);\n363: \n364:           if (lockedIndexResult.status === 'rejected') {\n365:             handledFailureWhileLocked = true;\n366:             const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n367:             rollbackSucceededAfterRejectedSave = pendingCleanupResult.cleaned;\n368:             if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n369:               mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n370:             }\n371:             return {\n372:               kind: 'indexed',\n373:               indexResult: lockedIndexResult,\n374:               context: lockedContext,\n375:             } as const;\n376:           }\n377: \n378:           (dependencies.promotePendingFile ?? promotePendingFile)(pendingPath, effectiveFilePath);\n379:           promotedToFinalPath = true;\n380:           anyPromotionAttempted = true;\n381: \n382:           return {\n383:             kind: 'indexed',\n384:             indexResult: lockedIndexResult,\n385:             context: lockedContext,\n386:           } as const;\n387:         } catch (lockedError: unknown) {\n388:           handledFailureWhileLocked = true;\n389:           const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n390:           if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n391:             mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n392:           }\n393: \n394:           if (promotedToFinalPath) {\n395:             const rollbackResult = (dependencies.restoreOriginalState ?? restoreOriginalState)(\n396:               effectiveFilePath,\n397:               originalState ?? captureOriginalState(effectiveFilePath),\n398:             );\n399:             restoredOriginalAfterFailure = rollbackResult.restored;\n400:             if (!rollbackResult.restored && rollbackResult.error) {\n401:               mergeErrorMetadata({ rollbackError: rollbackResult.error });\n402:             }\n403:             if (!restoredOriginalAfterFailure) {\n404:               const message = toErrorMessage(lockedError);\n405:               throw new Error(`Original file rollback failed after promote-before-index path: ${message}`);\n406:             }\n407:           }\n408: \n409:           throw lockedError;\n410:         }\n411:       });\n412: \n413:       if (lockedResult.kind === 'terminal') {\n414:         return lockedResult.result;\n415:       }\n416: \n417:       indexResult = lockedResult.indexResult;\n418: \n419:       if (indexResult.status === 'error') {\n420:         throw new Error(indexResult.message ?? indexResult.error ?? 'atomicIndexMemory indexPrepared returned status=error');\n421:       }\n422: \n423:       if (indexResult.status === 'rejected') {\n424:         return buildRejectedResult(lastEffectiveFilePath, indexResult, rollbackSucceededAfterRejectedSave, errorMetadata);\n425:       }\n426: \n427:       successfulLockedContext = lockedResult.context;\n428:       indexError = null;\n429:       break;\n430:     } catch (error: unknown) {\n431:       if (!handledFailureWhileLocked) {\n432:         const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(lastPendingPath);\n433:         if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n434:           mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n435:         }\n436:       }\n437:       indexError = error instanceof Error ? error : new Error(toErrorMessage(error));\n438:       if (attempt === maxIndexAttempts) {\n439:         break;\n440:       }\n441:     }\n442:   }\n443: \n444:   if (!indexResult || indexError) {\n445:     return buildRetryFailureResult(\n446:       lastEffectiveFilePath,\n447:       indexError,\n448:       anyPromotionAttempted ? restoredOriginalAfterFailure : true,\n449:       errorMetadata,\n450:     );\n451:   }\n452: \n453:   if (dependencies.mapSuccessResult && successfulLockedContext) {\n454:     return await dependencies.mapSuccessResult(indexResult, successfulLockedContext);\n455:   }\n456: \n457:   return buildSuccessResult(successfulLockedContext?.ready.persistedFilePath ?? file_path, indexResult);\n458: }\n459: \n460: const atomic_index_memory = atomicIndexMemory;\n461: \n462: export { atomic_index_memory };\n\n(End of file - total 462 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\ninterface AtomicIndexOriginalState {\n  existed: boolean;\n  content: string | null;\n}\n\ninterface AtomicIndexPendingCleanupResult {\n  cleaned: boolean;\n  existed: boolean;\n  error?: string;\n}\n\ninterface AtomicIndexRestoreResult {\n  restored: boolean;\n  error?: string;\n}\n\nexport interface AtomicIndexReady<TPrepared = unknown> {\n  status: 'ready';\n  prepared: TPrepared;\n  specFolder: string;\n  persistedContent?: string;\n  persistedFilePath?: string;\n}\n\nexport interface AtomicIndexTerminal {\n  status: 'abort' | 'rejected';\n  result: AtomicSaveResult;\n}\n\nexport type AtomicIndexPreparation<TPrepared = unknown> =\n  | AtomicIndexReady<TPrepared>\n  | AtomicIndexTerminal;\n\nexport interface AtomicIndexAttemptContext {\n  attempt: number;\n  force: boolean;\n}\n\nexport interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n  params: AtomicSaveParams;\n  ready: AtomicIndexReady<TPrepared>;\n  specFolderLockAlreadyHeld: true;\n}\n\nexport interface AtomicIndexDependencies<TPrepared = unknown> {\n  prepare: (\n    params: AtomicSaveParams,\n    context: AtomicIndexAttemptContext,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  prepareLocked?: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  indexPrepared: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<IndexResult> | IndexResult;\n  mapSuccessResult?: (\n    indexResult: IndexResult,\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n  maxIndexAttempts?: number;\n  getPendingPath?: (filePath: string) => string;\n  withSpecFolderLock?: typeof withSpecFolderLock;\n  captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n  restoreOriginalState?: (\n    filePath: string,\n    originalState: AtomicIndexOriginalState,\n  ) => AtomicIndexRestoreResult;\n  cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n  writePendingFile?: (pendingPath: string, content: string) => void;\n  promotePendingFile?: (pendingPath: string, filePath: string) => void;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n  const existed = fs.existsSync(filePath);\n  if (!existed) {\n    return { deleted: false, existed: false };\n  }\n\n  try {\n    fs.unlinkSync(filePath);\n    return { deleted: true, existed: true };\n  } catch (error: unknown) {\n    return {\n      deleted: false,\n      existed: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction captureOriginalState(filePath: string): AtomicIndexOriginalState {\n  if (!fs.existsSync(filePath)) {\n    return { existed: false, content: null };\n  }\n\n  return {\n    existed: true,\n    content: fs.readFileSync(filePath, 'utf-8'),\n  };\n}\n\nfunction restoreOriginalState(\n  filePath: string,\n  originalState: AtomicIndexOriginalState,\n): AtomicIndexRestoreResult {\n  try {\n    if (!originalState.existed) {\n      const deleteResult = deleteFileIfPresent(filePath);\n      if (!deleteResult.existed || deleteResult.deleted) {\n        return { restored: true };\n      }\n      return {\n        restored: false,\n        error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n      };\n    }\n\n    if (typeof originalState.content !== 'string') {\n      return { restored: false, error: 'Original file content is unavailable for rollback' };\n    }\n\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, originalState.content, 'utf-8');\n    return { restored: true };\n  } catch (error: unknown) {\n    return {\n      restored: false,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n  const deleteResult = deleteFileIfPresent(pendingPath);\n  if (!deleteResult.existed || deleteResult.deleted) {\n    return {\n      cleaned: true,\n      existed: deleteResult.existed,\n    };\n  }\n  return {\n    cleaned: false,\n    existed: deleteResult.existed,\n    error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n  };\n}\n\nfunction writePendingFile(pendingPath: string, content: string): void {\n  fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n  fs.writeFileSync(pendingPath, content, 'utf-8');\n}\n\nfunction promotePendingFile(pendingPath: string, filePath: string): void {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.renameSync(pendingPath, filePath);\n}\n\nfunction defaultPendingPath(filePath: string): string {\n  const basePendingPath = transactionManager.getPendingPath(filePath);\n  return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n}\n\nfunction buildRejectedResult(\n  filePath: string,\n  indexResult: IndexResult,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  return {\n    success: false,\n    filePath,\n    status: 'rejected',\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: rollbackSucceeded\n      ? 'Atomic index rejected before file promotion'\n      : 'Atomic index rejected but pending file cleanup failed',\n    message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n    embeddingStatus: indexResult.embeddingStatus,\n    hints: [\n      rollbackSucceeded\n        ? 'Pending file was removed because the save was rejected before promotion'\n        : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n    ],\n    ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n    ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n  };\n}\n\nfunction buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n  const message = indexResult.message ?? (\n    indexResult.status === 'duplicate'\n      ? 'Memory skipped (duplicate content)'\n      : `Memory ${indexResult.status} successfully`\n  );\n\n  const hints: string[] = [];\n  if (indexResult.embeddingStatus === 'pending') {\n    hints.push('Memory will be fully indexed when embedding provider becomes available');\n  }\n  if (indexResult.embeddingStatus === 'partial') {\n    hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n  }\n\n  const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n\n  return {\n    success: true,\n    filePath,\n    status: indexResult.status,\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: message,\n    message,\n    embeddingStatus: indexResult.embeddingStatus,\n    ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n      ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n      : {}),\n    ...(hints.length > 0 ? { hints } : {}),\n  };\n}\n\nfunction buildRetryFailureResult(\n  filePath: string,\n  indexError: Error | null,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n  const finalErrorMetadata = errorMetadata ?? {};\n\n  return {\n    success: false,\n    filePath,\n    status: 'error',\n    summary: rollbackSucceeded\n      ? 'Atomic index failed after retry and restored original file state'\n      : 'Atomic index failed after retry and rollback was incomplete',\n    message: indexError?.message ?? 'Indexing failed after retry',\n    hints: [\n      rollbackSucceeded\n        ? 'Original file content was preserved or restored because indexing failed before completion'\n        : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n      'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n    ],\n    error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n    ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n  };\n}\n\nexport async function atomicIndexMemory<TPrepared = unknown>(\n  params: AtomicSaveParams,\n  options: AtomicSaveOptions = {},\n  dependencies: AtomicIndexDependencies<TPrepared>,\n): Promise<AtomicSaveResult> {\n  const { file_path, content } = params;\n  const { force = false } = options;\n\n  const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n\n  let indexResult: IndexResult | null = null;\n  let indexError: Error | null = null;\n  let restoredOriginalAfterFailure = false;\n  let anyPromotionAttempted = false;\n  let errorMetadata: Record<string, string> | null = null;\n  let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n  let lastEffectiveFilePath = file_path;\n  let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n\n  const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n    if (!entry) {\n      return;\n    }\n    errorMetadata = {\n      ...(errorMetadata ?? {}),\n      ...entry,\n    };\n  };\n\n  for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n    let promotedToFinalPath = false;\n    let handledFailureWhileLocked = false;\n    let rollbackSucceededAfterRejectedSave = false;\n    let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n\n    try {\n      const prepared = await dependencies.prepare(params, { attempt, force });\n      if (prepared.status !== 'ready') {\n        return prepared.result;\n      }\n\n      const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n      const lockedResult = await runWithLock(prepared.specFolder, async () => {\n        let effectiveFilePath = lastEffectiveFilePath;\n        let pendingPath = lastPendingPath;\n        let originalState: AtomicIndexOriginalState | null = null;\n        try {\n          let ready = prepared;\n          lockedContext = {\n            attempt,\n            force,\n            params,\n            ready,\n            specFolderLockAlreadyHeld: true,\n          };\n\n          if (dependencies.prepareLocked) {\n            const preparedLocked = await dependencies.prepareLocked(lockedContext);\n            if (preparedLocked.status !== 'ready') {\n              return {\n                kind: 'terminal',\n                result: preparedLocked.result,\n              } as const;\n            }\n\n            ready = preparedLocked;\n            lockedContext = {\n              attempt,\n              force,\n              params,\n              ready,\n              specFolderLockAlreadyHeld: true,\n            };\n          }\n\n          effectiveFilePath = ready.persistedFilePath ?? file_path;\n          const persistedContent = ready.persistedContent ?? content;\n          pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n          originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n          lastEffectiveFilePath = effectiveFilePath;\n          lastPendingPath = pendingPath;\n\n          (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n\n          const lockedIndexResult = await dependencies.indexPrepared(lockedContext);\n\n          if (lockedIndexResult.status === 'rejected') {\n            handledFailureWhileLocked = true;\n            const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n            rollbackSucceededAfterRejectedSave = pendingCleanupResult.cleaned;\n            if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n              mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n            }\n            return {\n              kind: 'indexed',\n              indexResult: lockedIndexResult,\n              context: lockedContext,\n            } as const;\n          }\n\n          (dependencies.promotePendingFile ?? promotePendingFile)(pendingPath, effectiveFilePath);\n          promotedToFinalPath = true;\n          anyPromotionAttempted = true;\n\n          return {\n            kind: 'indexed',\n            indexResult: lockedIndexResult,\n            context: lockedContext,\n          } as const;\n        } catch (lockedError: unknown) {\n          handledFailureWhileLocked = true;\n          const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n          if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n            mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n          }\n\n          if (promotedToFinalPath) {\n            const rollbackResult = (dependencies.restoreOriginalState ?? restoreOriginalState)(\n              effectiveFilePath,\n              originalState ?? captureOriginalState(effectiveFilePath),\n            );\n            restoredOriginalAfterFailure = rollbackResult.restored;\n            if (!rollbackResult.restored && rollbackResult.error) {\n              mergeErrorMetadata({ rollbackError: rollbackResult.error });\n            }\n            if (!restoredOriginalAfterFailure) {\n              const message = toErrorMessage(lockedError);\n              throw new Error(`Original file rollback failed after promote-before-index path: ${message}`);\n            }\n          }\n\n          throw lockedError;\n        }\n      });\n\n      if (lockedResult.kind === 'terminal') {\n        return lockedResult.result;\n      }\n\n      indexResult = lockedResult.indexResult;\n\n      if (indexResult.status === 'error') {\n        throw new Error(indexResult.message ?? indexResult.error ?? 'atomicIndexMemory indexPrepared returned status=error');\n      }\n\n      if (indexResult.status === 'rejected') {\n        return buildRejectedResult(lastEffectiveFilePath, indexResult, rollbackSucceededAfterRejectedSave, errorMetadata);\n      }\n\n      successfulLockedContext = lockedResult.context;\n      indexError = null;\n      break;\n    } catch (error: unknown) {\n      if (!handledFailureWhileLocked) {\n        const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(lastPendingPath);\n        if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n          mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n        }\n      }\n      indexError = error instanceof Error ? error : new Error(toErrorMessage(error));\n      if (attempt === maxIndexAttempts) {\n        break;\n      }\n    }\n  }\n\n  if (!indexResult || indexError) {\n    return buildRetryFailureResult(\n      lastEffectiveFilePath,\n      indexError,\n      anyPromotionAttempted ? restoredOriginalAfterFailure : true,\n      errorMetadata,\n    );\n  }\n\n  if (dependencies.mapSuccessResult && successfulLockedContext) {\n    return await dependencies.mapSuccessResult(indexResult, successfulLockedContext);\n  }\n\n  return buildSuccessResult(successfulLockedContext?.ready.persistedFilePath ?? file_path, indexResult);\n}\n\nconst atomic_index_memory = atomicIndexMemory;\n\nexport { atomic_index_memory };","lineStart":1,"lineEnd":462,"totalLines":462,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","time":{"start":1781761986623,"end":1781761986632}},"metadata":{"openai":{"itemId":"fc_0d551e0e52b69abc016a3387c28180819195bb7072bfdbf423"}},"id":"prt_ed94a50340019cjGaoABHxWMJz","sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","messageID":"msg_ed94a0fdf0012AkOM1mWIEPE3y"}}
