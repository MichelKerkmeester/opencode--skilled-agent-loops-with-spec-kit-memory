    21	
    22	function flagEnabled() {
    23	  return process.env[FLAG] === '1';
    24	}
    25	
    26	function servingAuthority(hubId) {
    27	  const manifest = path.join(ACTIVATION_ROOT, hubId, 'manifest.json');
    28	  if (!fs.existsSync(manifest)) return 'legacy';
    29	  try {
    30	    return JSON.parse(fs.readFileSync(manifest, 'utf8')).servingAuthority || 'legacy';
    31	  } catch {
    32	    return 'legacy';
    33	  }
    34	}
    35	
    36	// Returns a normalized compiled decision when this hub is served by the compiled
    37	// contract and the flag is on; otherwise null (use legacy routing). Fails safe:
    38	// any error resolving the compiled route returns null rather than throwing into
    39	// a routing hot path.
    40	function resolveRoute(hubId, taskText) {
    41	  if (!flagEnabled()) return null;
    42	  if (servingAuthority(hubId) !== 'compiled') return null;
    43	  try {
    44	    return compiledRoute(hubId, taskText);
    45	  } catch {
    46	    return null;
    47	  }
    48	}
    49	
    50	module.exports = { resolveRoute, servingAuthority, flagEnabled, FLAG, ACTIVATION_ROOT };
    51	
    52	// CLI front door: the invocable entry a compiled-serving hub's SKILL.md routing
    53	// directive calls. Prints the compiled decision when authoritative, else a
    54	// legacy sentinel so the caller falls back to the prose smart-router.
    55	if (require.main === module) {
    56	  const args = process.argv.slice(2);
    57	  const hub = args[args.indexOf('--hub') + 1];
    58	  const promptIdx = args.indexOf('--prompt');
    59	  const prompt = promptIdx >= 0 ? args[promptIdx + 1] : '';
    60	  if (!hub) {
    61	    process.stderr.write('usage: resolve.cjs --hub <hubId> --prompt <text>\n');
    62	    process.exit(2);
    63	  }
    64	  const route = resolveRoute(hub, prompt);
    65	  process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\n`);
    66	}

