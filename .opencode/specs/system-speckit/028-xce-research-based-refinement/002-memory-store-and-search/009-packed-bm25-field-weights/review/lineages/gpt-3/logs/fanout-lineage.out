{"type":"tool_use","timestamp":1781151931482,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"type":"tool","tool":"read","callID":"call_5g8yOgcoD9SEUwYmP0LMmZ7C","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Lexical Search\n3: // -------------------------------------------------------------------\n4: \n5: import {\n6:   BM25Index,\n7:   buildBm25DocumentFields,\n8:   type BM25DocumentFields,\n9:   type BM25DocumentSource,\n10:   type BM25FieldWeights,\n11:   type BM25SearchResult,\n12:   type BM25Stats,\n13:   type InMemoryBm25Engine,\n14: } from '../../search/bm25-index.js';\n15: \n16: /** Fielded document payload accepted by lexical search indexes. */\n17: export type LexicalDocumentFields = BM25DocumentFields;\n18: \n19: /** Source row shape that can be normalized into lexical document fields. */\n20: export type LexicalDocumentSource = BM25DocumentSource;\n21: \n22: /** Ranked lexical search result. */\n23: export type LexicalSearchResult = BM25SearchResult;\n24: \n25: /** Lexical index statistics. */\n26: export type LexicalSearchStats = BM25Stats;\n27: \n28: /** Query-time options for lexical scoring. */\n29: export interface LexicalSearchOptions {\n30:   readonly limit?: number;\n31:   readonly fieldWeights?: Partial<BM25FieldWeights>;\n32: }\n33: \n34: /**\n35:  * Port for document indexing and ranked lexical retrieval.\n36:  * Implementations may use SQLite FTS, in-memory BM25, or a test double.\n37:  */\n38: export interface LexicalSearch {\n39:   /** Index a plain-text document body. */\n40:   addDocument(id: string, text: string): void;\n41: \n42:   /** Index a fielded document with title, trigger, path, and body signals. */\n43:   addDocumentFields(id: string, fields: LexicalDocumentFields): void;\n44: \n45:   /** Remove a document from the lexical index. */\n46:   removeDocument(id: string): boolean;\n47: \n48:   /** Search indexed documents by query text. */\n49:   search(query: string, options?: LexicalSearchOptions): LexicalSearchResult[];\n50: \n51:   /** Return current index statistics. */\n52:   getStats(): LexicalSearchStats;\n53: \n54:   /** Clear all indexed documents. */\n55:   clear(): void;\n56: }\n57: \n58: /**\n59:  * Packed BM25 lexical-search adapter over the shipped in-memory engine.\n60:  *\n61:  * No production caller adopts this port yet: the hybrid lexical search\n62:  * path calls the BM25 engine directly as a documented coupling\n63:  * exception, because routing it through this port regresses hybrid\n64:  * ranking behavior.\n65:  */\n66: export class PackedBm25LexicalSearch implements LexicalSearch {\n67:   private readonly index: BM25Index;\n68: \n69:   /**\n70:    * When no engine is supplied, BM25Index resolves it from the\n71:    * environment via resolveInMemoryBm25Engine() instead of hardcoding\n72:    * the packed engine, keeping this adapter aligned with engine\n73:    * selection everywhere else.\n74:    */\n75:   constructor(engine?: InMemoryBm25Engine) {\n76:     this.index = new BM25Index(undefined, undefined, engine);\n77:   }\n78: \n79:   addDocument(id: string, text: string): void {\n80:     this.index.addDocument(id, text);\n81:   }\n82: \n83:   addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n84:     this.index.addDocumentFields(id, fields);\n85:   }\n86: \n87:   addDocumentSource(id: string, source: LexicalDocumentSource): void {\n88:     this.addDocumentFields(id, buildBm25DocumentFields(source));\n89:   }\n90: \n91:   removeDocument(id: string): boolean {\n92:     return this.index.removeDocument(id);\n93:   }\n94: \n95:   search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n96:     return this.index.search(query, options.limit, { fieldWeights: options.fieldWeights });\n97:   }\n98: \n99:   getStats(): LexicalSearchStats {\n100:     return this.index.getStats();\n101:   }\n102: \n103:   clear(): void {\n104:     this.index.clear();\n105:   }\n106: \n107:   finalize(): void {\n108:     this.index.finalizePackedPostings();\n109:   }\n110: }\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Lexical Search\n// -------------------------------------------------------------------\n\nimport {\n  BM25Index,\n  buildBm25DocumentFields,\n  type BM25DocumentFields,\n  type BM25DocumentSource,\n  type BM25FieldWeights,\n  type BM25SearchResult,\n  type BM25Stats,\n  type InMemoryBm25Engine,\n} from '../../search/bm25-index.js';\n\n/** Fielded document payload accepted by lexical search indexes. */\nexport type LexicalDocumentFields = BM25DocumentFields;\n\n/** Source row shape that can be normalized into lexical document fields. */\nexport type LexicalDocumentSource = BM25DocumentSource;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Lexical Search\n// -------------------------------------------------------------------\n\nimport {\n  BM25Index,\n  buildBm25DocumentFields,\n  type BM25DocumentFields,\n  type BM25DocumentSource,\n  type BM25FieldWeights,\n  type BM25SearchResult,\n  type BM25Stats,\n  type InMemoryBm25Engine,\n} from '../../search/bm25-index.js';\n\n/** Fielded document payload accepted by lexical search indexes. */\nexport type LexicalDocumentFields = BM25DocumentFields;\n\n/** Source row shape that can be normalized into lexical document fields. */\nexport type LexicalDocumentSource = BM25DocumentSource;\n\n/** Ranked lexical search result. */\nexport type LexicalSearchResult = BM25SearchResult;\n\n/** Lexical index statistics. */\nexport type LexicalSearchStats = BM25Stats;\n\n/** Query-time options for lexical scoring. */\nexport interface LexicalSearchOptions {\n  readonly limit?: number;\n  readonly fieldWeights?: Partial<BM25FieldWeights>;\n}\n\n/**\n * Port for document indexing and ranked lexical retrieval.\n * Implementations may use SQLite FTS, in-memory BM25, or a test double.\n */\nexport interface LexicalSearch {\n  /** Index a plain-text document body. */\n  addDocument(id: string, text: string): void;\n\n  /** Index a fielded document with title, trigger, path, and body signals. */\n  addDocumentFields(id: string, fields: LexicalDocumentFields): void;\n\n  /** Remove a document from the lexical index. */\n  removeDocument(id: string): boolean;\n\n  /** Search indexed documents by query text. */\n  search(query: string, options?: LexicalSearchOptions): LexicalSearchResult[];\n\n  /** Return current index statistics. */\n  getStats(): LexicalSearchStats;\n\n  /** Clear all indexed documents. */\n  clear(): void;\n}\n\n/**\n * Packed BM25 lexical-search adapter over the shipped in-memory engine.\n *\n * No production caller adopts this port yet: the hybrid lexical search\n * path calls the BM25 engine directly as a documented coupling\n * exception, because routing it through this port regresses hybrid\n * ranking behavior.\n */\nexport class PackedBm25LexicalSearch implements LexicalSearch {\n  private readonly index: BM25Index;\n\n  /**\n   * When no engine is supplied, BM25Index resolves it from the\n   * environment via resolveInMemoryBm25Engine() instead of hardcoding\n   * the packed engine, keeping this adapter aligned with engine\n   * selection everywhere else.\n   */\n  constructor(engine?: InMemoryBm25Engine) {\n    this.index = new BM25Index(undefined, undefined, engine);\n  }\n\n  addDocument(id: string, text: string): void {\n    this.index.addDocument(id, text);\n  }\n\n  addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n    this.index.addDocumentFields(id, fields);\n  }\n\n  addDocumentSource(id: string, source: LexicalDocumentSource): void {\n    this.addDocumentFields(id, buildBm25DocumentFields(source));\n  }\n\n  removeDocument(id: string): boolean {\n    return this.index.removeDocument(id);\n  }\n\n  search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n    return this.index.search(query, options.limit, { fieldWeights: options.fieldWeights });\n  }\n\n  getStats(): LexicalSearchStats {\n    return this.index.getStats();\n  }\n\n  clear(): void {\n    this.index.clear();\n  }\n\n  finalize(): void {\n    this.index.finalizePackedPostings();\n  }\n}","lineStart":1,"lineEnd":110,"totalLines":110,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts","time":{"start":1781151931478,"end":1781151931481}},"metadata":{"openai":{"itemId":"fc_0ca9d8fb692d1595016a2a38bb6bc48191a3cbdc78909665b4"}},"id":"prt_eb4ed9c300017it5xjru1giDVn","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed7a53001psMRwt8gfjAsTu"}}
{"type":"tool_use","timestamp":1781151931512,"sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","part":{"type":"tool","tool":"read","callID":"call_lvpvIl0iFonLAOvSRTJi9W9L","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","offset":130,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts</path>\n<type>file</type>\n<content>\n130:     }\n131:     return {\n132:       lexicalPath: 'unavailable',\n133:       fallbackState: 'missing_table',\n134:     };\n135:   }\n136: \n137:   return {\n138:     lexicalPath: 'fts5',\n139:     fallbackState: 'ok',\n140:   };\n141: }\n142: \n143: // ───────────────────────────────────────────────────────────────\n144: // 3. CORE FUNCTION\n145: \n146: // ───────────────────────────────────────────────────────────────\n147: /**\n148:  * Execute a weighted BM25 FTS5 search against memory_fts.\n149:  *\n150:  * Uses SQLite FTS5's built-in bm25() ranking function with\n151:  * per-column weights instead of the default `rank` pseudo-column.\n152:  * This gives title matches 10x weight, trigger_phrases 5x, etc.\n153:  *\n154:  * @param db - SQLite database connection\n155:  * @param query - Raw search query (will be sanitized)\n156:  * @param options - Search options (limit, specFolder, includeArchived)\n157:  * @returns Array of results with BM25 scores (higher = better)\n158:  * @example\n159:  * ```ts\n160:  * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n161:  * ```\n162:  */\n163: function fts5Bm25Search(\n164:   db: Database.Database,\n165:   query: string,\n166:   options: FtsBm25Options = {}\n167: ): FtsBm25Result[] {\n168:   const { limit = 20, specFolder, includeArchived = false } = options;\n169:   void includeArchived;\n170: \n171:   // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n172:   const sanitized = normalizeLexicalQueryTokens(query).fts;\n173: \n174:   if (!sanitized) {\n175:     setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n176:     return [];\n177:   }\n178: \n179:   const folderFilter = specFolder\n180:     ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? || '/%')\"\n181:     : '';\n182:   const deprecatedTierFilter =\n183:     \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n184: \n185:   const params: (string | number)[] = specFolder\n186:     ? [sanitized, specFolder, specFolder, limit]\n187:     : [sanitized, limit];\n188: \n189:   // Bm25() returns negative scores (lower = better), so we negate\n190:   // To produce positive scores where higher = better match.\n191:   const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n192:   const sql = `\n193:     SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n194:     FROM memory_fts\n195:     JOIN memory_index m ON m.id = memory_fts.rowid\n196:     WHERE memory_fts MATCH ?\n197:       ${folderFilter}\n198:       ${deprecatedTierFilter}\n199:     ORDER BY fts_score DESC\n200:     LIMIT ?\n201:   `;\n202: \n203:   const capability = probeFts5Capability(db);\n204:   setLastLexicalCapabilitySnapshot(capability);\n205:   if (capability.fallbackState !== 'ok') {\n206:     console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n207:     return [];\n208:   }\n209: \n210:   try {\n211:     const rows = (db.prepare(sql) as Database.Statement).all(\n212:       ...params\n213:     ) as Array<Record<string, unknown>>;\n214: \n215:     const normalizedRows = rows.map(row => ({\n216:       ...row,\n217:       id: row.id as number,\n218:       fts_score: (row.fts_score as number) || 0,\n219:     }));\n220:     setLastLexicalCapabilitySnapshot({\n221:       lexicalPath: 'fts5',\n222:       fallbackState: 'ok',\n223:     });\n224:     return normalizedRows;\n225:   } catch (error: unknown) {\n226:     const msg = error instanceof Error ? error.message : String(error);\n227:     const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n228:       ? {\n229:           lexicalPath: 'unavailable',\n230:           fallbackState: 'no_such_module_fts5',\n231:         }\n232:       : isBm25RuntimeFailure(error)\n233:         ? {\n234:             lexicalPath: 'unavailable',\n235:             fallbackState: 'bm25_runtime_failure',\n236:           }\n237:         : msg.toLowerCase().includes('no such table: memory_fts')\n238:           ? {\n239:               lexicalPath: 'unavailable',\n240:               fallbackState: 'missing_table',\n241:             }\n242:           : {\n243:               lexicalPath: 'unavailable',\n244:               fallbackState: 'bm25_runtime_failure',\n245:             };\n246:     setLastLexicalCapabilitySnapshot(failureSnapshot);\n247:     console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n248:     return [];\n249:   }\n\n(Showing lines 130-249 of 294. Use offset=250 to continue.)\n</content>","metadata":{"preview":"    }\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'missing_table',\n    };\n  }\n\n  return {\n    lexicalPath: 'fts5',\n    fallbackState: 'ok',\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. CORE FUNCTION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Execute a weighted BM25 FTS5 search against memory_fts.\n *","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","text":"    }\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'missing_table',\n    };\n  }\n\n  return {\n    lexicalPath: 'fts5',\n    fallbackState: 'ok',\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. CORE FUNCTION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Execute a weighted BM25 FTS5 search against memory_fts.\n *\n * Uses SQLite FTS5's built-in bm25() ranking function with\n * per-column weights instead of the default `rank` pseudo-column.\n * This gives title matches 10x weight, trigger_phrases 5x, etc.\n *\n * @param db - SQLite database connection\n * @param query - Raw search query (will be sanitized)\n * @param options - Search options (limit, specFolder, includeArchived)\n * @returns Array of results with BM25 scores (higher = better)\n * @example\n * ```ts\n * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n * ```\n */\nfunction fts5Bm25Search(\n  db: Database.Database,\n  query: string,\n  options: FtsBm25Options = {}\n): FtsBm25Result[] {\n  const { limit = 20, specFolder, includeArchived = false } = options;\n  void includeArchived;\n\n  // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n  const sanitized = normalizeLexicalQueryTokens(query).fts;\n\n  if (!sanitized) {\n    setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n    return [];\n  }\n\n  const folderFilter = specFolder\n    ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? || '/%')\"\n    : '';\n  const deprecatedTierFilter =\n    \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n\n  const params: (string | number)[] = specFolder\n    ? [sanitized, specFolder, specFolder, limit]\n    : [sanitized, limit];\n\n  // Bm25() returns negative scores (lower = better), so we negate\n  // To produce positive scores where higher = better match.\n  const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n  const sql = `\n    SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n    FROM memory_fts\n    JOIN memory_index m ON m.id = memory_fts.rowid\n    WHERE memory_fts MATCH ?\n      ${folderFilter}\n      ${deprecatedTierFilter}\n    ORDER BY fts_score DESC\n    LIMIT ?\n  `;\n\n  const capability = probeFts5Capability(db);\n  setLastLexicalCapabilitySnapshot(capability);\n  if (capability.fallbackState !== 'ok') {\n    console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n    return [];\n  }\n\n  try {\n    const rows = (db.prepare(sql) as Database.Statement).all(\n      ...params\n    ) as Array<Record<string, unknown>>;\n\n    const normalizedRows = rows.map(row => ({\n      ...row,\n      id: row.id as number,\n      fts_score: (row.fts_score as number) || 0,\n    }));\n    setLastLexicalCapabilitySnapshot({\n      lexicalPath: 'fts5',\n      fallbackState: 'ok',\n    });\n    return normalizedRows;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n      ? {\n          lexicalPath: 'unavailable',\n          fallbackState: 'no_such_module_fts5',\n        }\n      : isBm25RuntimeFailure(error)\n        ? {\n            lexicalPath: 'unavailable',\n            fallbackState: 'bm25_runtime_failure',\n          }\n        : msg.toLowerCase().includes('no such table: memory_fts')\n          ? {\n              lexicalPath: 'unavailable',\n              fallbackState: 'missing_table',\n            }\n          : {\n              lexicalPath: 'unavailable',\n              fallbackState: 'bm25_runtime_failure',\n            };\n    setLastLexicalCapabilitySnapshot(failureSnapshot);\n    console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n    return [];\n  }","lineStart":130,"lineEnd":249,"totalLines":294,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","time":{"start":1781151931507,"end":1781151931511}},"metadata":{"openai":{"itemId":"fc_0ca9d8fb692d1595016a2a38bb6bdc8191af5494c45955dee3"}},"id":"prt_eb4ed9c57001ZIfoaSdH8O4AB6","sessionID":"ses_14b140818ffeCXPWPVn2SL18QY","messageID":"msg_eb4ed7a53001psMRwt8gfjAsTu"}}
