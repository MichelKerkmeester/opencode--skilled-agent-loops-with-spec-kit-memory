   160	function uncertaintyFor(contributions: readonly LaneContribution[], confidence: number, ambiguousPressure: number): number {
   161	  const U = SCORING_CALIBRATION.uncertainty;
   162	  const evidenceCount = contributions.reduce((total, contribution) => total + contribution.evidence.length, 0);
   163	  const direct = contributions
   164	    .filter((contribution) => contribution.lane === 'explicit_author' || contribution.lane === 'lexical')
   165	    .reduce((max, contribution) => Math.max(max, contribution.rawScore), 0);
   166	  let uncertainty = U.noEvidenceDefault;
   167	  if (evidenceCount >= U.highEvidenceCount) uncertainty = U.lowFloor;
   168	  else if (evidenceCount >= U.mediumEvidenceCount) uncertainty = U.mediumFloor;
   169	  else if (evidenceCount >= U.someEvidenceCount) uncertainty = U.elevatedFloor;
   170	  if (direct >= U.directEvidenceDiscountThreshold) uncertainty -= U.directEvidenceDiscount;
   171	  if (confidence < U.lowConfidencePenaltyThreshold) uncertainty += U.lowConfidencePenalty;
   172	  uncertainty += ambiguousPressure;
   173	  return Number(Math.max(U.hardFloor, Math.min(U.hardCeiling, uncertainty)).toFixed(2));
   174	}
