up_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n940:     fs.renameSync(legacySkillDir, backup);\n941:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n942:     actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n943:     refreshPaths();\n944:     return;\n945:   }\n946: \n947:   // Compatibility symlink `.opencode/skill -> skills` removed: 096 packet cleaned\n948:   // up consumers of the singular path, so the bridge no longer needs to be\n949:   // recreated on every MCP startup. Migration paths above (rename / move-aside)\n950:   // still create the symlink when an actual legacy singular dir is present.\n951: }\n952: \n953: function requiredArtifacts() {\n954:   return [\n955:     path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n956:     path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n957:     path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n958:   ];\n959: }\n960: \n961: function artifactsReady() {\n962:   return requiredArtifacts().every(exists);\n963: }\n964: \n965: function buildIfNeeded(actions) {\n966:   if (artifactsReady()) {\n967:     return;\n968:   }\n969: \n970:   if (!exists(kitDir)) {\n971:     throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n972:   }\n973: \n974:   actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n975:   const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n976:   run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n977:   run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n978:   run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n979: \n980:   const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n981:   if (missing.length > 0) {\n982:     throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n983:   }\n984: }\n985: \n986: function getContextServerNodeArgs() {\n987:   const nodeArgs = [];\n988:   const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n989:   if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n990:     return nodeArgs;\n991:   }\n992: \n993:   const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n994:   if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n995:     log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n996:     return nodeArgs;\n997:   }\n998: \n999:   nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n1000:   log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n1001:   return nodeArgs;\n1002: }\n1003: \n1004: function waitForChildExit(child, timeoutMs) {\n1005:   if (!isChildRunning(child)) return Promise.resolve(true);\n1006:   return new Promise((resolve) => {\n1007:     let settled = false;\n1008:     const finish = (exited) => {\n1009:       if (settled) return;\n1010:       settled = true;\n1011:       clearTimeout(timer);\n1012:       child.off('exit', onExit);\n1013:       resolve(exited);\n1014:     };\n1015:     const onExit = () => finish(true);\n1016:     const timer = setTimeout(() => finish(false), timeoutMs);\n1017:     timer.unref?.();\n1018:     child.once('exit', onExit);\n1019:   });\n1020: }\n1021: \n1022: // Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n1023: // the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n1024: // snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\n1025: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n1026:   return mss.refreshDescendantSnapshot(childPid, runner, {\n1027:     snapshotPids: lastKnownDescendantPids,\n1028:     snapshot: {\n1029:       set: (pids) => {\n1030:         lastKnownDescendantPids = pids;\n1031:       },\n1032:     },\n1033:   });\n1034: }\n1035: \n1036: // Reap an orphaned sidecar on crash-loop give-up. The dominant RC-1 RSS lives in a\n1037: // forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n1038: // anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n1039: // still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n1040: // (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n1041: // bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\n1042: function reapProcessTreeGroups(childPid, options = {}) {\n1043:   return mss.reapProcessTreeGroups(childPid, {\n1044:     ...options,\n1045:     snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n1046:     signal: options.signal || signalProcess,\n1047:   });\n1048: }\n1049: \n1050: // Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n1051: // reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n1052: // closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\n1053: async function recycleDaemonInPlace(graceMs, deps = {}) {\n1054:   const ctx = {\n1055:     getContextChild: deps.getContextChild ?? (() => childProcess),\n1056:     hfControl: deps.hfControl ?? hfControl,\n1057:     isChildRunning: deps.isChildRunning ?? isChildRunning,\n1058:     waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n1059:     clearLease: deps.clearLease ?? clearLeaseFile,\n1060:     clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n1061:     isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n1062:     setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n1063:     log: deps.log ?? log,\n1064:   };\n1065:   if (ctx.isRecycleInProgress()) return;\n1066:   ctx.setRecycleInProgress(true);\n1067:   ctx.clearWatchdog();\n1068:   ctx.hfControl.clearTimers();\n1069:   await ctx.hfControl.stopDemandListener();\n1070:   const modelServerChild = ctx.hfControl.getChild();\n1071:   if (ctx.isChildRunning(modelServerChild)) {\n1072:     ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n1073:     modelServerChild.kill('SIGTERM');\n1074:     ctx.hfControl.reapProcessTree(modelServerChild.pid);\n1075:     const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n1076:     if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n1077:       ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1078:       modelServerChild.kill('SIGKILL');\n1079:       await ctx.waitForChildExit(modelServerChild, 1000);\n1080:     }\n1081:   }\n1082:   const contextChild = ctx.getContextChild();\n1083:   if (!ctx.isChildRunning(contextChild)) {\n1084:     ctx.clearLease();\n1085:     ctx.setRecycleInProgress(false);\n1086:     return;\n1087:   }\n1088: \n1089:   ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n1090:   contextChild.kill('SIGTERM');\n1091:   const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n1092:   if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n1093:     ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1094:     contextChild.kill('SIGKILL');\n1095:     await ctx.waitForChildExit(contextChild, 1000);\n1096:   }\n1097:   // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n1098:   // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n1099:   // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until\n\n(Showing lines 900-1099 of 1470. Use offset=1100 to continue.)\n</content>","metadata":{"preview":"    process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n    actions.push(\n      `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n    );\n  }\n}\n\nfunction run(command, args, options = {}) {\n  const result = spawnSync(command, args, {\n    cwd: options.cwd || root,\n    env: process.env,\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n\n  if (result.stdout) {\n    process.stderr.write(result.stdout);\n  }\n  if (result.stderr) {\n    process.stderr.write(result.stderr);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"    process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n    actions.push(\n      `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n    );\n  }\n}\n\nfunction run(command, args, options = {}) {\n  const result = spawnSync(command, args, {\n    cwd: options.cwd || root,\n    env: process.env,\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n\n  if (result.stdout) {\n    process.stderr.write(result.stdout);\n  }\n  if (result.stderr) {\n    process.stderr.write(result.stderr);\n  }\n  if (result.error) {\n    throw result.error;\n  }\n  if (result.status !== 0) {\n    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n  }\n}\n\nfunction ensureLayout(actions) {\n  if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    fs.renameSync(legacySkillDir, skillsDir);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n    refreshPaths();\n    return;\n  }\n\n  if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n    fs.renameSync(legacySkillDir, backup);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n    refreshPaths();\n    return;\n  }\n\n  // Compatibility symlink `.opencode/skill -> skills` removed: 096 packet cleaned\n  // up consumers of the singular path, so the bridge no longer needs to be\n  // recreated on every MCP startup. Migration paths above (rename / move-aside)\n  // still create the symlink when an actual legacy singular dir is present.\n}\n\nfunction requiredArtifacts() {\n  return [\n    path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n    path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n    path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n  ];\n}\n\nfunction artifactsReady() {\n  return requiredArtifacts().every(exists);\n}\n\nfunction buildIfNeeded(actions) {\n  if (artifactsReady()) {\n    return;\n  }\n\n  if (!exists(kitDir)) {\n    throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n  }\n\n  actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n  const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n  run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n\n  const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n  if (missing.length > 0) {\n    throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n  }\n}\n\nfunction getContextServerNodeArgs() {\n  const nodeArgs = [];\n  const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n  if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n    return nodeArgs;\n  }\n\n  const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n  if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n    log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n    return nodeArgs;\n  }\n\n  nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n  log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n  return nodeArgs;\n}\n\nfunction waitForChildExit(child, timeoutMs) {\n  if (!isChildRunning(child)) return Promise.resolve(true);\n  return new Promise((resolve) => {\n    let settled = false;\n    const finish = (exited) => {\n      if (settled) return;\n      settled = true;\n      clearTimeout(timer);\n      child.off('exit', onExit);\n      resolve(exited);\n    };\n    const onExit = () => finish(true);\n    const timer = setTimeout(() => finish(false), timeoutMs);\n    timer.unref?.();\n    child.once('exit', onExit);\n  });\n}\n\n// Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n// the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n// snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n  return mss.refreshDescendantSnapshot(childPid, runner, {\n    snapshotPids: lastKnownDescendantPids,\n    snapshot: {\n      set: (pids) => {\n        lastKnownDescendantPids = pids;\n      },\n    },\n  });\n}\n\n// Reap an orphaned sidecar on crash-loop give-up. The dominant RC-1 RSS lives in a\n// forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n// anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n// still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n// (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n// bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  return mss.reapProcessTreeGroups(childPid, {\n    ...options,\n    snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n    signal: options.signal || signalProcess,\n  });\n}\n\n// Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n// reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n// closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\nasync function recycleDaemonInPlace(graceMs, deps = {}) {\n  const ctx = {\n    getContextChild: deps.getContextChild ?? (() => childProcess),\n    hfControl: deps.hfControl ?? hfControl,\n    isChildRunning: deps.isChildRunning ?? isChildRunning,\n    waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n    clearLease: deps.clearLease ?? clearLeaseFile,\n    clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n    isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n    setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n    log: deps.log ?? log,\n  };\n  if (ctx.isRecycleInProgress()) return;\n  ctx.setRecycleInProgress(true);\n  ctx.clearWatchdog();\n  ctx.hfControl.clearTimers();\n  await ctx.hfControl.stopDemandListener();\n  const modelServerChild = ctx.hfControl.getChild();\n  if (ctx.isChildRunning(modelServerChild)) {\n    ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n    modelServerChild.kill('SIGTERM');\n    ctx.hfControl.reapProcessTree(modelServerChild.pid);\n    const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n    if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n      ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n      modelServerChild.kill('SIGKILL');\n      await ctx.waitForChildExit(modelServerChild, 1000);\n    }\n  }\n  const contextChild = ctx.getContextChild();\n  if (!ctx.isChildRunning(contextChild)) {\n    ctx.clearLease();\n    ctx.setRecycleInProgress(false);\n    return;\n  }\n\n  ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n  contextChild.kill('SIGTERM');\n  const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n  if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n    ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n    contextChild.kill('SIGKILL');\n    await ctx.waitForChildExit(contextChild, 1000);\n  }\n  // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n  // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n  // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until","lineStart":900,"lineEnd":1099,"totalLines":1470,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780741927