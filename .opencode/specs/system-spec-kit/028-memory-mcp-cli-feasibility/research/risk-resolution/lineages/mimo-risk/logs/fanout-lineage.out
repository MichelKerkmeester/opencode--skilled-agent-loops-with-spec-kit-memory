oBe('tcp://127.0.0.1:31337');\n\n  Line 179:     expect(mss.resolveModelServerSocketPath({ SPECKIT_IPC_SOCKET_DIR: 'tcp://127.0.0.1:41414' }, { dbDir: systemSpecKitDbDir })).toBe('tcp://127.0.0.1:41414');\n\n  Line 180:     expect(mss.resolveModelServerSocketPath({ SPECKIT_IPC_SOCKET_DIR: '/tmp/shared-hf' }, { dbDir: systemSpecKitDbDir })).toBe('/tmp/shared-hf/hf-embed.sock');\n\n  Line 620:     process.env.SPECKIT_IPC_SOCKET_DIR = socketDir;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/ipc-socket-resolve.vitest.ts:\n  Line 15: const ORIGINAL = process.env.SPECKIT_IPC_SOCKET_DIR;\n\n  Line 18:   delete process.env.SPECKIT_IPC_SOCKET_DIR;\n\n  Line 23:     delete process.env.SPECKIT_IPC_SOCKET_DIR;\n\n  Line 25:     process.env.SPECKIT_IPC_SOCKET_DIR = ORIGINAL;\n\n  Line 33:     process.env.SPECKIT_IPC_SOCKET_DIR = missingDir;\n\n  Line 45:     process.env.SPECKIT_IPC_SOCKET_DIR = '/var/mk-code-index-out-of-root-xyz';\n","metadata":{"matches":69,"truncated":false},"title":"sun_path|104.*char|macos.*socket|socket.*limit|SPECKIT_IPC_SOCKET_DIR","time":{"start":1780742104555,"end":1780742104650}},"id":"prt_e9c8025e90012iXvDmn1ohwKQ6","sessionID":"ses_16384c52effeHJzY2mg4EmA5Ud","messageID":"msg_e9c801804001z2Q7cfNMc03l97"}}
