lePath && filePath.includes(folderBoost.folder)) {\n661:       if (typeof raw.similarity === 'number') {\n662:         raw.similarity = Math.min(raw.similarity * folderBoost.factor, 1.0);\n663:         boostedCount++;\n664:       }\n665:     }\n666:   }\n667: \n668:   if (boostedCount === 0) {\n669:     return false;\n670:   }\n671: \n672:   results.sort((a, b) => {\n673:     const sa = ((a as Record<string, unknown>).similarity as number | undefined) ?? 0;\n674:     const sb = ((b as Record<string, unknown>).similarity as number | undefined) ?? 0;\n675:     return sb - sa;\n676:   });\n677:   return true;\n678: }\n679: \n680: function isPlainRecord(value: unknown): value is Record<string, unknown> {\n681:   return typeof value === 'object' && value !== null && !Array.isArray(value);\n682: }\n683: \n684: function documentKey(document: unknown): string | null {\n685:   if (!isPlainRecord(document) || typeof document.path !== 'string') {\n686:     return null;\n687:   }\n688:   const anchor = typeof document.anchor === 'string' ? document.anchor : '';\n689:   return `${document.path}\\u0000${anchor}`;\n690: }\n691: \n692: function resultDocumentKey(result: Record<string, unknown>): string | null {\n693:   const whyRanked = isPlainRecord(result.why_ranked) ? result.why_ranked : null;\n694:   const fromWhyRanked = whyRanked ? documentKey(whyRanked.document) : null;\n695:   if (fromWhyRanked !== null) {\n696:     return fromWhyRanked;\n697:   }\n698: \n699:   const filePath = result.filePath ?? result.file_path;\n700:   return typeof filePath === 'string' ? `${filePath}\\u0000` : null;\n701: }\n702: \n703: function warningStillApplies(warning: unknown, returnedDocumentKeys: Set<string>): boolean {\n704:   if (!isPlainRecord(warning) || !Array.isArray(warning.documents)) {\n705:     return true;\n706:   }\n707:   const keys = warning.documents.map(documentKey);\n708:   if (keys.length !== 2 || keys.some((key) => key === null)) {\n709:     return true;\n\n(Showing lines 630-709 of 1788. Use offset=710 to continue.)\n</content>","metadata":{"preview":"// Sections 3–5 (STATE_PRIORITY, MAX_DEEP_QUERY_VARIANTS, buildDeepQueryVariants,\n// StrengthenOnAccess, applyTestingEffect, filterByMemoryState) removed in\n// These were only used by the legacy V1 pipeline.\n// The V2 4-stage pipeline handles state filtering (Stage 4), testing effect, and\n// Query expansion through its own stages.\n\n/* ───────────────────────────────────────────────────────────────\n   6. SESSION DEDUPLICATION UTILITIES\n──────────────────────────────────────────────────────────────── */\n\nfunction stampFinalRankScores(results: Array<Record<string, unknown>>): void {\n  const total = results.length;\n  results.forEach((result, index) => {\n    result.finalRankScore = calculateFinalRankScore(total, index);\n  });\n}\n\nfunction calculateFinalRankScore(total: number, index: number): number | null {\n  return total > 0 ? (total - index) / total : null;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"// Sections 3–5 (STATE_PRIORITY, MAX_DEEP_QUERY_VARIANTS, buildDeepQueryVariants,\n// StrengthenOnAccess, applyTestingEffect, filterByMemoryState) removed in\n// These were only used by the legacy V1 pipeline.\n// The V2 4-stage pipeline handles state filtering (Stage 4), testing effect, and\n// Query expansion through its own stages.\n\n/* ───────────────────────────────────────────────────────────────\n   6. SESSION DEDUPLICATION UTILITIES\n──────────────────────────────────────────────────────────────── */\n\nfunction stampFinalRankScores(results: Array<Record<string, unknown>>): void {\n  const total = results.length;\n  results.forEach((result, index) => {\n    result.finalRankScore = calculateFinalRankScore(total, index);\n  });\n}\n\nfunction calculateFinalRankScore(total: number, index: number): number | null {\n  return total > 0 ? (total - index) / total : null;\n}\n\nfunction applyFolderBoostRanking(results: SessionAwareResult[], folderBoost: FolderBoost | undefined): boolean {\n  if (!folderBoost || !folderBoost.folder || folderBoost.factor <= 1) {\n    return false;\n  }\n\n  let boostedCount = 0;\n  for (const r of results) {\n    const raw = r as Record<string, unknown>;\n    const filePath = raw.file_path as string | undefined;\n    if (filePath && filePath.includes(folderBoost.folder)) {\n      if (typeof raw.similarity === 'number') {\n        raw.similarity = Math.min(raw.similarity * folderBoost.factor, 1.0);\n        boostedCount++;\n      }\n    }\n  }\n\n  if (boostedCount === 0) {\n    return false;\n  }\n\n  results.sort((a, b) => {\n    const sa = ((a as Record<string, unknown>).similarity as number | undefined) ?? 0;\n    const sb = ((b as Record<string, unknown>).similarity as number | undefined) ?? 0;\n    return sb - sa;\n  });\n  return true;\n}\n\nfunction isPlainRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === 'object' && value !== null && !Array.isArray(value);\n}\n\nfunction documentKey(document: unknown): string | null {\n  if (!isPlainRecord(document) || typeof document.path !== 'string') {\n    return null;\n  }\n  const anchor = typeof document.anchor === 'string' ? document.anchor : '';\n  return `${document.path}\\u0000${anchor}`;\n}\n\nfunction resultDocumentKey(result: Record<string, unknown>): string | null {\n  const whyRanked = isPlainRecord(result.why_ranked) ? result.why_ranked : null;\n  const fromWhyRanked = whyRanked ? documentKey(whyRanked.document) : null;\n  if (fromWhyRanked !== null) {\n    return fromWhyRanked;\n  }\n\n  const filePath = result.filePath ?? result.file_path;\n  return typeof filePath === 'string' ? `${filePath}\\u0000` : null;\n}\n\nfunction warningStillApplies(warning: unknown, returnedDocumentKeys: Set<string>): boolean {\n  if (!isPlainRecord(warning) || !Array.isArray(warning.documents)) {\n    return true;\n  }\n  const keys = warning.documents.map(documentKey);\n  if (keys.length !== 2 || keys.some((key) => key === null)) {\n    return true;","lineStart":630,"lineEnd":709,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781762697999,"end":1781762698006}},"metadata":{"openai":{"itemId":"fc_0ca6a69e419d0321016a338a89c6dc81919aeb1cc5255e7e52"}},"id":"prt_ed9552aff001XGohlDcndiNCfr","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed955035b001aDkee2keYWcIds"}}
