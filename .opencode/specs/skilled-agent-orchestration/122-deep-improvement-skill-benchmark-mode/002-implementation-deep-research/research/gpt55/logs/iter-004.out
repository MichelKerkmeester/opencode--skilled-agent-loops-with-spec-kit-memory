    37	  promoted: 'promoted',
    38	  rolledBack: 'rolledBack',
    39	  advisoryOnly: 'advisoryOnly',
    40	});
    41	
    42	/**
    43	 * Valid event types for the improvement journal.
    44	 * Journal captures lifecycle events and stop decisions (orchestrator only).
    45	 * @type {Readonly<string[]>}
    46	 */
    47	const VALID_EVENT_TYPES = Object.freeze([
    48	  'session_start',
    49	  'session_initialized',
    50	  'integration_scanned',
    51	  'candidate_generated',
    52	  'candidate_scored',
    53	  'benchmark_completed',
    54	  'gate_evaluation',
    55	  'legal_stop_evaluated',
    56	  'blocked_stop',
    57	  'promotion_attempt',
    58	  'promotion_attempted',
    59	  'promotion_result',
    60	  'rollback',
    61	  'rollback_result',
    62	  'trade_off_detected',
    63	  'mutation_proposed',
    64	  'mutation_outcome',
    65	  'session_ended',
    66	  'session_end',
    67	]);
    68	
    69	const LEGAL_STOP_GATES = Object.freeze([
    70	  'contractGate',
    71	  'behaviorGate',
    72	  'integrationGate',
    73	  'evidenceGate',
    74	  'improvementGate',
    75	]);
    76	
    77	// ─────────────────────────────────────────────────────────────────────────────
    78	// 3. HELPERS
    79	// ─────────────────────────────────────────────────────────────────────────────
    80	
    81	/**
    82	 * Validate that an event object has the required fields and a valid event type.
    83	 * @param {object} event - Event to validate
    84	 * @returns {{ valid: boolean, errors: string[] }}
    85	 */
    86	function validateEvent(event) {
    87	  const errors = [];
    88	
    89	  if (!event || typeof event !== 'object') {
    90	    return { valid: false, errors: ['Event must be a non-null object'] };
    91	  }
    92	
    93	  if (!event.eventType || typeof event.eventType !== 'string') {
    94	    errors.push('Event must have a string eventType');
    95	  } else if (!VALID_EVENT_TYPES.includes(event.eventType)) {
    96	    errors.push(`Invalid eventType: "${event.eventType}". Valid types: ${VALID_EVENT_TYPES.join(', ')}`);
    97	  }
    98	
    99	  if (event.eventType === 'session_ended' || event.eventType === 'session_end') {
   100	    if (!event.details || !event.details.stopReason) {
   101	      errors.push('session_ended/session_end events MUST include details.stopReason');
   102	    } else if (!Object.values(STOP_REASONS).includes(event.details.stopReason)) {
   103	      errors.push(`Invalid stopReason: "${event.details.stopReason}". Valid reasons: ${Object.values(STOP_REASONS).join(', ')}`);
   104	    }
   105	    if (!event.details || !event.details.sessionOutcome) {
   106	      errors.push('session_ended/session_end events MUST include details.sessionOutcome');
   107	    } else if (!Object.values(SESSION_OUTCOMES).includes(event.details.sessionOutcome)) {
   108	      errors.push(`Invalid sessionOutcome: "${event.details.sessionOutcome}". Valid outcomes: ${Object.values(SESSION_OUTCOMES).join(', ')}`);
   109	    }
   110	  }
   111	
   112	  if (event.eventType === 'legal_stop_evaluated') {
   113	    const gateResults = event.details && event.details.gateResults;
   114	    if (!gateResults || typeof gateResults !== 'object' || Array.isArray(gateResults)) {
   115	      errors.push('legal_stop_evaluated events MUST include details.gateResults object');
   116	    } else {
   117	      for (const gateName of LEGAL_STOP_GATES) {
   118	        if (!Object.prototype.hasOwnProperty.call(gateResults, gateName)) {
   119	          errors.push(`legal_stop_evaluated details.gateResults missing ${gateName}`);
   120	        }
   121	      }
   122	    }
   123	  }
   124	
   125	  return { valid: errors.length === 0, errors };
   126	}
   127	
   128	// ─────────────────────────────────────────────────────────────────────────────
   129	// 4. CORE API
   130	// ─────────────────────────────────────────────────────────────────────────────
   131	
   132	/**
   133	 * Append an event to the improvement journal (append-only JSONL).
   134	 * Journal emission is orchestrator-only; this function is the single write point.
   135	 *
   136	 * @param {string} journalPath - Path to the improvement-journal.jsonl file
   137	 * @param {object} event - Event object with { eventType, iteration?, candidateId?, details? }
   138	 * @returns {{ success: boolean, errors?: string[] }}
   139	 */
   140	function emitEvent(journalPath, event) {
   141	  const enrichedEvent = {
   142	    timestamp: new Date().toISOString(),
   143	    ...event,
   144	  };
   145	
   146	  const validation = validateEvent(enrichedEvent);
   147	  if (!validation.valid) {
   148	    return { success: false, errors: validation.errors };
   149	  }
   150	
   151	  // Ensure directory exists
   152	  const dir = path.dirname(journalPath);
   153	  fs.mkdirSync(dir, { recursive: true });
   154	
   155	  // Append-only: use 'a' flag (NFR-R01: survives process restart, no in-memory buffering)
   156	  const line = JSON.stringify(enrichedEvent) + '\n';
   157	  fs.appendFileSync(journalPath, line, 'utf8');
   158	
   159	  return { success: true };
   160	}
   161	
   162	/**
   163	 * Read all events from a journal file.
   164	 * Used for resume/replay semantics (REQ-AI-003).
   165	 *
   166	 * @param {string} journalPath - Path to the improvement-journal.jsonl file
   167	 * @returns {object[]} Array of parsed event objects
   168	 */
   169	function readJournal(journalPath) {
   170	  try {
   171	    const content = fs.readFileSync(journalPath, 'utf8');
   172	    return content
   173	      .split('\n')
   174	      .map((line) => line.trim())
   175	      .filter(Boolean)
   176	      .flatMap((line) => {
   177	        try {
   178	          return [JSON.parse(line)];
   179	        } catch (_err) {
   180	          return [];
   181	        }
   182	      });
   183	  } catch (_err) {
   184	    return [];
   185	  }
   186	}
   187	
   188	/**
   189	 * Get the last completed iteration number from a journal.
   190	 * Used for resume semantics — continuedFromIteration field.
   191	 *
   192	 * @param {string} journalPath - Path to the improvement-journal.jsonl file
   193	 * @returns {number} Last completed iteration number, or 0 if none
   194	 */
   195	function getLastIteration(journalPath) {
   196	  const events = readJournal(journalPath);
   197	  let maxIteration = 0;
   198	  for (const event of events) {
   199	    if (typeof event.iteration === 'number' && event.iteration > maxIteration) {
   200	      maxIteration = event.iteration;
   201	    }
   202	  }
   203	  return maxIteration;
   204	}
   205	
   206	/**
   207	 * Get the stop reason from the last session_ended event.
   208	 *
   209	 * @param {string} journalPath - Path to the improvement-journal.jsonl file
   210	 * @returns {{ stopReason: string|null, sessionOutcome: string|null }}
   211	 */
   212	function getSessionResult(journalPath) {
   213	  const events = readJournal(journalPath);
   214	  const endEvents = events.filter(
   215	    (e) => e.eventType === 'session_ended' || e.eventType === 'session_end'
   216	  );
   217	  if (endEvents.length === 0) {
   218	    return { stopReason: null, sessionOutcome: null };
   219	  }
   220	  const last = endEvents[endEvents.length - 1];

