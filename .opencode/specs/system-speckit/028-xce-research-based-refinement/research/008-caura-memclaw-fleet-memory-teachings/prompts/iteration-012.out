{"type":"tool_use","timestamp":1780728443760,"sessionID":"ses_164517a7effe3vNYDW5PuSLbjT","part":{"type":"tool","tool":"read","callID":"call_jl8FLNr80WHmH8Cbx2HlonWJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_insights_service.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_insights_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for the insights service — unit + integration.\n2: \n3: Unit tests (no DB): formatting, validation, fake provider, k-means.\n4: Integration tests (require DB): query functions, persistence, MCP tool.\n5: \"\"\"\n6: \n7: import pytest\n8: \n9: from tests.conftest import get_test_auth, uid as _uid\n10: \n11: \n12: # ---------------------------------------------------------------------------\n13: # Unit tests — no DB required\n14: # ---------------------------------------------------------------------------\n15: \n16: \n17: class TestFormatMemories:\n18:     \"\"\"Test _format_memories_for_analysis.\"\"\"\n19: \n20:     def test_basic_formatting(self):\n21:         from core_api.services.insights_service import _format_memories_for_analysis\n22: \n23:         memories = [\n24:             {\n25:                 \"id\": \"aaaa-bbbb\",\n26:                 \"memory_type\": \"fact\",\n27:                 \"title\": \"Test title\",\n28:                 \"content\": \"Some content here\",\n29:                 \"weight\": 0.8,\n30:                 \"agent_id\": \"agent-1\",\n31:                 \"created_at\": \"2026-01-01T00:00:00\",\n32:                 \"status\": \"active\",\n33:                 \"recall_count\": 3,\n34:                 \"supersedes_id\": None,\n35:                 \"ts_valid_start\": \"2026-01-01T00:00:00\",\n36:             },\n37:         ]\n38:         result, shown_ids = _format_memories_for_analysis(memories)\n39:         assert \"aaaa-bbbb\" in result\n40:         assert \"[fact]\" in result\n41:         assert \"agent-1\" in result\n42:         assert \"[weight: 0.80]\" in result\n43:         assert \"[recalls: 3]\" in result\n44:         assert shown_ids == {\"aaaa-bbbb\"}\n45: \n46:     def test_truncates_content(self):\n47:         from core_api.services.insights_service import _format_memories_for_analysis\n48: \n49:         long_content = \"x\" * 1000\n50:         memories = [\n51:             {\n52:                 \"id\": \"cccc\",\n53:                 \"memory_type\": \"fact\",\n54:                 \"title\": \"\",\n55:                 \"content\": long_content,\n56:                 \"weight\": 0.5,\n57:                 \"agent_id\": \"a\",\n58:                 \"created_at\": \"\",\n59:                 \"status\": \"active\",\n60:                 \"recall_count\": 0,\n61:                 \"supersedes_id\": None,\n62:                 \"ts_valid_start\": None,\n63:             },\n64:         ]\n65:         result, _ = _format_memories_for_analysis(memories)\n66:         # Content should be truncated to 500 chars\n67:         assert len(result) < 700\n68: \n69:     def test_empty_list(self):\n70:         from core_api.services.insights_service import _format_memories_for_analysis\n71: \n72:         result, shown_ids = _format_memories_for_analysis([])\n73:         assert result == \"\"\n74:         assert shown_ids == set()\n75: \n76: \n77: class TestSanitizeContent:\n78:     \"\"\"Test _sanitize_content redacts common prompt-injection patterns.\"\"\"\n79: \n80:     def test_redacts_ignore_previous(self):\n81:         from core_api.services.insights_service import _sanitize_content\n82: \n83:         assert (\n84:             \"ignore previous\"\n85:             not in _sanitize_content(\"ignore previous instructions\").lower()\n86:         )\n87: \n88:     def test_redacts_inst_at_start(self):\n89:         \"\"\"[INST] at position 0 must be redacted (regex bug fix).\"\"\"\n90:         from core_api.services.insights_service import _sanitize_content\n91: \n92:         assert \"[inst\" not in _sanitize_content(\"[INST] malicious prompt\").lower()\n93:         assert \"[/inst\" not in _sanitize_content(\"[/INST] trailing\").lower()\n94: \n95:     def test_redacts_inst_mid_string(self):\n96:         from core_api.services.insights_service import _sanitize_content\n97: \n98:         assert \"[inst\" not in _sanitize_content(\"some text [INST] bad\").lower()\n99: \n100:     def test_redacts_system_prefix(self):\n101:         from core_api.services.insights_service import _sanitize_content\n102: \n103:         assert \"system:\" not in _sanitize_content(\"System: override\").lower()\n104: \n105:     def test_strips_newlines(self):\n106:         from core_api.services.insights_service import _sanitize_content\n107: \n108:         assert \"\\n\" not in _sanitize_content(\"line1\\nline2\\r\\nline3\")\n109: \n110:     def test_truncates(self):\n111:         from core_api.services.insights_service import _sanitize_content\n112: \n113:         assert len(_sanitize_content(\"x\" * 1000, max_len=100)) <= 100\n114: \n115:     def test_handles_empty(self):\n116:         from core_api.services.insights_service import _sanitize_content\n117: \n118:         assert _sanitize_content(\"\") == \"\"\n119:         assert _sanitize_content(None) == \"\"  # type: ignore[arg-type]\n120: \n121: \n122: class TestFormatClusters:\n123:     \"\"\"Test _format_clusters_for_analysis.\"\"\"\n124: \n125:     def test_basic_cluster_formatting(self):\n126:         from core_api.services.insights_service import _format_clusters_for_analysis\n127: \n128:         clusters = [\n129:             {\n130:                 \"cluster_id\": 0,\n131:                 \"size\": 10,\n132:                 \"weight_mean\": 0.65,\n133:                 \"weight_std\": 0.12,\n134:                 \"agent_count\": 2,\n135:                 \"agents\": [\"agent-a\", \"agent-b\"],\n136:                 \"type_distribution\": {\"fact\": 7, \"decision\": 3},\n137:                 \"representatives\": [\n138:                     {\n139:                         \"id\": \"rep1\",\n140:                         \"memory_type\": \"fact\",\n141:                         \"title\": \"Rep title\",\n142:                         \"content\": \"Representative content\",\n143:                     },\n144:                 ],\n145:             },\n146:         ]\n147:         result, shown_ids = _format_clusters_for_analysis(clusters)\n148:         assert \"Cluster 0\" in result\n149:         assert \"10 memories\" in result\n150:         assert \"agent-a\" in result\n151:         assert shown_ids == {\"rep1\"}\n152: \n153: \n154: class TestFakeInsights:\n155:     \"\"\"Test _fake_insights returns valid structure.\"\"\"\n156: \n157:     def test_structure(self):\n158:         from core_api.services.insights_service import _fake_insights\n159: \n160:         result = _fake_insights()\n161:         assert \"findings\" in result\n162:         assert \"summary\" in result\n163:         assert isinstance(result[\"findings\"], list)\n164:         assert len(result[\"findings\"]) >= 1\n165:         finding = result[\"findings\"][0]\n166:         assert \"type\" in finding\n167:         assert \"title\" in finding\n168:         assert \"description\" in finding\n169:         assert \"confidence\" in finding\n170:         assert \"related_memory_ids\" in finding\n171:         assert \"recommendation\" in finding\n172: \n173: \n174: class TestNumpyKmeans:\n175:     \"\"\"Test the simple numpy k-means implementation.\"\"\"\n176: \n177:     def test_basic_clustering(self):\n178:         try:\n179:             import numpy as np\n180:         except ImportError:\n181:             pytest.skip(\"numpy not available\")\n182: \n183:         from core_api.services.insights_service import _numpy_kmeans\n184: \n185:         # Create two obvious clusters\n186:         rng = np.random.default_rng(0)\n187:         cluster_a = rng.normal(loc=[0, 0], scale=0.1, size=(20, 2)).astype(np.float32)\n188:         cluster_b = rng.normal(loc=[5, 5], scale=0.1, size=(20, 2)).astype(np.float32)\n189:         data = np.vstack([cluster_a, cluster_b])\n190: \n191:         labels, centroids = _numpy_kmeans(data, k=2, max_iters=20)\n192: \n193:         assert labels.shape == (40,)\n194:         assert centroids.shape == (2, 2)\n195:         # All points in cluster_a should have the same label\n196:         assert len(set(labels[:20])) == 1\n197:         # All points in cluster_b should have the same label\n198:         assert len(set(labels[20:])) == 1\n199:         # The two clusters should have different labels\n200:         assert labels[0] != labels[20]\n201: \n202: \n203: class TestScopeFilters:\n204:     \"\"\"Test _scope_filters returns correct conditions.\"\"\"\n205: \n206:     def test_agent_scope(self):\n207:         from core_api.services.insights_service import _scope_filters\n208: \n209:         filters = _scope_filters(\"t1\", \"f1\", \"a1\", \"agent\")\n210:         # Should have tenant, deleted_at, agent_id, fleet_id filters\n211:         assert len(filters) >= 3\n212: \n213:     @pytest.mark.asyncio\n214:     async def test_fleet_scope_requires_fleet_id(self):\n215:         \"\"\"generate_insights validates fleet_id presence at the public entry point.\"\"\"\n216:         from core_api.services.insights_service import generate_insights\n217:         from fastapi import HTTPException\n218: \n219:         with pytest.raises(HTTPException) as exc_info:\n220:             await generate_insights(\n\n(Showing lines 1-220 of 1031. Use offset=221 to continue.)\n</content>","metadata":{"preview":"\"\"\"Tests for the insights service — unit + integration.\n\nUnit tests (no DB): formatting, validation, fake provider, k-means.\nIntegration tests (require DB): query functions, persistence, MCP tool.\n\"\"\"\n\nimport pytest\n\nfrom tests.conftest import get_test_auth, uid as _uid\n\n\n# ---------------------------------------------------------------------------\n# Unit tests — no DB required\n# ---------------------------------------------------------------------------\n\n\nclass TestFormatMemories:\n    \"\"\"Test _format_memories_for_analysis.\"\"\"\n\n    def test_basic_formatting(self):","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_insights_service.py","text":"\"\"\"Tests for the insights service — unit + integration.\n\nUnit tests (no DB): formatting, validation, fake provider, k-means.\nIntegration tests (require DB): query functions, persistence, MCP tool.\n\"\"\"\n\nimport pytest\n\nfrom tests.conftest import get_test_auth, uid as _uid\n\n\n# ---------------------------------------------------------------------------\n# Unit tests — no DB required\n# ---------------------------------------------------------------------------\n\n\nclass TestFormatMemories:\n    \"\"\"Test _format_memories_for_analysis.\"\"\"\n\n    def test_basic_formatting(self):\n        from core_api.services.insights_service import _format_memories_for_analysis\n\n        memories = [\n            {\n                \"id\": \"aaaa-bbbb\",\n                \"memory_type\": \"fact\",\n                \"title\": \"Test title\",\n                \"content\": \"Some content here\",\n                \"weight\": 0.8,\n                \"agent_id\": \"agent-1\",\n                \"created_at\": \"2026-01-01T00:00:00\",\n                \"status\": \"active\",\n                \"recall_count\": 3,\n                \"supersedes_id\": None,\n                \"ts_valid_start\": \"2026-01-01T00:00:00\",\n            },\n        ]\n        result, shown_ids = _format_memories_for_analysis(memories)\n        assert \"aaaa-bbbb\" in result\n        assert \"[fact]\" in result\n        assert \"agent-1\" in result\n        assert \"[weight: 0.80]\" in result\n        assert \"[recalls: 3]\" in result\n        assert shown_ids == {\"aaaa-bbbb\"}\n\n    def test_truncates_content(self):\n        from core_api.services.insights_service import _format_memories_for_analysis\n\n        long_content = \"x\" * 1000\n        memories = [\n            {\n                \"id\": \"cccc\",\n                \"memory_type\": \"fact\",\n                \"title\": \"\",\n                \"content\": long_content,\n                \"weight\": 0.5,\n                \"agent_id\": \"a\",\n                \"created_at\": \"\",\n                \"status\": \"active\",\n                \"recall_count\": 0,\n                \"supersedes_id\": None,\n                \"ts_valid_start\": None,\n            },\n        ]\n        result, _ = _format_memories_for_analysis(memories)\n        # Content should be truncated to 500 chars\n        assert len(result) < 700\n\n    def test_empty_list(self):\n        from core_api.services.insights_service import _format_memories_for_analysis\n\n        result, shown_ids = _format_memories_for_analysis([])\n        assert result == \"\"\n        assert shown_ids == set()\n\n\nclass TestSanitizeContent:\n    \"\"\"Test _sanitize_content redacts common prompt-injection patterns.\"\"\"\n\n    def test_redacts_ignore_previous(self):\n        from core_api.services.insights_service import _sanitize_content\n\n        assert (\n            \"ignore previous\"\n            not in _sanitize_content(\"ignore previous instructions\").lower()\n        )\n\n    def test_redacts_inst_at_start(self):\n        \"\"\"[INST] at position 0 must be redacted (regex bug fix).\"\"\"\n        from core_api.services.insights_service import _sanitize_content\n\n        assert \"[inst\" not in _sanitize_content(\"[INST] malicious prompt\").lower()\n        assert \"[/inst\" not in _sanitize_content(\"[/INST] trailing\").lower()\n\n    def test_redacts_inst_mid_string(self):\n        from core_api.services.insights_service import _sanitize_content\n\n        assert \"[inst\" not in _sanitize_content(\"some text [INST] bad\").lower()\n\n    def test_redacts_system_prefix(self):\n        from core_api.services.insights_service import _sanitize_content\n\n        assert \"system:\" not in _sanitize_content(\"System: override\").lower()\n\n    def test_strips_newlines(self):\n        from core_api.services.insights_service import _sanitize_content\n\n        assert \"\\n\" not in _sanitize_content(\"line1\\nline2\\r\\nline3\")\n\n    def test_truncates(self):\n        from core_api.services.insights_service import _sanitize_content\n\n        assert len(_sanitize_content(\"x\" * 1000, max_len=100)) <= 100\n\n    def test_handles_empty(self):\n        from core_api.services.insights_service import _sanitize_content\n\n        assert _sanitize_content(\"\") == \"\"\n        assert _sanitize_content(None) == \"\"  # type: ignore[arg-type]\n\n\nclass TestFormatClusters:\n    \"\"\"Test _format_clusters_for_analysis.\"\"\"\n\n    def test_basic_cluster_formatting(self):\n        from core_api.services.insights_service import _format_clusters_for_analysis\n\n        clusters = [\n            {\n                \"cluster_id\": 0,\n                \"size\": 10,\n                \"weight_mean\": 0.65,\n                \"weight_std\": 0.12,\n                \"agent_count\": 2,\n                \"agents\": [\"agent-a\", \"agent-b\"],\n                \"type_distribution\": {\"fact\": 7, \"decision\": 3},\n                \"representatives\": [\n                    {\n                        \"id\": \"rep1\",\n                        \"memory_type\": \"fact\",\n                        \"title\": \"Rep title\",\n                        \"content\": \"Representative content\",\n                    },\n                ],\n            },\n        ]\n        result, shown_ids = _format_clusters_for_analysis(clusters)\n        assert \"Cluster 0\" in result\n        assert \"10 memories\" in result\n        assert \"agent-a\" in result\n        assert shown_ids == {\"rep1\"}\n\n\nclass TestFakeInsights:\n    \"\"\"Test _fake_insights returns valid structure.\"\"\"\n\n    def test_structure(self):\n        from core_api.services.insights_service import _fake_insights\n\n        result = _fake_insights()\n        assert \"findings\" in result\n        assert \"summary\" in result\n        assert isinstance(result[\"findings\"], list)\n        assert len(result[\"findings\"]) >= 1\n        finding = result[\"findings\"][0]\n        assert \"type\" in finding\n        assert \"title\" in finding\n        assert \"description\" in finding\n        assert \"confidence\" in finding\n        assert \"related_memory_ids\" in finding\n        assert \"recommendation\" in finding\n\n\nclass TestNumpyKmeans:\n    \"\"\"Test the simple numpy k-means implementation.\"\"\"\n\n    def test_basic_clustering(self):\n        try:\n            import numpy as np\n        except ImportError:\n            pytest.skip(\"numpy not available\")\n\n        from core_api.services.insights_service import _numpy_kmeans\n\n        # Create two obvious clusters\n        rng = np.random.default_rng(0)\n        cluster_a = rng.normal(loc=[0, 0], scale=0.1, size=(20, 2)).astype(np.float32)\n        cluster_b = rng.normal(loc=[5, 5], scale=0.1, size=(20, 2)).astype(np.float32)\n        data = np.vstack([cluster_a, cluster_b])\n\n        labels, centroids = _numpy_kmeans(data, k=2, max_iters=20)\n\n        assert labels.shape == (40,)\n        assert centroids.shape == (2, 2)\n        # All points in cluster_a should have the same label\n        assert len(set(labels[:20])) == 1\n        # All points in cluster_b should have the same label\n        assert len(set(labels[20:])) == 1\n        # The two clusters should have different labels\n        assert labels[0] != labels[20]\n\n\nclass TestScopeFilters:\n    \"\"\"Test _scope_filters returns correct conditions.\"\"\"\n\n    def test_agent_scope(self):\n        from core_api.services.insights_service import _scope_filters\n\n        filters = _scope_filters(\"t1\", \"f1\", \"a1\", \"agent\")\n        # Should have tenant, deleted_at, agent_id, fleet_id filters\n        assert len(filters) >= 3\n\n    @pytest.mark.asyncio\n    async def test_fleet_scope_requires_fleet_id(self):\n        \"\"\"generate_insights validates fleet_id presence at the public entry point.\"\"\"\n        from core_api.services.insights_service import generate_insights\n        from fastapi import HTTPException\n\n        with pytest.raises(HTTPException) as exc_info:\n            await generate_insights(","lineStart":1,"lineEnd":220,"totalLines":1031,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_insights_service.py","time":{"start":1780728443723,"end":1780728443751}},"metadata":{"openai":{"itemId":"fc_0744622ac6b4d8da016a23c27b92c08191ba64a762b9215fb8"}},"id":"prt_e9bafb346001rnZFe7XD922dGa","sessionID":"ses_164517a7effe3vNYDW5PuSLbjT","messageID":"msg_e9baf8199001K1SyHMo1g4t8fC"}}
{"type":"tool_use","timestamp":1780728443760,"sessionID":"ses_164517a7effe3vNYDW5PuSLbjT","part":{"type":"tool","tool":"read","callID":"call_nNzvp4jCfSQlDmT92YYgyUNk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_evolve_service.py","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_evolve_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for the evolve service — unit + integration.\n2: \n3: Unit tests (no DB): validation, fake rule, delta/weight math.\n4: Integration tests (require DB): weight adjustment, outcome persistence, rule generation.\n5: \"\"\"\n6: \n7: import uuid\n8: \n9: import pytest\n10: \n11: from tests._mcp_test_helpers import as_text\n12: from tests.conftest import uid as _uid\n13: \n14: \n15: # ---------------------------------------------------------------------------\n16: # Unit tests\n17: # ---------------------------------------------------------------------------\n18: \n19: \n20: class TestOutcomeTypeValidation:\n21:     \"\"\"Test that invalid outcome_type is rejected before hitting the DB.\n22: \n23:     The service raises ValueError (not HTTPException) so it stays\n24:     decoupled from FastAPI — REST/MCP callers translate to their layer's\n25:     error convention.\n26:     \"\"\"\n27: \n28:     @pytest.mark.asyncio\n29:     async def test_invalid_outcome_type_raises(self):\n30:         from core_api.services.evolve_service import report_outcome\n31: \n32:         with pytest.raises(ValueError) as exc_info:\n33:             await report_outcome(None, \"t1\", outcome=\"test\", outcome_type=\"invalid\")\n34:         assert \"invalid\" in str(exc_info.value).lower()\n35: \n36:     @pytest.mark.asyncio\n37:     async def test_valid_outcome_types_accepted(self):\n38:         \"\"\"Valid types should not raise on validation (may fail later on DB access).\"\"\"\n39:         from core_api.constants import EVOLVE_OUTCOME_TYPES\n40: \n41:         assert \"success\" in EVOLVE_OUTCOME_TYPES\n42:         assert \"failure\" in EVOLVE_OUTCOME_TYPES\n43:         assert \"partial\" in EVOLVE_OUTCOME_TYPES\n44: \n45: \n46: class TestFakeRule:\n47:     \"\"\"Test _fake_rule returns valid structure.\"\"\"\n48: \n49:     def test_structure(self):\n50:         from core_api.services.evolve_service import _fake_rule\n51: \n52:         result = _fake_rule()\n53:         assert isinstance(result, dict)\n54:         assert \"condition\" in result\n55:         assert \"action\" in result\n56:         assert \"confidence\" in result\n57:         assert \"reasoning\" in result\n58:         assert isinstance(result[\"confidence\"], (int, float))\n59:         assert 0.0 <= result[\"confidence\"] <= 1.0\n60: \n61: \n62: class TestDeltaConstants:\n63:     \"\"\"Test the asymmetric delta design.\"\"\"\n64: \n65:     def test_success_positive(self):\n66:         from core_api.constants import EVOLVE_SUCCESS_DELTA\n67: \n68:         assert EVOLVE_SUCCESS_DELTA > 0\n69: \n70:     def test_failure_negative(self):\n71:         from core_api.constants import EVOLVE_FAILURE_DELTA\n72: \n73:         assert EVOLVE_FAILURE_DELTA < 0\n74: \n75:     def test_partial_positive_small(self):\n76:         from core_api.constants import EVOLVE_PARTIAL_DELTA, EVOLVE_SUCCESS_DELTA\n77: \n78:         assert EVOLVE_PARTIAL_DELTA > 0\n79:         assert EVOLVE_PARTIAL_DELTA < EVOLVE_SUCCESS_DELTA\n80: \n81:     def test_failure_stronger_than_success(self):\n82:         \"\"\"Failures should propagate faster than successes.\"\"\"\n83:         from core_api.constants import EVOLVE_FAILURE_DELTA, EVOLVE_SUCCESS_DELTA\n84: \n85:         assert abs(EVOLVE_FAILURE_DELTA) > abs(EVOLVE_SUCCESS_DELTA)\n86: \n87: \n88: class TestWeightBounds:\n89:     \"\"\"Test that weight calculations respect floor and cap.\"\"\"\n90: \n91:     def test_floor(self):\n92:         from core_api.constants import (\n93:             EVOLVE_FAILURE_DELTA,\n94:             EVOLVE_WEIGHT_FLOOR,\n95:             EVOLVE_WEIGHT_CAP,\n96:         )\n97: \n98:         # Starting at 0.1, failure delta = -0.15 → should floor at 0.05\n99:         old_weight = 0.1\n100:         new_weight = max(\n101:             EVOLVE_WEIGHT_FLOOR,\n102:             min(EVOLVE_WEIGHT_CAP, old_weight + EVOLVE_FAILURE_DELTA),\n103:         )\n104:         assert new_weight == EVOLVE_WEIGHT_FLOOR\n105: \n106:     def test_cap(self):\n107:         from core_api.constants import (\n108:             EVOLVE_SUCCESS_DELTA,\n109:             EVOLVE_WEIGHT_CAP,\n110:             EVOLVE_WEIGHT_FLOOR,\n111:         )\n112: \n113:         # Starting at 0.95, success delta = +0.1 → should cap at 1.0\n114:         old_weight = 0.95\n115:         new_weight = max(\n116:             EVOLVE_WEIGHT_FLOOR,\n117:             min(EVOLVE_WEIGHT_CAP, old_weight + EVOLVE_SUCCESS_DELTA),\n118:         )\n119:         assert new_weight == EVOLVE_WEIGHT_CAP\n120: \n121:     def test_no_negative_weight(self):\n122:         from core_api.constants import (\n123:             EVOLVE_FAILURE_DELTA,\n124:             EVOLVE_WEIGHT_CAP,\n125:             EVOLVE_WEIGHT_FLOOR,\n126:         )\n127: \n128:         # Even at absolute minimum starting weight\n129:         old_weight = 0.05\n130:         new_weight = max(\n131:             EVOLVE_WEIGHT_FLOOR,\n132:             min(EVOLVE_WEIGHT_CAP, old_weight + EVOLVE_FAILURE_DELTA),\n133:         )\n134:         assert new_weight >= EVOLVE_WEIGHT_FLOOR\n135:         assert new_weight > 0\n136: \n137: \n138: # ---------------------------------------------------------------------------\n139: # Integration tests — require DB\n140: # ---------------------------------------------------------------------------\n141: \n142: \n143: async def _create_test_memory_via_sc(\n144:     sc, tenant_id, agent_id=\"evolve-test-agent\", weight=0.5, fleet_id=None\n145: ):\n146:     \"\"\"Create a memory via storage client (committed, visible across sessions).\n147: \n148:     Also ensures the agent is registered so enforce_update passes.\n149:     \"\"\"\n150:     tag = _uid()\n151:     fid = fleet_id or f\"evolve-fleet-{tag}\"\n152: \n153:     # Ensure agent exists in DB (enforce_update checks agent registration)\n154:     await sc.create_or_update_agent(\n155:         {\n156:             \"agent_id\": agent_id,\n157:             \"tenant_id\": tenant_id,\n158:             \"trust_level\": 1,\n159:             \"fleet_id\": fid,\n160:         }\n161:     )\n162: \n163:     payload = {\n164:         \"tenant_id\": tenant_id,\n165:         \"agent_id\": agent_id,\n166:         \"fleet_id\": fid,\n167:         \"memory_type\": \"fact\",\n168:         \"content\": f\"Test memory for evolve [{tag}]\",\n169:         \"weight\": weight,\n170:         \"status\": \"active\",\n171:         \"recall_count\": 0,\n172:         \"visibility\": \"scope_team\",\n173:     }\n174:     mem = await sc.create_memory(payload)\n175:     return str(mem[\"id\"]), tag\n176: \n177: \n178: async def _create_test_memory(\n179:     db, tenant_id, agent_id=\"evolve-test-agent\", weight=0.5, fleet_id=None\n180: ):\n\n(Showing lines 1-180 of 1196. Use offset=181 to continue.)\n</content>","metadata":{"preview":"\"\"\"Tests for the evolve service — unit + integration.\n\nUnit tests (no DB): validation, fake rule, delta/weight math.\nIntegration tests (require DB): weight adjustment, outcome persistence, rule generation.\n\"\"\"\n\nimport uuid\n\nimport pytest\n\nfrom tests._mcp_test_helpers import as_text\nfrom tests.conftest import uid as _uid\n\n\n# ---------------------------------------------------------------------------\n# Unit tests\n# ---------------------------------------------------------------------------\n\n\nclass TestOutcomeTypeValidation:","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_evolve_service.py","text":"\"\"\"Tests for the evolve service — unit + integration.\n\nUnit tests (no DB): validation, fake rule, delta/weight math.\nIntegration tests (require DB): weight adjustment, outcome persistence, rule generation.\n\"\"\"\n\nimport uuid\n\nimport pytest\n\nfrom tests._mcp_test_helpers import as_text\nfrom tests.conftest import uid as _uid\n\n\n# ---------------------------------------------------------------------------\n# Unit tests\n# ---------------------------------------------------------------------------\n\n\nclass TestOutcomeTypeValidation:\n    \"\"\"Test that invalid outcome_type is rejected before hitting the DB.\n\n    The service raises ValueError (not HTTPException) so it stays\n    decoupled from FastAPI — REST/MCP callers translate to their layer's\n    error convention.\n    \"\"\"\n\n    @pytest.mark.asyncio\n    async def test_invalid_outcome_type_raises(self):\n        from core_api.services.evolve_service import report_outcome\n\n        with pytest.raises(ValueError) as exc_info:\n            await report_outcome(None, \"t1\", outcome=\"test\", outcome_type=\"invalid\")\n        assert \"invalid\" in str(exc_info.value).lower()\n\n    @pytest.mark.asyncio\n    async def test_valid_outcome_types_accepted(self):\n        \"\"\"Valid types should not raise on validation (may fail later on DB access).\"\"\"\n        from core_api.constants import EVOLVE_OUTCOME_TYPES\n\n        assert \"success\" in EVOLVE_OUTCOME_TYPES\n        assert \"failure\" in EVOLVE_OUTCOME_TYPES\n        assert \"partial\" in EVOLVE_OUTCOME_TYPES\n\n\nclass TestFakeRule:\n    \"\"\"Test _fake_rule returns valid structure.\"\"\"\n\n    def test_structure(self):\n        from core_api.services.evolve_service import _fake_rule\n\n        result = _fake_rule()\n        assert isinstance(result, dict)\n        assert \"condition\" in result\n        assert \"action\" in result\n        assert \"confidence\" in result\n        assert \"reasoning\" in result\n        assert isinstance(result[\"confidence\"], (int, float))\n        assert 0.0 <= result[\"confidence\"] <= 1.0\n\n\nclass TestDeltaConstants:\n    \"\"\"Test the asymmetric delta design.\"\"\"\n\n    def test_success_positive(self):\n        from core_api.constants import EVOLVE_SUCCESS_DELTA\n\n        assert EVOLVE_SUCCESS_DELTA > 0\n\n    def test_failure_negative(self):\n        from core_api.constants import EVOLVE_FAILURE_DELTA\n\n        assert EVOLVE_FAILURE_DELTA < 0\n\n    def test_partial_positive_small(self):\n        from core_api.constants import EVOLVE_PARTIAL_DELTA, EVOLVE_SUCCESS_DELTA\n\n        assert EVOLVE_PARTIAL_DELTA > 0\n        assert EVOLVE_PARTIAL_DELTA < EVOLVE_SUCCESS_DELTA\n\n    def test_failure_stronger_than_success(self):\n        \"\"\"Failures should propagate faster than successes.\"\"\"\n        from core_api.constants import EVOLVE_FAILURE_DELTA, EVOLVE_SUCCESS_DELTA\n\n        assert abs(EVOLVE_FAILURE_DELTA) > abs(EVOLVE_SUCCESS_DELTA)\n\n\nclass TestWeightBounds:\n    \"\"\"Test that weight calculations respect floor and cap.\"\"\"\n\n    def test_floor(self):\n        from core_api.constants import (\n            EVOLVE_FAILURE_DELTA,\n            EVOLVE_WEIGHT_FLOOR,\n            EVOLVE_WEIGHT_CAP,\n        )\n\n        # Starting at 0.1, failure delta = -0.15 → should floor at 0.05\n        old_weight = 0.1\n        new_weight = max(\n            EVOLVE_WEIGHT_FLOOR,\n            min(EVOLVE_WEIGHT_CAP, old_weight + EVOLVE_FAILURE_DELTA),\n        )\n        assert new_weight == EVOLVE_WEIGHT_FLOOR\n\n    def test_cap(self):\n        from core_api.constants import (\n            EVOLVE_SUCCESS_DELTA,\n            EVOLVE_WEIGHT_CAP,\n            EVOLVE_WEIGHT_FLOOR,\n        )\n\n        # Starting at 0.95, success delta = +0.1 → should cap at 1.0\n        old_weight = 0.95\n        new_weight = max(\n            EVOLVE_WEIGHT_FLOOR,\n            min(EVOLVE_WEIGHT_CAP, old_weight + EVOLVE_SUCCESS_DELTA),\n        )\n        assert new_weight == EVOLVE_WEIGHT_CAP\n\n    def test_no_negative_weight(self):\n        from core_api.constants import (\n            EVOLVE_FAILURE_DELTA,\n            EVOLVE_WEIGHT_CAP,\n            EVOLVE_WEIGHT_FLOOR,\n        )\n\n        # Even at absolute minimum starting weight\n        old_weight = 0.05\n        new_weight = max(\n            EVOLVE_WEIGHT_FLOOR,\n            min(EVOLVE_WEIGHT_CAP, old_weight + EVOLVE_FAILURE_DELTA),\n        )\n        assert new_weight >= EVOLVE_WEIGHT_FLOOR\n        assert new_weight > 0\n\n\n# ---------------------------------------------------------------------------\n# Integration tests — require DB\n# ---------------------------------------------------------------------------\n\n\nasync def _create_test_memory_via_sc(\n    sc, tenant_id, agent_id=\"evolve-test-agent\", weight=0.5, fleet_id=None\n):\n    \"\"\"Create a memory via storage client (committed, visible across sessions).\n\n    Also ensures the agent is registered so enforce_update passes.\n    \"\"\"\n    tag = _uid()\n    fid = fleet_id or f\"evolve-fleet-{tag}\"\n\n    # Ensure agent exists in DB (enforce_update checks agent registration)\n    await sc.create_or_update_agent(\n        {\n            \"agent_id\": agent_id,\n            \"tenant_id\": tenant_id,\n            \"trust_level\": 1,\n            \"fleet_id\": fid,\n        }\n    )\n\n    payload = {\n        \"tenant_id\": tenant_id,\n        \"agent_id\": agent_id,\n        \"fleet_id\": fid,\n        \"memory_type\": \"fact\",\n        \"content\": f\"Test memory for evolve [{tag}]\",\n        \"weight\": weight,\n        \"status\": \"active\",\n        \"recall_count\": 0,\n        \"visibility\": \"scope_team\",\n    }\n    mem = await sc.create_memory(payload)\n    return str(mem[\"id\"]), tag\n\n\nasync def _create_test_memory(\n    db, tenant_id, agent_id=\"evolve-test-agent\", weight=0.5, fleet_id=None\n):","lineStart":1,"lineEnd":180,"totalLines":1196,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/tests/test_evolve_service.py","time":{"start":1780728443724,"end":1780728443757}},"metadata":{"openai":{"itemId":"fc_0744622ac6b4d8da016a23c27b92c48191a48d1f751bab0926"}},"id":"prt_e9bafb34c001B32rns5p7OoukZ","sessionID":"ses_164517a7effe3vNYDW5PuSLbjT","messageID":"msg_e9baf8199001K1SyHMo1g4t8fC"}}
