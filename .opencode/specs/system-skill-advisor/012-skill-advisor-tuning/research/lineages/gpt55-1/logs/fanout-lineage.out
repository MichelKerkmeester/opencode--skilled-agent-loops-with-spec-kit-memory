 [['sk-code', 0.65]],\n88:   inp: [['sk-code', 0.65]],\n89:   lcp: [['sk-code', 0.55]],\n90:   fcp: [['sk-code', 0.55]],\n91:   cls: [['sk-code', 0.55]],\n92:   motion: [['sk-code', 0.6]],\n93:   observer: [['sk-code', 0.4]],\n94:   intersection: [['sk-code', 0.4]],\n95:   classifier: [['sk-code', 0.45]],\n96:   fixture: [['sk-code', 0.55]],\n97:   'gate-3-classifier': [['sk-code', 0.95]],\n98:   'negative-trigger': [['sk-code', 0.8]],\n99: };\n100: \n101: const PHRASE_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n102:   '/create:agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n103:   '/create:manual-testing-playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n104:   '/memory:save': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n105:   '/deep:start-research-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n106:   '/deep:start-review-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n107:   '/deep:start-model-benchmark-loop': [['deep-model-benchmark', 1.6], ['command-spec-kit', 0.45]],\n108:   '/deep:start-agent-improvement-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n109:   '/speckit:resume': [['system-spec-kit', 0.9], ['command-spec-kit', 0.75]],\n110:   'auto review release readiness': [['deep-loop-workflows', 1]],\n111:   // Colon-command syntax (\":review:auto\") is a deep-review LOOP invocation,\n112:   // distinct from natural-language \"auto review this PR\" (which routes to\n113:   // sk-code's code-review mode). Strong direct-evidence anchor + a bounded\n114:   // penalty on the single-pass skill so the loop skill wins the rank.\n115:   ':review:auto': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n116:   ':review:confirm': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n117:   // Domain phrase anchors (multi-token, so they lift confidence via the direct\n118:   // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n119:   'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n120:   'cms collection': [['mcp-code-mode', 1.4]],\n121:   'structural search': [['system-code-graph', 1.5]],\n122:   'code graph search': [['system-code-graph', 1.5]],\n123:   'find code that': [['system-code-graph', 1.4]],\n124:   'code that handles': [['system-code-graph', 1.4]],\n125:   '5d scoring': [['deep-loop-workflows', 1.5]],\n126:   '5-dimension agent scoring': [['deep-loop-workflows', 1.6]],\n127:   'integration scan': [['deep-loop-workflows', 1.5]],\n128:   'dynamic profile': [['deep-loop-workflows', 1.5]],\n129:   // Lane B (model-benchmark) command anchors. These benchmark or optimize a\n130:   // model / prompt framework against fixtures, routed by the\n131:   // /deep:start-model-benchmark-loop command (canonical deep-model-benchmark).\n132:   // Lane B runs as a MODE of the agent-improvement skill, now folded into\n133:   // deep-loop-workflows. The projection exposes that merged node, so the\n134:   // disambiguation penalty must target deep-loop-workflows to actually lower the\n135:   // ranked Lane A candidate; an alias-shaped target is not a projection node and\n136:   // its penalty would be inert. The bounded penalty keeps benchmark phrasing\n137:   // from out-ranking deep-model-benchmark.\n138:   'benchmark a model': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n139:   'benchmark a prompt framework': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n140:   'benchmark a prompt': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n141:   'optimize a model': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n142:   'optimize a prompt framework': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n143:   'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.4]],\n144:   'model benchmark': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n145:   'benchmark fixtures': [['deep-model-benchmark', 1.3]],\n146:   'prompt framework benchmark': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.4]],\n147:   'chrome devtools': [['mcp-chrome-devtools', 1]],\n148:   'staging url': [['mcp-chrome-devtools', 0.65]],\n149:   'staging site': [['mcp-chrome-devtools', 0.65]],\n150:   'staging website': [['mcp-chrome-devtools', 0.65]],\n151:   'live site': [['mcp-chrome-devtools', 0.65]],\n152:   'live website': [['mcp-chrome-devtools', 0.65]],\n153:   'live url': [['mcp-chrome-devtools', 0.65]],\n154:   'production site': [['mcp-chrome-devtools', 0.65]],\n155:   'production website': [['mcp-chrome-devtools', 0.65]],\n156:   'production url': [['mcp-chrome-devtools', 0.65]],\n157:   'browser console': [['mcp-chrome-devtools', 0.75]],\n158:   'cleaner prompt': [['sk-prompt', 1]],\n159:   'code review': [['sk-code', 1]],\n160:   'review the routing': [['sk-code', 0.6]],\n161:   'review the taxonomy': [['sk-code', 0.6]],\n162:   'review the routing taxonomy': [['sk-code', 1.1], ['sk-doc', -0.4]],\n163:   'review the packet docs': [['sk-code', 1.2]],\n164:   'audit packet docs': [['sk-code', 1.2]],\n165:   'audit whether': [['sk-code', 1.2]],\n166:   'audit the': [['sk-code', 1.0]],\n167:   'documented consistently': [['sk-code', 1]],\n168:   'scoped correctly': [['sk-code', 1]],\n169:   'iteration is scoped': [['sk-code', 1]],\n170:   'classifier vocabulary': [['sk-code', 0.9]],\n171:   'commonjs helper': [['sk-code', 1]],\n172:   'create a prompt': [['sk-prompt', 0.95]],\n173:   'deep research': [['deep-loop-workflows', 1]],\n174:   'deep review': [['deep-loop-workflows', 1]],\n175:   'deep ai council': [['deep-loop-workflows', 1.6]],\n176:   'deep-ai-council': [['deep-loop-workflows', 1.6]],\n177:   'deep-research': [['deep-loop-workflows', 1.3]],\n178:   'deep-review': [['deep-loop-workflows', 1.3]],\n179:   'ai council': [['deep-loop-workflows', 1.4]],\n180:   'planning council': [['deep-loop-workflows', 1.2]],\n181:   'council deliberation': [['deep-loop-workflows', 1.4]],\n182:   'persist council artifacts': [['deep-loop-workflows', 1.2]],\n183:   'ai-council artifacts': [['deep-loop-workflows', 1.2]],\n184:   'multi-ai-council': [['deep-loop-workflows', 1.2]],\n185:   'gate 3': [['system-spec-kit', 0.35], ['sk-code', 0.25]],\n186:   'gate-3-classifier': [['sk-code', 1]],\n187:   'generate implementation-summary': [['system-spec-kit', 1]],\n188:   'implementation-summary.md': [['system-spec-kit', 0.8]],\n189:   'continuation prompts': [['system-spec-kit', 0.9]],\n190:   'first-100 predictions': [['system-spec-kit', 0.8]],\n191:   'improve my prompt': [['sk-prompt', 1]],\n192:   'manual testing playbook': [['sk-doc', 1]],\n193:   'negative-trigger whitelist': [['sk-code', 0.9]],\n194:   'list any mismatches': [['sk-code', 0.8]],\n195:   'pull request': [['sk-code', 0.45], ['sk-git', 0.45]],\n196:   'resume deep research': [['deep-loop-workflows', 1]],\n197:   'resume deep review': [['deep-loop-workflows', 1]],\n198:   'resume the phase folder': [['system-spec-kit', 1]],\n199:   'phase folder': [['system-spec-kit', 0.75]],\n200:   'routing dashboard': [['sk-code', 0.35]],\n201:   'routing study config': [['system-spec-kit', 0.85]],\n202:   'css layout': [['sk-code', 0.85]],\n203:   'viewport height': [['sk-code', 0.55]],\n204:   'mobile browser': [['sk-code', 0.6]],\n205:   'browser verification': [['sk-code', 0.7]],\n206:   'create a new agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n207:   'create a test playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n208:   'create a testing playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n209:   'create new agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n210:   'create test playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n211:   'create testing playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n212:   'save context': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n213:   'save memory': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n214:   'semantic code search': [['system-code-graph', 0.8]],\n215:   'source-type mix': [['system-spec-kit', 0.35]],\n216:   'system prompt': [['sk-prompt', 0.8]],\n217:   'prompt variant': [['sk-prompt', 1]],\n218:   'user prompt': [['sk-prompt', 0.9]],\n219:   'cleaner user prompt': [['sk-prompt', 1]],\n220:   'vector-search': [['system-code-graph', 0.6]],\n221:   // sk-code phrases: frontend and system-code surfaces.\n222:   'motion v12': [['sk-code', 0.6]],\n223:   'opencode skill': [['sk-code', 0.95]],\n224:   'opencode agent': [['sk-code', 0.85]],\n225:   'opencode command': [['sk-code', 0.85]],\n226:   'opencode plugin': [['sk-code', 0.85]],\n227:   'smart router': [['sk-code', 0.65]],\n228:   'language standards': [['sk-code', 0.6]],\n229:   'typescript helper': [['sk-code', 0.75]],\n230:   'python script': [['sk-code', 0.75]],\n231:   'shell script': [['sk-code', 0.7]],\n232:   'frontend hero animation timing': [['sk-code', 0.95]],\n233:   'parallel routes': [['sk-code', 0.85]],\n234:   'route handler': [['sk-code', 0.7]],\n235:   'metadata api': [['sk-code', 0.65]],\n236: };\n237: \n238: const WRITE_VERBS = /\\b(add|build|change|configure|create|edit|fix|generate|implement|modify|patch|refactor|rename|replace|run|update|write)\\b/;\n239: const MEMORY_PRESERVATION_SESSION_INTENT = /\\b(preserve|remember|capture|keep|store)\\b.*\\b(next|future|later)\\s+session\\b|\\b(next|future|later)\\s+session\\b.*\\b(lose|lost|preserve|remember|capture|keep|store)\\b/;\n240: \n241: function push(\n242:   scores: Map<string, ExplicitScoreEntry>,\n243:   skillId: string,\n244:   amount: number,\n245:   evidence: string,\n246:   producerSkillId?: string,\n247: ): void {\n248:   const current = scores.get(skillId) ?? { score: 0, evidence: [], producerSkillIds: new Set<string>() };\n249:   current.score += amount;\n250:   current.evidence.push(evidence);\n251:   if (producerSkillId) {\n252:     current.producerSkillIds.add(producerSkillId);\n253:   }\n254:   scores.set(skillId, current);\n255: }\n256: \n257: export function scoreExplicitLane(\n258:   prompt: string,\n259:   projection: AdvisorProjection,\n260:   options: ExplicitLaneOptions = {},\n261: ): LaneMatch[] {\n262:   const lower = prompt.toLowerCase();\n263:   const tokens = tokenize(prompt, true);\n264:   const scores = new Map<string, ExplicitScoreEntry>();\n265: \n266:   for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {\n267:     if (!lower.includes(phrase)) continue;\n268:     for (const [skillId, amount] of boosts) {\n269:       push(scores, skillId, amount, `phrase:${phrase}`);\n270:     }\n271:   }\n272: \n273:   for (const token of tokens) {\n274:     for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {\n275:       push(scores, skillId, amount, `token:${token}`);\n276:     }\n277:   }\n278: \n279:   if (WRITE_VERBS.test(lower) && /\\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\\b/.test(lower)) {\n280:     push(scores, 'sk-doc', 0.7, 'write-doc-surface');\n281:   }\n282:   if (WRITE_VERBS.test(lower) && /\\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\\.py|mcp\\.json|commonjs)\\b/.test(lower)) {\n283:     push(scores, 'sk-code', 0.7, 'write-system-code-surface');\n284:   }\n285:   if (WRITE_VERBS.test(lower) && /\\b(error classes|trigger gap|reporter|mismatches?|bucket|gate 3)\\b/.test(lower)) {\n286:     push(scores, 'sk-code', 0.6, 'write-routing-tool-surface');\n287:   }\n288:   if (MEMORY_PRESERVATION_SESSION_INTENT.test(lower)) {\n289:     push(scores, 'memory:save', 1.2, 'memory-preservation-session-intent');\n290:     push(scores, 'command-memory-save', 0.8, 'memory-preservation-session-intent');\n291:     push(scores, 'system-spec-kit', 0.3, 'memory-preservation-session-intent');\n292:   }\n293:   if (lower.includes('/speckit:resume')) {\n294:     push(scores, 'system-spec-kit', 0.4, 'speckit-resume-skill-disambiguation');\n295:     push(scores, 'command-spec-kit', -1.0, 'speckit-resume-skill-disambiguation');\n296:   }\n297:   // Review-plus-write intent. When the prompt contains the word `review`\n298:   // AND an explicit write/edit verb (`update|edit|fix|modify`), the request\n299:   // is implementation work; anchor the explicit lane firmly on `sk-code` so\n300:   // the code hub wins the skill selection (its router then selects the\n301:   // implement mode rather than the code-review mode). The lane's emit clamps\n302:   // with `Math.min(value.score, 1)`, so the wide magnitude only guarantees\n303:   // the anchor; it cannot overshoot.\n304:   if (/\\breview\\b/.test(lower) && /\\b(update|edit|fix|modify)\\b/.test(lower)) {\n305:     push(scores, 'sk-code', 3.0, 'review-plus-write-disambiguation');\n306:   }\n307:   if (/\\b(continue|resume|launch|kick off|overnight|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\bresearch\\b/.test(lower)) {\n308:     push(scores, 'deep-loop-workflows', 0.85, 'research-loop');\n309:   }\n310:   if (/\\b(continue|resume|launch|start|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\breview\\b/.test(lower)) {\n311:     push(scores, 'deep-loop-workflows', 0.85, 'review-loop');\n312:     if (/\\b(audit|spec folder|packet|convergence)\\b/.test(lower)) {\n313:       push(scores, 'sk-code', -0.6, 'iterative-review-vs-pr-disambiguation');\n314:     }\n315:   }\n316:   if (/\\b(figure out|find|diagnose|debug)\\b.{0,40}\\b(wrong|broken|failing|bug|issue)\\b.{0,40}\\bcode\\b|\\b(wrong|broken|failing)\\b.{0,30}\\bcode\\b/.test(lower)) {\n317:     push(scores, 'sk-code', 0.9, 'ambiguous-code-problem');\n318:     push(scores, 'deep-loop-workflows', 0.45, 'ambiguous-code-problem');\n319:   }\n320: \n321:   for (const skill of projection.skills) {\n322:     for (const variant of skillNameVariants(skill.id)) {\n323:       if (matchesPhraseBoundary(lower, variant)) {\n324:         push(scores, skill.id, 1, `explicit:${variant}`);\n325:       }\n326:     }\n327:     for (const phrase of [...skill.intentSignals, ...skill.keywords]) {\n328:       if (matchesPhraseBoundary(lower, phrase)) {\n329:         push(\n330:           scores,\n331:           skill.id,\n332:           phraseSpecificity(phrase),\n333:           `author:${phrase}`,\n334:           options.includeProducerIdentity ? skill.id : undefined,\n335:         );\n336:       }\n337:     }\n338:   }\n339: \n340:   return [...scores.entries()].map(([skillId, value]) => {\n341:     const producerSkillIds = [...value.producerSkillIds].sort();\n342:     return {\n343:       skillId,\n344:       lane: 'explicit_author' as const,\n345:       score: Math.min(value.score, 1),\n346:       evidence: value.evidence.slice(0, 6),\n347:       ...(producerSkillIds.length > 0 ? { producerSkillIds } : {}),\n348:     };\n349:   });\n350: }\n\n(End of file - total 350 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, skillNameVariants, tokenize } from '../text.js';\n\ninterface ExplicitLaneOptions {\n  readonly includeProducerIdentity?: boolean;\n}\n\ninterface ExplicitScoreEntry {\n  score: number;\n  readonly evidence: string[];\n  readonly producerSkillIds: Set<string>;\n}\n\nconst TOKEN_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  audit: [['sk-code', 0.75]],\n  branch: [['sk-git', 0.45]],","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, skillNameVariants, tokenize } from '../text.js';\n\ninterface ExplicitLaneOptions {\n  readonly includeProducerIdentity?: boolean;\n}\n\ninterface ExplicitScoreEntry {\n  score: number;\n  readonly evidence: string[];\n  readonly producerSkillIds: Set<string>;\n}\n\nconst TOKEN_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  audit: [['sk-code', 0.75]],\n  branch: [['sk-git', 0.45]],\n  browser: [['sk-code', 0.55]],\n  checklist: [['system-spec-kit', 0.55]],\n  chrome: [['mcp-chrome-devtools', 0.95]],\n  commit: [['sk-git', 0.65]],\n  commonjs: [['sk-code', 0.75]],\n  context: [['system-spec-kit', 0.65]],\n  corpus: [['system-spec-kit', 0.45]],\n  council: [['deep-loop-workflows', 0.9]],\n  css: [['sk-code', 0.55]],\n  dashboard: [['sk-code', 0.35]],\n  deliberation: [['deep-loop-workflows', 0.8]],\n  debug: [['sk-code', 0.25]],\n  devtools: [['mcp-chrome-devtools', 1]],\n  docs: [['sk-doc', 0.8]],\n  documentation: [['sk-doc', 0.85]],\n  findings: [['sk-code', 0.85]],\n  frontend: [['sk-code', 0.7]],\n  git: [['sk-git', 1]],\n  github: [['sk-git', 0.95]],\n  grep: [['system-code-graph', 0.45]],\n  har: [['mcp-chrome-devtools', 0.75]],\n  html: [['sk-code', 0.55]],\n  javascript: [['sk-code', 0.65]],\n  json: [['sk-code', 0.4]],\n  jsonl: [['sk-code', 0.45], ['system-spec-kit', 0.35]],\n  layout: [['sk-code', 0.45]],\n  mcp: [['sk-code', 0.65], ['mcp-code-mode', 0.45]],\n  memory: [['system-spec-kit', 0.95]],\n  mobile: [['sk-code', 0.45]],\n  opencode: [['sk-code', 1]],\n  packet: [['system-spec-kit', 0.55]],\n  playbook: [['sk-doc', 0.75]],\n  pr: [['sk-code', 0.5], ['sk-git', 0.35]],\n  prompt: [['sk-prompt', 0.75]],\n  prompts: [['sk-prompt', 0.75]],\n  python: [['sk-code', 0.7]],\n  readme: [['sk-doc', 0.95]],\n  rebase: [['sk-git', 0.85]],\n  reducer: [['sk-code', 0.35]],\n  regression: [['sk-code', 0.55]],\n  responsive: [['sk-code', 0.55]],\n  review: [['sk-code', 0.85]],\n  reviewer: [],\n  routing: [['system-spec-kit', 0.25]],\n  save: [['system-spec-kit', 0.6]],\n  semantic: [['system-code-graph', 0.55]],\n  shell: [['sk-code', 0.55]],\n  staging: [['mcp-chrome-devtools', 0.35]],\n  style: [['sk-code', 0.4]],\n  taxonomy: [['sk-doc', 0.45]],\n  tests: [['sk-code', 0.35]],\n  typescript: [['sk-code', 0.75]],\n  vitest: [['sk-code', 0.85]],\n  viewport: [['sk-code', 0.45]],\n  vscode: [['sk-code', 0.75]],\n  web: [['sk-code', 0.5]],\n  worktree: [['sk-git', 1]],\n  delete: [['system-spec-kit', 0.45]],\n  scratch: [['system-spec-kit', 0.45]],\n  // sk-code surface keywords: frontend and system-code surfaces.\n  animation: [['sk-code', 0.75]],\n  flicker: [['sk-code', 0.4]],\n  minify: [['sk-code', 0.65]],\n  cdn: [['sk-code', 0.55]],\n  lighthouse: [['sk-code', 0.65]],\n  pagespeed: [['sk-code', 0.65]],\n  tbt: [['sk-code', 0.65]],\n  inp: [['sk-code', 0.65]],\n  lcp: [['sk-code', 0.55]],\n  fcp: [['sk-code', 0.55]],\n  cls: [['sk-code', 0.55]],\n  motion: [['sk-code', 0.6]],\n  observer: [['sk-code', 0.4]],\n  intersection: [['sk-code', 0.4]],\n  classifier: [['sk-code', 0.45]],\n  fixture: [['sk-code', 0.55]],\n  'gate-3-classifier': [['sk-code', 0.95]],\n  'negative-trigger': [['sk-code', 0.8]],\n};\n\nconst PHRASE_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  '/create:agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n  '/create:manual-testing-playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n  '/memory:save': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n  '/deep:start-research-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n  '/deep:start-review-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n  '/deep:start-model-benchmark-loop': [['deep-model-benchmark', 1.6], ['command-spec-kit', 0.45]],\n  '/deep:start-agent-improvement-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n  '/speckit:resume': [['system-spec-kit', 0.9], ['command-spec-kit', 0.75]],\n  'auto review release readiness': [['deep-loop-workflows', 1]],\n  // Colon-command syntax (\":review:auto\") is a deep-review LOOP invocation,\n  // distinct from natural-language \"auto review this PR\" (which routes to\n  // sk-code's code-review mode). Strong direct-evidence anchor + a bounded\n  // penalty on the single-pass skill so the loop skill wins the rank.\n  ':review:auto': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n  ':review:confirm': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n  // Domain phrase anchors (multi-token, so they lift confidence via the direct\n  // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n  'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n  'cms collection': [['mcp-code-mode', 1.4]],\n  'structural search': [['system-code-graph', 1.5]],\n  'code graph search': [['system-code-graph', 1.5]],\n  'find code that': [['system-code-graph', 1.4]],\n  'code that handles': [['system-code-graph', 1.4]],\n  '5d scoring': [['deep-loop-workflows', 1.5]],\n  '5-dimension agent scoring': [['deep-loop-workflows', 1.6]],\n  'integration scan': [['deep-loop-workflows', 1.5]],\n  'dynamic profile': [['deep-loop-workflows', 1.5]],\n  // Lane B (model-benchmark) command anchors. These benchmark or optimize a\n  // model / prompt framework against fixtures, routed by the\n  // /deep:start-model-benchmark-loop command (canonical deep-model-benchmark).\n  // Lane B runs as a MODE of the agent-improvement skill, now folded into\n  // deep-loop-workflows. The projection exposes that merged node, so the\n  // disambiguation penalty must target deep-loop-workflows to actually lower the\n  // ranked Lane A candidate; an alias-shaped target is not a projection node and\n  // its penalty would be inert. The bounded penalty keeps benchmark phrasing\n  // from out-ranking deep-model-benchmark.\n  'benchmark a model': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n  'benchmark a prompt framework': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n  'benchmark a prompt': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n  'optimize a model': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n  'optimize a prompt framework': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n  'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.4]],\n  'model benchmark': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n  'benchmark fixtures': [['deep-model-benchmark', 1.3]],\n  'prompt framework benchmark': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.4]],\n  'chrome devtools': [['mcp-chrome-devtools', 1]],\n  'staging url': [['mcp-chrome-devtools', 0.65]],\n  'staging site': [['mcp-chrome-devtools', 0.65]],\n  'staging website': [['mcp-chrome-devtools', 0.65]],\n  'live site': [['mcp-chrome-devtools', 0.65]],\n  'live website': [['mcp-chrome-devtools', 0.65]],\n  'live url': [['mcp-chrome-devtools', 0.65]],\n  'production site': [['mcp-chrome-devtools', 0.65]],\n  'production website': [['mcp-chrome-devtools', 0.65]],\n  'production url': [['mcp-chrome-devtools', 0.65]],\n  'browser console': [['mcp-chrome-devtools', 0.75]],\n  'cleaner prompt': [['sk-prompt', 1]],\n  'code review': [['sk-code', 1]],\n  'review the routing': [['sk-code', 0.6]],\n  'review the taxonomy': [['sk-code', 0.6]],\n  'review the routing taxonomy': [['sk-code', 1.1], ['sk-doc', -0.4]],\n  'review the packet docs': [['sk-code', 1.2]],\n  'audit packet docs': [['sk-code', 1.2]],\n  'audit whether': [['sk-code', 1.2]],\n  'audit the': [['sk-code', 1.0]],\n  'documented consistently': [['sk-code', 1]],\n  'scoped correctly': [['sk-code', 1]],\n  'iteration is scoped': [['sk-code', 1]],\n  'classifier vocabulary': [['sk-code', 0.9]],\n  'commonjs helper': [['sk-code', 1]],\n  'create a prompt': [['sk-prompt', 0.95]],\n  'deep research': [['deep-loop-workflows', 1]],\n  'deep review': [['deep-loop-workflows', 1]],\n  'deep ai council': [['deep-loop-workflows', 1.6]],\n  'deep-ai-council': [['deep-loop-workflows', 1.6]],\n  'deep-research': [['deep-loop-workflows', 1.3]],\n  'deep-review': [['deep-loop-workflows', 1.3]],\n  'ai council': [['deep-loop-workflows', 1.4]],\n  'planning council': [['deep-loop-workflows', 1.2]],\n  'council deliberation': [['deep-loop-workflows', 1.4]],\n  'persist council artifacts': [['deep-loop-workflows', 1.2]],\n  'ai-council artifacts': [['deep-loop-workflows', 1.2]],\n  'multi-ai-council': [['deep-loop-workflows', 1.2]],\n  'gate 3': [['system-spec-kit', 0.35], ['sk-code', 0.25]],\n  'gate-3-classifier': [['sk-code', 1]],\n  'generate implementation-summary': [['system-spec-kit', 1]],\n  'implementation-summary.md': [['system-spec-kit', 0.8]],\n  'continuation prompts': [['system-spec-kit', 0.9]],\n  'first-100 predictions': [['system-spec-kit', 0.8]],\n  'improve my prompt': [['sk-prompt', 1]],\n  'manual testing playbook': [['sk-doc', 1]],\n  'negative-trigger whitelist': [['sk-code', 0.9]],\n  'list any mismatches': [['sk-code', 0.8]],\n  'pull request': [['sk-code', 0.45], ['sk-git', 0.45]],\n  'resume deep research': [['deep-loop-workflows', 1]],\n  'resume deep review': [['deep-loop-workflows', 1]],\n  'resume the phase folder': [['system-spec-kit', 1]],\n  'phase folder': [['system-spec-kit', 0.75]],\n  'routing dashboard': [['sk-code', 0.35]],\n  'routing study config': [['system-spec-kit', 0.85]],\n  'css layout': [['sk-code', 0.85]],\n  'viewport height': [['sk-code', 0.55]],\n  'mobile browser': [['sk-code', 0.6]],\n  'browser verification': [['sk-code', 0.7]],\n  'create a new agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n  'create a test playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n  'create a testing playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n  'create new agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n  'create test playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n  'create testing playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n  'save context': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n  'save memory': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n  'semantic code search': [['system-code-graph', 0.8]],\n  'source-type mix': [['system-spec-kit', 0.35]],\n  'system prompt': [['sk-prompt', 0.8]],\n  'prompt variant': [['sk-prompt', 1]],\n  'user prompt': [['sk-prompt', 0.9]],\n  'cleaner user prompt': [['sk-prompt', 1]],\n  'vector-search': [['system-code-graph', 0.6]],\n  // sk-code phrases: frontend and system-code surfaces.\n  'motion v12': [['sk-code', 0.6]],\n  'opencode skill': [['sk-code', 0.95]],\n  'opencode agent': [['sk-code', 0.85]],\n  'opencode command': [['sk-code', 0.85]],\n  'opencode plugin': [['sk-code', 0.85]],\n  'smart router': [['sk-code', 0.65]],\n  'language standards': [['sk-code', 0.6]],\n  'typescript helper': [['sk-code', 0.75]],\n  'python script': [['sk-code', 0.75]],\n  'shell script': [['sk-code', 0.7]],\n  'frontend hero animation timing': [['sk-code', 0.95]],\n  'parallel routes': [['sk-code', 0.85]],\n  'route handler': [['sk-code', 0.7]],\n  'metadata api': [['sk-code', 0.65]],\n};\n\nconst WRITE_VERBS = /\\b(add|build|change|configure|create|edit|fix|generate|implement|modify|patch|refactor|rename|replace|run|update|write)\\b/;\nconst MEMORY_PRESERVATION_SESSION_INTENT = /\\b(preserve|remember|capture|keep|store)\\b.*\\b(next|future|later)\\s+session\\b|\\b(next|future|later)\\s+session\\b.*\\b(lose|lost|preserve|remember|capture|keep|store)\\b/;\n\nfunction push(\n  scores: Map<string, ExplicitScoreEntry>,\n  skillId: string,\n  amount: number,\n  evidence: string,\n  producerSkillId?: string,\n): void {\n  const current = scores.get(skillId) ?? { score: 0, evidence: [], producerSkillIds: new Set<string>() };\n  current.score += amount;\n  current.evidence.push(evidence);\n  if (producerSkillId) {\n    current.producerSkillIds.add(producerSkillId);\n  }\n  scores.set(skillId, current);\n}\n\nexport function scoreExplicitLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  options: ExplicitLaneOptions = {},\n): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = tokenize(prompt, true);\n  const scores = new Map<string, ExplicitScoreEntry>();\n\n  for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {\n    if (!lower.includes(phrase)) continue;\n    for (const [skillId, amount] of boosts) {\n      push(scores, skillId, amount, `phrase:${phrase}`);\n    }\n  }\n\n  for (const token of tokens) {\n    for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {\n      push(scores, skillId, amount, `token:${token}`);\n    }\n  }\n\n  if (WRITE_VERBS.test(lower) && /\\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\\b/.test(lower)) {\n    push(scores, 'sk-doc', 0.7, 'write-doc-surface');\n  }\n  if (WRITE_VERBS.test(lower) && /\\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\\.py|mcp\\.json|commonjs)\\b/.test(lower)) {\n    push(scores, 'sk-code', 0.7, 'write-system-code-surface');\n  }\n  if (WRITE_VERBS.test(lower) && /\\b(error classes|trigger gap|reporter|mismatches?|bucket|gate 3)\\b/.test(lower)) {\n    push(scores, 'sk-code', 0.6, 'write-routing-tool-surface');\n  }\n  if (MEMORY_PRESERVATION_SESSION_INTENT.test(lower)) {\n    push(scores, 'memory:save', 1.2, 'memory-preservation-session-intent');\n    push(scores, 'command-memory-save', 0.8, 'memory-preservation-session-intent');\n    push(scores, 'system-spec-kit', 0.3, 'memory-preservation-session-intent');\n  }\n  if (lower.includes('/speckit:resume')) {\n    push(scores, 'system-spec-kit', 0.4, 'speckit-resume-skill-disambiguation');\n    push(scores, 'command-spec-kit', -1.0, 'speckit-resume-skill-disambiguation');\n  }\n  // Review-plus-write intent. When the prompt contains the word `review`\n  // AND an explicit write/edit verb (`update|edit|fix|modify`), the request\n  // is implementation work; anchor the explicit lane firmly on `sk-code` so\n  // the code hub wins the skill selection (its router then selects the\n  // implement mode rather than the code-review mode). The lane's emit clamps\n  // with `Math.min(value.score, 1)`, so the wide magnitude only guarantees\n  // the anchor; it cannot overshoot.\n  if (/\\breview\\b/.test(lower) && /\\b(update|edit|fix|modify)\\b/.test(lower)) {\n    push(scores, 'sk-code', 3.0, 'review-plus-write-disambiguation');\n  }\n  if (/\\b(continue|resume|launch|kick off|overnight|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\bresearch\\b/.test(lower)) {\n    push(scores, 'deep-loop-workflows', 0.85, 'research-loop');\n  }\n  if (/\\b(continue|resume|launch|start|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\breview\\b/.test(lower)) {\n    push(scores, 'deep-loop-workflows', 0.85, 'review-loop');\n    if (/\\b(audit|spec folder|packet|convergence)\\b/.test(lower)) {\n      push(scores, 'sk-code', -0.6, 'iterative-review-vs-pr-disambiguation');\n    }\n  }\n  if (/\\b(figure out|find|diagnose|debug)\\b.{0,40}\\b(wrong|broken|failing|bug|issue)\\b.{0,40}\\bcode\\b|\\b(wrong|broken|failing)\\b.{0,30}\\bcode\\b/.test(lower)) {\n    push(scores, 'sk-code', 0.9, 'ambiguous-code-problem');\n    push(scores, 'deep-loop-workflows', 0.45, 'ambiguous-code-problem');\n  }\n\n  for (const skill of projection.skills) {\n    for (const variant of skillNameVariants(skill.id)) {\n      if (matchesPhraseBoundary(lower, variant)) {\n        push(scores, skill.id, 1, `explicit:${variant}`);\n      }\n    }\n    for (const phrase of [...skill.intentSignals, ...skill.keywords]) {\n      if (matchesPhraseBoundary(lower, phrase)) {\n        push(\n          scores,\n          skill.id,\n          phraseSpecificity(phrase),\n          `author:${phrase}`,\n          options.includeProducerIdentity ? skill.id : undefined,\n        );\n      }\n    }\n  }\n\n  return [...scores.entries()].map(([skillId, value]) => {\n    const producerSkillIds = [...value.producerSkillIds].sort();\n    return {\n      skillId,\n      lane: 'explicit_author' as const,\n      score: Math.min(value.score, 1),\n      evidence: value.evidence.slice(0, 6),\n      ...(producerSkillIds.length > 0 ? { producerSkillIds } : {}),\n    };\n  });\n}","lineStart":1,"lineEnd":350,"totalLines":350,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","time":{"start":1783437201945,"end":1783437201948}},"metadata":{"openai":{"itemId":"fc_002f97d8e79f1a0a016a4d1791cdcc8191a79b1acd415f5e1e"}},"id":"prt_f3d2411cf001ayCV3aY7OFyUWO","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ"}}
{"type":"tool_use","timestamp":1783437201973,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_zcvISAELVQYR24OH5qLWCTRG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":1,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor 5-Lane Fusion\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n6: \n7: import { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\n8: import { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\n9: import {\n10:   ADVISOR_HOOK_FRESHNESS_VALUES,\n11:   ADVISOR_RUNTIME_VALUES,\n12:   isSpeckitMetricsEnabled,\n13:   speckitMetrics,\n14: } from '../metrics.js';\n15: import { normalize } from '../affordance-normalizer.js';\n16: import { scoreDerivedLane } from './lanes/derived.js';\n17: import { scoreExplicitLane } from './lanes/explicit.js';\n18: import { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\n19: import { scoreLexicalLane } from './lanes/lexical.js';\n20: import { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\n21: import { applyExecutorDelegationOverride } from './executor-delegation.js';\n22: import { loadAdvisorProjection } from './projection.js';\n23: import { SCORING_CALIBRATION } from './scoring-constants.js';\n24: import { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\n25: import {\n26:   DEFAULT_SCORER_WEIGHTS,\n27:   SCORER_LANES,\n28:   liveWeightTotal,\n29: } from './weights-config.js';\n30: import { isLiveScorerLane } from './lane-registry.js';\n31: import { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\n32: import type {\n33:   AdvisorProjection,\n34:   AdvisorScoredRecommendation,\n35:   AdvisorScoringOptions,\n36:   AdvisorScoringResult,\n37:   LaneContribution,\n38:   LaneMatch,\n39:   LaneRuntimeHealth,\n40:   LaneScores,\n41:   ScorerLane,\n42:   SkillProjection,\n43: } from './types.js';\n44: import type { NormalizedAffordance } from '../affordance-normalizer.js';\n45: import type { RankedList, RrfItem } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n46: \n47: const DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\n48: const DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\n49: export const ADVISOR_RRF_FUSION_FLAG = 'SPECKIT_ADVISOR_RRF_FUSION';\n50: export const ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG = 'SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD';\n51: export const ADVISOR_QUERY_CLASS_ROUTING_FLAG = 'SPECKIT_ADVISOR_QUERY_CLASS_ROUTING';\n52: export const ADVISOR_EXACT_SEMANTIC_RERANK_FLAG = 'SPECKIT_ADVISOR_EXACT_SEMANTIC_RERANK';\n53: export const ADVISOR_RRF_K = 8;\n54: export const ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K = 10;\n55: const ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW = 0.05;\n56: const TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\n57: const DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\n58: const FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\n59: const MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n60: // Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n61: // multi-concern optimization is under-specified for single-skill routing.\n62: const BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\n63: const BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n64: // Narrow anchors that make a broad-build prompt specific enough to route.\n65: const BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\n66: const MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\n67: const CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\n68: const CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\n69: const TRUE_FLAG_VALUES = new Set(['1', 'true', 'yes', 'on', 'enabled']);\n70: const NO_RRF_RANK = Number.MAX_SAFE_INTEGER;\n71: const ADVISOR_SELF_RECOMMENDATION_SKILL_IDS = new Set(['system-skill-advisor', 'skill-advisor']);\n72: \n73: type MutableLaneScores = {\n74:   -readonly [K in keyof LaneScores]: LaneMatch[];\n75: };\n76: \n77: interface LaneScoreBundle {\n78:   readonly laneScores: LaneScores;\n79:   readonly graphConflictMatches: readonly LaneMatch[];\n80: }\n81: \n82: interface AdvisorRrfFusion {\n83:   readonly scoreBySkill: ReadonlyMap<string, number>;\n84:   readonly rankBySkill: ReadonlyMap<string, number>;\n85: }\n86: \n87: type AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\n88: type AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\n89: export type AdvisorQueryClass = 'implementation' | 'review' | 'documentation' | 'memory' | 'tooling' | 'unknown';\n90: \n91: interface ExactSemanticRerankEntry {\n92:   readonly rawScore: number;\n93: }\n94: \n95: type ExactSemanticRerankIndex = ReadonlyMap<string, ExactSemanticRerankEntry>;\n96: \n97: function emptyLaneScores(): MutableLaneScores {\n98:   return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n99: }\n100: \n101: export function isAdvisorRrfFusionEnabled(): boolean {\n102:   const value = process.env[ADVISOR_RRF_FUSION_FLAG]?.trim().toLowerCase();\n103:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n104: }\n105: \n106: export function isAdvisorSelfRecommendationGuardEnabled(): boolean {\n107:   const value = process.env[ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG]?.trim().toLowerCase();\n108:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n109: }\n110: \n111: export function isAdvisorQueryClassRoutingEnabled(): boolean {\n112:   const value = process.env[ADVISOR_QUERY_CLASS_ROUTING_FLAG]?.trim().toLowerCase();\n113:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n114: }\n115: \n116: export function isAdvisorExactSemanticRerankEnabled(): boolean {\n117:   const value = process.env[ADVISOR_EXACT_SEMANTIC_RERANK_FLAG]?.trim().toLowerCase();\n118:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n119: }\n120: \n121: export function classifyAdvisorQuery(prompt: string): AdvisorQueryClass {\n122:   const promptLower = prompt.toLowerCase();\n123:   if (/\\b(save context|save memory|handover|resume|checkpoint|spec folder|implementation summary|packet docs?)\\b/.test(promptLower)) {\n124:     return 'memory';\n125:   }\n126:   if (/\\b(review|audit|findings|regression|pull request|pr readiness|release readiness)\\b/.test(promptLower)) {\n127:     return 'review';\n128:   }\n129:   if (/\\b(readme|markdown|documentation|docs|manual testing playbook|feature catalog|taxonomy)\\b/.test(promptLower)) {\n130:     return 'documentation';\n131:   }\n132:   if (/\\b(call_tool_chain|code mode|tool ?chain|chrome devtools|browser console|figma|github|clickup)\\b/.test(promptLower)) {\n133:     return 'tooling';\n134:   }\n135:   if (TASK_INTENT.test(promptLower) || /\\b(typescript|javascript|python|vitest|mcp|handler|schema|fixture)\\b/.test(promptLower)) {\n136:     return 'implementation';\n137:   }\n138:   return 'unknown';\n139: }\n140: \n141: export function queryClassLaneMultipliers(queryClass: AdvisorQueryClass): Readonly<Partial<Record<ScorerLane, number>>> {\n142:   switch (queryClass) {\n143:     case 'implementation':\n144:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.98, semantic_shadow: 1.00 };\n145:     case 'review':\n146:       return { explicit_author: 1.03, lexical: 1.02, graph_causal: 0.96, derived_generated: 0.98, semantic_shadow: 1.00 };\n147:     case 'documentation':\n148:       return { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n149:     case 'memory':\n150:       return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n151:     case 'tooling':\n152:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n153:     case 'unknown':\n154:       return {};\n155:   }\n156: }\n157: \n158: export function applyQueryClassLaneMultipliers(\n159:   weights: Readonly<Record<ScorerLane, number>>,\n160:   queryClass: AdvisorQueryClass,\n161: ): Readonly<Record<ScorerLane, number>> {\n162:   const multipliers = queryClassLaneMultipliers(queryClass);\n163:   if (Object.keys(multipliers).length === 0) return weights;\n164:   const next = { ...weights };\n165:   for (const lane of SCORER_LANES) {\n166:     const multiplier = multipliers[lane];\n167:     if (typeof multiplier === 'number' && Number.isFinite(multiplier)) {\n168:       next[lane] = Number((next[lane] * multiplier).toFixed(6));\n169:     }\n170:   }\n171:   const strongestOther = Math.max(...SCORER_LANES\n172:     .filter((lane) => lane !== 'explicit_author')\n173:     .map((lane) => next[lane]));\n174:   if (next.explicit_author < strongestOther) {\n175:     next.explicit_author = Number(strongestOther.toFixed(6));\n176:   }\n177:   return next;\n178: }\n179: \n180: function effectiveScorerWeights(\n181:   override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n182:   queryClass: AdvisorQueryClass = 'unknown',\n183: ): Readonly<Record<ScorerLane, number>> {\n184:   const base = !override ? DEFAULT_SCORER_WEIGHTS : (() => {\n185:     const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n186:     const runtimeOverride = override as Partial<Record<string, number>>;\n187:     for (const lane of SCORER_LANES) {\n188:       const value = runtimeOverride[lane];\n189:       if (typeof value === 'number' && Number.isFinite(value)) {\n190:         weights[lane] = value;\n191:       }\n192:     }\n193:     return weights;\n194:   })();\n195:   if (queryClass === 'unknown') return base;\n196:   return applyQueryClassLaneMultipliers(base, queryClass);\n197: }\n198: \n199: function normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n200:   if (value === undefined) {\n201:     return null;\n202:   }\n203:   return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n204: }\n205: \n206: function normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n207:   if (value === undefined) {\n208:     return 'unavailable';\n209:   }\n210:   return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n211: }\n212: \n213: interface LaneMatchIndexEntry {\n214:   rawScore: number;\n215:   evidence: string[];\n216:   producerSkillIds: string[];\n217: }\n218: \n219: type LaneMatchIndex = Map<string, LaneMatchIndexEntry>;\n220: \n221: function buildLaneRuntimeHealth(\n222:   laneScores: LaneScores,\n223:   disabled: ReadonlySet<ScorerLane>,\n224:   runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n225: ): readonly LaneRuntimeHealth[] {\n226:   return SCORER_LANES.map((lane): LaneRuntimeHealth => {\n227:     const matchCount = laneScores[lane].length;\n228:     const signal = runtimeLaneHealth?.[lane];\n229:     if (!disabled.has(lane) && signal?.status === 'runtime_degraded' && matchCount === 0) {\n230:       return {\n231:         lane,\n232:         status: 'runtime_degraded',\n233:         matchCount,\n234:         ...(signal.reason ? { reason: signal.reason } : {}),\n235:       };\n236:     }\n237:     return {\n238:       lane,\n239:       status: matchCount > 0 ? 'healthy' : 'matched_nothing',\n240:       matchCount,\n241:       ...(signal?.reason && signal.status === 'healthy' ? { reason: signal.reason } : {}),\n242:     };\n243:   });\n244: }\n245: \n246: function projectionRuntimeLaneHealth(\n247:   projection: AdvisorProjection,\n248:   runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n249: ): AdvisorScoringOptions['runtimeLaneHealth'] | undefined {\n250:   if (!projection.embeddingStaleness?.stale) {\n251:     return runtimeLaneHealth;\n252:   }\n253:   return {\n254:     ...runtimeLaneHealth,\n255:     semantic_shadow: runtimeLaneHealth?.semantic_shadow ?? {\n256:       status: 'runtime_degraded',\n257:       reason: projection.embeddingStaleness.reason ?? 'projection_embedding_stale',\n258:     },\n259:   };\n260: }\n261: \n262: function degradedLaneReason(degradedLanes: readonly ScorerLane[]): string | null {\n263:   if (degradedLanes.length === 0) return null;\n264:   return `Runtime-degraded scorer lanes omitted from confidence normalization: ${degradedLanes.join(', ')}.`;\n265: }\n266: \n267: function buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n268:   const index: LaneMatchIndex = new Map();\n269:   for (const match of matches) {\n270:     const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [], producerSkillIds: [] };\n271:     existing.rawScore = Math.max(existing.rawScore, match.score);\n272:     if (existing.evidence.length < 6) {\n273:       existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n274:     }\n275:     for (const producerSkillId of match.producerSkillIds ?? []) {\n276:       if (!existing.producerSkillIds.includes(producerSkillId)) {\n277:         existing.producerSkillIds.push(producerSkillId);\n278:       }\n279:     }\n280:     index.set(match.skillId, existing);\n281:   }\n282:   return index;\n283: }\n284: \n285: function buildConflictMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n286:   const index: LaneMatchIndex = new Map();\n287:   for (const match of matches) {\n288:     const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [], producerSkillIds: [] };\n289:     existing.rawScore = Math.min(existing.rawScore, match.score);\n290:     if (existing.evidence.length < 6) {\n291:       existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n292:     }\n293:     index.set(match.skillId, existing);\n294:   }\n295:   return index;\n296: }\n297: \n298: function rankedRrfItems(matches: readonly LaneMatch[]): RrfItem[] {\n299:   return [...matches]\n300:     .filter((match) => match.score > 0)\n301:     .sort((left, right) => right.score - left.score || left.skillId.localeCompare(right.skillId))\n302:     .map((match) => ({ id: match.skillId }));\n303: }\n304: \n305: export function fuseAdvisorLaneRanks(\n306:   laneScores: LaneScores,\n307:   weights: Readonly<Record<ScorerLane, number>>,\n308:   disabled: ReadonlySet<ScorerLane> = new Set(),\n309:   runtimeDegraded: ReadonlySet<ScorerLane> = new Set(),\n310: ): AdvisorRrfFusion {\n311:   const lists: RankedList[] = SCORER_LANES.map((lane) => ({\n312:     source: lane,\n313:     results: rankedRrfItems(laneScores[lane]),\n314:     weight: disabled.has(lane) || runtimeDegraded.has(lane) || !isLiveScorerLane(lane)\n315:       ? 0\n316:       : weights[lane],\n317:   }));\n318:   const fused = fuseResultsMulti(lists, {\n319:     k: ADVISOR_RRF_K,\n320:     convergenceBonus: 0,\n321:     calibratedOverlapBeta: 0,\n322:     bonusOverChannels: 'configured',\n323:   });\n324:   const scoreBySkill = new Map<string, number>();\n325:   const rankBySkill = new Map<string, number>();\n326:   fused.forEach((result, index) => {\n327:     const skillId = String(result.id);\n328:     scoreBySkill.set(skillId, result.rrfScore);\n329:     rankBySkill.set(skillId, index);\n330:   });\n331:   return { scoreBySkill, rankBySkill };\n332: }\n333: \n334: function graphConflictAdjustment(\n335:   conflictIndex: LaneMatchIndex,\n336:   recommendation: AdvisorScoredRecommendation,\n337: ): number {\n338:   return conflictIndex.get(recommendation.skill)?.rawScore ?? 0;\n339: }\n340: \n341: function buildExactSemanticRerankIndex(\n342:   prompt: string,\n343:   projection: AdvisorProjection,\n344:   recommendations: readonly AdvisorScoredRecommendation[],\n345:   fusion: AdvisorRrfFusion | null,\n346: ): ExactSemanticRerankIndex {\n347:   if (!fusion) return new Map();\n348:   const topSkillIds = [...recommendations]\n349:     .filter((recommendation) => fusion.rankBySkill.has(recommendation.skill))\n350:     .sort((left, right) => rrfRankFor(fusion, left) - rrfRankFor(fusion, right))\n351:     .slice(0, ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K)\n352:     .map((recommendation) => recommendation.skill);\n353:   const matches = scoreSemanticShadowExactSubset(prompt, projection, topSkillIds);\n354:   return new Map(matches.map((match) => [match.skillId, {\n355:     rawScore: match.score,\n356:   }]));\n357: }\n358: \n359: function exactSemanticRerankScore(\n360:   rerankIndex: ExactSemanticRerankIndex,\n361:   recommendation: AdvisorScoredRecommendation,\n362: ): number | null {\n363:   return rerankIndex.get(recommendation.skill)?.rawScore ?? null;\n364: }\n365: \n366: function rrfRankFor(\n367:   fusion: AdvisorRrfFusion | null,\n368:   recommendation: AdvisorScoredRecommendation,\n369: ): number {\n370:   return fusion?.rankBySkill.get(recommendation.skill) ?? NO_RRF_RANK;\n371: }\n372: \n373: function promptMentionsSkill(promptLower: string, skill: SkillProjection): boolean {\n374:   return [skill.id, skill.name, skill.id.replace(/-/g, ' ')].some((phrase) => matchesPhraseBoundary(promptLower, phrase.toLowerCase()));\n375: }\n376: \n377: function isDefaultRoutable(promptLower: string, skill: SkillProjection): boolean {\n378:   if (skill.lifecycleStatus === 'archived' || skill.lifecycleStatus === 'future') return false;\n379:   if (skill.lifecycleStatus === 'deprecated') return promptMentionsSkill(promptLower, skill);\n380:   return true;\n381: }\n382: \n383: function isAdvisorSelfRecommendationSkill(skillId: string): boolean {\n384:   return ADVISOR_SELF_RECOMMENDATION_SKILL_IDS.has(skillId);\n385: }\n386: \n387: function hasAdvisorSelfAuthoredSignal(skillId: string, explicitMatch: LaneMatchIndexEntry | undefined): boolean {\n388:   return isAdvisorSelfRecommendationSkill(skillId)\n389:     && explicitMatch?.producerSkillIds.some((producerSkillId) => producerSkillId === skillId) === true;\n390: }\n391: \n392: function shouldApplyAdvisorSelfRecommendationGuard(args: {\n393:   readonly skillId: string;\n394:   readonly guardEnabled: boolean;\n395:   readonly hasSelfAuthoredSignal?: boolean;\n396: }): boolean {\n397:   return args.guardEnabled\n398:     && isAdvisorSelfRecommendationSkill(args.skillId)\n399:     && (args.hasSelfAuthoredSignal ?? true);\n400: }\n401: \n402: function confidenceFor(args: {\n403:   liveNormalized: number;\n404:   directScore: number;\n405:   readOnlyExplainer: boolean;\n406:   hasExplicitWorkflowSignal: boolean;\n407:   hasTaskIntent: boolean;\n408:   readOnlyRouteAllowed: boolean;\n409:   derivedDominant: boolean;\n410:   skillId: string;\n411:   selfRecommendationGuardEnabled: boolean;\n412:   hasAdvisorSelfAuthoredSignal: boolean;\n413: }): number {\n414:   const C = SCORING_CALIBRATION.confidence;\n415:   if (!args.selfRecommendationGuardEnabled && args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n416:   if (args.readOnlyExplainer && shouldApplyAdvisorSelfRecommendationGuard({\n417:     skillId: args.skillId,\n418:     guardEnabled: args.selfRecommendationGuardEnabled,\n419:     hasSelfAuthoredSignal: args.hasAdvisorSelfAuthoredSignal,\n420:   })) {\n421:     return C.readOnlyExplainerFloor;\n422:   }\n423:   const base = C.baseConstant\n424:     + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;\n425:   if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;\n426:   if (args.readOnlyRouteAllowed) {\n427:     return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));\n428:   }\n429:   if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {\n430:     return C.derivedDominantConfidence;\n431:   }\n432:   if (args.hasTaskIntent\n433:     && (args.directScore >= C.taskIntentDirectScoreFloor\n434:       || args.liveNormalized >= C.taskIntentLiveNormalizedFloor)) {\n435:     // Token-stuffing dispersion guard. Without this, a prompt\n436:     // with task-intent + many weak signals (saturating liveNormalized) but\n437:     // no strong direct anchor would force confidence to taskIntentFloor for\n438:     // many unrelated skills. The guard fires when liveNormalized is near-\n439:     // saturated AND directScore is below the directScoreLiftThreshold —\n440:     // the precise signature of a token-stuffed prompt. Legitimate task-intent\n441:     // prompts have at least one strong direct hit and pass via directScore;\n442:     // they don't hit this branch. When the guard fires we fall through to\n443:     // the standard `base + directBonus` math below.\n444:     const dispersionGuardTripped = args.liveNormalized >= 0.95\n445:       && args.directScore < C.directScoreLiftThreshold;\n446:     if (!dispersionGuardTripped) {\n447:       return Number(Math.max(base, C.taskIntentFloor).toFixed(4));\n448:     }\n449:   }\n450:   if (args.directScore >= C.directScoreLiftThreshold) {\n451:     return Number(Math.max(base, C.directScoreFloor).toFixed(4));\n452:   }\n453:   const directBonus = args.directScore >= C.directScoreBonusThreshold ? C.directScoreBonus : 0;\n454:   return Number(Math.max(0, Math.min(C.hardCeiling, base + directBonus)).toFixed(4));\n455: }\n456: \n457: function uncertaintyFor(contributions: readonly LaneContribution[], confidence: number, ambiguousPressure: number): number {\n458:   const U = SCORING_CALIBRATION.uncertainty;\n459:   const evidenceCount = contributions.reduce((total, contribution) => total + contribution.evidence.length, 0);\n460:   const direct = contributions\n461:     .filter((contribution) => contribution.lane === 'explicit_author' || contribution.lane === 'lexical')\n462:     .reduce((max, contribution) => Math.max(max, contribution.rawScore), 0);\n463:   let uncertainty = U.noEvidenceDefault;\n464:   if (evidenceCount >= U.highEvidenceCount) uncertainty = U.lowFloor;\n465:   else if (evidenceCount >= U.mediumEvidenceCount) uncertainty = U.mediumFloor;\n466:   else if (evidenceCount >= U.someEvidenceCount) uncertainty = U.elevatedFloor;\n467:   if (direct >= U.directEvidenceDiscountThreshold) uncertainty -= U.directEvidenceDiscount;\n468:   if (confidence < U.lowConfidencePenaltyThreshold) uncertainty += U.lowConfidencePenalty;\n469:   uncertainty += ambiguousPressure;\n470:   return Number(Math.max(U.hardFloor, Math.min(U.hardCeiling, uncertainty)).toFixed(2));\n471: }\n472: \n473: function buildLaneScores(\n474:   prompt: string,\n475:   projection: AdvisorProjection,\n476:   disabled: Set<ScorerLane>,\n477:   affordances: readonly NormalizedAffordance[],\n478:   useRrfFusion: boolean,\n479:   includeProducerIdentity: boolean,\n480: ): LaneScoreBundle {\n481:   const scores = emptyLaneScores();\n482:   if (!disabled.has('explicit_author')) {\n483:     scores.explicit_author = scoreExplicitLane(prompt, projection, { includeProducerIdentity });\n484:   }\n485:   if (!disabled.has('lexical')) scores.lexical = scoreLexicalLane(prompt, projection);\n486:   if (!disabled.has('derived_generated')) scores.derived_generated = scoreDerivedLane(prompt, projection, new Date(), affordances);\n487:   if (!disabled.has('semantic_shadow')) scores.semantic_shadow = scoreSemanticShadowLane(prompt, projection);\n488:   let graphConflictMatches: readonly LaneMatch[] = [];\n489:   if (!disabled.has('graph_causal')) {\n490:     const graphSplit = scoreGraphCausalLaneSplit([\n491:       ...scores.explicit_author,\n492:       ...scores.lexical,\n493:       ...scores.derived_generated,\n494:     ], projection, {}, affordances);\n495:     scores.graph_causal = useRrfFusion ? graphSplit.positiveMatches : graphSplit.combinedMatches;\n496:     graphConflictMatches = graphSplit.conflictMatches;\n497:   }\n498:   return { laneScores: scores, graphConflictMatches };\n499: }\n500: \n501: function hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n502:   const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n503:   if (!explicit || explicit.rawScore < 0.55) return false;\n504:   return explicit.evidence.some((entry) => (\n505:     entry.startsWith('phrase:')\n506:     || entry.startsWith('explicit:')\n507:     || entry.startsWith('author:')\n508:     || entry.includes(skillId)\n509:     || entry.includes('loop')\n510:     || entry.includes('write-')\n511:   ));\n512: }\n513: \n514: function readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n515:   if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n516:     return false;\n517:   }\n518:   if (skillId === 'sk-code' && /\\b(compare|audit|review)\\b/.test(promptLower)\n519:     && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n520:     return true;\n\n(Showing lines 1-520 of 911. Use offset=521 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\nimport { applyExecutorDelegationOverride } from './executor-delegation.js';\nimport { loadAdvisorProjection } from './projection.js';\nimport { SCORING_CALIBRATION } from './scoring-constants.js';\nimport { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\nimport {\n  DEFAULT_SCORER_WEIGHTS,\n  SCORER_LANES,\n  liveWeightTotal,\n} from './weights-config.js';\nimport { isLiveScorerLane } from './lane-registry.js';\nimport { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\nimport type {\n  AdvisorProjection,\n  AdvisorScoredRecommendation,\n  AdvisorScoringOptions,\n  AdvisorScoringResult,\n  LaneContribution,\n  LaneMatch,\n  LaneRuntimeHealth,\n  LaneScores,\n  ScorerLane,\n  SkillProjection,\n} from './types.js';\nimport type { NormalizedAffordance } from '../affordance-normalizer.js';\nimport type { RankedList, RrfItem } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nconst DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\nconst DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\nexport const ADVISOR_RRF_FUSION_FLAG = 'SPECKIT_ADVISOR_RRF_FUSION';\nexport const ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG = 'SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD';\nexport const ADVISOR_QUERY_CLASS_ROUTING_FLAG = 'SPECKIT_ADVISOR_QUERY_CLASS_ROUTING';\nexport const ADVISOR_EXACT_SEMANTIC_RERANK_FLAG = 'SPECKIT_ADVISOR_EXACT_SEMANTIC_RERANK';\nexport const ADVISOR_RRF_K = 8;\nexport const ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K = 10;\nconst ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW = 0.05;\nconst TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\nconst DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\nconst FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\nconst MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n// Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n// multi-concern optimization is under-specified for single-skill routing.\nconst BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\nconst BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n// Narrow anchors that make a broad-build prompt specific enough to route.\nconst BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\nconst MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\nconst CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\nconst CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\nconst TRUE_FLAG_VALUES = new Set(['1', 'true', 'yes', 'on', 'enabled']);\nconst NO_RRF_RANK = Number.MAX_SAFE_INTEGER;\nconst ADVISOR_SELF_RECOMMENDATION_SKILL_IDS = new Set(['system-skill-advisor', 'skill-advisor']);\n\ntype MutableLaneScores = {\n  -readonly [K in keyof LaneScores]: LaneMatch[];\n};\n\ninterface LaneScoreBundle {\n  readonly laneScores: LaneScores;\n  readonly graphConflictMatches: readonly LaneMatch[];\n}\n\ninterface AdvisorRrfFusion {\n  readonly scoreBySkill: ReadonlyMap<string, number>;\n  readonly rankBySkill: ReadonlyMap<string, number>;\n}\n\ntype AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\ntype AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\nexport type AdvisorQueryClass = 'implementation' | 'review' | 'documentation' | 'memory' | 'tooling' | 'unknown';\n\ninterface ExactSemanticRerankEntry {\n  readonly rawScore: number;\n}\n\ntype ExactSemanticRerankIndex = ReadonlyMap<string, ExactSemanticRerankEntry>;\n\nfunction emptyLaneScores(): MutableLaneScores {\n  return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n}\n\nexport function isAdvisorRrfFusionEnabled(): boolean {\n  const value = process.env[ADVISOR_RRF_FUSION_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorSelfRecommendationGuardEnabled(): boolean {\n  const value = process.env[ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorQueryClassRoutingEnabled(): boolean {\n  const value = process.env[ADVISOR_QUERY_CLASS_ROUTING_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorExactSemanticRerankEnabled(): boolean {\n  const value = process.env[ADVISOR_EXACT_SEMANTIC_RERANK_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function classifyAdvisorQuery(prompt: string): AdvisorQueryClass {\n  const promptLower = prompt.toLowerCase();\n  if (/\\b(save context|save memory|handover|resume|checkpoint|spec folder|implementation summary|packet docs?)\\b/.test(promptLower)) {\n    return 'memory';\n  }\n  if (/\\b(review|audit|findings|regression|pull request|pr readiness|release readiness)\\b/.test(promptLower)) {\n    return 'review';\n  }\n  if (/\\b(readme|markdown|documentation|docs|manual testing playbook|feature catalog|taxonomy)\\b/.test(promptLower)) {\n    return 'documentation';\n  }\n  if (/\\b(call_tool_chain|code mode|tool ?chain|chrome devtools|browser console|figma|github|clickup)\\b/.test(promptLower)) {\n    return 'tooling';\n  }\n  if (TASK_INTENT.test(promptLower) || /\\b(typescript|javascript|python|vitest|mcp|handler|schema|fixture)\\b/.test(promptLower)) {\n    return 'implementation';\n  }\n  return 'unknown';\n}\n\nexport function queryClassLaneMultipliers(queryClass: AdvisorQueryClass): Readonly<Partial<Record<ScorerLane, number>>> {\n  switch (queryClass) {\n    case 'implementation':\n      return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.98, semantic_shadow: 1.00 };\n    case 'review':\n      return { explicit_author: 1.03, lexical: 1.02, graph_causal: 0.96, derived_generated: 0.98, semantic_shadow: 1.00 };\n    case 'documentation':\n      return { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n    case 'memory':\n      return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n    case 'tooling':\n      return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n    case 'unknown':\n      return {};\n  }\n}\n\nexport function applyQueryClassLaneMultipliers(\n  weights: Readonly<Record<ScorerLane, number>>,\n  queryClass: AdvisorQueryClass,\n): Readonly<Record<ScorerLane, number>> {\n  const multipliers = queryClassLaneMultipliers(queryClass);\n  if (Object.keys(multipliers).length === 0) return weights;\n  const next = { ...weights };\n  for (const lane of SCORER_LANES) {\n    const multiplier = multipliers[lane];\n    if (typeof multiplier === 'number' && Number.isFinite(multiplier)) {\n      next[lane] = Number((next[lane] * multiplier).toFixed(6));\n    }\n  }\n  const strongestOther = Math.max(...SCORER_LANES\n    .filter((lane) => lane !== 'explicit_author')\n    .map((lane) => next[lane]));\n  if (next.explicit_author < strongestOther) {\n    next.explicit_author = Number(strongestOther.toFixed(6));\n  }\n  return next;\n}\n\nfunction effectiveScorerWeights(\n  override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n  queryClass: AdvisorQueryClass = 'unknown',\n): Readonly<Record<ScorerLane, number>> {\n  const base = !override ? DEFAULT_SCORER_WEIGHTS : (() => {\n    const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n    const runtimeOverride = override as Partial<Record<string, number>>;\n    for (const lane of SCORER_LANES) {\n      const value = runtimeOverride[lane];\n      if (typeof value === 'number' && Number.isFinite(value)) {\n        weights[lane] = value;\n      }\n    }\n    return weights;\n  })();\n  if (queryClass === 'unknown') return base;\n  return applyQueryClassLaneMultipliers(base, queryClass);\n}\n\nfunction normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n  if (value === undefined) {\n    return null;\n  }\n  return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n}\n\nfunction normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n  if (value === undefined) {\n    return 'unavailable';\n  }\n  return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n}\n\ninterface LaneMatchIndexEntry {\n  rawScore: number;\n  evidence: string[];\n  producerSkillIds: string[];\n}\n\ntype LaneMatchIndex = Map<string, LaneMatchIndexEntry>;\n\nfunction buildLaneRuntimeHealth(\n  laneScores: LaneScores,\n  disabled: ReadonlySet<ScorerLane>,\n  runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n): readonly LaneRuntimeHealth[] {\n  return SCORER_LANES.map((lane): LaneRuntimeHealth => {\n    const matchCount = laneScores[lane].length;\n    const signal = runtimeLaneHealth?.[lane];\n    if (!disabled.has(lane) && signal?.status === 'runtime_degraded' && matchCount === 0) {\n      return {\n        lane,\n        status: 'runtime_degraded',\n        matchCount,\n        ...(signal.reason ? { reason: signal.reason } : {}),\n      };\n    }\n    return {\n      lane,\n      status: matchCount > 0 ? 'healthy' : 'matched_nothing',\n      matchCount,\n      ...(signal?.reason && signal.status === 'healthy' ? { reason: signal.reason } : {}),\n    };\n  });\n}\n\nfunction projectionRuntimeLaneHealth(\n  projection: AdvisorProjection,\n  runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n): AdvisorScoringOptions['runtimeLaneHealth'] | undefined {\n  if (!projection.embeddingStaleness?.stale) {\n    return runtimeLaneHealth;\n  }\n  return {\n    ...runtimeLaneHealth,\n    semantic_shadow: runtimeLaneHealth?.semantic_shadow ?? {\n      status: 'runtime_degraded',\n      reason: projection.embeddingStaleness.reason ?? 'projection_embedding_stale',\n    },\n  };\n}\n\nfunction degradedLaneReason(degradedLanes: readonly ScorerLane[]): string | null {\n  if (degradedLanes.length === 0) return null;\n  return `Runtime-degraded scorer lanes omitted from confidence normalization: ${degradedLanes.join(', ')}.`;\n}\n\nfunction buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n  const index: LaneMatchIndex = new Map();\n  for (const match of matches) {\n    const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [], producerSkillIds: [] };\n    existing.rawScore = Math.max(existing.rawScore, match.score);\n    if (existing.evidence.length < 6) {\n      existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n    }\n    for (const producerSkillId of match.producerSkillIds ?? []) {\n      if (!existing.producerSkillIds.includes(producerSkillId)) {\n        existing.producerSkillIds.push(producerSkillId);\n      }\n    }\n    index.set(match.skillId, existing);\n  }\n  return index;\n}\n\nfunction buildConflictMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n  const index: LaneMatchIndex = new Map();\n  for (const match of matches) {\n    const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [], producerSkillIds: [] };\n    existing.rawScore = Math.min(existing.rawScore, match.score);\n    if (existing.evidence.length < 6) {\n      existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n    }\n    index.set(match.skillId, existing);\n  }\n  return index;\n}\n\nfunction rankedRrfItems(matches: readonly LaneMatch[]): RrfItem[] {\n  return [...matches]\n    .filter((match) => match.score > 0)\n    .sort((left, right) => right.score - left.score || left.skillId.localeCompare(right.skillId))\n    .map((match) => ({ id: match.skillId }));\n}\n\nexport function fuseAdvisorLaneRanks(\n  laneScores: LaneScores,\n  weights: Readonly<Record<ScorerLane, number>>,\n  disabled: ReadonlySet<ScorerLane> = new Set(),\n  runtimeDegraded: ReadonlySet<ScorerLane> = new Set(),\n): AdvisorRrfFusion {\n  const lists: RankedList[] = SCORER_LANES.map((lane) => ({\n    source: lane,\n    results: rankedRrfItems(laneScores[lane]),\n    weight: disabled.has(lane) || runtimeDegraded.has(lane) || !isLiveScorerLane(lane)\n      ? 0\n      : weights[lane],\n  }));\n  const fused = fuseResultsMulti(lists, {\n    k: ADVISOR_RRF_K,\n    convergenceBonus: 0,\n    calibratedOverlapBeta: 0,\n    bonusOverChannels: 'configured',\n  });\n  const scoreBySkill = new Map<string, number>();\n  const rankBySkill = new Map<string, number>();\n  fused.forEach((result, index) => {\n    const skillId = String(result.id);\n    scoreBySkill.set(skillId, result.rrfScore);\n    rankBySkill.set(skillId, index);\n  });\n  return { scoreBySkill, rankBySkill };\n}\n\nfunction graphConflictAdjustment(\n  conflictIndex: LaneMatchIndex,\n  recommendation: AdvisorScoredRecommendation,\n): number {\n  return conflictIndex.get(recommendation.skill)?.rawScore ?? 0;\n}\n\nfunction buildExactSemanticRerankIndex(\n  prompt: string,\n  projection: AdvisorProjection,\n  recommendations: readonly AdvisorScoredRecommendation[],\n  fusion: AdvisorRrfFusion | null,\n): ExactSemanticRerankIndex {\n  if (!fusion) return new Map();\n  const topSkillIds = [...recommendations]\n    .filter((recommendation) => fusion.rankBySkill.has(recommendation.skill))\n    .sort((left, right) => rrfRankFor(fusion, left) - rrfRankFor(fusion, right))\n    .slice(0, ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K)\n    .map((recommendation) => recommendation.skill);\n  const matches = scoreSemanticShadowExactSubset(prompt, projection, topSkillIds);\n  return new Map(matches.map((match) => [match.skillId, {\n    rawScore: match.score,\n  }]));\n}\n\nfunction exactSemanticRerankScore(\n  rerankIndex: ExactSemanticRerankIndex,\n  recommendation: AdvisorScoredRecommendation,\n): number | null {\n  return rerankIndex.get(recommendation.skill)?.rawScore ?? null;\n}\n\nfunction rrfRankFor(\n  fusion: AdvisorRrfFusion | null,\n  recommendation: AdvisorScoredRecommendation,\n): number {\n  return fusion?.rankBySkill.get(recommendation.skill) ?? NO_RRF_RANK;\n}\n\nfunction promptMentionsSkill(promptLower: string, skill: SkillProjection): boolean {\n  return [skill.id, skill.name, skill.id.replace(/-/g, ' ')].some((phrase) => matchesPhraseBoundary(promptLower, phrase.toLowerCase()));\n}\n\nfunction isDefaultRoutable(promptLower: string, skill: SkillProjection): boolean {\n  if (skill.lifecycleStatus === 'archived' || skill.lifecycleStatus === 'future') return false;\n  if (skill.lifecycleStatus === 'deprecated') return promptMentionsSkill(promptLower, skill);\n  return true;\n}\n\nfunction isAdvisorSelfRecommendationSkill(skillId: string): boolean {\n  return ADVISOR_SELF_RECOMMENDATION_SKILL_IDS.has(skillId);\n}\n\nfunction hasAdvisorSelfAuthoredSignal(skillId: string, explicitMatch: LaneMatchIndexEntry | undefined): boolean {\n  return isAdvisorSelfRecommendationSkill(skillId)\n    && explicitMatch?.producerSkillIds.some((producerSkillId) => producerSkillId === skillId) === true;\n}\n\nfunction shouldApplyAdvisorSelfRecommendationGuard(args: {\n  readonly skillId: string;\n  readonly guardEnabled: boolean;\n  readonly hasSelfAuthoredSignal?: boolean;\n}): boolean {\n  return args.guardEnabled\n    && isAdvisorSelfRecommendationSkill(args.skillId)\n    && (args.hasSelfAuthoredSignal ?? true);\n}\n\nfunction confidenceFor(args: {\n  liveNormalized: number;\n  directScore: number;\n  readOnlyExplainer: boolean;\n  hasExplicitWorkflowSignal: boolean;\n  hasTaskIntent: boolean;\n  readOnlyRouteAllowed: boolean;\n  derivedDominant: boolean;\n  skillId: string;\n  selfRecommendationGuardEnabled: boolean;\n  hasAdvisorSelfAuthoredSignal: boolean;\n}): number {\n  const C = SCORING_CALIBRATION.confidence;\n  if (!args.selfRecommendationGuardEnabled && args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n  if (args.readOnlyExplainer && shouldApplyAdvisorSelfRecommendationGuard({\n    skillId: args.skillId,\n    guardEnabled: args.selfRecommendationGuardEnabled,\n    hasSelfAuthoredSignal: args.hasAdvisorSelfAuthoredSignal,\n  })) {\n    return C.readOnlyExplainerFloor;\n  }\n  const base = C.baseConstant\n    + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;\n  if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;\n  if (args.readOnlyRouteAllowed) {\n    return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));\n  }\n  if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {\n    return C.derivedDominantConfidence;\n  }\n  if (args.hasTaskIntent\n    && (args.directScore >= C.taskIntentDirectScoreFloor\n      || args.liveNormalized >= C.taskIntentLiveNormalizedFloor)) {\n    // Token-stuffing dispersion guard. Without this, a prompt\n    // with task-intent + many weak signals (saturating liveNormalized) but\n    // no strong direct anchor would force confidence to taskIntentFloor for\n    // many unrelated skills. The guard fires when liveNormalized is near-\n    // saturated AND directScore is below the directScoreLiftThreshold —\n    // the precise signature of a token-stuffed prompt. Legitimate task-intent\n    // prompts have at least one strong direct hit and pass via directScore;\n    // they don't hit this branch. When the guard fires we fall through to\n    // the standard `base + directBonus` math below.\n    const dispersionGuardTripped = args.liveNormalized >= 0.95\n      && args.directScore < C.directScoreLiftThreshold;\n    if (!dispersionGuardTripped) {\n      return Number(Math.max(base, C.taskIntentFloor).toFixed(4));\n    }\n  }\n  if (args.directScore >= C.directScoreLiftThreshold) {\n    return Number(Math.max(base, C.directScoreFloor).toFixed(4));\n  }\n  const directBonus = args.directScore >= C.directScoreBonusThreshold ? C.directScoreBonus : 0;\n  return Number(Math.max(0, Math.min(C.hardCeiling, base + directBonus)).toFixed(4));\n}\n\nfunction uncertaintyFor(contributions: readonly LaneContribution[], confidence: number, ambiguousPressure: number): number {\n  const U = SCORING_CALIBRATION.uncertainty;\n  const evidenceCount = contributions.reduce((total, contribution) => total + contribution.evidence.length, 0);\n  const direct = contributions\n    .filter((contribution) => contribution.lane === 'explicit_author' || contribution.lane === 'lexical')\n    .reduce((max, contribution) => Math.max(max, contribution.rawScore), 0);\n  let uncertainty = U.noEvidenceDefault;\n  if (evidenceCount >= U.highEvidenceCount) uncertainty = U.lowFloor;\n  else if (evidenceCount >= U.mediumEvidenceCount) uncertainty = U.mediumFloor;\n  else if (evidenceCount >= U.someEvidenceCount) uncertainty = U.elevatedFloor;\n  if (direct >= U.directEvidenceDiscountThreshold) uncertainty -= U.directEvidenceDiscount;\n  if (confidence < U.lowConfidencePenaltyThreshold) uncertainty += U.lowConfidencePenalty;\n  uncertainty += ambiguousPressure;\n  return Number(Math.max(U.hardFloor, Math.min(U.hardCeiling, uncertainty)).toFixed(2));\n}\n\nfunction buildLaneScores(\n  prompt: string,\n  projection: AdvisorProjection,\n  disabled: Set<ScorerLane>,\n  affordances: readonly NormalizedAffordance[],\n  useRrfFusion: boolean,\n  includeProducerIdentity: boolean,\n): LaneScoreBundle {\n  const scores = emptyLaneScores();\n  if (!disabled.has('explicit_author')) {\n    scores.explicit_author = scoreExplicitLane(prompt, projection, { includeProducerIdentity });\n  }\n  if (!disabled.has('lexical')) scores.lexical = scoreLexicalLane(prompt, projection);\n  if (!disabled.has('derived_generated')) scores.derived_generated = scoreDerivedLane(prompt, projection, new Date(), affordances);\n  if (!disabled.has('semantic_shadow')) scores.semantic_shadow = scoreSemanticShadowLane(prompt, projection);\n  let graphConflictMatches: readonly LaneMatch[] = [];\n  if (!disabled.has('graph_causal')) {\n    const graphSplit = scoreGraphCausalLaneSplit([\n      ...scores.explicit_author,\n      ...scores.lexical,\n      ...scores.derived_generated,\n    ], projection, {}, affordances);\n    scores.graph_causal = useRrfFusion ? graphSplit.positiveMatches : graphSplit.combinedMatches;\n    graphConflictMatches = graphSplit.conflictMatches;\n  }\n  return { laneScores: scores, graphConflictMatches };\n}\n\nfunction hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n  const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n  if (!explicit || explicit.rawScore < 0.55) return false;\n  return explicit.evidence.some((entry) => (\n    entry.startsWith('phrase:')\n    || entry.startsWith('explicit:')\n    || entry.startsWith('author:')\n    || entry.includes(skillId)\n    || entry.includes('loop')\n    || entry.includes('write-')\n  ));\n}\n\nfunction readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n  if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n    return false;\n  }\n  if (skillId === 'sk-code' && /\\b(compare|audit|review)\\b/.test(promptLower)\n    && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    return true;","lineStart":1,"lineEnd":520,"totalLines":911,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437201968,"end":1783437201972}},"metadata":{"openai":{"itemId":"fc_002f97d8e79f1a0a016a4d1791cddc819195f6769d54277e1f"}},"id":"prt_f3d241225001u3iKqucWUqCGec","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ"}}
{"type":"tool_use","timestamp":1783437201987,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_PZMAbjDQfXwNqqsZGdTZjV4S","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","offset":1,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Skill Projection\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { existsSync, readFileSync, readdirSync } from 'node:fs';\n6: import { dirname, isAbsolute, join, resolve } from 'node:path';\n7: \n8: import Database from 'better-sqlite3';\n9: \n10: import { getManifest } from '../embedders/registry.js';\n11: import type { BackendKind } from '../embedders/types.js';\n12: import { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\n13: import { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\n14: import { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\n15: import { providerModelId } from '../skill-graph/skill-graph-db.js';\n16: import { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\n17: import { parseSkillFrontmatter } from '../utils/skill-markdown.js';\n18: import type {\n19:   AdvisorEmbeddingSignature,\n20:   AdvisorEmbeddingStalenessVerdict,\n21:   AdvisorProjection,\n22:   SkillDocTriggerProjection,\n23:   SkillEdgeProjection,\n24:   SkillLifecycleStatus,\n25:   SkillProjection,\n26: } from './types.js';\n27: import { phraseVariants, unique } from './text.js';\n28: \n29: interface SkillNodeRow {\n30:   readonly id: string;\n31:   readonly family: string;\n32:   readonly category: string;\n33:   readonly domains: string | null;\n34:   readonly intent_signals: string | null;\n35:   readonly derived: string | null;\n36:   readonly source_path: string;\n37: }\n38: \n39: interface SkillEdgeRow {\n40:   readonly source_id: string;\n41:   readonly target_id: string;\n42:   readonly edge_type: SkillEdgeProjection['edgeType'];\n43:   readonly weight: number;\n44:   readonly context: string;\n45: }\n46: \n47: interface SkillMarkdownMetadata {\n48:   readonly name: string;\n49:   readonly description: string;\n50:   readonly keywords: readonly string[];\n51: }\n52: \n53: const advisorDbDirOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n54: const SKILL_GRAPH_DB = advisorDbDirOverride\n55:   ? join(advisorDbDirOverride, 'skill-graph.sqlite')\n56:   : join('.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database', 'skill-graph.sqlite');\n57: \n58: const COMMAND_BRIDGES: readonly SkillProjection[] = [\n59:   {\n60:     id: 'command-spec-kit',\n61:     kind: 'command',\n62:     family: 'system',\n63:     category: 'command',\n64:     name: 'command-spec-kit',\n65:     description: 'Spec Kit command bridge for /spec_kit workflows.',\n66:     keywords: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n67:     domains: ['spec-kit', 'command'],\n68:     intentSignals: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n69:     derivedTriggers: [],\n70:     derivedKeywords: [],\n71:     sourcePath: null,\n72:     lifecycleStatus: 'active',\n73:   },\n74:   {\n75:     id: 'memory:save',\n76:     kind: 'command',\n77:     family: 'system',\n78:     category: 'command',\n79:     name: 'memory:save',\n80:     description: 'Memory save command bridge for /memory:save context preservation.',\n81:     keywords: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n82:     domains: ['memory', 'command'],\n83:     intentSignals: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n84:     derivedTriggers: [],\n85:     derivedKeywords: [],\n86:     sourcePath: null,\n87:     lifecycleStatus: 'active',\n88:   },\n89:   {\n90:     id: 'command-memory-save',\n91:     kind: 'command',\n92:     family: 'system',\n93:     category: 'command',\n94:     name: 'command-memory-save',\n95:     description: 'Memory save command bridge for /memory:save context preservation.',\n96:     keywords: ['/memory:save', 'save context', 'save memory'],\n97:     domains: ['memory', 'command'],\n98:     intentSignals: ['/memory:save', 'save context', 'save memory'],\n99:     derivedTriggers: [],\n100:     derivedKeywords: [],\n101:     sourcePath: null,\n102:     lifecycleStatus: 'active',\n103:   },\n104:   {\n105:     id: 'create:agent',\n106:     kind: 'command',\n107:     family: 'system',\n108:     category: 'command',\n109:     name: 'create:agent',\n110:     description: 'Create command bridge for /create:agent OpenCode agent scaffolding.',\n111:     keywords: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n112:     domains: ['create', 'agent', 'command'],\n113:     intentSignals: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n114:     derivedTriggers: [],\n115:     derivedKeywords: [],\n116:     sourcePath: null,\n117:     lifecycleStatus: 'active',\n118:   },\n119:   {\n120:     id: 'create:manual-testing-playbook',\n121:     kind: 'command',\n122:     family: 'system',\n123:     category: 'command',\n124:     name: 'create:manual-testing-playbook',\n125:     description: 'Create command bridge for /create:manual-testing-playbook manual testing playbook scaffolding.',\n126:     keywords: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n127:     domains: ['create', 'testing', 'playbook', 'command'],\n128:     intentSignals: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n129:     derivedTriggers: [],\n130:     derivedKeywords: [],\n131:     sourcePath: null,\n132:     lifecycleStatus: 'active',\n133:   },\n134:   {\n135:     id: 'deep-model-benchmark',\n136:     kind: 'command',\n137:     family: 'system',\n138:     category: 'command',\n139:     name: 'deep-model-benchmark',\n140:     description: 'Deep command bridge for /deep:start-model-benchmark-loop model and prompt-framework benchmarking.',\n141:     keywords: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n142:     domains: ['deep', 'benchmark', 'model', 'command'],\n143:     intentSignals: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n144:     derivedTriggers: [],\n145:     derivedKeywords: [],\n146:     sourcePath: null,\n147:     lifecycleStatus: 'active',\n148:   },\n149: ];\n150: \n151: function jsonArray(value: string | null | undefined): string[] {\n152:   return value ? parseJsonStringArray(value) : [];\n153: }\n154: \n155: function jsonObject(value: string | null | undefined): Record<string, unknown> {\n156:   return value ? parseJsonObject(value) ?? {} : {};\n157: }\n158: \n159: function stringArray(value: unknown): string[] {\n160:   return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n161: }\n162: \n163: function boundedDemotion(value: unknown): number | undefined {\n164:   return typeof value === 'number' && Number.isFinite(value)\n165:     ? Math.max(0, Math.min(1, value))\n166:     : undefined;\n167: }\n168: \n169: function readJson(filePath: string): Record<string, unknown> {\n170:   return readJsonObject(filePath) ?? {};\n171: }\n172: \n173: function parseSkillMarkdown(skillMdPath: string, fallbackId: string): SkillMarkdownMetadata {\n174:   if (!existsSync(skillMdPath)) {\n175:     return { name: fallbackId, description: '', keywords: [] };\n176:   }\n177:   const { frontmatter, keywords } = parseSkillFrontmatter(readFileSync(skillMdPath, 'utf8'));\n178:   return {\n179:     name: frontmatter.name || fallbackId,\n180:     description: frontmatter.description || '',\n181:     keywords,\n182:   };\n183: }\n184: \n185: function lifecycleStatus(raw: unknown, sourcePath: string): SkillLifecycleStatus {\n186:   if (raw === 'deprecated' || raw === 'archived' || raw === 'future' || raw === 'active') return raw;\n187:   const pathStatus = lifecycleStatusForPath(sourcePath);\n188:   return pathStatus === 'archived' || pathStatus === 'future' ? pathStatus : 'active';\n189: }\n190: \n191: function projectionFromRow(row: SkillNodeRow): SkillProjection {\n192:   const derived = sanitizeDerivedMetadata(jsonObject(row.derived), row.source_path) ?? {};\n193:   const graphMetadata = readJson(row.source_path);\n194:   const skillDir = dirname(row.source_path);\n195:   const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), row.id);\n196:   const lifecycle = lifecycleStatus(\n197:     graphMetadata.lifecycle_status ?? derived.lifecycle_status,\n198:     row.source_path,\n199:   );\n200:   const redirectTo = typeof graphMetadata.redirect_to === 'string'\n201:     ? graphMetadata.redirect_to\n202:     : (typeof derived.redirect_to === 'string' ? derived.redirect_to : null);\n203:   const redirectFrom = stringArray(graphMetadata.redirect_from ?? derived.redirect_from);\n204:   // Distinguish derivedTriggers (intent-shaped phrases) from\n205:   // derivedKeywords (entity-shaped concepts). Previously both fields were\n206:   // assigned the same array (value-by-reference), which double-counted the\n207:   // same evidence into two scoring inputs. Triggers now come from\n208:   // `derived.trigger_phrases` only; keywords come from `derived.key_topics`\n209:   // + `derived.entities` + `derived.key_files` + `derived.source_docs`. Each\n210:   // pipeline still passes through `phraseVariants` and `unique`. The two\n211:   // arrays may overlap when authors duplicate entries, but they are no longer\n212:   // assigned the same value-by-reference.\n213:   const derivedTriggers = unique(\n214:     stringArray(derived.trigger_phrases).flatMap((entry) => phraseVariants(entry)),\n215:   );\n216:   const derivedKeywords = unique([\n217:     ...stringArray(derived.key_topics),\n218:     ...stringArray(derived.entities),\n219:     ...stringArray(derived.key_files),\n220:     ...stringArray(derived.source_docs),\n221:   ].flatMap((entry) => phraseVariants(entry)));\n222: \n223:   return {\n224:     id: row.id,\n225:     kind: 'skill',\n226:     family: row.family,\n227:     category: row.category,\n228:     name: skillMd.name,\n229:     description: skillMd.description,\n230:     keywords: unique(skillMd.keywords.flatMap((entry) => phraseVariants(entry))),\n231:     domains: unique(sanitizeMetadataStringArray(jsonArray(row.domains), row.source_path).flatMap((entry) => phraseVariants(entry))),\n232:     intentSignals: unique(sanitizeMetadataStringArray(jsonArray(row.intent_signals), row.source_path).flatMap((entry) => phraseVariants(entry))),\n233:     derivedTriggers,\n234:     derivedKeywords,\n235:     derivedDemotion: boundedDemotion(derived.demotion),\n236:     // V2 derived sync stamps generated_at (the canonical author/sync time of\n237:     // the derived block); older shapes carried last_updated_at/created_at.\n238:     // generated_at leads the chain so a V2 block's real freshness wins over a\n239:     // stray legacy field. This value is AUTHOR-TIME, not runtime: rebuild\n240:     // re-indexes the existing block without re-stamping it; only a\n241:     // derived-content change through sync re-stamps generated_at.\n242:     derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n243:     sourcePath: row.source_path,\n244:     lifecycleStatus: lifecycle,\n245:     redirectTo,\n246:     redirectFrom,\n247:   };\n248: }\n249: \n250: function isoTimestampOrNull(value: unknown): string | null {\n251:   if (typeof value !== 'string' || value.trim().length === 0) return null;\n252:   return Number.isNaN(Date.parse(value)) ? null : value;\n253: }\n254: \n255: interface SkillDocRow {\n256:   readonly skill_id: string;\n257:   readonly doc_path: string;\n258:   readonly trigger_phrases: string;\n259:   readonly importance_tier: string | null;\n260: }\n261: \n262: interface MetadataRow {\n263:   readonly key: string;\n264:   readonly value: string;\n265: }\n266: \n267: interface TableNameRow {\n268:   readonly name: string;\n269: }\n270: \n271: interface EmbeddingModelRow {\n272:   readonly model_id: string | null;\n273: }\n274: \n275: interface StoredEmbeddingSummary {\n276:   readonly vectorCount: number;\n277:   readonly missingModelCount: number;\n278:   readonly modelIds: readonly string[];\n279:   readonly dim: number | null;\n280: }\n281: \n282: interface ActiveEmbeddingPointer {\n283:   readonly name: string;\n284:   readonly dim: number;\n285:   readonly provider: string | null;\n286: }\n287: \n288: const ACTIVE_EMBEDDER_NAME_KEY = 'active_embedder_name';\n289: const ACTIVE_EMBEDDER_DIM_KEY = 'active_embedder_dim';\n290: const ACTIVE_EMBEDDER_PROVIDER_KEY = 'active_embedder_provider';\n291: \n292: function sqliteTableExists(db: Database.Database, tableName: string): boolean {\n293:   const row = db.prepare(`\n294:     SELECT 1 AS present\n295:     FROM sqlite_master\n296:     WHERE type = 'table' AND name = ?\n297:     LIMIT 1\n298:   `).get(tableName) as { present: number } | undefined;\n299:   return Boolean(row);\n300: }\n301: \n302: function readMetadataMap(db: Database.Database): Map<string, string> {\n303:   if (!sqliteTableExists(db, 'vec_metadata')) return new Map();\n304:   const rows = db.prepare(`\n305:     SELECT key, value\n306:     FROM vec_metadata\n307:     WHERE key IN (?, ?, ?)\n308:   `).all(ACTIVE_EMBEDDER_NAME_KEY, ACTIVE_EMBEDDER_DIM_KEY, ACTIVE_EMBEDDER_PROVIDER_KEY) as MetadataRow[];\n309:   return new Map(rows.map((row) => [row.key, row.value]));\n310: }\n311: \n312: function providerForBackend(backend: BackendKind | undefined): string | null {\n313:   switch (backend) {\n314:     case 'ollama':\n315:       return 'ollama';\n316:     case 'api':\n317:       return 'openai';\n318:     case 'sentence-transformers':\n319:       return 'hf-local';\n320:     default:\n321:       return null;\n322:   }\n323: }\n324: \n325: function readActiveEmbeddingPointer(db: Database.Database): ActiveEmbeddingPointer | null {\n326:   const metadata = readMetadataMap(db);\n327:   const name = metadata.get(ACTIVE_EMBEDDER_NAME_KEY);\n328:   const rawDim = metadata.get(ACTIVE_EMBEDDER_DIM_KEY);\n329:   const dim = rawDim && /^[0-9]+$/.test(rawDim) ? Number.parseInt(rawDim, 10) : null;\n330:   if (!name || dim === null || dim <= 0) {\n331:     return null;\n332:   }\n333:   const metadataProvider = metadata.get(ACTIVE_EMBEDDER_PROVIDER_KEY);\n334:   const manifest = getManifest(name);\n335:   return {\n336:     name,\n337:     dim,\n338:     provider: metadataProvider && metadataProvider.trim().length > 0\n339:       ? metadataProvider\n340:       : providerForBackend(manifest?.backend),\n341:   };\n342: }\n343: \n344: function signatureFromPointer(pointer: ActiveEmbeddingPointer): AdvisorEmbeddingSignature {\n345:   const profileId = pointer.provider\n346:     ? providerModelId({ provider: pointer.provider, model: pointer.name, dim: pointer.dim })\n347:     : null;\n348:   return {\n349:     provider: pointer.provider,\n350:     name: pointer.name,\n351:     dim: pointer.dim,\n352:     modelId: pointer.name,\n353:     providerModelId: profileId,\n354:   };\n355: }\n356: \n357: function parseProviderModelId(modelId: string): { provider: string; name: string; dim: number } | null {\n358:   const slugParts = modelId.split('__');\n359:   if (slugParts.length >= 3 && /^[0-9]+$/.test(slugParts[2])) {\n360:     return {\n361:       provider: slugParts[0],\n362:       name: slugParts[1],\n363:       dim: Number.parseInt(slugParts[2], 10),\n364:     };\n365:   }\n366: \n367:   const parts = modelId.split(':');\n368:   for (let index = parts.length - 1; index >= 2; index--) {\n369:     if (!/^[0-9]+$/.test(parts[index])) continue;\n370:     return {\n371:       provider: parts[0],\n372:       name: parts.slice(1, index).join(':'),\n373:       dim: Number.parseInt(parts[index], 10),\n374:     };\n375:   }\n376:   return null;\n377: }\n378: \n379: function signatureFromModelId(modelId: string, fallbackDim: number | null): AdvisorEmbeddingSignature {\n380:   const parsed = parseProviderModelId(modelId);\n381:   if (parsed) {\n382:     return {\n383:       provider: parsed.provider,\n384:       name: parsed.name,\n385:       dim: parsed.dim,\n386:       modelId,\n387:       providerModelId: modelId,\n388:     };\n389:   }\n390:   return {\n391:     provider: null,\n392:     name: modelId,\n393:     dim: fallbackDim ?? 0,\n394:     modelId,\n395:     providerModelId: null,\n396:   };\n397: }\n398: \n399: function activeCompatibleModelIds(active: AdvisorEmbeddingSignature): Set<string> {\n400:   const ids = new Set<string>([active.modelId]);\n401:   if (active.providerModelId) ids.add(active.providerModelId);\n402:   const manifest = getManifest(active.name);\n403:   if (active.provider && manifest?.ollamaName) {\n404:     ids.add(providerModelId({ provider: active.provider, model: manifest.ollamaName, dim: active.dim }));\n405:   }\n406:   return ids;\n407: }\n408: \n409: function vecTables(db: Database.Database): Array<{ name: string; dim: number }> {\n410:   const rows = db.prepare(`\n411:     SELECT name\n412:     FROM sqlite_master\n413:     WHERE type = 'table' AND name GLOB 'vec_[0-9]*'\n414:     ORDER BY name ASC\n415:   `).all() as TableNameRow[];\n416:   return rows\n417:     .map((row) => {\n418:       const match = /^vec_([0-9]+)$/.exec(row.name);\n419:       return match ? { name: row.name, dim: Number.parseInt(match[1], 10) } : null;\n420:     })\n421:     .filter((row): row is { name: string; dim: number } => row !== null);\n422: }\n423: \n424: function summarizeModelRows(rows: readonly EmbeddingModelRow[], dim: number | null): StoredEmbeddingSummary {\n425:   const normalizedModelIds = rows.map((row) => row.model_id?.trim() ?? '');\n426:   const modelIds = unique(\n427:     normalizedModelIds.filter((modelId) => modelId.length > 0),\n428:   );\n429:   return {\n430:     vectorCount: rows.length,\n431:     missingModelCount: normalizedModelIds.filter((modelId) => modelId.length === 0).length,\n432:     modelIds,\n433:     dim,\n434:   };\n435: }\n436: \n437: function summarizeVecTable(db: Database.Database, tableName: string, dim: number): StoredEmbeddingSummary {\n438:   const rows = db.prepare(`\n439:     SELECT model_id\n440:     FROM ${tableName}\n441:     WHERE embedding IS NOT NULL\n442:     ORDER BY skill_id ASC\n443:   `).all() as EmbeddingModelRow[];\n444:   return summarizeModelRows(rows, dim);\n445: }\n446: \n447: function summarizeLegacyEmbeddings(db: Database.Database): StoredEmbeddingSummary {\n448:   if (!sqliteTableExists(db, 'skill_nodes')) {\n449:     return { vectorCount: 0, missingModelCount: 0, modelIds: [], dim: null };\n450:   }\n451:   const rows = db.prepare(`\n452:     SELECT embedding_model_id AS model_id\n453:     FROM skill_nodes\n454:     WHERE embedding IS NOT NULL\n455:     ORDER BY id ASC\n456:   `).all() as EmbeddingModelRow[];\n457:   return summarizeModelRows(rows, null);\n458: }\n459: \n460: function combineSummaries(summaries: readonly StoredEmbeddingSummary[]): StoredEmbeddingSummary {\n461:   return {\n462:     vectorCount: summaries.reduce((total, summary) => total + summary.vectorCount, 0),\n463:     missingModelCount: summaries.reduce((total, summary) => total + summary.missingModelCount, 0),\n464:     modelIds: unique(summaries.flatMap((summary) => [...summary.modelIds])),\n465:     dim: summaries.find((summary) => summary.dim !== null)?.dim ?? null,\n466:   };\n467: }\n468: \n469: function storedEmbeddingSummary(db: Database.Database, active: ActiveEmbeddingPointer | null): StoredEmbeddingSummary {\n470:   const tables = vecTables(db);\n471:   if (active) {\n472:     const activeTable = tables.find((table) => table.dim === active.dim);\n473:     if (activeTable) {\n474:       const summary = summarizeVecTable(db, activeTable.name, activeTable.dim);\n475:       if (summary.vectorCount > 0 || summary.missingModelCount > 0) {\n476:         return summary;\n477:       }\n478:     }\n479:     const nonActiveSummaries = tables\n480:       .filter((table) => table.dim !== active.dim)\n481:       .map((table) => summarizeVecTable(db, table.name, table.dim))\n482:       .filter((summary) => summary.vectorCount > 0 || summary.missingModelCount > 0);\n483:     return combineSummaries(nonActiveSummaries);\n484:   }\n485: \n486:   const legacy = summarizeLegacyEmbeddings(db);\n487:   if (legacy.vectorCount > 0 || legacy.missingModelCount > 0) {\n488:     return legacy;\n489:   }\n490:   return combineSummaries(\n491:     tables\n492:       .map((table) => summarizeVecTable(db, table.name, table.dim))\n493:       .filter((summary) => summary.vectorCount > 0 || summary.missingModelCount > 0),\n494:   );\n495: }\n496: \n497: function buildEmbeddingStalenessVerdict(\n498:   active: AdvisorEmbeddingSignature | null,\n499:   summary: StoredEmbeddingSummary,\n500: ): AdvisorEmbeddingStalenessVerdict {\n501:   if (summary.vectorCount === 0 && summary.missingModelCount === 0) {\n502:     return { stale: false, active, stored: null, vectorCount: 0 };\n503:   }\n504: \n505:   const storedModelId = summary.modelIds[0] ?? null;\n506:   const rawStored = storedModelId\n507:     ? signatureFromModelId(storedModelId, summary.dim)\n508:     : null;\n509:   const stored = rawStored && active && activeCompatibleModelIds(active).has(rawStored.modelId)\n510:     ? { ...active, modelId: rawStored.modelId }\n511:     : rawStored;\n512:   const base = {\n513:     active,\n514:     stored,\n515:     vectorCount: summary.vectorCount,\n516:     modelIds: summary.modelIds,\n517:   };\n518: \n519:   if (!active) {\n520:     return { ...base, stale: true, reason: 'main active-embedder pointer incomplete' };\n\n(Showing lines 1-520 of 733. Use offset=521 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Projection\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { dirname, isAbsolute, join, resolve } from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { getManifest } from '../embedders/registry.js';\nimport type { BackendKind } from '../embedders/types.js';\nimport { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\nimport { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\nimport { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\nimport { providerModelId } from '../skill-graph/skill-graph-db.js';\nimport { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type {\n  AdvisorEmbeddingSignature,\n  AdvisorEmbeddingStalenessVerdict,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Projection\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { dirname, isAbsolute, join, resolve } from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { getManifest } from '../embedders/registry.js';\nimport type { BackendKind } from '../embedders/types.js';\nimport { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\nimport { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\nimport { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\nimport { providerModelId } from '../skill-graph/skill-graph-db.js';\nimport { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type {\n  AdvisorEmbeddingSignature,\n  AdvisorEmbeddingStalenessVerdict,\n  AdvisorProjection,\n  SkillDocTriggerProjection,\n  SkillEdgeProjection,\n  SkillLifecycleStatus,\n  SkillProjection,\n} from './types.js';\nimport { phraseVariants, unique } from './text.js';\n\ninterface SkillNodeRow {\n  readonly id: string;\n  readonly family: string;\n  readonly category: string;\n  readonly domains: string | null;\n  readonly intent_signals: string | null;\n  readonly derived: string | null;\n  readonly source_path: string;\n}\n\ninterface SkillEdgeRow {\n  readonly source_id: string;\n  readonly target_id: string;\n  readonly edge_type: SkillEdgeProjection['edgeType'];\n  readonly weight: number;\n  readonly context: string;\n}\n\ninterface SkillMarkdownMetadata {\n  readonly name: string;\n  readonly description: string;\n  readonly keywords: readonly string[];\n}\n\nconst advisorDbDirOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\nconst SKILL_GRAPH_DB = advisorDbDirOverride\n  ? join(advisorDbDirOverride, 'skill-graph.sqlite')\n  : join('.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database', 'skill-graph.sqlite');\n\nconst COMMAND_BRIDGES: readonly SkillProjection[] = [\n  {\n    id: 'command-spec-kit',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'command-spec-kit',\n    description: 'Spec Kit command bridge for /spec_kit workflows.',\n    keywords: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n    domains: ['spec-kit', 'command'],\n    intentSignals: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'memory:save',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'memory:save',\n    description: 'Memory save command bridge for /memory:save context preservation.',\n    keywords: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n    domains: ['memory', 'command'],\n    intentSignals: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'command-memory-save',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'command-memory-save',\n    description: 'Memory save command bridge for /memory:save context preservation.',\n    keywords: ['/memory:save', 'save context', 'save memory'],\n    domains: ['memory', 'command'],\n    intentSignals: ['/memory:save', 'save context', 'save memory'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'create:agent',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'create:agent',\n    description: 'Create command bridge for /create:agent OpenCode agent scaffolding.',\n    keywords: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n    domains: ['create', 'agent', 'command'],\n    intentSignals: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'create:manual-testing-playbook',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'create:manual-testing-playbook',\n    description: 'Create command bridge for /create:manual-testing-playbook manual testing playbook scaffolding.',\n    keywords: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n    domains: ['create', 'testing', 'playbook', 'command'],\n    intentSignals: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'deep-model-benchmark',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'deep-model-benchmark',\n    description: 'Deep command bridge for /deep:start-model-benchmark-loop model and prompt-framework benchmarking.',\n    keywords: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n    domains: ['deep', 'benchmark', 'model', 'command'],\n    intentSignals: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n];\n\nfunction jsonArray(value: string | null | undefined): string[] {\n  return value ? parseJsonStringArray(value) : [];\n}\n\nfunction jsonObject(value: string | null | undefined): Record<string, unknown> {\n  return value ? parseJsonObject(value) ?? {} : {};\n}\n\nfunction stringArray(value: unknown): string[] {\n  return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n}\n\nfunction boundedDemotion(value: unknown): number | undefined {\n  return typeof value === 'number' && Number.isFinite(value)\n    ? Math.max(0, Math.min(1, value))\n    : undefined;\n}\n\nfunction readJson(filePath: string): Record<string, unknown> {\n  return readJsonObject(filePath) ?? {};\n}\n\nfunction parseSkillMarkdown(skillMdPath: string, fallbackId: string): SkillMarkdownMetadata {\n  if (!existsSync(skillMdPath)) {\n    return { name: fallbackId, description: '', keywords: [] };\n  }\n  const { frontmatter, keywords } = parseSkillFrontmatter(readFileSync(skillMdPath, 'utf8'));\n  return {\n    name: frontmatter.name || fallbackId,\n    description: frontmatter.description || '',\n    keywords,\n  };\n}\n\nfunction lifecycleStatus(raw: unknown, sourcePath: string): SkillLifecycleStatus {\n  if (raw === 'deprecated' || raw === 'archived' || raw === 'future' || raw === 'active') return raw;\n  const pathStatus = lifecycleStatusForPath(sourcePath);\n  return pathStatus === 'archived' || pathStatus === 'future' ? pathStatus : 'active';\n}\n\nfunction projectionFromRow(row: SkillNodeRow): SkillProjection {\n  const derived = sanitizeDerivedMetadata(jsonObject(row.derived), row.source_path) ?? {};\n  const graphMetadata = readJson(row.source_path);\n  const skillDir = dirname(row.source_path);\n  const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), row.id);\n  const lifecycle = lifecycleStatus(\n    graphMetadata.lifecycle_status ?? derived.lifecycle_status,\n    row.source_path,\n  );\n  const redirectTo = typeof graphMetadata.redirect_to === 'string'\n    ? graphMetadata.redirect_to\n    : (typeof derived.redirect_to === 'string' ? derived.redirect_to : null);\n  const redirectFrom = stringArray(graphMetadata.redirect_from ?? derived.redirect_from);\n  // Distinguish derivedTriggers (intent-shaped phrases) from\n  // derivedKeywords (entity-shaped concepts). Previously both fields were\n  // assigned the same array (value-by-reference), which double-counted the\n  // same evidence into two scoring inputs. Triggers now come from\n  // `derived.trigger_phrases` only; keywords come from `derived.key_topics`\n  // + `derived.entities` + `derived.key_files` + `derived.source_docs`. Each\n  // pipeline still passes through `phraseVariants` and `unique`. The two\n  // arrays may overlap when authors duplicate entries, but they are no longer\n  // assigned the same value-by-reference.\n  const derivedTriggers = unique(\n    stringArray(derived.trigger_phrases).flatMap((entry) => phraseVariants(entry)),\n  );\n  const derivedKeywords = unique([\n    ...stringArray(derived.key_topics),\n    ...stringArray(derived.entities),\n    ...stringArray(derived.key_files),\n    ...stringArray(derived.source_docs),\n  ].flatMap((entry) => phraseVariants(entry)));\n\n  return {\n    id: row.id,\n    kind: 'skill',\n    family: row.family,\n    category: row.category,\n    name: skillMd.name,\n    description: skillMd.description,\n    keywords: unique(skillMd.keywords.flatMap((entry) => phraseVariants(entry))),\n    domains: unique(sanitizeMetadataStringArray(jsonArray(row.domains), row.source_path).flatMap((entry) => phraseVariants(entry))),\n    intentSignals: unique(sanitizeMetadataStringArray(jsonArray(row.intent_signals), row.source_path).flatMap((entry) => phraseVariants(entry))),\n    derivedTriggers,\n    derivedKeywords,\n    derivedDemotion: boundedDemotion(derived.demotion),\n    // V2 derived sync stamps generated_at (the canonical author/sync time of\n    // the derived block); older shapes carried last_updated_at/created_at.\n    // generated_at leads the chain so a V2 block's real freshness wins over a\n    // stray legacy field. This value is AUTHOR-TIME, not runtime: rebuild\n    // re-indexes the existing block without re-stamping it; only a\n    // derived-content change through sync re-stamps generated_at.\n    derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n    sourcePath: row.source_path,\n    lifecycleStatus: lifecycle,\n    redirectTo,\n    redirectFrom,\n  };\n}\n\nfunction isoTimestampOrNull(value: unknown): string | null {\n  if (typeof value !== 'string' || value.trim().length === 0) return null;\n  return Number.isNaN(Date.parse(value)) ? null : value;\n}\n\ninterface SkillDocRow {\n  readonly skill_id: string;\n  readonly doc_path: string;\n  readonly trigger_phrases: string;\n  readonly importance_tier: string | null;\n}\n\ninterface MetadataRow {\n  readonly key: string;\n  readonly value: string;\n}\n\ninterface TableNameRow {\n  readonly name: string;\n}\n\ninterface EmbeddingModelRow {\n  readonly model_id: string | null;\n}\n\ninterface StoredEmbeddingSummary {\n  readonly vectorCount: number;\n  readonly missingModelCount: number;\n  readonly modelIds: readonly string[];\n  readonly dim: number | null;\n}\n\ninterface ActiveEmbeddingPointer {\n  readonly name: string;\n  readonly dim: number;\n  readonly provider: string | null;\n}\n\nconst ACTIVE_EMBEDDER_NAME_KEY = 'active_embedder_name';\nconst ACTIVE_EMBEDDER_DIM_KEY = 'active_embedder_dim';\nconst ACTIVE_EMBEDDER_PROVIDER_KEY = 'active_embedder_provider';\n\nfunction sqliteTableExists(db: Database.Database, tableName: string): boolean {\n  const row = db.prepare(`\n    SELECT 1 AS present\n    FROM sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { present: number } | undefined;\n  return Boolean(row);\n}\n\nfunction readMetadataMap(db: Database.Database): Map<string, string> {\n  if (!sqliteTableExists(db, 'vec_metadata')) return new Map();\n  const rows = db.prepare(`\n    SELECT key, value\n    FROM vec_metadata\n    WHERE key IN (?, ?, ?)\n  `).all(ACTIVE_EMBEDDER_NAME_KEY, ACTIVE_EMBEDDER_DIM_KEY, ACTIVE_EMBEDDER_PROVIDER_KEY) as MetadataRow[];\n  return new Map(rows.map((row) => [row.key, row.value]));\n}\n\nfunction providerForBackend(backend: BackendKind | undefined): string | null {\n  switch (backend) {\n    case 'ollama':\n      return 'ollama';\n    case 'api':\n      return 'openai';\n    case 'sentence-transformers':\n      return 'hf-local';\n    default:\n      return null;\n  }\n}\n\nfunction readActiveEmbeddingPointer(db: Database.Database): ActiveEmbeddingPointer | null {\n  const metadata = readMetadataMap(db);\n  const name = metadata.get(ACTIVE_EMBEDDER_NAME_KEY);\n  const rawDim = metadata.get(ACTIVE_EMBEDDER_DIM_KEY);\n  const dim = rawDim && /^[0-9]+$/.test(rawDim) ? Number.parseInt(rawDim, 10) : null;\n  if (!name || dim === null || dim <= 0) {\n    return null;\n  }\n  const metadataProvider = metadata.get(ACTIVE_EMBEDDER_PROVIDER_KEY);\n  const manifest = getManifest(name);\n  return {\n    name,\n    dim,\n    provider: metadataProvider && metadataProvider.trim().length > 0\n      ? metadataProvider\n      : providerForBackend(manifest?.backend),\n  };\n}\n\nfunction signatureFromPointer(pointer: ActiveEmbeddingPointer): AdvisorEmbeddingSignature {\n  const profileId = pointer.provider\n    ? providerModelId({ provider: pointer.provider, model: pointer.name, dim: pointer.dim })\n    : null;\n  return {\n    provider: pointer.provider,\n    name: pointer.name,\n    dim: pointer.dim,\n    modelId: pointer.name,\n    providerModelId: profileId,\n  };\n}\n\nfunction parseProviderModelId(modelId: string): { provider: string; name: string; dim: number } | null {\n  const slugParts = modelId.split('__');\n  if (slugParts.length >= 3 && /^[0-9]+$/.test(slugParts[2])) {\n    return {\n      provider: slugParts[0],\n      name: slugParts[1],\n      dim: Number.parseInt(slugParts[2], 10),\n    };\n  }\n\n  const parts = modelId.split(':');\n  for (let index = parts.length - 1; index >= 2; index--) {\n    if (!/^[0-9]+$/.test(parts[index])) continue;\n    return {\n      provider: parts[0],\n      name: parts.slice(1, index).join(':'),\n      dim: Number.parseInt(parts[index], 10),\n    };\n  }\n  return null;\n}\n\nfunction signatureFromModelId(modelId: string, fallbackDim: number | null): AdvisorEmbeddingSignature {\n  const parsed = parseProviderModelId(modelId);\n  if (parsed) {\n    return {\n      provider: parsed.provider,\n      name: parsed.name,\n      dim: parsed.dim,\n      modelId,\n      providerModelId: modelId,\n    };\n  }\n  return {\n    provider: null,\n    name: modelId,\n    dim: fallbackDim ?? 0,\n    modelId,\n    providerModelId: null,\n  };\n}\n\nfunction activeCompatibleModelIds(active: AdvisorEmbeddingSignature): Set<string> {\n  const ids = new Set<string>([active.modelId]);\n  if (active.providerModelId) ids.add(active.providerModelId);\n  const manifest = getManifest(active.name);\n  if (active.provider && manifest?.ollamaName) {\n    ids.add(providerModelId({ provider: active.provider, model: manifest.ollamaName, dim: active.dim }));\n  }\n  return ids;\n}\n\nfunction vecTables(db: Database.Database): Array<{ name: string; dim: number }> {\n  const rows = db.prepare(`\n    SELECT name\n    FROM sqlite_master\n    WHERE type = 'table' AND name GLOB 'vec_[0-9]*'\n    ORDER BY name ASC\n  `).all() as TableNameRow[];\n  return rows\n    .map((row) => {\n      const match = /^vec_([0-9]+)$/.exec(row.name);\n      return match ? { name: row.name, dim: Number.parseInt(match[1], 10) } : null;\n    })\n    .filter((row): row is { name: string; dim: number } => row !== null);\n}\n\nfunction summarizeModelRows(rows: readonly EmbeddingModelRow[], dim: number | null): StoredEmbeddingSummary {\n  const normalizedModelIds = rows.map((row) => row.model_id?.trim() ?? '');\n  const modelIds = unique(\n    normalizedModelIds.filter((modelId) => modelId.length > 0),\n  );\n  return {\n    vectorCount: rows.length,\n    missingModelCount: normalizedModelIds.filter((modelId) => modelId.length === 0).length,\n    modelIds,\n    dim,\n  };\n}\n\nfunction summarizeVecTable(db: Database.Database, tableName: string, dim: number): StoredEmbeddingSummary {\n  const rows = db.prepare(`\n    SELECT model_id\n    FROM ${tableName}\n    WHERE embedding IS NOT NULL\n    ORDER BY skill_id ASC\n  `).all() as EmbeddingModelRow[];\n  return summarizeModelRows(rows, dim);\n}\n\nfunction summarizeLegacyEmbeddings(db: Database.Database): StoredEmbeddingSummary {\n  if (!sqliteTableExists(db, 'skill_nodes')) {\n    return { vectorCount: 0, missingModelCount: 0, modelIds: [], dim: null };\n  }\n  const rows = db.prepare(`\n    SELECT embedding_model_id AS model_id\n    FROM skill_nodes\n    WHERE embedding IS NOT NULL\n    ORDER BY id ASC\n  `).all() as EmbeddingModelRow[];\n  return summarizeModelRows(rows, null);\n}\n\nfunction combineSummaries(summaries: readonly StoredEmbeddingSummary[]): StoredEmbeddingSummary {\n  return {\n    vectorCount: summaries.reduce((total, summary) => total + summary.vectorCount, 0),\n    missingModelCount: summaries.reduce((total, summary) => total + summary.missingModelCount, 0),\n    modelIds: unique(summaries.flatMap((summary) => [...summary.modelIds])),\n    dim: summaries.find((summary) => summary.dim !== null)?.dim ?? null,\n  };\n}\n\nfunction storedEmbeddingSummary(db: Database.Database, active: ActiveEmbeddingPointer | null): StoredEmbeddingSummary {\n  const tables = vecTables(db);\n  if (active) {\n    const activeTable = tables.find((table) => table.dim === active.dim);\n    if (activeTable) {\n      const summary = summarizeVecTable(db, activeTable.name, activeTable.dim);\n      if (summary.vectorCount > 0 || summary.missingModelCount > 0) {\n        return summary;\n      }\n    }\n    const nonActiveSummaries = tables\n      .filter((table) => table.dim !== active.dim)\n      .map((table) => summarizeVecTable(db, table.name, table.dim))\n      .filter((summary) => summary.vectorCount > 0 || summary.missingModelCount > 0);\n    return combineSummaries(nonActiveSummaries);\n  }\n\n  const legacy = summarizeLegacyEmbeddings(db);\n  if (legacy.vectorCount > 0 || legacy.missingModelCount > 0) {\n    return legacy;\n  }\n  return combineSummaries(\n    tables\n      .map((table) => summarizeVecTable(db, table.name, table.dim))\n      .filter((summary) => summary.vectorCount > 0 || summary.missingModelCount > 0),\n  );\n}\n\nfunction buildEmbeddingStalenessVerdict(\n  active: AdvisorEmbeddingSignature | null,\n  summary: StoredEmbeddingSummary,\n): AdvisorEmbeddingStalenessVerdict {\n  if (summary.vectorCount === 0 && summary.missingModelCount === 0) {\n    return { stale: false, active, stored: null, vectorCount: 0 };\n  }\n\n  const storedModelId = summary.modelIds[0] ?? null;\n  const rawStored = storedModelId\n    ? signatureFromModelId(storedModelId, summary.dim)\n    : null;\n  const stored = rawStored && active && activeCompatibleModelIds(active).has(rawStored.modelId)\n    ? { ...active, modelId: rawStored.modelId }\n    : rawStored;\n  const base = {\n    active,\n    stored,\n    vectorCount: summary.vectorCount,\n    modelIds: summary.modelIds,\n  };\n\n  if (!active) {\n    return { ...base, stale: true, reason: 'main active-embedder pointer incomplete' };","lineStart":1,"lineEnd":520,"totalLines":733,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","time":{"start":1783437201983,"end":1783437201986}},"metadata":{"openai":{"itemId":"fc_002f97d8e79f1a0a016a4d1791cde88191949ded00dfc0bb53"}},"id":"prt_f3d241231001114EsL7zVKJdpl","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ"}}
