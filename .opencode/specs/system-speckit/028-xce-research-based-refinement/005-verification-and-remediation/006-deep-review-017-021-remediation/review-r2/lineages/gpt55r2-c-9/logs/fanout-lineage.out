mand-driven spawn, shutdown, or listen failure) so a second launcher sharing this socket loses\n1238:     // cleanly with 'model-server-respawn-lock-held' instead of racing the bind. (Lock LIFETIME differs\n1239:     // from the single-launcher path by design; the wx-open + UDS-bind primitives are unchanged.)\n1240:     const lock = acquireDemandRespawnLock(socketPath);\n1241:     if (!lock.acquired) return { shouldListen: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n1242:     let reapResult;\n1243:     if (fs.existsSync(socketPath)) {\n1244:       reapResult = await reapRecordedModelServerBeforeRespawn(socketPath, { lock });\n1245:     } else {\n1246:       // No socket file yet — but a sibling launcher may have JUST spawned the server: launch() writes the\n1247:       // shared hf-embed.pid synchronously before the child binds, so during the spawn->bind window the pid\n1248:       // is live while the socket is absent. Respect a live recorded pid so we do not clobber a booting\n1249:       // resident (the demand lock can be momentarily free right after a sibling's spawn).\n1250:       const recordedPid = readModelServerPid();\n1251:       if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n1252:         releaseDemandRespawnLock();\n1253:         return { shouldListen: false, reason: 'model-server-booting' };\n1254:       }\n1255:       reapResult = { allowed: true, reaped: false, reason: 'missing-model-server-pid' };\n1256:     }\n1257:     if (!reapResult.allowed) {\n1258:       releaseDemandRespawnLock();\n1259:       return { shouldListen: false, reason: reapResult.reason, lockPath: reapResult.lockPath };\n1260:     }\n1261:     if (reapResult.reaped && (deadProbeReason === 'loading-wedged' || deadProbeReason === 'health-error')) {\n1262:       armGiveUpCooldown();\n1263:     }\n1264:     unlinkModelServerSocket(socketPath);\n1265:     return { shouldListen: true, reason: reapResult.reason };\n1266:   }\n1267: \n1268:   function handleModelServerDemand(request, response) {\n1269:     const routePath = new URL(request.url || '/', 'http://127.0.0.1').pathname;\n1270:     // A launcher liveness probe must never be treated as embed demand. A sibling launcher's\n1271:     // boot-time health check would otherwise wake — and on a host where the local model is\n1272:     // unsupported, crash-loop — a model server that no consumer actually needs. Genuine consumers\n1273:     // never send this marker, so their lazy wake-on-demand path is unaffected.\n1274:     const probeMarker = request.headers && request.headers['x-speckit-probe'];\n1275:     if (typeof probeMarker === 'string' && probeMarker.toLowerCase() === 'liveness') {\n1276:       writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1277:         state: 'no-resident',\n1278:         reason: 'liveness-probe',\n1279:       });\n1280:       return;\n1281:     }\n1282:     const cooldown = activeGiveUpCooldown(state.demandTarget || resolveSocketPath());\n1283:     if (cooldown) {\n1284:       logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; crash-loop cooldown active for ${cooldown.retryAfterMs}ms`);\n1285:       writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1286:         state: 'error',\n1287:         reason: 'crash-loop-cooldown',\n1288:         retryAfterMs: cooldown.retryAfterMs,\n1289:       });\n1290:       return;\n1291:     }\n1292:     logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; spawning launcher-owned sibling`);\n1293:     releaseModelServerDemandListenerForSpawn({ keepRespawnLock: true });\n1294:     const launched = getSupervisor().launch();\n1295:     releaseDemandRespawnLock();\n1296:     if (!launched) {\n1297:       // launch() returned false (spawn produced no pid, or a child is already running). The\n1298:       // demand server was already torn down above and the respawn lock released, so without re