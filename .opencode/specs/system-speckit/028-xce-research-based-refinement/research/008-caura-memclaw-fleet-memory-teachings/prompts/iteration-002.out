{"type":"tool_use","timestamp":1780727734371,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_Fq8TAClj4D0krNFFlE1SzNro","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/classify_query.py","offset":241,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/classify_query.py</path>\n<type>file</type>\n<content>\n241:                 hop, weight = hop_weight[\"hop\"], hop_weight[\"weight\"]\n242:                 if (\n243:                     eid not in merged\n244:                     or hop < merged[eid][0]\n245:                     or (hop == merged[eid][0] and weight > merged[eid][1])\n246:                 ):\n247:                     merged[eid] = (hop, weight)\n248:         return merged\n249: \n250:     @staticmethod\n251:     async def _entity_fts(\n252:         sc: object,\n253:         tokens: list[str],\n254:         tenant_id: str,\n255:         fleet_ids: list[str] | None,\n256:     ) -> list[UUID]:\n257:         \"\"\"Full-text search against the entity index via storage client.\"\"\"\n258:         data = {\n259:             \"tokens\": tokens,\n260:             \"tenant_id\": tenant_id,\n261:         }\n262:         if fleet_ids:\n263:             data[\"fleet_ids\"] = fleet_ids\n264:         result = await sc.fts_search_entities(data)\n265:         return [UUID(eid) for eid in result]\n266: \n267:     @staticmethod\n268:     async def _collect_memories(\n269:         sc: object,\n270:         entity_hops: dict[UUID, tuple[int, float]],\n271:         tenant_id: str,\n272:         top_k: int,\n273:         *,\n274:         fleet_ids: list[str] | None = None,\n275:         caller_agent_id: str | None = None,\n276:         filter_agent_id: str | None = None,\n277:         memory_type_filter: str | None = None,\n278:         status_filter: str | None = None,\n279:         valid_at: datetime | None = None,\n280:         readable_tenant_ids: list[str] | None = None,\n281:         slot_acquired_marker: dict | None = None,\n282:     ) -> list[types.SimpleNamespace]:\n283:         \"\"\"Load memories linked to graph-expanded entities, scored by hop distance.\"\"\"\n284:         all_entity_ids = list(entity_hops.keys())\n285: \n286:         # Cap entity count to bound the query size.\n287:         if len(all_entity_ids) > GRAPH_MAX_EXPANDED_ENTITIES:\n288:             all_entity_ids = sorted(\n289:                 all_entity_ids,\n290:                 key=lambda eid: (entity_hops[eid][0], -entity_hops[eid][1]),\n291:             )[:GRAPH_MAX_EXPANDED_ENTITIES]\n292: \n293:         # Get memory-entity links from storage client.\n294:         # Returns list of {\"memory_id\", \"entity_id\", \"role\"} dicts.\n295:         raw_links = await sc.get_memory_ids_by_entity_ids(\n296:             [str(eid) for eid in all_entity_ids],\n297:         )\n298: \n299:         # Sort by hop distance so closest entities are processed first.\n300:         all_links = sorted(\n301:             raw_links,\n302:             key=lambda r: entity_hops.get(UUID(r[\"entity_id\"]), (999, 0.0))[0],\n303:         )\n304: \n305:         # Best (lowest hop → highest boost) per memory + collect entity links.\n306:         memory_boost: dict[str, float] = {}\n307:         memory_entity_links: dict[str, list[EntityLinkOut]] = {}\n308:         for link in all_links:\n309:             mem_id, ent_id_str, role = link[\"memory_id\"], link[\"entity_id\"], link.get(\"role\")\n310:             ent_id = UUID(ent_id_str)\n311:             if ent_id not in entity_hops:\n312:                 continue\n313:             hop_dist, rel_weight = entity_hops[ent_id]\n314:             boost = GRAPH_HOP_BOOST.get(hop_dist, _GRAPH_HOP_BOOST_FALLBACK) * rel_weight\n315:             if mem_id not in memory_boost or boost > memory_boost[mem_id]:\n316:                 memory_boost[mem_id] = boost\n317:             memory_entity_links.setdefault(mem_id, []).append(EntityLinkOut(entity_id=ent_id, role=role))\n318: \n319:         if not memory_boost:\n320:             return []\n321: \n322:         # Cap to prevent popular-entity fan-out.\n323:         if len(memory_boost) > GRAPH_MAX_BOOSTED_MEMORIES:\n324:             memory_ids_sorted = sorted(memory_boost, key=memory_boost.__getitem__, reverse=True)[\n325:                 :GRAPH_MAX_BOOSTED_MEMORIES\n326:             ]\n327:             memory_boost = {mid: memory_boost[mid] for mid in memory_ids_sorted}\n328: \n329:         # CAURA-687: load memories by ID via the dedicated short-circuit\n330:         # endpoint. Pre-CAURA-687 this POSTed to /memories/scored-search\n331:         # with a ``memory_ids`` key + ``entity_lookup: True`` flag that\n332:         # route never read; storage hard-indexed body[\"embedding\"], 500'd,\n333:         # and the broad except below swallowed it. The path silently fell\n334:         # through to keyword/semantic on every entity-token query.\n335:         # ``valid_at`` / ``readable_tenant_ids`` are forwarded so this\n336:         # short-circuit's visibility behaviour matches the scored-search\n337:         # fallthrough exactly — drift is a cross-tenant leak risk.\n338:         # top_k is intentionally NOT forwarded: storage returns ALL matching\n339:         # IDs (capped client-side at GRAPH_MAX_BOOSTED_MEMORIES = 50), and\n340:         # the user-facing top_k is applied below AFTER sorting by hop boost.\n341:         # A server-side LIMIT here would discard high-boost rows non-\n342:         # deterministically because the storage query has no ORDER BY.\n343:         search_data: dict = {\n344:             \"tenant_id\": tenant_id,\n345:             \"memory_ids\": list(memory_boost.keys()),\n346:             \"fleet_ids\": fleet_ids,\n347:             \"caller_agent_id\": caller_agent_id,\n348:             \"filter_agent_id\": filter_agent_id,\n349:             \"memory_type_filter\": memory_type_filter,\n350:             \"status_filter\": status_filter,\n351:         }\n352:         if valid_at is not None:\n353:             search_data[\"valid_at\"] = str(valid_at)\n354:         # Forward readable_tenant_ids whenever the caller's authorised set\n355:         # differs from home-tenant-only. The explicit comparison (rather\n356:         # than `len > 1`) handles the edge case where a single-element\n357:         # list names a tenant other than ``tenant_id``: silently dropping\n358:         # it would degrade to home-tenant reads with no error or log.\n359:         if readable_tenant_ids and readable_tenant_ids != [tenant_id]:\n360:             search_data[\"readable_tenant_ids\"] = readable_tenant_ids\n361:         # Per-tenant storage bulkhead (CAURA-602 follow-up). C10: when\n362:         # this entity-lookup short-circuit acquires + releases the slot\n363:         # here, we mark the pipeline context so a downstream\n364:         # ``execute_scored_search`` running on the rare fall-through\n365:         # path (entity-lookup matched but produced no filtered rows)\n366:         # doesn't re-acquire and charge the tenant twice for one\n367:         # logical search. Same key as scored-search, intentional —\n368:         # the bucket counts request-level storage pressure, not\n369:         # call-level.\n370:         async with per_tenant_storage_slot(\"storage_search\", tenant_id):\n371:             memories = await sc.load_memories_by_ids(search_data)\n372:         if slot_acquired_marker is not None:\n373:             slot_acquired_marker[\"_storage_slot_acquired\"] = True\n374: \n375:         # Build result rows with boost scores.\n376:         memories_by_id = {m[\"id\"]: m for m in memories}\n377: \n378:         rows = [\n379:             types.SimpleNamespace(\n380:                 Memory=types.SimpleNamespace(**memories_by_id[mid]),\n381:                 score=boost,\n382:                 vec_sim=None,\n383:                 entity_links=memory_entity_links.get(mid, []),\n384:             )\n385:             for mid, boost in memory_boost.items()\n386:             if mid in memories_by_id\n387:         ]\n388:         rows.sort(key=lambda r: r.score, reverse=True)\n389:         return rows[:top_k]\n\n(End of file - total 389 lines)\n</content>","metadata":{"preview":"                hop, weight = hop_weight[\"hop\"], hop_weight[\"weight\"]\n                if (\n                    eid not in merged\n                    or hop < merged[eid][0]\n                    or (hop == merged[eid][0] and weight > merged[eid][1])\n                ):\n                    merged[eid] = (hop, weight)\n        return merged\n\n    @staticmethod\n    async def _entity_fts(\n        sc: object,\n        tokens: list[str],\n        tenant_id: str,\n        fleet_ids: list[str] | None,\n    ) -> list[UUID]:\n        \"\"\"Full-text search against the entity index via storage client.\"\"\"\n        data = {\n            \"tokens\": tokens,\n            \"tenant_id\": tenant_id,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/classify_query.py","text":"                hop, weight = hop_weight[\"hop\"], hop_weight[\"weight\"]\n                if (\n                    eid not in merged\n                    or hop < merged[eid][0]\n                    or (hop == merged[eid][0] and weight > merged[eid][1])\n                ):\n                    merged[eid] = (hop, weight)\n        return merged\n\n    @staticmethod\n    async def _entity_fts(\n        sc: object,\n        tokens: list[str],\n        tenant_id: str,\n        fleet_ids: list[str] | None,\n    ) -> list[UUID]:\n        \"\"\"Full-text search against the entity index via storage client.\"\"\"\n        data = {\n            \"tokens\": tokens,\n            \"tenant_id\": tenant_id,\n        }\n        if fleet_ids:\n            data[\"fleet_ids\"] = fleet_ids\n        result = await sc.fts_search_entities(data)\n        return [UUID(eid) for eid in result]\n\n    @staticmethod\n    async def _collect_memories(\n        sc: object,\n        entity_hops: dict[UUID, tuple[int, float]],\n        tenant_id: str,\n        top_k: int,\n        *,\n        fleet_ids: list[str] | None = None,\n        caller_agent_id: str | None = None,\n        filter_agent_id: str | None = None,\n        memory_type_filter: str | None = None,\n        status_filter: str | None = None,\n        valid_at: datetime | None = None,\n        readable_tenant_ids: list[str] | None = None,\n        slot_acquired_marker: dict | None = None,\n    ) -> list[types.SimpleNamespace]:\n        \"\"\"Load memories linked to graph-expanded entities, scored by hop distance.\"\"\"\n        all_entity_ids = list(entity_hops.keys())\n\n        # Cap entity count to bound the query size.\n        if len(all_entity_ids) > GRAPH_MAX_EXPANDED_ENTITIES:\n            all_entity_ids = sorted(\n                all_entity_ids,\n                key=lambda eid: (entity_hops[eid][0], -entity_hops[eid][1]),\n            )[:GRAPH_MAX_EXPANDED_ENTITIES]\n\n        # Get memory-entity links from storage client.\n        # Returns list of {\"memory_id\", \"entity_id\", \"role\"} dicts.\n        raw_links = await sc.get_memory_ids_by_entity_ids(\n            [str(eid) for eid in all_entity_ids],\n        )\n\n        # Sort by hop distance so closest entities are processed first.\n        all_links = sorted(\n            raw_links,\n            key=lambda r: entity_hops.get(UUID(r[\"entity_id\"]), (999, 0.0))[0],\n        )\n\n        # Best (lowest hop → highest boost) per memory + collect entity links.\n        memory_boost: dict[str, float] = {}\n        memory_entity_links: dict[str, list[EntityLinkOut]] = {}\n        for link in all_links:\n            mem_id, ent_id_str, role = link[\"memory_id\"], link[\"entity_id\"], link.get(\"role\")\n            ent_id = UUID(ent_id_str)\n            if ent_id not in entity_hops:\n                continue\n            hop_dist, rel_weight = entity_hops[ent_id]\n            boost = GRAPH_HOP_BOOST.get(hop_dist, _GRAPH_HOP_BOOST_FALLBACK) * rel_weight\n            if mem_id not in memory_boost or boost > memory_boost[mem_id]:\n                memory_boost[mem_id] = boost\n            memory_entity_links.setdefault(mem_id, []).append(EntityLinkOut(entity_id=ent_id, role=role))\n\n        if not memory_boost:\n            return []\n\n        # Cap to prevent popular-entity fan-out.\n        if len(memory_boost) > GRAPH_MAX_BOOSTED_MEMORIES:\n            memory_ids_sorted = sorted(memory_boost, key=memory_boost.__getitem__, reverse=True)[\n                :GRAPH_MAX_BOOSTED_MEMORIES\n            ]\n            memory_boost = {mid: memory_boost[mid] for mid in memory_ids_sorted}\n\n        # CAURA-687: load memories by ID via the dedicated short-circuit\n        # endpoint. Pre-CAURA-687 this POSTed to /memories/scored-search\n        # with a ``memory_ids`` key + ``entity_lookup: True`` flag that\n        # route never read; storage hard-indexed body[\"embedding\"], 500'd,\n        # and the broad except below swallowed it. The path silently fell\n        # through to keyword/semantic on every entity-token query.\n        # ``valid_at`` / ``readable_tenant_ids`` are forwarded so this\n        # short-circuit's visibility behaviour matches the scored-search\n        # fallthrough exactly — drift is a cross-tenant leak risk.\n        # top_k is intentionally NOT forwarded: storage returns ALL matching\n        # IDs (capped client-side at GRAPH_MAX_BOOSTED_MEMORIES = 50), and\n        # the user-facing top_k is applied below AFTER sorting by hop boost.\n        # A server-side LIMIT here would discard high-boost rows non-\n        # deterministically because the storage query has no ORDER BY.\n        search_data: dict = {\n            \"tenant_id\": tenant_id,\n            \"memory_ids\": list(memory_boost.keys()),\n            \"fleet_ids\": fleet_ids,\n            \"caller_agent_id\": caller_agent_id,\n            \"filter_agent_id\": filter_agent_id,\n            \"memory_type_filter\": memory_type_filter,\n            \"status_filter\": status_filter,\n        }\n        if valid_at is not None:\n            search_data[\"valid_at\"] = str(valid_at)\n        # Forward readable_tenant_ids whenever the caller's authorised set\n        # differs from home-tenant-only. The explicit comparison (rather\n        # than `len > 1`) handles the edge case where a single-element\n        # list names a tenant other than ``tenant_id``: silently dropping\n        # it would degrade to home-tenant reads with no error or log.\n        if readable_tenant_ids and readable_tenant_ids != [tenant_id]:\n            search_data[\"readable_tenant_ids\"] = readable_tenant_ids\n        # Per-tenant storage bulkhead (CAURA-602 follow-up). C10: when\n        # this entity-lookup short-circuit acquires + releases the slot\n        # here, we mark the pipeline context so a downstream\n        # ``execute_scored_search`` running on the rare fall-through\n        # path (entity-lookup matched but produced no filtered rows)\n        # doesn't re-acquire and charge the tenant twice for one\n        # logical search. Same key as scored-search, intentional —\n        # the bucket counts request-level storage pressure, not\n        # call-level.\n        async with per_tenant_storage_slot(\"storage_search\", tenant_id):\n            memories = await sc.load_memories_by_ids(search_data)\n        if slot_acquired_marker is not None:\n            slot_acquired_marker[\"_storage_slot_acquired\"] = True\n\n        # Build result rows with boost scores.\n        memories_by_id = {m[\"id\"]: m for m in memories}\n\n        rows = [\n            types.SimpleNamespace(\n                Memory=types.SimpleNamespace(**memories_by_id[mid]),\n                score=boost,\n                vec_sim=None,\n                entity_links=memory_entity_links.get(mid, []),\n            )\n            for mid, boost in memory_boost.items()\n            if mid in memories_by_id\n        ]\n        rows.sort(key=lambda r: r.score, reverse=True)\n        return rows[:top_k]","lineStart":241,"lineEnd":389,"totalLines":389,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/classify_query.py","time":{"start":1780727734358,"end":1780727734367}},"metadata":{"openai":{"itemId":"fc_02a1e48b466abf07016a23bfb5327481919faeb7505416aaf0"}},"id":"prt_e9ba4dbe5001L7Oc4UZCmBip7Z","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba4d014001vTNukxF5odHp7Y"}}
{"type":"step_finish","timestamp":1780727734730,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba4e1c8001cUkC9hD2oPTLck","reason":"tool-calls","snapshot":"e08102e447291c6bad75781ff71748ae23be302d","messageID":"msg_e9ba4d014001vTNukxF5odHp7Y","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","type":"step-finish","tokens":{"total":111406,"input":10440,"output":85,"reasoning":17,"cache":{"write":0,"read":100864}},"cost":0}}
{"type":"step_start","timestamp":1780727739983,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba4f64e001N2wyIIT4W5qXFL","messageID":"msg_e9ba4e330001kLRT7xxTWmf3AS","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","snapshot":"6a6aa0fd753670e687801b2a41b4ecc9da0c5a90","type":"step-start"}}
{"type":"tool_use","timestamp":1780727748513,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_e0bbQqmrZVWHcFUc5BM7tkjm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Service-level embedding entrypoints with retry + degraded-state stats.\n2: \n3: Reads provider selection from env (``EMBEDDING_PROVIDER``) when no\n4: tenant override is supplied — both core-api and core-worker drive the\n5: same code path, just with / without ``tenant_config``.\n6: \"\"\"\n7: \n8: from __future__ import annotations\n9: \n10: import asyncio\n11: import logging\n12: import os\n13: import time\n14: from collections.abc import Awaitable, Callable\n15: \n16: from common.embedding._registry import get_embedding_provider\n17: from common.embedding.constants import EMBEDDING_RETRY_ATTEMPTS, EMBEDDING_RETRY_DELAY_S\n18: from common.embedding.protocols import InstructionAwareEmbedder\n19: \n20: logger = logging.getLogger(__name__)\n21: \n22: \n23: class _EmbeddingStats:\n24:     \"\"\"Track failure rate to surface a degraded-provider signal in logs.\n25: \n26:     Three consecutive failures fire a single ERROR log (per cycle) so a\n27:     sustained provider outage shows up loudly without spamming once-per-\n28:     request. Reset on the next success.\n29:     \"\"\"\n30: \n31:     def __init__(self) -> None:\n32:         self.failures = 0\n33:         self.successes = 0\n34:         self.last_failure_time = 0.0\n35:         self.consecutive_failures = 0\n36:         self._lock = asyncio.Lock()\n37: \n38:     async def record_success(self) -> None:\n39:         async with self._lock:\n40:             self.successes += 1\n41:             self.consecutive_failures = 0\n42: \n43:     async def record_failure(self) -> None:\n44:         async with self._lock:\n45:             self.failures += 1\n46:             self.consecutive_failures += 1\n47:             self.last_failure_time = time.monotonic()\n48:             # Fire on first detection (failure 3) and then every 10\n49:             # failures thereafter (13, 23, 33, …). Loud enough to alert\n50:             # on a fresh outage, quiet enough not to spam during a\n51:             # sustained provider degradation. The next success resets\n52:             # the counter, so a subsequent streak re-fires from 3.\n53:             if (\n54:                 self.consecutive_failures >= 3\n55:                 and (self.consecutive_failures - 3) % 10 == 0\n56:             ):\n57:                 logger.error(\n58:                     \"Embedding service degraded: %d consecutive failures (total: %d/%d)\",\n59:                     self.consecutive_failures,\n60:                     self.failures,\n61:                     self.failures + self.successes,\n62:                 )\n63: \n64: \n65: _stats = _EmbeddingStats()\n66: \n67: # One-shot misconfiguration log dedup. The registry raises ``ValueError``\n68: # on env-var misconfig; ``_resolve_provider_or_degrade`` catches it,\n69: # records a failure stat, and returns ``None``. That guard runs on\n70: # every embed/query request, so logging the ERROR unconditionally\n71: # would spam the log at request rate. Keyed on the resolved provider\n72: # name (``\"openai\"``, ``\"vertex\"``, …) so a multi-tenant deployment\n73: # misconfiguring multiple providers still warns once per provider.\n74: # Module-level (process-scoped); restart resets the set, which is\n75: # the right cadence for \"operator forgot a flag\" errors.\n76: _misconfiguration_logged: set[str] = set()\n77: \n78: \n79: def _resolve_provider_name(tenant_config: object | None) -> str:\n80:     \"\"\"Tenant override first, else ``EMBEDDING_PROVIDER`` env, else ``\"fake\"``.\"\"\"\n81:     if tenant_config is not None:\n82:         name = getattr(tenant_config, \"embedding_provider\", None)\n83:         if name:\n84:             return name\n85:     return os.environ.get(\"EMBEDDING_PROVIDER\", \"fake\")\n86: \n87: \n88: async def get_embeddings_batch(\n89:     texts: list[str], tenant_config: object | None = None\n90: ) -> list[list[float]]:\n91:     \"\"\"Generate embeddings for multiple texts in a single API call.\n92: \n93:     Raises on any provider-side error. Bulk callers\n94:     (``memory_service.create_memories_bulk``,\n95:     ``_reembed_batch_via_provider``) already wrap this in\n96:     ``try: ... except Exception:`` and fall back to per-item retries,\n97:     so any exception type is acceptable here — what matters is that\n98:     the failure stats counter increments so the registry-level\n99:     degraded-provider trip-wire fires consistently with the single-embed\n100:     paths (``get_embedding`` / ``get_query_embedding``).\n101: \n102:     Two error shapes are explicitly accounted for:\n103: \n104:     1. ``ValueError`` from ``get_embedding_provider`` — env-var\n105:        misconfiguration (e.g. ``OPENAI_EMBEDDING_BASE_URL`` ⊕\n106:        ``SEND_DIMENSIONS`` mismatch). Used to propagate as an unhandled\n107:        exception that bulk callers caught generically but bypassed\n108:        ``_stats.record_failure``, so the trip-wire never fired under\n109:        sustained misconfig. Now records a failure and re-raises.\n110:     2. Any provider-side exception from ``embed_batch`` — auth, HTTP\n111:        client errors, Vertex quota, etc. Same record_failure + re-raise\n112:        contract as before.\n113:     \"\"\"\n114:     provider_name = _resolve_provider_name(tenant_config)\n115:     # Provider construction and embed dispatch are wrapped in *separate*\n116:     # try/excepts on purpose. Provider implementations (notably\n117:     # ``OpenAIEmbeddingProvider._postprocess``) raise ``ValueError`` at\n118:     # runtime — e.g. when the model returns fewer dimensions than\n119:     # ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``. That is NOT a registry\n120:     # misconfiguration; folding it into the misconfig branch would\n121:     # incorrectly route runtime data errors through the misconfig path.\n122:     #\n123:     # On a registry ``ValueError``, this path logs but does NOT claim\n124:     # the once-per-provider dedup gate (``_misconfiguration_logged``).\n125:     # Bulk-call failures cascade into the per-item ``_reembed_memory``\n126:     # fallback in ``memory_service``, which calls ``get_embedding`` →\n127:     # ``_resolve_provider_or_degrade`` → that path owns the dedup gate\n128:     # (and logs once with full context). If we `.add()` here, the per-\n129:     # item fallback's first ERROR log gets silenced as a duplicate,\n130:     # losing the more useful single-row attribution.\n131:     try:\n132:         provider = get_embedding_provider(provider_name, tenant_config)\n133:     except ValueError:\n134:         logger.error(\n135:             \"Bulk embedding: provider misconfiguration\",\n136:             exc_info=True,\n137:         )\n138:         await _stats.record_failure()\n139:         raise\n140:     try:\n141:         result = await provider.embed_batch(texts)\n142:     except Exception:\n143:         await _stats.record_failure()\n144:         raise\n145:     await _stats.record_success()\n146:     return result\n147: \n148: \n149: async def _run_with_retry(\n150:     make_call: Callable[[], Awaitable[list[float]]],\n151:     context: str,\n152: ) -> list[float] | None:\n153:     \"\"\"Execute *make_call* under the shared retry / stats / logging policy.\n154: \n155:     *make_call* is invoked once per attempt, so it should construct a\n156:     fresh coroutine each time it runs (coroutines aren't reusable across\n157:     awaits). Returns ``None`` after the attempt budget is exhausted —\n158:     callers degrade gracefully (write path persists ``embedding=NULL``;\n159:     search path raises 503 upstream).\n160: \n161:     *context* is a short human-readable label (``\"Embedding\"``,\n162:     ``\"Query embedding\"``) interpolated into the per-attempt warning\n163:     and the terminal error log so failures are attributable.\n164:     \"\"\"\n165:     last_exc: BaseException | None = None\n166:     for attempt in range(1, EMBEDDING_RETRY_ATTEMPTS + 1):\n167:         try:\n168:             result = await make_call()\n169:             await _stats.record_success()\n170:             return result\n171:         # Intentionally broad: must catch all provider-specific errors during retry.\n172:         except Exception as exc:\n173:             # Capture so the terminal log below can attach the stack trace.\n174:             # ``exc_info=True`` outside an except block reads\n175:             # ``sys.exc_info()`` which has been cleared by the time the\n176:             # loop exits, so we have to bind the exception explicitly.\n177:             last_exc = exc\n178:             logger.warning(\n179:                 \"%s attempt %d/%d failed\",\n180:                 context,\n181:                 attempt,\n182:                 EMBEDDING_RETRY_ATTEMPTS,\n183:                 exc_info=True,\n184:             )\n185:             if attempt < EMBEDDING_RETRY_ATTEMPTS:\n186:                 await asyncio.sleep(EMBEDDING_RETRY_DELAY_S * attempt)\n187:     await _stats.record_failure()\n188:     logger.error(\n189:         \"%s failed after %d attempts, returning None\",\n190:         context,\n191:         EMBEDDING_RETRY_ATTEMPTS,\n192:         exc_info=last_exc,\n193:     )\n194:     return None\n195: \n196: \n197: async def _resolve_provider_or_degrade(\n198:     tenant_config: object | None,\n199:     context: str,\n200: ) -> object | None:\n201:     \"\"\"Resolve the embedding provider, mapping a misconfiguration\n202:     ``ValueError`` from the registry to the same ``None`` degradation\n203:     contract the rest of this module documents.\n204: \n205:     ``get_embedding_provider`` raises ``ValueError`` on env-var misconfig\n206:     (``base_url`` ⊕ ``send_dimensions`` mismatch, invalid\n207:     ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``, etc.). Without this guard the\n208:     error would propagate out of ``get_embedding`` / ``get_query_embedding``\n209:     and break callers that rely on \"returns None on failure\" — write\n210:     paths persist rows with ``embedding=NULL`` for later backfill, search\n211:     paths typically translate None → 503. Logging once at error level\n212:     keeps the misconfiguration visible without making the request handler\n213:     crash.\n214:     \"\"\"\n215:     provider_name = _resolve_provider_name(tenant_config)\n216:     try:\n217:         return get_embedding_provider(provider_name, tenant_config)\n218:     except ValueError:\n219:         # Dedup: once-per-provider-name so a misconfigured deployment\n220:         # gets a single ERROR at first request rather than one per\n\n(Showing lines 1-220 of 300. Use offset=221 to continue.)\n</content>","metadata":{"preview":"\"\"\"Service-level embedding entrypoints with retry + degraded-state stats.\n\nReads provider selection from env (``EMBEDDING_PROVIDER``) when no\ntenant override is supplied — both core-api and core-worker drive the\nsame code path, just with / without ``tenant_config``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport os\nimport time\nfrom collections.abc import Awaitable, Callable\n\nfrom common.embedding._registry import get_embedding_provider\nfrom common.embedding.constants import EMBEDDING_RETRY_ATTEMPTS, EMBEDDING_RETRY_DELAY_S\nfrom common.embedding.protocols import InstructionAwareEmbedder\n\nlogger = logging.getLogger(__name__)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","text":"\"\"\"Service-level embedding entrypoints with retry + degraded-state stats.\n\nReads provider selection from env (``EMBEDDING_PROVIDER``) when no\ntenant override is supplied — both core-api and core-worker drive the\nsame code path, just with / without ``tenant_config``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport os\nimport time\nfrom collections.abc import Awaitable, Callable\n\nfrom common.embedding._registry import get_embedding_provider\nfrom common.embedding.constants import EMBEDDING_RETRY_ATTEMPTS, EMBEDDING_RETRY_DELAY_S\nfrom common.embedding.protocols import InstructionAwareEmbedder\n\nlogger = logging.getLogger(__name__)\n\n\nclass _EmbeddingStats:\n    \"\"\"Track failure rate to surface a degraded-provider signal in logs.\n\n    Three consecutive failures fire a single ERROR log (per cycle) so a\n    sustained provider outage shows up loudly without spamming once-per-\n    request. Reset on the next success.\n    \"\"\"\n\n    def __init__(self) -> None:\n        self.failures = 0\n        self.successes = 0\n        self.last_failure_time = 0.0\n        self.consecutive_failures = 0\n        self._lock = asyncio.Lock()\n\n    async def record_success(self) -> None:\n        async with self._lock:\n            self.successes += 1\n            self.consecutive_failures = 0\n\n    async def record_failure(self) -> None:\n        async with self._lock:\n            self.failures += 1\n            self.consecutive_failures += 1\n            self.last_failure_time = time.monotonic()\n            # Fire on first detection (failure 3) and then every 10\n            # failures thereafter (13, 23, 33, …). Loud enough to alert\n            # on a fresh outage, quiet enough not to spam during a\n            # sustained provider degradation. The next success resets\n            # the counter, so a subsequent streak re-fires from 3.\n            if (\n                self.consecutive_failures >= 3\n                and (self.consecutive_failures - 3) % 10 == 0\n            ):\n                logger.error(\n                    \"Embedding service degraded: %d consecutive failures (total: %d/%d)\",\n                    self.consecutive_failures,\n                    self.failures,\n                    self.failures + self.successes,\n                )\n\n\n_stats = _EmbeddingStats()\n\n# One-shot misconfiguration log dedup. The registry raises ``ValueError``\n# on env-var misconfig; ``_resolve_provider_or_degrade`` catches it,\n# records a failure stat, and returns ``None``. That guard runs on\n# every embed/query request, so logging the ERROR unconditionally\n# would spam the log at request rate. Keyed on the resolved provider\n# name (``\"openai\"``, ``\"vertex\"``, …) so a multi-tenant deployment\n# misconfiguring multiple providers still warns once per provider.\n# Module-level (process-scoped); restart resets the set, which is\n# the right cadence for \"operator forgot a flag\" errors.\n_misconfiguration_logged: set[str] = set()\n\n\ndef _resolve_provider_name(tenant_config: object | None) -> str:\n    \"\"\"Tenant override first, else ``EMBEDDING_PROVIDER`` env, else ``\"fake\"``.\"\"\"\n    if tenant_config is not None:\n        name = getattr(tenant_config, \"embedding_provider\", None)\n        if name:\n            return name\n    return os.environ.get(\"EMBEDDING_PROVIDER\", \"fake\")\n\n\nasync def get_embeddings_batch(\n    texts: list[str], tenant_config: object | None = None\n) -> list[list[float]]:\n    \"\"\"Generate embeddings for multiple texts in a single API call.\n\n    Raises on any provider-side error. Bulk callers\n    (``memory_service.create_memories_bulk``,\n    ``_reembed_batch_via_provider``) already wrap this in\n    ``try: ... except Exception:`` and fall back to per-item retries,\n    so any exception type is acceptable here — what matters is that\n    the failure stats counter increments so the registry-level\n    degraded-provider trip-wire fires consistently with the single-embed\n    paths (``get_embedding`` / ``get_query_embedding``).\n\n    Two error shapes are explicitly accounted for:\n\n    1. ``ValueError`` from ``get_embedding_provider`` — env-var\n       misconfiguration (e.g. ``OPENAI_EMBEDDING_BASE_URL`` ⊕\n       ``SEND_DIMENSIONS`` mismatch). Used to propagate as an unhandled\n       exception that bulk callers caught generically but bypassed\n       ``_stats.record_failure``, so the trip-wire never fired under\n       sustained misconfig. Now records a failure and re-raises.\n    2. Any provider-side exception from ``embed_batch`` — auth, HTTP\n       client errors, Vertex quota, etc. Same record_failure + re-raise\n       contract as before.\n    \"\"\"\n    provider_name = _resolve_provider_name(tenant_config)\n    # Provider construction and embed dispatch are wrapped in *separate*\n    # try/excepts on purpose. Provider implementations (notably\n    # ``OpenAIEmbeddingProvider._postprocess``) raise ``ValueError`` at\n    # runtime — e.g. when the model returns fewer dimensions than\n    # ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``. That is NOT a registry\n    # misconfiguration; folding it into the misconfig branch would\n    # incorrectly route runtime data errors through the misconfig path.\n    #\n    # On a registry ``ValueError``, this path logs but does NOT claim\n    # the once-per-provider dedup gate (``_misconfiguration_logged``).\n    # Bulk-call failures cascade into the per-item ``_reembed_memory``\n    # fallback in ``memory_service``, which calls ``get_embedding`` →\n    # ``_resolve_provider_or_degrade`` → that path owns the dedup gate\n    # (and logs once with full context). If we `.add()` here, the per-\n    # item fallback's first ERROR log gets silenced as a duplicate,\n    # losing the more useful single-row attribution.\n    try:\n        provider = get_embedding_provider(provider_name, tenant_config)\n    except ValueError:\n        logger.error(\n            \"Bulk embedding: provider misconfiguration\",\n            exc_info=True,\n        )\n        await _stats.record_failure()\n        raise\n    try:\n        result = await provider.embed_batch(texts)\n    except Exception:\n        await _stats.record_failure()\n        raise\n    await _stats.record_success()\n    return result\n\n\nasync def _run_with_retry(\n    make_call: Callable[[], Awaitable[list[float]]],\n    context: str,\n) -> list[float] | None:\n    \"\"\"Execute *make_call* under the shared retry / stats / logging policy.\n\n    *make_call* is invoked once per attempt, so it should construct a\n    fresh coroutine each time it runs (coroutines aren't reusable across\n    awaits). Returns ``None`` after the attempt budget is exhausted —\n    callers degrade gracefully (write path persists ``embedding=NULL``;\n    search path raises 503 upstream).\n\n    *context* is a short human-readable label (``\"Embedding\"``,\n    ``\"Query embedding\"``) interpolated into the per-attempt warning\n    and the terminal error log so failures are attributable.\n    \"\"\"\n    last_exc: BaseException | None = None\n    for attempt in range(1, EMBEDDING_RETRY_ATTEMPTS + 1):\n        try:\n            result = await make_call()\n            await _stats.record_success()\n            return result\n        # Intentionally broad: must catch all provider-specific errors during retry.\n        except Exception as exc:\n            # Capture so the terminal log below can attach the stack trace.\n            # ``exc_info=True`` outside an except block reads\n            # ``sys.exc_info()`` which has been cleared by the time the\n            # loop exits, so we have to bind the exception explicitly.\n            last_exc = exc\n            logger.warning(\n                \"%s attempt %d/%d failed\",\n                context,\n                attempt,\n                EMBEDDING_RETRY_ATTEMPTS,\n                exc_info=True,\n            )\n            if attempt < EMBEDDING_RETRY_ATTEMPTS:\n                await asyncio.sleep(EMBEDDING_RETRY_DELAY_S * attempt)\n    await _stats.record_failure()\n    logger.error(\n        \"%s failed after %d attempts, returning None\",\n        context,\n        EMBEDDING_RETRY_ATTEMPTS,\n        exc_info=last_exc,\n    )\n    return None\n\n\nasync def _resolve_provider_or_degrade(\n    tenant_config: object | None,\n    context: str,\n) -> object | None:\n    \"\"\"Resolve the embedding provider, mapping a misconfiguration\n    ``ValueError`` from the registry to the same ``None`` degradation\n    contract the rest of this module documents.\n\n    ``get_embedding_provider`` raises ``ValueError`` on env-var misconfig\n    (``base_url`` ⊕ ``send_dimensions`` mismatch, invalid\n    ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``, etc.). Without this guard the\n    error would propagate out of ``get_embedding`` / ``get_query_embedding``\n    and break callers that rely on \"returns None on failure\" — write\n    paths persist rows with ``embedding=NULL`` for later backfill, search\n    paths typically translate None → 503. Logging once at error level\n    keeps the misconfiguration visible without making the request handler\n    crash.\n    \"\"\"\n    provider_name = _resolve_provider_name(tenant_config)\n    try:\n        return get_embedding_provider(provider_name, tenant_config)\n    except ValueError:\n        # Dedup: once-per-provider-name so a misconfigured deployment\n        # gets a single ERROR at first request rather than one per","lineStart":1,"lineEnd":220,"totalLines":300,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","time":{"start":1780727748503,"end":1780727748510}},"metadata":{"openai":{"itemId":"fc_050cfe688c2da96c016a23bfc3d4408191a6e5f1b14c2fa3be"}},"id":"prt_e9ba51651001top0cg4SgP6a85","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba4e330001kLRT7xxTWmf3AS"}}
{"type":"tool_use","timestamp":1780727749043,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_9myg2lSynfJ6GgIeBbMNnDaL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/openai.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/openai.py</path>\n<type>file</type>\n<content>\n1: \"\"\"OpenAI-compatible embedding provider.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import math\n6: \n7: import httpx\n8: import openai\n9: \n10: from common.constants import VECTOR_DIM\n11: from common.embedding.constants import (\n12:     OPENAI_EMBEDDING_MODEL,\n13:     OPENAI_HTTPX_MAX_CONNECTIONS,\n14:     OPENAI_HTTPX_MAX_KEEPALIVE_CONNECTIONS,\n15:     OPENAI_REQUEST_TIMEOUT_SECONDS,\n16: )\n17: \n18: \n19: class OpenAIEmbeddingProvider:\n20:     \"\"\"Embedding provider using the OpenAI embeddings API.\n21: \n22:     Also serves any OpenAI-compatible endpoint (TEI, vLLM, etc.) by setting\n23:     ``base_url``. Supports asymmetric query/doc encoding for instruction-aware\n24:     embedders (Qwen3-Embedding, e5-instruct, ...) via :meth:`embed_query` and\n25:     the ``query_instruction`` constructor arg. Supports Matryoshka-style\n26:     output truncation via ``truncate_to_dim`` so models with native dim\n27:     larger than the pgvector column can be used without a schema migration.\n28:     \"\"\"\n29: \n30:     def __init__(\n31:         self,\n32:         api_key: str,\n33:         model: str = OPENAI_EMBEDDING_MODEL,\n34:         base_url: str | None = None,\n35:         send_dimensions: bool = True,\n36:         query_instruction: str | None = None,\n37:         truncate_to_dim: int | None = None,\n38:     ) -> None:\n39:         self._api_key = api_key\n40:         self._model = model\n41:         self._send_dimensions = send_dimensions\n42:         self._query_instruction = query_instruction\n43:         self._truncate_to_dim = truncate_to_dim\n44:         # Defence in depth: the registry's ``get_embedding_provider``\n45:         # already validates this knob before constructing a provider,\n46:         # but direct construction (a one-off script, a migration helper,\n47:         # a test that mocks the registry) bypasses that path. Without\n48:         # this guard, ``truncate_to_dim=512`` against a 1024-dim schema\n49:         # silently produces 512-element vectors that pgvector rejects\n50:         # at write time with a dim-mismatch error far from the original\n51:         # constructor call. Fail fast at construction instead.\n52:         if truncate_to_dim is not None and truncate_to_dim != VECTOR_DIM:\n53:             raise ValueError(\n54:                 f\"truncate_to_dim={truncate_to_dim} must equal \"\n55:                 f\"VECTOR_DIM={VECTOR_DIM}; this knob is only for truncating a \"\n56:                 \"wider model's native output to the schema dimension.\"\n57:             )\n58:         # Explicit per-call timeout — without this the SDK rides\n59:         # httpx's default 600s read timeout, and a single hung\n60:         # api.openai.com response would silently eat the worker's\n61:         # entire ack budget. Mirrors the same env-driven default that\n62:         # gates ``OpenAILLMProvider``.\n63:         #\n64:         # Explicit ``http_client`` with ``httpx.Limits`` sized for our\n65:         # bulk-write fan-out (CAURA-627). Same rationale as\n66:         # ``OpenAILLMProvider``: the SDK's default httpx pool (100 max\n67:         # / 20 keepalive) saturates under storm load and queues other\n68:         # tenants' embed calls at the pool layer.\n69:         client_kwargs: dict = {\n70:             \"api_key\": api_key,\n71:             \"timeout\": OPENAI_REQUEST_TIMEOUT_SECONDS,\n72:             \"http_client\": httpx.AsyncClient(\n73:                 limits=httpx.Limits(\n74:                     max_connections=OPENAI_HTTPX_MAX_CONNECTIONS,\n75:                     max_keepalive_connections=OPENAI_HTTPX_MAX_KEEPALIVE_CONNECTIONS,\n76:                 ),\n77:             ),\n78:         }\n79:         if base_url:\n80:             client_kwargs[\"base_url\"] = base_url\n81:         self._client = openai.AsyncOpenAI(**client_kwargs)\n82: \n83:     @property\n84:     def provider_name(self) -> str:\n85:         return \"openai\"\n86: \n87:     @property\n88:     def model(self) -> str:\n89:         return self._model\n90: \n91:     async def aclose(self) -> None:\n92:         \"\"\"Close the underlying httpx pool cleanly.\n93: \n94:         Without this, ``asyncio`` debug mode emits ``ResourceWarning:\n95:         Unclosed <httpx.AsyncClient>`` when the provider is GC'd —\n96:         noisy in tests and a leak in long-lived processes that rotate\n97:         client instances. Idempotent; safe to call multiple times.\n98:         \"\"\"\n99:         await self._client.close()\n100: \n101:     def _postprocess(self, emb: list[float]) -> list[float]:\n102:         # Matryoshka truncation: slice to ``truncate_to_dim`` and L2-renormalize.\n103:         # Models trained with MRL (Qwen3-Embedding, jina-v3, snowflake-arctic-l)\n104:         # produce vectors that stay coherent under truncation, but the resulting\n105:         # vector is no longer unit-norm — we re-normalize so cosine similarity\n106:         # at the pgvector layer stays correct.\n107:         # Explicit ``is not None`` rather than truthy check: a\n108:         # hypothetical ``truncate_to_dim=0`` would slip through a\n109:         # truthy gate as \"no truncation\" but is invalid configuration\n110:         # the registry already rejects. Be unambiguous here too.\n111:         if self._truncate_to_dim is not None and len(emb) > self._truncate_to_dim:\n112:             # Slicing a list already returns a new list — no need to\n113:             # wrap in ``list(...)`` (which would allocate a redundant\n114:             # second copy of the truncated data).\n115:             emb = emb[: self._truncate_to_dim]\n116:             n = math.sqrt(sum(x * x for x in emb))\n117:             if n > 0:\n118:                 emb = [x / n for x in emb]\n119:         elif self._truncate_to_dim is not None and len(emb) < self._truncate_to_dim:\n120:             # Undersized passthrough is silently broken: returning a\n121:             # vector with fewer than ``truncate_to_dim`` elements would\n122:             # produce inserts that pgvector rejects with\n123:             # ``expected N dimensions, not M``. Fail fast here so the\n124:             # mismatch is attributable to the model+truncate config,\n125:             # not surfaced obliquely as a write error far downstream.\n126:             raise ValueError(\n127:                 f\"Model returned {len(emb)}-dim vector but truncate_to_dim=\"\n128:                 f\"{self._truncate_to_dim}; the configured model must produce \"\n129:                 f\"at least {self._truncate_to_dim} native dimensions.\"\n130:             )\n131:         return emb\n132: \n133:     async def embed(self, text: str) -> list[float]:\n134:         \"\"\"Generate an embedding vector for a single text (document/ingest path).\"\"\"\n135:         kwargs: dict = {\"model\": self._model, \"input\": text}\n136:         if self._send_dimensions:\n137:             kwargs[\"dimensions\"] = VECTOR_DIM\n138:         response = await self._client.embeddings.create(**kwargs)\n139:         return self._postprocess(response.data[0].embedding)\n140: \n141:     async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n142:         \"\"\"Generate embedding vectors for multiple texts in one call.\"\"\"\n143:         kwargs: dict = {\"model\": self._model, \"input\": texts}\n144:         if self._send_dimensions:\n145:             kwargs[\"dimensions\"] = VECTOR_DIM\n146:         response = await self._client.embeddings.create(**kwargs)\n147:         # OpenAI returns embeddings sorted by index\n148:         sorted_data = sorted(response.data, key=lambda x: x.index)\n149:         return [self._postprocess(item.embedding) for item in sorted_data]\n150: \n151:     async def embed_query(\n152:         self, text: str, instruction: str | None = None\n153:     ) -> list[float]:\n154:         \"\"\"Generate an embedding vector for a search-side query.\n155: \n156:         For instruction-aware models (Qwen3-Embedding, e5-instruct), prepends\n157:         the resolved instruction in the convention these models were trained\n158:         with: ``\"Instruct: <task>\\\\nQuery: <text>\"``. The instruction is\n159:         resolved as: per-call *instruction* arg → constructor\n160:         *query_instruction* → no prefix.\n161: \n162:         For symmetric models (bge-m3, snowflake-arctic-l, gte-en-v1.5,\n163:         OpenAI text-embedding-3-small), pass no instruction at construction\n164:         time and this is equivalent to :meth:`embed`.\n165:         \"\"\"\n166:         instr = instruction or self._query_instruction\n167:         if instr:\n168:             text = f\"Instruct: {instr}\\nQuery: {text}\"\n169:         return await self.embed(text)\n\n(End of file - total 169 lines)\n</content>","metadata":{"preview":"\"\"\"OpenAI-compatible embedding provider.\"\"\"\n\nfrom __future__ import annotations\n\nimport math\n\nimport httpx\nimport openai\n\nfrom common.constants import VECTOR_DIM\nfrom common.embedding.constants import (\n    OPENAI_EMBEDDING_MODEL,\n    OPENAI_HTTPX_MAX_CONNECTIONS,\n    OPENAI_HTTPX_MAX_KEEPALIVE_CONNECTIONS,\n    OPENAI_REQUEST_TIMEOUT_SECONDS,\n)\n\n\nclass OpenAIEmbeddingProvider:\n    \"\"\"Embedding provider using the OpenAI embeddings API.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/openai.py","text":"\"\"\"OpenAI-compatible embedding provider.\"\"\"\n\nfrom __future__ import annotations\n\nimport math\n\nimport httpx\nimport openai\n\nfrom common.constants import VECTOR_DIM\nfrom common.embedding.constants import (\n    OPENAI_EMBEDDING_MODEL,\n    OPENAI_HTTPX_MAX_CONNECTIONS,\n    OPENAI_HTTPX_MAX_KEEPALIVE_CONNECTIONS,\n    OPENAI_REQUEST_TIMEOUT_SECONDS,\n)\n\n\nclass OpenAIEmbeddingProvider:\n    \"\"\"Embedding provider using the OpenAI embeddings API.\n\n    Also serves any OpenAI-compatible endpoint (TEI, vLLM, etc.) by setting\n    ``base_url``. Supports asymmetric query/doc encoding for instruction-aware\n    embedders (Qwen3-Embedding, e5-instruct, ...) via :meth:`embed_query` and\n    the ``query_instruction`` constructor arg. Supports Matryoshka-style\n    output truncation via ``truncate_to_dim`` so models with native dim\n    larger than the pgvector column can be used without a schema migration.\n    \"\"\"\n\n    def __init__(\n        self,\n        api_key: str,\n        model: str = OPENAI_EMBEDDING_MODEL,\n        base_url: str | None = None,\n        send_dimensions: bool = True,\n        query_instruction: str | None = None,\n        truncate_to_dim: int | None = None,\n    ) -> None:\n        self._api_key = api_key\n        self._model = model\n        self._send_dimensions = send_dimensions\n        self._query_instruction = query_instruction\n        self._truncate_to_dim = truncate_to_dim\n        # Defence in depth: the registry's ``get_embedding_provider``\n        # already validates this knob before constructing a provider,\n        # but direct construction (a one-off script, a migration helper,\n        # a test that mocks the registry) bypasses that path. Without\n        # this guard, ``truncate_to_dim=512`` against a 1024-dim schema\n        # silently produces 512-element vectors that pgvector rejects\n        # at write time with a dim-mismatch error far from the original\n        # constructor call. Fail fast at construction instead.\n        if truncate_to_dim is not None and truncate_to_dim != VECTOR_DIM:\n            raise ValueError(\n                f\"truncate_to_dim={truncate_to_dim} must equal \"\n                f\"VECTOR_DIM={VECTOR_DIM}; this knob is only for truncating a \"\n                \"wider model's native output to the schema dimension.\"\n            )\n        # Explicit per-call timeout — without this the SDK rides\n        # httpx's default 600s read timeout, and a single hung\n        # api.openai.com response would silently eat the worker's\n        # entire ack budget. Mirrors the same env-driven default that\n        # gates ``OpenAILLMProvider``.\n        #\n        # Explicit ``http_client`` with ``httpx.Limits`` sized for our\n        # bulk-write fan-out (CAURA-627). Same rationale as\n        # ``OpenAILLMProvider``: the SDK's default httpx pool (100 max\n        # / 20 keepalive) saturates under storm load and queues other\n        # tenants' embed calls at the pool layer.\n        client_kwargs: dict = {\n            \"api_key\": api_key,\n            \"timeout\": OPENAI_REQUEST_TIMEOUT_SECONDS,\n            \"http_client\": httpx.AsyncClient(\n                limits=httpx.Limits(\n                    max_connections=OPENAI_HTTPX_MAX_CONNECTIONS,\n                    max_keepalive_connections=OPENAI_HTTPX_MAX_KEEPALIVE_CONNECTIONS,\n                ),\n            ),\n        }\n        if base_url:\n            client_kwargs[\"base_url\"] = base_url\n        self._client = openai.AsyncOpenAI(**client_kwargs)\n\n    @property\n    def provider_name(self) -> str:\n        return \"openai\"\n\n    @property\n    def model(self) -> str:\n        return self._model\n\n    async def aclose(self) -> None:\n        \"\"\"Close the underlying httpx pool cleanly.\n\n        Without this, ``asyncio`` debug mode emits ``ResourceWarning:\n        Unclosed <httpx.AsyncClient>`` when the provider is GC'd —\n        noisy in tests and a leak in long-lived processes that rotate\n        client instances. Idempotent; safe to call multiple times.\n        \"\"\"\n        await self._client.close()\n\n    def _postprocess(self, emb: list[float]) -> list[float]:\n        # Matryoshka truncation: slice to ``truncate_to_dim`` and L2-renormalize.\n        # Models trained with MRL (Qwen3-Embedding, jina-v3, snowflake-arctic-l)\n        # produce vectors that stay coherent under truncation, but the resulting\n        # vector is no longer unit-norm — we re-normalize so cosine similarity\n        # at the pgvector layer stays correct.\n        # Explicit ``is not None`` rather than truthy check: a\n        # hypothetical ``truncate_to_dim=0`` would slip through a\n        # truthy gate as \"no truncation\" but is invalid configuration\n        # the registry already rejects. Be unambiguous here too.\n        if self._truncate_to_dim is not None and len(emb) > self._truncate_to_dim:\n            # Slicing a list already returns a new list — no need to\n            # wrap in ``list(...)`` (which would allocate a redundant\n            # second copy of the truncated data).\n            emb = emb[: self._truncate_to_dim]\n            n = math.sqrt(sum(x * x for x in emb))\n            if n > 0:\n                emb = [x / n for x in emb]\n        elif self._truncate_to_dim is not None and len(emb) < self._truncate_to_dim:\n            # Undersized passthrough is silently broken: returning a\n            # vector with fewer than ``truncate_to_dim`` elements would\n            # produce inserts that pgvector rejects with\n            # ``expected N dimensions, not M``. Fail fast here so the\n            # mismatch is attributable to the model+truncate config,\n            # not surfaced obliquely as a write error far downstream.\n            raise ValueError(\n                f\"Model returned {len(emb)}-dim vector but truncate_to_dim=\"\n                f\"{self._truncate_to_dim}; the configured model must produce \"\n                f\"at least {self._truncate_to_dim} native dimensions.\"\n            )\n        return emb\n\n    async def embed(self, text: str) -> list[float]:\n        \"\"\"Generate an embedding vector for a single text (document/ingest path).\"\"\"\n        kwargs: dict = {\"model\": self._model, \"input\": text}\n        if self._send_dimensions:\n            kwargs[\"dimensions\"] = VECTOR_DIM\n        response = await self._client.embeddings.create(**kwargs)\n        return self._postprocess(response.data[0].embedding)\n\n    async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n        \"\"\"Generate embedding vectors for multiple texts in one call.\"\"\"\n        kwargs: dict = {\"model\": self._model, \"input\": texts}\n        if self._send_dimensions:\n            kwargs[\"dimensions\"] = VECTOR_DIM\n        response = await self._client.embeddings.create(**kwargs)\n        # OpenAI returns embeddings sorted by index\n        sorted_data = sorted(response.data, key=lambda x: x.index)\n        return [self._postprocess(item.embedding) for item in sorted_data]\n\n    async def embed_query(\n        self, text: str, instruction: str | None = None\n    ) -> list[float]:\n        \"\"\"Generate an embedding vector for a search-side query.\n\n        For instruction-aware models (Qwen3-Embedding, e5-instruct), prepends\n        the resolved instruction in the convention these models were trained\n        with: ``\"Instruct: <task>\\\\nQuery: <text>\"``. The instruction is\n        resolved as: per-call *instruction* arg → constructor\n        *query_instruction* → no prefix.\n\n        For symmetric models (bge-m3, snowflake-arctic-l, gte-en-v1.5,\n        OpenAI text-embedding-3-small), pass no instruction at construction\n        time and this is equivalent to :meth:`embed`.\n        \"\"\"\n        instr = instruction or self._query_instruction\n        if instr:\n            text = f\"Instruct: {instr}\\nQuery: {text}\"\n        return await self.embed(text)","lineStart":1,"lineEnd":169,"totalLines":169,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/openai.py","time":{"start":1780727749034,"end":1780727749041}},"metadata":{"openai":{"itemId":"fc_050cfe688c2da96c016a23bfc3d45481919672b6cde463911d"}},"id":"prt_e9ba51804001msMDdvT771XENR","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba4e330001kLRT7xxTWmf3AS"}}
{"type":"tool_use","timestamp":1780727749508,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_Pu8kzrzW0qBlCPtNdRkNGQqU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/local.py","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/local.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Local embedding provider using sentence-transformers.\n2: \n3: Runs a local model (default: BAAI/bge-base-en-v1.5) for embedding generation.\n4: The sentence-transformers package is lazy-imported so it remains an optional\n5: dependency.\n6: \"\"\"\n7: \n8: from __future__ import annotations\n9: \n10: import asyncio\n11: import logging\n12: \n13: from common.constants import VECTOR_DIM\n14: \n15: logger = logging.getLogger(__name__)\n16: \n17: \n18: class LocalEmbedding:\n19:     \"\"\"Embedding provider backed by a local sentence-transformers model.\"\"\"\n20: \n21:     def __init__(self, model_name: str = \"BAAI/bge-base-en-v1.5\") -> None:\n22:         self._model_name = model_name\n23:         self._model = None\n24:         self._load_lock = asyncio.Lock()\n25: \n26:     @property\n27:     def provider_name(self) -> str:\n28:         return \"local\"\n29: \n30:     @property\n31:     def model(self) -> str:\n32:         return self._model_name\n33: \n34:     # ------------------------------------------------------------------\n35:     # Internal helpers\n36:     # ------------------------------------------------------------------\n37: \n38:     async def _ensure_model(self) -> None:\n39:         if self._model is not None:\n40:             return\n41:         async with self._load_lock:\n42:             if self._model is not None:\n43:                 return\n44:             try:\n45:                 from sentence_transformers import SentenceTransformer\n46:             except ImportError:\n47:                 raise ImportError(\n48:                     \"sentence-transformers is required for local embeddings. \"\n49:                     \"Install it with: pip install sentence-transformers\"\n50:                 ) from None\n51:             logger.info(\"Loading local embedding model: %s\", self._model_name)\n52:             loop = asyncio.get_running_loop()\n53:             model = await loop.run_in_executor(\n54:                 None, lambda: SentenceTransformer(self._model_name)\n55:             )\n56:             test_dim = model.get_sentence_embedding_dimension()\n57:             if test_dim != VECTOR_DIM:\n58:                 logger.warning(\n59:                     \"Model %s produces %d-dim vectors, expected %d (VECTOR_DIM)\",\n60:                     self._model_name,\n61:                     test_dim,\n62:                     VECTOR_DIM,\n63:                 )\n64:             self._model = model\n65: \n66:     # ------------------------------------------------------------------\n67:     # Public API\n68:     # ------------------------------------------------------------------\n69: \n70:     async def embed(self, text: str) -> list[float]:\n71:         \"\"\"Embed a single text string.\"\"\"\n72:         await self._ensure_model()\n73:         loop = asyncio.get_running_loop()\n74:         vec = await loop.run_in_executor(\n75:             None,\n76:             lambda: self._model.encode(text, normalize_embeddings=True),\n77:         )\n78:         return vec.tolist()\n79: \n80:     async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n81:         \"\"\"Embed a batch of texts.\"\"\"\n82:         await self._ensure_model()\n83:         loop = asyncio.get_running_loop()\n84:         vecs = await loop.run_in_executor(\n85:             None,\n86:             lambda: self._model.encode(texts, normalize_embeddings=True, batch_size=32),\n87:         )\n88:         return vecs.tolist()\n89: \n90:     # Deliberately does NOT implement ``embed_query`` — sentence-\n91:     # transformers models served here (default ``BAAI/bge-base-en-v1.5``)\n92:     # are symmetric encoders with no query-side instruction prefix. The\n93:     # query path falls back to :meth:`embed` via the\n94:     # ``hasattr(provider, \"embed_query\")`` check in\n95:     # :func:`common.embedding._service.get_query_embedding`.\n\n(End of file - total 95 lines)\n</content>","metadata":{"preview":"\"\"\"Local embedding provider using sentence-transformers.\n\nRuns a local model (default: BAAI/bge-base-en-v1.5) for embedding generation.\nThe sentence-transformers package is lazy-imported so it remains an optional\ndependency.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\n\nfrom common.constants import VECTOR_DIM\n\nlogger = logging.getLogger(__name__)\n\n\nclass LocalEmbedding:\n    \"\"\"Embedding provider backed by a local sentence-transformers model.\"\"\"\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/local.py","text":"\"\"\"Local embedding provider using sentence-transformers.\n\nRuns a local model (default: BAAI/bge-base-en-v1.5) for embedding generation.\nThe sentence-transformers package is lazy-imported so it remains an optional\ndependency.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\n\nfrom common.constants import VECTOR_DIM\n\nlogger = logging.getLogger(__name__)\n\n\nclass LocalEmbedding:\n    \"\"\"Embedding provider backed by a local sentence-transformers model.\"\"\"\n\n    def __init__(self, model_name: str = \"BAAI/bge-base-en-v1.5\") -> None:\n        self._model_name = model_name\n        self._model = None\n        self._load_lock = asyncio.Lock()\n\n    @property\n    def provider_name(self) -> str:\n        return \"local\"\n\n    @property\n    def model(self) -> str:\n        return self._model_name\n\n    # ------------------------------------------------------------------\n    # Internal helpers\n    # ------------------------------------------------------------------\n\n    async def _ensure_model(self) -> None:\n        if self._model is not None:\n            return\n        async with self._load_lock:\n            if self._model is not None:\n                return\n            try:\n                from sentence_transformers import SentenceTransformer\n            except ImportError:\n                raise ImportError(\n                    \"sentence-transformers is required for local embeddings. \"\n                    \"Install it with: pip install sentence-transformers\"\n                ) from None\n            logger.info(\"Loading local embedding model: %s\", self._model_name)\n            loop = asyncio.get_running_loop()\n            model = await loop.run_in_executor(\n                None, lambda: SentenceTransformer(self._model_name)\n            )\n            test_dim = model.get_sentence_embedding_dimension()\n            if test_dim != VECTOR_DIM:\n                logger.warning(\n                    \"Model %s produces %d-dim vectors, expected %d (VECTOR_DIM)\",\n                    self._model_name,\n                    test_dim,\n                    VECTOR_DIM,\n                )\n            self._model = model\n\n    # ------------------------------------------------------------------\n    # Public API\n    # ------------------------------------------------------------------\n\n    async def embed(self, text: str) -> list[float]:\n        \"\"\"Embed a single text string.\"\"\"\n        await self._ensure_model()\n        loop = asyncio.get_running_loop()\n        vec = await loop.run_in_executor(\n            None,\n            lambda: self._model.encode(text, normalize_embeddings=True),\n        )\n        return vec.tolist()\n\n    async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n        \"\"\"Embed a batch of texts.\"\"\"\n        await self._ensure_model()\n        loop = asyncio.get_running_loop()\n        vecs = await loop.run_in_executor(\n            None,\n            lambda: self._model.encode(texts, normalize_embeddings=True, batch_size=32),\n        )\n        return vecs.tolist()\n\n    # Deliberately does NOT implement ``embed_query`` — sentence-\n    # transformers models served here (default ``BAAI/bge-base-en-v1.5``)\n    # are symmetric encoders with no query-side instruction prefix. The\n    # query path falls back to :meth:`embed` via the\n    # ``hasattr(provider, \"embed_query\")`` check in\n    # :func:`common.embedding._service.get_query_embedding`.","lineStart":1,"lineEnd":95,"totalLines":95,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/providers/local.py","time":{"start":1780727749499,"end":1780727749506}},"metadata":{"openai":{"itemId":"fc_050cfe688c2da96c016a23bfc3d45c81918225d7a882fbc4c6"}},"id":"prt_e9ba519cd001rMUTigWm6cqdnF","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba4e330001kLRT7xxTWmf3AS"}}
{"type":"tool_use","timestamp":1780727749789,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_WqBdZsRg1nm83uXAj8vThYjf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Embedding-provider protocols shared across services.\n2: \n3: Two protocols, by design split:\n4: \n5: * :class:`EmbeddingProvider` — the symmetric core every provider must\n6:   implement (``embed``, ``embed_batch``, ``provider_name``, ``model``).\n7:   Conformance held by ``Fake``, ``Local``, ``Vertex``, and\n8:   ``OpenAIEmbeddingProvider``.\n9: \n10: * :class:`InstructionAwareEmbedder` — the optional extension for models\n11:   trained with asymmetric query/document encoding (Qwen3-Embedding,\n12:   e5-instruct, KaLM). Conformance held by ``OpenAIEmbeddingProvider``\n13:   only — when pointed at an instruction-aware model. Symmetric providers\n14:   deliberately do NOT implement this; callers (see\n15:   :func:`common.embedding._service.get_query_embedding`) ``hasattr``-check\n16:   and fall back to :meth:`EmbeddingProvider.embed`.\n17: \n18: Splitting the protocols keeps ``runtime_checkable`` honest:\n19: ``isinstance(p, EmbeddingProvider)`` is true for every provider without\n20: forcing a no-op shim onto symmetric ones. The narrower protocol expresses\n21: real capability rather than protocol-conformance ceremony.\n22: \"\"\"\n23: \n24: from __future__ import annotations\n25: \n26: from typing import Protocol, runtime_checkable\n27: \n28: \n29: @runtime_checkable\n30: class EmbeddingProvider(Protocol):\n31:     \"\"\"Async embedding provider for single and batch text embedding.\"\"\"\n32: \n33:     @property\n34:     def provider_name(self) -> str: ...\n35: \n36:     @property\n37:     def model(self) -> str: ...\n38: \n39:     async def embed(self, text: str) -> list[float]:\n40:         \"\"\"Generate an embedding vector for a single text.\n41: \n42:         The returned vector size is determined by the provider and model\n43:         configuration. Callers should not assume a specific dimensionality\n44:         — the system-wide ``VECTOR_DIM`` constant and the pgvector column\n45:         definition enforce consistency at the storage layer.\n46:         \"\"\"\n47:         ...\n48: \n49:     async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n50:         \"\"\"Generate embedding vectors for multiple texts in one call.\n51: \n52:         Same dimensionality contract as :meth:`embed`.\n53:         \"\"\"\n54:         ...\n55: \n56: \n57: @runtime_checkable\n58: class InstructionAwareEmbedder(Protocol):\n59:     \"\"\"Optional extension for models with asymmetric query/document encoding.\n60: \n61:     Instruction-aware embedders (Qwen3-Embedding, e5-instruct, KaLM-Gemma3,\n62:     …) train the query-side encoder to expect a task-description prefix\n63:     that documents do not receive. A provider conforming to this protocol\n64:     must:\n65: \n66:     * Apply the prefix on :meth:`embed_query` only — never on the\n67:       document path (:meth:`EmbeddingProvider.embed`).\n68:     * Resolve *instruction* in this order: per-call arg → constructor\n69:       default → no prefix (degenerates to :meth:`embed`).\n70: \n71:     Symmetric providers (``Fake``, ``Local``, ``Vertex``,\n72:     OpenAI ``text-embedding-3-small``, ``bge-m3``, ``gte-en-v1.5``) do\n73:     **not** implement this protocol. The query path\n74:     (:func:`common.embedding._service.get_query_embedding`) checks\n75:     ``isinstance(provider, InstructionAwareEmbedder)`` (or, equivalently,\n76:     ``hasattr(provider, \"embed_query\")``) and falls back to\n77:     :meth:`EmbeddingProvider.embed` when absent.\n78:     \"\"\"\n79: \n80:     async def embed_query(\n81:         self, text: str, instruction: str | None = None\n82:     ) -> list[float]:\n83:         \"\"\"Generate an embedding vector for a search-side query.\"\"\"\n84:         ...\n\n(End of file - total 84 lines)\n</content>","metadata":{"preview":"\"\"\"Embedding-provider protocols shared across services.\n\nTwo protocols, by design split:\n\n* :class:`EmbeddingProvider` — the symmetric core every provider must\n  implement (``embed``, ``embed_batch``, ``provider_name``, ``model``).\n  Conformance held by ``Fake``, ``Local``, ``Vertex``, and\n  ``OpenAIEmbeddingProvider``.\n\n* :class:`InstructionAwareEmbedder` — the optional extension for models\n  trained with asymmetric query/document encoding (Qwen3-Embedding,\n  e5-instruct, KaLM). Conformance held by ``OpenAIEmbeddingProvider``\n  only — when pointed at an instruction-aware model. Symmetric providers\n  deliberately do NOT implement this; callers (see\n  :func:`common.embedding._service.get_query_embedding`) ``hasattr``-check\n  and fall back to :meth:`EmbeddingProvider.embed`.\n\nSplitting the protocols keeps ``runtime_checkable`` honest:\n``isinstance(p, EmbeddingProvider)`` is true for every provider without\nforcing a no-op shim onto symmetric ones. The narrower protocol expresses","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py","text":"\"\"\"Embedding-provider protocols shared across services.\n\nTwo protocols, by design split:\n\n* :class:`EmbeddingProvider` — the symmetric core every provider must\n  implement (``embed``, ``embed_batch``, ``provider_name``, ``model``).\n  Conformance held by ``Fake``, ``Local``, ``Vertex``, and\n  ``OpenAIEmbeddingProvider``.\n\n* :class:`InstructionAwareEmbedder` — the optional extension for models\n  trained with asymmetric query/document encoding (Qwen3-Embedding,\n  e5-instruct, KaLM). Conformance held by ``OpenAIEmbeddingProvider``\n  only — when pointed at an instruction-aware model. Symmetric providers\n  deliberately do NOT implement this; callers (see\n  :func:`common.embedding._service.get_query_embedding`) ``hasattr``-check\n  and fall back to :meth:`EmbeddingProvider.embed`.\n\nSplitting the protocols keeps ``runtime_checkable`` honest:\n``isinstance(p, EmbeddingProvider)`` is true for every provider without\nforcing a no-op shim onto symmetric ones. The narrower protocol expresses\nreal capability rather than protocol-conformance ceremony.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Protocol, runtime_checkable\n\n\n@runtime_checkable\nclass EmbeddingProvider(Protocol):\n    \"\"\"Async embedding provider for single and batch text embedding.\"\"\"\n\n    @property\n    def provider_name(self) -> str: ...\n\n    @property\n    def model(self) -> str: ...\n\n    async def embed(self, text: str) -> list[float]:\n        \"\"\"Generate an embedding vector for a single text.\n\n        The returned vector size is determined by the provider and model\n        configuration. Callers should not assume a specific dimensionality\n        — the system-wide ``VECTOR_DIM`` constant and the pgvector column\n        definition enforce consistency at the storage layer.\n        \"\"\"\n        ...\n\n    async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n        \"\"\"Generate embedding vectors for multiple texts in one call.\n\n        Same dimensionality contract as :meth:`embed`.\n        \"\"\"\n        ...\n\n\n@runtime_checkable\nclass InstructionAwareEmbedder(Protocol):\n    \"\"\"Optional extension for models with asymmetric query/document encoding.\n\n    Instruction-aware embedders (Qwen3-Embedding, e5-instruct, KaLM-Gemma3,\n    …) train the query-side encoder to expect a task-description prefix\n    that documents do not receive. A provider conforming to this protocol\n    must:\n\n    * Apply the prefix on :meth:`embed_query` only — never on the\n      document path (:meth:`EmbeddingProvider.embed`).\n    * Resolve *instruction* in this order: per-call arg → constructor\n      default → no prefix (degenerates to :meth:`embed`).\n\n    Symmetric providers (``Fake``, ``Local``, ``Vertex``,\n    OpenAI ``text-embedding-3-small``, ``bge-m3``, ``gte-en-v1.5``) do\n    **not** implement this protocol. The query path\n    (:func:`common.embedding._service.get_query_embedding`) checks\n    ``isinstance(provider, InstructionAwareEmbedder)`` (or, equivalently,\n    ``hasattr(provider, \"embed_query\")``) and falls back to\n    :meth:`EmbeddingProvider.embed` when absent.\n    \"\"\"\n\n    async def embed_query(\n        self, text: str, instruction: str | None = None\n    ) -> list[float]:\n        \"\"\"Generate an embedding vector for a search-side query.\"\"\"\n        ...","lineStart":1,"lineEnd":84,"totalLines":84,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py","time":{"start":1780727749785,"end":1780727749788}},"metadata":{"openai":{"itemId":"fc_050cfe688c2da96c016a23bfc3d4688191a56061e32638fb5f"}},"id":"prt_e9ba51b7d001ruNKR5mrruzPgR","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba4e330001kLRT7xxTWmf3AS"}}
