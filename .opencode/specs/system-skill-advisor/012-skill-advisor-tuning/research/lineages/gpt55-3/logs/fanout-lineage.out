nst degradedLanes = laneHealth\n659:     .filter((lane) => lane.status === 'runtime_degraded')\n660:     .map((lane) => lane.lane);\n661:   const runtimeDegradedLanes = new Set(degradedLanes);\n662:   const graphConflictIndex = buildConflictMatchIndex(graphConflictMatches);\n663:   const rrfFusion = useRrfFusion\n664:     ? fuseAdvisorLaneRanks(laneScores, weights, disabled, runtimeDegradedLanes)\n665:     : null;\n666:   const laneScoreIndexes = Object.fromEntries(\n667:     SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n668:   ) as Record<ScorerLane, LaneMatchIndex>;\n669:   const liveTotal = SCORER_LANES\n670:     .filter((lane) => !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n671:     .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n672:   const runtimeLiveLaneCount = SCORER_LANES\n673:     .filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n674:     .length;\n675:   if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n676:     for (const lane of SCORER_LANES) {\n677:       if (!isLiveScorerLane(lane) || disabled.has(lane) || runtimeDegradedLanes.has(lane)) continue;\n678:       speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n679:     }\n680:   }\n681:   const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n682:   const hasTaskIntent = TASK_INTENT.test(promptLower);\n683:   const recommendations: AdvisorScoredRecommendation[] = [];\n684: \n685:   for (const skill of projection.skills) {\n686:     if (!isDefaultRoutable(promptLower, skill)) continue;\n687:     const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n688:       const laneMatch = laneScoreIndexes[lane].get(skill.id);\n689:       const rawScore = laneMatch?.rawScore ?? 0;\n690:       const shadowOnly = !isLiveScorerLane(lane);\n691:       const runtimeDegraded = runtimeDegradedLanes.has(lane);\n692:       return {\n693:         lane,\n694:         rawScore,\n695:         weightedScore: shadowOnly || disabled.has(lane) || runtimeDegraded ? 0 : rawScore * weights[lane],\n696:         weight: disabled.has(lane) || runtimeDegraded ? 0 : weights[lane],\n697:         evidence: laneMatch?.evidence ?? [],\n698:         shadowOnly,\n699:       };\n700:     });\n701:     const weightedScore = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n702:     const rrfScore = rrfFusion?.scoreBySkill.get(skill.id);\n703:     const score = useRrfFusion ? rrfScore ?? 0 : weightedScore;\n704:     if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n705:     if (isSpeckitMetricsEnabled()) {\n706:       for (const contribution of contributions) {\n707:         if (contribution.weightedScore !== 0) {\n708:           speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n709:         }\n710:       }\n711:     }\n712: \n713:     const directScore = Math.max(\n714:       contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n715:       contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n716:     );\n717:     const derivedDominant = isDerivedDominant(contributions);\n718:     const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n719:     const explicitMatch = laneScoreIndexes.explicit_author.get(skill.id);\n720:     const liveNormalized = score / liveTotal;\n721:     let confidence = confidenceFor({\n722:       liveNormalized,\n723:       directScore,\n724:       readOnlyExplainer,\n725:       hasExplicitWorkflowSignal: explicitSignal,\n726:       hasTaskIntent,\n727:       readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n728:       derivedDominant,\n729:       skillId: skill.id,\n730:       selfRecommendationGuardEnabled,\n731:       hasAdvisorSelfAuthoredSignal: hasAdvisorSelfAuthoredSignal(skill.id, explicitMatch),\n732:     });\n733:     if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n734:       confidence = Math.min(confidence, 0.49);\n735:     }\n736:     recommendations.push({\n737:       skill: skill.id,\n738:       kind: skill.kind,\n739:       confidence,\n740:       uncertainty: uncertaintyFor(contributions, confidence, 0),\n741:       passes_threshold: false,\n742:       reason: attributionReason(contributions),\n743:       score: useRrfFusion ? score : Number(score.toFixed(6)),\n744:       laneContributions: contributions,\n745:       dominantLane: dominantLane(contributions),\n746:       redirectTo: skill.redirectTo ?? undefined,\n747:       redirectFrom: skill.redirectFrom,\n748:       lifecycleStatus: skill.lifecycleStatus,\n749:     });\n750:   }\n751: \n752:   if (isSpeckitMetricsEnabled()) {\n753:     for (const recommendation of recommendations) {\n754:       if (primaryIntentBonus(promptLower, recommendation, selfRecommendationGuardEnabled) !== 0) {\n755:         speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n756:       }\n757:       if (useRrfFusion && graphConflictAdjustment(graphConflictIndex, recommendation) !== 0) {\n758:         speckitMetrics.incrementCounter('spec_kit.scorer.graph_conflict_demote_applied_total', { skill_id: recommendation.skill });\n759:       }\n760:     }\n761:   }\n762:   const exactSemanticRerankIndex = useExactSemanticRerank\n763:     ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n764:     : new Map<string, ExactSemanticRerankEntry>();\n765:   let ranked = recommendations.sort((left, right) => {\n766:     const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n767:     const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n768:     const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n769:     const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n770:     const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n771:     const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n772:     const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n773:       - (left.score + leftCommandBonus + leftIntent + leftConflict);\n774:     if (useRrfFusion) {\n775:       const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n776:       const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n777:       if (leftExactSemantic !== null\n778:         && rightExactSemantic !== null\n779:         && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {\n780:         const exactSemanticDiff = rightExactSemantic - leftExactSemantic;\n781:         if (exactSemanticDiff !== 0) {\n782:           return exactSemanticDiff;\n783:         }\n784:       }\n785:       return adjustedScoreDiff\n786:         || rrfRankFor(rrfFusion, left) - rrfRankFor(rrfFusion, right)\n787:         || left.skill.localeCompare(right.skill);\n788:     }\n789:     return adjustedScoreDiff\n790:       || right.confidence - left.confidence\n791:       || left.skill.localeCompare(right.skill);\n792:   });\n793: \n794:   ranked = ranked.map((recommendation, index) => {\n795:     const next = ranked[index + 1];\n796:     const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n797:     const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n798:     return {\n799:       ...recommendation,\n800:       uncertainty,\n801:       passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n802:         && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n803:     };\n804:   });\n805:   ranked = applyAmbiguity(ranked);\n806: \n807:   // Low-information ambiguity abstention: a short, intent-less prompt that lands\n808:   // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n809:   // every cluster member's uncertainty above the strict threshold so strict\n810:   // callers abstain, while confidence-only callers still surface the best guess\n811:   // (the disambiguated top-ranked candidate).\n812:   const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n813:   const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n814:   if (lowInfoPrompt) {\n815:     const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n816:     // Only abstain when the cluster's lead is built from diffuse, shared\n817:     // single-word keyword matches rather than a distinctive multi-word phrase\n818:     // anchor (an explicit-author/derived phrase match such as \"code audit\").\n819:     // A multi-word anchor means the prompt does pin a specific skill, so it\n\n(Showing lines 630-819 of 911. Use offset=820 to continue.)\n</content>","metadata":{"preview":"    if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n  }\n  return 0;\n}\n\nexport function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n  const promptLower = prompt.toLowerCase();\n  const queryClass = classifyAdvisorQuery(promptLower);\n  const weights = effectiveScorerWeights(\n    options.laneWeightsOverride,\n    isAdvisorQueryClassRouting