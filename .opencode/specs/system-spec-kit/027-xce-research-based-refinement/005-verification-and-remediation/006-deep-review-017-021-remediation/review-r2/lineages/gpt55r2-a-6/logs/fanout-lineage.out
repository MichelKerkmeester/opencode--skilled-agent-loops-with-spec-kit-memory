on\",\"mode\":\"review\",\"sessionId\":\"fanout-gpt55r2-a-6-1781761314338-6u1ztm\",\"iteration\":1,\"dimension\":\"correctness\",\"focus\":\"search/retrieval numeric score normalization and read-path fallback seams\",\"status\":\"complete\",\"verdict\":\"CONDITIONAL\",\"newInfoRatio\":1,\"severityCounts\":{\"P0\":0,\"P1\":1,\"P2\":0},\"findings\":[{\"id\":\"gpt55r2-a-6-F001\",\"severity\":\"P1\",\"category\":\"correctness\",\"title\":\"Folder boost demotes scoped hits by capping 0-100 similarity at 1.0\",\"evidenceRefs\":[\".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts:651-676\",\".opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts:85-103\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts:57-75\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts:1326-1334\",\".opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts:96-124\"],\"status\":\"open\"}],\"timestamp\":\"2026-06-18T06:05:37Z\"}\n+{\"type\":\"event\",\"event\":\"phase_synthesis\",\"mode\":\"review\",\"sessionId\":\"fanout-gpt55r2-a-6-1781761314338-6u1ztm\",\"status\":\"complete\",\"verdict\":\"CONDITIONAL\",\"timestamp\":\"2026-06-18T06:05:37Z\"}\n*** Add File: .opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-a-6/deep-review-findings-registry.json\n+{\n+  \"sessionId\": \"fanout-gpt55r2-a-6-1781761314338-6u1ztm\",\n+  \"generation\": 1,\n+  \"lineageMode\": \"new\",\n+  \"openFindings\": [\n+    {\n+      \"id\": \"gpt55r2-a-6-F001\",\n+      \"severity\": \"P1\",\n+      \"category\": \"correctness\",\n+      \"title\": \"Folder boost demotes scoped hits by capping 0-100 similarity at 1.0\",\n+      \"status\": \"open\",\n+      \"iteration\": 1,\n+      \"findingClass\": \"numeric-score-scale-contract\",\n+      \"scopeProof\": \"The issue is in memory_search folder ranking, a search/query handler under the declared search/retrieval MCP server scope.\",\n+      \"affectedSurfaceHints\": [\n+        \"memory_search calls with folderBoost from memory_context folder discovery\",\n+        \"ranking order and formatted similarity for returned search results\",\n+        \"openltm retrieval observability test coverage\"\n+      ],\n+      \"evidenceRefs\": [\n+        \".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts:651-676\",\n+        \".opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts:85-103\",\n+        \".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts:57-75\",\n+        \".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts:1326-1334\",\n+        \".opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts:96-124\"\n+      ],\n+      \"claimAdjudication\": {\n+        \"type\": \"gate-relevant-P1\",\n+        \"claim\": \"Folder boost can invert intended ranking because it multiplies raw 0-100 similarity and caps boosted in-folder rows at 1.0 before sorting by similarity descending.\",\n+        \"evidenceRefs\": [\n+          \".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts:651-676\",\n+          \".opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts:85-103\",\n+          \".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts:1326-1334\"\n+        ],\n+        \"counterevidenceSought\": \"Checked the test exercising applyFolderBoostRanking and found it uses 0.7/0.6 similarity inputs, which do not match the documented and produced 0-100 production contract.\",\n+        \"alternativeExplanation\": \"If all callers supplied already-normalized 0-1 similarity, the cap would be valid; formatter and pipeline contracts show that is not the handler's production contract.\",\n+        \"finalSeverity\": \"P1\",\n+        \"confidence\": 0.88,\n+        \"downgradeTrigger\": \"Downgrade if the production rows reaching applyFolderBoostRanking are proven normalized to 0-1 on every path before this function runs.\"\n+      }\n+    }\n+  ],\n+  \"resolvedFindings\": [],\n+  \"repeatedFindings\": [],\n+  \"dimensionCoverage\": {\n+    \"correctness\": true,\n+    \"security\": false,\n+    \"traceability\": false,\n+    \"maintainability\": false\n+  },\n+  \"findingsBySeverity\": {\n+    \"P0\": 0,\n+    \"P1\": 1,\n+    \"P2\": 0\n+  },\n+  \"openFindingsCount\": 1,\n+  \"resolvedFindingsCount\": 0,\n+  \"convergenceScore\": 1.0,\n+  \"verdict\": \"CONDITIONAL\"\n+}\n*** Add File: .opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-a-6/deep-review-strategy.md\n+---\n+title: Deep Review Strategy - gpt55r2-a-6\n+description: One-iteration search/retrieval deep-review lineage strategy and state.\n+trigger_phrases:\n+  - \"gpt55r2-a-6 search retrieval review\"\n+  - \"folder boost similarity scale\"\n+importance_tier: normal\n+contextType: planning\n+---\n+\n+# Deep Review Strategy - gpt55r2-a-6\n+\n+## 1. Overview\n+\n+One-iteration fanout lineage for the search/retrieval subsystem under `.opencode/skills/system-spec-kit/mcp_server/`. The review is read-only for target code and writes only into this lineage artifact directory.\n+\n+## 2. Topic\n+\n+Search and retrieval correctness, with emphasis on numeric score-scale contracts, cross-module seams, and read-path fallback behavior.\n+\n+## 3. Review Dimensions\n+\n+<!-- MACHINE-OWNED: START -->\n+- [x] D1 Correctness, numeric score normalization and ranking behavior\n+- [ ] D2 Security, input trust boundaries and data exposure\n+- [ ] D3 Traceability, spec/code alignment and evidence completeness\n+- [ ] D4 Maintainability, clarity and safe follow-on change cost\n+<!-- MACHINE-OWNED: END -->\n+\n+## 4. Non-Goals\n+\n+- 