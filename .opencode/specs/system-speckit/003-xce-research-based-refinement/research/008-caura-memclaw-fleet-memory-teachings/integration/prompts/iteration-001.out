from '../lib/search/vector-index-mutations.js';\n74: import {\n75:   runQualityLoop,\n76: } from './quality-loop.js';\n77: import type {\n78:   QualityLoopResult,\n79: } from './quality-loop.js';\n80: \n81: // O2-5/O2-12: V-rule validation (previously only in workflow path)\n82: import {\n83:   validateMemoryQualityContent,\n84:   determineValidationDisposition,\n85: } from './v-rule-bridge.js';\n86: \n87: // Save pipeline modules\n88: import type {\n89:   IndexResult,\n90:   RouteCategory,\n91:   MergeModeHint,\n92:   SaveArgs,\n93:   AtomicSaveParams,\n94:   AtomicSaveOptions,\n95:   AtomicSaveResult,\n96:   PlannerAdvisory,\n97:   PlannerBlocker,\n98:   PlannerFollowUpAction,\n99:   PlannerRouteTarget,\n100: } from './save/index.js';\n101: import { checkExistingRow, checkContentHashDedup } from './save/dedup.js';\n102: import { generateOrCacheEmbedding, persistPendingEmbeddingCacheWrite } from './save/embedding-pipeline.js';\n103: import { evaluateAndApplyPeDecision } from './save/pe-orchestration.js';\n104: import {\n105:   findScopeFilteredCandidates,\n106:   getRequestedScope,\n107:   runReconsolidationIfEnabled,\n108: } from './save/reconsolidation-bridge.js';\n109: import {\n110:   runPostInsertEnrichmentIfEnabled,\n111:   runPostInsertEnrichment,\n112:   shouldRunPostInsertEnrichment,\n113:   buildDeferredEnrichmentResult,\n114: } from './save/post-insert.js';\n115: import type { PostInsertEnrichmentResult } from './save/post-insert.js';\n116: import {\n117:   markEnrichmentPending,\n118:   needsEnrichmentRepair,\n119:   POST_INSERT_ENRICHMENT_VERSION,\n120:   recordEnrichmentResult,\n121:   repairEnrichmentOnReplay,\n122: } from './save/enrichment-state.js';\n123: import {\n124:   buildIndexResult,\n125:   buildPlannerResponse,\n126:   buildSaveResponse,\n127:   classifySaveErrorCode,\n128:   extractSaveErrorDetails,\n129:   serializePlannerAdvisory,\n130:   serializePlannerBlocker,\n131:   serializePlannerFollowUpAction,\n132:   serializePlannerProposedEd