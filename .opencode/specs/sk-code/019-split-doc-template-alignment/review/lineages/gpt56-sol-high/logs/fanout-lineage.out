{"type":"tool_use","timestamp":1783912345041,"sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","part":{"type":"tool","tool":"read","callID":"call_FCHxgKBBK6L3y8cEPhoS7Kjr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/render-command-contract.cjs","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/render-command-contract.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: const crypto = require('node:crypto');\n5: const fs = require('node:fs');\n6: const path = require('node:path');\n7: \n8: const {\n9:   canonicalizeCommand,\n10:   resolveInjectionMode,\n11: } = require('../../shared/rollout/resolve-injection-mode.cjs');\n12: const { checkCommand } = require('./check-contract-drift.cjs');\n13: \n14: const WORKSPACE_ROOT = path.resolve(__dirname, '..', '..', '..', '..', '..');\n15: const MANIFEST_PATH = '.opencode/commands/deep/assets/compiled/manifest.jsonl';\n16: \n17: const COMMANDS = {\n18:   'deep/ai-council': {\n19:     slug: 'deep_ai-council',\n20:     legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_ai-council.body.md',\n21:     compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_ai-council.contract.md',\n22:   },\n23:   'deep/review': {\n24:     slug: 'deep_review',\n25:     legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_review.body.md',\n26:     compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_review.contract.md',\n27:   },\n28:   'deep/research': {\n29:     slug: 'deep_research',\n30:     legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_research.body.md',\n31:     compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_research.contract.md',\n32:   },\n33:   'deep/alignment': {\n34:     slug: 'deep_alignment',\n35:     legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_alignment.body.md',\n36:     compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_alignment.contract.md',\n37:   },\n38: };\n39: \n40: function absolutePath(sourcePath) {\n41:   return path.resolve(WORKSPACE_ROOT, sourcePath);\n42: }\n43: \n44: function sha256(input) {\n45:   return crypto.createHash('sha256').update(input).digest('hex');\n46: }\n47: \n48: function readBuffer(sourcePath) {\n49:   return fs.readFileSync(absolutePath(sourcePath));\n50: }\n51: \n52: function getCommandDefinition(command) {\n53:   const canonicalCommand = canonicalizeCommand(command);\n54:   const definition = COMMANDS[canonicalCommand];\n55:   if (!definition) {\n56:     const supported = Object.keys(COMMANDS).join(', ');\n57:     throw new Error(`Unsupported command ${command}. Supported commands: ${supported}`);\n58:   }\n59:   return { command: canonicalCommand, ...definition };\n60: }\n61: \n62: function passthroughArgsText(argv) {\n63:   if (argv.length === 0) return '';\n64:   if (argv.length === 1) return argv[0];\n65:   return argv.join(' ');\n66: }\n67: \n68: function resolveMode(command) {\n69:   return resolveInjectionMode(command);\n70: }\n71: \n72: function assertCompiledContractFresh(definition, check = checkCommand) {\n73:   const drift = check(definition.command);\n74:   if (drift.failures.length > 0) {\n75:     const classes = [...new Set(drift.failures.map((failure) => failure.class))].join(', ');\n76:     throw new Error(\n77:       `Refusing stale compiled contract for ${definition.command}: ${classes}. `\n78:         + 'Re-run compile-command-contracts.cjs --write.',\n79:     );\n80:   }\n81: }\n82: \n83: function renderPayload(definition, mode) {\n84:   const legacyBody = readBuffer(definition.legacyBodyPath);\n85: \n86:   if (mode === 'fallback') return legacyBody;\n87:   if (mode === 'fix') {\n88:     assertCompiledContractFresh(definition);\n89:     const compiledContract = readBuffer(definition.compiledContractPath);\n90:     return Buffer.concat([compiledContract, legacyBody]);\n91:   }\n92:   throw new Error(`Unsupported injection mode ${mode} for ${definition.command}`);\n93: }\n94: \n95: // The command reaches the executor as rendered markdown; the raw invocation message\n96: // (target, :auto suffix, spec_folder, topic, flags) arrives only via this prelude's\n97: // argv and must be echoed back, or the model never sees it and re-asks for setup.\n98: // This mirrors the memory-search command's ARGS_PRESENT/QUERY surface.\n99: function buildInvocationPrefix(argsText) {\n100:   const present = argsText.trim().length > 0;\n101:   const lines = [\n102:     '<!-- INVOCATION MESSAGE (the user input for this run) -->',\n103:     `ARGS_PRESENT=${present}`,\n104:   ];\n105:   if (present) {\n106:     lines.push('MESSAGE:', argsText, '');\n107:     lines.push(\n108:       'Bind setup from the MESSAGE above — the target, the `:auto`/`:confirm` suffix, `--spec-folder`, the research topic, and other flags are there. When ARGS_PRESENT=true you MUST proceed on that MESSAGE now: do NOT ask the setup question, and do NOT treat a populated MESSAGE as empty.',\n109:     );\n110:   } else {\n111:     lines.push('MESSAGE: (none supplied)', '');\n112:     lines.push('ARGS_PRESENT=false: no invocation message was supplied; follow the command body below for setup routing.');\n113:   }\n114:   lines.push('', '<!-- END INVOCATION MESSAGE -->', '');\n115:   return Buffer.from(lines.join('\\n'), 'utf8');\n116: }\n117: \n118: function buildManifestRow(definition, mode, argsText, output) {\n119:   const legacyBody = readBuffer(definition.legacyBodyPath);\n120:   const compiledContract = readBuffer(definition.compiledContractPath);\n121:   return {\n122:     command: definition.command,\n123:     mode,\n124:     argsSha256: sha256(Buffer.from(argsText, 'utf8')),\n125:     legacyBodySha256: sha256(legacyBody),\n126:     compiledContractSha256: sha256(compiledContract),\n127:     renderedSha256: sha256(output),\n128:   };\n129: }\n130: \n131: function appendManifestRow(row, manifestPath = absolutePath(MANIFEST_PATH)) {\n132:   fs.mkdirSync(path.dirname(manifestPath), { recursive: true });\n133:   fs.appendFileSync(manifestPath, `${JSON.stringify(row)}\\n`, 'utf8');\n134: }\n135: \n136: function renderCommandContract(command, options = {}) {\n137:   const definition = getCommandDefinition(command);\n138:   const mode = resolveMode(definition.command);\n139:   const argsText = options.argsText ?? '';\n140:   const body = renderPayload(definition, mode);\n141:   const prefix = buildInvocationPrefix(argsText);\n142:   const output = Buffer.concat([prefix, body]);\n143:   const manifestRow = buildManifestRow(definition, mode, argsText, output);\n144: \n145:   if (options.writeManifest !== false) {\n146:     appendManifestRow(manifestRow, options.manifestPath ? path.resolve(options.manifestPath) : undefined);\n147:   }\n148: \n149:   return { command: definition.command, mode, output, body, prefix, manifestRow };\n150: }\n151: \n152: function firstByteDiff(left, right) {\n153:   const length = Math.min(left.length, right.length);\n154:   for (let index = 0; index < length; index += 1) {\n155:     if (left[index] !== right[index]) {\n156:       return {\n157:         offset: index,\n158:         expected: right[index],\n159:         actual: left[index],\n160:       };\n161:     }\n162:   }\n163:   if (left.length !== right.length) {\n164:     return {\n165:       offset: length,\n166:       expected: right.length > length ? right[length] : null,\n167:       actual: left.length > length ? left[length] : null,\n168:     };\n169:   }\n170:   return null;\n171: }\n172: \n173: function compareFallback(command) {\n174:   const definition = getCommandDefinition(command);\n175:   const rendered = renderPayload(definition, 'fallback');\n176:   const legacyBody = readBuffer(definition.legacyBodyPath);\n177:   const equal = rendered.equals(legacyBody);\n178:   return {\n179:     command: definition.command,\n180:     equal,\n181:     renderedLength: rendered.length,\n182:     legacyBodyLength: legacyBody.length,\n183:     diff: equal ? null : firstByteDiff(rendered, legacyBody),\n184:   };\n185: }\n186: \n187: function parseArgs(argv) {\n188:   const args = { compare: false, passthroughArgs: [] };\n189:   for (let index = 0; index < argv.length; index += 1) {\n190:     const token = argv[index];\n191:     if (token === '--') {\n192:       args.passthroughArgs = argv.slice(index + 1);\n193:       return args;\n194:     }\n195:     if (token === '--command') {\n196:       const value = argv[index + 1];\n197:       if (!value || value.startsWith('--')) throw new Error('--command requires a value');\n198:       args.command = value;\n199:       index += 1;\n200:       continue;\n201:     }\n202:     if (token === '--compare') {\n203:       args.compare = true;\n204:       continue;\n205:     }\n206:     if (token === '--help' || token === '-h') {\n207:       args.help = true;\n208:       continue;\n209:     }\n210:     throw new Error(`Unknown argument: ${token}`);\n211:   }\n212:   return args;\n213: }\n214: \n215: function printHelp() {\n216:   process.stdout.write('Usage: node render-command-contract.cjs --command deep/ai-council|deep/review|deep/research [--compare] -- [arguments]\\n');\n217: }\n218: \n219: function main(argv = process.argv.slice(2)) {\n220:   const args = parseArgs(argv);\n221:   if (args.help) {\n222:     printHelp();\n223:     return;\n224:   }\n225:   if (!args.command) throw new Error('--command is required');\n226: \n227:   if (args.compare) {\n228:     const comparison = compareFallback(args.command);\n229:     if (!comparison.equal) {\n230:       process.stderr.write(`${JSON.stringify(comparison)}\\n`);\n231:       process.exit(2);\n232:     }\n233:     process.stdout.write(`COMPARE OK command=${comparison.command} bytes=${comparison.renderedLength}\\n`);\n234:     return;\n235:   }\n236: \n237:   const result = renderCommandContract(args.command, {\n238:     argsText: passthroughArgsText(args.passthroughArgs),\n239:   });\n240:   process.stdout.write(result.output);\n241: }\n242: \n243: if (require.main === module) {\n244:   try {\n245:     main();\n246:   } catch (error) {\n247:     process.stderr.write(`${error instanceof Error ? error.message : String(error)}\\n`);\n248:     process.exit(1);\n249:   }\n250: }\n251: \n252: module.exports = {\n253:   COMMANDS,\n254:   MANIFEST_PATH,\n255:   WORKSPACE_ROOT,\n256:   appendManifestRow,\n257:   buildInvocationPrefix,\n258:   buildManifestRow,\n259:   compareFallback,\n260:   getCommandDefinition,\n261:   passthroughArgsText,\n262:   renderCommandContract,\n263:   renderPayload,\n264:   resolveMode,\n265:   sha256,\n266: };\n\n(End of file - total 266 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\nconst crypto = require('node:crypto');\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst {\n  canonicalizeCommand,\n  resolveInjectionMode,\n} = require('../../shared/rollout/resolve-injection-mode.cjs');\nconst { checkCommand } = require('./check-contract-drift.cjs');\n\nconst WORKSPACE_ROOT = path.resolve(__dirname, '..', '..', '..', '..', '..');\nconst MANIFEST_PATH = '.opencode/commands/deep/assets/compiled/manifest.jsonl';\n\nconst COMMANDS = {\n  'deep/ai-council': {\n    slug: 'deep_ai-council',\n    legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_ai-council.body.md',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/render-command-contract.cjs","text":"#!/usr/bin/env node\n'use strict';\n\nconst crypto = require('node:crypto');\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst {\n  canonicalizeCommand,\n  resolveInjectionMode,\n} = require('../../shared/rollout/resolve-injection-mode.cjs');\nconst { checkCommand } = require('./check-contract-drift.cjs');\n\nconst WORKSPACE_ROOT = path.resolve(__dirname, '..', '..', '..', '..', '..');\nconst MANIFEST_PATH = '.opencode/commands/deep/assets/compiled/manifest.jsonl';\n\nconst COMMANDS = {\n  'deep/ai-council': {\n    slug: 'deep_ai-council',\n    legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_ai-council.body.md',\n    compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_ai-council.contract.md',\n  },\n  'deep/review': {\n    slug: 'deep_review',\n    legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_review.body.md',\n    compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_review.contract.md',\n  },\n  'deep/research': {\n    slug: 'deep_research',\n    legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_research.body.md',\n    compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_research.contract.md',\n  },\n  'deep/alignment': {\n    slug: 'deep_alignment',\n    legacyBodyPath: '.opencode/commands/deep/assets/legacy/deep_alignment.body.md',\n    compiledContractPath: '.opencode/commands/deep/assets/compiled/deep_alignment.contract.md',\n  },\n};\n\nfunction absolutePath(sourcePath) {\n  return path.resolve(WORKSPACE_ROOT, sourcePath);\n}\n\nfunction sha256(input) {\n  return crypto.createHash('sha256').update(input).digest('hex');\n}\n\nfunction readBuffer(sourcePath) {\n  return fs.readFileSync(absolutePath(sourcePath));\n}\n\nfunction getCommandDefinition(command) {\n  const canonicalCommand = canonicalizeCommand(command);\n  const definition = COMMANDS[canonicalCommand];\n  if (!definition) {\n    const supported = Object.keys(COMMANDS).join(', ');\n    throw new Error(`Unsupported command ${command}. Supported commands: ${supported}`);\n  }\n  return { command: canonicalCommand, ...definition };\n}\n\nfunction passthroughArgsText(argv) {\n  if (argv.length === 0) return '';\n  if (argv.length === 1) return argv[0];\n  return argv.join(' ');\n}\n\nfunction resolveMode(command) {\n  return resolveInjectionMode(command);\n}\n\nfunction assertCompiledContractFresh(definition, check = checkCommand) {\n  const drift = check(definition.command);\n  if (drift.failures.length > 0) {\n    const classes = [...new Set(drift.failures.map((failure) => failure.class))].join(', ');\n    throw new Error(\n      `Refusing stale compiled contract for ${definition.command}: ${classes}. `\n        + 'Re-run compile-command-contracts.cjs --write.',\n    );\n  }\n}\n\nfunction renderPayload(definition, mode) {\n  const legacyBody = readBuffer(definition.legacyBodyPath);\n\n  if (mode === 'fallback') return legacyBody;\n  if (mode === 'fix') {\n    assertCompiledContractFresh(definition);\n    const compiledContract = readBuffer(definition.compiledContractPath);\n    return Buffer.concat([compiledContract, legacyBody]);\n  }\n  throw new Error(`Unsupported injection mode ${mode} for ${definition.command}`);\n}\n\n// The command reaches the executor as rendered markdown; the raw invocation message\n// (target, :auto suffix, spec_folder, topic, flags) arrives only via this prelude's\n// argv and must be echoed back, or the model never sees it and re-asks for setup.\n// This mirrors the memory-search command's ARGS_PRESENT/QUERY surface.\nfunction buildInvocationPrefix(argsText) {\n  const present = argsText.trim().length > 0;\n  const lines = [\n    '<!-- INVOCATION MESSAGE (the user input for this run) -->',\n    `ARGS_PRESENT=${present}`,\n  ];\n  if (present) {\n    lines.push('MESSAGE:', argsText, '');\n    lines.push(\n      'Bind setup from the MESSAGE above — the target, the `:auto`/`:confirm` suffix, `--spec-folder`, the research topic, and other flags are there. When ARGS_PRESENT=true you MUST proceed on that MESSAGE now: do NOT ask the setup question, and do NOT treat a populated MESSAGE as empty.',\n    );\n  } else {\n    lines.push('MESSAGE: (none supplied)', '');\n    lines.push('ARGS_PRESENT=false: no invocation message was supplied; follow the command body below for setup routing.');\n  }\n  lines.push('', '<!-- END INVOCATION MESSAGE -->', '');\n  return Buffer.from(lines.join('\\n'), 'utf8');\n}\n\nfunction buildManifestRow(definition, mode, argsText, output) {\n  const legacyBody = readBuffer(definition.legacyBodyPath);\n  const compiledContract = readBuffer(definition.compiledContractPath);\n  return {\n    command: definition.command,\n    mode,\n    argsSha256: sha256(Buffer.from(argsText, 'utf8')),\n    legacyBodySha256: sha256(legacyBody),\n    compiledContractSha256: sha256(compiledContract),\n    renderedSha256: sha256(output),\n  };\n}\n\nfunction appendManifestRow(row, manifestPath = absolutePath(MANIFEST_PATH)) {\n  fs.mkdirSync(path.dirname(manifestPath), { recursive: true });\n  fs.appendFileSync(manifestPath, `${JSON.stringify(row)}\\n`, 'utf8');\n}\n\nfunction renderCommandContract(command, options = {}) {\n  const definition = getCommandDefinition(command);\n  const mode = resolveMode(definition.command);\n  const argsText = options.argsText ?? '';\n  const body = renderPayload(definition, mode);\n  const prefix = buildInvocationPrefix(argsText);\n  const output = Buffer.concat([prefix, body]);\n  const manifestRow = buildManifestRow(definition, mode, argsText, output);\n\n  if (options.writeManifest !== false) {\n    appendManifestRow(manifestRow, options.manifestPath ? path.resolve(options.manifestPath) : undefined);\n  }\n\n  return { command: definition.command, mode, output, body, prefix, manifestRow };\n}\n\nfunction firstByteDiff(left, right) {\n  const length = Math.min(left.length, right.length);\n  for (let index = 0; index < length; index += 1) {\n    if (left[index] !== right[index]) {\n      return {\n        offset: index,\n        expected: right[index],\n        actual: left[index],\n      };\n    }\n  }\n  if (left.length !== right.length) {\n    return {\n      offset: length,\n      expected: right.length > length ? right[length] : null,\n      actual: left.length > length ? left[length] : null,\n    };\n  }\n  return null;\n}\n\nfunction compareFallback(command) {\n  const definition = getCommandDefinition(command);\n  const rendered = renderPayload(definition, 'fallback');\n  const legacyBody = readBuffer(definition.legacyBodyPath);\n  const equal = rendered.equals(legacyBody);\n  return {\n    command: definition.command,\n    equal,\n    renderedLength: rendered.length,\n    legacyBodyLength: legacyBody.length,\n    diff: equal ? null : firstByteDiff(rendered, legacyBody),\n  };\n}\n\nfunction parseArgs(argv) {\n  const args = { compare: false, passthroughArgs: [] };\n  for (let index = 0; index < argv.length; index += 1) {\n    const token = argv[index];\n    if (token === '--') {\n      args.passthroughArgs = argv.slice(index + 1);\n      return args;\n    }\n    if (token === '--command') {\n      const value = argv[index + 1];\n      if (!value || value.startsWith('--')) throw new Error('--command requires a value');\n      args.command = value;\n      index += 1;\n      continue;\n    }\n    if (token === '--compare') {\n      args.compare = true;\n      continue;\n    }\n    if (token === '--help' || token === '-h') {\n      args.help = true;\n      continue;\n    }\n    throw new Error(`Unknown argument: ${token}`);\n  }\n  return args;\n}\n\nfunction printHelp() {\n  process.stdout.write('Usage: node render-command-contract.cjs --command deep/ai-council|deep/review|deep/research [--compare] -- [arguments]\\n');\n}\n\nfunction main(argv = process.argv.slice(2)) {\n  const args = parseArgs(argv);\n  if (args.help) {\n    printHelp();\n    return;\n  }\n  if (!args.command) throw new Error('--command is required');\n\n  if (args.compare) {\n    const comparison = compareFallback(args.command);\n    if (!comparison.equal) {\n      process.stderr.write(`${JSON.stringify(comparison)}\\n`);\n      process.exit(2);\n    }\n    process.stdout.write(`COMPARE OK command=${comparison.command} bytes=${comparison.renderedLength}\\n`);\n    return;\n  }\n\n  const result = renderCommandContract(args.command, {\n    argsText: passthroughArgsText(args.passthroughArgs),\n  });\n  process.stdout.write(result.output);\n}\n\nif (require.main === module) {\n  try {\n    main();\n  } catch (error) {\n    process.stderr.write(`${error instanceof Error ? error.message : String(error)}\\n`);\n    process.exit(1);\n  }\n}\n\nmodule.exports = {\n  COMMANDS,\n  MANIFEST_PATH,\n  WORKSPACE_ROOT,\n  appendManifestRow,\n  buildInvocationPrefix,\n  buildManifestRow,\n  compareFallback,\n  getCommandDefinition,\n  passthroughArgsText,\n  renderCommandContract,\n  renderPayload,\n  resolveMode,\n  sha256,\n};","lineStart":1,"lineEnd":266,"totalLines":266,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/scripts/render-command-contract.cjs","time":{"start":1783912345022,"end":1783912345039}},"metadata":{"openai":{"itemId":"fc_05b2c0b511cb73fe016a545798f66881918aeb0279506d6b7a"}},"id":"prt_f59762dbd001IwF1i15Rlaz5Ou","sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","messageID":"msg_f5975f967001oRvE3U7uqnZ0zQ"}}
{"type":"tool_use","timestamp":1783912345046,"sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","part":{"type":"tool","tool":"read","callID":"call_1adxjzPnAp0jA2Itm568vjZv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n7: // ║         --base-artifact-dir).                                            ║\n8: // ║ Output: JSON to stdout.                                                  ║\n9: // ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: \n12: 'use strict';\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 1. IMPORTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: const fs = require('node:fs');\n19: const os = require('node:os');\n20: const path = require('node:path');\n21: const { spawn } = require('node:child_process');\n22: \n23: const {\n24:   classifyExitCode,\n25:   maybeThrowTestFault,\n26:   validateNamespaceValue,\n27: } = require('./lib/cli-guards.cjs');\n28: \n29: const {\n30:   runCappedPool,\n31:   appendStatusLedger,\n32:   markOrphanedLineages,\n33:   readRetryCountsFromLedger,\n34:   createWavePlannerInterface,\n35:   writeOrchestrationSummary,\n36: } = require('./fanout-pool.cjs');\n37: \n38: const {\n39:   runSalvageSweep,\n40:   extractTextFromOpencodeJson,\n41: } = require('./fanout-salvage.cjs');\n42: \n43: const {\n44:   appendObservabilityEvent,\n45: } = require('../lib/deep-loop/observability-events.cjs');\n46: \n47: // ─────────────────────────────────────────────────────────────────────────────\n48: // 2. TSX BOOTSTRAP\n49: // ─────────────────────────────────────────────────────────────────────────────\n50: \n51: const TSX_LOADER = require.resolve('tsx');\n52: const isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n53: \n54: function runTsxBootstrap() {\n55:   const child = spawn(\n56:     process.execPath,\n57:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n58:     {\n59:       cwd: process.cwd(),\n60:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n61:       stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n62:     },\n63:   );\n64: \n65:   if (!process.stdin.isTTY && child.stdin) {\n66:     child.stdin.on('error', () => {});\n67:     process.stdin.pipe(child.stdin);\n68:   }\n69: \n70:   child.stdout?.pipe(process.stdout);\n71:   child.stderr?.pipe(process.stderr);\n72: \n73:   for (const signal of ['SIGINT', 'SIGTERM']) {\n74:     process.once(signal, () => {\n75:       child.kill(signal);\n76:     });\n77:   }\n78: \n79:   child.on('close', (status, signal) => {\n80:     if (status !== null) {\n81:       process.exit(status);\n82:     }\n83:     process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n84:   });\n85: }\n86: \n87: if (require.main === module && !isTsxLoaded) {\n88:   runTsxBootstrap();\n89: }\n90: \n91: // ─────────────────────────────────────────────────────────────────────────────\n92: // 3. HELPERS\n93: // ─────────────────────────────────────────────────────────────────────────────\n94: \n95: function parseArgs(argv = process.argv.slice(2)) {\n96:   const args = {};\n97:   for (let i = 0; i < argv.length; i += 1) {\n98:     const token = argv[i];\n99:     if (!token.startsWith('--')) {\n100:       throw inputError(`Unexpected positional argument: ${token}`);\n101:     }\n102:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n103:     const next = argv[i + 1];\n104:     if (next === undefined || next.startsWith('--')) {\n105:       args[key] = true;\n106:     } else {\n107:       args[key] = next;\n108:       i += 1;\n109:     }\n110:   }\n111:   return args;\n112: }\n113: \n114: function inputError(message) {\n115:   const err = new Error(message);\n116:   err.code = 'INPUT_VALIDATION';\n117:   return err;\n118: }\n119: \n120: function ensureString(args, key) {\n121:   if (!args[key] || typeof args[key] !== 'string') {\n122:     throw inputError(`${key} is required`);\n123:   }\n124:   return args[key];\n125: }\n126: \n127: function parseOptionalNumber(args, key) {\n128:   const raw = args[key];\n129:   if (raw === undefined || raw === false || raw === null || raw === '') {\n130:     return null;\n131:   }\n132:   if (raw === true || typeof raw !== 'string') {\n133:     throw inputError(`${key} must be a number`);\n134:   }\n135:   const value = Number(raw);\n136:   if (!Number.isFinite(value) || value < 0) {\n137:     throw inputError(`${key} must be a non-negative number`);\n138:   }\n139:   return value;\n140: }\n141: \n142: function readRawConfigNumber(rawConfig, names, fieldName) {\n143:   if (!isRecord(rawConfig)) return null;\n144:   for (const name of names) {\n145:     if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n146:     const raw = rawConfig[name];\n147:     if (raw === undefined || raw === null || raw === '') return null;\n148:     if (raw === true || raw === false) {\n149:       throw inputError(`${fieldName} must be a non-negative number`);\n150:     }\n151:     const value = Number(raw);\n152:     if (!Number.isFinite(value) || value < 0) {\n153:       throw inputError(`${fieldName} must be a non-negative number`);\n154:     }\n155:     return Math.floor(value);\n156:   }\n157:   return null;\n158: }\n159: \n160: function readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n161:   const value = readRawConfigNumber(rawConfig, names, fieldName);\n162:   if (value === null) return fallback;\n163:   if (value <= 0) {\n164:     throw inputError(`${fieldName} must be greater than 0`);\n165:   }\n166:   return value;\n167: }\n168: \n169: function rawConfigWithCliBudgetOverrides(rawConfig, args) {\n170:   const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n171:   const mappings = [\n172:     ['stallWatchdogMs', 'stallWatchdogMs'],\n173:     ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n174:     ['maxAggregateCostUnits', 'maxAggregateCostUnits'],\n175:     ['maxTokensPerLineage', 'maxTokensPerLineage'],\n176:     ['maxTokenBudget', 'maxTokenBudget'],\n177:     ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n178:     ['costUnitsPerIteration', 'costUnitsPerIteration'],\n179:     ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n180:   ];\n181:   for (const [targetKey, argKey] of mappings) {\n182:     if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n183:       merged[targetKey] = args[argKey];\n184:     }\n185:   }\n186:   return merged;\n187: }\n188: \n189: function normalizeStopPolicy(raw) {\n190:   if (raw === undefined || raw === false || raw === null || raw === '') {\n191:     return 'convergence';\n192:   }\n193:   if (raw === true || typeof raw !== 'string') {\n194:     throw inputError('stopPolicy must be convergence or max-iterations');\n195:   }\n196:   if (raw !== 'convergence' && raw !== 'max-iterations') {\n197:     throw inputError('stopPolicy must be convergence or max-iterations');\n198:   }\n199:   return raw;\n200: }\n201: \n202: function jsonOut(payload) {\n203:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n204: }\n205: \n206: function signalExitCode(signal) {\n207:   return signal === 'SIGINT' ? 130 : 143;\n208: }\n209: \n210: let fanoutSignalHandlersInstalled = false;\n211: \n212: function installFanoutSignalHandlers(onStop) {\n213:   if (fanoutSignalHandlersInstalled) return;\n214:   fanoutSignalHandlersInstalled = true;\n215: \n216:   for (const signal of ['SIGINT', 'SIGTERM']) {\n217:     process.once(signal, () => {\n218:       try {\n219:         onStop(signal);\n220:       } finally {\n221:         process.exit(signalExitCode(signal));\n222:       }\n223:     });\n224:   }\n225: }\n226: \n227: function updateLineageSnapshot(snapshots, event) {\n228:   if (!event || typeof event.label !== 'string') return;\n229:   const existing = snapshots.get(event.label) || { label: event.label };\n230: \n231:   if (event.event === 'started') {\n232:     snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n233:     return;\n234:   }\n235:   if (event.event === 'completed') {\n236:     snapshots.set(event.label, {\n237:       ...existing,\n238:       status: 'fulfilled',\n239:       completed_at_iso: event.at,\n240:       duration_ms: event.duration_ms,\n241:     });\n242:     return;\n243:   }\n244:   if (event.event === 'failed') {\n245:     snapshots.set(event.label, {\n246:       ...existing,\n247:       status: event.terminal === false ? 'retrying' : 'rejected',\n248:       completed_at_iso: event.at,\n249:       duration_ms: event.duration_ms,\n250:       error: event.error,\n251:     });\n252:     return;\n253:   }\n254:   if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n255:     snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n256:     return;\n257:   }\n258:   if (event.event === 'progress') {\n259:     snapshots.set(event.label, {\n260:       ...existing,\n261:       status: 'running',\n262:       updated_at_iso: event.at,\n263:       duration_ms: event.duration_ms,\n264:     });\n265:   }\n266: }\n267: \n268: function buildLineageSnapshots(lineages, snapshots) {\n269:   return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n270: }\n271: \n272: function summarizeSnapshots(lineages, snapshots) {\n273:   const results = buildLineageSnapshots(lineages, snapshots);\n274:   const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n275:   const failed = results.filter((result) => result.status === 'rejected').length;\n276:   return {\n277:     results,\n278:     summary: {\n279:       total: lineages.length,\n280:       succeeded,\n281:       failed,\n282:       all_failed: lineages.length > 0 && failed === lineages.length,\n283:     },\n284:   };\n285: }\n286: \n287: function observabilityPathForLedger(ledgerPath) {\n288:   return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n289: }\n290: \n291: function statusForLedgerEvent(entry) {\n292:   if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n293:     return entry.status;\n294:   }\n295:   if (!entry || typeof entry.event !== 'string') return 'unknown';\n296:   if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n297:   if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n298:   if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n299:   if (entry.event === 'stopped') return 'stopped';\n300:   if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n301:   // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n302:   // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n303:   if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n304:   if (entry.event === 'lag_ceiling_abort') return 'failed';\n305:   if (entry.event === 'stall_detected') return 'warning';\n306:   if (entry.event === 'budget_cap_exceeded') return 'failed';\n307:   if (entry.event === 'aggregate_budget_cap_exceeded') return 'failed';\n308:   return 'unknown';\n309: }\n310: \n311: function appendFanoutStatusLedger(ledgerPath, entry) {\n312:   appendStatusLedger(ledgerPath, entry);\n313:   try {\n314:     appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n315:       producer: 'fanout-run',\n316:       stream: 'orchestration-status',\n317:       subject: {\n318:         run_id: entry.run_id ?? null,\n319:         label: entry.label ?? null,\n320:         loop_type: entry.loop_type ?? null,\n321:         spec_folder: entry.spec_folder ?? null,\n322:       },\n323:       event: entry.event,\n324:       status: statusForLedgerEvent(entry),\n325:     });\n326:   } catch {\n327:     // Observability must not make the primary orchestration ledger fail.\n328:   }\n329: }\n330: \n331: const FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\n332: const WAVE_ASSIGNMENT_MODEL = 'wave';\n333: const WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\n334: const WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\n335: const STATE_LOG_BY_LOOP_TYPE = {\n336:   research: 'deep-research-state.jsonl',\n337:   review: 'deep-review-state.jsonl',\n338: };\n339: const ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\n340: const DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n341: \n342: function assertActiveFanoutLoopType(loopType) {\n343:   if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n344:     throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n345:   }\n346: }\n347: \n348: function hasNonEmptyArrayField(value) {\n349:   return Array.isArray(value) && value.length > 0;\n350: }\n351: \n352: function collectFlatPoolGuardRejections(fanoutConfig) {\n353:   const rejections = [];\n354:   if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n355:     rejections.push({\n356:       scope: 'fanout',\n357:       label: null,\n358:       field: 'assignment_model',\n359:       message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n360:     });\n361:   }\n362: \n363:   for (const lineage of fanoutConfig.executors) {\n364:     if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n365:       rejections.push({\n366:         scope: 'lineage',\n367:         label: lineage.label,\n368:         field: 'assignment_model',\n369:         message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n370:       });\n371:     }\n372: \n373:     const reservedFields = [];\n374:     if (hasNonEmptyArrayField(lineage.depends_on)) {\n375:       reservedFields.push('depends_on');\n376:     }\n377:     if (hasNonEmptyArrayField(lineage.touches)) {\n378:       reservedFields.push('touches');\n379:     }\n380:     if (reservedFields.length > 0) {\n381:       rejections.push({\n382:         scope: 'lineage',\n383:         label: lineage.label,\n384:         field: reservedFields.join(','),\n385:         message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n386:       });\n387:     }\n388:   }\n389: \n390:   return rejections;\n391: }\n392: \n393: /**\n394:  * Force fan-out execution onto the existing flat pool while wave planning is gated.\n395:  *\n396:  * @param {Object} fanoutConfig - Parsed fan-out config.\n397:  * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n398:  */\n399: function applyFlatPoolAssignmentGuard(fanoutConfig) {\n400:   const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n401:   return {\n402:     config: {\n403:       ...fanoutConfig,\n404:       assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n405:       executors: fanoutConfig.executors.map((lineage) => ({\n406:         ...lineage,\n407:         assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n408:       })),\n409:     },\n410:     rejections,\n411:   };\n412: }\n413: \n414: function logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n415:   if (rejections.length === 0) {\n416:     return;\n417:   }\n418:   const wavePlanner = createWavePlannerInterface();\n419:   for (const rejection of rejections) {\n420:     const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n421:     process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n422:     appendFanoutStatusLedger(ledgerPath, {\n423:       event: 'assignment_model_rejected',\n424:       severity: 'warning',\n425:       at: new Date().toISOString(),\n426:       run_id: runId,\n427:       loop_type: loopType,\n428:       spec_folder: specFolder,\n429:       planner_status: wavePlanner.status,\n430:       fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n431:       ...rejection,\n432:     });\n433:   }\n434: }\n435: \n436: // Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\n437: const SPECKIT_STATE_ENV_BY_KIND = {\n438:   'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n439:   'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n440: };\n441: \n442: const activeLineageProcesses = new Set();\n443: const WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\n444: const WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\n445: const WAIT_SLEEP_CHUNK_MS = 200;\n446: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n447: const DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n448: \n449: function stopActiveLineageProcesses(signal) {\n450:   for (const child of activeLineageProcesses) {\n451:     terminateLineageProcess(child, signal);\n452:   }\n453: }\n454: \n455: function expandHomeDir(inputPath) {\n456:   if (inputPath === '~') {\n457:     return os.homedir();\n458:   }\n459:   if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n460:     return path.join(os.homedir(), inputPath.slice(2));\n461:   }\n462:   return inputPath;\n463: }\n464: \n465: function isPathInside(childPath, parentPath) {\n466:   const relative = path.relative(parentPath, childPath);\n467:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n468: }\n469: \n470: function physicalPathForValidation(targetPath) {\n471:   try {\n472:     return fs.realpathSync.native(targetPath);\n473:   } catch {\n474:     const parentPath = path.dirname(targetPath);\n475:     try {\n476:       return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n477:     } catch {\n478:       return targetPath;\n479:     }\n480:   }\n481: }\n482: \n483: function validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n484:   if (baseArtifactDir.includes('\\0')) {\n485:     throw inputError('baseArtifactDir must not contain null bytes');\n486:   }\n487:   if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n488:     throw inputError('baseArtifactDir must not contain \"..\" path segments');\n489:   }\n490:   const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n491:   const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n492:   const expectedRoot = path.join(resolvedSpecFolder, loopType);\n493:   if (!isPathInside(resolvedBase, expectedRoot)) {\n494:     throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n495:   }\n496:   return baseArtifactDir;\n497: }\n498: \n499: function validateClaudeConfigDir(configDir) {\n500:   if (typeof configDir !== 'string' || configDir.trim() === '') {\n501:     throw inputError('configDir must be a non-empty string when set');\n502:   }\n503:   validateNamespaceValue(configDir, 'configDir', inputError);\n504: \n505:   const expanded = expandHomeDir(configDir);\n506:   const resolved = path.resolve(process.cwd(), expanded);\n507:   const homeDir = path.resolve(os.homedir());\n508:   const cwd = path.resolve(process.cwd());\n509:   const homeRelative = path.relative(homeDir, resolved);\n510:   const cwdRelative = path.relative(cwd, resolved);\n511:   const homeTop = homeRelative.split(path.sep)[0] || '';\n512:   const cwdTop = cwdRelative.split(path.sep)[0] || '';\n513:   const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n514: \n515:   if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n516:     return resolved;\n517:   }\n518:   if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n519:     return resolved;\n520:   }\n521:   throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n522: }\n523: \n524: function terminateLineageProcess(child, signal) {\n525:   if (!child || child.killed) return;\n526:   if (process.platform !== 'win32' && child.pid) {\n527:     try {\n528:       process.kill(-child.pid, signal);\n529:       return;\n530:     } catch (error) {\n531:       if (error && error.code !== 'ESRCH') {\n532:         try {\n533:           child.kill(signal);\n534:         } catch {\n535:           // The process may have already exited between the group and direct kill attempts.\n536:         }\n537:       }\n538:       return;\n539:     }\n540:   }\n541:   try {\n542:     child.kill(signal);\n543:   } catch {\n544:     // The process may have already exited.\n545:   }\n546: }\n547: \n548: function expectedLineageArtifactPaths(loopType, lineageDir) {\n549:   assertActiveFanoutLoopType(loopType);\n550:   if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n551:   return [path.join(lineageDir, 'research.md')];\n552: }\n553: \n554: function hasNonEmptyFile(filePath) {\n555:   try {\n556:     return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n557:   } catch {\n558:     return false;\n559:   }\n560: }\n561: \n562: function findMissingLineageArtifacts(loopType, lineageDir) {\n563:   return expectedLineageArtifactPaths(loopType, lineageDir)\n564:     .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n565: }\n566: \n567: function parseJsonlRecords(filePath) {\n568:   const text = fs.readFileSync(filePath, 'utf8');\n569:   return text\n570:     .split(/\\r?\\n/)\n571:     .filter((line) => line.trim() !== '')\n572:     .map((line) => JSON.parse(line));\n573: }\n574: \n575: function lineageStateLogName(loopType) {\n576:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n577: }\n578: \n579: function readLineageStateRecords(loopType, lineageDir) {\n580:   const stateLogName = lineageStateLogName(loopType);\n581:   if (!stateLogName) {\n582:     return { statePath: null, records: [], missing: true, parseError: null };\n583:   }\n584:   const statePath = path.join(lineageDir, stateLogName);\n585:   if (!hasNonEmptyFile(statePath)) {\n586:     return { statePath, records: [], missing: true, parseError: null };\n587:   }\n588:   try {\n589:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n590:   } catch (error) {\n591:     return {\n592:       statePath,\n593:       records: [],\n594:       missing: false,\n595:       parseError: error instanceof Error ? error.message : String(error),\n596:     };\n597:   }\n598: }\n599: \n600: // A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n601: // spelling. The iteration-count check above already proves the lineage ran every iteration,\n602: // so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n603: // \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n604: // such as convergence, a manual stop, or an error.\n605: function isMaxIterationsStopReason(stopReason) {\n606:   if (typeof stopReason !== 'string') return false;\n607:   return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n608: }\n609: \n610: function findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n611:   if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n612:   if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n613:     return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n614:   }\n615: \n616:   if (!stateRead || stateRead.missing) {\n617:     return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n618:   }\n619:   if (stateRead.parseError) {\n620:     return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n621:   }\n622: \n623:   const records = stateRead.records;\n624:   const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n625:   const synthesis = [...records]\n626:     .reverse()\n627:     .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n628:   if (!synthesis) {\n629:     return 'missing synthesis_complete event for max-iterations stop-policy validation';\n630:   }\n631: \n632:   const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n633:     ? Number(synthesis.totalIterations)\n634:     : iterationCount;\n635:   if (totalIterations !== lineage.iterations) {\n636:     return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n637:   }\n638:   if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n639:     return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n640:   }\n641:   return null;\n642: }\n643: \n644: function isRecord(value) {\n645:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n646: }\n647: \n648: function normalizeStallWatchdogMs(rawConfig) {\n649:   // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n650:   // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n651:   // because this knob is intentionally outside fanoutConfigSchema. Non-disableable while\n652:   // running autonomously: an explicit 0 no longer opts out, it is rejected.\n653:   const value = readRawConfigNumber(rawConfig, [\n654:     'stallWatchdogMs',\n655:     'stall_watchdog_ms',\n656:     'stallWatchdogMillis',\n657:     'stall_watchdog_millis',\n658:   ], 'stallWatchdogMs');\n659:   if (value === 0) {\n660:     throw inputError('stallWatchdogMs must be greater than 0; stall detection cannot be disabled for autonomous fan-out runs');\n661:   }\n662:   return value ?? 300000;\n663: }\n664: \n665: const DEFAULT_MAX_COST_UNITS_PER_LINEAGE = 72;\n666: \n667: function normalizeLineageBudgetGuards(rawConfig = {}) {\n668:   return {\n669:     max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n670:       'maxCostUnitsPerLineage',\n671:       'max_cost_units_per_lineage',\n672:       'maxLineageCostUnits',\n673:       'max_lineage_cost_units',\n674:       'maxTokensPerLineage',\n675:       'max_tokens_per_lineage',\n676:       'maxTokenBudget',\n677:       'max_token_budget',\n678:       'maxTokenBudgetPerLineage',\n679:       'max_token_budget_per_lineage',\n680:     ], 'maxCostUnitsPerLineage') ?? DEFAULT_MAX_COST_UNITS_PER_LINEAGE,\n681:     cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n682:       'costUnitsPerIteration',\n683:       'cost_units_per_iteration',\n684:       'estimatedTokensPerIteration',\n685:       'estimated_tokens_per_iteration',\n686:     ], 'costUnitsPerIteration', 1),\n687:   };\n688: }\n689: \n690: function computeLineageBudgetUpperBound(lineage, guardsInput = {}, maxRetries = 0) {\n691:   const guards = normalizeLineageBudgetGuards(guardsInput);\n692:   const rawIterations = Number(lineage && lineage.iterations);\n693:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n694:   const normalizedRetries = Number.isFinite(Number(maxRetries)) && Number(maxRetries) >= 0\n695:     ? Math.floor(Number(maxRetries))\n696:     : 0;\n697:   const totalAttempts = normalizedRetries + 1;\n698:   return {\n699:     ...guards,\n700:     iterations,\n701:     total_attempts: totalAttempts,\n702:     estimated_cost_units: iterations * guards.cost_units_per_iteration * totalAttempts,\n703:   };\n704: }\n705: \n706: function evaluateLineageBudgetCap(input = {}) {\n707:   const upperBound = computeLineageBudgetUpperBound(\n708:     input.lineage || {},\n709:     input.guards || input,\n710:     input.maxRetries,\n711:   );\n712:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n713:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n714:   return {\n715:     continue_allowed: !exceeded,\n716:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n717:     upper_bound: upperBound,\n718:   };\n719: }\n720: \n721: // Aggregate budget across every expanded lineage in a run. This is a SEPARATE ceiling\n722: // from DEFAULT_MAX_COST_UNITS_PER_LINEAGE above: the per-lineage cap bounds any single\n723: // lineage, this bounds the whole fan-out submission, and both are enforced independently\n724: // (a run may pass one and still fail the other).\n725: const DEFAULT_MAX_AGGREGATE_COST_UNITS = 288;\n726: \n727: function normalizeAggregateBudgetGuards(rawConfig = {}) {\n728:   return {\n729:     max_aggregate_cost_units: readRawConfigNumber(rawConfig, [\n730:       'maxAggregateCostUnits',\n731:       'max_aggregate_cost_units',\n732:       'maxTotalCostUnits',\n733:       'max_total_cost_units',\n734:     ], 'maxAggregateCostUnits') ?? DEFAULT_MAX_AGGREGATE_COST_UNITS,\n735:   };\n736: }\n737: \n738: function computeAggregateBudgetUpperBound(lineages, guardsInput = {}, maxRetries = 0) {\n739:   const aggregateGuards = normalizeAggregateBudgetGuards(guardsInput);\n740:   const lineageGuards = normalizeLineageBudgetGuards(guardsInput);\n741:   const perLineage = (lineages || []).map((lineage) => {\n742:     const upperBound = computeLineageBudgetUpperBound(lineage, lineageGuards, maxRetries);\n743:     return { label: lineage && lineage.label, estimated_cost_units: upperBound.estimated_cost_units };\n744:   });\n745:   const estimatedCostUnits = perLineage.reduce((sum, entry) => sum + entry.estimated_cost_units, 0);\n746:   return {\n747:     max_aggregate_cost_units: aggregateGuards.max_aggregate_cost_units,\n748:     estimated_cost_units: estimatedCostUnits,\n749:     lineage_count: perLineage.length,\n750:     per_lineage: perLineage,\n751:   };\n752: }\n753: \n754: function evaluateAggregateBudgetCap(input = {}) {\n755:   const upperBound = computeAggregateBudgetUpperBound(\n756:     input.lineages || [],\n757:     input.guards || input,\n758:     input.maxRetries,\n759:   );\n760:   const exceeded = upperBound.max_aggregate_cost_units > 0\n761:     && upperBound.estimated_cost_units > upperBound.max_aggregate_cost_units;\n762:   return {\n763:     continue_allowed: !exceeded,\n764:     stop_reasons: exceeded ? ['max_aggregate_cost_units'] : [],\n765:     upper_bound: upperBound,\n766:   };\n767: }\n768: \n769: function buildTimestampAnomalyCounts(check) {\n770:   return {\n771:     anomalous: check.anomalous,\n772:     untimestamped: check.untimestamped,\n773:     unparseable: check.unparseable,\n774:     total: check.total,\n775:   };\n776: }\n777: \n778: function buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n779:   return {\n780:     label: lineage.label,\n781:     state_log: statePath,\n782:     window: {\n783:       start_at_iso: check.windowStart,\n784:       end_at_iso: check.windowEnd,\n785:       tolerance_ms: check.toleranceMs,\n786:     },\n787:     counts: buildTimestampAnomalyCounts(check),\n788:     sample: check.sample,\n789:   };\n790: }\n791: \n792: function collectTimestampAnomalies(results) {\n793:   return results\n794:     .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n795:     .map((result) => result.output.timestamp_anomaly);\n796: }\n797: \n798: function normalizeNonNegativeDelayMs(value) {\n799:   if (value === undefined || value === null) return null;\n800:   const n = Number(value);\n801:   if (!Number.isFinite(n) || n < 0) return null;\n802:   return Math.floor(n);\n803: }\n804: \n805: function normalizeWaitDurationMs(value) {\n806:   return normalizeNonNegativeDelayMs(value) ?? 0;\n807: }\n808: \n809: function waitCheckpointPath(baseArtifactDir) {\n810:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n811: }\n812: \n813: function atomicWriteJson(filePath, payload) {\n814:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n815:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n816:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n817:   fs.renameSync(tmpPath, filePath);\n818: }\n819: \n820: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n821:   const durationMs = normalizeWaitDurationMs(waitMs);\n822:   const updatedAt = new Date(nowMs).toISOString();\n823:   if (durationMs <= 0) {\n824:     return {\n825:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n826:       status: 'idle',\n827:       nextRunAt: null,\n828:       remainingDelayMs: null,\n829:       updatedAt,\n830:       runId,\n831:       loopType,\n832:       specFolder,\n833:     };\n834:   }\n835: \n836:   return {\n837:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n838:     status: 'waiting',\n839:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n840:     remainingDelayMs: durationMs,\n841:     updatedAt,\n842:     runId,\n843:     loopType,\n844:     specFolder,\n845:   };\n846: }\n847: \n848: function normalizeWaitCheckpoint(raw, context) {\n849:   if (!isRecord(raw)) {\n850:     throw inputError('wait checkpoint must be a JSON object');\n851:   }\n852: \n853:   const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n854:   const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n855:   const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n856:   const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n857:     ? raw.nextRunAt\n858:     : null;\n859:   const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n860:   const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n861:   const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n862:   const base = {\n863:     runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n864:     loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n865:     specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n866:   };\n867: \n868:   const checkpoint = waiting\n869:     ? {\n870:         schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n871:         status: 'waiting',\n872:         nextRunAt,\n873:         remainingDelayMs,\n874:         updatedAt: new Date(nowMs).toISOString(),\n875:         ...base,\n876:       }\n877:     : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n878:   const staleWaitingFields = !waiting\n879:     && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n880:   const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n881: \n882:   return {\n883:     checkpoint,\n884:     migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n885:   };\n886: }\n887: \n888: function readWaitCheckpoint(checkpointPath, context) {\n889:   if (!fs.existsSync(checkpointPath)) {\n890:     return { exists: false, checkpoint: null, migrated: false };\n891:   }\n892: \n893:   let raw;\n894:   try {\n895:     raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n896:   } catch (error) {\n897:     throw inputError(\n898:       `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n899:     );\n900:   }\n901: \n902:   const normalized = normalizeWaitCheckpoint(raw, context);\n903:   if (normalized.migrated) {\n904:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n905:   }\n906:   return { exists: true, ...normalized };\n907: }\n908: \n909: function sleepWaitChunk(ms) {\n910:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n911: }\n912: \n913: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n914:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n915:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n916: \n917:   while (remainingDelayMs > 0) {\n918:     atomicWriteJson(checkpointPath, {\n919:       ...checkpoint,\n920:       remainingDelayMs,\n921:       updatedAt: new Date().toISOString(),\n922:     });\n923:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n924:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n925:   }\n926: \n927:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n928: }\n929: \n930: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n931:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n932:   const loaded = readWaitCheckpoint(checkpointPath, context);\n933:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n934:     return { didWait: false, migrated: loaded.migrated };\n935:   }\n936: \n937:   appendFanoutStatusLedger(ledgerPath, {\n938:     event: 'resume_waiting',\n939:     at: new Date().toISOString(),\n940:     run_id: runId,\n941:     loop_type: loopType,\n942:     spec_folder: specFolder,\n943:     nextRunAt: loaded.checkpoint.nextRunAt,\n944:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n945:   });\n946: \n947:   await waitUntilCheckpointExpires({\n948:     checkpointPath,\n949:     checkpoint: loaded.checkpoint,\n950:     context: { runId, loopType, specFolder },\n951:   });\n952: \n953:   appendFanoutStatusLedger(ledgerPath, {\n954:     event: 'resume_waiting_complete',\n955:     at: new Date().toISOString(),\n956:     run_id: runId,\n957:     loop_type: loopType,\n958:     spec_folder: specFolder,\n959:   });\n960: \n961:   return { didWait: true, migrated: loaded.migrated };\n962: }\n963: \n964: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n965:   const durationMs = normalizeWaitDurationMs(waitMs);\n966:   if (durationMs <= 0) {\n967:     return { didWait: false };\n968:   }\n969: \n970:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n971:   atomicWriteJson(checkpointPath, checkpoint);\n972:   appendFanoutStatusLedger(ledgerPath, {\n973:     event: 'wait_checkpoint_persisted',\n974:     at: checkpoint.updatedAt,\n975:     run_id: runId,\n976:     loop_type: loopType,\n977:     spec_folder: specFolder,\n978:     nextRunAt: checkpoint.nextRunAt,\n979:     remainingDelayMs: checkpoint.remainingDelayMs,\n980:   });\n981: \n982:   await waitUntilCheckpointExpires({\n983:     checkpointPath,\n984:     checkpoint,\n985:     context: { runId, loopType, specFolder },\n986:   });\n987: \n988:   appendFanoutStatusLedger(ledgerPath, {\n989:     event: 'wait_checkpoint_cleared',\n990:     at: new Date().toISOString(),\n991:     run_id: runId,\n992:     loop_type: loopType,\n993:     spec_folder: specFolder,\n994:   });\n995: \n996:   return { didWait: true };\n997: }\n998: \n999: /**\n1000:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1001:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1002:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1003:  */\n1004: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1005:   assertActiveFanoutLoopType(loopType);\n1006:   const skillFile =\n1007:     loopType === 'review'\n1008:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1009:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1010:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1011:   const detachedIntro = lineage.kind === 'cli-opencode'\n1012:     ? [\n1013:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1014:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1015:         ``,\n1016:       ]\n1017:     : lineage.kind === 'native'\n1018:       ? [\n1019:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1020:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1021:           ``,\n1022:         ]\n1023:       : [];\n1024:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1025:   const stopPolicy = options.stopPolicy || 'convergence';\n1026:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1027:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1028:     : hasIterationCap\n1029:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1030:       : 'to legal convergence';\n1031:   const params = [\n1032:     `  spec_folder: ${specFolder}`,\n1033:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1034:     `  session_id: ${sessionId}`,\n1035:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1036:     `  loop_type: ${loopType}`,\n1037:     `  config.stopPolicy: ${stopPolicy}`,\n1038:   ];\n1039:   if (researchTopic) {\n1040:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1041:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1042:     // Review loops scope by spec_folder and intentionally pass no topic.\n1043:     params.push(`  research_topic: ${researchTopic}`);\n1044:   }\n1045:   if (hasIterationCap) {\n1046:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1047:   }\n1048:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1049:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1050:   }\n1051:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1052:   // still requires the same review setup bindings the native command path pre-binds.\n1053:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1054:   // different setup contract than native lineages.\n1055:   const setupBindings =\n1056:     loopType === 'review'\n1057:       ? [\n1058:           ``,\n1059:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1060:           `review_target: ${specFolder}`,\n1061:           `review_target_type: spec-folder`,\n1062:           `review_dimensions: all`,\n1063:           `spec_folder: ${specFolder}`,\n1064:           `execution_mode: AUTONOMOUS`,\n1065:           `lineage_mode: auto`,\n1066:           ``,\n1067:         ]\n1068:       : [];\n1069:   return [\n1070:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1071:     ...detachedIntro,\n1072:     ``,\n1073:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1074:     ...params,\n1075:     ...setupBindings,\n1076:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1077:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1078:     `command; bind artifact_dir directly to the override value.`,\n1079:     ``,\n1080:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1081:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1082:     ``,\n1083:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1084:   ].join('\\n');\n1085: }\n1086: \n1087: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1088:   assertActiveFanoutLoopType(loopType);\n1089:   const maxIterations = lineage.iterations || 12;\n1090:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1091:   const stopPolicy = options.stopPolicy || 'convergence';\n1092:   const sessionId = options.sessionId || '';\n1093:   const args = [\n1094:     ':auto',\n1095:     JSON.stringify(specFolder),\n1096:     `--spec-folder=${specFolder}`,\n1097:     `--max-iterations=${maxIterations}`,\n1098:     `--convergence=${convergenceThreshold}`,\n1099:     `--stop-policy=${stopPolicy}`,\n1100:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1101:     '--lineage-mode=auto',\n1102:   ];\n1103:   if (loopType === 'research' && options.researchTopic) {\n1104:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1105:   }\n1106: \n1107:   return [\n1108:     args.join(' '),\n1109:     '',\n1110:     'PRE-BOUND SETUP ANSWERS:',\n1111:     `review_target: ${specFolder}`,\n1112:     'review_target_type: spec-folder',\n1113:     'review_dimensions: all',\n1114:     `spec_folder: ${specFolder}`,\n1115:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1116:     'execution_mode: AUTONOMOUS',\n1117:     'lineage_mode: auto',\n1118:     `maxIterations: ${maxIterations}`,\n1119:     `convergenceThreshold: ${convergenceThreshold}`,\n1120:     `stop_policy: ${stopPolicy}`,\n1121:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1122:   ].join('\\n');\n1123: }\n1124: \n1125: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1126: // ceiling and a positive override may only narrow it, never widen past it.\n1127: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1128: \n1129: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1130:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1131:     throw inputError(\n1132:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1133:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1134:     );\n1135:   }\n1136: }\n1137: \n1138: /**\n1139:  * Compute a generous timeout for a full lineage loop run.\n1140:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1141:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1142:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1143:  */\n1144: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1145:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1146:   const iters = lineage.iterations || 12;\n1147:   const perIterSecs = lineage.timeoutSeconds || 900;\n1148:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1149:     ? ceilingHoursOverride * 60 * 60 * 1000\n1150:     : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n1151:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1152: }\n1153: \n1154: function normalizeProgressHeartbeatMs(seconds) {\n1155:   const value = Number(seconds);\n1156:   if (!Number.isFinite(value) || value <= 0) return 0;\n1157:   return Math.max(1, Math.floor(value * 1000));\n1158: }\n1159: \n1160: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1161:   const explicit = readRawConfigNumber(rawConfig, [\n1162:     'postExitGraceMs',\n1163:     'post_exit_grace_ms',\n1164:     'postSubprocessExitGraceMs',\n1165:     'post_subprocess_exit_grace_ms',\n1166:     'orchestratorPostExitGraceMs',\n1167:     'orchestrator_post_exit_grace_ms',\n1168:   ], 'postExitGraceMs');\n1169:   if (explicit !== null) return explicit;\n1170: \n1171:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1172:     ? progressHeartbeatMs * 2\n1173:     : 0;\n1174:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1175: }\n1176: \n1177: function slotDurationMsFromHrtime(hrStart) {\n1178:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1179:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1180: }\n1181: \n1182: function computeSkippedCount(slotDurationMs, intervalMs) {\n1183:   const elapsed = Number(slotDurationMs);\n1184:   const interval = Number(intervalMs);\n1185:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1186:     return 0;\n1187:   }\n1188:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1189: }\n1190: \n1191: function buildSlotAccounting(hrStart, intervalMs) {\n1192:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1193:   return {\n1194:     slotDurationMs,\n1195:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1196:   };\n1197: }\n1198: \n1199: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1200:   if (!event || typeof event.label !== 'string') return event;\n1201:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1202: \n1203:   const accounting = accountingByLabel.get(event.label);\n1204:   if (!accounting) return event;\n1205:   return {\n1206:     ...event,\n1207:     skippedCount: accounting.skippedCount,\n1208:     slotDurationMs: accounting.slotDurationMs,\n1209:   };\n1210: }\n1211: \n1212: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1213:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1214:     return () => {};\n1215:   }\n1216:   const startedAtMs = Date.now();\n1217:   const timer = setInterval(() => {\n1218:     appendFanoutStatusLedger(ledgerPath, {\n1219:       event: 'progress',\n1220:       label,\n1221:       at: new Date().toISOString(),\n1222:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1223:         gauges: getGauges(),\n1224:       });\n1225:       if (typeof onProgress === 'function') onProgress();\n1226:     }, cadenceMs);\n1227:   timer.unref?.();\n1228:   return () => clearInterval(timer);\n1229: }\n1230: \n1231: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1232:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1233:     return () => {};\n1234:   }\n1235: \n1236:   let timer = null;\n1237:   let fired = false;\n1238:   const schedule = () => {\n1239:     if (fired) return;\n1240:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1241:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1242:     timer = setTimeout(() => {\n1243:       timer = null;\n1244:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1245:       if (latestQuietMs >= thresholdMs) {\n1246:         fired = true;\n1247:         appendFanoutStatusLedger(ledgerPath, {\n1248:           event: 'stall_detected',\n1249:           label,\n1250:           at: new Date().toISOString(),\n1251:           severity: 'warning',\n1252:           metric: 'time_since_last_lineage_event',\n1253:           stall_watchdog_ms: thresholdMs,\n1254:           quiet_ms: Math.floor(latestQuietMs),\n1255:           gauges: getGauges(),\n1256:         });\n1257:         return;\n1258:       }\n1259:       schedule();\n1260:     }, delayMs);\n1261:     timer.unref?.();\n1262:   };\n1263: \n1264:   schedule();\n1265:   return () => {\n1266:     fired = true;\n1267:     if (timer) clearTimeout(timer);\n1268:   };\n1269: }\n1270: \n1271: /**\n1272:  * Run a lineage subprocess without blocking the Node event loop.\n1273:  *\n1274:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1275:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1276:  * thread until each child exited, serializing every lineage regardless of the\n1277:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1278:  *\n1279:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1280:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1281:  *\n1282:  * @param {string} command - Executable to run.\n1283:  * @param {string[]} cmdArgs - Arguments for the executable.\n1284:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1285:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1286:  */\n1287: function runLineageProcess(command, cmdArgs, opts) {\n1288:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1289:   const hasInput = typeof opts.input === 'string';\n1290: \n1291:   return new Promise((resolvePromise) => {\n1292:     let child;\n1293:     try {\n1294:       child = spawn(command, cmdArgs, {\n1295:         cwd,\n1296:         env,\n1297:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1298:         detached: process.platform !== 'win32',\n1299:       });\n1300:     } catch (error) {\n1301:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1302:       return;\n1303:     }\n1304:     activeLineageProcesses.add(child);\n1305:     if (typeof opts.onSpawn === 'function') {\n1306:       opts.onSpawn({ pid: child.pid });\n1307:     }\n1308: \n1309:     let stdout = '';\n1310:     let stdoutBytes = 0;\n1311:     let truncated = false;\n1312:     let timedOut = false;\n1313:     let settled = false;\n1314:     let spawnError;\n1315: \n1316:     const timer = setTimeout(() => {\n1317:       timedOut = true;\n1318:       terminateLineageProcess(child, 'SIGTERM');\n1319:     }, timeoutMs);\n1320:     timer.unref?.();\n1321: \n1322:     const abortHandler = () => {\n1323:       terminateLineageProcess(child, 'SIGTERM');\n1324:     };\n1325:     if (opts.abortSignal) {\n1326:       if (opts.abortSignal.aborted) {\n1327:         abortHandler();\n1328:       } else {\n1329:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1330:       }\n1331:     }\n1332: \n1333:     child.stdout?.setEncoding('utf8');\n1334:     child.stdout?.on('data', (chunk) => {\n1335:       if (typeof opts.onOutput === 'function') opts.onOutput();\n1336:       if (truncated) return;\n1337:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1338:       if (stdoutBytes > maxBuffer) {\n1339:         truncated = true;\n1340:         terminateLineageProcess(child, 'SIGTERM');\n1341:         return;\n1342:       }\n1343:       stdout += chunk;\n1344:     });\n1345:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1346:     child.stderr?.resume();\n1347: \n1348:     child.on('error', (error) => {\n1349:       spawnError = error;\n1350:     });\n1351: \n1352:     child.on('close', (code, signal) => {\n1353:       if (settled) return;\n1354:       settled = true;\n1355:       activeLineageProcesses.delete(child);\n1356:       clearTimeout(timer);\n1357:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1358:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1359:       if (typeof opts.onExit === 'function') {\n1360:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1361:       }\n1362:       resolvePromise({\n1363:         status: timedOut ? null : code,\n1364:         signal: effectiveSignal,\n1365:         stdout,\n1366:         ...(spawnError ? { error: spawnError } : {}),\n1367:       });\n1368:     });\n1369: \n1370:     if (hasInput) {\n1371:       child.stdin?.on('error', () => {});\n1372:       child.stdin?.end(opts.input);\n1373:     }\n1374:   });\n1375: }\n1376: \n1377: /**\n1378:  * Build the subprocess command for a fan-out lineage.\n1379:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1380:  */\n1381: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1382:   const kind = lineage.kind;\n1383: \n1384:   if (kind === 'cli-claude-code') {\n1385:     const args = [\n1386:       '-p',\n1387:       prompt,\n1388:       '--model',\n1389:       lineage.model || 'claude-opus-4-8',\n1390:       '--permission-mode',\n1391:       resolvedPermission,\n1392:       '--output-format',\n1393:       'text',\n1394:     ];\n1395:     if (lineage.reasoningEffort) {\n1396:       args.push('--effort', lineage.reasoningEffort);\n1397:     }\n1398:     return { command: 'claude', args };\n1399:   }\n1400: \n1401:   if (kind === 'native') {\n1402:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1403:     // For review runs this is the real deep/review command surface with a lineage\n1404:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1405:     const args = [\n1406:       'run',\n1407:       '--format',\n1408:       'json',\n1409:       '--dangerously-skip-permissions',\n1410:       '--dir',\n1411:       process.cwd(),\n1412:       '--command',\n1413:       `deep/${options.loopType || 'review'}`,\n1414:     ];\n1415:     args.push(buildNativeCommandInput(\n1416:       options.loopType || 'review',\n1417:       options.specFolder || '',\n1418:       options.lineageDir || '',\n1419:       lineage,\n1420:       options,\n1421:     ));\n1422:     return { command: 'opencode', args, input: '' };\n1423:   }\n1424: \n1425:   if (kind === 'cli-opencode') {\n1426:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1427:     // on a top-level `run`. The default agent runs when none is named, and a\n1428:     // specific agent profile can be requested in the prompt body instead.\n1429:     const args = [\n1430:       'run',\n1431:       '--model',\n1432:       lineage.model || 'anthropic/claude-opus-4-8',\n1433:       '--format',\n1434:       'json',\n1435:       '--pure',\n1436:       '--dir',\n1437:       process.cwd(),\n1438:     ];\n1439:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1440:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1441:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1442:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1443:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n\n(Output capped at 50 KB. Showing lines 1-1443. Use offset=1444 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\nconst { spawn } = require('node:child_process');\n\nconst {\n  classifyExitCode,\n  maybeThrowTestFault,\n  validateNamespaceValue,\n} = require('./lib/cli-guards.cjs');\n\nconst {\n  runCappedPool,\n  appendStatusLedger,\n  markOrphanedLineages,\n  readRetryCountsFromLedger,\n  createWavePlannerInterface,\n  writeOrchestrationSummary,\n} = require('./fanout-pool.cjs');\n\nconst {\n  runSalvageSweep,\n  extractTextFromOpencodeJson,\n} = require('./fanout-salvage.cjs');\n\nconst {\n  appendObservabilityEvent,\n} = require('../lib/deep-loop/observability-events.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\nconst isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n\nfunction runTsxBootstrap() {\n  const child = spawn(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n    },\n  );\n\n  if (!process.stdin.isTTY && child.stdin) {\n    child.stdin.on('error', () => {});\n    process.stdin.pipe(child.stdin);\n  }\n\n  child.stdout?.pipe(process.stdout);\n  child.stderr?.pipe(process.stderr);\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      child.kill(signal);\n    });\n  }\n\n  child.on('close', (status, signal) => {\n    if (status !== null) {\n      process.exit(status);\n    }\n    process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n  });\n}\n\nif (require.main === module && !isTsxLoaded) {\n  runTsxBootstrap();\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction parseOptionalNumber(args, key) {\n  const raw = args[key];\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return null;\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError(`${key} must be a number`);\n  }\n  const value = Number(raw);\n  if (!Number.isFinite(value) || value < 0) {\n    throw inputError(`${key} must be a non-negative number`);\n  }\n  return value;\n}\n\nfunction readRawConfigNumber(rawConfig, names, fieldName) {\n  if (!isRecord(rawConfig)) return null;\n  for (const name of names) {\n    if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n    const raw = rawConfig[name];\n    if (raw === undefined || raw === null || raw === '') return null;\n    if (raw === true || raw === false) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    const value = Number(raw);\n    if (!Number.isFinite(value) || value < 0) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    return Math.floor(value);\n  }\n  return null;\n}\n\nfunction readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n  const value = readRawConfigNumber(rawConfig, names, fieldName);\n  if (value === null) return fallback;\n  if (value <= 0) {\n    throw inputError(`${fieldName} must be greater than 0`);\n  }\n  return value;\n}\n\nfunction rawConfigWithCliBudgetOverrides(rawConfig, args) {\n  const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n  const mappings = [\n    ['stallWatchdogMs', 'stallWatchdogMs'],\n    ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n    ['maxAggregateCostUnits', 'maxAggregateCostUnits'],\n    ['maxTokensPerLineage', 'maxTokensPerLineage'],\n    ['maxTokenBudget', 'maxTokenBudget'],\n    ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n    ['costUnitsPerIteration', 'costUnitsPerIteration'],\n    ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n  ];\n  for (const [targetKey, argKey] of mappings) {\n    if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n      merged[targetKey] = args[argKey];\n    }\n  }\n  return merged;\n}\n\nfunction normalizeStopPolicy(raw) {\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return 'convergence';\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  if (raw !== 'convergence' && raw !== 'max-iterations') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  return raw;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\nfunction signalExitCode(signal) {\n  return signal === 'SIGINT' ? 130 : 143;\n}\n\nlet fanoutSignalHandlersInstalled = false;\n\nfunction installFanoutSignalHandlers(onStop) {\n  if (fanoutSignalHandlersInstalled) return;\n  fanoutSignalHandlersInstalled = true;\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      try {\n        onStop(signal);\n      } finally {\n        process.exit(signalExitCode(signal));\n      }\n    });\n  }\n}\n\nfunction updateLineageSnapshot(snapshots, event) {\n  if (!event || typeof event.label !== 'string') return;\n  const existing = snapshots.get(event.label) || { label: event.label };\n\n  if (event.event === 'started') {\n    snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'completed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'fulfilled',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n    return;\n  }\n  if (event.event === 'failed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: event.terminal === false ? 'retrying' : 'rejected',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n      error: event.error,\n    });\n    return;\n  }\n  if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n    snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'progress') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'running',\n      updated_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n  }\n}\n\nfunction buildLineageSnapshots(lineages, snapshots) {\n  return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n}\n\nfunction summarizeSnapshots(lineages, snapshots) {\n  const results = buildLineageSnapshots(lineages, snapshots);\n  const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n  const failed = results.filter((result) => result.status === 'rejected').length;\n  return {\n    results,\n    summary: {\n      total: lineages.length,\n      succeeded,\n      failed,\n      all_failed: lineages.length > 0 && failed === lineages.length,\n    },\n  };\n}\n\nfunction observabilityPathForLedger(ledgerPath) {\n  return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n}\n\nfunction statusForLedgerEvent(entry) {\n  if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n    return entry.status;\n  }\n  if (!entry || typeof entry.event !== 'string') return 'unknown';\n  if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n  if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n  if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n  if (entry.event === 'stopped') return 'stopped';\n  if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n  // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n  // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n  if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n  if (entry.event === 'lag_ceiling_abort') return 'failed';\n  if (entry.event === 'stall_detected') return 'warning';\n  if (entry.event === 'budget_cap_exceeded') return 'failed';\n  if (entry.event === 'aggregate_budget_cap_exceeded') return 'failed';\n  return 'unknown';\n}\n\nfunction appendFanoutStatusLedger(ledgerPath, entry) {\n  appendStatusLedger(ledgerPath, entry);\n  try {\n    appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n      producer: 'fanout-run',\n      stream: 'orchestration-status',\n      subject: {\n        run_id: entry.run_id ?? null,\n        label: entry.label ?? null,\n        loop_type: entry.loop_type ?? null,\n        spec_folder: entry.spec_folder ?? null,\n      },\n      event: entry.event,\n      status: statusForLedgerEvent(entry),\n    });\n  } catch {\n    // Observability must not make the primary orchestration ledger fail.\n  }\n}\n\nconst FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\nconst WAVE_ASSIGNMENT_MODEL = 'wave';\nconst WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\nconst WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\nconst STATE_LOG_BY_LOOP_TYPE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n};\nconst ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\nconst DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n\nfunction assertActiveFanoutLoopType(loopType) {\n  if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n    throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n  }\n}\n\nfunction hasNonEmptyArrayField(value) {\n  return Array.isArray(value) && value.length > 0;\n}\n\nfunction collectFlatPoolGuardRejections(fanoutConfig) {\n  const rejections = [];\n  if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n    rejections.push({\n      scope: 'fanout',\n      label: null,\n      field: 'assignment_model',\n      message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n    });\n  }\n\n  for (const lineage of fanoutConfig.executors) {\n    if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: 'assignment_model',\n        message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n      });\n    }\n\n    const reservedFields = [];\n    if (hasNonEmptyArrayField(lineage.depends_on)) {\n      reservedFields.push('depends_on');\n    }\n    if (hasNonEmptyArrayField(lineage.touches)) {\n      reservedFields.push('touches');\n    }\n    if (reservedFields.length > 0) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: reservedFields.join(','),\n        message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n      });\n    }\n  }\n\n  return rejections;\n}\n\n/**\n * Force fan-out execution onto the existing flat pool while wave planning is gated.\n *\n * @param {Object} fanoutConfig - Parsed fan-out config.\n * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n */\nfunction applyFlatPoolAssignmentGuard(fanoutConfig) {\n  const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n  return {\n    config: {\n      ...fanoutConfig,\n      assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      executors: fanoutConfig.executors.map((lineage) => ({\n        ...lineage,\n        assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      })),\n    },\n    rejections,\n  };\n}\n\nfunction logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n  if (rejections.length === 0) {\n    return;\n  }\n  const wavePlanner = createWavePlannerInterface();\n  for (const rejection of rejections) {\n    const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n    process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'assignment_model_rejected',\n      severity: 'warning',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      planner_status: wavePlanner.status,\n      fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      ...rejection,\n    });\n  }\n}\n\n// Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\nconst SPECKIT_STATE_ENV_BY_KIND = {\n  'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n  'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n};\n\nconst activeLineageProcesses = new Set();\nconst WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\nconst WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\nconst WAIT_SLEEP_CHUNK_MS = 200;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\nconst DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n\nfunction stopActiveLineageProcesses(signal) {\n  for (const child of activeLineageProcesses) {\n    terminateLineageProcess(child, signal);\n  }\n}\n\nfunction expandHomeDir(inputPath) {\n  if (inputPath === '~') {\n    return os.homedir();\n  }\n  if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n    return path.join(os.homedir(), inputPath.slice(2));\n  }\n  return inputPath;\n}\n\nfunction isPathInside(childPath, parentPath) {\n  const relative = path.relative(parentPath, childPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction physicalPathForValidation(targetPath) {\n  try {\n    return fs.realpathSync.native(targetPath);\n  } catch {\n    const parentPath = path.dirname(targetPath);\n    try {\n      return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n    } catch {\n      return targetPath;\n    }\n  }\n}\n\nfunction validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n  if (baseArtifactDir.includes('\\0')) {\n    throw inputError('baseArtifactDir must not contain null bytes');\n  }\n  if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n    throw inputError('baseArtifactDir must not contain \"..\" path segments');\n  }\n  const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n  const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n  const expectedRoot = path.join(resolvedSpecFolder, loopType);\n  if (!isPathInside(resolvedBase, expectedRoot)) {\n    throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n  }\n  return baseArtifactDir;\n}\n\nfunction validateClaudeConfigDir(configDir) {\n  if (typeof configDir !== 'string' || configDir.trim() === '') {\n    throw inputError('configDir must be a non-empty string when set');\n  }\n  validateNamespaceValue(configDir, 'configDir', inputError);\n\n  const expanded = expandHomeDir(configDir);\n  const resolved = path.resolve(process.cwd(), expanded);\n  const homeDir = path.resolve(os.homedir());\n  const cwd = path.resolve(process.cwd());\n  const homeRelative = path.relative(homeDir, resolved);\n  const cwdRelative = path.relative(cwd, resolved);\n  const homeTop = homeRelative.split(path.sep)[0] || '';\n  const cwdTop = cwdRelative.split(path.sep)[0] || '';\n  const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n\n  if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n    return resolved;\n  }\n  if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n    return resolved;\n  }\n  throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {\n    child.kill(signal);\n  } catch {\n    // The process may have already exited.\n  }\n}\n\nfunction expectedLineageArtifactPaths(loopType, lineageDir) {\n  assertActiveFanoutLoopType(loopType);\n  if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n  return [path.join(lineageDir, 'research.md')];\n}\n\nfunction hasNonEmptyFile(filePath) {\n  try {\n    return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n  } catch {\n    return false;\n  }\n}\n\nfunction findMissingLineageArtifacts(loopType, lineageDir) {\n  return expectedLineageArtifactPaths(loopType, lineageDir)\n    .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n}\n\nfunction parseJsonlRecords(filePath) {\n  const text = fs.readFileSync(filePath, 'utf8');\n  return text\n    .split(/\\r?\\n/)\n    .filter((line) => line.trim() !== '')\n    .map((line) => JSON.parse(line));\n}\n\nfunction lineageStateLogName(loopType) {\n  return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n}\n\nfunction readLineageStateRecords(loopType, lineageDir) {\n  const stateLogName = lineageStateLogName(loopType);\n  if (!stateLogName) {\n    return { statePath: null, records: [], missing: true, parseError: null };\n  }\n  const statePath = path.join(lineageDir, stateLogName);\n  if (!hasNonEmptyFile(statePath)) {\n    return { statePath, records: [], missing: true, parseError: null };\n  }\n  try {\n    return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n  } catch (error) {\n    return {\n      statePath,\n      records: [],\n      missing: false,\n      parseError: error instanceof Error ? error.message : String(error),\n    };\n  }\n}\n\n// A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n// spelling. The iteration-count check above already proves the lineage ran every iteration,\n// so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n// \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n// such as convergence, a manual stop, or an error.\nfunction isMaxIterationsStopReason(stopReason) {\n  if (typeof stopReason !== 'string') return false;\n  return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n}\n\nfunction findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n  if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n  if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n    return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n  }\n\n  if (!stateRead || stateRead.missing) {\n    return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n  }\n  if (stateRead.parseError) {\n    return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n  }\n\n  const records = stateRead.records;\n  const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n  const synthesis = [...records]\n    .reverse()\n    .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n  if (!synthesis) {\n    return 'missing synthesis_complete event for max-iterations stop-policy validation';\n  }\n\n  const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n    ? Number(synthesis.totalIterations)\n    : iterationCount;\n  if (totalIterations !== lineage.iterations) {\n    return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n  }\n  if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n    return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n  }\n  return null;\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n  // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n  // because this knob is intentionally outside fanoutConfigSchema. Non-disableable while\n  // running autonomously: an explicit 0 no longer opts out, it is rejected.\n  const value = readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs');\n  if (value === 0) {\n    throw inputError('stallWatchdogMs must be greater than 0; stall detection cannot be disabled for autonomous fan-out runs');\n  }\n  return value ?? 300000;\n}\n\nconst DEFAULT_MAX_COST_UNITS_PER_LINEAGE = 72;\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? DEFAULT_MAX_COST_UNITS_PER_LINEAGE,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}, maxRetries = 0) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  const normalizedRetries = Number.isFinite(Number(maxRetries)) && Number(maxRetries) >= 0\n    ? Math.floor(Number(maxRetries))\n    : 0;\n  const totalAttempts = normalizedRetries + 1;\n  return {\n    ...guards,\n    iterations,\n    total_attempts: totalAttempts,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration * totalAttempts,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(\n    input.lineage || {},\n    input.guards || input,\n    input.maxRetries,\n  );\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\n// Aggregate budget across every expanded lineage in a run. This is a SEPARATE ceiling\n// from DEFAULT_MAX_COST_UNITS_PER_LINEAGE above: the per-lineage cap bounds any single\n// lineage, this bounds the whole fan-out submission, and both are enforced independently\n// (a run may pass one and still fail the other).\nconst DEFAULT_MAX_AGGREGATE_COST_UNITS = 288;\n\nfunction normalizeAggregateBudgetGuards(rawConfig = {}) {\n  return {\n    max_aggregate_cost_units: readRawConfigNumber(rawConfig, [\n      'maxAggregateCostUnits',\n      'max_aggregate_cost_units',\n      'maxTotalCostUnits',\n      'max_total_cost_units',\n    ], 'maxAggregateCostUnits') ?? DEFAULT_MAX_AGGREGATE_COST_UNITS,\n  };\n}\n\nfunction computeAggregateBudgetUpperBound(lineages, guardsInput = {}, maxRetries = 0) {\n  const aggregateGuards = normalizeAggregateBudgetGuards(guardsInput);\n  const lineageGuards = normalizeLineageBudgetGuards(guardsInput);\n  const perLineage = (lineages || []).map((lineage) => {\n    const upperBound = computeLineageBudgetUpperBound(lineage, lineageGuards, maxRetries);\n    return { label: lineage && lineage.label, estimated_cost_units: upperBound.estimated_cost_units };\n  });\n  const estimatedCostUnits = perLineage.reduce((sum, entry) => sum + entry.estimated_cost_units, 0);\n  return {\n    max_aggregate_cost_units: aggregateGuards.max_aggregate_cost_units,\n    estimated_cost_units: estimatedCostUnits,\n    lineage_count: perLineage.length,\n    per_lineage: perLineage,\n  };\n}\n\nfunction evaluateAggregateBudgetCap(input = {}) {\n  const upperBound = computeAggregateBudgetUpperBound(\n    input.lineages || [],\n    input.guards || input,\n    input.maxRetries,\n  );\n  const exceeded = upperBound.max_aggregate_cost_units > 0\n    && upperBound.estimated_cost_units > upperBound.max_aggregate_cost_units;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_aggregate_cost_units'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction buildTimestampAnomalyCounts(check) {\n  return {\n    anomalous: check.anomalous,\n    untimestamped: check.untimestamped,\n    unparseable: check.unparseable,\n    total: check.total,\n  };\n}\n\nfunction buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n  return {\n    label: lineage.label,\n    state_log: statePath,\n    window: {\n      start_at_iso: check.windowStart,\n      end_at_iso: check.windowEnd,\n      tolerance_ms: check.toleranceMs,\n    },\n    counts: buildTimestampAnomalyCounts(check),\n    sample: check.sample,\n  };\n}\n\nfunction collectTimestampAnomalies(results) {\n  return results\n    .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n    .map((result) => result.output.timestamp_anomaly);\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };\n}\n\nfunction normalizeWaitCheckpoint(raw, context) {\n  if (!isRecord(raw)) {\n    throw inputError('wait checkpoint must be a JSON object');\n  }\n\n  const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n  const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n  const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n  const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n    ? raw.nextRunAt\n    : null;\n  const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n  const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n  const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n  const base = {\n    runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n    loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n    specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n  };\n\n  const checkpoint = waiting\n    ? {\n        schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n        status: 'waiting',\n        nextRunAt,\n        remainingDelayMs,\n        updatedAt: new Date(nowMs).toISOString(),\n        ...base,\n      }\n    : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n  const staleWaitingFields = !waiting\n    && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n  const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n\n  return {\n    checkpoint,\n    migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n  };\n}\n\nfunction readWaitCheckpoint(checkpointPath, context) {\n  if (!fs.existsSync(checkpointPath)) {\n    return { exists: false, checkpoint: null, migrated: false };\n  }\n\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n  } catch (error) {\n    throw inputError(\n      `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n\n  const normalized = normalizeWaitCheckpoint(raw, context);\n  if (normalized.migrated) {\n    atomicWriteJson(checkpointPath, normalized.checkpoint);\n  }\n  return { exists: true, ...normalized };\n}\n\nfunction sleepWaitChunk(ms) {\n  return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n}\n\nasync function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n  const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n  let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n\n  while (remainingDelayMs > 0) {\n    atomicWriteJson(checkpointPath, {\n      ...checkpoint,\n      remainingDelayMs,\n      updatedAt: new Date().toISOString(),\n    });\n    await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n    remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n  }\n\n  atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n}\n\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n      : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n// Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n// ceiling and a positive override may only narrow it, never widen past it.\nconst LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n\nfunction assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n  if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n    throw inputError(\n      `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n        + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n    );\n  }\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (typeof opts.onOutput === 'function') opts.onOutput();\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n    // --dangerously-skip-permissions so their writes are subject to the CLI permission\n    // boundary. opencode has no path-scoped write flag, so a workspace-write review\n    // lineage's lineageDir-only boundary still relies on the prompt — but the operator","lineStart":1,"lineEnd":1443,"totalLines":1444,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1783912345020,"end":1783912345043}},"metadata":{"openai":{"itemId":"fc_05b2c0b511cb73fe016a545798f6648191a18b84b8ab57ca9a"}},"id":"prt_f59762dba001wqsgpN8rpcqLzg","sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","messageID":"msg_f5975f967001oRvE3U7uqnZ0zQ"}}
