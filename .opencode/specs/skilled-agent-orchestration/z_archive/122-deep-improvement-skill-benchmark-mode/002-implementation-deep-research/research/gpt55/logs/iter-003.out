 succeeded in 0ms:
     1	#!/usr/bin/env node
     2	'use strict';
     3	
     4	/**
     5	 * scripts/dispatch-model.cjs
     6	 *
     7	 * Model-agnostic CLI dispatcher for the deep-agent-improvement model-benchmark
     8	 * mode. Generalized from 120/003's dispatch-minimax.cjs: same interface and the
     9	 * same rate-limit / backoff / pause-sentinel machinery, but the invocation layer
    10	 * routes through an executor map keyed on `opts.executor` instead of being
    11	 * hardcoded to `opencode run`.
    12	 *
    13	 * Interface (matches the dispatcher seam):
    14	 *   dispatch({ prompt_file, executor, model, agent, variant, state_dir, mock, mock_mode, cwd, timeout_ms })
    15	 *     -> { ok, exit_code, stdout, stderr, attempts, paused?, pause_reason?, sentinel_path?, mock? }
    16	 *
    17	 * Notes:
    18	 *   - `--variant` is forwarded ONLY when opts.variant is set. Agent-improvement
    19	 *     holds it constant (omits it); model-benchmark may vary it as the axis.
    20	 *   - Config (model/agent/executor/timeout/backoff) is read from
    21	 *     improvement_config.json -> modelBenchmarkConfig when present; opts override.
    22	 *   - Mock outputs are model-agnostic and shared with the 120/003 rig shapes.
    23	 *   - Read-only by default (F-P1-1): executors run in their non-write mode;
    24	 *     write-capable evaluation requires DEEP_AGENT_DISPATCH_WRITE=1.
    25	 *   - Pause sentinel is run-scoped (F-P1-14): opts.state_dir / --state-dir /
    26	 *     DEEP_AGENT_STATE_DIR pick the dir; falls back to the skill state/ dir.
    27	 *   - Test-only seams (never set by production callers): opts._spawn overrides
    28	 *     spawnSync; opts._backoff overrides the rate-limit backoff schedule.
    29	 */
    30	
    31	const fs = require('fs');
    32	const path = require('path');
    33	const crypto = require('crypto');
    34	const { spawnSync, execSync } = require('child_process');
    35	
    36	// 121/013: this file now lives in scripts/model-benchmark/, one level deeper
    37	// than the original scripts/ root. SCRIPTS_ROOT is __dirname (model-benchmark/),
    38	// so every path that reaches the skill root needs an extra '..' versus the
    39	// pre-move scripts/-root depth. state/ and assets/ live at the skill root
    40	// (scripts/../.. from here), NOT at scripts/.. .
    41	const SCRIPTS_ROOT = __dirname;
    42	// F-P1-14 (014 review): the pause sentinel is no longer pinned to this shared
    43	// skill state dir. resolveStateDir() prefers a packet-local dir (opts.state_dir
    44	// / --state-dir / DEEP_AGENT_STATE_DIR) so concurrent benchmark runs under
    45	// different spec folders do not collide on one global .benchmark-pause file.
    46	// LEGACY_STATE_DIR is the backstop only when no run-scoped dir is supplied.
    47	const LEGACY_STATE_DIR = path.join(SCRIPTS_ROOT, '..', '..', 'state');
    48	const PAUSE_SENTINEL_BASENAME = '.benchmark-pause';
    49	
    50	// F-P1-1 (014 review): grader/benchmark dispatch is a read-only judgment — the
    51	// model emits its verdict on stdout and must NOT mutate the workspace. Executors
    52	// run in their READ-ONLY mode by default. Write-capable evaluation is an explicit
    53	// opt-in via DEEP_AGENT_DISPATCH_WRITE=1 (e.g. an isolated temp workspace run).
    54	function writeCapableOptIn() {
    55	  const v = process.env.DEEP_AGENT_DISPATCH_WRITE;
    56	  return v === '1' || v === 'true';
    57	}
    58	
    59	function resolveStateDir(opts) {
    60	  return (
    61	    (opts && opts.state_dir) ||
    62	    process.env.DEEP_AGENT_STATE_DIR ||
    63	    LEGACY_STATE_DIR
    64	  );
    65	}
