al\",\"gateClass\":\"hard\",\"applicable\":true,\"counts\":{\"pass\":0,\"partial\":1,\"fail\":0,\"skipped\":0},\"evidence\":[\".opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/scopes/C-rest-of-server/spec.md:1-17\"],\"findingRefs\":[],\"summary\":\"Scope packet has no checklist.md, so checklist evidence protocol is N/A for checked items but incomplete for full deep-review coverage.\"}],\"summary\":{\"core\":\"partial\",\"overlay\":\"not-run\"}},\"newFindingsRatio\":1,\"durationMs\":0,\"timestamp\":\"2026-06-18T05:47:52Z\"}\n+{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":1,\"passed\":true,\"packets\":[{\"findingId\":\"F001\",\"finalSeverity\":\"P1\",\"confidence\":0.88},{\"findingId\":\"F002\",\"finalSeverity\":\"P1\",\"confidence\":0.9}],\"timestamp\":\"2026-06-18T05:47:52Z\",\"sessionId\":\"fanout-gpt55r2-c-1-1781761364358-6qni37\",\"generation\":1}\n+{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":1,\"verdict\":\"CONDITIONAL\",\"activeP0\":0,\"activeP1\":2,\"activeP2\":0,\"hasAdvisories\":false,\"stopReason\":\"maxIterationsReached\",\"releaseReadinessState\":\"in-progress\",\"timestamp\":\"2026-06-18T05:47:52Z\",\"sessionId\":\"fanout-gpt55r2-c-1-1781761364358-6qni37\",\"generation\":1}\n*** Add File: .opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-c-1/deep-review-findings-registry.json\n+{\n+  \"sessionId\": \"fanout-gpt55r2-c-1-1781761364358-6qni37\",\n+  \"generation\": 1,\n+  \"lineageMode\": \"new\",\n+  \"openFindings\": [\n+    {\n+      \"findingId\": \"F001\",\n+      \"severity\": \"P1\",\n+      \"category\": \"security\",\n+      \"status\": \"active\",\n+      \"dimension\": \"security\",\n+      \"title\": \"Scoped checkpoint callers can match unscoped checkpoints\