   509	def _compute_hub_skills(adjacency: Dict[str, Dict[str, Dict[str, float]]]) -> List[str]:
   510	    """Compute hub skills using the compiled-graph median inbound-degree rule."""
   511	    inbound_counts: Dict[str, int] = {}
   512	
   513	    for edge_groups in adjacency.values():
   514	        for targets in edge_groups.values():
   515	            for target in targets:
   516	                inbound_counts[target] = inbound_counts.get(target, 0) + 1
   517	
   518	    if not inbound_counts:
   519	        return []
   520	
   521	    counts = sorted(inbound_counts.values())
   522	    median = counts[len(counts) // 2]
   523	    return sorted(skill for skill, count in inbound_counts.items() if count > median)
