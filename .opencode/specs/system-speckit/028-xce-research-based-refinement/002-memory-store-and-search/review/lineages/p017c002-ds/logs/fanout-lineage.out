{"type":"tool_use","timestamp":1781722867957,"sessionID":"ses_1290b2ac2ffehiRdmPDPzPhMIv","part":{"type":"tool","tool":"read","callID":"call_00_Hu1Cji8K6jbG3s9WFXdA7089","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Scoring\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-result calibrated confidence scoring\n5: //\n6: // PURPOSE: Combine margin, multi-channel agreement,\n7: // and anchor density into a single calibrated confidence score per\n8: // result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n9: //\n10: // FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n11: //\n12: // OUTPUT SHAPE (per result):\n13: // {\n14: //   \"confidence\": {\n15: //     \"label\": \"high\" | \"medium\" | \"low\",\n16: //     \"value\": 0.78,\n17: //     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n18: //   },\n19: //   \"requestQuality\": {\n20: //     \"label\": \"good\" | \"weak\" | \"gap\"\n21: //   }\n22: // }\n23: //\n24: // IMPORTANT: This module only models ranking confidence for retrieval ordering.\n25: // It is not freshness authority and it is not a substitute for StructuralTrust.\n26: import { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n27: import {\n28:   isAbsoluteRelevanceCalibrationEnabled,\n29:   isConfidenceCalibrationEnabled,\n30:   getConfidenceCalibrationModelPath,\n31: } from './search-flags.js';\n32: import { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n33: \n34: declare const rankingConfidenceBrand: unique symbol;\n35: \n36: // -- Constants --\n37: \n38: const HIGH_THRESHOLD = 0.7;\n39: const LOW_THRESHOLD = 0.4;\n40: \n41: // Weights for each active confidence factor. The former reranker weight (0.20)\n42: // was removed with the LLM reranker; its term was already inert (always 0), so\n43: // rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n44: // is intentionally NOT redistributed (that would change confidence scores).\n45: const WEIGHT_MARGIN = 0.35;\n46: const WEIGHT_CHANNEL_AGREEMENT = 0.30;\n47: const WEIGHT_ANCHOR_DENSITY = 0.15;\n48: \n49: // Blend of the heuristic signal (margin/channel/anchor) and the absolute\n50: // relevance prior into the final per-result value. Relevance is intentionally\n51: // weighted higher than the heuristics so the band is monotonic in relevance: a\n52: // strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n53: // not be capped at \"medium\" purely because the heuristic signals are weak.\n54: // These two must sum to 1.0.\n55: const WEIGHT_HEURISTIC = 0.45;\n56: const WEIGHT_SCORE_PRIOR = 0.55;\n57: \n58: // Margin thresholds (gap between top score and next score, 0–1 scale)\n59: const LARGE_MARGIN_THRESHOLD = 0.15;\n60: const SMALL_MARGIN_THRESHOLD = 0.05;\n61: \n62: // Channel count thresholds\n63: const STRONG_CHANNEL_AGREEMENT_MIN = 2;\n64: \n65: // Request-quality aggregation: a top hit at or above this absolute relevance\n66: // stands on its own, so a weak tail cannot drag the verdict below \"good\".\n67: const TOP_DOMINANT_THRESHOLD = 0.8;\n68: \n69: // Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n70: // for recall appends weaker tail results; counting them would mechanically\n71: // depress the ratio and penalize a query for retrieving more candidates.\n72: const QUALITY_RATIO_HEAD = 5;\n73: \n74: // -- Types --\n75: \n76: /** Confidence label for a single result. */\n77: export type ConfidenceLabel = 'high' | 'medium' | 'low';\n78: \n79: /**\n80:  * Branded ranking score for retrieval ordering only.\n81:  * Consumers must not reuse this as parser provenance, evidence status,\n82:  * freshness authority, or any other StructuralTrust axis.\n83:  */\n84: export type RankingConfidenceValue = number & {\n85:   readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n86: };\n87: \n88: /** Quality label at the request level (across all results). */\n89: export type RequestQualityLabel = 'good' | 'weak' | 'gap';\n90: \n91: /** Which factors drove the confidence score upward. */\n92: export type ConfidenceDriver =\n93:   | 'large_margin'\n94:   | 'multi_channel_agreement'\n95:   | 'anchor_density';\n96: \n97: /** Per-result confidence payload. */\n98: export interface RankingConfidenceContract {\n99:   label: ConfidenceLabel;\n100:   value: RankingConfidenceValue;\n101:   drivers: ConfidenceDriver[];\n102:   structuralTrust?: never;\n103:   parserProvenance?: never;\n104:   evidenceStatus?: never;\n105:   freshnessAuthority?: never;\n106: }\n107: \n108: export interface ResultConfidence {\n109:   confidence: RankingConfidenceContract;\n110: }\n111: \n112: /** Request-level quality assessment (one per search call). */\n113: export interface RequestQualityAssessment {\n114:   requestQuality: {\n115:     label: RequestQualityLabel;\n116:   };\n117: }\n118: \n119: /**\n120:  * Minimal result shape needed for confidence computation.\n121:  * Uses `Record<string, unknown>` to stay compatible with both\n122:  * `RawSearchResult` and `PipelineRow` without importing either.\n123:  */\n124: export interface ScoredResult extends Record<string, unknown> {\n125:   id: number;\n126:   /** Composite score (0–1). */\n127:   score?: number;\n128:   /** RRF fusion score (0–1). */\n129:   rrfScore?: number;\n130:   /** Intent-adjusted score (0–1). */\n131:   intentAdjustedScore?: number;\n132:   /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n133:   similarity?: number;\n134:   /** Score origin metadata for distinguishing real reranks from fallbacks. */\n135:   scoringMethod?: string;\n136:   /** Anchor metadata array populated by Stage 2. */\n137:   anchorMetadata?: Array<Record<string, unknown>>;\n138:   /** Source channels that contributed this result. */\n139:   sources?: string[];\n140:   /** Single source channel string (legacy). */\n141:   source?: string;\n142:   /** Trace metadata containing channel attribution. */\n143:   traceMetadata?: Record<string, unknown>;\n144: }\n145: \n146: // -- Internal helpers --\n147: \n148: function resolveScore(result: ScoredResult): number {\n149:   return resolveEffectiveScore(result as PipelineRow);\n150: }\n151: \n152: /**\n153:  * Absolute relevance used for confidence calibration and request-quality — keeps\n154:  * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n155:  * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n156:  * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n157:  */\n158: function resolveCalibrationScore(result: ScoredResult): number {\n159:   return isAbsoluteRelevanceCalibrationEnabled()\n160:     ? resolveAbsoluteRelevance(result as PipelineRow)\n161:     : resolveEffectiveScore(result as PipelineRow);\n162: }\n163: \n164: // Lazily-loaded calibration model, memoized by its source path so the search\n165: // hot path reads the file at most once per path. `undefined` = not yet looked\n166: // up; `null` = looked up and absent/invalid (degrade to identity).\n167: let cachedCalibrationModel: CalibrationModel | null | undefined;\n168: let cachedCalibrationModelPath: string | undefined;\n169: \n170: function resolveCalibrationModel(): CalibrationModel | null {\n171:   const path = getConfidenceCalibrationModelPath();\n172:   if (!path) return null;\n173:   if (cachedCalibrationModel !== undefined && cachedCalibrationModelPath === path) {\n174:     return cachedCalibrationModel;\n175:   }\n176:   cachedCalibrationModelPath = path;\n177:   cachedCalibrationModel = loadCalibrationModel(path);\n178:   return cachedCalibrationModel;\n179: }\n180: \n181: /**\n182:  * Map a rebalanced confidence value through the empirical calibration model\n183:  * when enabled. Default OFF and a no-op when no model is configured, so the\n184:  * returned value is identical to the rebalance-only path until a validated\n185:  * model is wired in.\n186:  */\n187: function maybeCalibrate(value: number): number {\n188:   if (!isConfidenceCalibrationEnabled()) return value;\n189:   const model = resolveCalibrationModel();\n190:   if (!model) return value;\n191:   return applyCalibration(model, value);\n192: }\n193: \n194: /**\n195:  * Count the number of unique channels that retrieved this result.\n196:  * Inspects `sources`, `source`, and traceMetadata.attribution.\n197:  */\n198: function countChannels(result: ScoredResult): number {\n199:   const channels = new Set<string>();\n200: \n201:   if (Array.isArray(result.sources)) {\n202:     for (const s of result.sources) {\n203:       if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n204:     }\n205:   }\n206: \n207:   if (typeof result.source === 'string' && result.source.trim().length > 0) {\n208:     channels.add(result.source.trim());\n209:   }\n210: \n211:   // Check traceMetadata.attribution for richer channel data\n212:   const numericId = typeof result.id === 'number' ? result.id : null;\n213:   const attribution = result.traceMetadata?.attribution;\n214:   if (attribution && typeof attribution === 'object' && numericId !== null) {\n215:     for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n216:       if (!Array.isArray(memoryIds)) continue;\n217:       const matched = memoryIds.some((mid) => {\n218:         const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n219:         return Number.isFinite(n) && n === numericId;\n220:       });\n221:       if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n222:         channels.add(channel.trim());\n223:       }\n224:     }\n225:   }\n226: \n227:   return channels.size;\n228: }\n229: \n230: /**\n231:  * Count anchors present in this result's anchorMetadata array.\n232:  * A result with multiple named anchors is considered \"dense\" and\n233:  * more likely to be a high-quality, well-structured memory.\n234:  */\n235: function countAnchors(result: ScoredResult): number {\n236:   if (!Array.isArray(result.anchorMetadata)) return 0;\n237:   return result.anchorMetadata.length;\n238: }\n239: \n240: /**\n241:  * Compute the score margin between result[i] and result[i+1].\n242:  * Tail results have no successor, so they receive no synthetic margin boost.\n243:  */\n244: function computeMargin(score: number, nextScore: number | null): number {\n245:   if (nextScore === null) return 0;\n246:   const gap = score - nextScore;\n247:   return Math.max(0, gap);\n248: }\n249: \n250: /**\n251:  * Map raw confidence value to a coarse label.\n252:  */\n253: function toConfidenceLabel(value: number): ConfidenceLabel {\n254:   if (value >= HIGH_THRESHOLD) return 'high';\n255:   if (value >= LOW_THRESHOLD) return 'medium';\n256:   return 'low';\n257: }\n258: \n259: export function asRankingConfidenceValue(value: number): RankingConfidenceValue {\n260:   const clamped = Math.max(0, Math.min(1, value));\n261:   return (Math.round(clamped * 1000) / 1000) as RankingConfidenceValue;\n262: }\n263: \n264: // -- Public API --\n265: \n266: /**\n267:  * Compute per-result confidence for a ranked list of results.\n268:  *\n269:  * Each result receives a confidence object derived from:\n270:  *   - Score margin to the next result (35% weight)\n271:  *   - Number of channels that contributed this result (30%)\n272:  *   - Anchor density in anchorMetadata (15%)\n273:  *\n274:  * @param results - Ranked results (highest score first). Ordering is assumed.\n275:  * @returns Array of ResultConfidence objects, parallel to `results`.\n276:  */\n277: export function computeResultConfidence(results: ScoredResult[]): ResultConfidence[] {\n278:   if (!Array.isArray(results) || results.length === 0) return [];\n279: \n280:   const scores = results.map(resolveScore);\n281: \n282:   return results.map((result, i): ResultConfidence => {\n283:     const score = scores[i] ?? 0;\n284:     const nextScore = i + 1 < scores.length ? (scores[i + 1] ?? null) : null;\n285: \n286:     const margin = computeMargin(score, nextScore);\n287:     const channelCount = countChannels(result);\n288:     const anchorCount = countAnchors(result);\n289: \n290:     // Factor scores (each 0–1)\n291:     const marginFactor = margin >= LARGE_MARGIN_THRESHOLD\n292:       ? 1.0\n293:       : margin >= SMALL_MARGIN_THRESHOLD\n294:         ? margin / LARGE_MARGIN_THRESHOLD\n295:         : 0;\n296: \n297:     const channelFactor = channelCount >= STRONG_CHANNEL_AGREEMENT_MIN\n298:       ? 1.0\n299:       : channelCount === 1\n300:         ? 0.5\n301:         : 0;\n302: \n303:     // Anchor density: 1 anchor → 0.3, 2 → 0.6, 3+ → 1.0\n304:     const anchorFactor = Math.min(1, anchorCount * 0.33);\n305: \n306:     const rawValue =\n307:       WEIGHT_MARGIN * marginFactor +\n308:       WEIGHT_CHANNEL_AGREEMENT * channelFactor +\n309:       WEIGHT_ANCHOR_DENSITY * anchorFactor;\n310: \n311:     // Base score is a strong prior: if the score itself is very high, confidence\n312:     // should reflect that even when heuristic signals are weak. Use the absolute\n313:     // relevance (cosine) here, not the RRF ordering score — an RRF magnitude of\n314:     // ~0.03 would make this prior contribute ~0.01 and defeat its purpose.\n315:     // Relevance carries the larger weight so the band stays monotonic in it.\n316:     const scorePrior = resolveCalibrationScore(result) * WEIGHT_SCORE_PRIOR;\n317:     const heuristicValue = rawValue * WEIGHT_HEURISTIC;\n318:     const rebalancedValue = Math.max(0, Math.min(1, heuristicValue + scorePrior));\n319: \n320:     // Optional empirical calibration to P(relevant). Default OFF: only applied\n321:     // when the flag is on AND a fitted model is available, so production\n322:     // confidence is the rebalance-only value until a validated model exists.\n323:     const value = maybeCalibrate(rebalancedValue);\n324: \n325:     const drivers: ConfidenceDriver[] = [];\n326:     if (margin >= LARGE_MARGIN_THRESHOLD) drivers.push('large_margin');\n327:     if (channelCount >= STRONG_CHANNEL_AGREEMENT_MIN) drivers.push('multi_channel_agreement');\n328:     if (anchorCount >= 2) drivers.push('anchor_density');\n329: \n330:       return {\n331:         confidence: {\n332:           label: toConfidenceLabel(value),\n333:           value: asRankingConfidenceValue(value),\n334:           drivers,\n335:         },\n336:       };\n337:   });\n338: }\n339: \n340: /**\n341:  * Compute request-level quality assessment based on the overall result set.\n342:  *\n343:  * - \"good\":  a dominant top hit, or a healthy top score with confident head / clear margin\n344:  * - \"weak\":  results exist but signals are mixed or low\n345:  * - \"gap\":   no results, or all results have low confidence\n346:  *\n347:  * The \"good\" rule is top-dominant and margin-aware: a single strong, well-separated\n348:  * top hit is citable even when the tail is weak. Without this, a strong top result\n349:  * is dragged to \"weak\" by a weaker tail, and expanding recall (more tail candidates)\n350:  * mechanically lowers the quality ratio — penalizing the very recall that found the hit.\n351:  *\n352:  * @param results   - The scored results for the query.\n353:  * @param confidences - Parallel confidence array from `computeResultConfidence`.\n354:  */\n355: export function assessRequestQuality(\n356:   results: ScoredResult[],\n357:   confidences: ResultConfidence[],\n358: ): RequestQualityAssessment {\n359:   if (!Array.isArray(results) || results.length === 0) {\n360:     return { requestQuality: { label: 'gap' } };\n361:   }\n362: \n363:   // Absolute relevance, not the RRF ordering score: HIGH_THRESHOLD/LOW_THRESHOLD\n364:   // are calibrated for a 0–1 cosine scale, so an RRF-magnitude topScore (~0.03)\n365:   // would put \"good\" out of reach and collapse every query to weak/gap.\n366:   const topScore = resolveCalibrationScore(results[0]);\n367: \n368:   // Quality ratio over the head of the ranking only, so recall expansion does\n369:   // not depress it (see QUALITY_RATIO_HEAD).\n370:   const head = Math.min(confidences.length, QUALITY_RATIO_HEAD);\n371:   const highOrMediumCount = confidences\n372:     .slice(0, head)\n373:     .filter((c) => c.confidence.label === 'high' || c.confidence.label === 'medium')\n374:     .length;\n375:   const qualityRatio = head > 0 ? highOrMediumCount / head : 0;\n376: \n377:   // Margin between #1 and #2 on the same absolute scale as topScore. A clear gap\n378:   // to the runner-up marks a dominant top hit even when the tail is weak.\n379:   const topMargin = results.length > 1\n380:     ? computeMargin(topScore, resolveCalibrationScore(results[1]))\n381:     : 0;\n382: \n383:   // A sufficiently strong top hit is citable on its own, regardless of the tail.\n384:   if (topScore >= TOP_DOMINANT_THRESHOLD) {\n385:     return { requestQuality: { label: 'good' } };\n386:   }\n387:   // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n388:   // OR the top hit clearly dominates the runner-up.\n389:   if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n390:     return { requestQuality: { label: 'good' } };\n391:   }\n392:   // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n393:   // genuinely low-signal queries.\n394:   if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n395:     return { requestQuality: { label: 'weak' } };\n396:   }\n397:   return { requestQuality: { label: 'gap' } };\n398: }\n399: \n400: /**\n401:  * Check whether the per-result confidence feature flag is enabled.\n402:  * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n403:  */\n404: export { isResultConfidenceEnabled } from './search-flags.js';\n\n(End of file - total 404 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"\n//   }\n// }\n//\n// IMPORTANT: This module only models ranking confidence for retrieval ordering.\n// It is not freshness authority and it is not a substitute for StructuralTrust.\nimport { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport {\n  isAbsoluteRelevanceCalibrationEnabled,\n  isConfidenceCalibrationEnabled,\n  getConfidenceCalibrationModelPath,\n} from './search-flags.js';\nimport { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n\ndeclare const rankingConfidenceBrand: unique symbol;\n\n// -- Constants --\n\nconst HIGH_THRESHOLD = 0.7;\nconst LOW_THRESHOLD = 0.4;\n\n// Weights for each active confidence factor. The former reranker weight (0.20)\n// was removed with the LLM reranker; its term was already inert (always 0), so\n// rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n// is intentionally NOT redistributed (that would change confidence scores).\nconst WEIGHT_MARGIN = 0.35;\nconst WEIGHT_CHANNEL_AGREEMENT = 0.30;\nconst WEIGHT_ANCHOR_DENSITY = 0.15;\n\n// Blend of the heuristic signal (margin/channel/anchor) and the absolute\n// relevance prior into the final per-result value. Relevance is intentionally\n// weighted higher than the heuristics so the band is monotonic in relevance: a\n// strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n// not be capped at \"medium\" purely because the heuristic signals are weak.\n// These two must sum to 1.0.\nconst WEIGHT_HEURISTIC = 0.45;\nconst WEIGHT_SCORE_PRIOR = 0.55;\n\n// Margin thresholds (gap between top score and next score, 0–1 scale)\nconst LARGE_MARGIN_THRESHOLD = 0.15;\nconst SMALL_MARGIN_THRESHOLD = 0.05;\n\n// Channel count thresholds\nconst STRONG_CHANNEL_AGREEMENT_MIN = 2;\n\n// Request-quality aggregation: a top hit at or above this absolute relevance\n// stands on its own, so a weak tail cannot drag the verdict below \"good\".\nconst TOP_DOMINANT_THRESHOLD = 0.8;\n\n// Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n// for recall appends weaker tail results; counting them would mechanically\n// depress the ratio and penalize a query for retrieving more candidates.\nconst QUALITY_RATIO_HEAD = 5;\n\n// -- Types --\n\n/** Confidence label for a single result. */\nexport type ConfidenceLabel = 'high' | 'medium' | 'low';\n\n/**\n * Branded ranking score for retrieval ordering only.\n * Consumers must not reuse this as parser provenance, evidence status,\n * freshness authority, or any other StructuralTrust axis.\n */\nexport type RankingConfidenceValue = number & {\n  readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n};\n\n/** Quality label at the request level (across all results). */\nexport type RequestQualityLabel = 'good' | 'weak' | 'gap';\n\n/** Which factors drove the confidence score upward. */\nexport type ConfidenceDriver =\n  | 'large_margin'\n  | 'multi_channel_agreement'\n  | 'anchor_density';\n\n/** Per-result confidence payload. */\nexport interface RankingConfidenceContract {\n  label: ConfidenceLabel;\n  value: RankingConfidenceValue;\n  drivers: ConfidenceDriver[];\n  structuralTrust?: never;\n  parserProvenance?: never;\n  evidenceStatus?: never;\n  freshnessAuthority?: never;\n}\n\nexport interface ResultConfidence {\n  confidence: RankingConfidenceContract;\n}\n\n/** Request-level quality assessment (one per search call). */\nexport interface RequestQualityAssessment {\n  requestQuality: {\n    label: RequestQualityLabel;\n  };\n}\n\n/**\n * Minimal result shape needed for confidence computation.\n * Uses `Record<string, unknown>` to stay compatible with both\n * `RawSearchResult` and `PipelineRow` without importing either.\n */\nexport interface ScoredResult extends Record<string, unknown> {\n  id: number;\n  /** Composite score (0–1). */\n  score?: number;\n  /** RRF fusion score (0–1). */\n  rrfScore?: number;\n  /** Intent-adjusted score (0–1). */\n  intentAdjustedScore?: number;\n  /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n  similarity?: number;\n  /** Score origin metadata for distinguishing real reranks from fallbacks. */\n  scoringMethod?: string;\n  /** Anchor metadata array populated by Stage 2. */\n  anchorMetadata?: Array<Record<string, unknown>>;\n  /** Source channels that contributed this result. */\n  sources?: string[];\n  /** Single source channel string (legacy). */\n  source?: string;\n  /** Trace metadata containing channel attribution. */\n  traceMetadata?: Record<string, unknown>;\n}\n\n// -- Internal helpers --\n\nfunction resolveScore(result: ScoredResult): number {\n  return resolveEffectiveScore(result as PipelineRow);\n}\n\n/**\n * Absolute relevance used for confidence calibration and request-quality — keeps\n * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n */\nfunction resolveCalibrationScore(result: ScoredResult): number {\n  return isAbsoluteRelevanceCalibrationEnabled()\n    ? resolveAbsoluteRelevance(result as PipelineRow)\n    : resolveEffectiveScore(result as PipelineRow);\n}\n\n// Lazily-loaded calibration model, memoized by its source path so the search\n// hot path reads the file at most once per path. `undefined` = not yet looked\n// up; `null` = looked up and absent/invalid (degrade to identity).\nlet cachedCalibrationModel: CalibrationModel | null | undefined;\nlet cachedCalibrationModelPath: string | undefined;\n\nfunction resolveCalibrationModel(): CalibrationModel | null {\n  const path = getConfidenceCalibrationModelPath();\n  if (!path) return null;\n  if (cachedCalibrationModel !== undefined && cachedCalibrationModelPath === path) {\n    return cachedCalibrationModel;\n  }\n  cachedCalibrationModelPath = path;\n  cachedCalibrationModel = loadCalibrationModel(path);\n  return cachedCalibrationModel;\n}\n\n/**\n * Map a rebalanced confidence value through the empirical calibration model\n * when enabled. Default OFF and a no-op when no model is configured, so the\n * returned value is identical to the rebalance-only path until a validated\n * model is wired in.\n */\nfunction maybeCalibrate(value: number): number {\n  if (!isConfidenceCalibrationEnabled()) return value;\n  const model = resolveCalibrationModel();\n  if (!model) return value;\n  return applyCalibration(model, value);\n}\n\n/**\n * Count the number of unique channels that retrieved this result.\n * Inspects `sources`, `source`, and traceMetadata.attribution.\n */\nfunction countChannels(result: ScoredResult): number {\n  const channels = new Set<string>();\n\n  if (Array.isArray(result.sources)) {\n    for (const s of result.sources) {\n      if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n    }\n  }\n\n  if (typeof result.source === 'string' && result.source.trim().length > 0) {\n    channels.add(result.source.trim());\n  }\n\n  // Check traceMetadata.attribution for richer channel data\n  const numericId = typeof result.id === 'number' ? result.id : null;\n  const attribution = result.traceMetadata?.attribution;\n  if (attribution && typeof attribution === 'object' && numericId !== null) {\n    for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n      if (!Array.isArray(memoryIds)) continue;\n      const matched = memoryIds.some((mid) => {\n        const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n        return Number.isFinite(n) && n === numericId;\n      });\n      if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n        channels.add(channel.trim());\n      }\n    }\n  }\n\n  return channels.size;\n}\n\n/**\n * Count anchors present in this result's anchorMetadata array.\n * A result with multiple named anchors is considered \"dense\" and\n * more likely to be a high-quality, well-structured memory.\n */\nfunction countAnchors(result: ScoredResult): number {\n  if (!Array.isArray(result.anchorMetadata)) return 0;\n  return result.anchorMetadata.length;\n}\n\n/**\n * Compute the score margin between result[i] and result[i+1].\n * Tail results have no successor, so they receive no synthetic margin boost.\n */\nfunction computeMargin(score: number, nextScore: number | null): number {\n  if (nextScore === null) return 0;\n  const gap = score - nextScore;\n  return Math.max(0, gap);\n}\n\n/**\n * Map raw confidence value to a coarse label.\n */\nfunction toConfidenceLabel(value: number): ConfidenceLabel {\n  if (value >= HIGH_THRESHOLD) return 'high';\n  if (value >= LOW_THRESHOLD) return 'medium';\n  return 'low';\n}\n\nexport function asRankingConfidenceValue(value: number): RankingConfidenceValue {\n  const clamped = Math.max(0, Math.min(1, value));\n  return (Math.round(clamped * 1000) / 1000) as RankingConfidenceValue;\n}\n\n// -- Public API --\n\n/**\n * Compute per-result confidence for a ranked list of results.\n *\n * Each result receives a confidence object derived from:\n *   - Score margin to the next result (35% weight)\n *   - Number of channels that contributed this result (30%)\n *   - Anchor density in anchorMetadata (15%)\n *\n * @param results - Ranked results (highest score first). Ordering is assumed.\n * @returns Array of ResultConfidence objects, parallel to `results`.\n */\nexport function computeResultConfidence(results: ScoredResult[]): ResultConfidence[] {\n  if (!Array.isArray(results) || results.length === 0) return [];\n\n  const scores = results.map(resolveScore);\n\n  return results.map((result, i): ResultConfidence => {\n    const score = scores[i] ?? 0;\n    const nextScore = i + 1 < scores.length ? (scores[i + 1] ?? null) : null;\n\n    const margin = computeMargin(score, nextScore);\n    const channelCount = countChannels(result);\n    const anchorCount = countAnchors(result);\n\n    // Factor scores (each 0–1)\n    const marginFactor = margin >= LARGE_MARGIN_THRESHOLD\n      ? 1.0\n      : margin >= SMALL_MARGIN_THRESHOLD\n        ? margin / LARGE_MARGIN_THRESHOLD\n        : 0;\n\n    const channelFactor = channelCount >= STRONG_CHANNEL_AGREEMENT_MIN\n      ? 1.0\n      : channelCount === 1\n        ? 0.5\n        : 0;\n\n    // Anchor density: 1 anchor → 0.3, 2 → 0.6, 3+ → 1.0\n    const anchorFactor = Math.min(1, anchorCount * 0.33);\n\n    const rawValue =\n      WEIGHT_MARGIN * marginFactor +\n      WEIGHT_CHANNEL_AGREEMENT * channelFactor +\n      WEIGHT_ANCHOR_DENSITY * anchorFactor;\n\n    // Base score is a strong prior: if the score itself is very high, confidence\n    // should reflect that even when heuristic signals are weak. Use the absolute\n    // relevance (cosine) here, not the RRF ordering score — an RRF magnitude of\n    // ~0.03 would make this prior contribute ~0.01 and defeat its purpose.\n    // Relevance carries the larger weight so the band stays monotonic in it.\n    const scorePrior = resolveCalibrationScore(result) * WEIGHT_SCORE_PRIOR;\n    const heuristicValue = rawValue * WEIGHT_HEURISTIC;\n    const rebalancedValue = Math.max(0, Math.min(1, heuristicValue + scorePrior));\n\n    // Optional empirical calibration to P(relevant). Default OFF: only applied\n    // when the flag is on AND a fitted model is available, so production\n    // confidence is the rebalance-only value until a validated model exists.\n    const value = maybeCalibrate(rebalancedValue);\n\n    const drivers: ConfidenceDriver[] = [];\n    if (margin >= LARGE_MARGIN_THRESHOLD) drivers.push('large_margin');\n    if (channelCount >= STRONG_CHANNEL_AGREEMENT_MIN) drivers.push('multi_channel_agreement');\n    if (anchorCount >= 2) drivers.push('anchor_density');\n\n      return {\n        confidence: {\n          label: toConfidenceLabel(value),\n          value: asRankingConfidenceValue(value),\n          drivers,\n        },\n      };\n  });\n}\n\n/**\n * Compute request-level quality assessment based on the overall result set.\n *\n * - \"good\":  a dominant top hit, or a healthy top score with confident head / clear margin\n * - \"weak\":  results exist but signals are mixed or low\n * - \"gap\":   no results, or all results have low confidence\n *\n * The \"good\" rule is top-dominant and margin-aware: a single strong, well-separated\n * top hit is citable even when the tail is weak. Without this, a strong top result\n * is dragged to \"weak\" by a weaker tail, and expanding recall (more tail candidates)\n * mechanically lowers the quality ratio — penalizing the very recall that found the hit.\n *\n * @param results   - The scored results for the query.\n * @param confidences - Parallel confidence array from `computeResultConfidence`.\n */\nexport function assessRequestQuality(\n  results: ScoredResult[],\n  confidences: ResultConfidence[],\n): RequestQualityAssessment {\n  if (!Array.isArray(results) || results.length === 0) {\n    return { requestQuality: { label: 'gap' } };\n  }\n\n  // Absolute relevance, not the RRF ordering score: HIGH_THRESHOLD/LOW_THRESHOLD\n  // are calibrated for a 0–1 cosine scale, so an RRF-magnitude topScore (~0.03)\n  // would put \"good\" out of reach and collapse every query to weak/gap.\n  const topScore = resolveCalibrationScore(results[0]);\n\n  // Quality ratio over the head of the ranking only, so recall expansion does\n  // not depress it (see QUALITY_RATIO_HEAD).\n  const head = Math.min(confidences.length, QUALITY_RATIO_HEAD);\n  const highOrMediumCount = confidences\n    .slice(0, head)\n    .filter((c) => c.confidence.label === 'high' || c.confidence.label === 'medium')\n    .length;\n  const qualityRatio = head > 0 ? highOrMediumCount / head : 0;\n\n  // Margin between #1 and #2 on the same absolute scale as topScore. A clear gap\n  // to the runner-up marks a dominant top hit even when the tail is weak.\n  const topMargin = results.length > 1\n    ? computeMargin(topScore, resolveCalibrationScore(results[1]))\n    : 0;\n\n  // A sufficiently strong top hit is citable on its own, regardless of the tail.\n  if (topScore >= TOP_DOMINANT_THRESHOLD) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n  // OR the top hit clearly dominates the runner-up.\n  if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n  // genuinely low-signal queries.\n  if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n    return { requestQuality: { label: 'weak' } };\n  }\n  return { requestQuality: { label: 'gap' } };\n}\n\n/**\n * Check whether the per-result confidence feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n */\nexport { isResultConfidenceEnabled } from './search-flags.js';","lineStart":1,"lineEnd":404,"totalLines":404,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","time":{"start":1781722867952,"end":1781722867956}},"id":"prt_ed6f5678b001HHg3Vu1T8sXfne","sessionID":"ses_1290b2ac2ffehiRdmPDPzPhMIv","messageID":"msg_ed6f5480f001avJMu78jo7hScr"}}
{"type":"tool_use","timestamp":1781722868368,"sessionID":"ses_1290b2ac2ffehiRdmPDPzPhMIv","part":{"type":"tool","tool":"read","callID":"call_01_bqXKAJIy3wZuf8AdvcaO1568","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/request-quality-aggregation.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/request-quality-aggregation.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: Request-Quality Aggregation — top-dominant + margin-aware\n3: // ───────────────────────────────────────────────────────────────\n4: // Covers the \"good\" rule that lets a strong, well-separated top hit be citable\n5: // even when the tail is weak, and that caps the quality ratio at the head of the\n6: // ranking so recall expansion does not mechanically depress the verdict.\n7: // The weak/gap safety net for genuinely low-signal sets must stay intact.\n8: \n9: import { beforeEach, describe, expect, it } from 'vitest';\n10: import {\n11:   computeResultConfidence,\n12:   assessRequestQuality,\n13:   type ScoredResult,\n14: } from '../lib/search/confidence-scoring';\n15: \n16: const CALIBRATION_FLAG = 'SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION';\n17: \n18: // Cosine similarity (0–100) drives the absolute relevance that topScore reads.\n19: function strong(id: number, similarity: number): ScoredResult {\n20:   return {\n21:     id,\n22:     similarity,\n23:     sources: ['vector', 'fts'],\n24:     anchorMetadata: [{ id: 'a' }, { id: 'b' }],\n25:   };\n26: }\n27: \n28: function weak(id: number, similarity: number): ScoredResult {\n29:   return { id, similarity };\n30: }\n31: \n32: function assess(results: ScoredResult[]) {\n33:   return assessRequestQuality(results, computeResultConfidence(results)).requestQuality.label;\n34: }\n35: \n36: describe('assessRequestQuality — top-dominant + margin-aware (calibration ON)', () => {\n37:   beforeEach(() => {\n38:     delete process.env[CALIBRATION_FLAG]; // default-ON\n39:   });\n40: \n41:   it('reads \"good\" via margin: a strong top (0.78) clearly beats a weak tail', () => {\n42:     // qualityRatio stays below 0.6 (only the top hit is confident), so the\n43:     // margin disjunct — not the ratio — is what carries the verdict to \"good\".\n44:     const results = [strong(1, 78), weak(2, 50), weak(3, 49), weak(4, 48), weak(5, 47)];\n45:     const confidences = computeResultConfidence(results);\n46:     const highOrMedium = confidences.filter(\n47:       (c) => c.confidence.label !== 'low',\n48:     ).length;\n49:     expect(highOrMedium / 5).toBeLessThan(0.6);\n50:     expect(assess(results)).toBe('good');\n51:   });\n52: \n53:   it('reads \"good\" top-dominant: a 0.81 top wins despite small margin and weak tail', () => {\n54:     // Margin to #2 is only 0.06 (< 0.15) and the head is not mostly confident,\n55:     // so only the top-dominant rule (>= 0.8) can yield \"good\".\n56:     const results = [strong(1, 81), weak(2, 75)];\n57:     expect(assess(results)).toBe('good');\n58:   });\n59: \n60:   it('does not let recall expansion depress a confident head (quality ratio capped at the head)', () => {\n61:     // First five are confident; six weak tail candidates would drag a whole-set\n62:     // ratio to ~0.45. Margins are tiny (< 0.15), so without the head cap this\n63:     // would collapse to \"weak\".\n64:     const head = [strong(1, 78), strong(2, 77), strong(3, 76), strong(4, 75), strong(5, 74)];\n65:     const tail = [weak(6, 45), weak(7, 44), weak(8, 43), weak(9, 42), weak(10, 41), weak(11, 40)];\n66:     const results = [...head, ...tail];\n67:     const confidences = computeResultConfidence(results);\n68:     const wholeSetRatio =\n69:       confidences.filter((c) => c.confidence.label !== 'low').length / results.length;\n70:     expect(wholeSetRatio).toBeLessThan(0.6);\n71:     expect(assess(results)).toBe('good');\n72:   });\n73: \n74:   it('keeps a genuinely mediocre set at \"weak\"', () => {\n75:     const results = [weak(1, 55), weak(2, 52), weak(3, 50)];\n76:     expect(assess(results)).toBe('weak');\n77:   });\n78: \n79:   it('keeps a genuinely low-signal set at \"gap\" (do-not-cite safety net)', () => {\n80:     const results = [weak(1, 10), weak(2, 8), weak(3, 5)];\n81:     expect(assess(results)).toBe('gap');\n82:   });\n83: \n84:   it('returns \"gap\" for an empty result set', () => {\n85:     expect(assessRequestQuality([], []).requestQuality.label).toBe('gap');\n86:   });\n87: });\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: Request-Quality Aggregation — top-dominant + margin-aware\n// ───────────────────────────────────────────────────────────────\n// Covers the \"good\" rule that lets a strong, well-separated top hit be citable\n// even when the tail is weak, and that caps the quality ratio at the head of the\n// ranking so recall expansion does not mechanically depress the verdict.\n// The weak/gap safety net for genuinely low-signal sets must stay intact.\n\nimport { beforeEach, describe, expect, it } from 'vitest';\nimport {\n  computeResultConfidence,\n  assessRequestQuality,\n  type ScoredResult,\n} from '../lib/search/confidence-scoring';\n\nconst CALIBRATION_FLAG = 'SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION';\n\n// Cosine similarity (0–100) drives the absolute relevance that topScore reads.\nfunction strong(id: number, similarity: number): ScoredResult {\n  return {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/request-quality-aggregation.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: Request-Quality Aggregation — top-dominant + margin-aware\n// ───────────────────────────────────────────────────────────────\n// Covers the \"good\" rule that lets a strong, well-separated top hit be citable\n// even when the tail is weak, and that caps the quality ratio at the head of the\n// ranking so recall expansion does not mechanically depress the verdict.\n// The weak/gap safety net for genuinely low-signal sets must stay intact.\n\nimport { beforeEach, describe, expect, it } from 'vitest';\nimport {\n  computeResultConfidence,\n  assessRequestQuality,\n  type ScoredResult,\n} from '../lib/search/confidence-scoring';\n\nconst CALIBRATION_FLAG = 'SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION';\n\n// Cosine similarity (0–100) drives the absolute relevance that topScore reads.\nfunction strong(id: number, similarity: number): ScoredResult {\n  return {\n    id,\n    similarity,\n    sources: ['vector', 'fts'],\n    anchorMetadata: [{ id: 'a' }, { id: 'b' }],\n  };\n}\n\nfunction weak(id: number, similarity: number): ScoredResult {\n  return { id, similarity };\n}\n\nfunction assess(results: ScoredResult[]) {\n  return assessRequestQuality(results, computeResultConfidence(results)).requestQuality.label;\n}\n\ndescribe('assessRequestQuality — top-dominant + margin-aware (calibration ON)', () => {\n  beforeEach(() => {\n    delete process.env[CALIBRATION_FLAG]; // default-ON\n  });\n\n  it('reads \"good\" via margin: a strong top (0.78) clearly beats a weak tail', () => {\n    // qualityRatio stays below 0.6 (only the top hit is confident), so the\n    // margin disjunct — not the ratio — is what carries the verdict to \"good\".\n    const results = [strong(1, 78), weak(2, 50), weak(3, 49), weak(4, 48), weak(5, 47)];\n    const confidences = computeResultConfidence(results);\n    const highOrMedium = confidences.filter(\n      (c) => c.confidence.label !== 'low',\n    ).length;\n    expect(highOrMedium / 5).toBeLessThan(0.6);\n    expect(assess(results)).toBe('good');\n  });\n\n  it('reads \"good\" top-dominant: a 0.81 top wins despite small margin and weak tail', () => {\n    // Margin to #2 is only 0.06 (< 0.15) and the head is not mostly confident,\n    // so only the top-dominant rule (>= 0.8) can yield \"good\".\n    const results = [strong(1, 81), weak(2, 75)];\n    expect(assess(results)).toBe('good');\n  });\n\n  it('does not let recall expansion depress a confident head (quality ratio capped at the head)', () => {\n    // First five are confident; six weak tail candidates would drag a whole-set\n    // ratio to ~0.45. Margins are tiny (< 0.15), so without the head cap this\n    // would collapse to \"weak\".\n    const head = [strong(1, 78), strong(2, 77), strong(3, 76), strong(4, 75), strong(5, 74)];\n    const tail = [weak(6, 45), weak(7, 44), weak(8, 43), weak(9, 42), weak(10, 41), weak(11, 40)];\n    const results = [...head, ...tail];\n    const confidences = computeResultConfidence(results);\n    const wholeSetRatio =\n      confidences.filter((c) => c.confidence.label !== 'low').length / results.length;\n    expect(wholeSetRatio).toBeLessThan(0.6);\n    expect(assess(results)).toBe('good');\n  });\n\n  it('keeps a genuinely mediocre set at \"weak\"', () => {\n    const results = [weak(1, 55), weak(2, 52), weak(3, 50)];\n    expect(assess(results)).toBe('weak');\n  });\n\n  it('keeps a genuinely low-signal set at \"gap\" (do-not-cite safety net)', () => {\n    const results = [weak(1, 10), weak(2, 8), weak(3, 5)];\n    expect(assess(results)).toBe('gap');\n  });\n\n  it('returns \"gap\" for an empty result set', () => {\n    expect(assessRequestQuality([], []).requestQuality.label).toBe('gap');\n  });\n});","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/request-quality-aggregation.vitest.ts","time":{"start":1781722868364,"end":1781722868367}},"id":"prt_ed6f5694e001JGOKqcF8ZrchZ9","sessionID":"ses_1290b2ac2ffehiRdmPDPzPhMIv","messageID":"msg_ed6f5480f001avJMu78jo7hScr"}}
