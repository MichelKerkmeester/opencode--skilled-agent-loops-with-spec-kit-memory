{"type":"tool_use","timestamp":1781762458714,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_Q9LS2Hu01jeJvYjfsUiByIkN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const fs = require('fs');\n4: const net = require('net');\n5: const path = require('path');\n6: const { StringDecoder } = require('string_decoder');\n7: \n8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n9: const DEFAULT_PROBE_TIMEOUT_MS = 5000;\n10: const MAX_PROBE_TIMEOUT_MS = 6999;\n11: const DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\n12: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n13: const MODEL_SERVER_HEALTH_PATH = '/api/health';\n14: let nextProbeId = 1;\n15: \n16: function parsePositiveInteger(value, fallback) {\n17:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n18:   const parsed = Number.parseInt(String(value).trim(), 10);\n19:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n20: }\n21: \n22: function clampProbeTimeoutMs(value) {\n23:   return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n24: }\n25: \n26: function resolveProbeTimeoutMs(options = {}) {\n27:   if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n28:     return clampProbeTimeoutMs(options.timeoutMs);\n29:   }\n30:   return clampProbeTimeoutMs(parsePositiveInteger(\n31:     (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n32:     DEFAULT_PROBE_TIMEOUT_MS,\n33:   ));\n34: }\n35: \n36: function parseNonNegativeInteger(value, fallback) {\n37:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n38:   const parsed = Number.parseInt(String(value).trim(), 10);\n39:   return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n40: }\n41: \n42: // A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n43: // daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n44: // consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n45: // its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n46: // the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\n47: function resolveLeaseProbeAttempts(env = process.env) {\n48:   return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n49: }\n50: function resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n51:   return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n52: }\n53: function resolveLeaseProbeRetryBackoffMs(env = process.env) {\n54:   return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n55: }\n56: \n57: function repoRoot() {\n58:   return path.resolve(__dirname, '..', '..', '..');\n59: }\n60: \n61: function defaultDbDirForService(serviceName) {\n62:   const root = repoRoot();\n63:   if (serviceName === 'mk-spec-memory') {\n64:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n65:   }\n66:   if (serviceName === 'mk-code-index') {\n67:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n68:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n69:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n70:   }\n71:   if (serviceName === 'mk-skill-advisor') {\n72:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n73:     return advisorOverride\n74:       ? path.resolve(advisorOverride)\n75:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n76:   }\n77:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n78: }\n79: \n80: function getIpcSocketPath(serviceName, options = {}) {\n81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n83:   }\n84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n86:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n87:   return path.join(socketDir, SOCKET_FILE_NAME);\n88: }\n89: \n90: function toConnectionOptions(socketPath) {\n91:   if (!socketPath.startsWith('tcp://')) {\n92:     return socketPath;\n93:   }\n94:   const url = new URL(socketPath);\n95:   return {\n96:     host: url.hostname,\n97:     port: Number.parseInt(url.port, 10),\n98:   };\n99: }\n100: \n101: function bridgeStdioToSocket(socketPath, options = {}) {\n102:   const input = options.stdin ?? process.stdin;\n103:   const output = options.stdout ?? process.stdout;\n104:   const exit = options.exit ?? ((code) => process.exit(code));\n105:   const socket = net.createConnection(toConnectionOptions(socketPath));\n106:   let closed = false;\n107: \n108:   const closeOnce = (code = 0) => {\n109:     if (closed) return;\n110:     closed = true;\n111:     input.unpipe(socket);\n112:     socket.unpipe(output);\n113:     socket.destroy();\n114:     exit(code);\n115:   };\n116: \n117:   socket.once('connect', () => {\n118:     options.onConnect?.(socket);\n119:     input.pipe(socket);\n120:     socket.pipe(output);\n121:   });\n122: \n123:   socket.once('error', (error) => {\n124:     options.onError?.(error);\n125:     closeOnce(0);\n126:   });\n127: \n128:   socket.once('close', () => {\n129:     closeOnce(0);\n130:   });\n131: \n132:   input.once('end', () => {\n133:     socket.end();\n134:   });\n135:   input.once('close', () => {\n136:     closeOnce(0);\n137:   });\n138:   output.once('error', () => {\n139:     closeOnce(0);\n140:   });\n141: \n142:   return socket;\n143: }\n144: \n145: function probeDaemon(socketPath, options = {}) {\n146:   const timeoutMs = resolveProbeTimeoutMs(options);\n147:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n148:   // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n149:   // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n150:   // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n151:   // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n152:   const deepProbe = options.deepProbe === true;\n153:   const id = nextProbeId++;\n154:   const request = `${JSON.stringify({\n155:     jsonrpc: '2.0',\n156:     id,\n157:     method: 'initialize',\n158:     params: {\n159:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n160:       capabilities: {},\n161:       clientInfo: { name: 'liveness-probe', version: '0' },\n162:     },\n163:   })}\\n`;\n164: \n165:   return new Promise((resolve) => {\n166:     let socket;\n167:     let settled = false;\n168:     let buffer = '';\n169:     let timer;\n170:     // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n171:     // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n172:     const decoder = new StringDecoder('utf8');\n173: \n174:     const finish = (status, reason) => {\n175:       if (settled) return;\n176:       settled = true;\n177:       if (timer) clearTimeout(timer);\n178:       if (socket) socket.destroy();\n179:       resolve({ status, reason });\n180:     };\n181: \n182:     try {\n183:       socket = connect(toConnectionOptions(socketPath));\n184:     } catch (error) {\n185:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n186:       return;\n187:     }\n188: \n189:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n190:     timer.unref?.();\n191: \n192:     socket.once('connect', () => {\n193:       if (!deepProbe) {\n194:         finish('alive', 'connect-ok');\n195:         return;\n196:       }\n197:       socket.write(request);\n198:     });\n199:     socket.on('data', (chunk) => {\n200:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n201:       let newlineIndex = buffer.indexOf('\\n');\n202:       while (newlineIndex !== -1) {\n203:         const line = buffer.slice(0, newlineIndex).trim();\n204:         buffer = buffer.slice(newlineIndex + 1);\n205:         newlineIndex = buffer.indexOf('\\n');\n206:         if (!line) continue;\n207:         try {\n208:           const parsed = JSON.parse(line);\n209:           if (\n210:             parsed &&\n211:             parsed.jsonrpc === '2.0' &&\n212:             parsed.id === id &&\n213:             (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n214:               Object.prototype.hasOwnProperty.call(parsed, 'error'))\n215:           ) {\n216:             finish('alive', 'json-rpc-reply');\n217:             return;\n218:           }\n219:         } catch {\n220:           // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n221:         }\n222:       }\n223:     });\n224:     socket.once('error', (error) => {\n225:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n226:     });\n227:     socket.once('close', () => {\n228:       finish('dead', 'closed-before-reply');\n229:     });\n230:   });\n231: }\n232: \n233: function parseHttpJsonResponse(buffer) {\n234:   const raw = buffer.toString('utf8');\n235:   const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n236:   if (headerEnd === -1) return null;\n237:   const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n238:   const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n239:   if (!statusMatch) return null;\n240:   const statusCode = Number.parseInt(statusMatch[1], 10);\n241:   const bodyRaw = raw.slice(headerEnd + 4).trim();\n242:   let body = null;\n243:   try {\n244:     body = bodyRaw ? JSON.parse(bodyRaw) : null;\n245:   } catch {\n246:     return { statusCode, body: null };\n247:   }\n248:   return { statusCode, body };\n249: }\n250: \n251: function probeModelServer(socketPath, options = {}) {\n252:   const timeoutMs = resolveProbeTimeoutMs(options);\n253:   const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n254:     ? options.loadingMaxMs\n255:     : parsePositiveInteger(\n256:       (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n257:       DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n258:     );\n259:   const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n260:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n261:   // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n262:   // without spawning a model server. Genuine embed consumers do not send this header, so their\n263:   // wake-on-demand path is unchanged.\n264:   const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n265: \n266:   return new Promise((resolve) => {\n267:     let socket;\n268:     let settled = false;\n269:     let chunks = [];\n270:     let timer;\n271: \n272:     // Carry the parsed health body so callers (the idle-eviction tick) can read\n273:     // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n274:     const finish = (status, reason, health) => {\n275:       if (settled) return;\n276:       settled = true;\n277:       if (timer) clearTimeout(timer);\n278:       if (socket) socket.destroy();\n279:       resolve({ status, reason, health });\n280:     };\n281: \n282:     try {\n283:       socket = connect(toConnectionOptions(socketPath));\n284:     } catch (error) {\n285:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n286:       return;\n287:     }\n288: \n289:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n290:     timer.unref?.();\n291: \n292:     socket.once('connect', () => {\n293:       socket.write(request);\n294:     });\n295:     socket.on('data', (chunk) => {\n296:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n297:     });\n298:     socket.once('end', () => {\n299:       const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n300:       const state = parsed && parsed.body && typeof parsed.body === 'object'\n301:         ? parsed.body.state\n302:         : null;\n303:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n304:         finish('alive', `health-${state}`, parsed.body);\n305:         return;\n306:       }\n307:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n308:         const loadStartedAt = parsed.body.loadStartedAt;\n309:         const loadProgressAt = parsed.body.loadProgressAt;\n310:         // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n311:         const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n312:           ? loadProgressAt\n313:           : loadStartedAt;\n314:         if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n315:           finish('dead', 'loading-wedged');\n316:           return;\n317:         }\n318:         finish('alive', 'health-loading', parsed.body);\n319:         return;\n320:       }\n321:       finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n322:     });\n323:     socket.once('error', (error) => {\n324:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n325:     });\n326:     socket.once('close', () => {\n327:       if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n328:     });\n329:   });\n330: }\n331: \n332: // Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n333: // only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n334: // sleep are injectable so the retry decision is unit-testable without real sockets or timers.\n335: async function probeLeaseHolderWithRetries(socketPath, options = {}) {\n336:   const {\n337:     probe = probeDaemon,\n338:     firstTimeoutMs,\n339:     retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n340:     retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n341:     attempts = resolveLeaseProbeAttempts(),\n342:     connect,\n343:     sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n344:     onRetry,\n345:   } = options;\n346:   const totalAttempts = Math.max(1, attempts);\n347:   let result = { status: 'dead', reason: 'no-probe-attempted' };\n348:   for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n349:     const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n350:     result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n351:     if (result.status === 'alive') return result;\n352:     if (attempt < totalAttempts) {\n353:       if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n354:       await sleepFn(retryBackoffMs);\n355:     }\n356:   }\n357:   return result;\n358: }\n359: \n360: async function maybeBridgeLeaseHolder(options) {\n361:   const {\n362:     serviceName,\n363:     leaseResult,\n364:     loggerPrefix,\n365:     dbDir,\n366:     legacyReport,\n367:     probeTimeoutMs,\n368:     connect,\n369:     bridge,\n370:   } = options;\n371:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n372:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n373:   const ownerPid = leaseResult.ownerPid;\n374:   const writeLeaseHeld = (suffix = '') => {\n375:     process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n376:   };\n377: \n378:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n379:     if (legacyReport) {\n380:       legacyReport(leaseResult);\n381:       return { action: 'report', reason: 'bridge-disabled' };\n382:     }\n383:     writeLeaseHeld();\n384:     return { action: 'report', reason: 'bridge-disabled' };\n385:   }\n386: \n387:   // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n388:   // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n389:   // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n390:   // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n391:   // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n392:   // leases never carry it.\n393:   const storedSocketPath = leaseResult.socketPath;\n394:   const usableStoredSocketPath = typeof storedSocketPath === 'string'\n395:     && storedSocketPath.length > 0\n396:     && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n397:     ? storedSocketPath\n398:     : null;\n399:   const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n400:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n401:     writeLeaseHeld(' (no-bridge-socket)');\n402:     return { action: 'report', reason: 'no-bridge-socket', socketPath };\n403:   }\n404: \n405:   // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n406:   // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n407:   // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n408:   // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n409:   // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n410:   // does not regress that.\n411:   // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n412:   const probeAttempts = resolveLeaseProbeAttempts();\n413:   const probe = await probeLeaseHolderWithRetries(socketPath, {\n414:     firstTimeoutMs: probeTimeoutMs,\n415:     attempts: probeAttempts,\n416:     connect,\n417:     onRetry: (attempt, total, result) => process.stderr.write(\n418:       `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n419:     ),\n420:   });\n\n(Showing lines 1-420 of 451. Use offset=421 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction parseNonNegativeInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n}\n\n// A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n// daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n// consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n// its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n// the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\nfunction resolveLeaseProbeAttempts(env = process.env) {\n  return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n}\nfunction resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n  return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n}\nfunction resolveLeaseProbeRetryBackoffMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });\n\n  socket.once('error', (error) => {\n    options.onError?.(error);\n    closeOnce(0);\n  });\n\n  socket.once('close', () => {\n    closeOnce(0);\n  });\n\n  input.once('end', () => {\n    socket.end();\n  });\n  input.once('close', () => {\n    closeOnce(0);\n  });\n  output.once('error', () => {\n    closeOnce(0);\n  });\n\n  return socket;\n}\n\nfunction probeDaemon(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n  // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n  // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n  // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n  const deepProbe = options.deepProbe === true;\n  const id = nextProbeId++;\n  const request = `${JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    method: 'initialize',\n    params: {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'liveness-probe', version: '0' },\n    },\n  })}\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let buffer = '';\n    let timer;\n    // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n    // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n    const decoder = new StringDecoder('utf8');\n\n    const finish = (status, reason) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      if (!deepProbe) {\n        finish('alive', 'connect-ok');\n        return;\n      }\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const line = buffer.slice(0, newlineIndex).trim();\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (!line) continue;\n        try {\n          const parsed = JSON.parse(line);\n          if (\n            parsed &&\n            parsed.jsonrpc === '2.0' &&\n            parsed.id === id &&\n            (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n              Object.prototype.hasOwnProperty.call(parsed, 'error'))\n          ) {\n            finish('alive', 'json-rpc-reply');\n            return;\n          }\n        } catch {\n          // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n        }\n      }\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\nfunction parseHttpJsonResponse(buffer) {\n  const raw = buffer.toString('utf8');\n  const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n  if (headerEnd === -1) return null;\n  const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n  const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n  if (!statusMatch) return null;\n  const statusCode = Number.parseInt(statusMatch[1], 10);\n  const bodyRaw = raw.slice(headerEnd + 4).trim();\n  let body = null;\n  try {\n    body = bodyRaw ? JSON.parse(bodyRaw) : null;\n  } catch {\n    return { statusCode, body: null };\n  }\n  return { statusCode, body };\n}\n\nfunction probeModelServer(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n    ? options.loadingMaxMs\n    : parsePositiveInteger(\n      (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n      DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n    );\n  const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n  // without spawning a model server. Genuine embed consumers do not send this header, so their\n  // wake-on-demand path is unchanged.\n  const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let chunks = [];\n    let timer;\n\n    // Carry the parsed health body so callers (the idle-eviction tick) can read\n    // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n    const finish = (status, reason, health) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason, health });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n    });\n    socket.once('end', () => {\n      const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n      const state = parsed && parsed.body && typeof parsed.body === 'object'\n        ? parsed.body.state\n        : null;\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n        finish('alive', `health-${state}`, parsed.body);\n        return;\n      }\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n        const loadStartedAt = parsed.body.loadStartedAt;\n        const loadProgressAt = parsed.body.loadProgressAt;\n        // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n        const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n          ? loadProgressAt\n          : loadStartedAt;\n        if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n          finish('dead', 'loading-wedged');\n          return;\n        }\n        finish('alive', 'health-loading', parsed.body);\n        return;\n      }\n      finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\n// Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n// only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n// sleep are injectable so the retry decision is unit-testable without real sockets or timers.\nasync function probeLeaseHolderWithRetries(socketPath, options = {}) {\n  const {\n    probe = probeDaemon,\n    firstTimeoutMs,\n    retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n    retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n    attempts = resolveLeaseProbeAttempts(),\n    connect,\n    sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n    onRetry,\n  } = options;\n  const totalAttempts = Math.max(1, attempts);\n  let result = { status: 'dead', reason: 'no-probe-attempted' };\n  for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n    const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n    result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt < totalAttempts) {\n      if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n      await sleepFn(retryBackoffMs);\n    }\n  }\n  return result;\n}\n\nasync function maybeBridgeLeaseHolder(options) {\n  const {\n    serviceName,\n    leaseResult,\n    loggerPrefix,\n    dbDir,\n    legacyReport,\n    probeTimeoutMs,\n    connect,\n    bridge,\n  } = options;\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  const ownerPid = leaseResult.ownerPid;\n  const writeLeaseHeld = (suffix = '') => {\n    process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n  };\n\n  if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n    if (legacyReport) {\n      legacyReport(leaseResult);\n      return { action: 'report', reason: 'bridge-disabled' };\n    }\n    writeLeaseHeld();\n    return { action: 'report', reason: 'bridge-disabled' };\n  }\n\n  // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n  // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n  // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n  // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n  // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n  // leases never carry it.\n  const storedSocketPath = leaseResult.socketPath;\n  const usableStoredSocketPath = typeof storedSocketPath === 'string'\n    && storedSocketPath.length > 0\n    && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n    ? storedSocketPath\n    : null;\n  const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n  if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n    writeLeaseHeld(' (no-bridge-socket)');\n    return { action: 'report', reason: 'no-bridge-socket', socketPath };\n  }\n\n  // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n  // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n  // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n  // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n  // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n  // does not regress that.\n  // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n  const probeAttempts = resolveLeaseProbeAttempts();\n  const probe = await probeLeaseHolderWithRetries(socketPath, {\n    firstTimeoutMs: probeTimeoutMs,\n    attempts: probeAttempts,\n    connect,\n    onRetry: (attempt, total, result) => process.stderr.write(\n      `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n    ),\n  });","lineStart":1,"lineEnd":420,"totalLines":451,"truncated":true}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1781762458703,"end":1781762458712}},"metadata":{"openai":{"itemId":"fc_070593cc26a0fe51016a33899a9ecc81919e8e76b935cfa1ce"}},"id":"prt_ed951843e0010G8Ohp4noZYUk5","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9514ffc0013jubQwE1tV4h20"}}
{"type":"tool_use","timestamp":1781762458781,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_j1RScqAyZftIpqEEh195dOHi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs</path>\n<type>file</type>\n<content>\n1: // [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n2: 'use strict';\n3: \n4: const net = require('net');\n5: const { StringDecoder } = require('string_decoder');\n6: const {\n7:   probeDaemon,\n8:   toConnectionOptions,\n9: } = require('./launcher-ipc-bridge.cjs');\n10: \n11: const PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\n12: const DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n13: // Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n14: // seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n15: // daemon answers the deep probe within the first few attempts; the only thing this shortens is\n16: // the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\n17: const DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\n18: const INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\n19: const DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\n20: const DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;\n21: const DEFAULT_MAX_QUEUED_CLIENT_FRAMES = 1000;\n22: const PROXY_PRIVATE_ID_PREFIX = '__launcher_session_proxy_keepalive__';\n23: const RETRYABLE_RECYCLE_ERROR = Object.freeze({\n24:   code: -32001,\n25:   message: 'backend recycled; retry',\n26:   data: { retryable: true },\n27: });\n28: const PROTOCOL_MISMATCH_ERROR = Object.freeze({\n29:   code: -32002,\n30:   message: 'backend protocol version changed; client reconnect required',\n31:   data: { retryable: false },\n32: });\n33: const REPLAYABLE_TOOL_NAMES = new Set([\n34:   'memory_search',\n35:   'memory_context',\n36:   'memory_match_triggers',\n37:   'memory_quick_search',\n38:   'memory_save',\n39:   'session_bootstrap',\n40:   'session_health',\n41:   'session_resume',\n42:   'session_status',\n43:   'memory_stats',\n44:   'memory_status',\n45:   'checkpoint_list',\n46:   'embedder_health',\n47: ]);\n48: const UNSAFE_TOOL_NAMES = new Set([\n49:   'memory_delete',\n50:   'memory_bulk_delete',\n51:   'memory_update',\n52:   'checkpoint_restore',\n53:   'checkpoint_delete',\n54:   'embedder_set',\n55:   'memory_retention_sweep',\n56:   'memory_ingest_start',\n57:   'memory_ingest_cancel',\n58: ]);\n59: const REPLAYABLE_PROTOCOL_METHODS = new Set([\n60:   'initialize',\n61:   'ping',\n62: ]);\n63: \n64: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n65: \n66: function defaultConnect(connectionOptions) {\n67:   return net.createConnection(connectionOptions);\n68: }\n69: \n70: function defaultLog(message) {\n71:   process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n72: }\n73: \n74: function createFrameSplitter(onFrame) {\n75:   let buffer = '';\n76:   // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n77:   // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n78:   // of emitting U+FFFD replacement chars on the partial sequence.\n79:   const decoder = new StringDecoder('utf8');\n80:   return {\n81:     push(chunk) {\n82:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n83:       let newlineIndex = buffer.indexOf('\\n');\n84:       while (newlineIndex !== -1) {\n85:         const frame = buffer.slice(0, newlineIndex);\n86:         buffer = buffer.slice(newlineIndex + 1);\n87:         newlineIndex = buffer.indexOf('\\n');\n88:         if (frame.trim().length === 0) continue;\n89:         onFrame(frame);\n90:       }\n91:     },\n92:     discard() {\n93:       buffer = '';\n94:       decoder.end();\n95:     },\n96:     buffered() {\n97:       return buffer;\n98:     },\n99:   };\n100: }\n101: \n102: function parseFrame(frame) {\n103:   try {\n104:     const parsed = JSON.parse(String(frame).trim());\n105:     return parsed && typeof parsed === 'object' ? parsed : null;\n106:   } catch {\n107:     return null;\n108:   }\n109: }\n110: \n111: function hasOwn(object, key) {\n112:   return Object.prototype.hasOwnProperty.call(object, key);\n113: }\n114: \n115: function hasRequestId(parsed) {\n116:   return parsed !== null && hasOwn(parsed, 'id');\n117: }\n118: \n119: function isResponseFrame(parsed) {\n120:   return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n121: }\n122: \n123: // Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n124: // (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n125: // servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n126: // tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\n127: function createClassifyFrame(options = {}) {\n128:   const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n129:   const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n130:   return function classify(frame) {\n131:     const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n132:     if (!parsed || typeof parsed.method !== 'string') return false;\n133:     if (parsed.method !== 'tools/call') {\n134:       return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n135:     }\n136:     const toolName = parsed.params && typeof parsed.params === 'object'\n137:       ? parsed.params.name\n138:       : undefined;\n139:     if (typeof toolName !== 'string') return false;\n140:     if (unsafe.has(toolName)) return false;\n141:     if (replayable.has(toolName)) return true;\n142:     return false;\n143:   };\n144: }\n145: \n146: // Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n147: // commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n148: // active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n149: // collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n150: // index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n151: // on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n152: // idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n153: // lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\n154: const classifyFrame = createClassifyFrame();\n155: \n156: function createPendingRequestsTracker(classify = classifyFrame) {\n157:   const pendingRequests = new Map();\n158:   let cachedInitialize = null;\n159:   let cachedInitializeId = null;\n160:   let negotiatedProtocolVersion = null;\n161:   let protocolVersionObserved = false;\n162: \n163:   function handleClientFrame(frame) {\n164:     const parsed = parseFrame(frame);\n165:     if (!parsed) return;\n166:     if (parsed.method === 'initialize') {\n167:       cachedInitialize = frame;\n168:       cachedInitializeId = hasRequestId(parsed) ? parsed.id : null;\n169:     }\n170:     if (!hasRequestId(parsed)) return;\n171:     pendingRequests.set(parsed.id, {\n172:       frame,\n173:       replayable: classify(frame),\n174:     });\n175:   }\n176: \n177:   function handleBackendFrame(frame) {\n178:     const parsed = parseFrame(frame);\n179:     if (!parsed || !isResponseFrame(parsed)) return;\n180:     pendingRequests.delete(parsed.id);\n181:   }\n182: \n183:   return {\n184:     pendingRequests,\n185:     handleClientFrame,\n186:     handleBackendFrame,\n187:     getCachedInitialize() {\n188:       return cachedInitialize;\n189:     },\n190:     getCachedInitializeId() {\n191:       return cachedInitializeId;\n192:     },\n193:     getNegotiatedProtocolVersion() {\n194:       return negotiatedProtocolVersion;\n195:     },\n196:     hasObservedProtocolVersion() {\n197:       return protocolVersionObserved;\n198:     },\n199:     recordNegotiatedProtocolVersion(version) {\n200:       if (protocolVersionObserved) return;\n201:       protocolVersionObserved = true;\n202:       negotiatedProtocolVersion = typeof version === 'string' ? version : null;\n203:     },\n204:   };\n205: }\n206: \n207: function resolveColdStartAttempts() {\n208:   const fromEnv = Number.parseInt(process.env.SPECKIT_PROXY_COLD_START_ATTEMPTS ?? '', 10);\n209:   return Number.isInteger(fromEnv) && fromEnv > 0 ? fromEnv : DEFAULT_MAX_COLD_START_ATTEMPTS;\n210: }\n211: \n212: async function waitForDaemonReady(socketPath, probe, connect, log, options = {}) {\n213:   const maxAttempts = Number.isInteger(options.maxAttempts) && options.maxAttempts > 0\n214:     ? options.maxAttempts\n215:     : Infinity;\n216:   for (let attempt = 0; attempt < maxAttempts; attempt += 1) {\n217:     const result = await probe(socketPath, { connect, deepProbe: true });\n218:     if (result.status === 'alive') return result;\n219:     if (attempt + 1 >= maxAttempts) return result;\n220:     const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n221:     log(`daemon socket not ready (${result.reason}); retrying in ${delayMs}ms`);\n222:     await sleep(delayMs);\n223:   }\n224:   return { status: 'dead', reason: 'reattach-attempts-exhausted' };\n225: }\n226: \n227: function writeFrame(stream, frame) {\n228:   return stream.write(`${frame}\\n`);\n229: }\n230: \n231: function retryableErrorFrame(id) {\n232:   return JSON.stringify({\n233:     jsonrpc: '2.0',\n234:     id,\n235:     error: RETRYABLE_RECYCLE_ERROR,\n236:   });\n237: }\n238: \n239: function protocolMismatchErrorFrame(id) {\n240:   return JSON.stringify({\n241:     jsonrpc: '2.0',\n242:     id,\n243:     error: PROTOCOL_MISMATCH_ERROR,\n244:   });\n245: }\n246: \n247: function connectSocket(connect, socketPath) {\n248:   return new Promise((resolve, reject) => {\n249:     let socket;\n250:     try {\n251:       socket = connect(toConnectionOptions(socketPath));\n252:     } catch (error) {\n253:       reject(error);\n254:       return;\n255:     }\n256: \n257:     const cleanup = () => {\n258:       socket.off?.('connect', onConnect);\n259:       socket.off?.('error', onError);\n260:     };\n261:     const onConnect = () => {\n262:       cleanup();\n263:       resolve(socket);\n264:     };\n265:     const onError = (error) => {\n266:       cleanup();\n267:       socket.destroy?.();\n268:       reject(error);\n269:     };\n270: \n271:     socket.once('connect', onConnect);\n272:     socket.once('error', onError);\n273:   });\n274: }\n275: \n276: function internalHandshake(socket, initializeFrame) {\n277:   if (!initializeFrame) return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n278: \n279:   const initialize = parseFrame(initializeFrame);\n280:   if (!initialize || !hasRequestId(initialize)) {\n281:     return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n282:   }\n283: \n284:   return new Promise((resolve, reject) => {\n285:     let buffer = '';\n286:     let residual = '';\n287:     let negotiatedVersion;\n288:     let initializeResponse = null;\n289:     // Hold a multibyte char split across chunk boundaries until complete, so a CJK/emoji\n290:     // payload in the residual (post-handshake) stream is not corrupted to U+FFFD.\n291:     const decoder = new StringDecoder('utf8');\n292:     const timer = setTimeout(() => {\n293:       cleanup();\n294:       reject(new Error('timed out waiting for internal initialize'));\n295:     }, INTERNAL_HANDSHAKE_TIMEOUT_MS);\n296:     timer.unref?.();\n297:     const cleanup = () => {\n298:       clearTimeout(timer);\n299:       socket.off?.('data', onData);\n300:       socket.off?.('error', onError);\n301:       socket.off?.('close', onClose);\n302:     };\n303:     const onData = (chunk) => {\n304:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n305:       let initialized = false;\n306:       let newlineIndex = buffer.indexOf('\\n');\n307:       while (newlineIndex !== -1) {\n308:         const frame = buffer.slice(0, newlineIndex);\n309:         buffer = buffer.slice(newlineIndex + 1);\n310:         newlineIndex = buffer.indexOf('\\n');\n311:         if (frame.trim().length === 0) continue;\n312:         const parsed = parseFrame(frame);\n313:         if (parsed && isResponseFrame(parsed) && parsed.id === initialize.id) {\n314:           initialized = true;\n315:           initializeResponse = frame;\n316:           negotiatedVersion = parsed.result && typeof parsed.result === 'object'\n317:             ? parsed.result.protocolVersion\n318:             : undefined;\n319:           continue;\n320:         }\n321:         residual += `${frame}\\n`;\n322:       }\n323:       if (!initialized) return;\n324:       const remainder = residual + buffer;\n325:       buffer = '';\n326:       residual = '';\n327:       cleanup();\n328:       resolve({ residual: remainder, protocolVersion: negotiatedVersion, handshakeObserved: true, initializeResponse });\n329:     };\n330:     const onError = (error) => {\n331:       cleanup();\n332:       reject(error);\n333:     };\n334:     const onClose = () => {\n335:       cleanup();\n336:       reject(new Error('socket closed during internal initialize'));\n337:     };\n338: \n339:     socket.on('data', onData);\n340:     socket.once('error', onError);\n341:     socket.once('close', onClose);\n342:     writeFrame(socket, initializeFrame);\n343:   });\n344: }\n345: \n346: function createSessionProxy(options) {\n347:   const socketPath = options?.socketPath;\n348:   const input = options?.stdin ?? process.stdin;\n349:   const output = options?.stdout ?? process.stdout;\n350:   const probe = options?.probe ?? probeDaemon;\n351:   const connect = options?.connect ?? defaultConnect;\n352:   const log = options?.log ?? defaultLog;\n353:   const classify = options?.classify ?? classifyFrame;\n354:   const maxReattachAttempts = Number.isInteger(options?.maxReattachAttempts) && options.maxReattachAttempts > 0\n355:     ? options.maxReattachAttempts\n356:     : DEFAULT_MAX_REATTACH_ATTEMPTS;\n357:   const maxColdStartAttempts = Number.isInteger(options?.maxColdStartAttempts) && options.maxColdStartAttempts > 0\n358:     ? options.maxColdStartAttempts\n359:     : resolveColdStartAttempts();\n360:   const keepaliveIntervalMs = Number.isInteger(options?.keepaliveIntervalMs) && options.keepaliveIntervalMs > 0\n361:     ? options.keepaliveIntervalMs\n362:     : DEFAULT_KEEPALIVE_INTERVAL_MS;\n363:   const keepaliveTimeoutMs = Number.isInteger(options?.keepaliveTimeoutMs) && options.keepaliveTimeoutMs > 0\n364:     ? options.keepaliveTimeoutMs\n365:     : DEFAULT_KEEPALIVE_TIMEOUT_MS;\n366:   const maxQueuedClientFrames = Number.isInteger(options?.maxQueuedClientFrames) && options.maxQueuedClientFrames > 0\n367:     ? options.maxQueuedClientFrames\n368:     : DEFAULT_MAX_QUEUED_CLIENT_FRAMES;\n369: \n370:   let socket = null;\n371:   let state = 'REATTACHING';\n372:   let stopped = false;\n373:   let clientEnded = false;\n374:   let reattachRunning = false;\n375:   let backendSplitter = createFrameSplitter(handleBackendFrame);\n376:   let socketHalfClosed = false;\n377:   let keepaliveInterval = null;\n378:   let keepaliveTimer = null;\n379:   let keepaliveId = 0;\n380:   let pendingKeepaliveId = null;\n381:   let lastBackendActivity = Date.now();\n382:   let socketDrainWaiting = false;\n383:   let outputDrainWaiting = false;\n384:   let outputEndRequested = false;\n385:   const queuedClientFrames = [];\n386:   const socketWriteQueue = [];\n387:   const outputWriteQueue = [];\n388:   const tracker = createPendingRequestsTracker(classify);\n389:   const clientSplitter = createFrameSplitter(handleClientFrame);\n390: \n391:   if (typeof socketPath !== 'string' || socketPath.length === 0) {\n392:     throw new Error('createSessionProxy requires a non-empty socketPath');\n393:   }\n394: \n395:   function pauseClientInput() {\n396:     input.pause?.();\n397:   }\n398: \n399:   function resumeClientInputIfReady() {\n400:     if (!clientEnded && !stopped && state === 'CONNECTED') input.resume?.();\n401:   }\n402: \n403:   function stopKeepalive() {\n404:     if (keepaliveInterval !== null) {\n405:       clearInterval(keepaliveInterval);\n406:       keepaliveInterval = null;\n407:     }\n408:     if (keepaliveTimer !== null) {\n409:       clearTimeout(keepaliveTimer);\n410:       keepaliveTimer = null;\n411:     }\n412:     pendingKeepaliveId = null;\n413:   }\n414: \n415:   function detachSocket(destroy = true) {\n416:     stopKeepalive();\n417:     if (!socket) return;\n418:     const oldSocket = socket;\n419:     socket = null;\n420:     socketHalfClosed = false;\n\n(Showing lines 1-420 of 853. Use offset=421 to continue.)\n</content>","metadata":{"preview":"// [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n'use strict';\n\nconst net = require('net');\nconst { StringDecoder } = require('string_decoder');\nconst {\n  probeDaemon,\n  toConnectionOptions,\n} = require('./launcher-ipc-bridge.cjs');\n\nconst PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\nconst DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n// Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n// seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n// daemon answers the deep probe within the first few attempts; the only thing this shortens is\n// the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\nconst DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\nconst INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\nconst DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\nconst DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","text":"// [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n'use strict';\n\nconst net = require('net');\nconst { StringDecoder } = require('string_decoder');\nconst {\n  probeDaemon,\n  toConnectionOptions,\n} = require('./launcher-ipc-bridge.cjs');\n\nconst PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\nconst DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n// Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n// seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n// daemon answers the deep probe within the first few attempts; the only thing this shortens is\n// the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\nconst DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\nconst INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\nconst DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\nconst DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;\nconst DEFAULT_MAX_QUEUED_CLIENT_FRAMES = 1000;\nconst PROXY_PRIVATE_ID_PREFIX = '__launcher_session_proxy_keepalive__';\nconst RETRYABLE_RECYCLE_ERROR = Object.freeze({\n  code: -32001,\n  message: 'backend recycled; retry',\n  data: { retryable: true },\n});\nconst PROTOCOL_MISMATCH_ERROR = Object.freeze({\n  code: -32002,\n  message: 'backend protocol version changed; client reconnect required',\n  data: { retryable: false },\n});\nconst REPLAYABLE_TOOL_NAMES = new Set([\n  'memory_search',\n  'memory_context',\n  'memory_match_triggers',\n  'memory_quick_search',\n  'memory_save',\n  'session_bootstrap',\n  'session_health',\n  'session_resume',\n  'session_status',\n  'memory_stats',\n  'memory_status',\n  'checkpoint_list',\n  'embedder_health',\n]);\nconst UNSAFE_TOOL_NAMES = new Set([\n  'memory_delete',\n  'memory_bulk_delete',\n  'memory_update',\n  'checkpoint_restore',\n  'checkpoint_delete',\n  'embedder_set',\n  'memory_retention_sweep',\n  'memory_ingest_start',\n  'memory_ingest_cancel',\n]);\nconst REPLAYABLE_PROTOCOL_METHODS = new Set([\n  'initialize',\n  'ping',\n]);\n\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nfunction defaultConnect(connectionOptions) {\n  return net.createConnection(connectionOptions);\n}\n\nfunction defaultLog(message) {\n  process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n}\n\nfunction createFrameSplitter(onFrame) {\n  let buffer = '';\n  // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n  // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n  // of emitting U+FFFD replacement chars on the partial sequence.\n  const decoder = new StringDecoder('utf8');\n  return {\n    push(chunk) {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        onFrame(frame);\n      }\n    },\n    discard() {\n      buffer = '';\n      decoder.end();\n    },\n    buffered() {\n      return buffer;\n    },\n  };\n}\n\nfunction parseFrame(frame) {\n  try {\n    const parsed = JSON.parse(String(frame).trim());\n    return parsed && typeof parsed === 'object' ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction hasOwn(object, key) {\n  return Object.prototype.hasOwnProperty.call(object, key);\n}\n\nfunction hasRequestId(parsed) {\n  return parsed !== null && hasOwn(parsed, 'id');\n}\n\nfunction isResponseFrame(parsed) {\n  return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n}\n\n// Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n// (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n// servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n// tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\nfunction createClassifyFrame(options = {}) {\n  const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n  const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n  return function classify(frame) {\n    const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n    if (!parsed || typeof parsed.method !== 'string') return false;\n    if (parsed.method !== 'tools/call') {\n      return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n    }\n    const toolName = parsed.params && typeof parsed.params === 'object'\n      ? parsed.params.name\n      : undefined;\n    if (typeof toolName !== 'string') return false;\n    if (unsafe.has(toolName)) return false;\n    if (replayable.has(toolName)) return true;\n    return false;\n  };\n}\n\n// Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n// commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n// active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n// collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n// index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n// on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n// idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n// lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\nconst classifyFrame = createClassifyFrame();\n\nfunction createPendingRequestsTracker(classify = classifyFrame) {\n  const pendingRequests = new Map();\n  let cachedInitialize = null;\n  let cachedInitializeId = null;\n  let negotiatedProtocolVersion = null;\n  let protocolVersionObserved = false;\n\n  function handleClientFrame(frame) {\n    const parsed = parseFrame(frame);\n    if (!parsed) return;\n    if (parsed.method === 'initialize') {\n      cachedInitialize = frame;\n      cachedInitializeId = hasRequestId(parsed) ? parsed.id : null;\n    }\n    if (!hasRequestId(parsed)) return;\n    pendingRequests.set(parsed.id, {\n      frame,\n      replayable: classify(frame),\n    });\n  }\n\n  function handleBackendFrame(frame) {\n    const parsed = parseFrame(frame);\n    if (!parsed || !isResponseFrame(parsed)) return;\n    pendingRequests.delete(parsed.id);\n  }\n\n  return {\n    pendingRequests,\n    handleClientFrame,\n    handleBackendFrame,\n    getCachedInitialize() {\n      return cachedInitialize;\n    },\n    getCachedInitializeId() {\n      return cachedInitializeId;\n    },\n    getNegotiatedProtocolVersion() {\n      return negotiatedProtocolVersion;\n    },\n    hasObservedProtocolVersion() {\n      return protocolVersionObserved;\n    },\n    recordNegotiatedProtocolVersion(version) {\n      if (protocolVersionObserved) return;\n      protocolVersionObserved = true;\n      negotiatedProtocolVersion = typeof version === 'string' ? version : null;\n    },\n  };\n}\n\nfunction resolveColdStartAttempts() {\n  const fromEnv = Number.parseInt(process.env.SPECKIT_PROXY_COLD_START_ATTEMPTS ?? '', 10);\n  return Number.isInteger(fromEnv) && fromEnv > 0 ? fromEnv : DEFAULT_MAX_COLD_START_ATTEMPTS;\n}\n\nasync function waitForDaemonReady(socketPath, probe, connect, log, options = {}) {\n  const maxAttempts = Number.isInteger(options.maxAttempts) && options.maxAttempts > 0\n    ? options.maxAttempts\n    : Infinity;\n  for (let attempt = 0; attempt < maxAttempts; attempt += 1) {\n    const result = await probe(socketPath, { connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt + 1 >= maxAttempts) return result;\n    const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n    log(`daemon socket not ready (${result.reason}); retrying in ${delayMs}ms`);\n    await sleep(delayMs);\n  }\n  return { status: 'dead', reason: 'reattach-attempts-exhausted' };\n}\n\nfunction writeFrame(stream, frame) {\n  return stream.write(`${frame}\\n`);\n}\n\nfunction retryableErrorFrame(id) {\n  return JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    error: RETRYABLE_RECYCLE_ERROR,\n  });\n}\n\nfunction protocolMismatchErrorFrame(id) {\n  return JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    error: PROTOCOL_MISMATCH_ERROR,\n  });\n}\n\nfunction connectSocket(connect, socketPath) {\n  return new Promise((resolve, reject) => {\n    let socket;\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      reject(error);\n      return;\n    }\n\n    const cleanup = () => {\n      socket.off?.('connect', onConnect);\n      socket.off?.('error', onError);\n    };\n    const onConnect = () => {\n      cleanup();\n      resolve(socket);\n    };\n    const onError = (error) => {\n      cleanup();\n      socket.destroy?.();\n      reject(error);\n    };\n\n    socket.once('connect', onConnect);\n    socket.once('error', onError);\n  });\n}\n\nfunction internalHandshake(socket, initializeFrame) {\n  if (!initializeFrame) return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n\n  const initialize = parseFrame(initializeFrame);\n  if (!initialize || !hasRequestId(initialize)) {\n    return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n  }\n\n  return new Promise((resolve, reject) => {\n    let buffer = '';\n    let residual = '';\n    let negotiatedVersion;\n    let initializeResponse = null;\n    // Hold a multibyte char split across chunk boundaries until complete, so a CJK/emoji\n    // payload in the residual (post-handshake) stream is not corrupted to U+FFFD.\n    const decoder = new StringDecoder('utf8');\n    const timer = setTimeout(() => {\n      cleanup();\n      reject(new Error('timed out waiting for internal initialize'));\n    }, INTERNAL_HANDSHAKE_TIMEOUT_MS);\n    timer.unref?.();\n    const cleanup = () => {\n      clearTimeout(timer);\n      socket.off?.('data', onData);\n      socket.off?.('error', onError);\n      socket.off?.('close', onClose);\n    };\n    const onData = (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let initialized = false;\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        const parsed = parseFrame(frame);\n        if (parsed && isResponseFrame(parsed) && parsed.id === initialize.id) {\n          initialized = true;\n          initializeResponse = frame;\n          negotiatedVersion = parsed.result && typeof parsed.result === 'object'\n            ? parsed.result.protocolVersion\n            : undefined;\n          continue;\n        }\n        residual += `${frame}\\n`;\n      }\n      if (!initialized) return;\n      const remainder = residual + buffer;\n      buffer = '';\n      residual = '';\n      cleanup();\n      resolve({ residual: remainder, protocolVersion: negotiatedVersion, handshakeObserved: true, initializeResponse });\n    };\n    const onError = (error) => {\n      cleanup();\n      reject(error);\n    };\n    const onClose = () => {\n      cleanup();\n      reject(new Error('socket closed during internal initialize'));\n    };\n\n    socket.on('data', onData);\n    socket.once('error', onError);\n    socket.once('close', onClose);\n    writeFrame(socket, initializeFrame);\n  });\n}\n\nfunction createSessionProxy(options) {\n  const socketPath = options?.socketPath;\n  const input = options?.stdin ?? process.stdin;\n  const output = options?.stdout ?? process.stdout;\n  const probe = options?.probe ?? probeDaemon;\n  const connect = options?.connect ?? defaultConnect;\n  const log = options?.log ?? defaultLog;\n  const classify = options?.classify ?? classifyFrame;\n  const maxReattachAttempts = Number.isInteger(options?.maxReattachAttempts) && options.maxReattachAttempts > 0\n    ? options.maxReattachAttempts\n    : DEFAULT_MAX_REATTACH_ATTEMPTS;\n  const maxColdStartAttempts = Number.isInteger(options?.maxColdStartAttempts) && options.maxColdStartAttempts > 0\n    ? options.maxColdStartAttempts\n    : resolveColdStartAttempts();\n  const keepaliveIntervalMs = Number.isInteger(options?.keepaliveIntervalMs) && options.keepaliveIntervalMs > 0\n    ? options.keepaliveIntervalMs\n    : DEFAULT_KEEPALIVE_INTERVAL_MS;\n  const keepaliveTimeoutMs = Number.isInteger(options?.keepaliveTimeoutMs) && options.keepaliveTimeoutMs > 0\n    ? options.keepaliveTimeoutMs\n    : DEFAULT_KEEPALIVE_TIMEOUT_MS;\n  const maxQueuedClientFrames = Number.isInteger(options?.maxQueuedClientFrames) && options.maxQueuedClientFrames > 0\n    ? options.maxQueuedClientFrames\n    : DEFAULT_MAX_QUEUED_CLIENT_FRAMES;\n\n  let socket = null;\n  let state = 'REATTACHING';\n  let stopped = false;\n  let clientEnded = false;\n  let reattachRunning = false;\n  let backendSplitter = createFrameSplitter(handleBackendFrame);\n  let socketHalfClosed = false;\n  let keepaliveInterval = null;\n  let keepaliveTimer = null;\n  let keepaliveId = 0;\n  let pendingKeepaliveId = null;\n  let lastBackendActivity = Date.now();\n  let socketDrainWaiting = false;\n  let outputDrainWaiting = false;\n  let outputEndRequested = false;\n  const queuedClientFrames = [];\n  const socketWriteQueue = [];\n  const outputWriteQueue = [];\n  const tracker = createPendingRequestsTracker(classify);\n  const clientSplitter = createFrameSplitter(handleClientFrame);\n\n  if (typeof socketPath !== 'string' || socketPath.length === 0) {\n    throw new Error('createSessionProxy requires a non-empty socketPath');\n  }\n\n  function pauseClientInput() {\n    input.pause?.();\n  }\n\n  function resumeClientInputIfReady() {\n    if (!clientEnded && !stopped && state === 'CONNECTED') input.resume?.();\n  }\n\n  function stopKeepalive() {\n    if (keepaliveInterval !== null) {\n      clearInterval(keepaliveInterval);\n      keepaliveInterval = null;\n    }\n    if (keepaliveTimer !== null) {\n      clearTimeout(keepaliveTimer);\n      keepaliveTimer = null;\n    }\n    pendingKeepaliveId = null;\n  }\n\n  function detachSocket(destroy = true) {\n    stopKeepalive();\n    if (!socket) return;\n    const oldSocket = socket;\n    socket = null;\n    socketHalfClosed = false;","lineStart":1,"lineEnd":420,"totalLines":853,"truncated":true}},"title":".opencode/bin/lib/launcher-session-proxy.cjs","time":{"start":1781762458769,"end":1781762458776}},"metadata":{"openai":{"itemId":"fc_070593cc26a0fe51016a33899a9ee481919d0ffda4acaa3284"}},"id":"prt_ed9518479001ttJRLqNlUHbcmP","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9514ffc0013jubQwE1tV4h20"}}
{"type":"tool_use","timestamp":1781762458781,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_PEz6yNhzMBgnsU0yqGyVk5em","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":780,"limit":430},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n780:   }\n781: \n782:   log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n783:   signalProcess(ownerPid, 'SIGTERM');\n784:   const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n785:   if (!exitedAfterTerm) {\n786:     log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n787:     signalProcess(ownerPid, 'SIGKILL');\n788:     await waitForPidExit(ownerPid, 1000);\n789:   }\n790:   return { allowed: true, reason: 'owner-reaped' };\n791: }\n792: \n793: async function respawnAfterDeadSocket(leaseResult, decision) {\n794:   if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n795:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n796:     return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n797:   }\n798: \n799:   const ownerPid = leaseResult.ownerPid;\n800:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n801:     log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n802:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n803:     return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n804:   }\n805: \n806:   const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n807:   const childPid = lease?.childPid;\n808:   if (!Number.isInteger(childPid) || childPid <= 0) {\n809:     log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n810:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n811:     return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n812:   }\n813: \n814:   // A daemon mid-maintenance (e.g. a background index scan) legitimately fails the\n815:   // deep liveness probe because its event loop is busy, not dead. If it holds a\n816:   // fresh marker naming this exact live child, refuse the respawn and leave it\n817:   // running. The marker lapses if the daemon is genuinely wedged (it can no longer\n818:   // refresh it), so a real death still respawns once the marker expires. Checked\n819:   // before the respawn lock and any reap so a bail unwinds nothing.\n820:   const deadSocketMarker = readMaintenanceMarker(maintenanceMarkerDir());\n821:   if (shouldAdoptDespiteProbe({ marker: deadSocketMarker, childPid, childLiveness: processLiveness(childPid) })) {\n822:     log(`confirmed-dead socket but child pid ${childPid} holds a fresh maintenance marker (activeUntil ${new Date(deadSocketMarker.activeUntilMs).toISOString()}); refusing respawn (busy, not dead)`);\n823:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-maintenance-active)');\n824:     return { action: 'report', reason: 'maintenance-active', socketPath: decision.socketPath };\n825:   }\n826: \n827:   let bootstrapLockHeld = false;\n828:   let respawnLock = null;\n829:   try {\n830:     bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n831:     respawnLock = acquireRespawnLockFile();\n832:     if (!respawnLock.acquired) {\n833:       log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n834:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n835:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n836:     }\n837: \n838:     const currentOwner = readOwnerLeaseFile();\n839:     if (currentOwner?.ownerPid !== ownerPid) {\n840:       log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n841:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n842:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n843:     }\n844: \n845:     const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n846:     if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n847:       log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n848:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n849:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n850:     }\n851: \n852:     const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n853:     if (!ownerReapResult.allowed) {\n854:       log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n855:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n856:       return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n857:     }\n858: \n859:     clearOwnerLeaseFileIfOwner(ownerPid);\n860:     const ownerLease = buildOwnerLease(process.pid);\n861:     if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n862:       const holder = readOwnerLeaseFile();\n863:       log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n864:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n865:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n866:     }\n867:     ownerLeasePid = process.pid;\n868: \n869:     const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n870:     if (!reapResult.allowed) {\n871:       log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n872:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n873:       return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n874:     }\n875: \n876:     buildIfNeeded([]);\n877:     leaseStartedAt = new Date().toISOString();\n878:     writeLeaseFile();\n879:     launchServer();\n880:     return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n881:   } finally {\n882:     releaseRespawnLockFile(respawnLock);\n883:     if (bootstrapLockHeld) {\n884:       fs.rmSync(lockDir, { recursive: true, force: true });\n885:     }\n886:   }\n887: }\n888: \n889: async function bridgeOrReportLeaseHeld(leaseResult) {\n890:   const readiness = bridgeReadiness(leaseResult);\n891:   if (!readiness.ready) {\n892:     writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n893:     return { action: 'report', reason: readiness.reason };\n894:   }\n895:   const { maybeBridgeLeaseHolder } = loadBridgeModule();\n896:   const decision = await maybeBridgeLeaseHolder({\n897:     serviceName: 'mk-spec-memory',\n898:     leaseResult,\n899:     loggerPrefix: 'mk-spec-memory-launcher',\n900:     dbDir: resolvedDbDir(),\n901:     bridge: bridgeStdioThroughSessionProxy,\n902:   });\n903:   if (decision && decision.action === 'respawn') {\n904:     return await respawnAfterDeadSocket(leaseResult, decision);\n905:   }\n906:   return decision;\n907: }\n908: \n909: async function bridgeOrReportLeaseHeldAndExit(leaseResult) {\n910:   const decision = await bridgeOrReportLeaseHeld(leaseResult);\n911:   if (!decision || decision.action === 'report') {\n912:     clearOwnerLeaseFile();\n913:     process.exit(0);\n914:   }\n915:   return decision;\n916: }\n917: \n918: function resolveModelServerSocketPath(env = process.env, options = {}) {\n919:   return mss.resolveModelServerSocketPath(env, {\n920:     ...options,\n921:     dbDir: options.dbDir || resolvedDbDir,\n922:   });\n923: }\n924: \n925: function getContextServerPid() {\n926:   return isChildRunning(childProcess) ? childProcess.pid : null;\n927: }\n928: \n929: // Pure lease-payload builder (exported for tests). `childPid`, `modelServerPid`, and `socketPath`\n930: // are ADDITIVE fields; existing readers consume only pid/startedAt/ownerPid and ignore the extras.\n931: // `socketPath` records the IPC path this owner actually listens on so a secondary launcher prefers\n932: // it over recomputing one that can diverge under a different SPECKIT_IPC_SOCKET_DIR.\n933: function buildLeaseObject(childPid = null, startedAt = leaseStartedAt, modelServerPid = null, socketPath = null) {\n934:   return buildSharedLeaseObject(childPid, startedAt || new Date().toISOString(), modelServerPid, socketPath);\n935: }\n936: \n937: function writeLeaseFile(childPid = getContextServerPid(), modelServerPid = hfControl.getPid()) {\n938:   if (!leaseStartedAt) leaseStartedAt = new Date().toISOString();\n939:   const payload = buildLeaseObject(childPid, leaseStartedAt, modelServerPid, resolveSessionProxySocketPath());\n940:   return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n941: }\n942: \n943: function sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n944:   const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n945:   return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n946: }\n947: \n948: function writeSharedModelServerPid(pid) {\n949:   const socketPath = resolveModelServerSocketPath();\n950:   const pidPath = sharedModelServerPidPath(socketPath);\n951:   if (!Number.isInteger(pid) || pid <= 0) {\n952:     try {\n953:       fs.unlinkSync(pidPath);\n954:     } catch (error) {\n955:       if (error.code === 'ENOENT') return true;\n956:       if (isDurableWriteUnavailable(error)) {\n957:         logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n958:         return false;\n959:       }\n960:       throw error;\n961:     }\n962:     return true;\n963:   }\n964: \n965:   return writeAtomicJsonFile(pidPath, {\n966:     pid,\n967:     startedAt: new Date().toISOString(),\n968:     ownerLauncher: 'mk-spec-memory',\n969:     socketPath,\n970:   }, 'shared model-server pid write');\n971: }\n972: \n973: function readSharedModelServerPid() {\n974:   const pidPath = sharedModelServerPidPath();\n975:   try {\n976:     const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n977:     if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n978:   } catch (error) {\n979:     if (error.code !== 'ENOENT') {\n980:       // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n981:     }\n982:   }\n983: \n984:   const lease = readLeaseFile();\n985:   return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n986: }\n987: \n988: const hfControl = mss.createModelServerControl({\n989:   log,\n990:   env: process.env,\n991:   rootDir: root,\n992:   opencodeDir,\n993:   dbDir: resolvedDbDir,\n994:   getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n995:   onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n996:   bridge: loadBridgeModule(),\n997:   writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n998:   readModelServerPid: () => readSharedModelServerPid(),\n999:   writeLease: () => writeLeaseFile(),\n1000: });\n1001: \n1002: function clearLeaseFile() {\n1003:   try {\n1004:     const lease = readLeaseFile();\n1005:     if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n1006:       try {\n1007:         hfControl.reapProcessTree(lease.modelServerPid);\n1008:       } catch {\n1009:         // Lease cleanup must remain best-effort even if a final process-tree read fails.\n1010:       }\n1011:     }\n1012:     if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n1013:   } catch {\n1014:     // Idempotent cleanup.\n1015:   }\n1016: }\n1017: \n1018: function clearAllLeaseFiles() {\n1019:   clearLeaseFile();\n1020:   clearOwnerLeaseFile();\n1021: }\n1022: \n1023: function isInside(parent, child) {\n1024:   const relative = path.relative(parent, child);\n1025:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n1026: }\n1027: \n1028: function enforceStandaloneCodeGraphDb(actions) {\n1029:   const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n1030:   const resolvedCurrent = current ? path.resolve(current) : null;\n1031:   const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n1032:   const specKitRoot = path.resolve(kitDir);\n1033: \n1034:   if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n1035:     process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n1036:     actions.push(\n1037:       `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n1038:     );\n1039:   }\n1040: }\n1041: \n1042: function run(command, args, options = {}) {\n1043:   const result = spawnSync(command, args, {\n1044:     cwd: options.cwd || root,\n1045:     env: process.env,\n1046:     encoding: 'utf8',\n1047:     stdio: ['ignore', 'pipe', 'pipe'],\n1048:   });\n1049: \n1050:   if (result.stdout) {\n1051:     process.stderr.write(result.stdout);\n1052:   }\n1053:   if (result.stderr) {\n1054:     process.stderr.write(result.stderr);\n1055:   }\n1056:   if (result.error) {\n1057:     throw result.error;\n1058:   }\n1059:   if (result.status !== 0) {\n1060:     throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n1061:   }\n1062: }\n1063: \n1064: function ensureLayout(actions) {\n1065:   if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n1066:     fs.renameSync(legacySkillDir, skillsDir);\n1067:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n1068:     actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n1069:     refreshPaths();\n1070:     return;\n1071:   }\n1072: \n1073:   if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n1074:     const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n1075:     fs.renameSync(legacySkillDir, backup);\n1076:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n1077:     actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n1078:     refreshPaths();\n1079:     return;\n1080:   }\n1081: \n1082:   // Compatibility symlink `.opencode/skill -> skills` removed; a prior cleanup cleaned\n1083:   // up consumers of the singular path, so the bridge no longer needs to be\n1084:   // recreated on every MCP startup. Migration paths above (rename / move-aside)\n1085:   // still create the symlink when an actual legacy singular dir is present.\n1086: }\n1087: \n1088: function requiredArtifacts() {\n1089:   return [\n1090:     path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n1091:     path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n1092:     path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n1093:   ];\n1094: }\n1095: \n1096: function artifactsReady() {\n1097:   return requiredArtifacts().every(exists);\n1098: }\n1099: \n1100: function buildIfNeeded(actions) {\n1101:   if (artifactsReady()) {\n1102:     return;\n1103:   }\n1104: \n1105:   if (!exists(kitDir)) {\n1106:     throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n1107:   }\n1108: \n1109:   actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n1110:   const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n1111:   run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n1112:   run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n1113:   run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n1114: \n1115:   const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n1116:   if (missing.length > 0) {\n1117:     throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n1118:   }\n1119: }\n1120: \n1121: function getContextServerNodeArgs() {\n1122:   const nodeArgs = [];\n1123:   const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n1124:   if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n1125:     return nodeArgs;\n1126:   }\n1127: \n1128:   const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n1129:   if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n1130:     log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n1131:     return nodeArgs;\n1132:   }\n1133: \n1134:   nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n1135:   log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n1136:   return nodeArgs;\n1137: }\n1138: \n1139: function waitForChildExit(child, timeoutMs) {\n1140:   if (!isChildRunning(child)) return Promise.resolve(true);\n1141:   return new Promise((resolve) => {\n1142:     let settled = false;\n1143:     const finish = (exited) => {\n1144:       if (settled) return;\n1145:       settled = true;\n1146:       clearTimeout(timer);\n1147:       child.off('exit', onExit);\n1148:       resolve(exited);\n1149:     };\n1150:     const onExit = () => finish(true);\n1151:     const timer = setTimeout(() => finish(false), timeoutMs);\n1152:     timer.unref?.();\n1153:     child.once('exit', onExit);\n1154:   });\n1155: }\n1156: \n1157: // Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n1158: // the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n1159: // snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\n1160: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n1161:   return mss.refreshDescendantSnapshot(childPid, runner, {\n1162:     snapshotPids: lastKnownDescendantPids,\n1163:     snapshot: {\n1164:       set: (pids) => {\n1165:         lastKnownDescendantPids = pids;\n1166:       },\n1167:     },\n1168:   });\n1169: }\n1170: \n1171: // Reap an orphaned sidecar on crash-loop give-up. The dominant RSS risk lives in a\n1172: // forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n1173: // anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n1174: // still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n1175: // (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n1176: // bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\n1177: function reapProcessTreeGroups(childPid, options = {}) {\n1178:   return mss.reapProcessTreeGroups(childPid, {\n1179:     ...options,\n1180:     snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n1181:     signal: options.signal || signalProcess,\n1182:   });\n1183: }\n1184: \n1185: // Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n1186: // reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n1187: // closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\n1188: async function recycleDaemonInPlace(graceMs, deps = {}) {\n1189:   const ctx = {\n1190:     getContextChild: deps.getContextChild ?? (() => childProcess),\n1191:     hfControl: deps.hfControl ?? hfControl,\n1192:     isChildRunning: deps.isChildRunning ?? isChildRunning,\n1193:     waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n1194:     clearLease: deps.clearLease ?? clearLeaseFile,\n1195:     clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n1196:     isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n1197:     setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n1198:     log: deps.log ?? log,\n1199:   };\n1200:   if (ctx.isRecycleInProgress()) return;\n1201:   ctx.setRecycleInProgress(true);\n1202:   ctx.clearWatchdog();\n1203:   ctx.hfControl.clearTimers();\n1204:   await ctx.hfControl.stopDemandListener();\n1205:   const modelServerChild = ctx.hfControl.getChild();\n1206:   if (ctx.isChildRunning(modelServerChild)) {\n1207:     ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n1208:     modelServerChild.kill('SIGTERM');\n1209:     ctx.hfControl.reapProcessTree(modelServerChild.pid);\n\n(Showing lines 780-1209 of 1882. Use offset=1210 to continue.)\n</content>","metadata":{"preview":"  }\n\n  log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n  signalProcess(ownerPid, 'SIGTERM');\n  const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n  if (!exitedAfterTerm) {\n    log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(ownerPid, 'SIGKILL');\n    await waitForPidExit(ownerPid, 1000);\n  }\n  return { allowed: true, reason: 'owner-reaped' };\n}\n\nasync function respawnAfterDeadSocket(leaseResult, decision) {\n  if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n    return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n  }\n\n  const ownerPid = leaseResult.ownerPid;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"  }\n\n  log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n  signalProcess(ownerPid, 'SIGTERM');\n  const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n  if (!exitedAfterTerm) {\n    log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(ownerPid, 'SIGKILL');\n    await waitForPidExit(ownerPid, 1000);\n  }\n  return { allowed: true, reason: 'owner-reaped' };\n}\n\nasync function respawnAfterDeadSocket(leaseResult, decision) {\n  if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n    return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n  }\n\n  const ownerPid = leaseResult.ownerPid;\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n    return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n  }\n\n  const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n  const childPid = lease?.childPid;\n  if (!Number.isInteger(childPid) || childPid <= 0) {\n    log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n    return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n  }\n\n  // A daemon mid-maintenance (e.g. a background index scan) legitimately fails the\n  // deep liveness probe because its event loop is busy, not dead. If it holds a\n  // fresh marker naming this exact live child, refuse the respawn and leave it\n  // running. The marker lapses if the daemon is genuinely wedged (it can no longer\n  // refresh it), so a real death still respawns once the marker expires. Checked\n  // before the respawn lock and any reap so a bail unwinds nothing.\n  const deadSocketMarker = readMaintenanceMarker(maintenanceMarkerDir());\n  if (shouldAdoptDespiteProbe({ marker: deadSocketMarker, childPid, childLiveness: processLiveness(childPid) })) {\n    log(`confirmed-dead socket but child pid ${childPid} holds a fresh maintenance marker (activeUntil ${new Date(deadSocketMarker.activeUntilMs).toISOString()}); refusing respawn (busy, not dead)`);\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-maintenance-active)');\n    return { action: 'report', reason: 'maintenance-active', socketPath: decision.socketPath };\n  }\n\n  let bootstrapLockHeld = false;\n  let respawnLock = null;\n  try {\n    bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n    respawnLock = acquireRespawnLockFile();\n    if (!respawnLock.acquired) {\n      log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n      return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n    }\n\n    const currentOwner = readOwnerLeaseFile();\n    if (currentOwner?.ownerPid !== ownerPid) {\n      log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n      return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n    }\n\n    const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n    if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n      log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n      return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n    }\n\n    const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n    if (!ownerReapResult.allowed) {\n      log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n      writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n      return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n    }\n\n    clearOwnerLeaseFileIfOwner(ownerPid);\n    const ownerLease = buildOwnerLease(process.pid);\n    if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n      const holder = readOwnerLeaseFile();\n      log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n      return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n    }\n    ownerLeasePid = process.pid;\n\n    const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n    if (!reapResult.allowed) {\n      log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n      writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n      return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n    }\n\n    buildIfNeeded([]);\n    leaseStartedAt = new Date().toISOString();\n    writeLeaseFile();\n    launchServer();\n    return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n  } finally {\n    releaseRespawnLockFile(respawnLock);\n    if (bootstrapLockHeld) {\n      fs.rmSync(lockDir, { recursive: true, force: true });\n    }\n  }\n}\n\nasync function bridgeOrReportLeaseHeld(leaseResult) {\n  const readiness = bridgeReadiness(leaseResult);\n  if (!readiness.ready) {\n    writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n    return { action: 'report', reason: readiness.reason };\n  }\n  const { maybeBridgeLeaseHolder } = loadBridgeModule();\n  const decision = await maybeBridgeLeaseHolder({\n    serviceName: 'mk-spec-memory',\n    leaseResult,\n    loggerPrefix: 'mk-spec-memory-launcher',\n    dbDir: resolvedDbDir(),\n    bridge: bridgeStdioThroughSessionProxy,\n  });\n  if (decision && decision.action === 'respawn') {\n    return await respawnAfterDeadSocket(leaseResult, decision);\n  }\n  return decision;\n}\n\nasync function bridgeOrReportLeaseHeldAndExit(leaseResult) {\n  const decision = await bridgeOrReportLeaseHeld(leaseResult);\n  if (!decision || decision.action === 'report') {\n    clearOwnerLeaseFile();\n    process.exit(0);\n  }\n  return decision;\n}\n\nfunction resolveModelServerSocketPath(env = process.env, options = {}) {\n  return mss.resolveModelServerSocketPath(env, {\n    ...options,\n    dbDir: options.dbDir || resolvedDbDir,\n  });\n}\n\nfunction getContextServerPid() {\n  return isChildRunning(childProcess) ? childProcess.pid : null;\n}\n\n// Pure lease-payload builder (exported for tests). `childPid`, `modelServerPid`, and `socketPath`\n// are ADDITIVE fields; existing readers consume only pid/startedAt/ownerPid and ignore the extras.\n// `socketPath` records the IPC path this owner actually listens on so a secondary launcher prefers\n// it over recomputing one that can diverge under a different SPECKIT_IPC_SOCKET_DIR.\nfunction buildLeaseObject(childPid = null, startedAt = leaseStartedAt, modelServerPid = null, socketPath = null) {\n  return buildSharedLeaseObject(childPid, startedAt || new Date().toISOString(), modelServerPid, socketPath);\n}\n\nfunction writeLeaseFile(childPid = getContextServerPid(), modelServerPid = hfControl.getPid()) {\n  if (!leaseStartedAt) leaseStartedAt = new Date().toISOString();\n  const payload = buildLeaseObject(childPid, leaseStartedAt, modelServerPid, resolveSessionProxySocketPath());\n  return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n}\n\nfunction sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n  const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n  return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n}\n\nfunction writeSharedModelServerPid(pid) {\n  const socketPath = resolveModelServerSocketPath();\n  const pidPath = sharedModelServerPidPath(socketPath);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    try {\n      fs.unlinkSync(pidPath);\n    } catch (error) {\n      if (error.code === 'ENOENT') return true;\n      if (isDurableWriteUnavailable(error)) {\n        logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n        return false;\n      }\n      throw error;\n    }\n    return true;\n  }\n\n  return writeAtomicJsonFile(pidPath, {\n    pid,\n    startedAt: new Date().toISOString(),\n    ownerLauncher: 'mk-spec-memory',\n    socketPath,\n  }, 'shared model-server pid write');\n}\n\nfunction readSharedModelServerPid() {\n  const pidPath = sharedModelServerPidPath();\n  try {\n    const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n    if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n    }\n  }\n\n  const lease = readLeaseFile();\n  return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n}\n\nconst hfControl = mss.createModelServerControl({\n  log,\n  env: process.env,\n  rootDir: root,\n  opencodeDir,\n  dbDir: resolvedDbDir,\n  getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n  onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n  bridge: loadBridgeModule(),\n  writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n  readModelServerPid: () => readSharedModelServerPid(),\n  writeLease: () => writeLeaseFile(),\n});\n\nfunction clearLeaseFile() {\n  try {\n    const lease = readLeaseFile();\n    if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n      try {\n        hfControl.reapProcessTree(lease.modelServerPid);\n      } catch {\n        // Lease cleanup must remain best-effort even if a final process-tree read fails.\n      }\n    }\n    if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction clearAllLeaseFiles() {\n  clearLeaseFile();\n  clearOwnerLeaseFile();\n}\n\nfunction isInside(parent, child) {\n  const relative = path.relative(parent, child);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction enforceStandaloneCodeGraphDb(actions) {\n  const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n  const resolvedCurrent = current ? path.resolve(current) : null;\n  const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n  const specKitRoot = path.resolve(kitDir);\n\n  if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n    process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n    actions.push(\n      `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n    );\n  }\n}\n\nfunction run(command, args, options = {}) {\n  const result = spawnSync(command, args, {\n    cwd: options.cwd || root,\n    env: process.env,\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n\n  if (result.stdout) {\n    process.stderr.write(result.stdout);\n  }\n  if (result.stderr) {\n    process.stderr.write(result.stderr);\n  }\n  if (result.error) {\n    throw result.error;\n  }\n  if (result.status !== 0) {\n    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n  }\n}\n\nfunction ensureLayout(actions) {\n  if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    fs.renameSync(legacySkillDir, skillsDir);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n    refreshPaths();\n    return;\n  }\n\n  if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n    fs.renameSync(legacySkillDir, backup);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n    refreshPaths();\n    return;\n  }\n\n  // Compatibility symlink `.opencode/skill -> skills` removed; a prior cleanup cleaned\n  // up consumers of the singular path, so the bridge no longer needs to be\n  // recreated on every MCP startup. Migration paths above (rename / move-aside)\n  // still create the symlink when an actual legacy singular dir is present.\n}\n\nfunction requiredArtifacts() {\n  return [\n    path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n    path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n    path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n  ];\n}\n\nfunction artifactsReady() {\n  return requiredArtifacts().every(exists);\n}\n\nfunction buildIfNeeded(actions) {\n  if (artifactsReady()) {\n    return;\n  }\n\n  if (!exists(kitDir)) {\n    throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n  }\n\n  actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n  const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n  run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n\n  const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n  if (missing.length > 0) {\n    throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n  }\n}\n\nfunction getContextServerNodeArgs() {\n  const nodeArgs = [];\n  const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n  if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n    return nodeArgs;\n  }\n\n  const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n  if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n    log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n    return nodeArgs;\n  }\n\n  nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n  log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n  return nodeArgs;\n}\n\nfunction waitForChildExit(child, timeoutMs) {\n  if (!isChildRunning(child)) return Promise.resolve(true);\n  return new Promise((resolve) => {\n    let settled = false;\n    const finish = (exited) => {\n      if (settled) return;\n      settled = true;\n      clearTimeout(timer);\n      child.off('exit', onExit);\n      resolve(exited);\n    };\n    const onExit = () => finish(true);\n    const timer = setTimeout(() => finish(false), timeoutMs);\n    timer.unref?.();\n    child.once('exit', onExit);\n  });\n}\n\n// Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n// the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n// snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n  return mss.refreshDescendantSnapshot(childPid, runner, {\n    snapshotPids: lastKnownDescendantPids,\n    snapshot: {\n      set: (pids) => {\n        lastKnownDescendantPids = pids;\n      },\n    },\n  });\n}\n\n// Reap an orphaned sidecar on crash-loop give-up. The dominant RSS risk lives in a\n// forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n// anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n// still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n// (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n// bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  return mss.reapProcessTreeGroups(childPid, {\n    ...options,\n    snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n    signal: options.signal || signalProcess,\n  });\n}\n\n// Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n// reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n// closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\nasync function recycleDaemonInPlace(graceMs, deps = {}) {\n  const ctx = {\n    getContextChild: deps.getContextChild ?? (() => childProcess),\n    hfControl: deps.hfControl ?? hfControl,\n    isChildRunning: deps.isChildRunning ?? isChildRunning,\n    waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n    clearLease: deps.clearLease ?? clearLeaseFile,\n    clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n    isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n    setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n    log: deps.log ?? log,\n  };\n  if (ctx.isRecycleInProgress()) return;\n  ctx.setRecycleInProgress(true);\n  ctx.clearWatchdog();\n  ctx.hfControl.clearTimers();\n  await ctx.hfControl.stopDemandListener();\n  const modelServerChild = ctx.hfControl.getChild();\n  if (ctx.isChildRunning(modelServerChild)) {\n    ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n    modelServerChild.kill('SIGTERM');\n    ctx.hfControl.reapProcessTree(modelServerChild.pid);","lineStart":780,"lineEnd":1209,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781762458771,"end":1781762458777}},"metadata":{"openai":{"itemId":"fc_070593cc26a0fe51016a33899a9eec8191b0b7b8c7e686d020"}},"id":"prt_ed9518492001uguraPuJRyL0z9","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9514ffc0013jubQwE1tV4h20"}}
{"type":"tool_use","timestamp":1781762458788,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_3B77JfVbtosvbDGWg29l80kk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Embeddings\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // PROVIDERS: EMBEDDINGS\n6: // Re-export from shared/ (canonical source)\n7: // Includes multi-provider support, task-specific functions, dynamic dimensions\n8: // MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n9: // Explicit named exports required for auditability.\n10: export {\n11:   generateEmbedding,\n12:   generateEmbeddingWithTimeout,\n13:   generateBatchEmbeddings,\n14:   generateDocumentEmbedding,\n15:   generateQueryEmbedding,\n16:   generateClusteringEmbedding,\n17:   buildWeightedDocumentText,\n18:   semanticChunk,\n19:   getEmbeddingDimension,\n20:   getModelName,\n21:   isModelLoaded,\n22:   getModelLoadTime,\n23:   getCurrentDevice,\n24:   getOptimalDevice,\n25:   getTaskPrefix,\n26:   preWarmModel,\n27:   getEmbeddingProfile,\n28:   getEmbeddingProfileAsync,\n29:   getProviderMetadata,\n30:   clearEmbeddingCache,\n31:   getEmbeddingCacheStats,\n32:   isProviderInitialized,\n33:   invalidateProviderSingleton,\n34:   shouldEagerWarmup,\n35:   getLazyLoadingStats,\n36:   validateApiKey,\n37:   VALIDATION_TIMEOUT_MS,\n38:   EMBEDDING_DIM,\n39:   EMBEDDING_TIMEOUT,\n40:   MAX_TEXT_LENGTH,\n41:   MODEL_NAME,\n42:   DEFAULT_MODEL_NAME,\n43:   TASK_PREFIX,\n44:   BATCH_DELAY_MS,\n45:   BATCH_RATE_LIMIT_DELAY,\n46:   RESERVED_OVERVIEW,\n47:   RESERVED_OUTCOME,\n48:   MIN_SECTION_LENGTH,\n49:   __embeddingCircuitTestables,\n50: } from '@spec-kit/shared/embeddings';\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embeddings\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// PROVIDERS: EMBEDDINGS\n// Re-export from shared/ (canonical source)\n// Includes multi-provider support, task-specific functions, dynamic dimensions\n// MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n// Explicit named exports required for auditability.\nexport {\n  generateEmbedding,\n  generateEmbeddingWithTimeout,\n  generateBatchEmbeddings,\n  generateDocumentEmbedding,\n  generateQueryEmbedding,\n  generateClusteringEmbedding,\n  buildWeightedDocumentText,\n  semanticChunk,\n  getEmbeddingDimension,\n  getModelName,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embeddings\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// PROVIDERS: EMBEDDINGS\n// Re-export from shared/ (canonical source)\n// Includes multi-provider support, task-specific functions, dynamic dimensions\n// MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n// Explicit named exports required for auditability.\nexport {\n  generateEmbedding,\n  generateEmbeddingWithTimeout,\n  generateBatchEmbeddings,\n  generateDocumentEmbedding,\n  generateQueryEmbedding,\n  generateClusteringEmbedding,\n  buildWeightedDocumentText,\n  semanticChunk,\n  getEmbeddingDimension,\n  getModelName,\n  isModelLoaded,\n  getModelLoadTime,\n  getCurrentDevice,\n  getOptimalDevice,\n  getTaskPrefix,\n  preWarmModel,\n  getEmbeddingProfile,\n  getEmbeddingProfileAsync,\n  getProviderMetadata,\n  clearEmbeddingCache,\n  getEmbeddingCacheStats,\n  isProviderInitialized,\n  invalidateProviderSingleton,\n  shouldEagerWarmup,\n  getLazyLoadingStats,\n  validateApiKey,\n  VALIDATION_TIMEOUT_MS,\n  EMBEDDING_DIM,\n  EMBEDDING_TIMEOUT,\n  MAX_TEXT_LENGTH,\n  MODEL_NAME,\n  DEFAULT_MODEL_NAME,\n  TASK_PREFIX,\n  BATCH_DELAY_MS,\n  BATCH_RATE_LIMIT_DELAY,\n  RESERVED_OVERVIEW,\n  RESERVED_OUTCOME,\n  MIN_SECTION_LENGTH,\n  __embeddingCircuitTestables,\n} from '@spec-kit/shared/embeddings';","lineStart":1,"lineEnd":50,"totalLines":50,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","time":{"start":1781762458779,"end":1781762458787}},"metadata":{"openai":{"itemId":"fc_070593cc26a0fe51016a33899a9ef88191b732f39bccf7ad29"}},"id":"prt_ed95184940016jXzZL1ddGZX3i","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9514ffc0013jubQwE1tV4h20"}}
{"type":"tool_use","timestamp":1781762458799,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_adA6dLuhXeIHaXh3wjjCfuCp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retry Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Embedding retry orchestrator\n5: // Node stdlib\n6: import * as fsPromises from 'fs/promises';\n7: \n8: // Internal modules\n9: import * as vectorIndex from '../search/vector-index.js';\n10: import { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\n11: import { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\n12: import { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\n13: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n14: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n15: import { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n16: \n17: // Type imports\n18: import type { MemoryDbRow } from '@spec-kit/shared/types';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. TYPES\n22: ──────────────────────────────────────────────────────────────── */\n23: \n24: interface BackgroundJobConfig {\n25:   intervalMs: number;\n26:   batchSize: number;\n27:   enabled: boolean;\n28: }\n29: \n30: interface RetryStats {\n31:   pending: number;\n32:   retry: number;\n33:   failed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health — no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n221: \n222: function sanitizeEmbeddingFailure(\n223:   raw: unknown,\n224:   options: SanitizeEmbeddingFailureOptions = {},\n225: ): SanitizedEmbeddingFailure {\n226:   const publicMessage = raw instanceof Error\n227:     ? raw.message.trim()\n228:     : String(raw ?? '').trim();\n229: \n230:   if (publicMessage.length === 0) {\n231:     return {\n232:       code: null,\n233:       provider: null,\n234:       errorType: null,\n235:       publicMessage,\n236:       sanitized: false,\n237:     };\n238:   }\n239: \n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n241:     return {\n242:       code: null,\n243:       provider: null,\n244:       errorType: null,\n245:       publicMessage,\n246:       sanitized: false,\n247:     };\n248:   }\n249: \n250:   const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n251:   const { code, errorType } = inferEmbeddingFailure(publicMessage);\n252: \n253:   return {\n254:     code,\n255:     provider,\n256:     errorType,\n257:     publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n258:     sanitized: true,\n259:   };\n260: }\n261: \n262: export function sanitizeEmbeddingFailureMessage(\n263:   raw: unknown,\n264:   options: SanitizeEmbeddingFailureOptions = {},\n265: ): string | null {\n266:   const failure = sanitizeEmbeddingFailure(raw, options);\n267:   return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n268: }\n269: \n270: export function sanitizeAndLogEmbeddingFailure(\n271:   context: string,\n272:   raw: unknown,\n273:   options: SanitizeEmbeddingFailureOptions = {},\n274: ): string | null {\n275:   const failure = sanitizeEmbeddingFailure(raw, options);\n276:   if (failure.publicMessage.length === 0) {\n277:     return null;\n278:   }\n279: \n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n301:   const now = new Date().toISOString();\n302:   const retryCount = getRetryCountValue(memory);\n303:   const lastRetryAt = getLastRetryAtValue(memory);\n304:   // Concurrency: atomic claim prevents double-processing of retry jobs\n305:   const result = previousStatus === 'pending'\n306:     ? db.prepare(`\n307:         UPDATE memory_index\n308:         SET embedding_status = 'retry',\n309:             last_retry_at = ?,\n310:             updated_at = ?\n311:         WHERE id = ?\n312:           AND embedding_status = 'pending'\n313:           AND retry_count = ?\n314:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n315:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n316:     : db.prepare(`\n317:         UPDATE memory_index\n318:         SET last_retry_at = ?,\n319:             updated_at = ?\n320:         WHERE id = ?\n321:           AND embedding_status = 'retry'\n322:           AND retry_count = ?\n323:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n324:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n325: \n326:   return {\n327:     claimed: result.changes > 0,\n328:     previousStatus,\n329:   };\n330: }\n331: \n332: /* ───────────────────────────────────────────────────────────────\n333:    2. CONFIGURATION\n334: ──────────────────────────────────────────────────────────────── */\n335: \n336: // Backoff delays in milliseconds (1min, 5min, 15min)\n337: const BACKOFF_DELAYS: number[] = [\n338:   60 * 1000,\n339:   5 * 60 * 1000,\n340:   15 * 60 * 1000,\n341: ];\n342: \n343: const MAX_RETRIES = 3;\n344: const MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n345: const MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n346: \n347: // 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n348: // applies to a long-lived daemon without depending on the exact restart sequence. The\n349: // module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\n350: function getMaxRetryQueuePending(): number {\n351:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n352: }\n353: \n354: function getMaxRetryQueueAgeMs(): number {\n355:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n356: }\n357: \n358: // Background retry job configuration\n359: // Env-overrideable\n360: //   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n\n(Showing lines 1-360 of 1141. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health — no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}\n\nfunction sanitizeEmbeddingFailure(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): SanitizedEmbeddingFailure {\n  const publicMessage = raw instanceof Error\n    ? raw.message.trim()\n    : String(raw ?? '').trim();\n\n  if (publicMessage.length === 0) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };\n}\n\nexport function sanitizeEmbeddingFailureMessage(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n}\n\nexport function sanitizeAndLogEmbeddingFailure(\n  context: string,\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  if (failure.publicMessage.length === 0) {\n    return null;\n  }\n\n  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n\n  const now = new Date().toISOString();\n  const retryCount = getRetryCountValue(memory);\n  const lastRetryAt = getLastRetryAtValue(memory);\n  // Concurrency: atomic claim prevents double-processing of retry jobs\n  const result = previousStatus === 'pending'\n    ? db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'pending'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n    : db.prepare(`\n        UPDATE memory_index\n        SET last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'retry'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n\n  return {\n    claimed: result.changes > 0,\n    previousStatus,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Backoff delays in milliseconds (1min, 5min, 15min)\nconst BACKOFF_DELAYS: number[] = [\n  60 * 1000,\n  5 * 60 * 1000,\n  15 * 60 * 1000,\n];\n\nconst MAX_RETRIES = 3;\nconst MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\nconst MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n\n// 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n// applies to a long-lived daemon without depending on the exact restart sequence. The\n// module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\nfunction getMaxRetryQueuePending(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n}\n\nfunction getMaxRetryQueueAgeMs(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n}\n\n// Background retry job configuration\n// Env-overrideable\n//   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)","lineStart":1,"lineEnd":360,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781762458794,"end":1781762458798}},"metadata":{"openai":{"itemId":"fc_070593cc26a0fe51016a33899a9f008191bf17931c811daef2"}},"id":"prt_ed951849c001YPI9boZA1VIf1q","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9514ffc0013jubQwE1tV4h20"}}
