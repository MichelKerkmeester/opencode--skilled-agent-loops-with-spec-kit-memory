{
  "color": {
    "jet-ink": {
      "$value": "#0a0a0a",
      "$type": "color",
      "$description": "Jet Ink — Primary text, filled CTA buttons, logo mark — near-black anchors the hierarchy without the harshness of pure black"
    },
    "charcoal": {
      "$value": "#151515",
      "$type": "color",
      "$description": "Charcoal — Dark code-block surface behind terminal demos (used where black feels too stark against warm white)"
    },
    "fog": {
      "$value": "#858585",
      "$type": "color",
      "$description": "Fog — Secondary text, icon strokes, inactive nav items — the most-used gray; carries the bulk of body and link copy"
    },
    "pewter": {
      "$value": "#9d9d9d",
      "$type": "color",
      "$description": "Pewter — Tertiary text, meta labels, decorative fills — softer than Fog for de-emphasized utility copy"
    },
    "steel": {
      "$value": "#545454",
      "$type": "color",
