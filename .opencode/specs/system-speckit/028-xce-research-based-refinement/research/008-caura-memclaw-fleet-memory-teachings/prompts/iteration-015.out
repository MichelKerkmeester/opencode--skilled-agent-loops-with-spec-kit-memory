{"type":"text","timestamp":1780728827486,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"id":"prt_e9bb5767d001dvRpiiwWvKqwli","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","type":"text","text":"The requested files resolve to the embedding/enrichment services, four event DTOs, `memory.py`, `postgres_service.py`, and the core-worker module; I’m reading the concrete implementation paths now for line-level evidence.","time":{"start":1780728821373,"end":1780728827484},"metadata":{"openai":{"itemId":"msg_0f3d86b8e8edc3b9016a23c3f55a8c81919ae415747a0ea610","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780728827532,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_sYsk3bSD7UvVX1nW82q3U1S2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Service-level embedding entrypoints with retry + degraded-state stats.\n2: \n3: Reads provider selection from env (``EMBEDDING_PROVIDER``) when no\n4: tenant override is supplied — both core-api and core-worker drive the\n5: same code path, just with / without ``tenant_config``.\n6: \"\"\"\n7: \n8: from __future__ import annotations\n9: \n10: import asyncio\n11: import logging\n12: import os\n13: import time\n14: from collections.abc import Awaitable, Callable\n15: \n16: from common.embedding._registry import get_embedding_provider\n17: from common.embedding.constants import EMBEDDING_RETRY_ATTEMPTS, EMBEDDING_RETRY_DELAY_S\n18: from common.embedding.protocols import InstructionAwareEmbedder\n19: \n20: logger = logging.getLogger(__name__)\n21: \n22: \n23: class _EmbeddingStats:\n24:     \"\"\"Track failure rate to surface a degraded-provider signal in logs.\n25: \n26:     Three consecutive failures fire a single ERROR log (per cycle) so a\n27:     sustained provider outage shows up loudly without spamming once-per-\n28:     request. Reset on the next success.\n29:     \"\"\"\n30: \n31:     def __init__(self) -> None:\n32:         self.failures = 0\n33:         self.successes = 0\n34:         self.last_failure_time = 0.0\n35:         self.consecutive_failures = 0\n36:         self._lock = asyncio.Lock()\n37: \n38:     async def record_success(self) -> None:\n39:         async with self._lock:\n40:             self.successes += 1\n41:             self.consecutive_failures = 0\n42: \n43:     async def record_failure(self) -> None:\n44:         async with self._lock:\n45:             self.failures += 1\n46:             self.consecutive_failures += 1\n47:             self.last_failure_time = time.monotonic()\n48:             # Fire on first detection (failure 3) and then every 10\n49:             # failures thereafter (13, 23, 33, …). Loud enough to alert\n50:             # on a fresh outage, quiet enough not to spam during a\n51:             # sustained provider degradation. The next success resets\n52:             # the counter, so a subsequent streak re-fires from 3.\n53:             if (\n54:                 self.consecutive_failures >= 3\n55:                 and (self.consecutive_failures - 3) % 10 == 0\n56:             ):\n57:                 logger.error(\n58:                     \"Embedding service degraded: %d consecutive failures (total: %d/%d)\",\n59:                     self.consecutive_failures,\n60:                     self.failures,\n61:                     self.failures + self.successes,\n62:                 )\n63: \n64: \n65: _stats = _EmbeddingStats()\n66: \n67: # One-shot misconfiguration log dedup. The registry raises ``ValueError``\n68: # on env-var misconfig; ``_resolve_provider_or_degrade`` catches it,\n69: # records a failure stat, and returns ``None``. That guard runs on\n70: # every embed/query request, so logging the ERROR unconditionally\n71: # would spam the log at request rate. Keyed on the resolved provider\n72: # name (``\"openai\"``, ``\"vertex\"``, …) so a multi-tenant deployment\n73: # misconfiguring multiple providers still warns once per provider.\n74: # Module-level (process-scoped); restart resets the set, which is\n75: # the right cadence for \"operator forgot a flag\" errors.\n76: _misconfiguration_logged: set[str] = set()\n77: \n78: \n79: def _resolve_provider_name(tenant_config: object | None) -> str:\n80:     \"\"\"Tenant override first, else ``EMBEDDING_PROVIDER`` env, else ``\"fake\"``.\"\"\"\n81:     if tenant_config is not None:\n82:         name = getattr(tenant_config, \"embedding_provider\", None)\n83:         if name:\n84:             return name\n85:     return os.environ.get(\"EMBEDDING_PROVIDER\", \"fake\")\n86: \n87: \n88: async def get_embeddings_batch(\n89:     texts: list[str], tenant_config: object | None = None\n90: ) -> list[list[float]]:\n91:     \"\"\"Generate embeddings for multiple texts in a single API call.\n92: \n93:     Raises on any provider-side error. Bulk callers\n94:     (``memory_service.create_memories_bulk``,\n95:     ``_reembed_batch_via_provider``) already wrap this in\n96:     ``try: ... except Exception:`` and fall back to per-item retries,\n97:     so any exception type is acceptable here — what matters is that\n98:     the failure stats counter increments so the registry-level\n99:     degraded-provider trip-wire fires consistently with the single-embed\n100:     paths (``get_embedding`` / ``get_query_embedding``).\n101: \n102:     Two error shapes are explicitly accounted for:\n103: \n104:     1. ``ValueError`` from ``get_embedding_provider`` — env-var\n105:        misconfiguration (e.g. ``OPENAI_EMBEDDING_BASE_URL`` ⊕\n106:        ``SEND_DIMENSIONS`` mismatch). Used to propagate as an unhandled\n107:        exception that bulk callers caught generically but bypassed\n108:        ``_stats.record_failure``, so the trip-wire never fired under\n109:        sustained misconfig. Now records a failure and re-raises.\n110:     2. Any provider-side exception from ``embed_batch`` — auth, HTTP\n111:        client errors, Vertex quota, etc. Same record_failure + re-raise\n112:        contract as before.\n113:     \"\"\"\n114:     provider_name = _resolve_provider_name(tenant_config)\n115:     # Provider construction and embed dispatch are wrapped in *separate*\n116:     # try/excepts on purpose. Provider implementations (notably\n117:     # ``OpenAIEmbeddingProvider._postprocess``) raise ``ValueError`` at\n118:     # runtime — e.g. when the model returns fewer dimensions than\n119:     # ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``. That is NOT a registry\n120:     # misconfiguration; folding it into the misconfig branch would\n121:     # incorrectly route runtime data errors through the misconfig path.\n122:     #\n123:     # On a registry ``ValueError``, this path logs but does NOT claim\n124:     # the once-per-provider dedup gate (``_misconfiguration_logged``).\n125:     # Bulk-call failures cascade into the per-item ``_reembed_memory``\n126:     # fallback in ``memory_service``, which calls ``get_embedding`` →\n127:     # ``_resolve_provider_or_degrade`` → that path owns the dedup gate\n128:     # (and logs once with full context). If we `.add()` here, the per-\n129:     # item fallback's first ERROR log gets silenced as a duplicate,\n130:     # losing the more useful single-row attribution.\n131:     try:\n132:         provider = get_embedding_provider(provider_name, tenant_config)\n133:     except ValueError:\n134:         logger.error(\n135:             \"Bulk embedding: provider misconfiguration\",\n136:             exc_info=True,\n137:         )\n138:         await _stats.record_failure()\n139:         raise\n140:     try:\n141:         result = await provider.embed_batch(texts)\n142:     except Exception:\n143:         await _stats.record_failure()\n144:         raise\n145:     await _stats.record_success()\n146:     return result\n147: \n148: \n149: async def _run_with_retry(\n150:     make_call: Callable[[], Awaitable[list[float]]],\n151:     context: str,\n152: ) -> list[float] | None:\n153:     \"\"\"Execute *make_call* under the shared retry / stats / logging policy.\n154: \n155:     *make_call* is invoked once per attempt, so it should construct a\n156:     fresh coroutine each time it runs (coroutines aren't reusable across\n157:     awaits). Returns ``None`` after the attempt budget is exhausted —\n158:     callers degrade gracefully (write path persists ``embedding=NULL``;\n159:     search path raises 503 upstream).\n160: \n161:     *context* is a short human-readable label (``\"Embedding\"``,\n162:     ``\"Query embedding\"``) interpolated into the per-attempt warning\n163:     and the terminal error log so failures are attributable.\n164:     \"\"\"\n165:     last_exc: BaseException | None = None\n166:     for attempt in range(1, EMBEDDING_RETRY_ATTEMPTS + 1):\n167:         try:\n168:             result = await make_call()\n169:             await _stats.record_success()\n170:             return result\n171:         # Intentionally broad: must catch all provider-specific errors during retry.\n172:         except Exception as exc:\n173:             # Capture so the terminal log below can attach the stack trace.\n174:             # ``exc_info=True`` outside an except block reads\n175:             # ``sys.exc_info()`` which has been cleared by the time the\n176:             # loop exits, so we have to bind the exception explicitly.\n177:             last_exc = exc\n178:             logger.warning(\n179:                 \"%s attempt %d/%d failed\",\n180:                 context,\n181:                 attempt,\n182:                 EMBEDDING_RETRY_ATTEMPTS,\n183:                 exc_info=True,\n184:             )\n185:             if attempt < EMBEDDING_RETRY_ATTEMPTS:\n186:                 await asyncio.sleep(EMBEDDING_RETRY_DELAY_S * attempt)\n187:     await _stats.record_failure()\n188:     logger.error(\n189:         \"%s failed after %d attempts, returning None\",\n190:         context,\n191:         EMBEDDING_RETRY_ATTEMPTS,\n192:         exc_info=last_exc,\n193:     )\n194:     return None\n195: \n196: \n197: async def _resolve_provider_or_degrade(\n198:     tenant_config: object | None,\n199:     context: str,\n200: ) -> object | None:\n201:     \"\"\"Resolve the embedding provider, mapping a misconfiguration\n202:     ``ValueError`` from the registry to the same ``None`` degradation\n203:     contract the rest of this module documents.\n204: \n205:     ``get_embedding_provider`` raises ``ValueError`` on env-var misconfig\n206:     (``base_url`` ⊕ ``send_dimensions`` mismatch, invalid\n207:     ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``, etc.). Without this guard the\n208:     error would propagate out of ``get_embedding`` / ``get_query_embedding``\n209:     and break callers that rely on \"returns None on failure\" — write\n210:     paths persist rows with ``embedding=NULL`` for later backfill, search\n211:     paths typically translate None → 503. Logging once at error level\n212:     keeps the misconfiguration visible without making the request handler\n213:     crash.\n214:     \"\"\"\n215:     provider_name = _resolve_provider_name(tenant_config)\n216:     try:\n217:         return get_embedding_provider(provider_name, tenant_config)\n218:     except ValueError:\n219:         # Dedup: once-per-provider-name so a misconfigured deployment\n220:         # gets a single ERROR at first request rather than one per\n221:         # request. Failure stats still increment on every call, so\n222:         # the degraded-provider trip-wire in ``_EmbeddingStats`` still\n223:         # fires correctly under sustained misconfiguration.\n224:         if provider_name not in _misconfiguration_logged:\n225:             _misconfiguration_logged.add(provider_name)\n226:             logger.error(\n227:                 \"%s: provider misconfiguration (will not repeat); returning None\",\n228:                 context,\n229:                 exc_info=True,\n230:             )\n231:         await _stats.record_failure()\n232:         return None\n233: \n234: \n235: async def get_embedding(\n236:     text: str, tenant_config: object | None = None\n237: ) -> list[float] | None:\n238:     \"\"\"Generate an embedding with retry. Returns ``None`` on exhausted retries.\n239: \n240:     Caller-friendly degradation: a transient OpenAI/Vertex hiccup\n\n(Showing lines 1-240 of 300. Use offset=241 to continue.)\n</content>","metadata":{"preview":"\"\"\"Service-level embedding entrypoints with retry + degraded-state stats.\n\nReads provider selection from env (``EMBEDDING_PROVIDER``) when no\ntenant override is supplied — both core-api and core-worker drive the\nsame code path, just with / without ``tenant_config``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport os\nimport time\nfrom collections.abc import Awaitable, Callable\n\nfrom common.embedding._registry import get_embedding_provider\nfrom common.embedding.constants import EMBEDDING_RETRY_ATTEMPTS, EMBEDDING_RETRY_DELAY_S\nfrom common.embedding.protocols import InstructionAwareEmbedder\n\nlogger = logging.getLogger(__name__)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","text":"\"\"\"Service-level embedding entrypoints with retry + degraded-state stats.\n\nReads provider selection from env (``EMBEDDING_PROVIDER``) when no\ntenant override is supplied — both core-api and core-worker drive the\nsame code path, just with / without ``tenant_config``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport os\nimport time\nfrom collections.abc import Awaitable, Callable\n\nfrom common.embedding._registry import get_embedding_provider\nfrom common.embedding.constants import EMBEDDING_RETRY_ATTEMPTS, EMBEDDING_RETRY_DELAY_S\nfrom common.embedding.protocols import InstructionAwareEmbedder\n\nlogger = logging.getLogger(__name__)\n\n\nclass _EmbeddingStats:\n    \"\"\"Track failure rate to surface a degraded-provider signal in logs.\n\n    Three consecutive failures fire a single ERROR log (per cycle) so a\n    sustained provider outage shows up loudly without spamming once-per-\n    request. Reset on the next success.\n    \"\"\"\n\n    def __init__(self) -> None:\n        self.failures = 0\n        self.successes = 0\n        self.last_failure_time = 0.0\n        self.consecutive_failures = 0\n        self._lock = asyncio.Lock()\n\n    async def record_success(self) -> None:\n        async with self._lock:\n            self.successes += 1\n            self.consecutive_failures = 0\n\n    async def record_failure(self) -> None:\n        async with self._lock:\n            self.failures += 1\n            self.consecutive_failures += 1\n            self.last_failure_time = time.monotonic()\n            # Fire on first detection (failure 3) and then every 10\n            # failures thereafter (13, 23, 33, …). Loud enough to alert\n            # on a fresh outage, quiet enough not to spam during a\n            # sustained provider degradation. The next success resets\n            # the counter, so a subsequent streak re-fires from 3.\n            if (\n                self.consecutive_failures >= 3\n                and (self.consecutive_failures - 3) % 10 == 0\n            ):\n                logger.error(\n                    \"Embedding service degraded: %d consecutive failures (total: %d/%d)\",\n                    self.consecutive_failures,\n                    self.failures,\n                    self.failures + self.successes,\n                )\n\n\n_stats = _EmbeddingStats()\n\n# One-shot misconfiguration log dedup. The registry raises ``ValueError``\n# on env-var misconfig; ``_resolve_provider_or_degrade`` catches it,\n# records a failure stat, and returns ``None``. That guard runs on\n# every embed/query request, so logging the ERROR unconditionally\n# would spam the log at request rate. Keyed on the resolved provider\n# name (``\"openai\"``, ``\"vertex\"``, …) so a multi-tenant deployment\n# misconfiguring multiple providers still warns once per provider.\n# Module-level (process-scoped); restart resets the set, which is\n# the right cadence for \"operator forgot a flag\" errors.\n_misconfiguration_logged: set[str] = set()\n\n\ndef _resolve_provider_name(tenant_config: object | None) -> str:\n    \"\"\"Tenant override first, else ``EMBEDDING_PROVIDER`` env, else ``\"fake\"``.\"\"\"\n    if tenant_config is not None:\n        name = getattr(tenant_config, \"embedding_provider\", None)\n        if name:\n            return name\n    return os.environ.get(\"EMBEDDING_PROVIDER\", \"fake\")\n\n\nasync def get_embeddings_batch(\n    texts: list[str], tenant_config: object | None = None\n) -> list[list[float]]:\n    \"\"\"Generate embeddings for multiple texts in a single API call.\n\n    Raises on any provider-side error. Bulk callers\n    (``memory_service.create_memories_bulk``,\n    ``_reembed_batch_via_provider``) already wrap this in\n    ``try: ... except Exception:`` and fall back to per-item retries,\n    so any exception type is acceptable here — what matters is that\n    the failure stats counter increments so the registry-level\n    degraded-provider trip-wire fires consistently with the single-embed\n    paths (``get_embedding`` / ``get_query_embedding``).\n\n    Two error shapes are explicitly accounted for:\n\n    1. ``ValueError`` from ``get_embedding_provider`` — env-var\n       misconfiguration (e.g. ``OPENAI_EMBEDDING_BASE_URL`` ⊕\n       ``SEND_DIMENSIONS`` mismatch). Used to propagate as an unhandled\n       exception that bulk callers caught generically but bypassed\n       ``_stats.record_failure``, so the trip-wire never fired under\n       sustained misconfig. Now records a failure and re-raises.\n    2. Any provider-side exception from ``embed_batch`` — auth, HTTP\n       client errors, Vertex quota, etc. Same record_failure + re-raise\n       contract as before.\n    \"\"\"\n    provider_name = _resolve_provider_name(tenant_config)\n    # Provider construction and embed dispatch are wrapped in *separate*\n    # try/excepts on purpose. Provider implementations (notably\n    # ``OpenAIEmbeddingProvider._postprocess``) raise ``ValueError`` at\n    # runtime — e.g. when the model returns fewer dimensions than\n    # ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``. That is NOT a registry\n    # misconfiguration; folding it into the misconfig branch would\n    # incorrectly route runtime data errors through the misconfig path.\n    #\n    # On a registry ``ValueError``, this path logs but does NOT claim\n    # the once-per-provider dedup gate (``_misconfiguration_logged``).\n    # Bulk-call failures cascade into the per-item ``_reembed_memory``\n    # fallback in ``memory_service``, which calls ``get_embedding`` →\n    # ``_resolve_provider_or_degrade`` → that path owns the dedup gate\n    # (and logs once with full context). If we `.add()` here, the per-\n    # item fallback's first ERROR log gets silenced as a duplicate,\n    # losing the more useful single-row attribution.\n    try:\n        provider = get_embedding_provider(provider_name, tenant_config)\n    except ValueError:\n        logger.error(\n            \"Bulk embedding: provider misconfiguration\",\n            exc_info=True,\n        )\n        await _stats.record_failure()\n        raise\n    try:\n        result = await provider.embed_batch(texts)\n    except Exception:\n        await _stats.record_failure()\n        raise\n    await _stats.record_success()\n    return result\n\n\nasync def _run_with_retry(\n    make_call: Callable[[], Awaitable[list[float]]],\n    context: str,\n) -> list[float] | None:\n    \"\"\"Execute *make_call* under the shared retry / stats / logging policy.\n\n    *make_call* is invoked once per attempt, so it should construct a\n    fresh coroutine each time it runs (coroutines aren't reusable across\n    awaits). Returns ``None`` after the attempt budget is exhausted —\n    callers degrade gracefully (write path persists ``embedding=NULL``;\n    search path raises 503 upstream).\n\n    *context* is a short human-readable label (``\"Embedding\"``,\n    ``\"Query embedding\"``) interpolated into the per-attempt warning\n    and the terminal error log so failures are attributable.\n    \"\"\"\n    last_exc: BaseException | None = None\n    for attempt in range(1, EMBEDDING_RETRY_ATTEMPTS + 1):\n        try:\n            result = await make_call()\n            await _stats.record_success()\n            return result\n        # Intentionally broad: must catch all provider-specific errors during retry.\n        except Exception as exc:\n            # Capture so the terminal log below can attach the stack trace.\n            # ``exc_info=True`` outside an except block reads\n            # ``sys.exc_info()`` which has been cleared by the time the\n            # loop exits, so we have to bind the exception explicitly.\n            last_exc = exc\n            logger.warning(\n                \"%s attempt %d/%d failed\",\n                context,\n                attempt,\n                EMBEDDING_RETRY_ATTEMPTS,\n                exc_info=True,\n            )\n            if attempt < EMBEDDING_RETRY_ATTEMPTS:\n                await asyncio.sleep(EMBEDDING_RETRY_DELAY_S * attempt)\n    await _stats.record_failure()\n    logger.error(\n        \"%s failed after %d attempts, returning None\",\n        context,\n        EMBEDDING_RETRY_ATTEMPTS,\n        exc_info=last_exc,\n    )\n    return None\n\n\nasync def _resolve_provider_or_degrade(\n    tenant_config: object | None,\n    context: str,\n) -> object | None:\n    \"\"\"Resolve the embedding provider, mapping a misconfiguration\n    ``ValueError`` from the registry to the same ``None`` degradation\n    contract the rest of this module documents.\n\n    ``get_embedding_provider`` raises ``ValueError`` on env-var misconfig\n    (``base_url`` ⊕ ``send_dimensions`` mismatch, invalid\n    ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM``, etc.). Without this guard the\n    error would propagate out of ``get_embedding`` / ``get_query_embedding``\n    and break callers that rely on \"returns None on failure\" — write\n    paths persist rows with ``embedding=NULL`` for later backfill, search\n    paths typically translate None → 503. Logging once at error level\n    keeps the misconfiguration visible without making the request handler\n    crash.\n    \"\"\"\n    provider_name = _resolve_provider_name(tenant_config)\n    try:\n        return get_embedding_provider(provider_name, tenant_config)\n    except ValueError:\n        # Dedup: once-per-provider-name so a misconfigured deployment\n        # gets a single ERROR at first request rather than one per\n        # request. Failure stats still increment on every call, so\n        # the degraded-provider trip-wire in ``_EmbeddingStats`` still\n        # fires correctly under sustained misconfiguration.\n        if provider_name not in _misconfiguration_logged:\n            _misconfiguration_logged.add(provider_name)\n            logger.error(\n                \"%s: provider misconfiguration (will not repeat); returning None\",\n                context,\n                exc_info=True,\n            )\n        await _stats.record_failure()\n        return None\n\n\nasync def get_embedding(\n    text: str, tenant_config: object | None = None\n) -> list[float] | None:\n    \"\"\"Generate an embedding with retry. Returns ``None`` on exhausted retries.\n\n    Caller-friendly degradation: a transient OpenAI/Vertex hiccup","lineStart":1,"lineEnd":240,"totalLines":300,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","time":{"start":1780728827515,"end":1780728827523}},"metadata":{"openai":{"itemId":"fc_0f3d86b8e8edc3b9016a23c3fb74708191bacfd8e021352697"}},"id":"prt_e9bb58e5d001c4BU95UbkzdbtP","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1"}}
{"type":"tool_use","timestamp":1780728827532,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_mNz5YPkXnNb2Yay58VmUInhD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Embedding-provider factory.\n2: \n3: Resolves a concrete provider instance from the canonical name +\n4: optional tenant config. Tier order:\n5: \n6:     Tenant key  →  Platform singleton  →  FakeEmbeddingProvider\n7: \n8: Env-driven (no service-config dependency) so both core-api (tenant-aware)\n9: and core-worker (platform-only) can use it.\n10: \"\"\"\n11: \n12: from __future__ import annotations\n13: \n14: import asyncio\n15: import logging\n16: import os\n17: from collections import OrderedDict\n18: \n19: from common.constants import VECTOR_DIM\n20: from common.embedding.constants import OPENAI_EMBEDDING_MODEL\n21: from common.embedding.protocols import EmbeddingProvider\n22: from common.embedding.providers.fake import FakeEmbeddingProvider\n23: from common.embedding.providers.local import LocalEmbedding\n24: from common.embedding.providers.openai import OpenAIEmbeddingProvider\n25: from common.provider_names import ProviderName\n26: \n27: logger = logging.getLogger(__name__)\n28: \n29: # Cache OpenAI provider instances by (api_key, model). Each instance\n30: # holds a long-lived ``AsyncOpenAI`` (and therefore a long-lived\n31: # ``httpx.AsyncClient`` connection pool); without the cache, every\n32: # ``get_embedding`` call from core-api would build a fresh pool and\n33: # pay a TLS handshake to api.openai.com on every request. Multi-tenant\n34: # safe: keying on ``api_key`` keeps tenant-A's client from being\n35: # reused for tenant-B's request. The platform-tier singleton has its\n36: # own caching (managed in ``_platform.py``) — we don't double-cache it.\n37: #\n38: # LRU-bounded so a rotated/revoked tenant key eventually gets evicted\n39: # instead of pinning a 401-returning client forever. ``OrderedDict``\n40: # semantics: ``move_to_end`` on hit, ``popitem(last=False)`` on miss\n41: # when full. 256 is well above any realistic tenant count for a single\n42: # process; raise if that proves wrong.\n43: #\n44: # Eviction must explicitly close the evicted provider's httpx pool\n45: # (CAURA-627). The OpenAI SDK now gets a user-provided ``http_client``\n46: # (set in ``OpenAIEmbeddingProvider.__init__`` so we control pool\n47: # sizing); per the SDK contract, user-provided clients are NOT closed\n48: # on SDK teardown — caller owns cleanup. ``_get_or_create_openai_provider``\n49: # below schedules ``aclose()`` on the evicted instance via\n50: # ``asyncio.create_task`` so the pool drains in the background instead\n51: # of leaking ``ResourceWarning`` and held connections under long-lived\n52: # processes that rotate keys past the cache cap.\n53: _OPENAI_CACHE_MAX = 256\n54: _openai_provider_cache: OrderedDict[\n55:     tuple[str, str, str | None, bool, str | None, int | None],\n56:     OpenAIEmbeddingProvider,\n57: ] = OrderedDict()\n58: \n59: # Strong references to in-flight ``aclose()`` cleanup tasks so the GC\n60: # doesn't reap them mid-execution. ``asyncio.create_task`` returns a\n61: # task that's kept alive only by user references; without this set the\n62: # task could be collected before its coroutine finishes draining the\n63: # httpx pool. The ``add_done_callback`` removes the task from the set\n64: # once it completes so this doesn't grow unboundedly.\n65: _background_tasks: set[asyncio.Task[None]] = set()\n66: \n67: \n68: def _get_or_create_openai_provider(\n69:     api_key: str,\n70:     model: str,\n71:     base_url: str | None,\n72:     send_dimensions: bool,\n73:     query_instruction: str | None,\n74:     truncate_to_dim: int | None,\n75: ) -> OpenAIEmbeddingProvider:\n76:     \"\"\"LRU-bounded ``OpenAIEmbeddingProvider`` lookup keyed on the full client\n77:     config tuple.\n78: \n79:     Cache key includes ``base_url`` / ``send_dimensions`` / ``query_instruction``\n80:     / ``truncate_to_dim`` so the same api_key can host multiple simultaneous\n81:     providers — e.g. real OpenAI for one tenant and a local TEI sidecar with\n82:     a Qwen3 instruction prefix for another — without the second silently\n83:     aliasing to the first cached client.\n84: \n85:     Not strictly async-safe across concurrent cache misses for the same\n86:     key — two coroutines can both observe a miss before either inserts.\n87:     The race is harmless: the later insert overwrites the earlier with\n88:     a functionally identical client (same key tuple, no per-call state),\n89:     and the earlier instance gets dropped on the next GC. Not worth an\n90:     asyncio.Lock for the cost of a duplicated TLS handshake on the\n91:     first concurrent miss.\n92:     \"\"\"\n93:     cache_key = (\n94:         api_key,\n95:         model,\n96:         base_url,\n97:         send_dimensions,\n98:         query_instruction,\n99:         truncate_to_dim,\n100:     )\n101:     cached = _openai_provider_cache.get(cache_key)\n102:     if cached is not None:\n103:         _openai_provider_cache.move_to_end(cache_key)\n104:         return cached\n105:     provider = OpenAIEmbeddingProvider(\n106:         api_key=api_key,\n107:         model=model,\n108:         base_url=base_url,\n109:         send_dimensions=send_dimensions,\n110:         query_instruction=query_instruction,\n111:         truncate_to_dim=truncate_to_dim,\n112:     )\n113:     _openai_provider_cache[cache_key] = provider\n114:     if len(_openai_provider_cache) > _OPENAI_CACHE_MAX:\n115:         _, evicted = _openai_provider_cache.popitem(last=False)\n116:         # Schedule cleanup of the evicted provider's httpx pool. The\n117:         # SDK won't do it for us (we pass an explicit ``http_client``).\n118:         # Best-effort — bare ``except RuntimeError`` covers the rare\n119:         # case where the registry is exercised outside a running event\n120:         # loop (e.g. early startup); GC will reclaim the connections\n121:         # eventually but with the ``ResourceWarning`` we'd see in\n122:         # asyncio debug mode.\n123:         try:\n124:             loop = asyncio.get_running_loop()\n125:             task = loop.create_task(evicted.aclose())\n126:             _background_tasks.add(task)\n127:             task.add_done_callback(_background_tasks.discard)\n128:         except RuntimeError:\n129:             pass\n130:     return provider\n131: \n132: \n133: def _resolve_openai_api_key(tenant_config: object | None) -> str:\n134:     \"\"\"Tenant override first, then ``OPENAI_API_KEY`` env. Empty string if neither.\n135: \n136:     Tenant config is duck-typed (loose ``getattr`` protocol) so callers\n137:     can pass any object exposing an ``openai_api_key`` attribute (or\n138:     none at all).\n139:     \"\"\"\n140:     if tenant_config is not None:\n141:         key = getattr(tenant_config, \"openai_api_key\", None)\n142:         if key:\n143:             return key\n144:     return os.environ.get(\"OPENAI_API_KEY\", \"\")\n145: \n146: \n147: def get_embedding_provider(\n148:     name: str,\n149:     tenant_config: object | None = None,\n150: ) -> EmbeddingProvider:\n151:     \"\"\"Construct an embedding provider by name.\n152: \n153:     Parameters\n154:     ----------\n155:     name:\n156:         Provider identifier: ``\"openai\"``, ``\"local\"``, or ``\"fake\"``.\n157:     tenant_config:\n158:         Optional ``ResolvedConfig``-shaped object for per-tenant overrides\n159:         (``openai_api_key``, ``embedding_model``). Can be ``None`` for\n160:         platform-only callers (e.g. core-worker).\n161: \n162:     Raises\n163:     ------\n164:     ValueError\n165:         If the provider name is unknown, or if the OpenAI-compatible\n166:         env var combination would guarantee 100% failed embed calls\n167:         (``base_url`` set with ``send_dimensions=true``, or\n168:         ``base_url`` unset with ``send_dimensions=false``), or if\n169:         ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM`` is set to anything other\n170:         than ``VECTOR_DIM``, or if it is not parseable as an integer.\n171:     \"\"\"\n172:     if name == ProviderName.FAKE:\n173:         return FakeEmbeddingProvider()\n174: \n175:     if name == ProviderName.OPENAI:\n176:         api_key = _resolve_openai_api_key(tenant_config)\n177:         if not api_key:\n178:             # Lazy import — avoids a circular at module-load time and\n179:             # keeps platform setup off the cold-start critical path\n180:             # for callers that don't need it.\n181:             from common.embedding._platform import get_platform_embedding\n182: \n183:             platform = get_platform_embedding()\n184:             if platform is not None:\n185:                 logger.info(\n186:                     \"No tenant key for OpenAI embedding, using platform embedding (%s)\",\n187:                     platform.model,\n188:                 )\n189:                 return platform\n190:             logger.warning(\n191:                 \"No API key for OpenAI embedding provider, returning FakeEmbeddingProvider\",\n192:             )\n193:             return FakeEmbeddingProvider()\n194:         embed_model = (\n195:             getattr(tenant_config, \"embedding_model\", None)\n196:             if tenant_config is not None\n197:             else None\n198:         ) or OPENAI_EMBEDDING_MODEL\n199:         base_url = os.environ.get(\"OPENAI_EMBEDDING_BASE_URL\") or None\n200:         # Strict bool parsing: only ``\"true\"`` / ``\"false\"`` (case-insensitive)\n201:         # accepted. The previous ``!= \"false\"`` check silently treated typos\n202:         # (\"trun\", \"yes\", \"1\") and accidental values as true, which is the\n203:         # wrong default direction for a flag that controls a config the\n204:         # registry now hard-fails on (any base_url + send_dimensions=true\n205:         # raises). Operators get a clear error on the parse rather than\n206:         # downstream on the misconfig.\n207:         _send_dim_raw = os.environ.get(\n208:             \"OPENAI_EMBEDDING_SEND_DIMENSIONS\", \"true\"\n209:         ).lower()\n210:         if _send_dim_raw not in (\"true\", \"false\"):\n211:             raise ValueError(\n212:                 f\"OPENAI_EMBEDDING_SEND_DIMENSIONS={_send_dim_raw!r} \"\n213:                 \"must be 'true' or 'false'.\"\n214:             )\n215:         send_dimensions = _send_dim_raw == \"true\"\n216:         # Option B: instruction-aware query encoding. Default applied to all\n217:         # /api/v1/search calls; documents (writes) embed unmodified text.\n218:         query_instruction = os.environ.get(\"EMBEDDING_QUERY_INSTRUCTION\") or None\n219:         truncate_raw = os.environ.get(\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM\")\n220:         # Surface the env var name in the parse error. Bare ``int(...)``\n\n(Showing lines 1-220 of 344. Use offset=221 to continue.)\n</content>","metadata":{"preview":"\"\"\"Embedding-provider factory.\n\nResolves a concrete provider instance from the canonical name +\noptional tenant config. Tier order:\n\n    Tenant key  →  Platform singleton  →  FakeEmbeddingProvider\n\nEnv-driven (no service-config dependency) so both core-api (tenant-aware)\nand core-worker (platform-only) can use it.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport os\nfrom collections import OrderedDict\n\nfrom common.constants import VECTOR_DIM\nfrom common.embedding.constants import OPENAI_EMBEDDING_MODEL","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py","text":"\"\"\"Embedding-provider factory.\n\nResolves a concrete provider instance from the canonical name +\noptional tenant config. Tier order:\n\n    Tenant key  →  Platform singleton  →  FakeEmbeddingProvider\n\nEnv-driven (no service-config dependency) so both core-api (tenant-aware)\nand core-worker (platform-only) can use it.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport os\nfrom collections import OrderedDict\n\nfrom common.constants import VECTOR_DIM\nfrom common.embedding.constants import OPENAI_EMBEDDING_MODEL\nfrom common.embedding.protocols import EmbeddingProvider\nfrom common.embedding.providers.fake import FakeEmbeddingProvider\nfrom common.embedding.providers.local import LocalEmbedding\nfrom common.embedding.providers.openai import OpenAIEmbeddingProvider\nfrom common.provider_names import ProviderName\n\nlogger = logging.getLogger(__name__)\n\n# Cache OpenAI provider instances by (api_key, model). Each instance\n# holds a long-lived ``AsyncOpenAI`` (and therefore a long-lived\n# ``httpx.AsyncClient`` connection pool); without the cache, every\n# ``get_embedding`` call from core-api would build a fresh pool and\n# pay a TLS handshake to api.openai.com on every request. Multi-tenant\n# safe: keying on ``api_key`` keeps tenant-A's client from being\n# reused for tenant-B's request. The platform-tier singleton has its\n# own caching (managed in ``_platform.py``) — we don't double-cache it.\n#\n# LRU-bounded so a rotated/revoked tenant key eventually gets evicted\n# instead of pinning a 401-returning client forever. ``OrderedDict``\n# semantics: ``move_to_end`` on hit, ``popitem(last=False)`` on miss\n# when full. 256 is well above any realistic tenant count for a single\n# process; raise if that proves wrong.\n#\n# Eviction must explicitly close the evicted provider's httpx pool\n# (CAURA-627). The OpenAI SDK now gets a user-provided ``http_client``\n# (set in ``OpenAIEmbeddingProvider.__init__`` so we control pool\n# sizing); per the SDK contract, user-provided clients are NOT closed\n# on SDK teardown — caller owns cleanup. ``_get_or_create_openai_provider``\n# below schedules ``aclose()`` on the evicted instance via\n# ``asyncio.create_task`` so the pool drains in the background instead\n# of leaking ``ResourceWarning`` and held connections under long-lived\n# processes that rotate keys past the cache cap.\n_OPENAI_CACHE_MAX = 256\n_openai_provider_cache: OrderedDict[\n    tuple[str, str, str | None, bool, str | None, int | None],\n    OpenAIEmbeddingProvider,\n] = OrderedDict()\n\n# Strong references to in-flight ``aclose()`` cleanup tasks so the GC\n# doesn't reap them mid-execution. ``asyncio.create_task`` returns a\n# task that's kept alive only by user references; without this set the\n# task could be collected before its coroutine finishes draining the\n# httpx pool. The ``add_done_callback`` removes the task from the set\n# once it completes so this doesn't grow unboundedly.\n_background_tasks: set[asyncio.Task[None]] = set()\n\n\ndef _get_or_create_openai_provider(\n    api_key: str,\n    model: str,\n    base_url: str | None,\n    send_dimensions: bool,\n    query_instruction: str | None,\n    truncate_to_dim: int | None,\n) -> OpenAIEmbeddingProvider:\n    \"\"\"LRU-bounded ``OpenAIEmbeddingProvider`` lookup keyed on the full client\n    config tuple.\n\n    Cache key includes ``base_url`` / ``send_dimensions`` / ``query_instruction``\n    / ``truncate_to_dim`` so the same api_key can host multiple simultaneous\n    providers — e.g. real OpenAI for one tenant and a local TEI sidecar with\n    a Qwen3 instruction prefix for another — without the second silently\n    aliasing to the first cached client.\n\n    Not strictly async-safe across concurrent cache misses for the same\n    key — two coroutines can both observe a miss before either inserts.\n    The race is harmless: the later insert overwrites the earlier with\n    a functionally identical client (same key tuple, no per-call state),\n    and the earlier instance gets dropped on the next GC. Not worth an\n    asyncio.Lock for the cost of a duplicated TLS handshake on the\n    first concurrent miss.\n    \"\"\"\n    cache_key = (\n        api_key,\n        model,\n        base_url,\n        send_dimensions,\n        query_instruction,\n        truncate_to_dim,\n    )\n    cached = _openai_provider_cache.get(cache_key)\n    if cached is not None:\n        _openai_provider_cache.move_to_end(cache_key)\n        return cached\n    provider = OpenAIEmbeddingProvider(\n        api_key=api_key,\n        model=model,\n        base_url=base_url,\n        send_dimensions=send_dimensions,\n        query_instruction=query_instruction,\n        truncate_to_dim=truncate_to_dim,\n    )\n    _openai_provider_cache[cache_key] = provider\n    if len(_openai_provider_cache) > _OPENAI_CACHE_MAX:\n        _, evicted = _openai_provider_cache.popitem(last=False)\n        # Schedule cleanup of the evicted provider's httpx pool. The\n        # SDK won't do it for us (we pass an explicit ``http_client``).\n        # Best-effort — bare ``except RuntimeError`` covers the rare\n        # case where the registry is exercised outside a running event\n        # loop (e.g. early startup); GC will reclaim the connections\n        # eventually but with the ``ResourceWarning`` we'd see in\n        # asyncio debug mode.\n        try:\n            loop = asyncio.get_running_loop()\n            task = loop.create_task(evicted.aclose())\n            _background_tasks.add(task)\n            task.add_done_callback(_background_tasks.discard)\n        except RuntimeError:\n            pass\n    return provider\n\n\ndef _resolve_openai_api_key(tenant_config: object | None) -> str:\n    \"\"\"Tenant override first, then ``OPENAI_API_KEY`` env. Empty string if neither.\n\n    Tenant config is duck-typed (loose ``getattr`` protocol) so callers\n    can pass any object exposing an ``openai_api_key`` attribute (or\n    none at all).\n    \"\"\"\n    if tenant_config is not None:\n        key = getattr(tenant_config, \"openai_api_key\", None)\n        if key:\n            return key\n    return os.environ.get(\"OPENAI_API_KEY\", \"\")\n\n\ndef get_embedding_provider(\n    name: str,\n    tenant_config: object | None = None,\n) -> EmbeddingProvider:\n    \"\"\"Construct an embedding provider by name.\n\n    Parameters\n    ----------\n    name:\n        Provider identifier: ``\"openai\"``, ``\"local\"``, or ``\"fake\"``.\n    tenant_config:\n        Optional ``ResolvedConfig``-shaped object for per-tenant overrides\n        (``openai_api_key``, ``embedding_model``). Can be ``None`` for\n        platform-only callers (e.g. core-worker).\n\n    Raises\n    ------\n    ValueError\n        If the provider name is unknown, or if the OpenAI-compatible\n        env var combination would guarantee 100% failed embed calls\n        (``base_url`` set with ``send_dimensions=true``, or\n        ``base_url`` unset with ``send_dimensions=false``), or if\n        ``OPENAI_EMBEDDING_TRUNCATE_TO_DIM`` is set to anything other\n        than ``VECTOR_DIM``, or if it is not parseable as an integer.\n    \"\"\"\n    if name == ProviderName.FAKE:\n        return FakeEmbeddingProvider()\n\n    if name == ProviderName.OPENAI:\n        api_key = _resolve_openai_api_key(tenant_config)\n        if not api_key:\n            # Lazy import — avoids a circular at module-load time and\n            # keeps platform setup off the cold-start critical path\n            # for callers that don't need it.\n            from common.embedding._platform import get_platform_embedding\n\n            platform = get_platform_embedding()\n            if platform is not None:\n                logger.info(\n                    \"No tenant key for OpenAI embedding, using platform embedding (%s)\",\n                    platform.model,\n                )\n                return platform\n            logger.warning(\n                \"No API key for OpenAI embedding provider, returning FakeEmbeddingProvider\",\n            )\n            return FakeEmbeddingProvider()\n        embed_model = (\n            getattr(tenant_config, \"embedding_model\", None)\n            if tenant_config is not None\n            else None\n        ) or OPENAI_EMBEDDING_MODEL\n        base_url = os.environ.get(\"OPENAI_EMBEDDING_BASE_URL\") or None\n        # Strict bool parsing: only ``\"true\"`` / ``\"false\"`` (case-insensitive)\n        # accepted. The previous ``!= \"false\"`` check silently treated typos\n        # (\"trun\", \"yes\", \"1\") and accidental values as true, which is the\n        # wrong default direction for a flag that controls a config the\n        # registry now hard-fails on (any base_url + send_dimensions=true\n        # raises). Operators get a clear error on the parse rather than\n        # downstream on the misconfig.\n        _send_dim_raw = os.environ.get(\n            \"OPENAI_EMBEDDING_SEND_DIMENSIONS\", \"true\"\n        ).lower()\n        if _send_dim_raw not in (\"true\", \"false\"):\n            raise ValueError(\n                f\"OPENAI_EMBEDDING_SEND_DIMENSIONS={_send_dim_raw!r} \"\n                \"must be 'true' or 'false'.\"\n            )\n        send_dimensions = _send_dim_raw == \"true\"\n        # Option B: instruction-aware query encoding. Default applied to all\n        # /api/v1/search calls; documents (writes) embed unmodified text.\n        query_instruction = os.environ.get(\"EMBEDDING_QUERY_INSTRUCTION\") or None\n        truncate_raw = os.environ.get(\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM\")\n        # Surface the env var name in the parse error. Bare ``int(...)``","lineStart":1,"lineEnd":220,"totalLines":344,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py","time":{"start":1780728827519,"end":1780728827530}},"metadata":{"openai":{"itemId":"fc_0f3d86b8e8edc3b9016a23c3fb748081918108cb02518b77a2"}},"id":"prt_e9bb58e7d001S94eRB6Irjvwvy","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1"}}
{"type":"tool_use","timestamp":1780728827541,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_Wu2rhIouz8YfkQCJqW0juIEj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Embedding-provider protocols shared across services.\n2: \n3: Two protocols, by design split:\n4: \n5: * :class:`EmbeddingProvider` — the symmetric core every provider must\n6:   implement (``embed``, ``embed_batch``, ``provider_name``, ``model``).\n7:   Conformance held by ``Fake``, ``Local``, ``Vertex``, and\n8:   ``OpenAIEmbeddingProvider``.\n9: \n10: * :class:`InstructionAwareEmbedder` — the optional extension for models\n11:   trained with asymmetric query/document encoding (Qwen3-Embedding,\n12:   e5-instruct, KaLM). Conformance held by ``OpenAIEmbeddingProvider``\n13:   only — when pointed at an instruction-aware model. Symmetric providers\n14:   deliberately do NOT implement this; callers (see\n15:   :func:`common.embedding._service.get_query_embedding`) ``hasattr``-check\n16:   and fall back to :meth:`EmbeddingProvider.embed`.\n17: \n18: Splitting the protocols keeps ``runtime_checkable`` honest:\n19: ``isinstance(p, EmbeddingProvider)`` is true for every provider without\n20: forcing a no-op shim onto symmetric ones. The narrower protocol expresses\n21: real capability rather than protocol-conformance ceremony.\n22: \"\"\"\n23: \n24: from __future__ import annotations\n25: \n26: from typing import Protocol, runtime_checkable\n27: \n28: \n29: @runtime_checkable\n30: class EmbeddingProvider(Protocol):\n31:     \"\"\"Async embedding provider for single and batch text embedding.\"\"\"\n32: \n33:     @property\n34:     def provider_name(self) -> str: ...\n35: \n36:     @property\n37:     def model(self) -> str: ...\n38: \n39:     async def embed(self, text: str) -> list[float]:\n40:         \"\"\"Generate an embedding vector for a single text.\n41: \n42:         The returned vector size is determined by the provider and model\n43:         configuration. Callers should not assume a specific dimensionality\n44:         — the system-wide ``VECTOR_DIM`` constant and the pgvector column\n45:         definition enforce consistency at the storage layer.\n46:         \"\"\"\n47:         ...\n48: \n49:     async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n50:         \"\"\"Generate embedding vectors for multiple texts in one call.\n51: \n52:         Same dimensionality contract as :meth:`embed`.\n53:         \"\"\"\n54:         ...\n55: \n56: \n57: @runtime_checkable\n58: class InstructionAwareEmbedder(Protocol):\n59:     \"\"\"Optional extension for models with asymmetric query/document encoding.\n60: \n61:     Instruction-aware embedders (Qwen3-Embedding, e5-instruct, KaLM-Gemma3,\n62:     …) train the query-side encoder to expect a task-description prefix\n63:     that documents do not receive. A provider conforming to this protocol\n64:     must:\n65: \n66:     * Apply the prefix on :meth:`embed_query` only — never on the\n67:       document path (:meth:`EmbeddingProvider.embed`).\n68:     * Resolve *instruction* in this order: per-call arg → constructor\n69:       default → no prefix (degenerates to :meth:`embed`).\n70: \n71:     Symmetric providers (``Fake``, ``Local``, ``Vertex``,\n72:     OpenAI ``text-embedding-3-small``, ``bge-m3``, ``gte-en-v1.5``) do\n73:     **not** implement this protocol. The query path\n74:     (:func:`common.embedding._service.get_query_embedding`) checks\n75:     ``isinstance(provider, InstructionAwareEmbedder)`` (or, equivalently,\n76:     ``hasattr(provider, \"embed_query\")``) and falls back to\n77:     :meth:`EmbeddingProvider.embed` when absent.\n78:     \"\"\"\n79: \n80:     async def embed_query(\n81:         self, text: str, instruction: str | None = None\n82:     ) -> list[float]:\n83:         \"\"\"Generate an embedding vector for a search-side query.\"\"\"\n84:         ...\n\n(End of file - total 84 lines)\n</content>","metadata":{"preview":"\"\"\"Embedding-provider protocols shared across services.\n\nTwo protocols, by design split:\n\n* :class:`EmbeddingProvider` — the symmetric core every provider must\n  implement (``embed``, ``embed_batch``, ``provider_name``, ``model``).\n  Conformance held by ``Fake``, ``Local``, ``Vertex``, and\n  ``OpenAIEmbeddingProvider``.\n\n* :class:`InstructionAwareEmbedder` — the optional extension for models\n  trained with asymmetric query/document encoding (Qwen3-Embedding,\n  e5-instruct, KaLM). Conformance held by ``OpenAIEmbeddingProvider``\n  only — when pointed at an instruction-aware model. Symmetric providers\n  deliberately do NOT implement this; callers (see\n  :func:`common.embedding._service.get_query_embedding`) ``hasattr``-check\n  and fall back to :meth:`EmbeddingProvider.embed`.\n\nSplitting the protocols keeps ``runtime_checkable`` honest:\n``isinstance(p, EmbeddingProvider)`` is true for every provider without\nforcing a no-op shim onto symmetric ones. The narrower protocol expresses","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py","text":"\"\"\"Embedding-provider protocols shared across services.\n\nTwo protocols, by design split:\n\n* :class:`EmbeddingProvider` — the symmetric core every provider must\n  implement (``embed``, ``embed_batch``, ``provider_name``, ``model``).\n  Conformance held by ``Fake``, ``Local``, ``Vertex``, and\n  ``OpenAIEmbeddingProvider``.\n\n* :class:`InstructionAwareEmbedder` — the optional extension for models\n  trained with asymmetric query/document encoding (Qwen3-Embedding,\n  e5-instruct, KaLM). Conformance held by ``OpenAIEmbeddingProvider``\n  only — when pointed at an instruction-aware model. Symmetric providers\n  deliberately do NOT implement this; callers (see\n  :func:`common.embedding._service.get_query_embedding`) ``hasattr``-check\n  and fall back to :meth:`EmbeddingProvider.embed`.\n\nSplitting the protocols keeps ``runtime_checkable`` honest:\n``isinstance(p, EmbeddingProvider)`` is true for every provider without\nforcing a no-op shim onto symmetric ones. The narrower protocol expresses\nreal capability rather than protocol-conformance ceremony.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Protocol, runtime_checkable\n\n\n@runtime_checkable\nclass EmbeddingProvider(Protocol):\n    \"\"\"Async embedding provider for single and batch text embedding.\"\"\"\n\n    @property\n    def provider_name(self) -> str: ...\n\n    @property\n    def model(self) -> str: ...\n\n    async def embed(self, text: str) -> list[float]:\n        \"\"\"Generate an embedding vector for a single text.\n\n        The returned vector size is determined by the provider and model\n        configuration. Callers should not assume a specific dimensionality\n        — the system-wide ``VECTOR_DIM`` constant and the pgvector column\n        definition enforce consistency at the storage layer.\n        \"\"\"\n        ...\n\n    async def embed_batch(self, texts: list[str]) -> list[list[float]]:\n        \"\"\"Generate embedding vectors for multiple texts in one call.\n\n        Same dimensionality contract as :meth:`embed`.\n        \"\"\"\n        ...\n\n\n@runtime_checkable\nclass InstructionAwareEmbedder(Protocol):\n    \"\"\"Optional extension for models with asymmetric query/document encoding.\n\n    Instruction-aware embedders (Qwen3-Embedding, e5-instruct, KaLM-Gemma3,\n    …) train the query-side encoder to expect a task-description prefix\n    that documents do not receive. A provider conforming to this protocol\n    must:\n\n    * Apply the prefix on :meth:`embed_query` only — never on the\n      document path (:meth:`EmbeddingProvider.embed`).\n    * Resolve *instruction* in this order: per-call arg → constructor\n      default → no prefix (degenerates to :meth:`embed`).\n\n    Symmetric providers (``Fake``, ``Local``, ``Vertex``,\n    OpenAI ``text-embedding-3-small``, ``bge-m3``, ``gte-en-v1.5``) do\n    **not** implement this protocol. The query path\n    (:func:`common.embedding._service.get_query_embedding`) checks\n    ``isinstance(provider, InstructionAwareEmbedder)`` (or, equivalently,\n    ``hasattr(provider, \"embed_query\")``) and falls back to\n    :meth:`EmbeddingProvider.embed` when absent.\n    \"\"\"\n\n    async def embed_query(\n        self, text: str, instruction: str | None = None\n    ) -> list[float]:\n        \"\"\"Generate an embedding vector for a search-side query.\"\"\"\n        ...","lineStart":1,"lineEnd":84,"totalLines":84,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/protocols.py","time":{"start":1780728827524,"end":1780728827539}},"metadata":{"openai":{"itemId":"fc_0f3d86b8e8edc3b9016a23c3fb74888191b558fe870ff64765"}},"id":"prt_e9bb58e810014Z5FGkDD8tN2ZW","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1"}}
{"type":"tool_use","timestamp":1780728827542,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_oI6cvJumBosUvOZKWMmZbs9Q","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"LLM-powered memory enrichment service — moved from\n2: ``core_api.services.memory_enrichment`` (CAURA-595).\n3: \n4: Public surface:\n5: \n6: * :func:`enrich_memory` — async entrypoint with 3-tier fallback.\n7: * :func:`fake_enrich` — keyword-heuristic fallback used both as the\n8:   ``\"fake\"`` provider and as the last-resort safety net.\n9: \n10: Provider resolution mirrors the embedding service: tenant config first,\n11: ``ENTITY_EXTRACTION_PROVIDER`` env var fallback. The service never\n12: raises — every error path lands on the heuristic fallback so the write\n13: pipeline can always continue.\n14: \"\"\"\n15: \n16: from __future__ import annotations\n17: \n18: import logging\n19: import os\n20: import time\n21: from datetime import UTC, date, datetime\n22: \n23: from dateutil import parser as dateutil_parser\n24: from dateutil.parser import ParserError\n25: \n26: from common.enrichment._prompts import ENRICHMENT_PROMPT\n27: from common.enrichment.constants import (\n28:     DEFAULT_MEMORY_TYPE,\n29:     MEMORY_STATUSES,\n30:     MEMORY_TYPES,\n31:     SERVER_RESERVED_MEMORY_TYPES,\n32:     MemoryType,\n33: )\n34: from common.enrichment.schema import EnrichmentResult\n35: from common.llm.protocols import LLMProvider\n36: from common.llm.retry import call_with_fallback\n37: from common.provider_names import ProviderName\n38: \n39: logger = logging.getLogger(__name__)\n40: \n41: \n42: def _parse_temporal(val: str) -> datetime | None:\n43:     \"\"\"Parse a temporal string to UTC datetime, returning None on failure.\"\"\"\n44:     try:\n45:         dt = dateutil_parser.parse(val, fuzzy=False)\n46:         if dt.tzinfo is None:\n47:             dt = dt.replace(tzinfo=UTC)\n48:         else:\n49:             dt = dt.astimezone(UTC)\n50:         # Sanity check: not before 1970, not after 2100\n51:         if dt.year < 1970 or dt.year > 2100:\n52:             logger.warning(\"Temporal value out of range: %s\", val)\n53:             return None\n54:         return dt\n55:     except (ValueError, OverflowError, ParserError):\n56:         logger.warning(\"Failed to parse temporal value: %s\", val)\n57:         return None\n58: \n59: \n60: def _validate_enrichment(raw: dict, llm_ms: int) -> EnrichmentResult:\n61:     \"\"\"Validate and sanitize raw LLM enrichment output.\"\"\"\n62:     # CAURA-651: defense-in-depth against an LLM provider returning a\n63:     # JSON list (or any non-dict shape) when the schema asks for an\n64:     # object. Vertex / Gemini / OpenAI all raise their own\n65:     # ``*ResponseShapeError(ValueError)`` at the JSON parse boundary;\n66:     # this guard is the catch-all in case a future provider misses\n67:     # that pattern. ``ValueError`` rather than ``TypeError`` because\n68:     # this is bad data from an external system, not a programmer's\n69:     # type-mismatch bug, and it stays consistent with the\n70:     # ``ResponseShapeError(ValueError)`` hierarchy so a single\n71:     # ``except ValueError`` catches both layers.\n72:     if not isinstance(raw, dict):\n73:         raise ValueError(\n74:             f\"enrichment LLM returned a JSON {type(raw).__name__} where a dict was expected\"\n75:         )\n76:     # Backstop for CAURA-699: the prompt no longer offers the server-reserved\n77:     # types (insight/outcome/rule), so a reserved value here means a\n78:     # hallucinated/out-of-vocab classification — treat it like any other\n79:     # invalid type and fall to the default. Reserved types are authored only\n80:     # by internal flows that set ``memory_type`` explicitly and bypass this\n81:     # classifier path entirely.\n82:     mt = raw.get(\"memory_type\")\n83:     if mt not in MEMORY_TYPES or mt in SERVER_RESERVED_MEMORY_TYPES:\n84:         raw[\"memory_type\"] = DEFAULT_MEMORY_TYPE\n85:     if raw.get(\"status\") not in MEMORY_STATUSES:\n86:         raw[\"status\"] = \"active\"\n87:     # Guard against the LLM emitting either a JSON null\n88:     # (``raw.get(\"weight\", 0.7)`` returns ``None``, not the default —\n89:     # the key exists, the value is ``None``) or a non-numeric string\n90:     # (``\"high\"``, ``\"medium\"``). Either crashes the entire\n91:     # enrichment, which then silently falls through to ``fake_enrich``\n92:     # via the outer caller's exception handling.\n93:     #\n94:     # Explicit ``is None`` test rather than ``or 0.7`` — ``or`` would\n95:     # promote a legitimate ``weight=0.0`` (zero-salience content) to\n96:     # the default, since ``0.0`` is falsy in Python.\n97:     weight_raw = raw.get(\"weight\")\n98:     try:\n99:         weight = float(weight_raw if weight_raw is not None else 0.7)\n100:     except (TypeError, ValueError):\n101:         weight = 0.7\n102:     raw[\"weight\"] = max(0.0, min(1.0, weight))\n103:     raw[\"title\"] = str(raw.get(\"title\", \"\"))[:80]\n104:     parsed_ts: dict[str, datetime | None] = {}\n105:     for ts_field in (\"ts_valid_start\", \"ts_valid_end\"):\n106:         val = raw.get(ts_field)\n107:         if val and isinstance(val, str):\n108:             parsed_ts[ts_field] = _parse_temporal(val)\n109:         else:\n110:             parsed_ts[ts_field] = None\n111:         raw[ts_field] = parsed_ts[ts_field].isoformat() if parsed_ts[ts_field] else None\n112:     # Ensure end > start; drop invalid end\n113:     start, end = parsed_ts[\"ts_valid_start\"], parsed_ts[\"ts_valid_end\"]\n114:     if start and end and end <= start:\n115:         logger.warning(\n116:             \"ts_valid_end (%s) <= ts_valid_start (%s), dropping end\",\n117:             raw[\"ts_valid_end\"],\n118:             raw[\"ts_valid_start\"],\n119:         )\n120:         raw[\"ts_valid_end\"] = None\n121: \n122:     # Episodes never expire: the event is a permanent historical fact.\n123:     # Safety net in case the LLM ignores the prompt rule.\n124:     if raw.get(\"memory_type\") == \"episode\" and raw.get(\"ts_valid_end\") is not None:\n125:         logger.warning(\n126:             \"Stripping ts_valid_end=%s from episode memory (episodes don't expire)\",\n127:             raw[\"ts_valid_end\"],\n128:         )\n129:         raw[\"ts_valid_end\"] = None\n130: \n131:     hint = raw.get(\"retrieval_hint\")\n132:     if isinstance(hint, str):\n133:         raw[\"retrieval_hint\"] = hint.strip()[:200]\n134:     else:\n135:         raw[\"retrieval_hint\"] = \"\"\n136: \n137:     facts_raw = raw.get(\"atomic_facts\")\n138:     cleaned_facts: list[dict] = []\n139:     if isinstance(facts_raw, list):\n140:         for f in facts_raw:\n141:             if not isinstance(f, dict):\n142:                 continue\n143:             fc = f.get(\"content\")\n144:             if not isinstance(fc, str) or not fc.strip():\n145:                 continue\n146:             st = f.get(\"suggested_type\")\n147:             if (\n148:                 not isinstance(st, str)\n149:                 or st not in MEMORY_TYPES\n150:                 or st in SERVER_RESERVED_MEMORY_TYPES\n151:             ):\n152:                 st = DEFAULT_MEMORY_TYPE\n153:             fh = f.get(\"retrieval_hint\")\n154:             if not isinstance(fh, str):\n155:                 fh = \"\"\n156:             cleaned_facts.append(\n157:                 {\n158:                     \"content\": fc.strip()[:10000],\n159:                     \"suggested_type\": st,\n160:                     \"retrieval_hint\": fh.strip()[:200],\n161:                 }\n162:             )\n163:     # Any fact the enricher calls out separately deserves its own child\n164:     # memory — even just one — because by definition the LLM considered\n165:     # it distinct enough from the main title/summary to name explicitly.\n166:     raw[\"atomic_facts\"] = cleaned_facts if cleaned_facts else None\n167:     raw[\"contains_pii\"] = bool(raw.get(\"contains_pii\", False))\n168:     raw[\"pii_types\"] = raw.get(\"pii_types\") or []\n169:     raw[\"llm_ms\"] = llm_ms\n170:     return EnrichmentResult(**raw)\n171: \n172: \n173: def fake_enrich(content: str) -> EnrichmentResult:\n174:     \"\"\"Keyword heuristic fallback used by the ``\"fake\"`` provider and\n175:     as the last-resort safety net when all real providers fail.\n176: \n177:     ``llm_ms=0`` is hardcoded below — no LLM call was made, so 0 is\n178:     the semantically correct value AND the reliable proxy the worker's\n179:     ``_build_patch`` uses to distinguish heuristic results from real\n180:     LLM results (it gates several \"clear stale storage value\" code\n181:     paths on ``result.llm_ms > 0``). The previous wall-clock-derived\n182:     value would occasionally land on ``llm_ms=1`` on a loaded VM and\n183:     cause heuristic results to masquerade as real LLM output.\n184:     \"\"\"\n185:     lower = content.lower()\n186:     st = \"active\"\n187:     if any(\n188:         kw in lower for kw in (\"decided\", \"chose\", \"going with\", \"approved\", \"we will\")\n189:     ):\n190:         mt, w = \"decision\", 0.85\n191:     elif any(\n192:         kw in lower for kw in (\"prefers\", \"likes\", \"always wants\", \"rather\", \"favorite\")\n193:     ):\n194:         mt, w = \"preference\", 0.70\n195:     elif any(\n196:         kw in lower\n197:         for kw in (\n198:             \"always notify\",\n199:             \"always do\",\n200:             \"never do\",\n201:             \"never use\",\n202:             \"never store\",\n203:             \"never commit\",\n204:             \"do not ever\",\n205:             \"must always\",\n206:             \"should always\",\n207:             \"policy:\",\n208:             \"guideline:\",\n209:             \"rule:\",\n210:             \"whenever you \",\n211:             \"whenever a \",\n212:             \"constraint:\",\n213:             \"requirement:\",\n214:             \"mandatory\",\n215:         )\n216:     ):\n217:         mt, w = \"rule\", 0.85\n218:     elif any(\n219:         kw in lower\n220:         for kw in (\"deployed\", \"happened\", \"launched\", \"met with\", \"incident\")\n221:     ):\n222:         mt, w = \"episode\", 0.65\n223:     elif any(kw in lower for kw in (\"task\", \"todo\", \"assigned\", \"need to\", \"must\")):\n224:         mt, w, st = \"task\", 0.70, \"pending\"\n225:     elif any(kw in lower for kw in (\"plan\", \"steps\", \"roadmap\", \"strategy\")):\n226:         mt, w, st = \"plan\", 0.75, \"pending\"\n227:     elif any(kw in lower for kw in (\"commit\", \"promise\", \"guarantee\", \"agreed to\")):\n228:         mt, w, st = \"commitment\", 0.80, \"pending\"\n229:     elif any(kw in lower for kw in (\"cancelled\", \"abandoned\", \"stopped\", \"withdrew\")):\n230:         mt, w = \"cancellation\", 0.65\n231:     elif any(kw in lower for kw in (\"result\", \"outcome\", \"achieved\", \"completed\")):\n232:         mt, w, st = \"outcome\", 0.70, \"confirmed\"\n233:     elif any(kw in lower for kw in (\"intend\", \"aim\", \"goal\", \"want to\")):\n234:         mt, w = \"intention\", 0.65\n235:     elif any(kw in lower for kw in (\"did\", \"executed\", \"performed\", \"ran\")):\n236:         mt, w = \"action\", 0.65\n237:     else:\n238:         mt, w = \"fact\", 0.70\n239: \n240:     words = content.split()\n241:     title = \" \".join(words[:10]) + (\"...\" if len(words) > 10 else \"\")\n242: \n243:     return EnrichmentResult(\n244:         memory_type=mt,\n245:         weight=w,\n246:         title=title,\n247:         summary=content[:200],\n248:         tags=[],\n249:         status=st,\n250:         llm_ms=0,  # see docstring — heuristic path, no LLM call\n251:     )\n252: \n253: \n254: def _demote_reserved_enrichment(result: EnrichmentResult) -> EnrichmentResult:\n255:     \"\"\"CAURA-699 — the auto-classifier must never mint a server-reserved type.\n256: \n257:     ``insight`` / ``outcome`` / ``rule`` reach storage only via internal flows\n258:     (insights_service / evolve_service) that set ``memory_type`` explicitly.\n259:     The LLM path is already guarded in ``_validate_enrichment`` (the prompt\n260:     omits these types and any hallucinated value is demoted); this is the\n\n(Showing lines 1-260 of 334. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"LLM-powered memory enrichment service — moved from\n``core_api.services.memory_enrichment`` (CAURA-595).\n\nPublic surface:\n\n* :func:`enrich_memory` — async entrypoint with 3-tier fallback.\n* :func:`fake_enrich` — keyword-heuristic fallback used both as the\n  ``\"fake\"`` provider and as the last-resort safety net.\n\nProvider resolution mirrors the embedding service: tenant config first,\n``ENTITY_EXTRACTION_PROVIDER`` env var fallback. The service never\nraises — every error path lands on the heuristic fallback so the write\npipeline can always continue.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport os\nimport time","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py","text":"\"\"\"LLM-powered memory enrichment service — moved from\n``core_api.services.memory_enrichment`` (CAURA-595).\n\nPublic surface:\n\n* :func:`enrich_memory` — async entrypoint with 3-tier fallback.\n* :func:`fake_enrich` — keyword-heuristic fallback used both as the\n  ``\"fake\"`` provider and as the last-resort safety net.\n\nProvider resolution mirrors the embedding service: tenant config first,\n``ENTITY_EXTRACTION_PROVIDER`` env var fallback. The service never\nraises — every error path lands on the heuristic fallback so the write\npipeline can always continue.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport os\nimport time\nfrom datetime import UTC, date, datetime\n\nfrom dateutil import parser as dateutil_parser\nfrom dateutil.parser import ParserError\n\nfrom common.enrichment._prompts import ENRICHMENT_PROMPT\nfrom common.enrichment.constants import (\n    DEFAULT_MEMORY_TYPE,\n    MEMORY_STATUSES,\n    MEMORY_TYPES,\n    SERVER_RESERVED_MEMORY_TYPES,\n    MemoryType,\n)\nfrom common.enrichment.schema import EnrichmentResult\nfrom common.llm.protocols import LLMProvider\nfrom common.llm.retry import call_with_fallback\nfrom common.provider_names import ProviderName\n\nlogger = logging.getLogger(__name__)\n\n\ndef _parse_temporal(val: str) -> datetime | None:\n    \"\"\"Parse a temporal string to UTC datetime, returning None on failure.\"\"\"\n    try:\n        dt = dateutil_parser.parse(val, fuzzy=False)\n        if dt.tzinfo is None:\n            dt = dt.replace(tzinfo=UTC)\n        else:\n            dt = dt.astimezone(UTC)\n        # Sanity check: not before 1970, not after 2100\n        if dt.year < 1970 or dt.year > 2100:\n            logger.warning(\"Temporal value out of range: %s\", val)\n            return None\n        return dt\n    except (ValueError, OverflowError, ParserError):\n        logger.warning(\"Failed to parse temporal value: %s\", val)\n        return None\n\n\ndef _validate_enrichment(raw: dict, llm_ms: int) -> EnrichmentResult:\n    \"\"\"Validate and sanitize raw LLM enrichment output.\"\"\"\n    # CAURA-651: defense-in-depth against an LLM provider returning a\n    # JSON list (or any non-dict shape) when the schema asks for an\n    # object. Vertex / Gemini / OpenAI all raise their own\n    # ``*ResponseShapeError(ValueError)`` at the JSON parse boundary;\n    # this guard is the catch-all in case a future provider misses\n    # that pattern. ``ValueError`` rather than ``TypeError`` because\n    # this is bad data from an external system, not a programmer's\n    # type-mismatch bug, and it stays consistent with the\n    # ``ResponseShapeError(ValueError)`` hierarchy so a single\n    # ``except ValueError`` catches both layers.\n    if not isinstance(raw, dict):\n        raise ValueError(\n            f\"enrichment LLM returned a JSON {type(raw).__name__} where a dict was expected\"\n        )\n    # Backstop for CAURA-699: the prompt no longer offers the server-reserved\n    # types (insight/outcome/rule), so a reserved value here means a\n    # hallucinated/out-of-vocab classification — treat it like any other\n    # invalid type and fall to the default. Reserved types are authored only\n    # by internal flows that set ``memory_type`` explicitly and bypass this\n    # classifier path entirely.\n    mt = raw.get(\"memory_type\")\n    if mt not in MEMORY_TYPES or mt in SERVER_RESERVED_MEMORY_TYPES:\n        raw[\"memory_type\"] = DEFAULT_MEMORY_TYPE\n    if raw.get(\"status\") not in MEMORY_STATUSES:\n        raw[\"status\"] = \"active\"\n    # Guard against the LLM emitting either a JSON null\n    # (``raw.get(\"weight\", 0.7)`` returns ``None``, not the default —\n    # the key exists, the value is ``None``) or a non-numeric string\n    # (``\"high\"``, ``\"medium\"``). Either crashes the entire\n    # enrichment, which then silently falls through to ``fake_enrich``\n    # via the outer caller's exception handling.\n    #\n    # Explicit ``is None`` test rather than ``or 0.7`` — ``or`` would\n    # promote a legitimate ``weight=0.0`` (zero-salience content) to\n    # the default, since ``0.0`` is falsy in Python.\n    weight_raw = raw.get(\"weight\")\n    try:\n        weight = float(weight_raw if weight_raw is not None else 0.7)\n    except (TypeError, ValueError):\n        weight = 0.7\n    raw[\"weight\"] = max(0.0, min(1.0, weight))\n    raw[\"title\"] = str(raw.get(\"title\", \"\"))[:80]\n    parsed_ts: dict[str, datetime | None] = {}\n    for ts_field in (\"ts_valid_start\", \"ts_valid_end\"):\n        val = raw.get(ts_field)\n        if val and isinstance(val, str):\n            parsed_ts[ts_field] = _parse_temporal(val)\n        else:\n            parsed_ts[ts_field] = None\n        raw[ts_field] = parsed_ts[ts_field].isoformat() if parsed_ts[ts_field] else None\n    # Ensure end > start; drop invalid end\n    start, end = parsed_ts[\"ts_valid_start\"], parsed_ts[\"ts_valid_end\"]\n    if start and end and end <= start:\n        logger.warning(\n            \"ts_valid_end (%s) <= ts_valid_start (%s), dropping end\",\n            raw[\"ts_valid_end\"],\n            raw[\"ts_valid_start\"],\n        )\n        raw[\"ts_valid_end\"] = None\n\n    # Episodes never expire: the event is a permanent historical fact.\n    # Safety net in case the LLM ignores the prompt rule.\n    if raw.get(\"memory_type\") == \"episode\" and raw.get(\"ts_valid_end\") is not None:\n        logger.warning(\n            \"Stripping ts_valid_end=%s from episode memory (episodes don't expire)\",\n            raw[\"ts_valid_end\"],\n        )\n        raw[\"ts_valid_end\"] = None\n\n    hint = raw.get(\"retrieval_hint\")\n    if isinstance(hint, str):\n        raw[\"retrieval_hint\"] = hint.strip()[:200]\n    else:\n        raw[\"retrieval_hint\"] = \"\"\n\n    facts_raw = raw.get(\"atomic_facts\")\n    cleaned_facts: list[dict] = []\n    if isinstance(facts_raw, list):\n        for f in facts_raw:\n            if not isinstance(f, dict):\n                continue\n            fc = f.get(\"content\")\n            if not isinstance(fc, str) or not fc.strip():\n                continue\n            st = f.get(\"suggested_type\")\n            if (\n                not isinstance(st, str)\n                or st not in MEMORY_TYPES\n                or st in SERVER_RESERVED_MEMORY_TYPES\n            ):\n                st = DEFAULT_MEMORY_TYPE\n            fh = f.get(\"retrieval_hint\")\n            if not isinstance(fh, str):\n                fh = \"\"\n            cleaned_facts.append(\n                {\n                    \"content\": fc.strip()[:10000],\n                    \"suggested_type\": st,\n                    \"retrieval_hint\": fh.strip()[:200],\n                }\n            )\n    # Any fact the enricher calls out separately deserves its own child\n    # memory — even just one — because by definition the LLM considered\n    # it distinct enough from the main title/summary to name explicitly.\n    raw[\"atomic_facts\"] = cleaned_facts if cleaned_facts else None\n    raw[\"contains_pii\"] = bool(raw.get(\"contains_pii\", False))\n    raw[\"pii_types\"] = raw.get(\"pii_types\") or []\n    raw[\"llm_ms\"] = llm_ms\n    return EnrichmentResult(**raw)\n\n\ndef fake_enrich(content: str) -> EnrichmentResult:\n    \"\"\"Keyword heuristic fallback used by the ``\"fake\"`` provider and\n    as the last-resort safety net when all real providers fail.\n\n    ``llm_ms=0`` is hardcoded below — no LLM call was made, so 0 is\n    the semantically correct value AND the reliable proxy the worker's\n    ``_build_patch`` uses to distinguish heuristic results from real\n    LLM results (it gates several \"clear stale storage value\" code\n    paths on ``result.llm_ms > 0``). The previous wall-clock-derived\n    value would occasionally land on ``llm_ms=1`` on a loaded VM and\n    cause heuristic results to masquerade as real LLM output.\n    \"\"\"\n    lower = content.lower()\n    st = \"active\"\n    if any(\n        kw in lower for kw in (\"decided\", \"chose\", \"going with\", \"approved\", \"we will\")\n    ):\n        mt, w = \"decision\", 0.85\n    elif any(\n        kw in lower for kw in (\"prefers\", \"likes\", \"always wants\", \"rather\", \"favorite\")\n    ):\n        mt, w = \"preference\", 0.70\n    elif any(\n        kw in lower\n        for kw in (\n            \"always notify\",\n            \"always do\",\n            \"never do\",\n            \"never use\",\n            \"never store\",\n            \"never commit\",\n            \"do not ever\",\n            \"must always\",\n            \"should always\",\n            \"policy:\",\n            \"guideline:\",\n            \"rule:\",\n            \"whenever you \",\n            \"whenever a \",\n            \"constraint:\",\n            \"requirement:\",\n            \"mandatory\",\n        )\n    ):\n        mt, w = \"rule\", 0.85\n    elif any(\n        kw in lower\n        for kw in (\"deployed\", \"happened\", \"launched\", \"met with\", \"incident\")\n    ):\n        mt, w = \"episode\", 0.65\n    elif any(kw in lower for kw in (\"task\", \"todo\", \"assigned\", \"need to\", \"must\")):\n        mt, w, st = \"task\", 0.70, \"pending\"\n    elif any(kw in lower for kw in (\"plan\", \"steps\", \"roadmap\", \"strategy\")):\n        mt, w, st = \"plan\", 0.75, \"pending\"\n    elif any(kw in lower for kw in (\"commit\", \"promise\", \"guarantee\", \"agreed to\")):\n        mt, w, st = \"commitment\", 0.80, \"pending\"\n    elif any(kw in lower for kw in (\"cancelled\", \"abandoned\", \"stopped\", \"withdrew\")):\n        mt, w = \"cancellation\", 0.65\n    elif any(kw in lower for kw in (\"result\", \"outcome\", \"achieved\", \"completed\")):\n        mt, w, st = \"outcome\", 0.70, \"confirmed\"\n    elif any(kw in lower for kw in (\"intend\", \"aim\", \"goal\", \"want to\")):\n        mt, w = \"intention\", 0.65\n    elif any(kw in lower for kw in (\"did\", \"executed\", \"performed\", \"ran\")):\n        mt, w = \"action\", 0.65\n    else:\n        mt, w = \"fact\", 0.70\n\n    words = content.split()\n    title = \" \".join(words[:10]) + (\"...\" if len(words) > 10 else \"\")\n\n    return EnrichmentResult(\n        memory_type=mt,\n        weight=w,\n        title=title,\n        summary=content[:200],\n        tags=[],\n        status=st,\n        llm_ms=0,  # see docstring — heuristic path, no LLM call\n    )\n\n\ndef _demote_reserved_enrichment(result: EnrichmentResult) -> EnrichmentResult:\n    \"\"\"CAURA-699 — the auto-classifier must never mint a server-reserved type.\n\n    ``insight`` / ``outcome`` / ``rule`` reach storage only via internal flows\n    (insights_service / evolve_service) that set ``memory_type`` explicitly.\n    The LLM path is already guarded in ``_validate_enrichment`` (the prompt\n    omits these types and any hallucinated value is demoted); this is the","lineStart":1,"lineEnd":260,"totalLines":334,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py","time":{"start":1780728827526,"end":1780728827540}},"metadata":{"openai":{"itemId":"fc_0f3d86b8e8edc3b9016a23c3fb748c8191b24328928996ef1c"}},"id":"prt_e9bb58e85001XersqwEJjkVBkh","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1"}}
{"type":"tool_use","timestamp":1780728827542,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_won3gUGYZ8nMPxDuQG3hqLbh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py</path>\n<type>file</type>\n<content>\n1: import uuid\n2: from datetime import datetime\n3: \n4: from pgvector.sqlalchemy import Vector\n5: from sqlalchemy import DateTime, Float, ForeignKey, Index, Integer, Text, func, text\n6: from sqlalchemy.dialects.postgresql import JSONB, TSVECTOR, UUID as PG_UUID\n7: from sqlalchemy.orm import Mapped, mapped_column\n8: \n9: from common.constants import VECTOR_DIM\n10: from common.models.base import Base\n11: \n12: \n13: class Memory(Base):\n14:     __tablename__ = \"memories\"\n15: \n16:     id: Mapped[uuid.UUID] = mapped_column(\n17:         primary_key=True, server_default=text(\"gen_random_uuid()\")\n18:     )\n19:     tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n20:     fleet_id: Mapped[str | None] = mapped_column(Text)\n21:     agent_id: Mapped[str] = mapped_column(Text, nullable=False)\n22:     memory_type: Mapped[str] = mapped_column(Text, nullable=False)\n23:     content: Mapped[str] = mapped_column(Text, nullable=False)\n24:     embedding = mapped_column(Vector(VECTOR_DIM))\n25:     weight: Mapped[float] = mapped_column(Float, server_default=text(\"0.5\"))\n26:     source_uri: Mapped[str | None] = mapped_column(Text)\n27:     run_id: Mapped[str | None] = mapped_column(Text)\n28:     metadata_: Mapped[dict | None] = mapped_column(\"metadata\", JSONB)\n29:     created_at: Mapped[datetime] = mapped_column(\n30:         DateTime(timezone=True), server_default=text(\"now()\")\n31:     )\n32:     title: Mapped[str | None] = mapped_column(Text)\n33:     content_hash: Mapped[str | None] = mapped_column(Text)\n34:     # Per-attempt idempotency token (CAURA-602). Server-derived from\n35:     # ``X-Bulk-Attempt-Id + \":\" + index`` on the bulk path; NULL for\n36:     # single-write and pre-rollout rows. The partial unique index\n37:     # ``ix_memories_attempt_unique`` (migration 007) enforces uniqueness\n38:     # only when this is non-NULL, so legacy paths are unaffected.\n39:     client_request_id: Mapped[str | None] = mapped_column(Text)\n40:     expires_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n41:     deleted_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n42:     search_vector = mapped_column(TSVECTOR)\n43: \n44:     # RDF triple representation\n45:     subject_entity_id: Mapped[uuid.UUID | None] = mapped_column(\n46:         PG_UUID(as_uuid=True),\n47:         ForeignKey(\"entities.id\", ondelete=\"SET NULL\"),\n48:     )\n49:     predicate: Mapped[str | None] = mapped_column(Text)\n50:     object_value: Mapped[str | None] = mapped_column(Text)\n51: \n52:     # Temporal validity windows\n53:     ts_valid_start: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n54:     ts_valid_end: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n55: \n56:     # Status lifecycle\n57:     status: Mapped[str] = mapped_column(\n58:         Text, server_default=text(\"'active'\"), nullable=False\n59:     )\n60: \n61:     # Visibility scope\n62:     visibility: Mapped[str] = mapped_column(\n63:         Text,\n64:         server_default=text(\"'scope_team'\"),\n65:         nullable=False,\n66:     )\n67: \n68:     # Recall tracking (incremented on agent-facing retrievals only)\n69:     recall_count: Mapped[int] = mapped_column(\n70:         Integer, server_default=text(\"0\"), nullable=False\n71:     )\n72:     last_recalled_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n73: \n74:     # Crystallizer dedup tracking\n75:     last_dedup_checked_at: Mapped[datetime | None] = mapped_column(\n76:         DateTime(timezone=True)\n77:     )\n78: \n79:     # Contradiction tracking\n80:     supersedes_id: Mapped[uuid.UUID | None] = mapped_column(\n81:         PG_UUID(as_uuid=True),\n82:         ForeignKey(\"memories.id\", ondelete=\"SET NULL\"),\n83:     )\n84: \n85:     __table_args__ = (\n86:         Index(\"ix_memories_tenant_type\", \"tenant_id\", \"memory_type\"),\n87:         Index(\"ix_memories_tenant_agent\", \"tenant_id\", \"agent_id\"),\n88:         Index(\"ix_memories_content_hash\", \"tenant_id\", \"content_hash\"),\n89:         # Backs per-attempt bulk-write idempotency (CAURA-602). Created\n90:         # ``CONCURRENTLY`` in migration 007 with the same predicates;\n91:         # declared here so SQLAlchemy reflection / Alembic autogen\n92:         # round-trips match the live schema. ``COALESCE(fleet_id, '')``\n93:         # makes fleetless rows participate in the unique constraint —\n94:         # PostgreSQL treats NULLs as distinct by default, so without\n95:         # this two retries with ``fleet_id IS NULL`` would both insert.\n96:         Index(\n97:             \"ix_memories_attempt_unique\",\n98:             \"tenant_id\",\n99:             func.coalesce(text(\"fleet_id\"), \"\"),\n100:             \"client_request_id\",\n101:             unique=True,\n102:             postgresql_where=text(\n103:                 \"deleted_at IS NULL AND client_request_id IS NOT NULL\"\n104:             ),\n105:         ),\n106:         Index(\"ix_memories_valid_range\", \"ts_valid_start\", \"ts_valid_end\"),\n107:         Index(\"ix_memories_subject_entity\", \"subject_entity_id\"),\n108:         Index(\"ix_memories_recall_count\", \"recall_count\"),\n109:         Index(\"ix_memories_tenant_fleet\", \"tenant_id\", \"fleet_id\"),\n110:         # Backs the cursor-paginated list path (``list_by_filters`` +\n111:         # the ``memclaw_list`` MCP tool) which orders by\n112:         # ``(created_at DESC, id DESC)`` under ``tenant_id = ?`` and\n113:         # ``deleted_at IS NULL``. Partial WHERE keeps the index small\n114:         # since soft-deleted rows are never read on the hot path.\n115:         # Bare-column references (``created_at.desc()`` not\n116:         # ``text(\"created_at DESC\")``) so Alembic autogen can reflect\n117:         # and compare the index — matches ``analysis_report.py:38``.\n118:         Index(\n119:             \"ix_memories_tenant_created_active\",\n120:             \"tenant_id\",\n121:             created_at.desc(),\n122:             id.desc(),\n123:             postgresql_where=text(\"deleted_at IS NULL\"),\n124:         ),\n125:         # Backs the CAURA-656 purge-fanout discovery query\n126:         # (``list_tenants_with_purgeable_memories``). Every other\n127:         # partial index on this table is keyed on\n128:         # ``deleted_at IS NULL`` (active path); without this\n129:         # complement the soft-deleted-side discovery falls back to a\n130:         # full scan.\n131:         Index(\n132:             \"ix_memories_purgeable\",\n133:             \"tenant_id\",\n134:             postgresql_where=text(\"deleted_at IS NOT NULL\"),\n135:         ),\n136:     )\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"import uuid\nfrom datetime import datetime\n\nfrom pgvector.sqlalchemy import Vector\nfrom sqlalchemy import DateTime, Float, ForeignKey, Index, Integer, Text, func, text\nfrom sqlalchemy.dialects.postgresql import JSONB, TSVECTOR, UUID as PG_UUID\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.constants import VECTOR_DIM\nfrom common.models.base import Base\n\n\nclass Memory(Base):\n    __tablename__ = \"memories\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py","text":"import uuid\nfrom datetime import datetime\n\nfrom pgvector.sqlalchemy import Vector\nfrom sqlalchemy import DateTime, Float, ForeignKey, Index, Integer, Text, func, text\nfrom sqlalchemy.dialects.postgresql import JSONB, TSVECTOR, UUID as PG_UUID\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.constants import VECTOR_DIM\nfrom common.models.base import Base\n\n\nclass Memory(Base):\n    __tablename__ = \"memories\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)\n    agent_id: Mapped[str] = mapped_column(Text, nullable=False)\n    memory_type: Mapped[str] = mapped_column(Text, nullable=False)\n    content: Mapped[str] = mapped_column(Text, nullable=False)\n    embedding = mapped_column(Vector(VECTOR_DIM))\n    weight: Mapped[float] = mapped_column(Float, server_default=text(\"0.5\"))\n    source_uri: Mapped[str | None] = mapped_column(Text)\n    run_id: Mapped[str | None] = mapped_column(Text)\n    metadata_: Mapped[dict | None] = mapped_column(\"metadata\", JSONB)\n    created_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), server_default=text(\"now()\")\n    )\n    title: Mapped[str | None] = mapped_column(Text)\n    content_hash: Mapped[str | None] = mapped_column(Text)\n    # Per-attempt idempotency token (CAURA-602). Server-derived from\n    # ``X-Bulk-Attempt-Id + \":\" + index`` on the bulk path; NULL for\n    # single-write and pre-rollout rows. The partial unique index\n    # ``ix_memories_attempt_unique`` (migration 007) enforces uniqueness\n    # only when this is non-NULL, so legacy paths are unaffected.\n    client_request_id: Mapped[str | None] = mapped_column(Text)\n    expires_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    deleted_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    search_vector = mapped_column(TSVECTOR)\n\n    # RDF triple representation\n    subject_entity_id: Mapped[uuid.UUID | None] = mapped_column(\n        PG_UUID(as_uuid=True),\n        ForeignKey(\"entities.id\", ondelete=\"SET NULL\"),\n    )\n    predicate: Mapped[str | None] = mapped_column(Text)\n    object_value: Mapped[str | None] = mapped_column(Text)\n\n    # Temporal validity windows\n    ts_valid_start: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    ts_valid_end: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n\n    # Status lifecycle\n    status: Mapped[str] = mapped_column(\n        Text, server_default=text(\"'active'\"), nullable=False\n    )\n\n    # Visibility scope\n    visibility: Mapped[str] = mapped_column(\n        Text,\n        server_default=text(\"'scope_team'\"),\n        nullable=False,\n    )\n\n    # Recall tracking (incremented on agent-facing retrievals only)\n    recall_count: Mapped[int] = mapped_column(\n        Integer, server_default=text(\"0\"), nullable=False\n    )\n    last_recalled_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n\n    # Crystallizer dedup tracking\n    last_dedup_checked_at: Mapped[datetime | None] = mapped_column(\n        DateTime(timezone=True)\n    )\n\n    # Contradiction tracking\n    supersedes_id: Mapped[uuid.UUID | None] = mapped_column(\n        PG_UUID(as_uuid=True),\n        ForeignKey(\"memories.id\", ondelete=\"SET NULL\"),\n    )\n\n    __table_args__ = (\n        Index(\"ix_memories_tenant_type\", \"tenant_id\", \"memory_type\"),\n        Index(\"ix_memories_tenant_agent\", \"tenant_id\", \"agent_id\"),\n        Index(\"ix_memories_content_hash\", \"tenant_id\", \"content_hash\"),\n        # Backs per-attempt bulk-write idempotency (CAURA-602). Created\n        # ``CONCURRENTLY`` in migration 007 with the same predicates;\n        # declared here so SQLAlchemy reflection / Alembic autogen\n        # round-trips match the live schema. ``COALESCE(fleet_id, '')``\n        # makes fleetless rows participate in the unique constraint —\n        # PostgreSQL treats NULLs as distinct by default, so without\n        # this two retries with ``fleet_id IS NULL`` would both insert.\n        Index(\n            \"ix_memories_attempt_unique\",\n            \"tenant_id\",\n            func.coalesce(text(\"fleet_id\"), \"\"),\n            \"client_request_id\",\n            unique=True,\n            postgresql_where=text(\n                \"deleted_at IS NULL AND client_request_id IS NOT NULL\"\n            ),\n        ),\n        Index(\"ix_memories_valid_range\", \"ts_valid_start\", \"ts_valid_end\"),\n        Index(\"ix_memories_subject_entity\", \"subject_entity_id\"),\n        Index(\"ix_memories_recall_count\", \"recall_count\"),\n        Index(\"ix_memories_tenant_fleet\", \"tenant_id\", \"fleet_id\"),\n        # Backs the cursor-paginated list path (``list_by_filters`` +\n        # the ``memclaw_list`` MCP tool) which orders by\n        # ``(created_at DESC, id DESC)`` under ``tenant_id = ?`` and\n        # ``deleted_at IS NULL``. Partial WHERE keeps the index small\n        # since soft-deleted rows are never read on the hot path.\n        # Bare-column references (``created_at.desc()`` not\n        # ``text(\"created_at DESC\")``) so Alembic autogen can reflect\n        # and compare the index — matches ``analysis_report.py:38``.\n        Index(\n            \"ix_memories_tenant_created_active\",\n            \"tenant_id\",\n            created_at.desc(),\n            id.desc(),\n            postgresql_where=text(\"deleted_at IS NULL\"),\n        ),\n        # Backs the CAURA-656 purge-fanout discovery query\n        # (``list_tenants_with_purgeable_memories``). Every other\n        # partial index on this table is keyed on\n        # ``deleted_at IS NULL`` (active path); without this\n        # complement the soft-deleted-side discovery falls back to a\n        # full scan.\n        Index(\n            \"ix_memories_purgeable\",\n            \"tenant_id\",\n            postgresql_where=text(\"deleted_at IS NOT NULL\"),\n        ),\n    )","lineStart":1,"lineEnd":136,"totalLines":136,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py","time":{"start":1780728827528,"end":1780728827541}},"metadata":{"openai":{"itemId":"fc_0f3d86b8e8edc3b9016a23c3fb749481919e63a3d2e2c057a8"}},"id":"prt_e9bb58e87001DFy5XsgPw9qnD0","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1"}}
{"type":"tool_use","timestamp":1780728827545,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_u2VD1ElzX6JDpjyGrSSKJvzC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Async-embed and async-enrich event consumers.\n2: \n3: Subscribes to:\n4: \n5: * ``Topics.Memory.EMBED_REQUESTED`` (CAURA-594) — one\n6:   :class:`~common.events.memory_embed_request.MemoryEmbedRequest`,\n7:   resolves the embedding via the platform-tier provider, PATCHes it\n8:   back onto the memory row.\n9: * ``Topics.Memory.ENRICH_REQUESTED`` (CAURA-595) — one\n10:   :class:`~common.events.memory_enrich_request.MemoryEnrichRequest`,\n11:   reconstructs the tenant config from the payload, runs\n12:   :func:`common.enrichment.enrich_memory` (3-tier provider fallback),\n13:   and PATCHes the resulting fields back onto the memory row.\n14: \n15: Embed-request flow (existing):\n16: \n17: 1. Validate the envelope's payload as ``MemoryEmbedRequest``.\n18: 2. Cache lookup: if any other row in the tenant already has an\n19:    embedding for the same ``content_hash``, reuse it and skip the\n20:    provider call.\n21: 3. Otherwise call the platform-tier embedding provider via\n22:    :func:`common.embedding.get_platform_embedding`.\n23: 4. PATCH the embedding back onto the memory row via core-storage-api.\n24: \n25: Idempotency: at-least-once delivery from Pub/Sub means a redelivered\n26: event re-PATCHes the row with the (deterministic) same embedding.\n27: That's safe — the storage update is a write-after-write of the same\n28: column. ``content_hash`` cache lookup keeps the redelivery cost down\n29: to a single GET in the steady-state.\n30: \n31: Failure modes:\n32: * ``ValidationError`` on a bad payload → ack + drop (poison-message\n33:   guard; matches the platform-audit-api pattern). The DLQ provisioned\n34:   by the bootstrap script catches anything we miss.\n35: * ``get_platform_embedding() is None`` (PLATFORM_EMBEDDING_* not\n36:   configured) → log + ack-drop. The worker is platform-only by\n37:   design; without the singleton there's nothing it can do, and\n38:   raising would just hot-loop redeliveries.\n39: * Provider exception or storage PATCH failure → raise → nack →\n40:   Pub/Sub redelivers (subject to max-delivery-attempts → DLQ).\n41: \"\"\"\n42: \n43: from __future__ import annotations\n44: \n45: import logging\n46: from collections.abc import Callable\n47: from datetime import datetime\n48: from types import SimpleNamespace\n49: \n50: import httpx\n51: from pydantic import ValidationError\n52: \n53: from common.embedding import get_platform_embedding\n54: from common.enrichment import EnrichmentResult, enrich_memory\n55: from common.events.base import Event\n56: from common.events.factory import get_event_bus\n57: from common.events.memory_embed_request import MemoryEmbedRequest\n58: from common.events.memory_embedded_publisher import publish_memory_embedded\n59: from common.events.memory_enrich_request import MemoryEnrichRequest\n60: from common.events.memory_enriched_publisher import publish_memory_enriched\n61: from common.events.suppression_handlers import (\n62:     SuppressionStorageAdapter,\n63:     register_suppression_consumer,\n64: )\n65: from common.events.topics import Topics\n66: from core_worker.clients.storage_client import (\n67:     find_embedding_by_content_hash,\n68:     update_memory_embedding,\n69:     update_memory_enrichment,\n70:     upsert_tenant_suppression,\n71: )\n72: from core_worker.per_tenant_concurrency import per_tenant_storage_slot\n73: \n74: logger = logging.getLogger(__name__)\n75: \n76: # Zero-arg factory so the consumer doesn't have to plumb Settings on\n77: # every event. The storage_client module reads its own Settings on\n78: # first call (singleton). Tests inject a stub by overriding this\n79: # variable directly via ``configure``.\n80: StorageClientFactory = Callable[[], httpx.AsyncClient]\n81: \n82: _storage_client_factory: StorageClientFactory | None = None\n83: \n84: \n85: def configure(storage_client_factory: StorageClientFactory) -> None:\n86:     \"\"\"Bind the per-process state the consumer needs.\n87: \n88:     Called once at app startup before ``register_consumers`` /\n89:     ``bus.start()``. ``storage_client_factory`` is a zero-arg callable\n90:     returning the shared httpx client (so tests can inject a stub).\n91:     \"\"\"\n92:     global _storage_client_factory\n93:     _storage_client_factory = storage_client_factory\n94: \n95: \n96: async def handle_embed_request(event: Event) -> None:\n97:     \"\"\"Process a single embed-request event.\"\"\"\n98:     try:\n99:         request = MemoryEmbedRequest(**event.payload)\n100:     except ValidationError:\n101:         # Schema-drift / malformed payload. Log loudly with the\n102:         # ``dropped=True`` alert hook (matches platform-audit-api) and\n103:         # ack-drop so the subscription doesn't loop on a poison message.\n104:         logger.exception(\n105:             \"dropping malformed embed-request payload\",\n106:             extra={\n107:                 \"event_type\": event.event_type,\n108:                 \"event_id\": str(event.event_id),\n109:                 \"dropped\": True,\n110:             },\n111:         )\n112:         return\n113: \n114:     if _storage_client_factory is None:\n115:         # Startup ordering bug — configure() was never called. Drop with\n116:         # a loud log (raising would nack-loop at full Pub/Sub throughput\n117:         # against a permanently misconfigured pod).\n118:         logger.error(\n119:             \"dropping embed-request: consumer not configured\",\n120:             extra={\n121:                 \"event_id\": str(event.event_id),\n122:                 \"memory_id\": str(request.memory_id),\n123:                 \"dropped\": True,\n124:             },\n125:         )\n126:         return\n127: \n128:     provider = get_platform_embedding()\n129:     if provider is None:\n130:         logger.error(\n131:             \"dropping embed-request: PLATFORM_EMBEDDING_* unset, no platform embedding singleton configured\",\n132:             extra={\n133:                 \"event_id\": str(event.event_id),\n134:                 \"memory_id\": str(request.memory_id),\n135:                 \"dropped\": True,\n136:             },\n137:         )\n138:         return\n139: \n140:     storage = _storage_client_factory()\n141: \n142:     embedding: list[float] | None = None\n143: \n144:     # Step 1 — content-hash cache lookup. Saves one provider call on\n145:     # redeliveries and on legitimate within-tenant duplicates.\n146:     if request.content_hash:\n147:         embedding = await find_embedding_by_content_hash(\n148:             storage,\n149:             tenant_id=request.tenant_id,\n150:             content_hash=request.content_hash,\n151:         )\n152:         if embedding is not None:\n153:             logger.info(\n154:                 \"reusing cached embedding for content_hash\",\n155:                 extra={\n156:                     \"memory_id\": str(request.memory_id),\n157:                     \"tenant_id\": request.tenant_id,\n158:                 },\n159:             )\n160: \n161:     # Step 2 — provider call (skipped on cache hit).\n162:     if embedding is None:\n163:         embedding = await provider.embed(request.content)\n164: \n165:     # Step 3 — persist. Raises on non-2xx → nacks → redelivers.\n166:     # Per-tenant slot scoped to the PATCH roundtrip only, so a\n167:     # tenant-A storm can't park every storage-writer connection here\n168:     # while tenant B's lone PATCH queues behind. Provider call above\n169:     # stays unguarded — that's the expensive step and it doesn't\n170:     # touch the storage-writer pool.\n171:     async with per_tenant_storage_slot(request.tenant_id):\n172:         await update_memory_embedding(\n173:             storage,\n174:             memory_id=request.memory_id,\n175:             tenant_id=request.tenant_id,\n176:             embedding=embedding,\n177:         )\n178: \n179:     # Back-channel: announce successful embed so core-api can fire\n180:     # post-embed contradiction detection. Closes the documented\n181:     # ``handle_memory_enriched`` gap that silently dropped detection\n182:     # whenever enrichment landed before embedding (the only case under\n183:     # ``EMBED_ON_HOT_PATH=false``). Best-effort — a publish failure\n184:     # MUST NOT nack the upstream PATCH that already succeeded; the\n185:     # embedding is durable in storage either way.\n186:     try:\n187:         await publish_memory_embedded(\n188:             memory_id=request.memory_id,\n189:             tenant_id=request.tenant_id,\n190:             content=request.content,\n191:         )\n192:     except Exception:\n193:         logger.exception(\n194:             \"embedded back-channel publish failed; ack-continuing\",\n195:             extra={\n196:                 \"memory_id\": str(request.memory_id),\n197:                 \"tenant_id\": request.tenant_id,\n198:             },\n199:         )\n200: \n201:     logger.info(\n202:         \"embed-request processed\",\n203:         extra={\n204:             \"memory_id\": str(request.memory_id),\n205:             \"tenant_id\": request.tenant_id,\n206:             \"provider\": provider.provider_name,\n207:             \"model\": provider.model,\n208:         },\n209:     )\n210: \n211: \n212: # ---------------------------------------------------------------------------\n213: # Enrich-request consumer (CAURA-595)\n214: # ---------------------------------------------------------------------------\n215: \n216: \n217: # ORM column fields the worker writes directly. Stays in sync with the\n218: # corresponding ``Memory`` columns + the synchronous-path mapping in\n219: # ``core_api.services.memory_service``. Anything an ``EnrichmentResult``\n220: # field would write to but isn't here lands in ``metadata_patch`` below.\n221: _ENRICHMENT_ORM_FIELDS: frozenset[str] = frozenset(\n222:     {\n223:         \"memory_type\",\n224:         \"weight\",\n225:         \"title\",\n226:         \"status\",\n227:         \"ts_valid_start\",\n228:         \"ts_valid_end\",\n229:     }\n230: )\n231: \n232: # Enrichment fields that live in ``Memory.metadata`` JSONB. Synchronous\n233: # path (``memory_service.py``) writes them as ``metadata[\"summary\"]``,\n234: # ``metadata[\"tags\"]``, etc.; the worker mirrors that via the storage\n235: # layer's atomic ``metadata_patch`` JSONB merge.\n236: _ENRICHMENT_METADATA_FIELDS: frozenset[str] = frozenset(\n237:     {\n238:         \"summary\",\n239:         \"tags\",\n240:         \"contains_pii\",\n241:         \"pii_types\",\n242:         \"retrieval_hint\",\n243:         \"llm_ms\",\n244:     }\n245: )\n246: \n247: # ``EnrichmentResult`` fields the worker INTENTIONALLY does not route\n248: # to storage. Listed explicitly so the exhaustive-routing assert below\n249: # fails when a future field is added without a code site to handle it\n250: # — silent drops are the failure mode we're guarding against.\n251: #\n252: # ``atomic_facts``: the synchronous write path fans these out into\n253: # child memories; the async worker doesn't yet implement that — see\n254: # the ``logger.debug`` in ``handle_enrich_request`` that surfaces the\n255: # gap when an enrichment produces them.\n256: _ENRICHMENT_UNROUTED_FIELDS: frozenset[str] = frozenset({\"atomic_facts\"})\n257: \n258: # Metadata fields that ALWAYS overwrite (when not ``None`` and the\n259: # result came from a real LLM call — see the ``llm_ms > 0`` guard at\n260: # the call site) so a re-delivery / second-LLM-run can clear stale\n261: # state from an earlier write. JSONB ``||`` merge treats ``False`` /\n262: # ``\"\"`` / ``[]`` as ordinary values and overwrites keyed entries.\n263: #\n264: # * ``contains_pii`` / ``pii_types`` — non-deterministic LLM output;\n265: #   an earlier ``contains_pii=True`` must be clearable.\n266: # * ``retrieval_hint`` — the prompt explicitly instructs the LLM to\n267: #   return ``\"\"`` for content that's already query-aligned; without\n268: #   always-write a re-enrichment that drops the hint would leave\n269: #   metadata stale AND the embedding still prefix-augmented.\n270: # * ``tags`` — the prompt instructs the LLM to always populate 2-6\n271: #   tags. ``tags=[]`` from a real LLM run means \"no tags\" intentionally\n272: #   and must overwrite a prior non-empty list.\n273: # * ``summary`` — without the guard, a heuristic-fallback redelivery\n274: #   would write ``fake_enrich``'s ``summary=content[:200]`` over a\n275: #   prior quality LLM summary. The truncation is a non-empty string,\n276: #   so the ``value in (False, 0, \"\", [])`` skip-check below doesn't\n277: #   catch it. Pairing summary with the ``llm_ms > 0`` guard ensures\n278: #   only real-LLM summaries can overwrite (or clear, if the LLM\n279: #   returns ``\"\"``).\n280: _ENRICHMENT_ALWAYS_WRITE_METADATA: frozenset[str] = frozenset(\n281:     {\"contains_pii\", \"pii_types\", \"retrieval_hint\", \"summary\", \"tags\"}\n282: )\n283: \n284: # Defence-in-depth: a typo in the tuples above would silently drop in\n285: # the storage layer's ``hasattr(Memory, key)`` filter, *and* a future\n286: # ``EnrichmentResult`` field that no one wires to a routing tuple\n287: # would silently fall on the floor. Catch both at module import.\n288: _unrouted = (\n289:     set(EnrichmentResult.model_fields)\n290:     - _ENRICHMENT_ORM_FIELDS\n291:     - _ENRICHMENT_METADATA_FIELDS\n292:     - _ENRICHMENT_UNROUTED_FIELDS\n293: )\n294: # Raise rather than ``assert`` — ``python -O`` strips assertions, and\n295: # this guard's whole point is to surface routing-table drift on every\n296: # import in every environment. Matches\n297: # ``_assert_override_fields_match_schemas`` in ``memory_service.py``.\n298: if _unrouted:\n299:     raise RuntimeError(\n300:         f\"EnrichmentResult fields not routed to storage by handle_enrich_request: \"\n301:         f\"{sorted(_unrouted)} — add to one of _ENRICHMENT_ORM_FIELDS / \"\n302:         f\"_ENRICHMENT_METADATA_FIELDS / _ENRICHMENT_UNROUTED_FIELDS\"\n303:     )\n304: del _unrouted\n305: \n306: \n307: def _build_tenant_config(request: MemoryEnrichRequest) -> SimpleNamespace | None:\n308:     \"\"\"Reconstruct a duck-typed tenant_config from the event payload.\n309: \n310:     ``common.enrichment.service.enrich_memory`` only reads attributes\n311:     off ``tenant_config``; a ``SimpleNamespace`` matching that surface is\n312:     enough — no need to import ``ResolvedConfig``.\n313: \n314:     Returns ``None`` only when the payload genuinely carries no\n315:     tenant-specific config — neither a provider preference nor any API\n316:     keys. The early-return on ``enrichment_provider is None`` alone\n317:     would silently discard a tenant's keys, making the async path\n318:     behave differently from the sync path: sync sees\n319:     ``provider=None`` and defaults to ``\"openai\"`` while still using\n320:     the tenant's ``openai_api_key``; async would fall through to the\n321:     platform-tier provider or the heuristic. The check below mirrors\n322:     sync semantics — if any credential is present we build the\n323:     namespace with ``enrichment_provider=None`` and let\n324:     :func:`enrich_memory` apply its ``or ProviderName.OPENAI``\n325:     default.\n326:     \"\"\"\n327:     has_any_credentials = any(\n328:         (\n329:             request.openai_api_key,\n330:             request.anthropic_api_key,\n331:             request.openrouter_api_key,\n332:             request.gemini_api_key,\n333:         )\n334:     )\n335:     if request.enrichment_provider is None and not has_any_credentials:\n336:         return None\n337: \n338:     fb_provider = request.fallback_provider\n339:     fb_model = request.fallback_model\n340: \n341:     def resolve_fallback() -> tuple[str | None, str | None]:\n342:         return fb_provider, fb_model\n343: \n344:     return SimpleNamespace(\n345:         enrichment_provider=request.enrichment_provider,\n346:         enrichment_model=request.enrichment_model,\n347:         openai_api_key=request.openai_api_key,\n348:         anthropic_api_key=request.anthropic_api_key,\n349:         openrouter_api_key=request.openrouter_api_key,\n350:         gemini_api_key=request.gemini_api_key,\n351:         # Synthesised callable matches the\n352:         # ``ResolvedConfig.resolve_fallback()`` shape ``call_with_fallback``\n353:         # expects. The publisher already pre-resolved the tuple at\n354:         # publish time so the worker doesn't run the policy itself.\n355:         resolve_fallback=resolve_fallback,\n356:     )\n357: \n358: \n359: def _build_patch(\n360:     result: EnrichmentResult,\n\n(Showing lines 1-360 of 625. Use offset=361 to continue.)\n</content>","metadata":{"preview":"\"\"\"Async-embed and async-enrich event consumers.\n\nSubscribes to:\n\n* ``Topics.Memory.EMBED_REQUESTED`` (CAURA-594) — one\n  :class:`~common.events.memory_embed_request.MemoryEmbedRequest`,\n  resolves the embedding via the platform-tier provider, PATCHes it\n  back onto the memory row.\n* ``Topics.Memory.ENRICH_REQUESTED`` (CAURA-595) — one\n  :class:`~common.events.memory_enrich_request.MemoryEnrichRequest`,\n  reconstructs the tenant config from the payload, runs\n  :func:`common.enrichment.enrich_memory` (3-tier provider fallback),\n  and PATCHes the resulting fields back onto the memory row.\n\nEmbed-request flow (existing):\n\n1. Validate the envelope's payload as ``MemoryEmbedRequest``.\n2. Cache lookup: if any other row in the tenant already has an\n   embedding for the same ``content_hash``, reuse it and skip the\n   provider call.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py","text":"\"\"\"Async-embed and async-enrich event consumers.\n\nSubscribes to:\n\n* ``Topics.Memory.EMBED_REQUESTED`` (CAURA-594) — one\n  :class:`~common.events.memory_embed_request.MemoryEmbedRequest`,\n  resolves the embedding via the platform-tier provider, PATCHes it\n  back onto the memory row.\n* ``Topics.Memory.ENRICH_REQUESTED`` (CAURA-595) — one\n  :class:`~common.events.memory_enrich_request.MemoryEnrichRequest`,\n  reconstructs the tenant config from the payload, runs\n  :func:`common.enrichment.enrich_memory` (3-tier provider fallback),\n  and PATCHes the resulting fields back onto the memory row.\n\nEmbed-request flow (existing):\n\n1. Validate the envelope's payload as ``MemoryEmbedRequest``.\n2. Cache lookup: if any other row in the tenant already has an\n   embedding for the same ``content_hash``, reuse it and skip the\n   provider call.\n3. Otherwise call the platform-tier embedding provider via\n   :func:`common.embedding.get_platform_embedding`.\n4. PATCH the embedding back onto the memory row via core-storage-api.\n\nIdempotency: at-least-once delivery from Pub/Sub means a redelivered\nevent re-PATCHes the row with the (deterministic) same embedding.\nThat's safe — the storage update is a write-after-write of the same\ncolumn. ``content_hash`` cache lookup keeps the redelivery cost down\nto a single GET in the steady-state.\n\nFailure modes:\n* ``ValidationError`` on a bad payload → ack + drop (poison-message\n  guard; matches the platform-audit-api pattern). The DLQ provisioned\n  by the bootstrap script catches anything we miss.\n* ``get_platform_embedding() is None`` (PLATFORM_EMBEDDING_* not\n  configured) → log + ack-drop. The worker is platform-only by\n  design; without the singleton there's nothing it can do, and\n  raising would just hot-loop redeliveries.\n* Provider exception or storage PATCH failure → raise → nack →\n  Pub/Sub redelivers (subject to max-delivery-attempts → DLQ).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections.abc import Callable\nfrom datetime import datetime\nfrom types import SimpleNamespace\n\nimport httpx\nfrom pydantic import ValidationError\n\nfrom common.embedding import get_platform_embedding\nfrom common.enrichment import EnrichmentResult, enrich_memory\nfrom common.events.base import Event\nfrom common.events.factory import get_event_bus\nfrom common.events.memory_embed_request import MemoryEmbedRequest\nfrom common.events.memory_embedded_publisher import publish_memory_embedded\nfrom common.events.memory_enrich_request import MemoryEnrichRequest\nfrom common.events.memory_enriched_publisher import publish_memory_enriched\nfrom common.events.suppression_handlers import (\n    SuppressionStorageAdapter,\n    register_suppression_consumer,\n)\nfrom common.events.topics import Topics\nfrom core_worker.clients.storage_client import (\n    find_embedding_by_content_hash,\n    update_memory_embedding,\n    update_memory_enrichment,\n    upsert_tenant_suppression,\n)\nfrom core_worker.per_tenant_concurrency import per_tenant_storage_slot\n\nlogger = logging.getLogger(__name__)\n\n# Zero-arg factory so the consumer doesn't have to plumb Settings on\n# every event. The storage_client module reads its own Settings on\n# first call (singleton). Tests inject a stub by overriding this\n# variable directly via ``configure``.\nStorageClientFactory = Callable[[], httpx.AsyncClient]\n\n_storage_client_factory: StorageClientFactory | None = None\n\n\ndef configure(storage_client_factory: StorageClientFactory) -> None:\n    \"\"\"Bind the per-process state the consumer needs.\n\n    Called once at app startup before ``register_consumers`` /\n    ``bus.start()``. ``storage_client_factory`` is a zero-arg callable\n    returning the shared httpx client (so tests can inject a stub).\n    \"\"\"\n    global _storage_client_factory\n    _storage_client_factory = storage_client_factory\n\n\nasync def handle_embed_request(event: Event) -> None:\n    \"\"\"Process a single embed-request event.\"\"\"\n    try:\n        request = MemoryEmbedRequest(**event.payload)\n    except ValidationError:\n        # Schema-drift / malformed payload. Log loudly with the\n        # ``dropped=True`` alert hook (matches platform-audit-api) and\n        # ack-drop so the subscription doesn't loop on a poison message.\n        logger.exception(\n            \"dropping malformed embed-request payload\",\n            extra={\n                \"event_type\": event.event_type,\n                \"event_id\": str(event.event_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    if _storage_client_factory is None:\n        # Startup ordering bug — configure() was never called. Drop with\n        # a loud log (raising would nack-loop at full Pub/Sub throughput\n        # against a permanently misconfigured pod).\n        logger.error(\n            \"dropping embed-request: consumer not configured\",\n            extra={\n                \"event_id\": str(event.event_id),\n                \"memory_id\": str(request.memory_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    provider = get_platform_embedding()\n    if provider is None:\n        logger.error(\n            \"dropping embed-request: PLATFORM_EMBEDDING_* unset, no platform embedding singleton configured\",\n            extra={\n                \"event_id\": str(event.event_id),\n                \"memory_id\": str(request.memory_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    storage = _storage_client_factory()\n\n    embedding: list[float] | None = None\n\n    # Step 1 — content-hash cache lookup. Saves one provider call on\n    # redeliveries and on legitimate within-tenant duplicates.\n    if request.content_hash:\n        embedding = await find_embedding_by_content_hash(\n            storage,\n            tenant_id=request.tenant_id,\n            content_hash=request.content_hash,\n        )\n        if embedding is not None:\n            logger.info(\n                \"reusing cached embedding for content_hash\",\n                extra={\n                    \"memory_id\": str(request.memory_id),\n                    \"tenant_id\": request.tenant_id,\n                },\n            )\n\n    # Step 2 — provider call (skipped on cache hit).\n    if embedding is None:\n        embedding = await provider.embed(request.content)\n\n    # Step 3 — persist. Raises on non-2xx → nacks → redelivers.\n    # Per-tenant slot scoped to the PATCH roundtrip only, so a\n    # tenant-A storm can't park every storage-writer connection here\n    # while tenant B's lone PATCH queues behind. Provider call above\n    # stays unguarded — that's the expensive step and it doesn't\n    # touch the storage-writer pool.\n    async with per_tenant_storage_slot(request.tenant_id):\n        await update_memory_embedding(\n            storage,\n            memory_id=request.memory_id,\n            tenant_id=request.tenant_id,\n            embedding=embedding,\n        )\n\n    # Back-channel: announce successful embed so core-api can fire\n    # post-embed contradiction detection. Closes the documented\n    # ``handle_memory_enriched`` gap that silently dropped detection\n    # whenever enrichment landed before embedding (the only case under\n    # ``EMBED_ON_HOT_PATH=false``). Best-effort — a publish failure\n    # MUST NOT nack the upstream PATCH that already succeeded; the\n    # embedding is durable in storage either way.\n    try:\n        await publish_memory_embedded(\n            memory_id=request.memory_id,\n            tenant_id=request.tenant_id,\n            content=request.content,\n        )\n    except Exception:\n        logger.exception(\n            \"embedded back-channel publish failed; ack-continuing\",\n            extra={\n                \"memory_id\": str(request.memory_id),\n                \"tenant_id\": request.tenant_id,\n            },\n        )\n\n    logger.info(\n        \"embed-request processed\",\n        extra={\n            \"memory_id\": str(request.memory_id),\n            \"tenant_id\": request.tenant_id,\n            \"provider\": provider.provider_name,\n            \"model\": provider.model,\n        },\n    )\n\n\n# ---------------------------------------------------------------------------\n# Enrich-request consumer (CAURA-595)\n# ---------------------------------------------------------------------------\n\n\n# ORM column fields the worker writes directly. Stays in sync with the\n# corresponding ``Memory`` columns + the synchronous-path mapping in\n# ``core_api.services.memory_service``. Anything an ``EnrichmentResult``\n# field would write to but isn't here lands in ``metadata_patch`` below.\n_ENRICHMENT_ORM_FIELDS: frozenset[str] = frozenset(\n    {\n        \"memory_type\",\n        \"weight\",\n        \"title\",\n        \"status\",\n        \"ts_valid_start\",\n        \"ts_valid_end\",\n    }\n)\n\n# Enrichment fields that live in ``Memory.metadata`` JSONB. Synchronous\n# path (``memory_service.py``) writes them as ``metadata[\"summary\"]``,\n# ``metadata[\"tags\"]``, etc.; the worker mirrors that via the storage\n# layer's atomic ``metadata_patch`` JSONB merge.\n_ENRICHMENT_METADATA_FIELDS: frozenset[str] = frozenset(\n    {\n        \"summary\",\n        \"tags\",\n        \"contains_pii\",\n        \"pii_types\",\n        \"retrieval_hint\",\n        \"llm_ms\",\n    }\n)\n\n# ``EnrichmentResult`` fields the worker INTENTIONALLY does not route\n# to storage. Listed explicitly so the exhaustive-routing assert below\n# fails when a future field is added without a code site to handle it\n# — silent drops are the failure mode we're guarding against.\n#\n# ``atomic_facts``: the synchronous write path fans these out into\n# child memories; the async worker doesn't yet implement that — see\n# the ``logger.debug`` in ``handle_enrich_request`` that surfaces the\n# gap when an enrichment produces them.\n_ENRICHMENT_UNROUTED_FIELDS: frozenset[str] = frozenset({\"atomic_facts\"})\n\n# Metadata fields that ALWAYS overwrite (when not ``None`` and the\n# result came from a real LLM call — see the ``llm_ms > 0`` guard at\n# the call site) so a re-delivery / second-LLM-run can clear stale\n# state from an earlier write. JSONB ``||`` merge treats ``False`` /\n# ``\"\"`` / ``[]`` as ordinary values and overwrites keyed entries.\n#\n# * ``contains_pii`` / ``pii_types`` — non-deterministic LLM output;\n#   an earlier ``contains_pii=True`` must be clearable.\n# * ``retrieval_hint`` — the prompt explicitly instructs the LLM to\n#   return ``\"\"`` for content that's already query-aligned; without\n#   always-write a re-enrichment that drops the hint would leave\n#   metadata stale AND the embedding still prefix-augmented.\n# * ``tags`` — the prompt instructs the LLM to always populate 2-6\n#   tags. ``tags=[]`` from a real LLM run means \"no tags\" intentionally\n#   and must overwrite a prior non-empty list.\n# * ``summary`` — without the guard, a heuristic-fallback redelivery\n#   would write ``fake_enrich``'s ``summary=content[:200]`` over a\n#   prior quality LLM summary. The truncation is a non-empty string,\n#   so the ``value in (False, 0, \"\", [])`` skip-check below doesn't\n#   catch it. Pairing summary with the ``llm_ms > 0`` guard ensures\n#   only real-LLM summaries can overwrite (or clear, if the LLM\n#   returns ``\"\"``).\n_ENRICHMENT_ALWAYS_WRITE_METADATA: frozenset[str] = frozenset(\n    {\"contains_pii\", \"pii_types\", \"retrieval_hint\", \"summary\", \"tags\"}\n)\n\n# Defence-in-depth: a typo in the tuples above would silently drop in\n# the storage layer's ``hasattr(Memory, key)`` filter, *and* a future\n# ``EnrichmentResult`` field that no one wires to a routing tuple\n# would silently fall on the floor. Catch both at module import.\n_unrouted = (\n    set(EnrichmentResult.model_fields)\n    - _ENRICHMENT_ORM_FIELDS\n    - _ENRICHMENT_METADATA_FIELDS\n    - _ENRICHMENT_UNROUTED_FIELDS\n)\n# Raise rather than ``assert`` — ``python -O`` strips assertions, and\n# this guard's whole point is to surface routing-table drift on every\n# import in every environment. Matches\n# ``_assert_override_fields_match_schemas`` in ``memory_service.py``.\nif _unrouted:\n    raise RuntimeError(\n        f\"EnrichmentResult fields not routed to storage by handle_enrich_request: \"\n        f\"{sorted(_unrouted)} — add to one of _ENRICHMENT_ORM_FIELDS / \"\n        f\"_ENRICHMENT_METADATA_FIELDS / _ENRICHMENT_UNROUTED_FIELDS\"\n    )\ndel _unrouted\n\n\ndef _build_tenant_config(request: MemoryEnrichRequest) -> SimpleNamespace | None:\n    \"\"\"Reconstruct a duck-typed tenant_config from the event payload.\n\n    ``common.enrichment.service.enrich_memory`` only reads attributes\n    off ``tenant_config``; a ``SimpleNamespace`` matching that surface is\n    enough — no need to import ``ResolvedConfig``.\n\n    Returns ``None`` only when the payload genuinely carries no\n    tenant-specific config — neither a provider preference nor any API\n    keys. The early-return on ``enrichment_provider is None`` alone\n    would silently discard a tenant's keys, making the async path\n    behave differently from the sync path: sync sees\n    ``provider=None`` and defaults to ``\"openai\"`` while still using\n    the tenant's ``openai_api_key``; async would fall through to the\n    platform-tier provider or the heuristic. The check below mirrors\n    sync semantics — if any credential is present we build the\n    namespace with ``enrichment_provider=None`` and let\n    :func:`enrich_memory` apply its ``or ProviderName.OPENAI``\n    default.\n    \"\"\"\n    has_any_credentials = any(\n        (\n            request.openai_api_key,\n            request.anthropic_api_key,\n            request.openrouter_api_key,\n            request.gemini_api_key,\n        )\n    )\n    if request.enrichment_provider is None and not has_any_credentials:\n        return None\n\n    fb_provider = request.fallback_provider\n    fb_model = request.fallback_model\n\n    def resolve_fallback() -> tuple[str | None, str | None]:\n        return fb_provider, fb_model\n\n    return SimpleNamespace(\n        enrichment_provider=request.enrichment_provider,\n        enrichment_model=request.enrichment_model,\n        openai_api_key=request.openai_api_key,\n        anthropic_api_key=request.anthropic_api_key,\n        openrouter_api_key=request.openrouter_api_key,\n        gemini_api_key=request.gemini_api_key,\n        # Synthesised callable matches the\n        # ``ResolvedConfig.resolve_fallback()`` shape ``call_with_fallback``\n        # expects. The publisher already pre-resolved the tuple at\n        # publish time so the worker doesn't run the policy itself.\n        resolve_fallback=resolve_fallback,\n    )\n\n\ndef _build_patch(\n    result: EnrichmentResult,","lineStart":1,"lineEnd":360,"totalLines":625,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py","time":{"start":1780728827537,"end":1780728827544}},"metadata":{"openai":{"itemId":"fc_0f3d86b8e8edc3b9016a23c3fb7498819190861965bde6e3d0"}},"id":"prt_e9bb58e8b001RrSWkQnn7sZ2K1","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1"}}
{"type":"step_finish","timestamp":1780728827874,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"id":"prt_e9bb58fe0001bIqFRYbywfwdjv","reason":"tool-calls","snapshot":"176ae7ef9ba979a6f19d165fe2b2bb6145c3ac5a","messageID":"msg_e9bb560e9001AXpNj11ffGIoH1","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","type":"step-finish","tokens":{"total":23492,"input":1949,"output":500,"reasoning":51,"cache":{"write":0,"read":20992}},"cost":0}}
{"type":"step_start","timestamp":1780728829128,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"id":"prt_e9bb594c2001LsMmYWG41AvCiI","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","snapshot":"44f378f769fd92d3ae8b6e43fdc36860344e2428","type":"step-start"}}
{"type":"text","timestamp":1780728839909,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"id":"prt_e9bb59b770013CL56H6dYHATpB","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","type":"text","text":"Initial read shows MemClaw has content-hash embedding reuse and enrichment merge semantics, but I still need the lower consumer/storage/event sections to verify whether model provenance and pending/stale state columns actually exist.","time":{"start":1780728830839,"end":1780728839906},"metadata":{"openai":{"itemId":"msg_001872bc89af9832016a23c3fed56481918f8669daeb2ce001","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780728839996,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_4rYbEgr1ihCpbAQlqlxX5z7Y","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","offset":241,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py</path>\n<type>file</type>\n<content>\n241:     returns ``None`` rather than raising, so write paths can persist\n242:     rows with ``embedding=NULL`` and let the async-embed worker backfill.\n243:     The same ``None`` is returned on a registry-level\n244:     ``ValueError`` (env-var misconfiguration) — see\n245:     :func:`_resolve_provider_or_degrade`.\n246: \n247:     This is the document/ingest path. For search-side queries that should\n248:     pass through an instruction-aware encoder (Qwen3-Embedding, e5-instruct,\n249:     etc.), use :func:`get_query_embedding` instead.\n250:     \"\"\"\n251:     provider = await _resolve_provider_or_degrade(tenant_config, \"Embedding\")\n252:     if provider is None:\n253:         return None\n254:     return await _run_with_retry(lambda: provider.embed(text), \"Embedding\")\n255: \n256: \n257: async def get_query_embedding(\n258:     text: str,\n259:     tenant_config: object | None = None,\n260:     instruction: str | None = None,\n261: ) -> list[float] | None:\n262:     \"\"\"Generate a query-side embedding (instruction-aware, asymmetric).\n263: \n264:     For instruction-aware models (Qwen3-Embedding, e5-instruct, KaLM), the\n265:     query encoder expects a task-description prefix that documents do not\n266:     receive. Symmetric providers (OpenAI ``text-embedding-3-small``,\n267:     ``bge-m3``, ``gte-en-v1.5``, ``Fake``, ``Local``, ``Vertex``) do not\n268:     implement :class:`~common.embedding.protocols.InstructionAwareEmbedder`\n269:     — the call site below detects that and falls back to the symmetric\n270:     :meth:`embed` path, matching :func:`get_embedding`.\n271: \n272:     Same retry / degradation semantics as :func:`get_embedding`: returns\n273:     ``None`` after exhausted retries rather than raising, so search routes\n274:     can degrade gracefully (typically by raising 503 to the caller). The\n275:     same ``None`` is returned on a registry-level ``ValueError`` (env-var\n276:     misconfiguration).\n277:     \"\"\"\n278:     provider = await _resolve_provider_or_degrade(tenant_config, \"Query embedding\")\n279:     if provider is None:\n280:         return None\n281: \n282:     # ``InstructionAwareEmbedder`` is an optional ``@runtime_checkable``\n283:     # Protocol declared in ``common.embedding.protocols`` for exactly\n284:     # this dispatch. Only providers backed by an instruction-aware\n285:     # model (e.g. ``OpenAIEmbeddingProvider`` pointed at\n286:     # Qwen3-Embedding) conform. ``Fake`` / ``Local`` / ``Vertex`` do\n287:     # not implement ``embed_query`` and the isinstance check returns\n288:     # False — they fall through to :meth:`embed` and silently ignore\n289:     # *instruction*.\n290:     is_instruction_aware = isinstance(provider, InstructionAwareEmbedder)\n291: \n292:     async def _call() -> list[float]:\n293:         # Inner ``def`` rather than a ``lambda`` so the closure captures\n294:         # *provider* / *text* / *instruction* with explicit ``await``\n295:         # ergonomics; ruff E731 disapproves of ``make_call = lambda:``.\n296:         if is_instruction_aware:\n297:             return await provider.embed_query(text, instruction)\n298:         return await provider.embed(text)\n299: \n300:     return await _run_with_retry(_call, \"Query embedding\")\n\n(End of file - total 300 lines)\n</content>","metadata":{"preview":"    returns ``None`` rather than raising, so write paths can persist\n    rows with ``embedding=NULL`` and let the async-embed worker backfill.\n    The same ``None`` is returned on a registry-level\n    ``ValueError`` (env-var misconfiguration) — see\n    :func:`_resolve_provider_or_degrade`.\n\n    This is the document/ingest path. For search-side queries that should\n    pass through an instruction-aware encoder (Qwen3-Embedding, e5-instruct,\n    etc.), use :func:`get_query_embedding` instead.\n    \"\"\"\n    provider = await _resolve_provider_or_degrade(tenant_config, \"Embedding\")\n    if provider is None:\n        return None\n    return await _run_with_retry(lambda: provider.embed(text), \"Embedding\")\n\n\nasync def get_query_embedding(\n    text: str,\n    tenant_config: object | None = None,\n    instruction: str | None = None,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","text":"    returns ``None`` rather than raising, so write paths can persist\n    rows with ``embedding=NULL`` and let the async-embed worker backfill.\n    The same ``None`` is returned on a registry-level\n    ``ValueError`` (env-var misconfiguration) — see\n    :func:`_resolve_provider_or_degrade`.\n\n    This is the document/ingest path. For search-side queries that should\n    pass through an instruction-aware encoder (Qwen3-Embedding, e5-instruct,\n    etc.), use :func:`get_query_embedding` instead.\n    \"\"\"\n    provider = await _resolve_provider_or_degrade(tenant_config, \"Embedding\")\n    if provider is None:\n        return None\n    return await _run_with_retry(lambda: provider.embed(text), \"Embedding\")\n\n\nasync def get_query_embedding(\n    text: str,\n    tenant_config: object | None = None,\n    instruction: str | None = None,\n) -> list[float] | None:\n    \"\"\"Generate a query-side embedding (instruction-aware, asymmetric).\n\n    For instruction-aware models (Qwen3-Embedding, e5-instruct, KaLM), the\n    query encoder expects a task-description prefix that documents do not\n    receive. Symmetric providers (OpenAI ``text-embedding-3-small``,\n    ``bge-m3``, ``gte-en-v1.5``, ``Fake``, ``Local``, ``Vertex``) do not\n    implement :class:`~common.embedding.protocols.InstructionAwareEmbedder`\n    — the call site below detects that and falls back to the symmetric\n    :meth:`embed` path, matching :func:`get_embedding`.\n\n    Same retry / degradation semantics as :func:`get_embedding`: returns\n    ``None`` after exhausted retries rather than raising, so search routes\n    can degrade gracefully (typically by raising 503 to the caller). The\n    same ``None`` is returned on a registry-level ``ValueError`` (env-var\n    misconfiguration).\n    \"\"\"\n    provider = await _resolve_provider_or_degrade(tenant_config, \"Query embedding\")\n    if provider is None:\n        return None\n\n    # ``InstructionAwareEmbedder`` is an optional ``@runtime_checkable``\n    # Protocol declared in ``common.embedding.protocols`` for exactly\n    # this dispatch. Only providers backed by an instruction-aware\n    # model (e.g. ``OpenAIEmbeddingProvider`` pointed at\n    # Qwen3-Embedding) conform. ``Fake`` / ``Local`` / ``Vertex`` do\n    # not implement ``embed_query`` and the isinstance check returns\n    # False — they fall through to :meth:`embed` and silently ignore\n    # *instruction*.\n    is_instruction_aware = isinstance(provider, InstructionAwareEmbedder)\n\n    async def _call() -> list[float]:\n        # Inner ``def`` rather than a ``lambda`` so the closure captures\n        # *provider* / *text* / *instruction* with explicit ``await``\n        # ergonomics; ruff E731 disapproves of ``make_call = lambda:``.\n        if is_instruction_aware:\n            return await provider.embed_query(text, instruction)\n        return await provider.embed(text)\n\n    return await _run_with_retry(_call, \"Query embedding\")","lineStart":241,"lineEnd":300,"totalLines":300,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_service.py","time":{"start":1780728839981,"end":1780728839995}},"metadata":{"openai":{"itemId":"fc_001872bc89af9832016a23c407cf4481919a54fbbd6bbda777"}},"id":"prt_e9bb5beeb001fClSuKbGokxcVJ","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T"}}
{"type":"tool_use","timestamp":1780728840046,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_6KfWztWPgxva71s562J45Gde","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py","offset":221,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py</path>\n<type>file</type>\n<content>\n221:         # raises ``ValueError: invalid literal for int() with base 10:\n222:         # 'foo'`` — which is true but doesn't tell the operator which\n223:         # knob they fat-fingered. Re-raise with the variable name and\n224:         # the offending value.\n225:         try:\n226:             truncate_to_dim = int(truncate_raw) if truncate_raw else None\n227:         except ValueError:\n228:             raise ValueError(\n229:                 f\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM={truncate_raw!r} must be an integer\"\n230:             ) from None\n231: \n232:         # Hot-path note. ``get_embedding_provider`` runs on every embed\n233:         # and search request, so we want the steady-state cache hit to\n234:         # be as cheap as possible — but the cache key itself includes\n235:         # the *parsed* env values (``send_dimensions: bool``,\n236:         # ``truncate_to_dim: int | None``), so the env lookups + strict\n237:         # bool/int parsing above ALWAYS run, regardless of cache hit\n238:         # or miss. They're O(microseconds) (a couple of ``os.environ``\n239:         # reads + a string compare + at most one ``int()``) and have\n240:         # been measured as below the noise floor of the embed call\n241:         # itself, but they're not free. The expensive structural\n242:         # validation — the ``base_url ⊕ send_dimensions`` raise and the\n243:         # ``truncate_to_dim`` vs ``VECTOR_DIM`` raise below — is what\n244:         # the cache lookup actually skips. On a steady-state cache hit\n245:         # nothing about the env-driven config has changed since the\n246:         # cached provider was constructed, so we don't need to re-run\n247:         # those structural checks. (Operators changing env vars\n248:         # mid-process would need to restart anyway — env parses don't\n249:         # invalidate cache entries.)\n250:         #\n251:         # ``_get_or_create_openai_provider`` re-does the same dict\n252:         # lookup on a miss — single O(1) and not worth a\n253:         # signature-breaking refactor.\n254:         cache_key = (\n255:             api_key,\n256:             embed_model,\n257:             base_url,\n258:             send_dimensions,\n259:             query_instruction,\n260:             truncate_to_dim,\n261:         )\n262:         cached = _openai_provider_cache.get(cache_key)\n263:         if cached is not None:\n264:             _openai_provider_cache.move_to_end(cache_key)\n265:             return cached\n266: \n267:         # ── Cache miss — first time we see this config tuple. ─────────\n268:         # Both misconfiguration shapes below GUARANTEE that every embed\n269:         # call will fail (4xx from the provider, or schema-dim mismatch\n270:         # at the pgvector layer). A warning + fall-through would mean:\n271:         # provider gets constructed, every request 4xx's, retries\n272:         # exhaust, ``get_embedding`` returns None, writes persist with\n273:         # ``embedding=NULL``, search silently broken. That's strictly\n274:         # worse than failing fast at construction time — the operator\n275:         # sees the misconfiguration on the first request rather than\n276:         # debugging mysteriously empty search results.\n277:         #\n278:         # Forward misconfiguration: TEI / vLLM and most OpenAI-compatible\n279:         # self-hosted endpoints reject the ``dimensions=`` SDK kwarg\n280:         # outright. Hosted ``api.openai.com`` is the only target that\n281:         # accepts (and requires) it.\n282:         if base_url and send_dimensions:\n283:             raise ValueError(\n284:                 f\"OPENAI_EMBEDDING_BASE_URL={base_url!r} is set but \"\n285:                 \"OPENAI_EMBEDDING_SEND_DIMENSIONS is true. Most \"\n286:                 \"OpenAI-compatible self-hosted endpoints (TEI, vLLM, ...) \"\n287:                 \"reject the ``dimensions=`` kwarg. Set \"\n288:                 \"OPENAI_EMBEDDING_SEND_DIMENSIONS=false for TEI/vLLM, or \"\n289:                 \"remove OPENAI_EMBEDDING_BASE_URL to use hosted OpenAI.\"\n290:             )\n291: \n292:         # Inverse misconfiguration: hosted OpenAI (no ``base_url``) with\n293:         # ``send_dimensions=false``. Hosted ``api.openai.com`` honours\n294:         # ``dimensions=`` to truncate the model's native output down to\n295:         # the schema dim; omitting it returns the full native dim\n296:         # (1536 for ``text-embedding-3-small``, 3072 for\n297:         # ``text-embedding-3-large``), which pgvector rejects on every\n298:         # write with ``expected N dimensions, not M``.\n299:         if not base_url and not send_dimensions:\n300:             raise ValueError(\n301:                 \"OPENAI_EMBEDDING_SEND_DIMENSIONS=false but \"\n302:                 \"OPENAI_EMBEDDING_BASE_URL is unset (hosted OpenAI). \"\n303:                 f\"Hosted OpenAI returns model {embed_model}'s native dim \"\n304:                 \"without the ``dimensions=`` kwarg (e.g. 1536 for \"\n305:                 \"text-embedding-3-small), which pgvector rejects at \"\n306:                 \"write time. Set OPENAI_EMBEDDING_SEND_DIMENSIONS=true \"\n307:                 \"(or unset it) for the hosted OpenAI path, or set \"\n308:                 \"OPENAI_EMBEDDING_BASE_URL to point at a self-hosted \"\n309:                 \"endpoint that produces VECTOR_DIM-sized vectors natively.\"\n310:             )\n311: \n312:         # Matryoshka truncation: lets us run instruction-aware models with\n313:         # native dim > VECTOR_DIM (Qwen3-Embedding-4B is 2560-d, 8B is\n314:         # 4096-d) against the 1024-d schema. Qwen3-Embedding-0.6B is\n315:         # natively 1024-d and does NOT need this knob — leave unset.\n316:         # ``OpenAIEmbeddingProvider._postprocess`` slices and\n317:         # L2-renormalizes so cosine sim correctness is preserved.\n318:         #\n319:         # Only valid value is exactly ``VECTOR_DIM``. Anything smaller\n320:         # produces vectors pgvector rejects at write time (column type\n321:         # is ``vector(VECTOR_DIM)``); anything larger would not fit\n322:         # the schema column either. The knob exists to truncate a\n323:         # *wider* model's native output down to the schema dimension —\n324:         # that's the only meaningful operation. Catch the misuse here\n325:         # instead of letting writes 4xx in production.\n326:         if truncate_to_dim is not None and truncate_to_dim != VECTOR_DIM:\n327:             raise ValueError(\n328:                 f\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM={truncate_to_dim} must equal \"\n329:                 f\"VECTOR_DIM={VECTOR_DIM}; this knob is only for truncating a \"\n330:                 \"wider model's native output to the schema dimension.\"\n331:             )\n332:         return _get_or_create_openai_provider(\n333:             api_key,\n334:             embed_model,\n335:             base_url,\n336:             send_dimensions,\n337:             query_instruction,\n338:             truncate_to_dim,\n339:         )\n340: \n341:     if name == ProviderName.LOCAL:\n342:         return LocalEmbedding()\n343: \n344:     raise ValueError(f\"Unknown embedding provider: {name}\")\n\n(End of file - total 344 lines)\n</content>","metadata":{"preview":"        # raises ``ValueError: invalid literal for int() with base 10:\n        # 'foo'`` — which is true but doesn't tell the operator which\n        # knob they fat-fingered. Re-raise with the variable name and\n        # the offending value.\n        try:\n            truncate_to_dim = int(truncate_raw) if truncate_raw else None\n        except ValueError:\n            raise ValueError(\n                f\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM={truncate_raw!r} must be an integer\"\n            ) from None\n\n        # Hot-path note. ``get_embedding_provider`` runs on every embed\n        # and search request, so we want the steady-state cache hit to\n        # be as cheap as possible — but the cache key itself includes\n        # the *parsed* env values (``send_dimensions: bool``,\n        # ``truncate_to_dim: int | None``), so the env lookups + strict\n        # bool/int parsing above ALWAYS run, regardless of cache hit\n        # or miss. They're O(microseconds) (a couple of ``os.environ``\n        # reads + a string compare + at most one ``int()``) and have\n        # been measured as below the noise floor of the embed call","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py","text":"        # raises ``ValueError: invalid literal for int() with base 10:\n        # 'foo'`` — which is true but doesn't tell the operator which\n        # knob they fat-fingered. Re-raise with the variable name and\n        # the offending value.\n        try:\n            truncate_to_dim = int(truncate_raw) if truncate_raw else None\n        except ValueError:\n            raise ValueError(\n                f\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM={truncate_raw!r} must be an integer\"\n            ) from None\n\n        # Hot-path note. ``get_embedding_provider`` runs on every embed\n        # and search request, so we want the steady-state cache hit to\n        # be as cheap as possible — but the cache key itself includes\n        # the *parsed* env values (``send_dimensions: bool``,\n        # ``truncate_to_dim: int | None``), so the env lookups + strict\n        # bool/int parsing above ALWAYS run, regardless of cache hit\n        # or miss. They're O(microseconds) (a couple of ``os.environ``\n        # reads + a string compare + at most one ``int()``) and have\n        # been measured as below the noise floor of the embed call\n        # itself, but they're not free. The expensive structural\n        # validation — the ``base_url ⊕ send_dimensions`` raise and the\n        # ``truncate_to_dim`` vs ``VECTOR_DIM`` raise below — is what\n        # the cache lookup actually skips. On a steady-state cache hit\n        # nothing about the env-driven config has changed since the\n        # cached provider was constructed, so we don't need to re-run\n        # those structural checks. (Operators changing env vars\n        # mid-process would need to restart anyway — env parses don't\n        # invalidate cache entries.)\n        #\n        # ``_get_or_create_openai_provider`` re-does the same dict\n        # lookup on a miss — single O(1) and not worth a\n        # signature-breaking refactor.\n        cache_key = (\n            api_key,\n            embed_model,\n            base_url,\n            send_dimensions,\n            query_instruction,\n            truncate_to_dim,\n        )\n        cached = _openai_provider_cache.get(cache_key)\n        if cached is not None:\n            _openai_provider_cache.move_to_end(cache_key)\n            return cached\n\n        # ── Cache miss — first time we see this config tuple. ─────────\n        # Both misconfiguration shapes below GUARANTEE that every embed\n        # call will fail (4xx from the provider, or schema-dim mismatch\n        # at the pgvector layer). A warning + fall-through would mean:\n        # provider gets constructed, every request 4xx's, retries\n        # exhaust, ``get_embedding`` returns None, writes persist with\n        # ``embedding=NULL``, search silently broken. That's strictly\n        # worse than failing fast at construction time — the operator\n        # sees the misconfiguration on the first request rather than\n        # debugging mysteriously empty search results.\n        #\n        # Forward misconfiguration: TEI / vLLM and most OpenAI-compatible\n        # self-hosted endpoints reject the ``dimensions=`` SDK kwarg\n        # outright. Hosted ``api.openai.com`` is the only target that\n        # accepts (and requires) it.\n        if base_url and send_dimensions:\n            raise ValueError(\n                f\"OPENAI_EMBEDDING_BASE_URL={base_url!r} is set but \"\n                \"OPENAI_EMBEDDING_SEND_DIMENSIONS is true. Most \"\n                \"OpenAI-compatible self-hosted endpoints (TEI, vLLM, ...) \"\n                \"reject the ``dimensions=`` kwarg. Set \"\n                \"OPENAI_EMBEDDING_SEND_DIMENSIONS=false for TEI/vLLM, or \"\n                \"remove OPENAI_EMBEDDING_BASE_URL to use hosted OpenAI.\"\n            )\n\n        # Inverse misconfiguration: hosted OpenAI (no ``base_url``) with\n        # ``send_dimensions=false``. Hosted ``api.openai.com`` honours\n        # ``dimensions=`` to truncate the model's native output down to\n        # the schema dim; omitting it returns the full native dim\n        # (1536 for ``text-embedding-3-small``, 3072 for\n        # ``text-embedding-3-large``), which pgvector rejects on every\n        # write with ``expected N dimensions, not M``.\n        if not base_url and not send_dimensions:\n            raise ValueError(\n                \"OPENAI_EMBEDDING_SEND_DIMENSIONS=false but \"\n                \"OPENAI_EMBEDDING_BASE_URL is unset (hosted OpenAI). \"\n                f\"Hosted OpenAI returns model {embed_model}'s native dim \"\n                \"without the ``dimensions=`` kwarg (e.g. 1536 for \"\n                \"text-embedding-3-small), which pgvector rejects at \"\n                \"write time. Set OPENAI_EMBEDDING_SEND_DIMENSIONS=true \"\n                \"(or unset it) for the hosted OpenAI path, or set \"\n                \"OPENAI_EMBEDDING_BASE_URL to point at a self-hosted \"\n                \"endpoint that produces VECTOR_DIM-sized vectors natively.\"\n            )\n\n        # Matryoshka truncation: lets us run instruction-aware models with\n        # native dim > VECTOR_DIM (Qwen3-Embedding-4B is 2560-d, 8B is\n        # 4096-d) against the 1024-d schema. Qwen3-Embedding-0.6B is\n        # natively 1024-d and does NOT need this knob — leave unset.\n        # ``OpenAIEmbeddingProvider._postprocess`` slices and\n        # L2-renormalizes so cosine sim correctness is preserved.\n        #\n        # Only valid value is exactly ``VECTOR_DIM``. Anything smaller\n        # produces vectors pgvector rejects at write time (column type\n        # is ``vector(VECTOR_DIM)``); anything larger would not fit\n        # the schema column either. The knob exists to truncate a\n        # *wider* model's native output down to the schema dimension —\n        # that's the only meaningful operation. Catch the misuse here\n        # instead of letting writes 4xx in production.\n        if truncate_to_dim is not None and truncate_to_dim != VECTOR_DIM:\n            raise ValueError(\n                f\"OPENAI_EMBEDDING_TRUNCATE_TO_DIM={truncate_to_dim} must equal \"\n                f\"VECTOR_DIM={VECTOR_DIM}; this knob is only for truncating a \"\n                \"wider model's native output to the schema dimension.\"\n            )\n        return _get_or_create_openai_provider(\n            api_key,\n            embed_model,\n            base_url,\n            send_dimensions,\n            query_instruction,\n            truncate_to_dim,\n        )\n\n    if name == ProviderName.LOCAL:\n        return LocalEmbedding()\n\n    raise ValueError(f\"Unknown embedding provider: {name}\")","lineStart":221,"lineEnd":344,"totalLines":344,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/embedding/_registry.py","time":{"start":1780728840042,"end":1780728840045}},"metadata":{"openai":{"itemId":"fc_001872bc89af9832016a23c407cf548191bb2649fd121b66e8"}},"id":"prt_e9bb5bf35001hjjCSaJRrymyW0","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T"}}
{"type":"tool_use","timestamp":1780728840100,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_gjXJmYjfbvPrFYdTLfHm7AGu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py","offset":261,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py</path>\n<type>file</type>\n<content>\n261:     matching guard for the keyword-heuristic fallback (:func:`fake_enrich`),\n262:     whose primitive vocabulary still recognises rule/outcome shapes. Demoting\n263:     here, rather than in the primitive, keeps ``fake_enrich`` reusable.\n264:     \"\"\"\n265:     if result.memory_type in SERVER_RESERVED_MEMORY_TYPES:\n266:         return result.model_copy(\n267:             update={\"memory_type\": MemoryType(DEFAULT_MEMORY_TYPE)}\n268:         )\n269:     return result\n270: \n271: \n272: async def enrich_memory(\n273:     content: str,\n274:     tenant_config: object | None = None,\n275:     *,\n276:     reference_datetime: datetime | None = None,\n277: ) -> EnrichmentResult:\n278:     \"\"\"Enrich memory content using LLM: classify, title, summarize, tag.\n279: \n280:     Fallback chain:\n281:       1. Configured provider (with retry)\n282:       2. Alternative LLM provider (with retry) — if API key available\n283:       3. Keyword heuristic (:func:`fake_enrich`) — always succeeds\n284: \n285:     Uses ``tenant_config`` if provided; otherwise reads\n286:     ``ENTITY_EXTRACTION_PROVIDER`` from the env (default ``\"openai\"``).\n287:     Never raises; always returns an :class:`EnrichmentResult`.\n288:     \"\"\"\n289:     if tenant_config is not None:\n290:         provider_name = (\n291:             getattr(tenant_config, \"enrichment_provider\", None) or ProviderName.OPENAI\n292:         )\n293:     else:\n294:         provider_name = os.environ.get(\n295:             \"ENTITY_EXTRACTION_PROVIDER\", ProviderName.OPENAI\n296:         )\n297: \n298:     if provider_name == ProviderName.FAKE:\n299:         return _demote_reserved_enrichment(fake_enrich(content))\n300:     if provider_name == ProviderName.NONE:\n301:         return EnrichmentResult()\n302: \n303:     ref_date = (\n304:         reference_datetime.date() if reference_datetime else date.today()\n305:     ).isoformat()\n306: \n307:     async def _do_enrich(llm: LLMProvider) -> EnrichmentResult:\n308:         # Escape ``{`` / ``}`` in user content before ``.format()`` —\n309:         # the prompt template uses them as field markers, so a memory\n310:         # whose content includes ``\"I used {memory_type} in my code\"``\n311:         # would raise ``KeyError`` from ``.format()``, get caught by\n312:         # the retry loop above, exhaust attempts, and silently fall to\n313:         # ``fake_enrich`` with no log surface for *why*. The template\n314:         # itself escapes its JSON example with literal ``{{ }}`` so\n315:         # there's no symmetry to preserve at the format-string layer\n316:         # — only user input needs the escape.\n317:         escaped_content = content.replace(\"{\", \"{{\").replace(\"}\", \"}}\")\n318:         prompt = ENRICHMENT_PROMPT.format(content=escaped_content, today=ref_date)\n319:         t0 = time.perf_counter()\n320:         raw = await llm.complete_json(prompt)\n321:         llm_ms = int((time.perf_counter() - t0) * 1000)\n322:         return _validate_enrichment(raw, llm_ms)\n323: \n324:     enrichment_model = (\n325:         getattr(tenant_config, \"enrichment_model\", None) if tenant_config else None\n326:     )\n327:     return await call_with_fallback(\n328:         primary_provider_name=provider_name,\n329:         call_fn=_do_enrich,\n330:         fake_fn=lambda: _demote_reserved_enrichment(fake_enrich(content)),\n331:         tenant_config=tenant_config,\n332:         service_label=\"enrichment\",\n333:         model_override=enrichment_model,\n334:     )\n\n(End of file - total 334 lines)\n</content>","metadata":{"preview":"    matching guard for the keyword-heuristic fallback (:func:`fake_enrich`),\n    whose primitive vocabulary still recognises rule/outcome shapes. Demoting\n    here, rather than in the primitive, keeps ``fake_enrich`` reusable.\n    \"\"\"\n    if result.memory_type in SERVER_RESERVED_MEMORY_TYPES:\n        return result.model_copy(\n            update={\"memory_type\": MemoryType(DEFAULT_MEMORY_TYPE)}\n        )\n    return result\n\n\nasync def enrich_memory(\n    content: str,\n    tenant_config: object | None = None,\n    *,\n    reference_datetime: datetime | None = None,\n) -> EnrichmentResult:\n    \"\"\"Enrich memory content using LLM: classify, title, summarize, tag.\n\n    Fallback chain:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py","text":"    matching guard for the keyword-heuristic fallback (:func:`fake_enrich`),\n    whose primitive vocabulary still recognises rule/outcome shapes. Demoting\n    here, rather than in the primitive, keeps ``fake_enrich`` reusable.\n    \"\"\"\n    if result.memory_type in SERVER_RESERVED_MEMORY_TYPES:\n        return result.model_copy(\n            update={\"memory_type\": MemoryType(DEFAULT_MEMORY_TYPE)}\n        )\n    return result\n\n\nasync def enrich_memory(\n    content: str,\n    tenant_config: object | None = None,\n    *,\n    reference_datetime: datetime | None = None,\n) -> EnrichmentResult:\n    \"\"\"Enrich memory content using LLM: classify, title, summarize, tag.\n\n    Fallback chain:\n      1. Configured provider (with retry)\n      2. Alternative LLM provider (with retry) — if API key available\n      3. Keyword heuristic (:func:`fake_enrich`) — always succeeds\n\n    Uses ``tenant_config`` if provided; otherwise reads\n    ``ENTITY_EXTRACTION_PROVIDER`` from the env (default ``\"openai\"``).\n    Never raises; always returns an :class:`EnrichmentResult`.\n    \"\"\"\n    if tenant_config is not None:\n        provider_name = (\n            getattr(tenant_config, \"enrichment_provider\", None) or ProviderName.OPENAI\n        )\n    else:\n        provider_name = os.environ.get(\n            \"ENTITY_EXTRACTION_PROVIDER\", ProviderName.OPENAI\n        )\n\n    if provider_name == ProviderName.FAKE:\n        return _demote_reserved_enrichment(fake_enrich(content))\n    if provider_name == ProviderName.NONE:\n        return EnrichmentResult()\n\n    ref_date = (\n        reference_datetime.date() if reference_datetime else date.today()\n    ).isoformat()\n\n    async def _do_enrich(llm: LLMProvider) -> EnrichmentResult:\n        # Escape ``{`` / ``}`` in user content before ``.format()`` —\n        # the prompt template uses them as field markers, so a memory\n        # whose content includes ``\"I used {memory_type} in my code\"``\n        # would raise ``KeyError`` from ``.format()``, get caught by\n        # the retry loop above, exhaust attempts, and silently fall to\n        # ``fake_enrich`` with no log surface for *why*. The template\n        # itself escapes its JSON example with literal ``{{ }}`` so\n        # there's no symmetry to preserve at the format-string layer\n        # — only user input needs the escape.\n        escaped_content = content.replace(\"{\", \"{{\").replace(\"}\", \"}}\")\n        prompt = ENRICHMENT_PROMPT.format(content=escaped_content, today=ref_date)\n        t0 = time.perf_counter()\n        raw = await llm.complete_json(prompt)\n        llm_ms = int((time.perf_counter() - t0) * 1000)\n        return _validate_enrichment(raw, llm_ms)\n\n    enrichment_model = (\n        getattr(tenant_config, \"enrichment_model\", None) if tenant_config else None\n    )\n    return await call_with_fallback(\n        primary_provider_name=provider_name,\n        call_fn=_do_enrich,\n        fake_fn=lambda: _demote_reserved_enrichment(fake_enrich(content)),\n        tenant_config=tenant_config,\n        service_label=\"enrichment\",\n        model_override=enrichment_model,\n    )","lineStart":261,"lineEnd":334,"totalLines":334,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py","time":{"start":1780728840096,"end":1780728840100}},"metadata":{"openai":{"itemId":"fc_001872bc89af9832016a23c407cf608191893f584333338d23"}},"id":"prt_e9bb5bf7d001VFCXisIf245kv6","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T"}}
{"type":"tool_use","timestamp":1780728840124,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_1vKeDmAlJibrnTHI6FqUkDkM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py","offset":359,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py</path>\n<type>file</type>\n<content>\n359: def _build_patch(\n360:     result: EnrichmentResult,\n361:     agent_provided_fields: list[str] | None = None,\n362: ) -> dict:\n363:     \"\"\"Translate an ``EnrichmentResult`` into the storage PATCH body.\n364: \n365:     ORM-column fields go at the top level; metadata fields land under\n366:     ``metadata_patch`` for the storage layer's atomic JSONB merge.\n367: \n368:     ``agent_provided_fields`` is the publisher's snapshot of which\n369:     columns the agent set explicitly at write time. Those fields are\n370:     excluded from the PATCH so a redelivery (or a slow worker run)\n371:     can't downgrade an agent-provided ``weight=0.9`` back to\n372:     ``EnrichmentResult.weight``'s default of ``0.7``. Critical because\n373:     Pydantic defaults survive ``exclude_none=True`` — every event\n374:     technically carries values for ``memory_type``, ``weight``,\n375:     ``status``.\n376: \n377:     ``ts_valid_*`` are emitted as ISO strings (``model_dump(mode=\"json\")``).\n378:     asyncpg requires datetime instances for ``DateTime(timezone=True)``\n379:     columns and rejects ISO strings with ``CannotCoerceError``, so the\n380:     storage layer's ``PATCH /memories/{id}`` route calls\n381:     ``_parse_datetimes(body)`` at the API boundary to coerce these\n382:     fields before the SQL UPDATE runs (mirrors the POST route's\n383:     pre-existing parse step). Keeping the worker's payload as ISO\n384:     strings keeps it JSON-serialisable end-to-end (httpx ``json=``\n385:     falls back to stdlib ``json.dumps`` which can't serialise\n386:     ``datetime``); the coercion lives at the storage boundary\n387:     rather than per-publisher. This was a real production bug\n388:     until 2026-04-26 — see PR <CAURA-595-ts-valid-iso-coercion>.\n389:     \"\"\"\n390:     skip = frozenset(agent_provided_fields or ())\n391:     dump = result.model_dump(mode=\"json\", exclude_none=True)\n392: \n393:     # ``ts_valid_*`` are semantically meaningful as ``None`` (\"this\n394:     # memory has no validity bounds\"), distinct from \"field absent\".\n395:     # ``exclude_none=True`` would silently drop them, leaving stale\n396:     # dates from a prior enrichment run intact in storage. Preserve\n397:     # them explicitly so a re-delivery (or a different LLM run that\n398:     # doesn't infer dates) can clear what an earlier run wrote.\n399:     #\n400:     # GUARD: only null-patch when the result came from a real LLM\n401:     # call (``llm_ms > 0``). The heuristic fallback (``fake_enrich``\n402:     # — used when the configured provider fails after retries +\n403:     # fallback chain exhausts) NEVER infers dates, so its absence of\n404:     # ``ts_valid_*`` is \"I don't know\", not \"no bounds\". Without this\n405:     # guard, a Pub/Sub redelivery that coincides with an LLM outage\n406:     # would land on the heuristic and wipe temporal bounds a prior\n407:     # successful run wrote — silent data loss with no log surface.\n408:     if result.llm_ms > 0:\n409:         for ts_field in (\"ts_valid_start\", \"ts_valid_end\"):\n410:             if ts_field not in skip and ts_field not in dump:\n411:                 dump[ts_field] = None\n412: \n413:     patch: dict = {}\n414:     for field in _ENRICHMENT_ORM_FIELDS:\n415:         if field in skip:\n416:             continue\n417:         if field in dump:\n418:             value = dump[field]\n419:             # Empty title from the LLM (or from ``fake_enrich`` for\n420:             # very short content) shouldn't clobber a previously-\n421:             # stored valid title. Other ORM fields (``memory_type``,\n422:             # ``weight``, ``status``) have schema defaults that\n423:             # ``EnrichmentResult`` always emits — those go through\n424:             # ``agent_provided_fields`` for the gate. ``title`` has\n425:             # no agent-side counterpart (it's enricher-only output)\n426:             # and no useful default — empty == \"didn't infer\".\n427:             if field == \"title\" and value == \"\":\n428:                 continue\n429:             patch[field] = value\n430: \n431:     # The hot-path writer set ``metadata.enrichment_pending=true`` when\n432:     # deferring; clear it unconditionally on every successful worker\n433:     # PATCH so a read-after-success returns clean state. Pre-seeds the\n434:     # patch dict so the ``if metadata_patch:`` gate below always fires\n435:     # (when heuristic fallback produces no real metadata fields, this\n436:     # seed ensures the PATCH still goes out and clears the stale flag\n437:     # — without it, a fallback redelivery would silently keep the row\n438:     # marked pending forever). Storage's JSONB ``||`` merge overwrites\n439:     # a prior ``True`` with ``False`` cleanly.\n440:     metadata_patch: dict = {\"enrichment_pending\": False}\n441:     for field in _ENRICHMENT_METADATA_FIELDS:\n442:         if field in skip:\n443:             continue\n444:         value = dump.get(field)\n445:         if field in _ENRICHMENT_ALWAYS_WRITE_METADATA:\n446:             # Same ``llm_ms > 0`` guard as ``ts_valid_*`` above:\n447:             # ``fake_enrich`` returns ``contains_pii=False``,\n448:             # ``pii_types=[]``, ``tags=[]``, ``retrieval_hint=\"\"`` as\n449:             # Pydantic defaults — all non-None. Without this guard, a\n450:             # heuristic-fallback redelivery (LLM outage during a\n451:             # storage 5xx retry) would clobber real LLM-produced PII\n452:             # detection + recall hints + tags that an earlier\n453:             # successful run wrote. The ``llm_ms > 0`` proxy is the\n454:             # same one ``ts_valid_*`` uses; ``fake_enrich`` hard-codes\n455:             # ``llm_ms=0`` so the proxy is reliable.\n456:             if result.llm_ms > 0 and value is not None:\n457:                 metadata_patch[field] = value\n458:             continue\n459:         # Other metadata fields: drop the specific defaults that carry\n460:         # no information — heuristic-fallback ``\"summary\": \"\"``,\n461:         # ``\"llm_ms\": 0`` from early-return paths. Listed by value\n462:         # rather than a blanket ``if not value`` so a future\n463:         # ``dict``-typed field isn't accidentally silenced.\n464:         if value is None or value in (False, 0, \"\", []):\n465:             continue\n466:         metadata_patch[field] = value\n467:     if metadata_patch:\n468:         patch[\"metadata_patch\"] = metadata_patch\n469: \n470:     return patch\n471: \n472: \n473: async def handle_enrich_request(event: Event) -> None:\n474:     \"\"\"Process a single enrich-request event.\n475: \n476:     Mirrors :func:`handle_embed_request`'s shape: validate → reconstruct\n477:     tenant config → run enricher (3-tier fallback inside\n478:     ``common.enrichment.enrich_memory``) → PATCH result onto the row.\n479:     \"\"\"\n480:     try:\n481:         request = MemoryEnrichRequest(**event.payload)\n482:     except ValidationError:\n483:         logger.exception(\n484:             \"dropping malformed enrich-request payload\",\n485:             extra={\n486:                 \"event_type\": event.event_type,\n487:                 \"event_id\": str(event.event_id),\n488:                 \"dropped\": True,\n489:             },\n490:         )\n491:         return\n492: \n493:     if _storage_client_factory is None:\n494:         logger.error(\n495:             \"dropping enrich-request: consumer not configured\",\n496:             extra={\n497:                 \"event_id\": str(event.event_id),\n498:                 \"memory_id\": str(request.memory_id),\n499:                 \"dropped\": True,\n500:             },\n501:         )\n502:         return\n503: \n504:     storage = _storage_client_factory()\n505:     tenant_config = _build_tenant_config(request)\n506: \n507:     reference_dt = datetime.fromisoformat(request.reference_datetime) if request.reference_datetime else None\n508: \n509:     # ``enrich_memory`` never raises — it falls through to the keyword\n510:     # heuristic (``fake_enrich``) on every error path. So a transient\n511:     # provider failure can't nack-loop the subscription.\n512:     result = await enrich_memory(\n513:         request.content,\n514:         tenant_config,\n515:         reference_datetime=reference_dt,\n516:     )\n517: \n518:     patch = _build_patch(result, request.agent_provided_fields)\n519: \n520:     # Surface the sync-vs-async behavioural gap: the synchronous write\n521:     # path in ``memory_service.py`` fans ``atomic_facts`` out into\n522:     # child memories. The async worker doesn't yet — content with\n523:     # multiple distinct claims gets fewer memories on this path.\n524:     # Implementing child-memory creation in the worker requires a\n525:     # fresh embed roundtrip per child + a parent-link plumb through\n526:     # storage; tracked separately.\n527:     #\n528:     # Logged at WARNING (not ERROR): the gap is real but expected\n529:     # under the current PR scope, and ERROR-paging on every multi-fact\n530:     # write would drown the on-call alert channel without giving them\n531:     # an actionable fix. The follow-up ticket reference makes the gap\n532:     # discoverable; a dashboard counter on the WARNING string lets\n533:     # operators quantify exposure.\n534:     if result.atomic_facts:\n535:         logger.warning(\n536:             \"enrich-request for memory %s produced %d atomic_facts; \"\n537:             \"child-memory creation not yet implemented in async path \"\n538:             \"(tracked: CAURA-595 follow-up) — secondary facts will \"\n539:             \"NOT appear as child memories\",\n540:             request.memory_id,\n541:             len(result.atomic_facts),\n542:         )\n543: \n544:     # Per-tenant slot scoped to the PATCH only; matches the embed\n545:     # consumer above. The LLM enrichment call upstream is the\n546:     # expensive step but doesn't touch the storage-writer pool.\n547:     async with per_tenant_storage_slot(request.tenant_id):\n548:         await update_memory_enrichment(\n549:             storage,\n550:             memory_id=request.memory_id,\n551:             tenant_id=request.tenant_id,\n552:             fields=patch,\n553:         )\n554: \n555:     # Back-channel: announce successful enrichment so core-api (or any\n556:     # other subscriber) can react. Best-effort — a publish failure\n557:     # MUST NOT nack the upstream PATCH that already succeeded; the\n558:     # enrichment is durable in storage either way. ``logger.exception``\n559:     # captures the failure for alerting; the consumer returns\n560:     # successfully so Pub/Sub acks the input event.\n561:     try:\n562:         await publish_memory_enriched(\n563:             memory_id=request.memory_id,\n564:             tenant_id=request.tenant_id,\n565:             content=request.content,\n566:             retrieval_hint=result.retrieval_hint or \"\",\n567:         )\n568:     except Exception:\n569:         logger.exception(\n570:             \"enriched back-channel publish failed; ack-continuing\",\n571:             extra={\n572:                 \"memory_id\": str(request.memory_id),\n573:                 \"tenant_id\": request.tenant_id,\n574:             },\n575:         )\n576: \n577:     logger.info(\n578:         \"enrich-request processed\",\n579:         extra={\n580:             \"memory_id\": str(request.memory_id),\n581:             \"tenant_id\": request.tenant_id,\n582:             \"provider\": request.enrichment_provider or \"platform\",\n583:             \"memory_type\": result.memory_type,\n584:             \"llm_ms\": result.llm_ms,\n585:         },\n586:     )\n587: \n588: \n589: class _SuppressionAdapter(SuppressionStorageAdapter):\n590:     \"\"\"Thin adapter wiring :func:`upsert_tenant_suppression` into the\n591:     shared :class:`SuppressionStorageAdapter` contract (CAURA-694).\n592: \n593:     Lives in the consumer module rather than ``clients/`` so the lazy\n594:     storage-client lookup (``_storage_client_factory``) stays bound to\n595:     the consumer's ``configure`` entry point — same pattern the embed\n596:     + enrich handlers use to reach the storage client.\n597:     \"\"\"\n598: \n599:     async def set_tenant_suppression(self, *, tenant_id: str, action: str, updated_by: str | None) -> None:\n600:         if _storage_client_factory is None:\n601:             raise RuntimeError(\"consumer.configure() must run before register_consumers()\")\n602:         client = _storage_client_factory()\n603:         await upsert_tenant_suppression(\n604:             client,\n605:             tenant_id=tenant_id,\n606:             action=action,\n607:             updated_by=updated_by,\n608:         )\n609: \n610: \n611: def register_consumers() -> None:\n612:     \"\"\"Wire the consumers into the event bus.\n613: \n614:     Called once at app startup, before ``bus.start()`` — the Pub/Sub\n615:     backend spawns its pull loops in ``start()`` based on the current\n616:     handler registry, so a late ``subscribe()`` would silently orphan\n617:     the handler.\n618:     \"\"\"\n619:     bus = get_event_bus()\n620:     bus.subscribe(Topics.Memory.EMBED_REQUESTED, handle_embed_request)\n621:     bus.subscribe(Topics.Memory.ENRICH_REQUESTED, handle_enrich_request)\n622:     # CAURA-694: register the org-suppression mirror handler. Subscribing\n623:     # here keeps the registration order single-file rather than scattered\n624:     # across multiple ``register_*`` entry points.\n625:     register_suppression_consumer(_SuppressionAdapter())\n\n(End of file - total 625 lines)\n</content>","metadata":{"preview":"def _build_patch(\n    result: EnrichmentResult,\n    agent_provided_fields: list[str] | None = None,\n) -> dict:\n    \"\"\"Translate an ``EnrichmentResult`` into the storage PATCH body.\n\n    ORM-column fields go at the top level; metadata fields land under\n    ``metadata_patch`` for the storage layer's atomic JSONB merge.\n\n    ``agent_provided_fields`` is the publisher's snapshot of which\n    columns the agent set explicitly at write time. Those fields are\n    excluded from the PATCH so a redelivery (or a slow worker run)\n    can't downgrade an agent-provided ``weight=0.9`` back to\n    ``EnrichmentResult.weight``'s default of ``0.7``. Critical because\n    Pydantic defaults survive ``exclude_none=True`` — every event\n    technically carries values for ``memory_type``, ``weight``,\n    ``status``.\n\n    ``ts_valid_*`` are emitted as ISO strings (``model_dump(mode=\"json\")``).\n    asyncpg requires datetime instances for ``DateTime(timezone=True)``","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py","text":"def _build_patch(\n    result: EnrichmentResult,\n    agent_provided_fields: list[str] | None = None,\n) -> dict:\n    \"\"\"Translate an ``EnrichmentResult`` into the storage PATCH body.\n\n    ORM-column fields go at the top level; metadata fields land under\n    ``metadata_patch`` for the storage layer's atomic JSONB merge.\n\n    ``agent_provided_fields`` is the publisher's snapshot of which\n    columns the agent set explicitly at write time. Those fields are\n    excluded from the PATCH so a redelivery (or a slow worker run)\n    can't downgrade an agent-provided ``weight=0.9`` back to\n    ``EnrichmentResult.weight``'s default of ``0.7``. Critical because\n    Pydantic defaults survive ``exclude_none=True`` — every event\n    technically carries values for ``memory_type``, ``weight``,\n    ``status``.\n\n    ``ts_valid_*`` are emitted as ISO strings (``model_dump(mode=\"json\")``).\n    asyncpg requires datetime instances for ``DateTime(timezone=True)``\n    columns and rejects ISO strings with ``CannotCoerceError``, so the\n    storage layer's ``PATCH /memories/{id}`` route calls\n    ``_parse_datetimes(body)`` at the API boundary to coerce these\n    fields before the SQL UPDATE runs (mirrors the POST route's\n    pre-existing parse step). Keeping the worker's payload as ISO\n    strings keeps it JSON-serialisable end-to-end (httpx ``json=``\n    falls back to stdlib ``json.dumps`` which can't serialise\n    ``datetime``); the coercion lives at the storage boundary\n    rather than per-publisher. This was a real production bug\n    until 2026-04-26 — see PR <CAURA-595-ts-valid-iso-coercion>.\n    \"\"\"\n    skip = frozenset(agent_provided_fields or ())\n    dump = result.model_dump(mode=\"json\", exclude_none=True)\n\n    # ``ts_valid_*`` are semantically meaningful as ``None`` (\"this\n    # memory has no validity bounds\"), distinct from \"field absent\".\n    # ``exclude_none=True`` would silently drop them, leaving stale\n    # dates from a prior enrichment run intact in storage. Preserve\n    # them explicitly so a re-delivery (or a different LLM run that\n    # doesn't infer dates) can clear what an earlier run wrote.\n    #\n    # GUARD: only null-patch when the result came from a real LLM\n    # call (``llm_ms > 0``). The heuristic fallback (``fake_enrich``\n    # — used when the configured provider fails after retries +\n    # fallback chain exhausts) NEVER infers dates, so its absence of\n    # ``ts_valid_*`` is \"I don't know\", not \"no bounds\". Without this\n    # guard, a Pub/Sub redelivery that coincides with an LLM outage\n    # would land on the heuristic and wipe temporal bounds a prior\n    # successful run wrote — silent data loss with no log surface.\n    if result.llm_ms > 0:\n        for ts_field in (\"ts_valid_start\", \"ts_valid_end\"):\n            if ts_field not in skip and ts_field not in dump:\n                dump[ts_field] = None\n\n    patch: dict = {}\n    for field in _ENRICHMENT_ORM_FIELDS:\n        if field in skip:\n            continue\n        if field in dump:\n            value = dump[field]\n            # Empty title from the LLM (or from ``fake_enrich`` for\n            # very short content) shouldn't clobber a previously-\n            # stored valid title. Other ORM fields (``memory_type``,\n            # ``weight``, ``status``) have schema defaults that\n            # ``EnrichmentResult`` always emits — those go through\n            # ``agent_provided_fields`` for the gate. ``title`` has\n            # no agent-side counterpart (it's enricher-only output)\n            # and no useful default — empty == \"didn't infer\".\n            if field == \"title\" and value == \"\":\n                continue\n            patch[field] = value\n\n    # The hot-path writer set ``metadata.enrichment_pending=true`` when\n    # deferring; clear it unconditionally on every successful worker\n    # PATCH so a read-after-success returns clean state. Pre-seeds the\n    # patch dict so the ``if metadata_patch:`` gate below always fires\n    # (when heuristic fallback produces no real metadata fields, this\n    # seed ensures the PATCH still goes out and clears the stale flag\n    # — without it, a fallback redelivery would silently keep the row\n    # marked pending forever). Storage's JSONB ``||`` merge overwrites\n    # a prior ``True`` with ``False`` cleanly.\n    metadata_patch: dict = {\"enrichment_pending\": False}\n    for field in _ENRICHMENT_METADATA_FIELDS:\n        if field in skip:\n            continue\n        value = dump.get(field)\n        if field in _ENRICHMENT_ALWAYS_WRITE_METADATA:\n            # Same ``llm_ms > 0`` guard as ``ts_valid_*`` above:\n            # ``fake_enrich`` returns ``contains_pii=False``,\n            # ``pii_types=[]``, ``tags=[]``, ``retrieval_hint=\"\"`` as\n            # Pydantic defaults — all non-None. Without this guard, a\n            # heuristic-fallback redelivery (LLM outage during a\n            # storage 5xx retry) would clobber real LLM-produced PII\n            # detection + recall hints + tags that an earlier\n            # successful run wrote. The ``llm_ms > 0`` proxy is the\n            # same one ``ts_valid_*`` uses; ``fake_enrich`` hard-codes\n            # ``llm_ms=0`` so the proxy is reliable.\n            if result.llm_ms > 0 and value is not None:\n                metadata_patch[field] = value\n            continue\n        # Other metadata fields: drop the specific defaults that carry\n        # no information — heuristic-fallback ``\"summary\": \"\"``,\n        # ``\"llm_ms\": 0`` from early-return paths. Listed by value\n        # rather than a blanket ``if not value`` so a future\n        # ``dict``-typed field isn't accidentally silenced.\n        if value is None or value in (False, 0, \"\", []):\n            continue\n        metadata_patch[field] = value\n    if metadata_patch:\n        patch[\"metadata_patch\"] = metadata_patch\n\n    return patch\n\n\nasync def handle_enrich_request(event: Event) -> None:\n    \"\"\"Process a single enrich-request event.\n\n    Mirrors :func:`handle_embed_request`'s shape: validate → reconstruct\n    tenant config → run enricher (3-tier fallback inside\n    ``common.enrichment.enrich_memory``) → PATCH result onto the row.\n    \"\"\"\n    try:\n        request = MemoryEnrichRequest(**event.payload)\n    except ValidationError:\n        logger.exception(\n            \"dropping malformed enrich-request payload\",\n            extra={\n                \"event_type\": event.event_type,\n                \"event_id\": str(event.event_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    if _storage_client_factory is None:\n        logger.error(\n            \"dropping enrich-request: consumer not configured\",\n            extra={\n                \"event_id\": str(event.event_id),\n                \"memory_id\": str(request.memory_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    storage = _storage_client_factory()\n    tenant_config = _build_tenant_config(request)\n\n    reference_dt = datetime.fromisoformat(request.reference_datetime) if request.reference_datetime else None\n\n    # ``enrich_memory`` never raises — it falls through to the keyword\n    # heuristic (``fake_enrich``) on every error path. So a transient\n    # provider failure can't nack-loop the subscription.\n    result = await enrich_memory(\n        request.content,\n        tenant_config,\n        reference_datetime=reference_dt,\n    )\n\n    patch = _build_patch(result, request.agent_provided_fields)\n\n    # Surface the sync-vs-async behavioural gap: the synchronous write\n    # path in ``memory_service.py`` fans ``atomic_facts`` out into\n    # child memories. The async worker doesn't yet — content with\n    # multiple distinct claims gets fewer memories on this path.\n    # Implementing child-memory creation in the worker requires a\n    # fresh embed roundtrip per child + a parent-link plumb through\n    # storage; tracked separately.\n    #\n    # Logged at WARNING (not ERROR): the gap is real but expected\n    # under the current PR scope, and ERROR-paging on every multi-fact\n    # write would drown the on-call alert channel without giving them\n    # an actionable fix. The follow-up ticket reference makes the gap\n    # discoverable; a dashboard counter on the WARNING string lets\n    # operators quantify exposure.\n    if result.atomic_facts:\n        logger.warning(\n            \"enrich-request for memory %s produced %d atomic_facts; \"\n            \"child-memory creation not yet implemented in async path \"\n            \"(tracked: CAURA-595 follow-up) — secondary facts will \"\n            \"NOT appear as child memories\",\n            request.memory_id,\n            len(result.atomic_facts),\n        )\n\n    # Per-tenant slot scoped to the PATCH only; matches the embed\n    # consumer above. The LLM enrichment call upstream is the\n    # expensive step but doesn't touch the storage-writer pool.\n    async with per_tenant_storage_slot(request.tenant_id):\n        await update_memory_enrichment(\n            storage,\n            memory_id=request.memory_id,\n            tenant_id=request.tenant_id,\n            fields=patch,\n        )\n\n    # Back-channel: announce successful enrichment so core-api (or any\n    # other subscriber) can react. Best-effort — a publish failure\n    # MUST NOT nack the upstream PATCH that already succeeded; the\n    # enrichment is durable in storage either way. ``logger.exception``\n    # captures the failure for alerting; the consumer returns\n    # successfully so Pub/Sub acks the input event.\n    try:\n        await publish_memory_enriched(\n            memory_id=request.memory_id,\n            tenant_id=request.tenant_id,\n            content=request.content,\n            retrieval_hint=result.retrieval_hint or \"\",\n        )\n    except Exception:\n        logger.exception(\n            \"enriched back-channel publish failed; ack-continuing\",\n            extra={\n                \"memory_id\": str(request.memory_id),\n                \"tenant_id\": request.tenant_id,\n            },\n        )\n\n    logger.info(\n        \"enrich-request processed\",\n        extra={\n            \"memory_id\": str(request.memory_id),\n            \"tenant_id\": request.tenant_id,\n            \"provider\": request.enrichment_provider or \"platform\",\n            \"memory_type\": result.memory_type,\n            \"llm_ms\": result.llm_ms,\n        },\n    )\n\n\nclass _SuppressionAdapter(SuppressionStorageAdapter):\n    \"\"\"Thin adapter wiring :func:`upsert_tenant_suppression` into the\n    shared :class:`SuppressionStorageAdapter` contract (CAURA-694).\n\n    Lives in the consumer module rather than ``clients/`` so the lazy\n    storage-client lookup (``_storage_client_factory``) stays bound to\n    the consumer's ``configure`` entry point — same pattern the embed\n    + enrich handlers use to reach the storage client.\n    \"\"\"\n\n    async def set_tenant_suppression(self, *, tenant_id: str, action: str, updated_by: str | None) -> None:\n        if _storage_client_factory is None:\n            raise RuntimeError(\"consumer.configure() must run before register_consumers()\")\n        client = _storage_client_factory()\n        await upsert_tenant_suppression(\n            client,\n            tenant_id=tenant_id,\n            action=action,\n            updated_by=updated_by,\n        )\n\n\ndef register_consumers() -> None:\n    \"\"\"Wire the consumers into the event bus.\n\n    Called once at app startup, before ``bus.start()`` — the Pub/Sub\n    backend spawns its pull loops in ``start()`` based on the current\n    handler registry, so a late ``subscribe()`` would silently orphan\n    the handler.\n    \"\"\"\n    bus = get_event_bus()\n    bus.subscribe(Topics.Memory.EMBED_REQUESTED, handle_embed_request)\n    bus.subscribe(Topics.Memory.ENRICH_REQUESTED, handle_enrich_request)\n    # CAURA-694: register the org-suppression mirror handler. Subscribing\n    # here keeps the registration order single-file rather than scattered\n    # across multiple ``register_*`` entry points.\n    register_suppression_consumer(_SuppressionAdapter())","lineStart":359,"lineEnd":625,"totalLines":625,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/consumer.py","time":{"start":1780728840119,"end":1780728840123}},"metadata":{"openai":{"itemId":"fc_001872bc89af9832016a23c407cf6c8191b685866e721512d3"}},"id":"prt_e9bb5bfa9001UfuI8GFELZp5FP","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T"}}
{"type":"tool_use","timestamp":1780728840158,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_FY1U4v6h39azA4su6DEW9gQi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"PostgreSQL service -- all database queries for core tables.\n2: \n3: Single point of DB access for the OSS core-storage-api.  Every query that\n4: was previously spread across eight repository classes now lives here, grouped\n5: by domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n6: \n7: Session management uses a module-level ``async_sessionmaker`` backed by the\n8: shared engine from ``core_storage_api.database.init.get_engine``.\n9: \"\"\"\n10: \n11: from __future__ import annotations\n12: \n13: import json\n14: import logging\n15: from collections import OrderedDict\n16: from collections.abc import AsyncIterator, Sequence\n17: from contextlib import asynccontextmanager\n18: from datetime import UTC, datetime, timedelta\n19: from types import SimpleNamespace\n20: from typing import Any\n21: from uuid import UUID\n22: \n23: from sqlalchemy import and_, case, delete, false, func, literal_column, or_, select, text, tuple_\n24: from sqlalchemy import update as sql_update\n25: from sqlalchemy.dialects.postgresql import insert as pg_insert\n26: from sqlalchemy.exc import IntegrityError\n27: from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker\n28: from sqlalchemy.orm import load_only\n29: \n30: from common.constants import (\n31:     CONTRADICTION_CANDIDATE_MAX,\n32:     CONTRADICTION_SIMILARITY_THRESHOLD,\n33:     DEFAULT_RELATION_TYPE_WEIGHT,\n34:     ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n35:     GRAPH_MAX_HOPS,\n36:     RECALL_BOOST_SCALE,\n37:     RELATION_TYPE_WEIGHTS,\n38:     SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n39:     SEMANTIC_DEDUP_THRESHOLD,\n40:     TYPE_DECAY_DAYS,\n41: )\n42: from common.events.lifecycle_purge_request import MEMORY_RETENTION_MAX_DAYS\n43: from common.models import (\n44:     Agent,\n45:     AuditLog,\n46:     BackgroundTaskLog,\n47:     CrystallizationReport,\n48:     DedupReview,\n49:     Document,\n50:     Entity,\n51:     FleetCommand,\n52:     FleetNode,\n53:     IdempotencyResponse,\n54:     LifecycleAudit,\n55:     Memory,\n56:     MemoryEntityLink,\n57:     Relation,\n58: )\n59: from core_storage_api.observability import db_measure\n60: \n61: logger = logging.getLogger(__name__)\n62: \n63: # ---------------------------------------------------------------------------\n64: # Session factories (singletons)\n65: # ---------------------------------------------------------------------------\n66: #\n67: # Two factories bound to two engines: writer (primary) and reader\n68: # (replica when ``read_database_url`` is set, else the primary). The\n69: # factories are lazy so tests can swap the underlying engines before\n70: # the first request without touching service-module state.\n71: \n72: _session_factory: async_sessionmaker[AsyncSession] | None = None\n73: _read_session_factory: async_sessionmaker[AsyncSession] | None = None\n74: \n75: \n76: def _get_session_factory() -> async_sessionmaker[AsyncSession]:\n77:     global _session_factory\n78:     if _session_factory is None:\n79:         from core_storage_api.database.init import get_engine\n80: \n81:         _session_factory = async_sessionmaker(\n82:             get_engine(),\n83:             expire_on_commit=False,\n84:         )\n85:     return _session_factory\n86: \n87: \n88: def _get_read_session_factory() -> async_sessionmaker[AsyncSession]:\n89:     global _read_session_factory\n90:     if _read_session_factory is None:\n91:         from core_storage_api.database.init import get_read_engine\n92: \n93:         _read_session_factory = async_sessionmaker(\n94:             get_read_engine(),\n95:             expire_on_commit=False,\n96:         )\n97:     return _read_session_factory\n98: \n99: \n100: @asynccontextmanager\n101: async def get_session() -> AsyncIterator[AsyncSession]:\n102:     \"\"\"Transactional writer session; commits on success, rolls back on error.\"\"\"\n103:     factory = _get_session_factory()\n104:     async with factory() as session:\n105:         async with session.begin():\n106:             yield session\n107: \n108: \n109: @asynccontextmanager\n110: async def get_read_session() -> AsyncIterator[AsyncSession]:\n111:     \"\"\"Reader session — no explicit transaction wrapper since these are\n112:     query-only paths. Routes to the replica engine when\n113:     ``settings.read_database_url`` is set; otherwise shares the primary\n114:     pool (OSS standalone — unchanged behavior).\n115: \n116:     Do NOT use for read-your-writes flows inside a single request; use\n117:     :func:`get_session` for those so the read sees the same transaction\n118:     scope as the write.\n119:     \"\"\"\n120:     factory = _get_read_session_factory()\n121:     async with factory() as session:\n122:         yield session\n123: \n124: \n125: # ---------------------------------------------------------------------------\n126: # Helpers\n127: # ---------------------------------------------------------------------------\n128: \n129: \n130: def _scope_sql(\n131:     tenant_id: str,\n132:     fleet_id: str | None,\n133:     table: str = \"m\",\n134: ) -> tuple[str, dict]:\n135:     \"\"\"Build a WHERE clause fragment for tenant + optional fleet scoping.\"\"\"\n136:     clause = f\"{table}.tenant_id = :tenant_id\"\n137:     params: dict = {\"tenant_id\": tenant_id}\n138:     if fleet_id is not None:\n139:         clause += f\" AND {table}.fleet_id = :fleet_id\"\n140:         params[\"fleet_id\"] = fleet_id\n141:     return clause, params\n142: \n143: \n144: def _relation_weight(relation_type: str, row_weight: float) -> float:\n145:     \"\"\"Compute effective weight for a relation edge.\"\"\"\n146:     type_w = RELATION_TYPE_WEIGHTS.get(\n147:         relation_type.lower(),\n148:         DEFAULT_RELATION_TYPE_WEIGHT,\n149:     )\n150:     return type_w * row_weight\n151: \n152: \n153: # Cached at import time so the per-row column-name filter on the bulk\n154: # write hot path (100 items x ~25 columns) doesn't pay the cost of\n155: # walking ``Memory.__table__.columns`` and ``__mapper__.column_attrs``\n156: # on every call. Both sets are static for the lifetime of the process.\n157: _MEMORY_VALID_FIELDS = frozenset(\n158:     {c.key for c in Memory.__table__.columns} | {a.key for a in Memory.__mapper__.column_attrs}\n159: )\n160: \n161: \n162: # ── Org hard-delete purge (CAURA-689) ──\n163: #\n164: # Tables wiped when an organization is permanently deleted. Ordered\n165: # children-before-parents so the per-table DELETEs never trip a foreign\n166: # key. Tables WITHOUT their own ``tenant_id`` column (``memory_entity_links``)\n167: # are not listed — they're removed by the ON DELETE CASCADE from\n168: # ``memories`` / ``entities``. ``relations`` and ``fleet_commands`` are\n169: # listed explicitly (ahead of their parents) so their per-table counts are\n170: # reported rather than hidden inside a cascade.\n171: _PURGE_TENANT_TABLES: tuple[str, ...] = (\n172:     \"relations\",\n173:     \"fleet_commands\",\n174:     \"memories\",\n175:     \"entities\",\n176:     \"agents\",\n177:     \"fleet_nodes\",\n178:     \"audit_log\",\n179:     \"documents\",\n180:     \"analysis_reports\",\n181:     \"dedup_reviews\",\n182:     \"background_task_log\",\n183:     \"idempotency_responses\",\n184: )\n185: # OSS keys these by ``org_id``, which equals the tenant id in the\n186: # single-key-per-tenant OSS model (CAURA-654). ``lifecycle_audit`` is\n187: # deliberately NOT purged: it's the operational audit trail (including\n188: # the hard-delete-org row itself), so wiping it would erase the record\n189: # of the very deletion being performed.\n190: _PURGE_ORG_KEYED_TABLES: tuple[str, ...] = (\n191:     \"organization_settings\",\n192:     \"organization_settings_audit\",\n193: )\n194: \n195: # ── Fleet-scoped hard-purge (test-tenant hygiene) ──\n196: #\n197: # The subset of ``_PURGE_TENANT_TABLES`` that carries its own ``fleet_id``\n198: # column, so a single fleet's footprint can be permanently removed from a\n199: # SHARED tenant without touching the rest of the tenant. Used by the\n200: # OpenClaw fleet-tester to clean up its run-scoped ``nightly-<run_id>-fleet-NN``\n201: # fleets at teardown (the dev tenant otherwise accumulates run data that\n202: # confounds isolation/trust tests). Ordered children-before-parents so the\n203: # per-table DELETEs never trip a foreign key.\n204: #\n205: # ``fleet_commands`` is intentionally NOT in this tuple — it has no\n206: # ``fleet_id`` of its own (it's keyed by ``node_id``); ``purge_fleet_data``\n207: # deletes it explicitly by the fleet's node ids before the nodes go, so its\n208: # count is reported rather than hidden inside the ``fleet_nodes`` ON DELETE\n209: # CASCADE. ``memory_entity_links`` (no ``fleet_id``) rides the CASCADE from\n210: # ``memories`` / ``entities``. Tenant-wide tables (``audit_log``,\n211: # ``background_task_log``, ``idempotency_responses``, ``organization_settings*``)\n212: # are excluded — they're tenant config or the retained audit trail, not\n213: # fleet-scoped run data.\n214: _PURGE_FLEET_TABLES: tuple[str, ...] = (\n215:     \"relations\",\n216:     \"memories\",\n217:     \"entities\",\n218:     \"agents\",\n219:     \"fleet_nodes\",\n220:     \"documents\",\n221:     \"analysis_reports\",\n222:     \"dedup_reviews\",\n223: )\n224: \n225: \n226: # ═══════════════════════════════════════════════════════════════════════════\n227: # PostgresService\n228: # ═══════════════════════════════════════════════════════════════════════════\n229: \n230: \n231: class PostgresService:\n232:     \"\"\"Single point of DB access for all core tables.\n233: \n234:     Every public method acquires its own session via ``get_session()``.\n235:     Callers never need to manage sessions or transactions.\n236:     \"\"\"\n237: \n238:     # ══════════════════════════════════════════════════════════════════════\n239:     #  MEMORIES\n240:     # ══════════════════════════════════════════════════════════════════════\n241: \n242:     # ------------------------------------------------------------------\n243:     # A) Core CRUD\n244:     # ------------------------------------------------------------------\n245: \n246:     async def memory_get_by_id(self, memory_id: UUID) -> Memory | None:\n247:         # Wrap the full session block so db_ms includes connection-pool\n248:         # wait time — a saturated pool shows up as slow \"DB\" here, which\n249:         # is exactly how we want to see it in Cloud Logging.\n250:         with db_measure():\n251:             async with get_read_session() as session:\n252:                 return await session.get(Memory, memory_id)\n253: \n254:     async def memory_get_by_id_for_tenant(\n255:         self,\n256:         memory_id: UUID,\n257:         tenant_id: str,\n258:     ) -> Memory | None:\n259:         with db_measure():\n260:             async with get_read_session() as session:\n261:                 memory = await session.get(Memory, memory_id)\n262:                 if memory is None or memory.tenant_id != tenant_id or memory.deleted_at is not None:\n263:                     return None\n264:                 return memory\n265: \n266:     @staticmethod\n267:     def _filter_fields(model_cls, data: dict) -> dict:\n268:         valid = {c.key for c in model_cls.__table__.columns}\n269:         return {k: v for k, v in data.items() if k in valid}\n270: \n271:     @staticmethod\n272:     def _filter_memory_fields(data: dict) -> dict:\n273:         return {k: v for k, v in data.items() if k in _MEMORY_VALID_FIELDS}\n274: \n275:     async def memory_add(self, data: dict) -> Memory:\n276:         async with get_session() as session:\n277:             memory = Memory(**self._filter_memory_fields(data))\n278:             session.add(memory)\n279:             await session.flush()\n280:             return memory\n281: \n282:     async def memory_add_all(self, items: list[dict]) -> list[dict]:\n283:         \"\"\"Insert with per-attempt idempotency (CAURA-602).\n284: \n285:         Every item must carry a non-empty ``client_request_id``. Callers\n286:         on the bulk-write path derive it from the\n287:         ``X-Bulk-Attempt-Id`` header (``f\"{attempt_id}:{index}\"``);\n288:         server-internal callers (auto-chunk, atomic-facts) generate a\n289:         UUID per item. Partial unique\n290:         ``ix_memories_attempt_unique`` makes a retry of the same logical\n291:         attempt deterministic: rows already committed by a prior call\n292:         are detected via ``ON CONFLICT DO NOTHING`` and returned with\n293:         ``was_inserted=False`` and the canonical row id, instead of\n294:         being silently re-inserted or vanishing because the response\n295:         was lost mid-flight.\n296: \n297:         Returns one entry per input item, **in input order**:\n298: \n299:             ``{client_request_id, id, was_inserted}``\n300: \n301:         ``id`` is ``None`` only in the pathological case where the\n302:         item was neither inserted nor found on a follow-up read — e.g.\n303:         a concurrent soft-delete between INSERT and SELECT, or the\n304:         unresolved row drifted out of scope. The caller surfaces those\n305:         as per-item errors.\n306:         \"\"\"\n307:         if not items:\n308:             return []\n309: \n310:         for d in items:\n311:             if not d.get(\"client_request_id\"):\n312:                 # Required at this layer so the partial-unique guarantee\n313:                 # holds for every row. Routing the rejection here, rather\n314:                 # than at the FastAPI route, also catches in-process\n315:                 # callers (auto-chunk via ``sc.create_memories``) that\n316:                 # forgot to mint an id.\n317:                 raise ValueError(\"memory_add_all: every item must carry client_request_id\")\n318: \n319:         # All callers send a single-tenant, single-fleet batch (the\n320:         # bulk endpoint is tenant-and-fleet-scoped on the way in). Pin\n321:         # the post-conflict re-query to BOTH dimensions so an attacker\n322:         # who learned a foreign ``client_request_id`` can't read\n323:         # across tenants OR fleets by sneaking it into an items list,\n324:         # and so the re-query window matches the unique index's scope\n325:         # ``(tenant_id, COALESCE(fleet_id, ''), client_request_id)``\n326:         # exactly. Validating up-front keeps the invariant explicit\n327:         # instead of relying on the upstream schema.\n328:         tenant_id = items[0][\"tenant_id\"]\n329:         fleet_id = items[0].get(\"fleet_id\")\n330:         if any(d.get(\"tenant_id\") != tenant_id for d in items):\n331:             raise ValueError(\"memory_add_all: all items must share the same tenant_id\")\n332:         if any(d.get(\"fleet_id\") != fleet_id for d in items):\n333:             raise ValueError(\"memory_add_all: all items must share the same fleet_id\")\n334: \n335:         async with get_session() as session:\n336:             rows = [self._filter_memory_fields(d) for d in items]\n337:             # The conflict target must mirror ``ix_memories_attempt_unique``\n338:             # *expression-for-expression* — the planner only treats the\n339:             # ON CONFLICT and the partial-unique index as matched if every\n340:             # element is byte-equivalent, including the ``COALESCE`` over\n341:             # nullable ``fleet_id``. Stripping the COALESCE here would\n342:             # silently fall back to \"no inferred constraint\" and double-\n343:             # insert on retry for fleetless attempts.\n344:             stmt = (\n345:                 pg_insert(Memory)\n346:                 .values(rows)\n347:                 .on_conflict_do_nothing(\n348:                     # ``text(\"COALESCE(fleet_id, '')\")`` matches migration\n349:                     # 007's CREATE INDEX SQL character-for-character.\n350:                     # ``func.coalesce(Memory.fleet_id, \"\")`` works today\n351:                     # via Postgres conflict-inference normalisation\n352:                     # (which strips table qualifiers), but pinning the\n353:                     # raw text removes the dependency on that\n354:                     # normalisation behaviour across SQLAlchemy + asyncpg\n355:                     # versions. A future renderer change that emits\n356:                     # ``coalesce(memories.fleet_id, '')`` *would* still\n357:                     # match today, but if the planner ever returns \"no\n358:                     # unique constraint matches the ON CONFLICT\n359:                     # specification\" the silent-create class re-emerges\n360:                     # as a 500-on-every-retry. The model-level Index in\n361:                     # ``common/models/memory.py`` uses the same text()\n362:                     # form for the same reason.\n363:                     index_elements=[\n364:                         Memory.tenant_id,\n365:                         text(\"COALESCE(fleet_id, '')\"),\n366:                         Memory.client_request_id,\n367:                     ],\n368:                     index_where=text(\"deleted_at IS NULL AND client_request_id IS NOT NULL\"),\n369:                 )\n370:                 .returning(Memory.id, Memory.client_request_id)\n371:             )\n372:             inserted: dict[str, UUID] = {\n373:                 row.client_request_id: row.id for row in (await session.execute(stmt)).all()\n374:             }\n375: \n376:             # Items the conflict swallowed already exist — committed by a\n377:             # prior attempt with the same ``X-Bulk-Attempt-Id``. Re-read\n378:             # their canonical ids in the same session so the caller can\n379:             # surface ``duplicate_attempt`` instead of dropping them.\n380:             unresolved = [d[\"client_request_id\"] for d in items if d[\"client_request_id\"] not in inserted]\n381:             existing: dict[str, UUID] = {}\n382:             if unresolved:\n383:                 # Chunk the IN-list to keep the parameter count well below\n384:                 # asyncpg's 32k bind-arg ceiling. 500 mirrors the bulk\n385:                 # batch ceiling so a single-batch retry is one query;\n386:                 # larger calls (auto-chunk) split cleanly.\n387:                 fleet_predicate = (\n388:                     Memory.fleet_id == fleet_id if fleet_id is not None else Memory.fleet_id.is_(None)\n389:                 )\n390:                 for chunk_start in range(0, len(unresolved), 500):\n391:                     chunk = unresolved[chunk_start : chunk_start + 500]\n392:                     result = await session.execute(\n393:                         select(Memory.id, Memory.client_request_id).where(\n394:                             Memory.tenant_id == tenant_id,\n395:                             fleet_predicate,\n396:                             Memory.client_request_id.in_(chunk),\n397:                             Memory.deleted_at.is_(None),\n398:                         )\n399:                     )\n400:                     for row in result.all():\n401:                         existing[row.client_request_id] = row.id\n402: \n403:         out: list[dict] = []\n404:         for d in items:\n405:             crid = d[\"client_request_id\"]\n406:             if crid in inserted:\n407:                 out.append({\"client_request_id\": crid, \"id\": str(inserted[crid]), \"was_inserted\": True})\n408:             elif crid in existing:\n409:                 out.append({\"client_request_id\": crid, \"id\": str(existing[crid]), \"was_inserted\": False})\n410:             else:\n411:                 # Soft-delete or schema-skew edge case: the row was neither\n412:                 # newly inserted nor visible on the follow-up read. ``id``\n413:                 # is None so the core-api layer surfaces this as a\n414:                 # per-item error rather than fabricating an id.\n415:                 out.append({\"client_request_id\": crid, \"id\": None, \"was_inserted\": False})\n416:         return out\n417: \n418:     async def memory_soft_delete(self, memory_id: UUID) -> None:\n419:         async with get_session() as session:\n420:             memory = await session.get(Memory, memory_id)\n\n(Showing lines 1-420 of 4754. Use offset=421 to continue.)\n</content>","metadata":{"preview":"\"\"\"PostgreSQL service -- all database queries for core tables.\n\nSingle point of DB access for the OSS core-storage-api.  Every query that\nwas previously spread across eight repository classes now lives here, grouped\nby domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n\nSession management uses a module-level ``async_sessionmaker`` backed by the\nshared engine from ``core_storage_api.database.init.get_engine``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nfrom collections import OrderedDict\nfrom collections.abc import AsyncIterator, Sequence\nfrom contextlib import asynccontextmanager\nfrom datetime import UTC, datetime, timedelta\nfrom types import SimpleNamespace\nfrom typing import Any","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"\"\"\"PostgreSQL service -- all database queries for core tables.\n\nSingle point of DB access for the OSS core-storage-api.  Every query that\nwas previously spread across eight repository classes now lives here, grouped\nby domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n\nSession management uses a module-level ``async_sessionmaker`` backed by the\nshared engine from ``core_storage_api.database.init.get_engine``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nfrom collections import OrderedDict\nfrom collections.abc import AsyncIterator, Sequence\nfrom contextlib import asynccontextmanager\nfrom datetime import UTC, datetime, timedelta\nfrom types import SimpleNamespace\nfrom typing import Any\nfrom uuid import UUID\n\nfrom sqlalchemy import and_, case, delete, false, func, literal_column, or_, select, text, tuple_\nfrom sqlalchemy import update as sql_update\nfrom sqlalchemy.dialects.postgresql import insert as pg_insert\nfrom sqlalchemy.exc import IntegrityError\nfrom sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker\nfrom sqlalchemy.orm import load_only\n\nfrom common.constants import (\n    CONTRADICTION_CANDIDATE_MAX,\n    CONTRADICTION_SIMILARITY_THRESHOLD,\n    DEFAULT_RELATION_TYPE_WEIGHT,\n    ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n    GRAPH_MAX_HOPS,\n    RECALL_BOOST_SCALE,\n    RELATION_TYPE_WEIGHTS,\n    SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n    SEMANTIC_DEDUP_THRESHOLD,\n    TYPE_DECAY_DAYS,\n)\nfrom common.events.lifecycle_purge_request import MEMORY_RETENTION_MAX_DAYS\nfrom common.models import (\n    Agent,\n    AuditLog,\n    BackgroundTaskLog,\n    CrystallizationReport,\n    DedupReview,\n    Document,\n    Entity,\n    FleetCommand,\n    FleetNode,\n    IdempotencyResponse,\n    LifecycleAudit,\n    Memory,\n    MemoryEntityLink,\n    Relation,\n)\nfrom core_storage_api.observability import db_measure\n\nlogger = logging.getLogger(__name__)\n\n# ---------------------------------------------------------------------------\n# Session factories (singletons)\n# ---------------------------------------------------------------------------\n#\n# Two factories bound to two engines: writer (primary) and reader\n# (replica when ``read_database_url`` is set, else the primary). The\n# factories are lazy so tests can swap the underlying engines before\n# the first request without touching service-module state.\n\n_session_factory: async_sessionmaker[AsyncSession] | None = None\n_read_session_factory: async_sessionmaker[AsyncSession] | None = None\n\n\ndef _get_session_factory() -> async_sessionmaker[AsyncSession]:\n    global _session_factory\n    if _session_factory is None:\n        from core_storage_api.database.init import get_engine\n\n        _session_factory = async_sessionmaker(\n            get_engine(),\n            expire_on_commit=False,\n        )\n    return _session_factory\n\n\ndef _get_read_session_factory() -> async_sessionmaker[AsyncSession]:\n    global _read_session_factory\n    if _read_session_factory is None:\n        from core_storage_api.database.init import get_read_engine\n\n        _read_session_factory = async_sessionmaker(\n            get_read_engine(),\n            expire_on_commit=False,\n        )\n    return _read_session_factory\n\n\n@asynccontextmanager\nasync def get_session() -> AsyncIterator[AsyncSession]:\n    \"\"\"Transactional writer session; commits on success, rolls back on error.\"\"\"\n    factory = _get_session_factory()\n    async with factory() as session:\n        async with session.begin():\n            yield session\n\n\n@asynccontextmanager\nasync def get_read_session() -> AsyncIterator[AsyncSession]:\n    \"\"\"Reader session — no explicit transaction wrapper since these are\n    query-only paths. Routes to the replica engine when\n    ``settings.read_database_url`` is set; otherwise shares the primary\n    pool (OSS standalone — unchanged behavior).\n\n    Do NOT use for read-your-writes flows inside a single request; use\n    :func:`get_session` for those so the read sees the same transaction\n    scope as the write.\n    \"\"\"\n    factory = _get_read_session_factory()\n    async with factory() as session:\n        yield session\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _scope_sql(\n    tenant_id: str,\n    fleet_id: str | None,\n    table: str = \"m\",\n) -> tuple[str, dict]:\n    \"\"\"Build a WHERE clause fragment for tenant + optional fleet scoping.\"\"\"\n    clause = f\"{table}.tenant_id = :tenant_id\"\n    params: dict = {\"tenant_id\": tenant_id}\n    if fleet_id is not None:\n        clause += f\" AND {table}.fleet_id = :fleet_id\"\n        params[\"fleet_id\"] = fleet_id\n    return clause, params\n\n\ndef _relation_weight(relation_type: str, row_weight: float) -> float:\n    \"\"\"Compute effective weight for a relation edge.\"\"\"\n    type_w = RELATION_TYPE_WEIGHTS.get(\n        relation_type.lower(),\n        DEFAULT_RELATION_TYPE_WEIGHT,\n    )\n    return type_w * row_weight\n\n\n# Cached at import time so the per-row column-name filter on the bulk\n# write hot path (100 items x ~25 columns) doesn't pay the cost of\n# walking ``Memory.__table__.columns`` and ``__mapper__.column_attrs``\n# on every call. Both sets are static for the lifetime of the process.\n_MEMORY_VALID_FIELDS = frozenset(\n    {c.key for c in Memory.__table__.columns} | {a.key for a in Memory.__mapper__.column_attrs}\n)\n\n\n# ── Org hard-delete purge (CAURA-689) ──\n#\n# Tables wiped when an organization is permanently deleted. Ordered\n# children-before-parents so the per-table DELETEs never trip a foreign\n# key. Tables WITHOUT their own ``tenant_id`` column (``memory_entity_links``)\n# are not listed — they're removed by the ON DELETE CASCADE from\n# ``memories`` / ``entities``. ``relations`` and ``fleet_commands`` are\n# listed explicitly (ahead of their parents) so their per-table counts are\n# reported rather than hidden inside a cascade.\n_PURGE_TENANT_TABLES: tuple[str, ...] = (\n    \"relations\",\n    \"fleet_commands\",\n    \"memories\",\n    \"entities\",\n    \"agents\",\n    \"fleet_nodes\",\n    \"audit_log\",\n    \"documents\",\n    \"analysis_reports\",\n    \"dedup_reviews\",\n    \"background_task_log\",\n    \"idempotency_responses\",\n)\n# OSS keys these by ``org_id``, which equals the tenant id in the\n# single-key-per-tenant OSS model (CAURA-654). ``lifecycle_audit`` is\n# deliberately NOT purged: it's the operational audit trail (including\n# the hard-delete-org row itself), so wiping it would erase the record\n# of the very deletion being performed.\n_PURGE_ORG_KEYED_TABLES: tuple[str, ...] = (\n    \"organization_settings\",\n    \"organization_settings_audit\",\n)\n\n# ── Fleet-scoped hard-purge (test-tenant hygiene) ──\n#\n# The subset of ``_PURGE_TENANT_TABLES`` that carries its own ``fleet_id``\n# column, so a single fleet's footprint can be permanently removed from a\n# SHARED tenant without touching the rest of the tenant. Used by the\n# OpenClaw fleet-tester to clean up its run-scoped ``nightly-<run_id>-fleet-NN``\n# fleets at teardown (the dev tenant otherwise accumulates run data that\n# confounds isolation/trust tests). Ordered children-before-parents so the\n# per-table DELETEs never trip a foreign key.\n#\n# ``fleet_commands`` is intentionally NOT in this tuple — it has no\n# ``fleet_id`` of its own (it's keyed by ``node_id``); ``purge_fleet_data``\n# deletes it explicitly by the fleet's node ids before the nodes go, so its\n# count is reported rather than hidden inside the ``fleet_nodes`` ON DELETE\n# CASCADE. ``memory_entity_links`` (no ``fleet_id``) rides the CASCADE from\n# ``memories`` / ``entities``. Tenant-wide tables (``audit_log``,\n# ``background_task_log``, ``idempotency_responses``, ``organization_settings*``)\n# are excluded — they're tenant config or the retained audit trail, not\n# fleet-scoped run data.\n_PURGE_FLEET_TABLES: tuple[str, ...] = (\n    \"relations\",\n    \"memories\",\n    \"entities\",\n    \"agents\",\n    \"fleet_nodes\",\n    \"documents\",\n    \"analysis_reports\",\n    \"dedup_reviews\",\n)\n\n\n# ═══════════════════════════════════════════════════════════════════════════\n# PostgresService\n# ═══════════════════════════════════════════════════════════════════════════\n\n\nclass PostgresService:\n    \"\"\"Single point of DB access for all core tables.\n\n    Every public method acquires its own session via ``get_session()``.\n    Callers never need to manage sessions or transactions.\n    \"\"\"\n\n    # ══════════════════════════════════════════════════════════════════════\n    #  MEMORIES\n    # ══════════════════════════════════════════════════════════════════════\n\n    # ------------------------------------------------------------------\n    # A) Core CRUD\n    # ------------------------------------------------------------------\n\n    async def memory_get_by_id(self, memory_id: UUID) -> Memory | None:\n        # Wrap the full session block so db_ms includes connection-pool\n        # wait time — a saturated pool shows up as slow \"DB\" here, which\n        # is exactly how we want to see it in Cloud Logging.\n        with db_measure():\n            async with get_read_session() as session:\n                return await session.get(Memory, memory_id)\n\n    async def memory_get_by_id_for_tenant(\n        self,\n        memory_id: UUID,\n        tenant_id: str,\n    ) -> Memory | None:\n        with db_measure():\n            async with get_read_session() as session:\n                memory = await session.get(Memory, memory_id)\n                if memory is None or memory.tenant_id != tenant_id or memory.deleted_at is not None:\n                    return None\n                return memory\n\n    @staticmethod\n    def _filter_fields(model_cls, data: dict) -> dict:\n        valid = {c.key for c in model_cls.__table__.columns}\n        return {k: v for k, v in data.items() if k in valid}\n\n    @staticmethod\n    def _filter_memory_fields(data: dict) -> dict:\n        return {k: v for k, v in data.items() if k in _MEMORY_VALID_FIELDS}\n\n    async def memory_add(self, data: dict) -> Memory:\n        async with get_session() as session:\n            memory = Memory(**self._filter_memory_fields(data))\n            session.add(memory)\n            await session.flush()\n            return memory\n\n    async def memory_add_all(self, items: list[dict]) -> list[dict]:\n        \"\"\"Insert with per-attempt idempotency (CAURA-602).\n\n        Every item must carry a non-empty ``client_request_id``. Callers\n        on the bulk-write path derive it from the\n        ``X-Bulk-Attempt-Id`` header (``f\"{attempt_id}:{index}\"``);\n        server-internal callers (auto-chunk, atomic-facts) generate a\n        UUID per item. Partial unique\n        ``ix_memories_attempt_unique`` makes a retry of the same logical\n        attempt deterministic: rows already committed by a prior call\n        are detected via ``ON CONFLICT DO NOTHING`` and returned with\n        ``was_inserted=False`` and the canonical row id, instead of\n        being silently re-inserted or vanishing because the response\n        was lost mid-flight.\n\n        Returns one entry per input item, **in input order**:\n\n            ``{client_request_id, id, was_inserted}``\n\n        ``id`` is ``None`` only in the pathological case where the\n        item was neither inserted nor found on a follow-up read — e.g.\n        a concurrent soft-delete between INSERT and SELECT, or the\n        unresolved row drifted out of scope. The caller surfaces those\n        as per-item errors.\n        \"\"\"\n        if not items:\n            return []\n\n        for d in items:\n            if not d.get(\"client_request_id\"):\n                # Required at this layer so the partial-unique guarantee\n                # holds for every row. Routing the rejection here, rather\n                # than at the FastAPI route, also catches in-process\n                # callers (auto-chunk via ``sc.create_memories``) that\n                # forgot to mint an id.\n                raise ValueError(\"memory_add_all: every item must carry client_request_id\")\n\n        # All callers send a single-tenant, single-fleet batch (the\n        # bulk endpoint is tenant-and-fleet-scoped on the way in). Pin\n        # the post-conflict re-query to BOTH dimensions so an attacker\n        # who learned a foreign ``client_request_id`` can't read\n        # across tenants OR fleets by sneaking it into an items list,\n        # and so the re-query window matches the unique index's scope\n        # ``(tenant_id, COALESCE(fleet_id, ''), client_request_id)``\n        # exactly. Validating up-front keeps the invariant explicit\n        # instead of relying on the upstream schema.\n        tenant_id = items[0][\"tenant_id\"]\n        fleet_id = items[0].get(\"fleet_id\")\n        if any(d.get(\"tenant_id\") != tenant_id for d in items):\n            raise ValueError(\"memory_add_all: all items must share the same tenant_id\")\n        if any(d.get(\"fleet_id\") != fleet_id for d in items):\n            raise ValueError(\"memory_add_all: all items must share the same fleet_id\")\n\n        async with get_session() as session:\n            rows = [self._filter_memory_fields(d) for d in items]\n            # The conflict target must mirror ``ix_memories_attempt_unique``\n            # *expression-for-expression* — the planner only treats the\n            # ON CONFLICT and the partial-unique index as matched if every\n            # element is byte-equivalent, including the ``COALESCE`` over\n            # nullable ``fleet_id``. Stripping the COALESCE here would\n            # silently fall back to \"no inferred constraint\" and double-\n            # insert on retry for fleetless attempts.\n            stmt = (\n                pg_insert(Memory)\n                .values(rows)\n                .on_conflict_do_nothing(\n                    # ``text(\"COALESCE(fleet_id, '')\")`` matches migration\n                    # 007's CREATE INDEX SQL character-for-character.\n                    # ``func.coalesce(Memory.fleet_id, \"\")`` works today\n                    # via Postgres conflict-inference normalisation\n                    # (which strips table qualifiers), but pinning the\n                    # raw text removes the dependency on that\n                    # normalisation behaviour across SQLAlchemy + asyncpg\n                    # versions. A future renderer change that emits\n                    # ``coalesce(memories.fleet_id, '')`` *would* still\n                    # match today, but if the planner ever returns \"no\n                    # unique constraint matches the ON CONFLICT\n                    # specification\" the silent-create class re-emerges\n                    # as a 500-on-every-retry. The model-level Index in\n                    # ``common/models/memory.py`` uses the same text()\n                    # form for the same reason.\n                    index_elements=[\n                        Memory.tenant_id,\n                        text(\"COALESCE(fleet_id, '')\"),\n                        Memory.client_request_id,\n                    ],\n                    index_where=text(\"deleted_at IS NULL AND client_request_id IS NOT NULL\"),\n                )\n                .returning(Memory.id, Memory.client_request_id)\n            )\n            inserted: dict[str, UUID] = {\n                row.client_request_id: row.id for row in (await session.execute(stmt)).all()\n            }\n\n            # Items the conflict swallowed already exist — committed by a\n            # prior attempt with the same ``X-Bulk-Attempt-Id``. Re-read\n            # their canonical ids in the same session so the caller can\n            # surface ``duplicate_attempt`` instead of dropping them.\n            unresolved = [d[\"client_request_id\"] for d in items if d[\"client_request_id\"] not in inserted]\n            existing: dict[str, UUID] = {}\n            if unresolved:\n                # Chunk the IN-list to keep the parameter count well below\n                # asyncpg's 32k bind-arg ceiling. 500 mirrors the bulk\n                # batch ceiling so a single-batch retry is one query;\n                # larger calls (auto-chunk) split cleanly.\n                fleet_predicate = (\n                    Memory.fleet_id == fleet_id if fleet_id is not None else Memory.fleet_id.is_(None)\n                )\n                for chunk_start in range(0, len(unresolved), 500):\n                    chunk = unresolved[chunk_start : chunk_start + 500]\n                    result = await session.execute(\n                        select(Memory.id, Memory.client_request_id).where(\n                            Memory.tenant_id == tenant_id,\n                            fleet_predicate,\n                            Memory.client_request_id.in_(chunk),\n                            Memory.deleted_at.is_(None),\n                        )\n                    )\n                    for row in result.all():\n                        existing[row.client_request_id] = row.id\n\n        out: list[dict] = []\n        for d in items:\n            crid = d[\"client_request_id\"]\n            if crid in inserted:\n                out.append({\"client_request_id\": crid, \"id\": str(inserted[crid]), \"was_inserted\": True})\n            elif crid in existing:\n                out.append({\"client_request_id\": crid, \"id\": str(existing[crid]), \"was_inserted\": False})\n            else:\n                # Soft-delete or schema-skew edge case: the row was neither\n                # newly inserted nor visible on the follow-up read. ``id``\n                # is None so the core-api layer surfaces this as a\n                # per-item error rather than fabricating an id.\n                out.append({\"client_request_id\": crid, \"id\": None, \"was_inserted\": False})\n        return out\n\n    async def memory_soft_delete(self, memory_id: UUID) -> None:\n        async with get_session() as session:\n            memory = await session.get(Memory, memory_id)","lineStart":1,"lineEnd":420,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780728840148,"end":1780728840156}},"metadata":{"openai":{"itemId":"fc_001872bc89af9832016a23c407cf808191b40bf0bf33cce46a"}},"id":"prt_e9bb5bfbc001bzDDvFKE1zlMsW","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T"}}
{"type":"tool_use","timestamp":1780728840231,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_Lt8yQVaq42760scB90E39Ng3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_embed_request.py","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_embed_request.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Typed payload for the ``memclaw.memory.embed-requested`` topic.\n2: \n3: The publisher (core-api, write hot path under CAURA-594 full form) emits\n4: one of these per memory written with ``embedding=NULL``. The consumer\n5: (core-worker) validates the envelope's ``payload`` against this model\n6: before invoking the embedding provider — schema-drift between publisher\n7: and consumer surfaces as a Pydantic ``ValidationError`` instead of a\n8: runtime KeyError deep inside the worker.\n9: \n10: The envelope itself is :class:`common.events.base.Event`; this is just\n11: the shape of its ``payload`` dict.\n12: \"\"\"\n13: \n14: from __future__ import annotations\n15: \n16: from uuid import UUID\n17: \n18: from pydantic import BaseModel, ConfigDict, Field\n19: \n20: \n21: class MemoryEmbedRequest(BaseModel):\n22:     \"\"\"Request to compute and persist an embedding for a memory row.\n23: \n24:     Fields:\n25:         memory_id: id of the row in ``memories`` to backfill.\n26:         tenant_id: tenant scope — passed through to the storage PATCH\n27:             so the storage-side guard rejects cross-tenant updates.\n28:         content: text to embed. Carried in the event rather than fetched\n29:             from storage so the worker doesn't need a read round-trip\n30:             on the hot path.\n31:         content_hash: optional dedup key for the content-hash embedding\n32:             cache lookup before calling the provider. Skip the call if\n33:             the hash is already embedded for this tenant.\n34:     \"\"\"\n35: \n36:     model_config = ConfigDict(frozen=True, extra=\"forbid\")\n37: \n38:     memory_id: UUID\n39:     tenant_id: str\n40:     content: str = Field(min_length=1)\n41:     # ``min_length=1`` so an empty-string hash from a buggy publisher\n42:     # is rejected at validation time rather than silently skipping the\n43:     # cache lookup downstream (the consumer's ``if request.content_hash:``\n44:     # treats ``\"\"`` and ``None`` the same — explicit is better here).\n45:     content_hash: str | None = Field(default=None, min_length=1)\n\n(End of file - total 45 lines)\n</content>","metadata":{"preview":"\"\"\"Typed payload for the ``memclaw.memory.embed-requested`` topic.\n\nThe publisher (core-api, write hot path under CAURA-594 full form) emits\none of these per memory written with ``embedding=NULL``. The consumer\n(core-worker) validates the envelope's ``payload`` against this model\nbefore invoking the embedding provider — schema-drift between publisher\nand consumer surfaces as a Pydantic ``ValidationError`` instead of a\nruntime KeyError deep inside the worker.\n\nThe envelope itself is :class:`common.events.base.Event`; this is just\nthe shape of its ``payload`` dict.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom uuid import UUID\n\nfrom pydantic import BaseModel, ConfigDict, Field\n\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_embed_request.py","text":"\"\"\"Typed payload for the ``memclaw.memory.embed-requested`` topic.\n\nThe publisher (core-api, write hot path under CAURA-594 full form) emits\none of these per memory written with ``embedding=NULL``. The consumer\n(core-worker) validates the envelope's ``payload`` against this model\nbefore invoking the embedding provider — schema-drift between publisher\nand consumer surfaces as a Pydantic ``ValidationError`` instead of a\nruntime KeyError deep inside the worker.\n\nThe envelope itself is :class:`common.events.base.Event`; this is just\nthe shape of its ``payload`` dict.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom uuid import UUID\n\nfrom pydantic import BaseModel, ConfigDict, Field\n\n\nclass MemoryEmbedRequest(BaseModel):\n    \"\"\"Request to compute and persist an embedding for a memory row.\n\n    Fields:\n        memory_id: id of the row in ``memories`` to backfill.\n        tenant_id: tenant scope — passed through to the storage PATCH\n            so the storage-side guard rejects cross-tenant updates.\n        content: text to embed. Carried in the event rather than fetched\n            from storage so the worker doesn't need a read round-trip\n            on the hot path.\n        content_hash: optional dedup key for the content-hash embedding\n            cache lookup before calling the provider. Skip the call if\n            the hash is already embedded for this tenant.\n    \"\"\"\n\n    model_config = ConfigDict(frozen=True, extra=\"forbid\")\n\n    memory_id: UUID\n    tenant_id: str\n    content: str = Field(min_length=1)\n    # ``min_length=1`` so an empty-string hash from a buggy publisher\n    # is rejected at validation time rather than silently skipping the\n    # cache lookup downstream (the consumer's ``if request.content_hash:``\n    # treats ``\"\"`` and ``None`` the same — explicit is better here).\n    content_hash: str | None = Field(default=None, min_length=1)","lineStart":1,"lineEnd":45,"totalLines":45,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_embed_request.py","time":{"start":1780728840224,"end":1780728840230}},"metadata":{"openai":{"itemId":"fc_001872bc89af9832016a23c407cf88819194a830658f49a5c1"}},"id":"prt_e9bb5bffb001Ms4Lh5qjvck3nS","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb590c5001ZIZF2CTiosHt0T"}}
