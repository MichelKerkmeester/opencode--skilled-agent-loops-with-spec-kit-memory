{"type":"step_start","timestamp":1781763848952,"sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","part":{"id":"prt_ed966baf5001Pf44zIbmGFmcTG","messageID":"msg_ed966b3aa001EJftVGhbS0o1FS","sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","snapshot":"870aafdeac128876254ad20b4ce17b02c1201df8","type":"step-start"}}
{"type":"text","timestamp":1781763858081,"sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","part":{"id":"prt_ed966d08f001g9gTl1JiMAMFdp","messageID":"msg_ed966b3aa001EJftVGhbS0o1FS","sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","type":"text","text":"The first hotspot pass shows recent safeguards around checkpoints, path traversal, job cancel mirrors, and pending-file recovery. I’m narrowing on retention/write lifecycle internals and index scan orchestration for evidence-backed findings.","time":{"start":1781763854480,"end":1781763858077},"metadata":{"openai":{"itemId":"msg_0790af5bc91d46de016a338f0e6f5481919347fa84c8b0719a","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781763858135,"sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","part":{"type":"tool","tool":"read","callID":"call_GcMNhepM7k3BdNXUuVzJDfT5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":2600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see — aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n341: \n342: function appendRetentionLedger(\n343:   database: Database.Database,\n344:   deletedIds: number[],\n345:   candidates: RetentionExpiredRow[],\n346: ): boolean {\n347:   try {\n348:     mutationLedger.initLedger(database);\n349:     mutationLedger.appendEntry(database, {\n350:       mutation_type: 'delete',\n351:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n352:       prior_hash: null,\n353:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n354:       linked_memory_ids: deletedIds.slice(0, 50),\n355:       decision_meta: {\n356:         tool: 'memory_retention_sweep',\n357:         reason: 'retention_expired',\n358:         totalDeleted: deletedIds.length,\n359:         originalDeleteAfter: candidates\n360:           .filter((candidate) => deletedIds.includes(candidate.id))\n361:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n362:       },\n363:       actor: 'mcp:memory_retention_sweep',\n364:     });\n365:     return true;\n366:   } catch (error: unknown) {\n367:     const message = error instanceof Error ? error.message : String(error);\n368:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n369:     return false;\n370:   }\n371: }\n372: \n373: function runPostDeleteMaintenance(database: Database.Database): void {\n374:   try {\n375:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n376:   } catch (error: unknown) {\n377:     const message = error instanceof Error ? error.message : String(error);\n378:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n379:   }\n380: \n381:   const maintenance = new BetterSqliteMaintenance(database, {\n382:     onMaintenanceError: reportRetentionMaintenanceError,\n383:   });\n384:   maintenance.vacuum();\n385:   maintenance.checkpoint({ mode: 'truncate' });\n386: }\n387: \n388: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n389:   const message = error instanceof Error ? error.message : String(error);\n390:   if (operation === 'auto_vacuum') {\n391:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n392:   } else if (operation === 'incremental_vacuum') {\n393:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n394:   } else if (operation === 'wal_checkpoint') {\n395:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n396:   }\n397: }\n398: \n399: /**\n400:  * Sweep expired governed memory rows.\n401:  *\n402:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n403:  * to enforce the ISO timestamps persisted by governed ingest.\n404:  */\n405: export function runMemoryRetentionSweep(\n406:   database: Database.Database,\n407:   args: MemoryRetentionSweepArgs = {},\n408: ): MemoryRetentionSweepResult {\n409:   const startTime = Date.now();\n410:   const dryRun = args.dryRun === true;\n411:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n412: \n413:   if (!hasTable(database, 'memory_index')) {\n414:     return {\n415:       swept: 0,\n416:       retained: 0,\n417:       protectedCount: 0,\n418:       dryRun,\n419:       durationMs: Date.now() - startTime,\n420:       candidates: [],\n421:       deletedIds: [],\n422:       protectedIds: [],\n423:       ledgerRecorded: null,\n424:       tombstoneState: {\n425:         usesPurgeablePartition: false,\n426:         usingPurgeableIndex: false,\n427:         candidateCount: 0,\n428:         deletedCount: 0,\n429:       },\n430:       edgeState: {\n431:         causalEdgesTablePresent: false,\n432:         candidateEdgeCount: 0,\n433:       },\n434:     };\n435:   }\n436: \n437:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n438:   const initialEdgeState = buildEdgeState(database, candidates);\n439:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n440:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n441:     : null;\n442: \n443:   if (dryRun || candidates.length === 0) {\n444:     const totalRows = countRows(database);\n445:     const dryRunProtectedIds = candidates\n446:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n447:       .map((candidate) => candidate.id);\n448:     return {\n449:       swept: 0,\n450:       retained: totalRows,\n451:       protectedCount: dryRunProtectedIds.length,\n452:       dryRun,\n453:       durationMs: Date.now() - startTime,\n454:       candidates,\n455:       deletedIds: [],\n456:       protectedIds: dryRunProtectedIds,\n457:       ledgerRecorded: null,\n458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n459:       edgeState: initialEdgeState,\n460:       ...(feedbackRetention ? { feedbackRetention } : {}),\n461:     };\n462:   }\n463: \n464:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n465:     const auditTx = database.transaction(() => {\n466:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n467:         database,\n468:         candidates,\n469:         feedbackRetention,\n470:         false,\n471:       );\n472:     });\n473:     auditTx();\n474: \n475:     return {\n476:       swept: 0,\n477:       retained: countRows(database),\n478:       protectedCount: feedbackRetention.protectedIds.length,\n479:       dryRun,\n480:       durationMs: Date.now() - startTime,\n481:       candidates,\n482:       deletedIds: [],\n483:       protectedIds: feedbackRetention.protectedIds,\n484:       extendedIds: [],\n485:       ledgerRecorded: null,\n486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n487:       edgeState: initialEdgeState,\n488:       feedbackRetention,\n489:     };\n490:   }\n491: \n492:   initHistory(database);\n493: \n494:   const deletedIds: number[] = [];\n495:   const protectedIds: number[] = [];\n496:   const extendedIds: number[] = [];\n497:   let ledgerRecorded: boolean | null = null;\n498: \n499:   const sweepTx = database.transaction(() => {\n500:     for (const candidate of candidates) {\n501:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n502:       const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n503:       if (!currentCandidate) {\n504:         continue;\n505:       }\n506:       let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n507:       if (feedbackRetention) {\n508:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n509:         if (!decision) {\n510:           continue;\n511:         }\n512: \n513:         if (decision.decision === 'protect') {\n514:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n515:           protectedIds.push(candidate.id);\n516:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n517:             mode: feedbackRetention.mode,\n518:             applied: true,\n519:             activeGatePassed: feedbackRetention.activeGatePassed,\n520:           });\n521:           feedbackRetention.auditCount += 1;\n522:           continue;\n523:         }\n524: \n525:         if (decision.decision === 'extend') {\n526:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n527:             decision.nextDeleteAfter,\n528:             candidate.id,\n529:           );\n530:           extendedIds.push(candidate.id);\n531:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n532:             mode: feedbackRetention.mode,\n533:             applied: true,\n534:             activeGatePassed: feedbackRetention.activeGatePassed,\n535:           });\n536:           feedbackRetention.auditCount += 1;\n537:           continue;\n538:         }\n539:         feedbackDeleteDecision = decision;\n540:       }\n541:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n542:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n543:       if (isProtectedFromRetentionDelete(currentCandidate)) {\n544:         if (feedbackRetention && feedbackDeleteDecision) {\n545:           recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n546:             mode: feedbackRetention.mode,\n547:             applied: false,\n548:             activeGatePassed: feedbackRetention.activeGatePassed,\n549:           });\n550:           feedbackRetention.auditCount += 1;\n551:         }\n552:         protectedIds.push(currentCandidate.id);\n553:         recordGovernanceAudit(database, {\n554:           action: 'retention_sweep',\n555:           decision: 'deny',\n556:           memoryId: currentCandidate.id,\n557:           logicalKey: currentCandidate.filePath,\n558:           tenantId: currentCandidate.tenantId ?? undefined,\n559:           userId: currentCandidate.userId ?? undefined,\n560:           agentId: currentCandidate.agentId ?? undefined,\n561:           sessionId: currentCandidate.sessionId ?? undefined,\n562:           reason: 'retention_tier_protected',\n563:           metadata: {\n564:             originalDeleteAfter: currentCandidate.deleteAfter,\n565:             importanceTier: currentCandidate.importanceTier,\n566:             isPinned: currentCandidate.isPinned,\n567:             specFolder: currentCandidate.specFolder,\n568:             filePath: currentCandidate.filePath,\n569:           },\n570:         });\n571:         continue;\n572:       }\n573:       if (feedbackRetention && feedbackDeleteDecision) {\n574:         recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n575:           mode: feedbackRetention.mode,\n576:           applied: true,\n577:           activeGatePassed: feedbackRetention.activeGatePassed,\n578:         });\n579:         feedbackRetention.auditCount += 1;\n580:       }\n581:       const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n582:       if (!deleted) {\n583:         continue;\n584:       }\n585: \n586:       deletedIds.push(currentCandidate.id);\n587: \n588:       recordHistory(\n589:         currentCandidate.id,\n590:         'DELETE',\n591:         {\n592:           reason: 'retention_expired',\n593:           deleteAfter: currentCandidate.deleteAfter,\n594:           filePath: currentCandidate.filePath,\n595:         },\n596:         null,\n597:         'mcp:memory_retention_sweep',\n598:         currentCandidate.specFolder,\n599:       );\n600: \n601:       recordGovernanceAudit(database, {\n602:         action: 'retention_sweep',\n603:         decision: 'delete',\n604:         memoryId: currentCandidate.id,\n605:         logicalKey: currentCandidate.filePath,\n606:         tenantId: currentCandidate.tenantId ?? undefined,\n607:         userId: currentCandidate.userId ?? undefined,\n608:         agentId: currentCandidate.agentId ?? undefined,\n609:         sessionId: currentCandidate.sessionId ?? undefined,\n610:         reason: 'retention_expired',\n611:         metadata: {\n612:           originalDeleteAfter: currentCandidate.deleteAfter,\n613:           delete_after: currentCandidate.deleteAfter,\n614:           specFolder: currentCandidate.specFolder,\n615:           filePath: currentCandidate.filePath,\n616:         },\n617:       });\n618:     }\n619: \n620:     if (deletedIds.length > 0) {\n621:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n622:     }\n623:   });\n624: \n625:   sweepTx();\n626:   if (deletedIds.length > 0) {\n627:     runPostDeleteMaintenance(database);\n628:   }\n629:   if (feedbackRetention) {\n630:     feedbackRetention.extendedIds = extendedIds;\n631:     feedbackRetention.protectedIds = protectedIds;\n632:     feedbackRetention.deletedIds = deletedIds;\n633:   }\n634: \n635:   return {\n636:     swept: deletedIds.length,\n637:     retained: countRows(database),\n638:     protectedCount: protectedIds.length,\n639:     dryRun,\n640:     durationMs: Date.now() - startTime,\n641:     candidates,\n642:     deletedIds,\n643:     protectedIds,\n644:     ledgerRecorded,\n645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n646:     edgeState: initialEdgeState,\n647:     ...(feedbackRetention ? { extendedIds } : {}),\n648:     ...(feedbackRetention ? { feedbackRetention } : {}),\n649:   };\n650: }\n\n(End of file - total 650 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see — aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n      if (!currentCandidate) {\n        continue;\n      }\n      let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n        feedbackDeleteDecision = decision;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(currentCandidate)) {\n        if (feedbackRetention && feedbackDeleteDecision) {\n          recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n            mode: feedbackRetention.mode,\n            applied: false,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n        }\n        protectedIds.push(currentCandidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: currentCandidate.id,\n          logicalKey: currentCandidate.filePath,\n          tenantId: currentCandidate.tenantId ?? undefined,\n          userId: currentCandidate.userId ?? undefined,\n          agentId: currentCandidate.agentId ?? undefined,\n          sessionId: currentCandidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: currentCandidate.deleteAfter,\n            importanceTier: currentCandidate.importanceTier,\n            isPinned: currentCandidate.isPinned,\n            specFolder: currentCandidate.specFolder,\n            filePath: currentCandidate.filePath,\n          },\n        });\n        continue;\n      }\n      if (feedbackRetention && feedbackDeleteDecision) {\n        recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(currentCandidate.id);\n\n      recordHistory(\n        currentCandidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: currentCandidate.deleteAfter,\n          filePath: currentCandidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        currentCandidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: currentCandidate.id,\n        logicalKey: currentCandidate.filePath,\n        tenantId: currentCandidate.tenantId ?? undefined,\n        userId: currentCandidate.userId ?? undefined,\n        agentId: currentCandidate.agentId ?? undefined,\n        sessionId: currentCandidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: currentCandidate.deleteAfter,\n          delete_after: currentCandidate.deleteAfter,\n          specFolder: currentCandidate.specFolder,\n          filePath: currentCandidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),\n    ...(feedbackRetention ? { feedbackRetention } : {}),\n  };\n}","lineStart":1,"lineEnd":650,"totalLines":650,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781763858128,"end":1781763858133}},"metadata":{"openai":{"itemId":"fc_0790af5bc91d46de016a338f120280819187edd9d8b3c249de"}},"id":"prt_ed966de9f001n8kY7iw1GYjfhv","sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","messageID":"msg_ed966b3aa001EJftVGhbS0o1FS"}}
{"type":"tool_use","timestamp":1781763858202,"sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","part":{"type":"tool","tool":"read","callID":"call_hD9Bo7E9UJvE9yiW8PC3E5sw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","offset":1,"limit":2600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Index\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import { createHash } from 'node:crypto';\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. CORE AND UTILS IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\n13: import { beginMaintenance } from '../lib/storage/maintenance-marker.js';\n14: import { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\n15: import { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\n16: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* ───────────────────────────────────────────────────────────────\n24:    2. LIB MODULE IMPORTS\n25: ──────────────────────────────────────────────────────────────── */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* ───────────────────────────────────────────────────────────────\n82:    4. TYPES\n83: ──────────────────────────────────────────────────────────────── */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   nearDuplicateRepaired: number;\n161:   orphanSwept: number;\n162:   orphanSweepFailed: number;\n163:   orphanSweepScanned: number;\n164:   orphanSweepNextCursor: number | null;\n165:   moveReconciled?: number;\n166:   files: ScanFileEntry[];\n167:   constitutional: {\n168:     found: number;\n169:     indexed: number;\n170:     alreadyIndexed: number;\n171:   };\n172:   incremental: {\n173:     enabled: boolean;\n174:     fast_path_skips: number;\n175:     mtime_changed: number;\n176:     metadataPromoter: {\n177:       processed: number;\n178:       resolved: number;\n179:       inserted: number;\n180:       skippedManual: number;\n181:       staleTombstoned: number;\n182:       staleDeleted: number;\n183:       warnings: number;\n184:     };\n185:   };\n186:   dedup: {\n187:     inputTotal: number;\n188:     uniqueTotal: number;\n189:     duplicatesSkipped: number;\n190:   };\n191:   aliasConflicts: AliasConflictSummary;\n192:   divergenceReconcile: DivergenceReconcileSummary;\n193:   checkpointRepair: CheckpointRepairReport;\n194:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n195:   warnings: string[];\n196:   capExceeded: DiscoveryCapExceeded;\n197: }\n198: \n199: interface CategorizedFiles {\n200:   toIndex: string[];\n201:   toUpdate: string[];\n202:   toSkip: string[];\n203:   toDelete: string[];\n204: }\n205: \n206: interface ScanKeyOptions {\n207:   spec_folder: string | null;\n208:   force: boolean;\n209:   incremental: boolean;\n210:   include_constitutional: boolean;\n211:   include_spec_docs: boolean;\n212: }\n213: \n214: interface RecordDeleteResult {\n215:   deleted: number;\n216:   failed: number;\n217:   actions: StatediffAction[];\n218: }\n219: \n220: interface OrphanSweepDeleteResult {\n221:   swept: number;\n222:   failed: number;\n223:   scannedRows: number;\n224:   nextCursor: number | null;\n225:   actions: StatediffAction[];\n226: }\n227: \n228: interface OrphanSweepCandidates {\n229:   swept: number;\n230:   nextCursor: number | null;\n231:   scannedRows: number;\n232:   orphanRecordIds?: number[];\n233: }\n234: \n235: const ORPHAN_SWEEP_LIMIT = 200;\n236: \n237: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n238: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n239: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n240: // event-loop block from a phase that is merely slow but yields — the two need\n241: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n242: const LOOP_LAG_SAMPLE_MS = 250;\n243: const LOOP_LAG_WARN_MS = 1000;\n244: \n245: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n246:   return {\n247:     sentinelPresent: false,\n248:     attempted: false,\n249:     completed: 0,\n250:     failed: 0,\n251:     skipped: 0,\n252:     cleared: false,\n253:     error: null,\n254:   };\n255: }\n256: \n257: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n258:   try {\n259:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n260:       source: 'memory_index_scan',\n261:       actor: 'mcp:memory_index_scan',\n262:     });\n263:     return {\n264:       sentinelPresent: repair.sentinelPresent,\n265:       attempted: repair.attempted,\n266:       completed: repair.summary?.completed.length ?? 0,\n267:       failed: repair.summary?.failed.length ?? 0,\n268:       skipped: repair.summary?.skipped.length ?? 0,\n269:       cleared: repair.cleared,\n270:       error: repair.error,\n271:     };\n272:   } catch (error: unknown) {\n273:     return {\n274:       ...emptyCheckpointRepairReport(),\n275:       sentinelPresent: true,\n276:       attempted: true,\n277:       error: toErrorMessage(error),\n278:     };\n279:   }\n280: }\n281: \n282: function createScanKey(options: ScanKeyOptions): string {\n283:   const normalized = {\n284:     spec_folder: options.spec_folder ?? null,\n285:     force: !!options.force,\n286:     incremental: !!options.incremental,\n287:     include_constitutional: !!options.include_constitutional,\n288:     include_spec_docs: !!options.include_spec_docs,\n289:   };\n290: \n291:   return createHash('sha256')\n292:     .update(JSON.stringify(normalized))\n293:     .digest('hex')\n294:     .slice(0, 16);\n295: }\n296: \n297: interface ScanArgs {\n298:   specFolder?: string | null;\n299:   force?: boolean;\n300:   includeConstitutional?: boolean;\n301:   includeSpecDocs?: boolean;\n302:   incremental?: boolean;\n303:   // Opt-in: run the scan as a background job and return a jobId immediately.\n304:   background?: boolean;\n305:   tenantId?: string;\n306:   userId?: string;\n307:   agentId?: string;\n308:   sessionId?: string;\n309:   provenanceSource?: string;\n310:   provenanceActor?: string;\n311:   governedAt?: string;\n312:   retentionPolicy?: 'keep' | 'ephemeral';\n313:   deleteAfter?: string;\n314: }\n315: \n316: /* ───────────────────────────────────────────────────────────────\n317:    5. SHARED INDEXING LOGIC\n318: ──────────────────────────────────────────────────────────────── */\n319: \n320: import { indexMemoryFile } from './memory-save.js';\n321: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n322: import type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n323: \n324: /** Index a single memory file, delegating to the shared indexMemoryFile logic */\n325: async function indexSingleFile(\n326:   filePath: string,\n327:   force: boolean = false,\n328:   options?: {\n329:     qualityGateMode?: 'enforce' | 'warn-only';\n330:     fromScan?: boolean;\n331:     asyncEmbedding?: boolean;\n332:     governance?: GovernanceDecision;\n333:     provenance?: WriteProvenanceContext;\n334:   },\n335: ): Promise<IndexResult> {\n336:   return indexMemoryFile(filePath, {\n337:     force,\n338:     qualityGateMode: options?.qualityGateMode,\n339:     fromScan: options?.fromScan,\n340:     asyncEmbedding: options?.asyncEmbedding,\n341:     governance: options?.governance,\n342:     provenance: options?.provenance,\n343:   });\n344: }\n345: \n346: /* ───────────────────────────────────────────────────────────────\n347:    6. MEMORY INDEX SCAN HANDLER\n348: ──────────────────────────────────────────────────────────────── */\n349: \n350: // Hooks let a background runner observe cancellation and report phase/progress.\n351: // On the synchronous path every hook is undefined, so behavior is identical.\n352: interface ScanRunContext {\n353:   isCancelled?: () => boolean;\n354:   onPhase?: (phase: string) => void;\n355:   onProgress?: (progress: { processed: number; total: number }) => void;\n356: }\n357: \n358: // Pull the envelope.data field back out of an MCP response so status can echo it.\n359: function extractEnvelopeData(response: MCPResponse): unknown {\n360:   try {\n361:     const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n362:     if (typeof text !== 'string') return null;\n363:     const parsed = JSON.parse(text) as { data?: unknown };\n364:     return parsed?.data ?? null;\n365:   } catch (_error: unknown) {\n366:     return null;\n367:   }\n368: }\n369: \n370: // Persisted payload for debugging: scan shape only, no governance identifiers.\n371: function redactScanArgs(args: ScanArgs): Record<string, unknown> {\n372:   return {\n373:     specFolder: args.specFolder ?? null,\n374:     force: !!args.force,\n375:     includeConstitutional: args.includeConstitutional !== false,\n376:     includeSpecDocs: args.includeSpecDocs !== false,\n377:     incremental: args.incremental !== false,\n378:     background: true,\n379:   };\n380: }\n381: \n382: function cancelledScanEnvelope(scanKey: string): MCPResponse {\n383:   return createMCPSuccessResponse({\n384:     tool: 'memory_index_scan',\n385:     summary: 'Index scan cancelled before completion',\n386:     data: { status: 'cancelled', cancelled: true, scanKey },\n387:     hints: ['The scan was cancelled via memory_index_scan_cancel'],\n388:   });\n389: }\n390: \n391: /** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\n392: async function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n393:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n394:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n395:   if (restoreBarrier) {\n396:     recordMaintenanceRun('memory_index_scan', { status: 'error' });\n397:     return createMCPErrorResponse({\n398:       tool: 'memory_index_scan',\n399:       error: restoreBarrier.message,\n400:       code: restoreBarrier.code,\n401:       recovery: {\n402:         hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n403:         actions: ['Wait for the restore to finish', 'Retry the index scan'],\n404:         severity: 'warning',\n405:       },\n406:     });\n407:   }\n408: \n409:   const {\n410:     specFolder: spec_folder = null,\n411:     force = false,\n412:     includeConstitutional: include_constitutional = true,\n413:     includeSpecDocs: include_spec_docs = true,\n414:     incremental = true\n415:   } = args;\n416:   const scanKey = createScanKey({\n417:     spec_folder,\n418:     force,\n419:     incremental,\n420:     include_constitutional,\n421:     include_spec_docs,\n422:   });\n423:   const governedIngest = requiresGovernedIngest(args);\n424:   const governanceDecision = validateGovernedIngest(args);\n425:   if (!governanceDecision.allowed) {\n426:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n427:   }\n428: \n429:   // Pre-flight dimension check\n430:   try {\n431:     const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n432:     if (profile) {\n433:       console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n434:     }\n435:   } catch (dimCheckError: unknown) {\n436:     const message = toErrorMessage(dimCheckError);\n437:     console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n438:   }\n439: \n440:   await checkDatabaseUpdated();\n441: \n442:   // Atomic scan lease check.\n443:   // Reserve scan_started_at up front to avoid check-then-set race windows.\n444:   const now = Date.now();\n445:   const lease = await acquireIndexScanLease({\n446:     now,\n447:     cooldownMs: INDEX_SCAN_COOLDOWN,\n448:   });\n449:   if (!lease.acquired) {\n450:     let message: string;\n451:     if (lease.reason === 'lease_active') {\n452:       message = 'A scan is already in progress; this call coalesced onto it.';\n453:     } else if (lease.reason === 'contention') {\n454:       message = 'The index DB is briefly locked by another writer; retry shortly.';\n455:     } else {\n456:       message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n457:     }\n458:     recordMaintenanceRun('memory_index_scan', {\n459:       status: 'coalesced',\n460:       counts: { waitSeconds: lease.waitSeconds },\n461:       staleCandidates: 0,\n462:     });\n463:     return createMCPSuccessResponse({\n464:       tool: 'memory_index_scan',\n465:       summary: message,\n466:       data: {\n467:         success: true,\n468:         coalesced: true,\n469:         status: 'coalesced',\n470:         reason: lease.reason,\n471:         scanKey,\n472:         waitSeconds: lease.waitSeconds,\n473:         nextPollAfterMs: lease.waitSeconds * 1000,\n474:         message,\n475:       },\n476:       hints: [message],\n477:     });\n478:   }\n479: \n480:   let scanLeaseReleased = false;\n481:   const releaseScanLease = async (): Promise<void> => {\n482:     if (scanLeaseReleased) return;\n483:     scanLeaseReleased = true;\n484:     await completeIndexScanLease(Date.now());\n485:   };\n486: \n487:   const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n488: \n489:   // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n490:   // processBatches() runs all batches sequentially and may exceed the lease expiry\n491:   // window (each batch waits on embedding/API latency). Without a periodic refresh\n492:   // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n493:   // launch a second parallel scan. Refresh well inside the expiry window (a third of\n494:   // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n495:   // from holding the event loop open at shutdown; finally clears it before release.\n496:   const leaseExpiryMs = lease.leaseExpiryMs;\n497:   const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n498:   let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n499: \n500:   // Background scans pass an onPhase hook; the synchronous foreground path does not.\n501:   // Gate diagnostics on it so the synchronous path's behavior stays identical.\n502:   const instrument = typeof ctx.onPhase === 'function';\n503:   let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n504:   let maxLoopLagMs = 0;\n505: \n506:   try {\n507:   leaseHeartbeat = setInterval(() => {\n508:     refreshScanLease();\n509:   }, leaseHeartbeatMs);\n510:   leaseHeartbeat.unref?.();\n511: \n512:   if (instrument) {\n513:     let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n514:     loopLagTimer = setInterval(() => {\n515:       const sampledAt = Date.now();\n516:       const lag = sampledAt - loopLagExpectedAt;\n517:       loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n518:       if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n519:       if (lag > LOOP_LAG_WARN_MS) {\n520:         // A late sample means the loop was blocked since the prior tick; logged\n521:         // adjacent to the phase=... line of whatever phase just ran, so the daemon\n522:         // log timeline fingers the blocking phase.\n523:         console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n524:       }\n525:     }, LOOP_LAG_SAMPLE_MS);\n526:     loopLagTimer.unref?.();\n527:   }\n528: \n529:   if (ctx.isCancelled?.()) {\n530:     await releaseScanLease();\n531:     return cancelledScanEnvelope(scanKey);\n532:   }\n533:   ctx.onPhase?.('discovering');\n534: \n535:   const workspacePath: string = DEFAULT_BASE_PATH;\n536: \n537:   const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n538:   const specDocFiles = include_spec_docs\n539:     ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n540:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n541:   const graphMetadataFiles = include_spec_docs\n542:     ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n543:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n544:   const walkerWarnings = [\n545:     ...discoveryWarnings(specDocFiles),\n546:     ...discoveryWarnings(graphMetadataFiles),\n547:   ];\n548:   const walkerCapExceeded = mergeDiscoveryCapExceeded(\n549:     discoveryCaps(specDocFiles),\n550:     discoveryCaps(graphMetadataFiles),\n551:   );\n552: \n553:   const canonicalKeyCache = new Map<string, string>();\n554:   const getCachedKey = (filePath: string): string => {\n555:     const cached = canonicalKeyCache.get(filePath);\n556:     if (cached) {\n557:       return cached;\n558:     }\n559: \n560:     const canonicalKey = getCanonicalPathKey(filePath);\n561:     canonicalKeyCache.set(filePath, canonicalKey);\n562:     return canonicalKey;\n563:   };\n564: \n565:   const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n566:   const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n567:   const seenCanonicalFiles = new Set<string>();\n568:   const files: string[] = [];\n569: \n570:   for (const filePath of mergedFiles) {\n571:     const canonicalKey = getCachedKey(filePath);\n572:     if (seenCanonicalFiles.has(canonicalKey)) {\n573:       continue;\n574:     }\n575:     seenCanonicalFiles.add(canonicalKey);\n576:     files.push(filePath);\n577:   }\n578: \n579:   const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n580:   if (dedupDuplicatesSkipped > 0) {\n581:     console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n582:   }\n583: \n584:   const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n585:     if (recordIds.length === 0) {\n586:       return { deleted: 0, failed: 0, actions: [] };\n587:     }\n588: \n589:     let deleted = 0;\n590:     let failed = 0;\n591:     const actions: StatediffAction[] = [];\n592: \n593:     for (const staleRecordId of recordIds) {\n594:       try {\n595:         const database = vectorIndex.getDb();\n596:         const staleSnapshot = database?.prepare(\n597:           'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n598:         ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n599: \n600:         if (database) {\n601:           causalEdges.init(database);\n602:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n603:             reason: 'memory_index stale record cleanup',\n604:             command: 'memory-index.deleteIndexedRecordIds',\n605:             restoreContext: {\n606:               memoryId: staleRecordId,\n607:               specFolder: staleSnapshot?.spec_folder ?? null,\n608:               filePath: staleSnapshot?.file_path ?? null,\n609:             },\n610:           });\n611:         }\n612: \n613:         if (vectorIndex.deleteMemory(staleRecordId)) {\n614:           deleted++;\n615:           actions.push(createStatediffAction('delete', {\n616:             target: 'memory_index',\n617:             key: String(staleRecordId),\n618:             sourceOperation: 'scan',\n619:             oldStateHash: null,\n620:             newStateHash: null,\n621:             metadata: {\n622:               filePath: staleSnapshot?.file_path ?? null,\n623:               specFolder: staleSnapshot?.spec_folder ?? null,\n624:             },\n625:           }));\n626:           // Record DELETE history only after confirmed deletion.\n627:           try {\n628:             recordHistory(\n629:               staleRecordId,\n630:               'DELETE',\n631:               staleSnapshot?.file_path ?? null,\n632:               null,\n633:               'mcp:memory_index_scan',\n634:               staleSnapshot?.spec_folder ?? null,\n635:             );\n636:           } catch (_histErr: unknown) {\n637:             // History recording is best-effort\n638:           }\n639:         } else {\n640:           failed++;\n641:         }\n642:       } catch (_error: unknown) {\n643:         failed++;\n644:       }\n645:     }\n646: \n647:     return { deleted, failed, actions };\n648:   };\n649: \n650:   const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n651:     if (paths.length === 0) {\n652:       return { deleted: 0, failed: 0, actions: [] };\n653:     }\n654: \n655:     return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n656:   };\n657: \n658:   const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n659:     if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n660:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n661:     }\n662: \n663:     const sweepOrphanIndexRows = (incrementalIndex as {\n664:       sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n665:     }).sweepOrphanIndexRows;\n666: \n667:     if (typeof sweepOrphanIndexRows !== 'function') {\n668:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n669:     }\n670: \n671:     const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n672:     const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n673:     return {\n674:       swept: deleteResult.deleted,\n675:       failed: deleteResult.failed,\n676:       scannedRows: sweep.scannedRows,\n677:       nextCursor: sweep.nextCursor,\n678:       actions: deleteResult.actions,\n679:     };\n680:   };\n681: \n682:   const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n683:     try {\n684:       runPostMutationHooks('scan', { ...context, statediffActions: actions });\n685:     } catch (error: unknown) {\n686:       console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n687:     }\n688:   };\n689: \n690:   const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n691:     result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n692:   );\n693: \n694:   const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n695:     target: 'memory_index',\n696:     key: 'trigger-embedding-backfill',\n697:     sourceOperation: 'scan',\n698:     metadata: {\n699:       readyRows: result.readyRows,\n700:       failedRows: result.failedRows,\n701:       pendingRows: result.pendingRows,\n702:     },\n703:   });\n704: \n705:   const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n706:     if (actions.length === 0) {\n707:       return;\n708:     }\n709:     results.aliasConflicts = detectAliasConflictsFromIndex();\n710:     results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n711:   };\n712: \n713:   const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n714:     try {\n715:       const repairResult = await repairIncompleteMarkers(\n716:         { database: requireDb(), plannerMode: 'full-auto' },\n717:         { limit: BATCH_SIZE },\n718:       );\n719:       if (repairResult.failed > 0) {\n720:         console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n721:       }\n722:       return repairResult.repaired;\n723:     } catch (error: unknown) {\n724:       console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n725:       return 0;\n726:     }\n727:   };\n728: \n729:   const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n730:     if (!isMemoryIdempotencyEnabled()) {\n731:       return 0;\n732:     }\n733:     try {\n734:       const database = requireDb();\n735:       const rows = database.prepare(`\n736:         SELECT id, spec_folder, title, content_text, content_hash,\n737:                tenant_id, user_id, agent_id, session_id\n738:         FROM memory_index\n739:         WHERE parent_id IS NULL\n740:           AND embedding_status = 'success'\n741:           AND content_text IS NOT NULL\n742:           AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n743:         ORDER BY id ASC\n744:         LIMIT ?\n745:       `).all(BATCH_SIZE) as Array<{\n746:         id: number;\n747:         spec_folder: string;\n748:         title: string | null;\n749:         content_text: string;\n750:         content_hash: string | null;\n751:         tenant_id: string | null;\n752:         user_id: string | null;\n753:         agent_id: string | null;\n754:         session_id: string | null;\n755:       }>;\n756:       let repaired = 0;\n757:       for (const row of rows) {\n758:         try {\n759:           const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n760:           const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n761:           recordNearDuplicateCheck({\n762:             database,\n763:             memoryId: row.id,\n764:             specFolder: row.spec_folder,\n765:             contentHash: row.content_hash,\n766:             embedding,\n767:             scope: {\n768:               tenantId: row.tenant_id,\n769:               userId: row.user_id,\n770:               agentId: row.agent_id,\n771:               sessionId: row.session_id,\n772:             },\n773:           });\n774:           repaired++;\n775:         } catch (error: unknown) {\n776:           console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n777:         }\n778:       }\n779:       return repaired;\n780:     } catch (error: unknown) {\n781:       console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n782:       return 0;\n783:     }\n784:   };\n785: \n786:   // Time each un-yielded tail phase: because these phases do not yield, their\n787:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n788:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n789:   // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n790:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n791:     ctx.onPhase?.(phase);\n792:     if (!instrument) {\n793:       return await fn();\n794:     }\n795:     const startedAt = Date.now();\n796:     try {\n797:       return await fn();\n798:     } finally {\n799:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n800:     }\n801:   };\n802: \n803:   if (files.length === 0) {\n804:     let staleDeleted = 0;\n805:     let staleDeleteFailed = 0;\n806:     const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n807:     const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n808:     const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n809: \n810:     if (incremental && !force) {\n811:       const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n812:       const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n813:       staleDeleted = staleDeleteResult.deleted;\n814:       staleDeleteFailed = staleDeleteResult.failed;\n815:       if (staleDeleted > 0) {\n816:         runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n817:       }\n818:     }\n819: \n820:     const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n821:       runTriggerEmbeddingBackfill(requireDb(), {\n822:         isCancelled: () => ctx.isCancelled?.() ?? false,\n823:       }));\n824: \n825:     if (orphanSweepResult.swept > 0) {\n826:       runScanInvalidationHooks({\n827:         orphanSwept: orphanSweepResult.swept,\n828:         orphanSweepFailed: orphanSweepResult.failed,\n829:         operation: 'orphan-sweep',\n830:       }, orphanSweepResult.actions);\n831:     }\n832:     if (postInsertEnrichmentRepaired > 0) {\n833:       runScanInvalidationHooks({\n834:         postInsertEnrichmentRepaired,\n835:         operation: 'post-insert-enrichment-repair',\n836:       }, [createStatediffAction('upsert', {\n837:         target: 'graph_edge',\n838:         key: 'post-insert-enrichment-repair',\n839:         sourceOperation: 'scan',\n840:         metadata: { postInsertEnrichmentRepaired },\n841:       })]);\n842:     }\n843:     if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n844:       runScanInvalidationHooks({\n845:         triggerEmbeddingBackfill,\n846:         operation: 'trigger-embedding-backfill',\n847:       }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n848:     }\n849: \n850:     recordMaintenanceRun('memory_index_scan', {\n851:       status: 'success',\n852:       counts: {\n853:         scanned: 0,\n854:         indexed: 0,\n855:         updated: 0,\n856:         unchanged: 0,\n857:         failed: 0,\n858:         staleDeleted,\n859:         staleDeleteFailed,\n860:         orphanSwept: orphanSweepResult.swept,\n861:       },\n862:       staleCandidates: staleDeleted + staleDeleteFailed,\n863:     });\n864:     await releaseScanLease();\n865:     return createMCPSuccessResponse({\n866:       tool: 'memory_index_scan',\n867:       summary: 'No memory files found',\n868:       data: {\n869:         status: 'complete',\n870:         scanKey,\n871:         scanned: 0,\n872:         indexed: 0,\n873:         updated: 0,\n874:         unchanged: 0,\n875:         failed: 0,\n876:         staleDeleted,\n877:         staleDeleteFailed,\n878:         postInsertEnrichmentRepaired,\n879:         nearDuplicateRepaired,\n880:         triggerEmbeddingBackfill,\n881:         orphanSwept: orphanSweepResult.swept,\n882:         orphanSweepFailed: orphanSweepResult.failed,\n883:         orphanSweepScanned: orphanSweepResult.scannedRows,\n884:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n885:         checkpointRepair,\n886:         warnings: walkerWarnings,\n887:         capExceeded: walkerCapExceeded,\n888:       },\n889:       hints: [\n890:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n891:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n892:         ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n893:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n894:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n895:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n896:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n897:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n898:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n899:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n900:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n901:         'Constitutional files go in .opencode/skills/*/constitutional/'\n902:       ]\n903:     });\n904:   }\n905: \n906:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n907: \n908:   const results: ScanResults = {\n909:     scanned: files.length,\n910:     indexed: 0,\n911:     updated: 0,\n912:     unchanged: 0,\n913:     failed: 0,\n914:     deferred: 0,\n915:     skipped_mtime: 0,\n916:     mtimeUpdates: 0,\n917:     staleDeleted: 0,\n918:     staleDeleteFailed: 0,\n919:     postInsertEnrichmentRepaired: 0,\n920:     nearDuplicateRepaired: 0,\n921:     orphanSwept: 0,\n922:     orphanSweepFailed: 0,\n923:     orphanSweepScanned: 0,\n924:     orphanSweepNextCursor: null,\n925:     files: [],\n926:     constitutional: {\n927:       found: constitutionalFiles.length,\n928:       indexed: 0,\n929:       alreadyIndexed: 0\n930:     },\n931:     incremental: {\n932:       enabled: incremental && !force,\n933:       fast_path_skips: 0,\n934:       mtime_changed: 0,\n935:       metadataPromoter: {\n936:         processed: 0,\n937:         resolved: 0,\n938:         inserted: 0,\n939:         skippedManual: 0,\n940:         staleTombstoned: 0,\n941:         staleDeleted: 0,\n942:         warnings: 0,\n943:       }\n944:     },\n945:     dedup: {\n946:       inputTotal: mergedFiles.length,\n947:       uniqueTotal: files.length,\n948:       duplicatesSkipped: dedupDuplicatesSkipped,\n949:     },\n950:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n951:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n952:     checkpointRepair,\n953:     warnings: walkerWarnings,\n954:     capExceeded: walkerCapExceeded,\n955:   };\n956:   const scanAppliedActions: StatediffAction[] = [];\n957: \n958:   let filesToIndex: string[] = files;\n959:   let filesToDelete: string[] = [];\n960: \n961:   if (incremental && !force) {\n962:     const startCategorize = Date.now();\n963:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n964: \n965:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n966:     filesToDelete = categorized.toDelete;\n967: \n968:     results.unchanged = categorized.toSkip.length;\n969:     results.skipped_mtime = categorized.toSkip.length;\n970:     results.incremental.fast_path_skips = categorized.toSkip.length;\n971:     results.incremental.mtime_changed = categorized.toUpdate.length;\n972: \n973:     for (const unchangedPath of categorized.toSkip) {\n974:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n975:         results.constitutional.alreadyIndexed++;\n976:       }\n977:     }\n978: \n979:     const categorizeTime = Date.now() - startCategorize;\n980:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n981:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n982:   }\n983: \n984:   // Attempt move reconciliation before full delete+reindex cycle.\n985:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n986:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n987:   // stored-document_type cross-checks; the matched row is updated in place.\n988:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n989:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n990:     if (moveResult.reconciled.length > 0) {\n991:       results.moveReconciled = moveResult.reconciled.length;\n992:       filesToDelete = moveResult.filteredToDelete;\n993:       filesToIndex = moveResult.filteredToIndex;\n994:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n995:     }\n996:   }\n997: \n998:   const plannedScanActions = [\n999:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n1000:       target: 'memory_index',\n1001:       key: getCachedKey(filePath),\n1002:       sourceOperation: 'scan',\n1003:       metadata: { filePath },\n1004:     })),\n1005:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n1006:       target: 'memory_index',\n1007:       key: getCachedKey(filePath),\n1008:       sourceOperation: 'scan',\n1009:       metadata: { filePath },\n1010:     })),\n1011:   ];\n1012:   if (plannedScanActions.length > 0) {\n1013:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n1014:   }\n1015: \n1016:   // Track successfully indexed files for post-indexing mtime update.\n1017:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n1018:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n1019:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n1020:   // Before indexing would cause silent data loss — a failed file would be\n1021:   // Marked \"already indexed\" and permanently skipped.\n1022:   const successfullyIndexedFiles: string[] = [];\n1023:   const scanBatchSize = BATCH_SIZE;\n1024: \n1025:   ctx.onPhase?.('indexing');\n1026:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1027: \n1028:   if (filesToIndex.length > 0) {\n1029:     let processedInScan = 0;\n1030:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1031:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1032:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1033:       if (ctx.isCancelled?.()) {\n1034:         return { status: 'cancelled' } as IndexResult;\n1035:       }\n1036:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1037:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1038:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1039:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1040:       // spec docs and pass them through warn-only mode so they index against the same\n1041:       // pipeline without the document-evidence requirements.\n1042:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1043:       // During force reindex, use warn-only for all files — the goal is to index\n1044:       // everything that has valid frontmatter, not to enforce template contracts on\n1045:       // older files created before current templates were established.\n1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1047:       const indexResult = await indexSingleFile(filePath, force, {\n1048:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1049:         fromScan: true,\n1050:         asyncEmbedding: true,\n1051:         governance: governedIngest ? governanceDecision : undefined,\n1052:       });\n1053:       processedInScan += 1;\n1054:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1055:       return indexResult;\n1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1057: \n1058:     for (let i = 0; i < batchResults.length; i++) {\n1059:       const result = batchResults[i];\n1060:       const filePath = filesToIndex[i];\n1061:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1062: \n1063:       if (result.error) {\n1064:         results.failed++;\n1065:         results.files.push({\n1066:           file: path.basename(filePath),\n1067:           filePath,\n1068:           status: 'failed',\n1069:           error: result.error,\n1070:           errorDetail: result.errorDetail\n1071:         });\n1072:       } else if (isIndexResult(result)) {\n1073:         const isSuccessfulStatus =\n1074:           result.status === 'success' ||\n1075:           result.status === 'indexed' ||\n1076:           result.status === 'updated' ||\n1077:           result.status === 'unchanged' ||\n1078:           result.status === 'reinforced' ||\n1079:           result.status === 'duplicate' ||\n1080:           result.status === 'deferred';\n1081:         // A cancelled file was never indexed and was never going to be: counting it\n1082:         // as a failure would attribute an operator-requested stop to a file error.\n1083:         // It is neither success nor failure, so it falls through both tallies.\n1084:         if (!isSuccessfulStatus && result.status !== 'cancelled') {\n1085:           results.failed++;\n1086:         }\n1087: \n1088:         if (result.status === 'indexed') {\n1089:           results.indexed++;\n1090:           successfullyIndexedFiles.push(filePath);\n1091:           scanAppliedActions.push(createStatediffAction('insert', {\n1092:             target: 'memory_index',\n1093:             key: String(result.id ?? getCachedKey(filePath)),\n1094:             sourceOperation: 'scan',\n1095:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1096:           }));\n1097:         } else if (result.status === 'updated') {\n1098:           results.updated++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('upsert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         } else if (result.status === 'unchanged') {\n1107:           results.unchanged++;\n1108:           successfullyIndexedFiles.push(filePath);\n1109:         } else if (result.status === 'reinforced') {\n1110:           results.updated++;\n1111:           successfullyIndexedFiles.push(filePath);\n1112:           scanAppliedActions.push(createStatediffAction('upsert', {\n1113:             target: 'memory_index',\n1114:             key: String(result.id ?? getCachedKey(filePath)),\n1115:             sourceOperation: 'scan',\n1116:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1117:           }));\n1118:         } else if (result.status === 'duplicate') {\n1119:           results.unchanged++;\n1120:           successfullyIndexedFiles.push(filePath);\n1121:         } else if (result.status === 'deferred') {\n1122:           results.indexed++;\n1123:           results.deferred++;\n1124:           successfullyIndexedFiles.push(filePath);\n1125:           scanAppliedActions.push(createStatediffAction('insert', {\n1126:             target: 'memory_index',\n1127:             key: String(result.id ?? getCachedKey(filePath)),\n1128:             sourceOperation: 'scan',\n1129:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1130:           }));\n1131:         }\n1132: \n1133:         if (isConstitutional) {\n1134:           if (result.status === 'indexed') {\n1135:             results.constitutional.indexed++;\n1136:           } else if (result.status === 'unchanged') {\n1137:             results.constitutional.alreadyIndexed++;\n1138:           }\n1139:         }\n1140: \n1141:         if (result.status !== 'unchanged') {\n1142:           const rejectionDetail = !isSuccessfulStatus\n1143:             ? {\n1144:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1145:                   ? { rejectionCode: result.rejectionCode }\n1146:                   : {}),\n1147:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1148:                   ? { rejectionReason: result.rejectionReason }\n1149:                   : (typeof result.message === 'string' && result.message.length > 0\n1150:                     ? { rejectionReason: result.message }\n1151:                     : {})),\n1152:                 ...(typeof result.error === 'string' && result.error.length > 0\n1153:                   ? { error: result.error }\n1154:                   : {}),\n1155:               }\n1156:             : {};\n1157: \n1158:           results.files.push({\n1159:             file: path.basename(filePath),\n1160:             filePath,\n1161:             specFolder: result.specFolder,\n1162:             status: result.status,\n1163:             id: result.id,\n1164:             isConstitutional,\n1165:             ...rejectionDetail,\n1166:           });\n1167:         }\n1168:       } else {\n1169:         results.failed++;\n1170:         results.files.push({\n1171:           file: path.basename(filePath),\n1172:           filePath,\n1173:           status: 'failed',\n1174:           error: 'Unexpected batch result shape',\n1175:           errorDetail: JSON.stringify(result),\n1176:         });\n1177:       }\n1178:     }\n1179:   }\n1180: \n1181:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1182:   // Failed files keep their old mtime so they are retried on next scan.\n1183:   // This is the ONLY place where scan-triggered mtime updates occur.\n1184:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1185:   // Which rolls back atomically on failure — a complementary safety mechanism.\n1186:   if (successfullyIndexedFiles.length > 0) {\n1187:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1188:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1189:   }\n1190: \n1191:   if (include_spec_docs) {\n1192:     const database = requireDb();\n1193:     let promoterYieldCount = 0;\n1194:     for (const fileResult of results.files) {\n1195:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1196:       // that is the whole corpus, so without a periodic macrotask yield the event\n1197:       // loop is starved for the duration and no IPC (status, cancel, health,\n1198:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1199:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1200:       // inside one, so atomicity on the shared connection is preserved.\n1201:       if (++promoterYieldCount % 200 === 0) {\n1202:         if (ctx.isCancelled?.()) {\n1203:           return cancelledScanEnvelope(scanKey);\n1204:         }\n1205:         await new Promise<void>((resolve) => setImmediate(resolve));\n1206:       }\n1207:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1208:         continue;\n1209:       }\n1210:       try {\n1211:         const promotion = promoteMetadataEdges(database, {\n1212:           memoryId: fileResult.id,\n1213:           filePath: fileResult.filePath,\n1214:         });\n1215:         results.incremental.metadataPromoter.processed += promotion.processed;\n1216:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1217:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1218:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1219:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1220:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1221:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1222:         for (const warning of promotion.warnings) {\n1223:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1224:         }\n1225:       } catch (error: unknown) {\n1226:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1227:       }\n1228:     }\n1229:   }\n1230: \n1231:   if (ctx.isCancelled?.()) {\n1232:     return cancelledScanEnvelope(scanKey);\n1233:   }\n1234:   ctx.onPhase?.('post-processing');\n1235: \n1236:   if (filesToDelete.length > 0) {\n1237:     if (results.failed === 0) {\n1238:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1239:       results.staleDeleted = staleDeleteResult.deleted;\n1240:       results.staleDeleteFailed = staleDeleteResult.failed;\n1241:       scanAppliedActions.push(...staleDeleteResult.actions);\n1242:     } else {\n1243:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1244:     }\n1245:   }\n1246: \n1247:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1248:   results.orphanSwept = orphanSweepResult.swept;\n1249:   results.orphanSweepFailed = orphanSweepResult.failed;\n1250:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1251:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1252:   scanAppliedActions.push(...orphanSweepResult.actions);\n1253: \n1254:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1255:   if (results.postInsertEnrichmentRepaired > 0) {\n1256:     scanAppliedActions.push(createStatediffAction('upsert', {\n1257:       target: 'graph_edge',\n1258:       key: 'post-insert-enrichment-repair',\n1259:       sourceOperation: 'scan',\n1260:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1261:     }));\n1262:   }\n1263: \n1264:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1265:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1266:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1267:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1268:   }\n1269:   results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1270: \n1271:   // Create causal chains between spec folder documents.\n1272:   // Includes deferred indexing outcomes and incremental single-file updates.\n1273:   if (include_spec_docs) {\n1274:     try {\n1275:       // Determine which spec folders had spec document changes in this scan.\n1276:       // We use parsed document type (not basename) to avoid false positives\n1277:       // From memory/plan.md or similar filenames.\n1278:       const affectedSpecFolders = new Set<string>();\n1279:       for (const fileResult of results.files) {\n1280:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1281:           continue;\n1282:         }\n1283: \n1284:         if (!fileResult.filePath) {\n1285:           continue;\n1286:         }\n1287: \n1288:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1289:         if (\n1290:           docType !== 'memory' &&\n1291:           docType !== 'constitutional'\n1292:         ) {\n1293:           affectedSpecFolders.add(fileResult.specFolder);\n1294:         }\n1295:       }\n1296: \n1297:       if (affectedSpecFolders.size > 0) {\n1298:         const database = requireDb();\n1299:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1300:         initCausalEdges(database);\n1301: \n1302:         // Build full per-folder document map from DB (not just this scan's files).\n1303:         const selectDocIds = database.prepare(`\n1304:           SELECT document_type, MAX(id) AS id\n1305:           FROM memory_index\n1306:           WHERE spec_folder = ?\n1307:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1308:           GROUP BY document_type\n1309:         `);\n1310: \n1311:         let chainsCreated = 0;\n1312:         let foldersProcessed = 0;\n1313:         let chainYieldCount = 0;\n1314: \n1315:         for (const folder of affectedSpecFolders) {\n\n(Output capped at 50 KB. Showing lines 1-1315. Use offset=1316 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* ───────────────────────────────────────────────────────────────\n   4. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  nearDuplicateRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields — the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. SHARED INDEXING LOGIC\n──────────────────────────────────────────────────────────────── */\n\nimport { indexMemoryFile } from './memory-save.js';\nimport type { GovernanceDecision } from '../lib/governance/scope-governance.js';\nimport type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n\n/** Index a single memory file, delegating to the shared indexMemoryFile logic */\nasync function indexSingleFile(\n  filePath: string,\n  force: boolean = false,\n  options?: {\n    qualityGateMode?: 'enforce' | 'warn-only';\n    fromScan?: boolean;\n    asyncEmbedding?: boolean;\n    governance?: GovernanceDecision;\n    provenance?: WriteProvenanceContext;\n  },\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    force,\n    qualityGateMode: options?.qualityGateMode,\n    fromScan: options?.fromScan,\n    asyncEmbedding: options?.asyncEmbedding,\n    governance: options?.governance,\n    provenance: options?.provenance,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MEMORY INDEX SCAN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n// Hooks let a background runner observe cancellation and report phase/progress.\n// On the synchronous path every hook is undefined, so behavior is identical.\ninterface ScanRunContext {\n  isCancelled?: () => boolean;\n  onPhase?: (phase: string) => void;\n  onProgress?: (progress: { processed: number; total: number }) => void;\n}\n\n// Pull the envelope.data field back out of an MCP response so status can echo it.\nfunction extractEnvelopeData(response: MCPResponse): unknown {\n  try {\n    const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n    if (typeof text !== 'string') return null;\n    const parsed = JSON.parse(text) as { data?: unknown };\n    return parsed?.data ?? null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\n// Persisted payload for debugging: scan shape only, no governance identifiers.\nfunction redactScanArgs(args: ScanArgs): Record<string, unknown> {\n  return {\n    specFolder: args.specFolder ?? null,\n    force: !!args.force,\n    includeConstitutional: args.includeConstitutional !== false,\n    includeSpecDocs: args.includeSpecDocs !== false,\n    incremental: args.incremental !== false,\n    background: true,\n  };\n}\n\nfunction cancelledScanEnvelope(scanKey: string): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: 'Index scan cancelled before completion',\n    data: { status: 'cancelled', cancelled: true, scanKey },\n    hints: ['The scan was cancelled via memory_index_scan_cancel'],\n  });\n}\n\n/** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\nasync function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    recordMaintenanceRun('memory_index_scan', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      recovery: {\n        hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the index scan'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    specFolder: spec_folder = null,\n    force = false,\n    includeConstitutional: include_constitutional = true,\n    includeSpecDocs: include_spec_docs = true,\n    incremental = true\n  } = args;\n  const scanKey = createScanKey({\n    spec_folder,\n    force,\n    incremental,\n    include_constitutional,\n    include_spec_docs,\n  });\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  // Pre-flight dimension check\n  try {\n    const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n    if (profile) {\n      console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n    }\n  } catch (dimCheckError: unknown) {\n    const message = toErrorMessage(dimCheckError);\n    console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n  }\n\n  await checkDatabaseUpdated();\n\n  // Atomic scan lease check.\n  // Reserve scan_started_at up front to avoid check-then-set race windows.\n  const now = Date.now();\n  const lease = await acquireIndexScanLease({\n    now,\n    cooldownMs: INDEX_SCAN_COOLDOWN,\n  });\n  if (!lease.acquired) {\n    let message: string;\n    if (lease.reason === 'lease_active') {\n      message = 'A scan is already in progress; this call coalesced onto it.';\n    } else if (lease.reason === 'contention') {\n      message = 'The index DB is briefly locked by another writer; retry shortly.';\n    } else {\n      message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n    }\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'coalesced',\n      counts: { waitSeconds: lease.waitSeconds },\n      staleCandidates: 0,\n    });\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: message,\n      data: {\n        success: true,\n        coalesced: true,\n        status: 'coalesced',\n        reason: lease.reason,\n        scanKey,\n        waitSeconds: lease.waitSeconds,\n        nextPollAfterMs: lease.waitSeconds * 1000,\n        message,\n      },\n      hints: [message],\n    });\n  }\n\n  let scanLeaseReleased = false;\n  const releaseScanLease = async (): Promise<void> => {\n    if (scanLeaseReleased) return;\n    scanLeaseReleased = true;\n    await completeIndexScanLease(Date.now());\n  };\n\n  const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n\n  // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n  // processBatches() runs all batches sequentially and may exceed the lease expiry\n  // window (each batch waits on embedding/API latency). Without a periodic refresh\n  // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n  // launch a second parallel scan. Refresh well inside the expiry window (a third of\n  // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n  // from holding the event loop open at shutdown; finally clears it before release.\n  const leaseExpiryMs = lease.leaseExpiryMs;\n  const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n  let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n\n  // Background scans pass an onPhase hook; the synchronous foreground path does not.\n  // Gate diagnostics on it so the synchronous path's behavior stays identical.\n  const instrument = typeof ctx.onPhase === 'function';\n  let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n  let maxLoopLagMs = 0;\n\n  try {\n  leaseHeartbeat = setInterval(() => {\n    refreshScanLease();\n  }, leaseHeartbeatMs);\n  leaseHeartbeat.unref?.();\n\n  if (instrument) {\n    let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n    loopLagTimer = setInterval(() => {\n      const sampledAt = Date.now();\n      const lag = sampledAt - loopLagExpectedAt;\n      loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n      if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n      if (lag > LOOP_LAG_WARN_MS) {\n        // A late sample means the loop was blocked since the prior tick; logged\n        // adjacent to the phase=... line of whatever phase just ran, so the daemon\n        // log timeline fingers the blocking phase.\n        console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n      }\n    }, LOOP_LAG_SAMPLE_MS);\n    loopLagTimer.unref?.();\n  }\n\n  if (ctx.isCancelled?.()) {\n    await releaseScanLease();\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('discovering');\n\n  const workspacePath: string = DEFAULT_BASE_PATH;\n\n  const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n  const specDocFiles = include_spec_docs\n    ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const graphMetadataFiles = include_spec_docs\n    ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const walkerWarnings = [\n    ...discoveryWarnings(specDocFiles),\n    ...discoveryWarnings(graphMetadataFiles),\n  ];\n  const walkerCapExceeded = mergeDiscoveryCapExceeded(\n    discoveryCaps(specDocFiles),\n    discoveryCaps(graphMetadataFiles),\n  );\n\n  const canonicalKeyCache = new Map<string, string>();\n  const getCachedKey = (filePath: string): string => {\n    const cached = canonicalKeyCache.get(filePath);\n    if (cached) {\n      return cached;\n    }\n\n    const canonicalKey = getCanonicalPathKey(filePath);\n    canonicalKeyCache.set(filePath, canonicalKey);\n    return canonicalKey;\n  };\n\n  const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n  const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n  const seenCanonicalFiles = new Set<string>();\n  const files: string[] = [];\n\n  for (const filePath of mergedFiles) {\n    const canonicalKey = getCachedKey(filePath);\n    if (seenCanonicalFiles.has(canonicalKey)) {\n      continue;\n    }\n    seenCanonicalFiles.add(canonicalKey);\n    files.push(filePath);\n  }\n\n  const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n  if (dedupDuplicatesSkipped > 0) {\n    console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n  }\n\n  const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n    if (recordIds.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    let deleted = 0;\n    let failed = 0;\n    const actions: StatediffAction[] = [];\n\n    for (const staleRecordId of recordIds) {\n      try {\n        const database = vectorIndex.getDb();\n        const staleSnapshot = database?.prepare(\n          'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n        ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n\n        if (database) {\n          causalEdges.init(database);\n          causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n            reason: 'memory_index stale record cleanup',\n            command: 'memory-index.deleteIndexedRecordIds',\n            restoreContext: {\n              memoryId: staleRecordId,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n              filePath: staleSnapshot?.file_path ?? null,\n            },\n          });\n        }\n\n        if (vectorIndex.deleteMemory(staleRecordId)) {\n          deleted++;\n          actions.push(createStatediffAction('delete', {\n            target: 'memory_index',\n            key: String(staleRecordId),\n            sourceOperation: 'scan',\n            oldStateHash: null,\n            newStateHash: null,\n            metadata: {\n              filePath: staleSnapshot?.file_path ?? null,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n            },\n          }));\n          // Record DELETE history only after confirmed deletion.\n          try {\n            recordHistory(\n              staleRecordId,\n              'DELETE',\n              staleSnapshot?.file_path ?? null,\n              null,\n              'mcp:memory_index_scan',\n              staleSnapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort\n          }\n        } else {\n          failed++;\n        }\n      } catch (_error: unknown) {\n        failed++;\n      }\n    }\n\n    return { deleted, failed, actions };\n  };\n\n  const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n    if (paths.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n  };\n\n  const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n    if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweepOrphanIndexRows = (incrementalIndex as {\n      sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n    }).sweepOrphanIndexRows;\n\n    if (typeof sweepOrphanIndexRows !== 'function') {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n    const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n    return {\n      swept: deleteResult.deleted,\n      failed: deleteResult.failed,\n      scannedRows: sweep.scannedRows,\n      nextCursor: sweep.nextCursor,\n      actions: deleteResult.actions,\n    };\n  };\n\n  const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n    try {\n      runPostMutationHooks('scan', { ...context, statediffActions: actions });\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n    }\n  };\n\n  const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n    result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n  );\n\n  const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n    target: 'memory_index',\n    key: 'trigger-embedding-backfill',\n    sourceOperation: 'scan',\n    metadata: {\n      readyRows: result.readyRows,\n      failedRows: result.failedRows,\n      pendingRows: result.pendingRows,\n    },\n  });\n\n  const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n    if (actions.length === 0) {\n      return;\n    }\n    results.aliasConflicts = detectAliasConflictsFromIndex();\n    results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n  };\n\n  const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n    try {\n      const repairResult = await repairIncompleteMarkers(\n        { database: requireDb(), plannerMode: 'full-auto' },\n        { limit: BATCH_SIZE },\n      );\n      if (repairResult.failed > 0) {\n        console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n      }\n      return repairResult.repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n    if (!isMemoryIdempotencyEnabled()) {\n      return 0;\n    }\n    try {\n      const database = requireDb();\n      const rows = database.prepare(`\n        SELECT id, spec_folder, title, content_text, content_hash,\n               tenant_id, user_id, agent_id, session_id\n        FROM memory_index\n        WHERE parent_id IS NULL\n          AND embedding_status = 'success'\n          AND content_text IS NOT NULL\n          AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n        ORDER BY id ASC\n        LIMIT ?\n      `).all(BATCH_SIZE) as Array<{\n        id: number;\n        spec_folder: string;\n        title: string | null;\n        content_text: string;\n        content_hash: string | null;\n        tenant_id: string | null;\n        user_id: string | null;\n        agent_id: string | null;\n        session_id: string | null;\n      }>;\n      let repaired = 0;\n      for (const row of rows) {\n        try {\n          const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n          const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n          recordNearDuplicateCheck({\n            database,\n            memoryId: row.id,\n            specFolder: row.spec_folder,\n            contentHash: row.content_hash,\n            embedding,\n            scope: {\n              tenantId: row.tenant_id,\n              userId: row.user_id,\n              agentId: row.agent_id,\n              sessionId: row.session_id,\n            },\n          });\n          repaired++;\n        } catch (error: unknown) {\n          console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n        }\n      }\n      return repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  if (files.length === 0) {\n    let staleDeleted = 0;\n    let staleDeleteFailed = 0;\n    const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n    const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n    const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n    if (incremental && !force) {\n      const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n      const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n      staleDeleted = staleDeleteResult.deleted;\n      staleDeleteFailed = staleDeleteResult.failed;\n      if (staleDeleted > 0) {\n        runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n      }\n    }\n\n    const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n      runTriggerEmbeddingBackfill(requireDb(), {\n        isCancelled: () => ctx.isCancelled?.() ?? false,\n      }));\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        nearDuplicateRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    nearDuplicateRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files — the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        // A cancelled file was never indexed and was never going to be: counting it\n        // as a failure would attribute an operator-requested stop to a file error.\n        // It is neither success nor failure, so it falls through both tallies.\n        if (!isSuccessfulStatus && result.status !== 'cancelled') {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure — a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {","lineStart":1,"lineEnd":1315,"totalLines":1316,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781763858176,"end":1781763858197}},"metadata":{"openai":{"itemId":"fc_0790af5bc91d46de016a338f1202988191834516a47d13529a"}},"id":"prt_ed966ded1001Uf48rfKOI4vrXn","sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","messageID":"msg_ed966b3aa001EJftVGhbS0o1FS"}}
{"type":"tool_use","timestamp":1781763858203,"sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","part":{"type":"tool","tool":"read","callID":"call_Oq77h67esOgjhFDzbL5G84Ig","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Idempotency Receipts\n3: // ───────────────────────────────────────────────────────────────\n4: import { createHash } from 'node:crypto';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import type { MCPResponse } from '../../handlers/types.js';\n8: \n9: export type IdempotencyOperation = 'memory_save' | 'memory_update';\n10: \n11: export interface IdempotencyReceiptInput {\n12:   operation: IdempotencyOperation;\n13:   contentHash: string | null;\n14:   requestFingerprint: Record<string, unknown>;\n15:   payload: Record<string, unknown>;\n16: }\n17: \n18: export interface IdempotencyReceiptKey {\n19:   operation: IdempotencyOperation;\n20:   receiptKey: string;\n21:   contentHash: string | null;\n22:   requestFingerprintHash: string;\n23:   payloadHash: string;\n24: }\n25: \n26: export type IdempotencyLookupResult =\n27:   | { status: 'miss'; key: IdempotencyReceiptKey }\n28:   | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n29:   | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n30: \n31: interface ReceiptRow {\n32:   payload_hash: string;\n33:   response_payload: string;\n34: }\n35: \n36: interface MemorySaveReceiptCandidate {\n37:   id?: unknown;\n38:   status?: unknown;\n39: }\n40: \n41: const RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n42: \n43: const CLIENT_TOKEN_KEYS = new Set([\n44:   'idempotencykey',\n45:   'idempotency_key',\n46:   'idempotencytoken',\n47:   'idempotency_token',\n48:   'clientidempotencykey',\n49:   'client_idempotency_key',\n50:   'clientidempotencytoken',\n51:   'client_idempotency_token',\n52: ]);\n53: \n54: export function isMemoryIdempotencyEnabled(): boolean {\n55:   const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n56:   return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n57: }\n58: \n59: function normalizeForHash(value: unknown): unknown {\n60:   if (Array.isArray(value)) {\n61:     return value.map(normalizeForHash);\n62:   }\n63:   if (!value || typeof value !== 'object') {\n64:     return value;\n65:   }\n66: \n67:   const record = value as Record<string, unknown>;\n68:   const normalized: Record<string, unknown> = {};\n69:   for (const key of Object.keys(record).sort()) {\n70:     if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n71:       continue;\n72:     }\n73:     const normalizedValue = normalizeForHash(record[key]);\n74:     if (normalizedValue !== undefined) {\n75:       normalized[key] = normalizedValue;\n76:     }\n77:   }\n78:   return normalized;\n79: }\n80: \n81: function hashJson(value: unknown): string {\n82:   return createHash('sha256')\n83:     .update(JSON.stringify(normalizeForHash(value)))\n84:     .digest('hex');\n85: }\n86: \n87: export function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n88:   const requestFingerprintHash = hashJson(input.requestFingerprint);\n89:   const payloadHash = hashJson(input.payload);\n90:   const material = {\n91:     operation: input.operation,\n92:     contentHash: input.contentHash ?? null,\n93:     requestFingerprintHash,\n94:   };\n95:   return {\n96:     operation: input.operation,\n97:     receiptKey: hashJson(material),\n98:     contentHash: input.contentHash ?? null,\n99:     requestFingerprintHash,\n100:     payloadHash,\n101:   };\n102: }\n103: \n104: export function shouldStoreMemorySaveReceipt(\n105:   result: MemorySaveReceiptCandidate,\n106:   response: MCPResponse,\n107: ): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n108:   return response.isError !== true\n109:     && typeof result.id === 'number'\n110:     && Number.isInteger(result.id)\n111:     && result.id > 0\n112:     && typeof result.status === 'string'\n113:     && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n114: }\n115: \n116: export function lookupIdempotencyReceipt(\n117:   database: BetterSqlite3.Database,\n118:   input: IdempotencyReceiptInput,\n119: ): IdempotencyLookupResult {\n120:   return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n121: }\n122: \n123: export function lookupIdempotencyReceiptByKey(\n124:   database: BetterSqlite3.Database,\n125:   key: IdempotencyReceiptKey,\n126: ): IdempotencyLookupResult {\n127:   const row = database.prepare(`\n128:     SELECT payload_hash, response_payload\n129:     FROM memory_idempotency_receipts\n130:     WHERE receipt_key = ?\n131:   `).get(key.receiptKey) as ReceiptRow | undefined;\n132: \n133:   if (!row) {\n134:     return { status: 'miss', key };\n135:   }\n136:   if (row.payload_hash !== key.payloadHash) {\n137:     return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n138:   }\n139:   return {\n140:     status: 'replay',\n141:     key,\n142:     response: JSON.parse(row.response_payload) as MCPResponse,\n143:   };\n144: }\n145: \n146: /**\n147:  * Drops the receipt for a key so a follow-up store writes fresh.\n148:  *\n149:  * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n150:  * not a durable record. When a replay is rejected because the live index no\n151:  * longer matches the receipt's content_hash (the logical path moved on and\n152:  * came back, so the cached response now carries a superseded memory id), the\n153:  * cache entry is stale: leaving it lets the post-write store lose the\n154:  * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n155:  * it first lets the re-indexed write store its current response and keeps the\n156:  * cache consistent with the active row. Best-effort: a delete failure must\n157:  * never block serving the live write.\n158:  */\n159: export function deleteIdempotencyReceiptByKey(\n160:   database: BetterSqlite3.Database,\n161:   key: IdempotencyReceiptKey,\n162: ): void {\n163:   try {\n164:     database.prepare(`\n165:       DELETE FROM memory_idempotency_receipts\n166:       WHERE receipt_key = ?\n167:     `).run(key.receiptKey);\n168:   } catch {\n169:     // Best-effort cache eviction; serving the live write takes priority.\n170:   }\n171: }\n172: \n173: export function storeIdempotencyReceipt(\n174:   database: BetterSqlite3.Database,\n175:   key: IdempotencyReceiptKey,\n176:   response: MCPResponse,\n177:   memoryId?: number | null,\n178: ): boolean {\n179:   const info = database.prepare(`\n180:     INSERT INTO memory_idempotency_receipts (\n181:       receipt_key,\n182:       operation,\n183:       content_hash,\n184:       request_fingerprint,\n185:       payload_hash,\n186:       response_payload,\n187:       memory_id,\n188:       updated_at\n189:     ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n190:     ON CONFLICT(receipt_key) DO NOTHING\n191:   `).run(\n192:     key.receiptKey,\n193:     key.operation,\n194:     key.contentHash,\n195:     key.requestFingerprintHash,\n196:     key.payloadHash,\n197:     JSON.stringify(response),\n198:     memoryId ?? null,\n199:   );\n200:   // changes === 0 means a concurrent caller already stored the canonical receipt\n201:   // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n202:   return info.changes > 0;\n203: }\n204: \n205: /**\n206:  * Marks a mutated loser's response with an explicit store-race conflict.\n207:  *\n208:  * When a writer loses the first-store race to a concurrent SAME-KEY,\n209:  * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n210:  * already landed (so an error response would lie), and the winner's stored\n211:  * response answers a different payload (so replaying it would lie too).\n212:  * Rolling the landed mutation back from this late window is the dangerous\n213:  * non-option. What remains is the loser's own response carrying a visible\n214:  * conflict block, so callers know the canonical receipt for this key\n215:  * belongs to a different concurrent request and a later retry may replay\n216:  * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n217:  * original response is returned unmodified.\n218:  */\n219: export function markResponseWithReceiptStoreConflict(\n220:   response: MCPResponse,\n221:   key: IdempotencyReceiptKey,\n222:   storedPayloadHash: string | undefined,\n223: ): MCPResponse {\n224:   const first = response.content?.[0];\n225:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n226:     return response;\n227:   }\n228:   try {\n229:     const envelope = JSON.parse(first.text) as Record<string, unknown>;\n230:     const data = (envelope.data && typeof envelope.data === 'object')\n231:       ? envelope.data as Record<string, unknown>\n232:       : {};\n233:     data.idempotencyStoreConflict = {\n234:       receiptKey: key.receiptKey,\n235:       payloadHash: key.payloadHash,\n236:       storedPayloadHash: storedPayloadHash ?? null,\n237:     };\n238:     envelope.data = data;\n239:     const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n240:     hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n241:     envelope.hints = hints;\n242:     return {\n243:       ...response,\n244:       content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n245:     };\n246:   } catch {\n247:     return response;\n248:   }\n249: }\n250: \n251: /**\n252:  * Deletes receipts older than the retention window. Receipts are replay\n253:  * caches, not durable records: unbounded growth plus indefinite stale\n254:  * replays (including against deleted memories) is the failure mode this\n255:  * sweep bounds. Best-effort by contract — callers must never let a sweep\n256:  * failure block serving.\n257:  */\n258: export function pruneExpiredIdempotencyReceipts(\n259:   database: BetterSqlite3.Database,\n260:   ttlDays?: number,\n261: ): number {\n262:   const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n263:   const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n264:   try {\n265:     // Prune on created_at: it is indexed and, since receipts are insert-only\n266:     // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at —\n267:     // so this is behaviorally identical but avoids a full table scan.\n268:     const info = database.prepare(`\n269:       DELETE FROM memory_idempotency_receipts\n270:       WHERE created_at < datetime('now', ?)\n271:     `).run(`-${days} days`);\n272:     return info.changes;\n273:   } catch {\n274:     return 0;\n275:   }\n276: }\n277: \n278: export function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n279:   const first = response.content?.[0];\n280:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n281:     return null;\n282:   }\n283:   try {\n284:     const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n285:     const id = envelope.data?.id ?? envelope.data?.updated;\n286:     return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n287:   } catch {\n288:     return null;\n289:   }\n290: }\n\n(End of file - total 290 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Idempotency Receipts\n// ───────────────────────────────────────────────────────────────\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Idempotency Receipts\n// ───────────────────────────────────────────────────────────────\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;\n  contentHash: string | null;\n  requestFingerprintHash: string;\n  payloadHash: string;\n}\n\nexport type IdempotencyLookupResult =\n  | { status: 'miss'; key: IdempotencyReceiptKey }\n  | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n  | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n\ninterface ReceiptRow {\n  payload_hash: string;\n  response_payload: string;\n}\n\ninterface MemorySaveReceiptCandidate {\n  id?: unknown;\n  status?: unknown;\n}\n\nconst RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n\nconst CLIENT_TOKEN_KEYS = new Set([\n  'idempotencykey',\n  'idempotency_key',\n  'idempotencytoken',\n  'idempotency_token',\n  'clientidempotencykey',\n  'client_idempotency_key',\n  'clientidempotencytoken',\n  'client_idempotency_token',\n]);\n\nexport function isMemoryIdempotencyEnabled(): boolean {\n  const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n  return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n}\n\nfunction normalizeForHash(value: unknown): unknown {\n  if (Array.isArray(value)) {\n    return value.map(normalizeForHash);\n  }\n  if (!value || typeof value !== 'object') {\n    return value;\n  }\n\n  const record = value as Record<string, unknown>;\n  const normalized: Record<string, unknown> = {};\n  for (const key of Object.keys(record).sort()) {\n    if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n      continue;\n    }\n    const normalizedValue = normalizeForHash(record[key]);\n    if (normalizedValue !== undefined) {\n      normalized[key] = normalizedValue;\n    }\n  }\n  return normalized;\n}\n\nfunction hashJson(value: unknown): string {\n  return createHash('sha256')\n    .update(JSON.stringify(normalizeForHash(value)))\n    .digest('hex');\n}\n\nexport function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n  const requestFingerprintHash = hashJson(input.requestFingerprint);\n  const payloadHash = hashJson(input.payload);\n  const material = {\n    operation: input.operation,\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n  };\n  return {\n    operation: input.operation,\n    receiptKey: hashJson(material),\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n    payloadHash,\n  };\n}\n\nexport function shouldStoreMemorySaveReceipt(\n  result: MemorySaveReceiptCandidate,\n  response: MCPResponse,\n): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n  return response.isError !== true\n    && typeof result.id === 'number'\n    && Number.isInteger(result.id)\n    && result.id > 0\n    && typeof result.status === 'string'\n    && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n}\n\nexport function lookupIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  input: IdempotencyReceiptInput,\n): IdempotencyLookupResult {\n  return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n}\n\nexport function lookupIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): IdempotencyLookupResult {\n  const row = database.prepare(`\n    SELECT payload_hash, response_payload\n    FROM memory_idempotency_receipts\n    WHERE receipt_key = ?\n  `).get(key.receiptKey) as ReceiptRow | undefined;\n\n  if (!row) {\n    return { status: 'miss', key };\n  }\n  if (row.payload_hash !== key.payloadHash) {\n    return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n  }\n  return {\n    status: 'replay',\n    key,\n    response: JSON.parse(row.response_payload) as MCPResponse,\n  };\n}\n\n/**\n * Drops the receipt for a key so a follow-up store writes fresh.\n *\n * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n * not a durable record. When a replay is rejected because the live index no\n * longer matches the receipt's content_hash (the logical path moved on and\n * came back, so the cached response now carries a superseded memory id), the\n * cache entry is stale: leaving it lets the post-write store lose the\n * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n * it first lets the re-indexed write store its current response and keeps the\n * cache consistent with the active row. Best-effort: a delete failure must\n * never block serving the live write.\n */\nexport function deleteIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): void {\n  try {\n    database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE receipt_key = ?\n    `).run(key.receiptKey);\n  } catch {\n    // Best-effort cache eviction; serving the live write takes priority.\n  }\n}\n\nexport function storeIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n  response: MCPResponse,\n  memoryId?: number | null,\n): boolean {\n  const info = database.prepare(`\n    INSERT INTO memory_idempotency_receipts (\n      receipt_key,\n      operation,\n      content_hash,\n      request_fingerprint,\n      payload_hash,\n      response_payload,\n      memory_id,\n      updated_at\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n    ON CONFLICT(receipt_key) DO NOTHING\n  `).run(\n    key.receiptKey,\n    key.operation,\n    key.contentHash,\n    key.requestFingerprintHash,\n    key.payloadHash,\n    JSON.stringify(response),\n    memoryId ?? null,\n  );\n  // changes === 0 means a concurrent caller already stored the canonical receipt\n  // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n  return info.changes > 0;\n}\n\n/**\n * Marks a mutated loser's response with an explicit store-race conflict.\n *\n * When a writer loses the first-store race to a concurrent SAME-KEY,\n * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n * already landed (so an error response would lie), and the winner's stored\n * response answers a different payload (so replaying it would lie too).\n * Rolling the landed mutation back from this late window is the dangerous\n * non-option. What remains is the loser's own response carrying a visible\n * conflict block, so callers know the canonical receipt for this key\n * belongs to a different concurrent request and a later retry may replay\n * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n * original response is returned unmodified.\n */\nexport function markResponseWithReceiptStoreConflict(\n  response: MCPResponse,\n  key: IdempotencyReceiptKey,\n  storedPayloadHash: string | undefined,\n): MCPResponse {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return response;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as Record<string, unknown>;\n    const data = (envelope.data && typeof envelope.data === 'object')\n      ? envelope.data as Record<string, unknown>\n      : {};\n    data.idempotencyStoreConflict = {\n      receiptKey: key.receiptKey,\n      payloadHash: key.payloadHash,\n      storedPayloadHash: storedPayloadHash ?? null,\n    };\n    envelope.data = data;\n    const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n    hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n    envelope.hints = hints;\n    return {\n      ...response,\n      content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n    };\n  } catch {\n    return response;\n  }\n}\n\n/**\n * Deletes receipts older than the retention window. Receipts are replay\n * caches, not durable records: unbounded growth plus indefinite stale\n * replays (including against deleted memories) is the failure mode this\n * sweep bounds. Best-effort by contract — callers must never let a sweep\n * failure block serving.\n */\nexport function pruneExpiredIdempotencyReceipts(\n  database: BetterSqlite3.Database,\n  ttlDays?: number,\n): number {\n  const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n  const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n  try {\n    // Prune on created_at: it is indexed and, since receipts are insert-only\n    // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at —\n    // so this is behaviorally identical but avoids a full table scan.\n    const info = database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE created_at < datetime('now', ?)\n    `).run(`-${days} days`);\n    return info.changes;\n  } catch {\n    return 0;\n  }\n}\n\nexport function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return null;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n    const id = envelope.data?.id ?? envelope.data?.updated;\n    return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n  } catch {\n    return null;\n  }\n}","lineStart":1,"lineEnd":290,"totalLines":290,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","time":{"start":1781763858182,"end":1781763858199}},"metadata":{"openai":{"itemId":"fc_0790af5bc91d46de016a338f1202a081919a18244494b5607d"}},"id":"prt_ed966df030012yWKTTS4N7bk3B","sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","messageID":"msg_ed966b3aa001EJftVGhbS0o1FS"}}
{"type":"tool_use","timestamp":1781763858203,"sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","part":{"type":"tool","tool":"read","callID":"call_uLvY6p6s8cqvCstdvfrnQezy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","offset":1,"limit":2600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Causal Edges\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Causal edge creation (memory_causal_link)\n5: // Causal relationship graph for memory lineage\n6: import type Database from 'better-sqlite3';\n7: import { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\n8: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n9: import { detectContradictions } from '../graph/contradiction-detection.js';\n10: import { ensureTemporalColumns } from '../graph/temporal-edges.js';\n11: import { isTemporalEdgesEnabled } from '../search/search-flags.js';\n12: import { runInTransaction } from './transaction-manager.js';\n13: import { sweepCausalEdges } from '../causal/sweep.js';\n14: import { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\n15: import type { CausalEdgeSweepResult } from '../causal/sweep.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    1. CONSTANTS\n19: ----------------------------------------------------------------*/\n20: \n21: const RELATION_TYPES = Object.freeze({\n22:   CAUSED: 'caused',\n23:   ENABLED: 'enabled',\n24:   SUPERSEDES: 'supersedes',\n25:   CONTRADICTS: 'contradicts',\n26:   DERIVED_FROM: 'derived_from',\n27:   SUPPORTS: 'supports',\n28: } as const);\n29: \n30: type RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n31: \n32: /**\n33:  * C138: Relation weight multipliers applied during traversal scoring.\n34:  * Higher values amplify the propagated strength; values < 1.0 dampen it.\n35:  */\n36: const RELATION_WEIGHTS: Record<string, number> = {\n37:   supersedes:   1.5,  // Strongest signal — new info replaces old\n38:   caused:       1.3,  // Strong causal link\n39:   enabled:      1.1,  // Weak causal link\n40:   supports:     1.0,  // Neutral / default\n41:   derived_from: 1.0,  // Neutral / default\n42:   contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n43: };\n44: \n45: const DEFAULT_MAX_DEPTH = 3;\n46: const MAX_EDGES_LIMIT = 100;\n47: \n48: // Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\n49: const MAX_EDGES_PER_NODE = 20;\n50: const MAX_AUTO_STRENGTH = 0.5;\n51: const MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\n52: const WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\n53: const CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\n54: const STALENESS_THRESHOLD_DAYS = 90;\n55: const DECAY_STRENGTH_AMOUNT = 0.1;\n56: const DECAY_PERIOD_DAYS = 30;\n57: \n58: function parsePositiveIntegerEnv(name: string, fallback: number): number {\n59:   const value = process.env[name];\n60:   if (!value) return fallback;\n61:   const parsed = Number.parseInt(value, 10);\n62:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n63: }\n64: \n65: function isFiniteNumber(value: unknown): value is number {\n66:   return typeof value === 'number' && Number.isFinite(value);\n67: }\n68: \n69: /**\n70:  * Classify edge provenance as automatic. Covers the legacy 'auto' creator and\n71:  * namespaced automatic creators such as 'auto-session'. Shared by the insert\n72:  * cap path and the consolidation strengthening cap so the two sites cannot\n73:  * drift. Non-auto values ('manual', 'automatic', 'author') must not match.\n74:  */\n75: function isAutoEdgeCreator(createdBy: string | null | undefined): boolean {\n76:   return createdBy === 'auto'\n77:     || (typeof createdBy === 'string' && createdBy.startsWith('auto-'));\n78: }\n79: \n80: function clampStrength(strength: number): number | null {\n81:   if (!Number.isFinite(strength)) return null;\n82:   return Math.max(0, Math.min(1, strength));\n83: }\n84: \n85: function normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n86:   return {\n87:     id: Number(row.id),\n88:     source_id: String(row.source_id),\n89:     target_id: String(row.target_id),\n90:     source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n91:     target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n92:     relation: String(row.relation) as RelationType,\n93:     strength: Number(row.strength),\n94:     evidence: row.evidence == null ? null : String(row.evidence),\n95:     extracted_at: String(row.extracted_at),\n96:     created_by: String(row.created_by ?? 'manual'),\n97:     last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n98:   };\n99: }\n100: \n101: /* ───────────────────────────────────────────────────────────────\n102:    2. INTERFACES\n103: ----------------------------------------------------------------*/\n104: \n105: interface CausalEdge {\n106:   id: number;\n107:   source_id: string;\n108:   target_id: string;\n109:   source_anchor: string | null;\n110:   target_anchor: string | null;\n111:   relation: RelationType;\n112:   strength: number;\n113:   evidence: string | null;\n114:   extracted_at: string;\n115:   created_by: string;\n116:   last_accessed: string | null;\n117: }\n118: \n119: interface CausalEdgeRow extends Record<string, unknown> {\n120:   id: number;\n121:   source_id: string;\n122:   target_id: string;\n123:   source_anchor?: string | null;\n124:   target_anchor?: string | null;\n125:   relation: RelationType;\n126:   strength: number;\n127:   evidence: string | null;\n128:   extracted_at: string;\n129:   created_by: string;\n130:   last_accessed: string | null;\n131: }\n132: \n133: type EdgeQueryResult = CausalEdge[] & {\n134:   truncated: boolean;\n135:   limit: number;\n136: };\n137: \n138: interface WeightHistoryEntry {\n139:   id: number;\n140:   edge_id: number;\n141:   old_strength: number;\n142:   new_strength: number;\n143:   changed_by: string;\n144:   changed_at: string;\n145:   reason: string | null;\n146: }\n147: \n148: interface GraphStats {\n149:   totalEdges: number;\n150:   byRelation: Record<string, number>;\n151:   avgStrength: number;\n152:   uniqueSources: number;\n153:   uniqueTargets: number;\n154: }\n155: \n156: interface DeleteEdgeOptions {\n157:   reason?: string;\n158:   command?: string;\n159:   restoreContext?: Record<string, unknown>;\n160: }\n161: \n162: interface InsertEdgeMetadataOptions {\n163:   confidence?: number;\n164:   extractionMethod?: string;\n165: }\n166: \n167: interface InsertEdgeOutcome {\n168:   status: 'inserted' | 'updated' | 'skipped';\n169:   reason: string | null;\n170:   edgeId: number | null;\n171: }\n172: \n173: interface CausalChainNode {\n174:   id: string;\n175:   edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n176:   depth: number;\n177:   relation: RelationType;\n178:   strength: number;\n179:   children: CausalChainNode[];\n180:   truncated?: boolean;\n181:   truncationLimit?: number | null;\n182: }\n183: \n184: /* ───────────────────────────────────────────────────────────────\n185:    3. MODULE STATE\n186: ----------------------------------------------------------------*/\n187: \n188: let db: Database.Database | null = null;\n189: let lastInsertEdgeOutcome: InsertEdgeOutcome | null = null;\n190: \n191: /**\n192:  * Monotonically-increasing generation counter bumped on every causal-edge\n193:  * mutation (insert/update/delete/rollback). Read-only callers can include this\n194:  * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n195:  * cached responses derived from the causal graph become stale on the next\n196:  * lookup without requiring a wholesale tool-cache invalidation.\n197:  *\n198:  * targeted memory_search cache invalidation.\n199:  */\n200: // Counter lives in causal-generation.ts so the tombstone sweep (which this\n201: // module imports) can bump it without a circular import.\n202: \n203: function setLastInsertEdgeOutcome(outcome: InsertEdgeOutcome): void {\n204:   lastInsertEdgeOutcome = outcome;\n205: }\n206: \n207: function getLastInsertEdgeOutcome(): InsertEdgeOutcome | null {\n208:   return lastInsertEdgeOutcome;\n209: }\n210: \n211: function invalidateDegreeCache(): void {\n212:   // bump the causal-edges generation FIRST so any cache key that\n213:   // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n214:   // stale on the next read without invalidating unrelated tool entries.\n215:   bumpCausalEdgesGeneration();\n216: \n217:   try {\n218:     // Use db-specific cache invalidation instead of the no-op global version\n219:     if (db) {\n220:       clearDegreeCacheForDb(db);\n221:     }\n222:   } catch (_error: unknown) {\n223:     // Cache invalidation is best-effort; never block edge mutations\n224:   }\n225:   try {\n226:     clearGraphSignalsCache();\n227:   } catch (_error: unknown) {\n228:     // Graph signals cache invalidation is best-effort\n229:   }\n230: }\n231: \n232: function enforceRelationWindowCap(\n233:   relation: string,\n234:   database: Database.Database,\n235:   windowMs: number = WINDOW_MS,\n236:   capPerWindow: number = CAP_PER_WINDOW,\n237: ): boolean {\n238:   try {\n239:     const windowStart = new Date(Date.now() - windowMs).toISOString();\n240:     const row = (database.prepare(`\n241:       SELECT COUNT(*) as count FROM causal_edges\n242:       WHERE relation = ?\n243:         AND datetime(extracted_at) >= datetime(?)\n244:     `) as Database.Statement).get(relation, windowStart) as { count: number };\n245:     const count = row.count;\n246:     if (count >= capPerWindow) {\n247:       console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n248:       return false;\n249:     }\n250:     return true;\n251:   } catch (error: unknown) {\n252:     const msg = error instanceof Error ? error.message : String(error);\n253:     console.warn(`[causal-edges] relation cap check failed for ${relation}: ${msg}`);\n254:     return true;\n255:   }\n256: }\n257: \n258: /* ───────────────────────────────────────────────────────────────\n259:    4. INITIALIZATION\n260: ----------------------------------------------------------------*/\n261: \n262: function init(database: Database.Database): void {\n263:   db = database;\n264: \n265:   // Defensive traversal indexes — the canonical creation lives in\n266:   // Vector-index-impl.ts migration v8. These IF NOT EXISTS guards\n267:   // Ensure the indexes are present even when the module is initialised outside\n268:   // The normal migration path (e.g. tests, standalone scripts).\n269:   try {\n270:     database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n271:     database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n272:     ensureTemporalColumns(database);\n273:   } catch (_e: unknown) {\n274:     // Best-effort: table may not exist yet during early startup sequencing\n275:   }\n276: }\n277: \n278: /* ───────────────────────────────────────────────────────────────\n279:    5. EDGE OPERATIONS\n280: ----------------------------------------------------------------*/\n281: \n282: function insertEdge(\n283:   sourceId: string,\n284:   targetId: string,\n285:   relation: RelationType,\n286:   strength: number = 1.0,\n287:   evidence: string | null = null,\n288:   shouldInvalidateCache: boolean = true,\n289:   createdBy: string = 'manual',\n290:   anchors: { sourceAnchor?: string | null; targetAnchor?: string | null } = {},\n291:   metadata: InsertEdgeMetadataOptions = {},\n292: ): number | null {\n293:   lastInsertEdgeOutcome = null;\n294:   if (!db) {\n295:     console.warn('[causal-edges] Database not initialized. Server may still be starting up.');\n296:     setLastInsertEdgeOutcome({ status: 'skipped', reason: 'database not initialized', edgeId: null });\n297:     return null;\n298:   }\n299:   const database = db;\n300: \n301:   // NFR-R01: Auto edges capped at MAX_AUTO_STRENGTH\n302:   const effectiveStrength = isAutoEdgeCreator(createdBy)\n303:     ? Math.min(strength, MAX_AUTO_STRENGTH)\n304:     : strength;\n305: \n306:   // Prevent self-loops\n307:   if (sourceId === targetId) {\n308:     setLastInsertEdgeOutcome({ status: 'skipped', reason: 'self-loop', edgeId: null });\n309:     return null;\n310:   }\n311: \n312:   // FK check deferred — test environments use synthetic IDs not in memory_index.\n313:   // Implementing FK validation would require seeding memory_index in 20+ causal edge tests.\n314: \n315:   // NFR-R01: Edge bounds — reject if node already has MAX_EDGES_PER_NODE auto edges\n316:   if (isAutoEdgeCreator(createdBy)) {\n317:     const edgeCount = countEdgesForNode(sourceId);\n318:     if (edgeCount >= MAX_EDGES_PER_NODE) {\n319:       console.warn(`[causal-edges] Edge bounds: node ${sourceId} has ${edgeCount} edges (max ${MAX_EDGES_PER_NODE}), rejecting auto edge`);\n320:       setLastInsertEdgeOutcome({ status: 'skipped', reason: 'edge bounds exceeded', edgeId: null });\n321:       return null;\n322:     }\n323:   }\n324: \n325:   try {\n326:     const clampedStrength = clampStrength(effectiveStrength);\n327:     if (clampedStrength === null) {\n328:       console.warn('[causal-edges] insertEdge rejected non-finite strength');\n329:       setLastInsertEdgeOutcome({ status: 'skipped', reason: 'non-finite strength', edgeId: null });\n330:       return null;\n331:     }\n332: \n333:     // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n334:     const rowId = database.transaction(() => {\n335:       if (isTemporalEdgesEnabled()) {\n336:         detectContradictions(\n337:           database,\n338:           Number.parseInt(sourceId, 10),\n339:           Number.parseInt(targetId, 10),\n340:           relation,\n341:         );\n342:       }\n343: \n344:       // Check if edge exists (for weight_history logging on conflict update).\n345:       // This SELECT is intentional: we need the old strength to decide whether\n346:       // To write a weight_history row after the upsert. The subsequent INSERT\n347:       // Uses last_insert_rowid() to avoid a second post-upsert SELECT.\n348:       const existing = (database.prepare(`\n349:         SELECT id, strength, evidence, created_by FROM causal_edges\n350:         WHERE source_id = ? AND target_id = ? AND relation = ?\n351:           AND COALESCE(source_anchor, '') = COALESCE(?, '')\n352:           AND COALESCE(target_anchor, '') = COALESCE(?, '')\n353:       `) as Database.Statement).get(\n354:         sourceId,\n355:         targetId,\n356:         relation,\n357:         anchors.sourceAnchor ?? null,\n358:         anchors.targetAnchor ?? null,\n359:       ) as { id: number; strength: number; evidence: string | null; created_by: string | null } | undefined;\n360: \n361:       // Manual/curated edges must never be overwritten by automatic writers:\n362:       // an auto upsert against a non-auto row is skipped so curated provenance\n363:       // and strength survive. Auto-to-auto updates remain allowed under caps.\n364:       if (existing && isAutoEdgeCreator(createdBy) && !isAutoEdgeCreator(existing.created_by ?? 'manual')) {\n365:         console.warn(\n366:           `[causal-edges] skipped manual edge ${existing.id} (created_by=${existing.created_by ?? 'manual'}); skipped overwrite by ${createdBy}`,\n367:         );\n368:         setLastInsertEdgeOutcome({ status: 'skipped', reason: 'skipped manual edge', edgeId: existing.id });\n369:         return 0;\n370:       }\n371: \n372:       const columns = new Set((database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n373:         .map((column) => column.name));\n374: \n375:       if (existing) {\n376:         const assignments = [\n377:           'strength = ?',\n378:           'evidence = COALESCE(?, evidence)',\n379:           'created_by = ?',\n380:         ];\n381:         const params: unknown[] = [clampedStrength, evidence, createdBy];\n382:         if (columns.has('confidence') && metadata.confidence !== undefined) {\n383:           assignments.push('confidence = ?');\n384:           params.push(metadata.confidence);\n385:         }\n386:         if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n387:           assignments.push('extraction_method = ?');\n388:           params.push(metadata.extractionMethod);\n389:         }\n390:         params.push(existing.id);\n391: \n392:         (database.prepare(`\n393:           UPDATE causal_edges\n394:           SET ${assignments.join(',\\n              ')}\n395:           WHERE id = ?\n396:         `) as Database.Statement).run(...params);\n397:         setLastInsertEdgeOutcome({ status: 'updated', reason: null, edgeId: existing.id });\n398:       } else {\n399:         if (!enforceRelationWindowCap(relation, database)) {\n400:           setLastInsertEdgeOutcome({ status: 'skipped', reason: 'relation cap exceeded', edgeId: null });\n401:           return 0;\n402:         }\n403: \n404:         const insertColumns = [\n405:           'source_id',\n406:           'target_id',\n407:           'source_anchor',\n408:           'target_anchor',\n409:           'relation',\n410:           'strength',\n411:           'evidence',\n412:           'created_by',\n413:         ];\n414:         const insertValues: unknown[] = [\n415:           sourceId,\n416:           targetId,\n417:           anchors.sourceAnchor ?? null,\n418:           anchors.targetAnchor ?? null,\n419:           relation,\n420:           clampedStrength,\n421:           evidence,\n422:           createdBy,\n423:         ];\n424:         if (columns.has('confidence') && metadata.confidence !== undefined) {\n425:           insertColumns.push('confidence');\n426:           insertValues.push(metadata.confidence);\n427:         }\n428:         if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n429:           insertColumns.push('extraction_method');\n430:           insertValues.push(metadata.extractionMethod);\n431:         }\n432: \n433:         (database.prepare(`\n434:           INSERT INTO causal_edges (\n435:             ${insertColumns.join(',\\n            ')}\n436:           )\n437:           VALUES (${insertColumns.map(() => '?').join(', ')})\n438:         `) as Database.Statement).run(...insertValues);\n439:       }\n440: \n441:       const row = (database.prepare(`\n442:         SELECT id FROM causal_edges\n443:         WHERE source_id = ? AND target_id = ? AND relation = ?\n444:           AND COALESCE(source_anchor, '') = COALESCE(?, '')\n445:           AND COALESCE(target_anchor, '') = COALESCE(?, '')\n446:       `) as Database.Statement).get(\n447:         sourceId,\n448:         targetId,\n449:         relation,\n450:         anchors.sourceAnchor ?? null,\n451:         anchors.targetAnchor ?? null,\n452:       ) as { id: number } | undefined;\n453:       const rowId = row ? row.id : 0;\n454:       if (!existing && rowId) {\n455:         setLastInsertEdgeOutcome({ status: 'inserted', reason: null, edgeId: rowId });\n456:       }\n457: \n458:       // Log weight change on conflict update\n459:       if (existing && rowId && isFiniteNumber(existing.strength) && existing.strength !== clampedStrength) {\n460:         logWeightChange(rowId, existing.strength, clampedStrength, createdBy, 'insert-upsert');\n461:       }\n462: \n463:       return rowId;\n464:     })();\n465: \n466:     if (shouldInvalidateCache) {\n467:       invalidateDegreeCache();\n468:     }\n469: \n470:     return rowId || null;\n471:   } catch (error: unknown) {\n472:     const msg = error instanceof Error ? error.message : String(error);\n473:     console.warn(`[causal-edges] insertEdge error: ${msg}`);\n474:     setLastInsertEdgeOutcome({ status: 'skipped', reason: msg, edgeId: null });\n475:     if (/SQLITE_BUSY|SQLITE_LOCKED|database is locked/i.test(msg)) {\n476:       throw error;\n477:     }\n478:     return null;\n479:   }\n480: }\n481: \n482: function insertEdgesBatch(\n483:   edges: Array<{\n484:     sourceId: string;\n485:     targetId: string;\n486:     relation: RelationType;\n487:     strength?: number;\n488:     evidence?: string | null;\n489:     createdBy?: string;\n490:     sourceAnchor?: string | null;\n491:     targetAnchor?: string | null;\n492:     confidence?: number;\n493:     extractionMethod?: string;\n494:   }>\n495: ): { inserted: number; failed: number; skippedManual: number } {\n496:   if (!db) return { inserted: 0, failed: edges.length, skippedManual: 0 };\n497: \n498:   let inserted = 0;\n499:   let failed = 0;\n500:   let skippedManual = 0;\n501: \n502:   const insertTx = db.transaction(() => {\n503:     for (const edge of edges) {\n504:       const id = insertEdge(\n505:         edge.sourceId,\n506:         edge.targetId,\n507:         edge.relation,\n508:         edge.strength ?? 1.0,\n509:         edge.evidence ?? null,\n510:         false,\n511:         edge.createdBy ?? 'manual',\n512:         {\n513:           sourceAnchor: edge.sourceAnchor ?? null,\n514:           targetAnchor: edge.targetAnchor ?? null,\n515:         },\n516:         {\n517:           confidence: edge.confidence,\n518:           extractionMethod: edge.extractionMethod,\n519:         },\n520:       );\n521:       if (id !== null) inserted++;\n522:       else {\n523:         failed++;\n524:         if (getLastInsertEdgeOutcome()?.reason === 'skipped manual edge') {\n525:           skippedManual++;\n526:         }\n527:       }\n528:     }\n529:   });\n530: \n531:   try {\n532:     insertTx();\n533:     if (inserted > 0) {\n534:       invalidateDegreeCache();\n535:     }\n536:   } catch (error: unknown) {\n537:     const msg = error instanceof Error ? error.message : String(error);\n538:     console.warn(`[causal-edges] insertEdgesBatch error: ${msg}`);\n539:   }\n540: \n541:   return { inserted, failed, skippedManual };\n542: }\n543: \n544: function bulkInsertEdges(edges: Array<Record<string, unknown>>): { inserted: number; failed: number } {\n545:   if (!db) return { inserted: 0, failed: edges.length };\n546: \n547:   const database = db;\n548:   let inserted = 0;\n549:   let failed = 0;\n550: \n551:   try {\n552:     const edgeColumns = (database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n553:       .map((column) => column.name)\n554:       .filter((name) => typeof name === 'string' && name.length > 0 && name !== 'id');\n555: \n556:     if (edgeColumns.length === 0) {\n557:       return { inserted: 0, failed: edges.length };\n558:     }\n559: \n560:     const insertEdgeStmt = database.prepare(`\n561:       INSERT OR IGNORE INTO causal_edges (${edgeColumns.join(', ')})\n562:       VALUES (${edgeColumns.map(() => '?').join(', ')})\n563:     `) as Database.Statement;\n564: \n565:     const insertTx = database.transaction(() => {\n566:       for (const edge of edges) {\n567:         if (!edge || typeof edge.source_id !== 'string' || typeof edge.target_id !== 'string') {\n568:           failed++;\n569:           continue;\n570:         }\n571:         if (typeof edge.relation !== 'string' || edge.relation.trim().length === 0) {\n572:           failed++;\n573:           continue;\n574:         }\n575:         if (edge.source_id === edge.target_id) {\n576:           failed++;\n577:           continue;\n578:         }\n579:         if (!enforceRelationWindowCap(edge.relation, database)) {\n580:           failed++;\n581:           continue;\n582:         }\n583: \n584:         const result = insertEdgeStmt.run(...edgeColumns.map((column) => edge[column] ?? null)) as { changes: number };\n585:         if (result.changes > 0) {\n586:           inserted++;\n587:         }\n588:       }\n589:     });\n590: \n591:     insertTx();\n592:     if (inserted > 0) {\n593:       invalidateDegreeCache();\n594:     }\n595:   } catch (error: unknown) {\n596:     const msg = error instanceof Error ? error.message : String(error);\n597:     console.warn(`[causal-edges] bulkInsertEdges error: ${msg}`);\n598:   }\n599: \n600:   return { inserted, failed };\n601: }\n602: \n603: function createEdgeQueryResult(\n604:   edges: CausalEdge[],\n605:   limit: number,\n606:   truncated: boolean,\n607: ): EdgeQueryResult {\n608:   const result = edges as EdgeQueryResult;\n609:   result.truncated = truncated;\n610:   result.limit = limit;\n611:   return result;\n612: }\n613: \n614: function getEdgesFrom(sourceId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n615:   if (!db) return createEdgeQueryResult([], limit, false);\n616: \n617:   try {\n618:     const rows = (db.prepare(`\n619:       SELECT * FROM causal_edges\n620:       WHERE source_id = ?\n621:       ORDER BY strength DESC\n622:       LIMIT ?\n623:     `) as Database.Statement).all(sourceId, limit + 1) as CausalEdgeRow[];\n624:     const truncated = rows.length > limit;\n625:     const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n626:     for (const edge of edges) {\n627:       try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n628:         console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n629:       }\n630:     }\n631:     return createEdgeQueryResult(edges, limit, truncated);\n632:   } catch (error: unknown) {\n633:     const msg = error instanceof Error ? error.message : String(error);\n634:     console.warn(`[causal-edges] getEdgesFrom error: ${msg}`);\n635:     return createEdgeQueryResult([], limit, false);\n636:   }\n637: }\n638: \n639: function getEdgesTo(targetId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n640:   if (!db) return createEdgeQueryResult([], limit, false);\n641: \n642:   try {\n643:     const rows = (db.prepare(`\n644:       SELECT * FROM causal_edges\n645:       WHERE target_id = ?\n646:       ORDER BY strength DESC\n647:       LIMIT ?\n648:     `) as Database.Statement).all(targetId, limit + 1) as CausalEdgeRow[];\n649:     const truncated = rows.length > limit;\n650:     const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n651:     for (const edge of edges) {\n652:       try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n653:         console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n654:       }\n655:     }\n656:     return createEdgeQueryResult(edges, limit, truncated);\n657:   } catch (error: unknown) {\n658:     const msg = error instanceof Error ? error.message : String(error);\n659:     console.warn(`[causal-edges] getEdgesTo error: ${msg}`);\n660:     return createEdgeQueryResult([], limit, false);\n661:   }\n662: }\n663: \n664: function getAllEdges(limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n665:   if (!db) return createEdgeQueryResult([], limit, false);\n666: \n667:   try {\n668:     const rows = (db.prepare(`\n669:       SELECT * FROM causal_edges\n670:       ORDER BY extracted_at DESC\n671:       LIMIT ?\n672:     `) as Database.Statement).all(limit + 1) as CausalEdgeRow[];\n673:     const truncated = rows.length > limit;\n674:     const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n675:     return createEdgeQueryResult(edges, limit, truncated);\n676:   } catch (error: unknown) {\n677:     const msg = error instanceof Error ? error.message : String(error);\n678:     console.warn(`[causal-edges] getAllEdges error: ${msg}`);\n679:     return createEdgeQueryResult([], limit, false);\n680:   }\n681: }\n682: \n683: /* ───────────────────────────────────────────────────────────────\n684:    6. GRAPH TRAVERSAL\n685: ----------------------------------------------------------------*/\n686: \n687: function getCausalChain(\n688:   rootId: string,\n689:   maxDepth: number = DEFAULT_MAX_DEPTH,\n690:   direction: 'forward' | 'backward' = 'forward',\n691:   edgeLimit: number = MAX_EDGES_LIMIT,\n692: ): CausalChainNode {\n693:   const root: CausalChainNode = {\n694:     id: rootId,\n695:     depth: 0,\n696:     relation: RELATION_TYPES.CAUSED,\n697:     strength: 1.0,\n698:     children: [],\n699:     truncated: false,\n700:     truncationLimit: null,\n701:   };\n702: \n703:   if (!db) return root;\n704: \n705:   function traverse(node: CausalChainNode, depth: number, path: Set<string>): void {\n706:     if (depth >= maxDepth) return;\n707: \n708:     const edges = direction === 'forward'\n709:       ? getEdgesFrom(node.id, edgeLimit)\n710:       : getEdgesTo(node.id, edgeLimit);\n711: \n712:     if (edges.truncated) {\n713:       root.truncated = true;\n714:       root.truncationLimit = edgeLimit;\n715:     }\n716: \n717:     for (const edge of edges) {\n718:       const nextId = direction === 'forward' ? edge.target_id : edge.source_id;\n719:       if (path.has(nextId)) continue;\n720: \n721:       // C138: apply cumulative path strength with relation weight multiplier,\n722:       // then clamp back to [0, 1].\n723:       const weight = RELATION_WEIGHTS[edge.relation] ?? 1.0;\n724:       const weightedStrength = clampStrength(node.strength * edge.strength * weight) ?? 0;\n725: \n726:       const child: CausalChainNode = {\n727:         id: nextId,\n728:         edgeId: edge.id,               // Preserve edge ID for unlink workflow\n729:         depth: depth + 1,\n730:         relation: edge.relation,\n731:         strength: weightedStrength,\n732:         children: [],\n733:       };\n734: \n735:       node.children.push(child);\n736:       const nextPath = new Set(path);\n737:       nextPath.add(nextId);\n738:       traverse(child, depth + 1, nextPath);\n739:     }\n740:   }\n741: \n742:   traverse(root, 0, new Set([rootId]));\n743:   return root;\n744: }\n745: \n746: /* ───────────────────────────────────────────────────────────────\n747:    7. EDGE MANAGEMENT\n748: ----------------------------------------------------------------*/\n749: \n750: function updateEdge(\n751:   edgeId: number,\n752:   updates: { strength?: number; evidence?: string; sourceAnchor?: string | null; targetAnchor?: string | null },\n753:   changedBy: string = 'manual',\n754:   reason: string | null = null,\n755: ): boolean {\n756:   if (!db) return false;\n757:   const database = db;\n758: \n759:   try {\n760:     const parts: string[] = [];\n761:     const params: unknown[] = [];\n762:     let nextStrength: number | undefined;\n763: \n764:     if (updates.strength !== undefined) {\n765:       const clampedStrength = clampStrength(updates.strength);\n766:       if (clampedStrength === null) {\n767:         console.warn('[causal-edges] updateEdge rejected non-finite strength');\n768:         return false;\n769:       }\n770:       nextStrength = clampedStrength;\n771:       parts.push('strength = ?');\n772:       params.push(clampedStrength);\n773:     }\n774:     if (updates.evidence !== undefined) {\n775:       parts.push('evidence = ?');\n776:       params.push(updates.evidence);\n777:     }\n778:     if (updates.sourceAnchor !== undefined) {\n779:       parts.push('source_anchor = ?');\n780:       params.push(updates.sourceAnchor);\n781:     }\n782:     if (updates.targetAnchor !== undefined) {\n783:       parts.push('target_anchor = ?');\n784:       params.push(updates.targetAnchor);\n785:     }\n786: \n787:     if (parts.length === 0) return false;\n788: \n789:     params.push(edgeId);\n790: \n791:     // Wrap SELECT + UPDATE + logWeightChange in a transaction for atomicity\n792:     const changed = database.transaction(() => {\n793:       // Capture old strength for weight_history logging\n794:       let oldStrength: number | undefined;\n795:       if (updates.strength !== undefined) {\n796:         const existing = (database.prepare(\n797:           'SELECT strength FROM causal_edges WHERE id = ?'\n798:         ) as Database.Statement).get(edgeId) as { strength: number } | undefined;\n799:         oldStrength = existing?.strength;\n800:       }\n801: \n802:       // String interpolation constructs IN(?,?,?) placeholder list only —\n803:       // All user values are parameterized. Accepted exception per audit H-08.\n804:       const result = (database.prepare(\n805:         `UPDATE causal_edges SET ${parts.join(', ')} WHERE id = ?`\n806:       ) as Database.Statement).run(...params);\n807: \n808:       const changed = (result as { changes: number }).changes > 0;\n809: \n810:       // Log weight change to weight_history\n811:       if (changed && nextStrength !== undefined && isFiniteNumber(oldStrength)) {\n812:         if (oldStrength !== nextStrength) {\n813:           logWeightChange(edgeId, oldStrength, nextStrength, changedBy, reason);\n814:         }\n815:       }\n816: \n817:       return changed;\n818:     })();\n819: \n820:     if (changed) {\n821:       invalidateDegreeCache();\n822:     }\n823: \n824:     return changed;\n825:   } catch (error: unknown) {\n826:     const msg = error instanceof Error ? error.message : String(error);\n827:     console.warn(`[causal-edges] updateEdge error: ${msg}`);\n828:     return false;\n829:   }\n830: }\n831: \n832: function deleteEdge(edgeId: number, options: DeleteEdgeOptions = {}): boolean {\n833:   if (!db) return false;\n834: \n835:   try {\n836:     const result = sweepCausalEdges(db, {\n837:       edgeIds: [edgeId],\n838:       reason: options.reason ?? 'causal edge unlink',\n839:       command: options.command ?? 'causal_edges.deleteEdge',\n840:       restoreContext: options.restoreContext,\n841:       invalidateCaches: false,\n842:     });\n843:     if (result.deleted > 0) {\n844:       invalidateDegreeCache();\n845:     }\n846:     return result.deleted > 0;\n847:   } catch (error: unknown) {\n848:     const msg = error instanceof Error ? error.message : String(error);\n849:     console.warn(`[causal-edges] deleteEdge error: ${msg}`);\n850:     return false;\n851:   }\n852: }\n853: \n854: // Let errors propagate so callers inside transactions see failures.\n855: // Previously errors were caught and swallowed, which hid edge-cleanup failures\n856: // From transactional callers (e.g., memory-bulk-delete, memory-crud-delete).\n857: function deleteEdgesForMemory(memoryId: string, options: DeleteEdgeOptions = {}): number {\n858:   if (!db) return 0;\n859: \n860:   const result = sweepCausalEdges(db, {\n861:     memoryIds: [memoryId],\n862:     reason: options.reason ?? 'memory delete causal cleanup',\n863:     command: options.command ?? 'causal_edges.deleteEdgesForMemory',\n864:     restoreContext: {\n865:       memoryId,\n866:       ...(options.restoreContext ?? {}),\n867:     },\n868:     invalidateCaches: false,\n869:   });\n870:   if (result.deleted > 0) {\n871:     invalidateDegreeCache();\n872:   }\n873:   return result.deleted;\n874: }\n875: \n876: /* ───────────────────────────────────────────────────────────────\n877:    8. STATS & QUERIES\n878: ----------------------------------------------------------------*/\n879: \n880: function getGraphStats(): GraphStats {\n881:   if (!db) {\n882:     return { totalEdges: 0, byRelation: {}, avgStrength: 0, uniqueSources: 0, uniqueTargets: 0 };\n883:   }\n884: \n885:   try {\n886:     const total = (db.prepare('SELECT COUNT(*) as count FROM causal_edges') as Database.Statement).get() as { count: number };\n887:     const byRelation = (db.prepare('SELECT relation, COUNT(*) as count FROM causal_edges GROUP BY relation') as Database.Statement).all() as Array<{ relation: string; count: number }>;\n888:     const avgStrength = (db.prepare('SELECT AVG(strength) as avg FROM causal_edges') as Database.Statement).get() as { avg: number | null };\n889:     const sources = (db.prepare('SELECT COUNT(DISTINCT source_id) as count FROM causal_edges') as Database.Statement).get() as { count: number };\n890:     const targets = (db.prepare('SELECT COUNT(DISTINCT target_id) as count FROM causal_edges') as Database.Statement).get() as { count: number };\n891: \n892:     const relationMap: Record<string, number> = {};\n893:     for (const row of byRelation) {\n894:       relationMap[row.relation] = row.count;\n895:     }\n896: \n897:     return {\n898:       totalEdges: total.count,\n899:       byRelation: relationMap,\n900:       avgStrength: Math.round((avgStrength.avg || 0) * 100) / 100,\n901:       uniqueSources: sources.count,\n902:       uniqueTargets: targets.count,\n903:     };\n904:   } catch (error: unknown) {\n905:     const msg = error instanceof Error ? error.message : String(error);\n906:     console.warn(`[causal-edges] getGraphStats error: ${msg}`);\n907:     return { totalEdges: 0, byRelation: {}, avgStrength: 0, uniqueSources: 0, uniqueTargets: 0 };\n908:   }\n909: }\n910: \n911: function findOrphanedEdges(): CausalEdge[] {\n912:   if (!db) return [];\n913: \n914:   try {\n915:     return (db.prepare(`\n916:       SELECT ce.* FROM causal_edges ce\n917:       WHERE NOT EXISTS (SELECT 1 FROM memory_index m WHERE CAST(m.id AS TEXT) = ce.source_id)\n918:         OR NOT EXISTS (SELECT 1 FROM memory_index m WHERE CAST(m.id AS TEXT) = ce.target_id)\n919:     `) as Database.Statement).all().map((row) => normalizeCausalEdgeRow(row as Record<string, unknown>)) as CausalEdge[];\n920:   } catch (error: unknown) {\n921:     const msg = error instanceof Error ? error.message : String(error);\n922:     console.warn(`[causal-edges] findOrphanedEdges error: ${msg}`);\n923:     return [];\n924:   }\n925: }\n926: \n927: // Automated orphan edge cleanup\n928: function cleanupOrphanedEdges(): { deleted: number; tombstoned: number; edgeIds: number[] } {\n929:   if (!db) return { deleted: 0, tombstoned: 0, edgeIds: [] };\n930:   try {\n931:     const orphaned = findOrphanedEdges();\n932:     const result = runInTransaction(db, () => {\n933:       if (orphaned.length === 0) {\n934:         return { deleted: 0, tombstoned: 0, edgeIds: [] };\n935:       }\n936:       return sweepCausalEdges(db!, {\n937:         edgeIds: orphaned.map((edge) => edge.id),\n938:         reason: 'orphan causal edge cleanup',\n939:         command: 'causal_edges.cleanupOrphanedEdges',\n940:         restoreContext: {\n941:           orphanedEndpoints: orphaned.map((edge) => ({\n942:             edgeId: edge.id,\n943:             sourceId: edge.source_id,\n944:             targetId: edge.target_id,\n945:           })),\n946:         },\n947:         invalidateCaches: false,\n948:       });\n949:     });\n950:     if (result.deleted > 0) {\n951:       invalidateDegreeCache();\n952:     }\n953:     return { deleted: result.deleted, tombstoned: result.tombstoned, edgeIds: result.edgeIds };\n954:   } catch (error: unknown) {\n955:     const msg = error instanceof Error ? error.message : String(error);\n956:     console.warn(`[causal-edges] cleanupOrphanedEdges error: ${msg}`);\n957:     return { deleted: 0, tombstoned: 0, edgeIds: [] };\n958:   }\n959: }\n960: \n961: /* ───────────────────────────────────────────────────────────────\n962:    SPEC DOCUMENT CHAINS\n963: ----------------------------------------------------------------*/\n964: \n965: /**\n966:  * Create causal relationship chain between spec folder documents.\n967:  * Links: spec -> plan (CAUSED), plan -> tasks (CAUSED), tasks -> impl-summary (CAUSED)\n968:  * Also: checklist SUPPORTS spec, decision-record SUPPORTS plan, research SUPPORTS spec\n969:  *\n970:  * @param documentIds Map of document_type -> memory_index.id for documents in the same spec folder\n971:  */\n972: function createSpecDocumentChain(documentIds: Record<string, number>): { inserted: number; failed: number } {\n973:   if (!db) return { inserted: 0, failed: 0 };\n974: \n975:   const edges: Array<{\n976:     sourceId: string;\n977:     targetId: string;\n978:     relation: RelationType;\n979:     strength?: number;\n980:     evidence?: string | null;\n981:   }> = [];\n982: \n983:   const ids = documentIds;\n984: \n985:   // Primary chain: spec -> plan -> tasks -> implementation_summary\n986:   if (ids.spec && ids.plan) {\n987:     edges.push({ sourceId: String(ids.spec), targetId: String(ids.plan), relation: RELATION_TYPES.CAUSED, strength: 0.9, evidence: 'Spec 126: spec -> plan chain' });\n988:   }\n989:   if (ids.plan && ids.tasks) {\n990:     edges.push({ sourceId: String(ids.plan), targetId: String(ids.tasks), relation: RELATION_TYPES.CAUSED, strength: 0.9, evidence: 'Spec 126: plan -> tasks chain' });\n991:   }\n992:   if (ids.tasks && ids.implementation_summary) {\n993:     edges.push({ sourceId: String(ids.tasks), targetId: String(ids.implementation_summary), relation: RELATION_TYPES.CAUSED, strength: 0.8, evidence: 'Spec 126: tasks -> impl-summary chain' });\n994:   }\n995: \n996:   // Support relationships\n997:   if (ids.checklist && ids.spec) {\n998:     edges.push({ sourceId: String(ids.checklist), targetId: String(ids.spec), relation: RELATION_TYPES.SUPPORTS, strength: 0.7, evidence: 'Spec 126: checklist supports spec' });\n999:   }\n1000:   if (ids.decision_record && ids.plan) {\n1001:     edges.push({ sourceId: String(ids.decision_record), targetId: String(ids.plan), relation: RELATION_TYPES.SUPPORTS, strength: 0.8, evidence: 'Spec 126: decision-record supports plan' });\n1002:   }\n1003:   if (ids.research && ids.spec) {\n1004:     edges.push({ sourceId: String(ids.research), targetId: String(ids.spec), relation: RELATION_TYPES.SUPPORTS, strength: 0.7, evidence: 'Spec 126: research supports spec' });\n1005:   }\n1006: \n1007:   if (edges.length === 0) return { inserted: 0, failed: 0 };\n1008: \n1009:   return insertEdgesBatch(edges);\n1010: }\n1011: \n1012: /* ───────────────────────────────────────────────────────────────\n1013:    WEIGHT HISTORY & AUDIT\n1014: ----------------------------------------------------------------*/\n1015: \n1016: function logWeightChange(\n1017:   edgeId: number,\n1018:   oldStrength: number,\n1019:   newStrength: number,\n1020:   changedBy: string = 'manual',\n1021:   reason: string | null = null,\n1022: ): void {\n1023:   if (!db) return;\n1024:   (db.prepare(`\n1025:     INSERT INTO weight_history (edge_id, old_strength, new_strength, changed_by, reason)\n1026:     VALUES (?, ?, ?, ?, ?)\n1027:   `) as Database.Statement).run(edgeId, oldStrength, newStrength, changedBy, reason);\n1028: }\n1029: \n1030: function getWeightHistory(edgeId: number, limit: number = 50): WeightHistoryEntry[] {\n1031:   if (!db) return [];\n1032:   try {\n1033:     return (db.prepare(`\n1034:       SELECT * FROM weight_history\n1035:       WHERE edge_id = ?\n1036:       ORDER BY changed_at DESC, id DESC\n1037:       LIMIT ?\n1038:     `) as Database.Statement).all(edgeId, limit) as WeightHistoryEntry[];\n1039:   } catch (error: unknown) {\n1040:     const msg = error instanceof Error ? error.message : String(error);\n1041:     console.warn(`[causal-edges] getWeightHistory error: ${msg}`);\n1042:     return [];\n1043:   }\n1044: }\n1045: \n1046: function rollbackWeights(edgeId: number, toTimestamp: string): boolean {\n1047:   if (!db) return false;\n1048:   const database = db;\n1049:   try {\n1050:     // Wrap SELECTs + UPDATE + logWeightChange in a transaction for atomicity\n1051:     const changed = database.transaction(() => {\n1052:       // Get current strength before rollback\n1053:       const current = (database.prepare(\n1054:         'SELECT strength FROM causal_edges WHERE id = ?'\n1055:       ) as Database.Statement).get(edgeId) as { strength: number } | undefined;\n1056:       if (!current) return null;\n1057: \n1058:       // Prefer the latest exact-timestamp row to make same-second\n1059:       // History entries deterministic when callers pass a value from getWeightHistory().\n1060:       let entry = (database.prepare(`\n1061:         SELECT old_strength FROM weight_history\n1062:         WHERE edge_id = ? AND changed_at = ?\n1063:         ORDER BY id DESC LIMIT 1\n1064:       `) as Database.Statement).get(edgeId, toTimestamp) as { old_strength: number } | undefined;\n1065: \n1066:       // Find the earliest history entry strictly after the target timestamp.\n1067:       // This preserves legacy \"rollback to before next change\" semantics for\n1068:       // Timestamps that do not exactly match a stored history row.\n1069:       if (!entry) {\n1070:         entry = (database.prepare(`\n1071:         SELECT old_strength FROM weight_history\n1072:         WHERE edge_id = ? AND changed_at > ?\n1073:         ORDER BY changed_at ASC, id ASC LIMIT 1\n1074:       `) as Database.Statement).get(edgeId, toTimestamp) as { old_strength: number } | undefined;\n1075:       }\n1076: \n1077:       if (!entry) {\n1078:         // Fall back: get the oldest entry's old_strength (pre-change baseline)\n1079:         entry = (database.prepare(`\n1080:           SELECT old_strength FROM weight_history\n1081:           WHERE edge_id = ?\n1082:           ORDER BY changed_at ASC, id ASC LIMIT 1\n1083:         `) as Database.Statement).get(edgeId) as { old_strength: number } | undefined;\n1084:       }\n1085:       if (!entry) return null;\n1086: \n1087:       // Restore the edge to the old_strength value\n1088:       const result = (database.prepare(\n1089:         'UPDATE causal_edges SET strength = ? WHERE id = ?'\n1090:       ) as Database.Statement).run(entry.old_strength, edgeId);\n1091: \n1092:       // Log the rollback\n1093:       if (isFiniteNumber(current.strength) && current.strength !== entry.old_strength) {\n1094:         logWeightChange(edgeId, current.strength, entry.old_strength, 'rollback', `rollback to ${toTimestamp}`);\n1095:       }\n1096: \n1097:       return (result as { changes: number }).changes > 0;\n1098:     })();\n1099: \n1100:     if (changed === null) return false;\n1101:     invalidateDegreeCache();\n1102:     return changed;\n1103:   } catch (error: unknown) {\n1104:     const msg = error instanceof Error ? error.message : String(error);\n1105:     console.warn(`[causal-edges] rollbackWeights error: ${msg}`);\n1106:     return false;\n1107:   }\n1108: }\n1109: \n1110: /* ───────────────────────────────────────────────────────────────\n1111:    11. EDGE BOUNDS & COUNTING (N3-lite NFR-R01)\n1112: ----------------------------------------------------------------*/\n1113: \n1114: function countEdgesForNode(nodeId: string): number {\n1115:   if (!db) return 0;\n1116:   try {\n1117:     const row = (db.prepare(`\n1118:       SELECT COUNT(*) as count FROM causal_edges\n1119:       WHERE source_id = ? OR target_id = ?\n1120:     `) as Database.Statement).get(nodeId, nodeId) as { count: number };\n1121:     return row.count;\n1122:   } catch (error: unknown) {\n1123:     const msg = error instanceof Error ? error.message : String(error);\n1124:     console.warn(`[causal-edges] countEdgesForNode error: ${msg}`);\n1125:     return 0;\n1126:   }\n1127: }\n1128: \n1129: function touchEdgeAccess(edgeId: number): void {\n1130:   if (!db) return;\n1131:   (db.prepare(\n1132:     \"UPDATE causal_edges SET last_accessed = datetime('now') WHERE id = ?\"\n1133:   ) as Database.Statement).run(edgeId);\n1134: }\n1135: \n1136: function getStaleEdges(thresholdDays: number = STALENESS_THRESHOLD_DAYS): CausalEdge[] {\n1137:   if (!db) return [];\n1138:   try {\n1139:     const rows = (db.prepare(`\n1140:       SELECT * FROM causal_edges\n1141:       WHERE (last_accessed IS NULL AND extracted_at < datetime('now', '-' || ? || ' days'))\n1142:          OR (last_accessed IS NOT NULL AND last_accessed < datetime('now', '-' || ? || ' days'))\n1143:       ORDER BY COALESCE(last_accessed, extracted_at) ASC\n1144:     `) as Database.Statement).all(thresholdDays, thresholdDays) as CausalEdgeRow[];\n1145:     return rows.map(normalizeCausalEdgeRow);\n1146:   } catch (error: unknown) {\n1147:     const msg = error instanceof Error ? error.message : String(error);\n1148:     console.warn(`[causal-edges] getStaleEdges error: ${msg}`);\n1149:     return [];\n1150:   }\n1151: }\n1152: \n1153: /* ───────────────────────────────────────────────────────────────\n1154:    12. EXPORTS\n1155: ----------------------------------------------------------------*/\n1156: \n1157: export {\n1158:   RELATION_TYPES,\n1159:   RELATION_WEIGHTS,\n1160:   DEFAULT_MAX_DEPTH,\n1161:   MAX_EDGES_LIMIT,\n1162:   MAX_EDGES_PER_NODE,\n1163:   MAX_AUTO_STRENGTH,\n1164:   MAX_STRENGTH_INCREASE_PER_CYCLE,\n1165:   WINDOW_MS,\n1166:   CAP_PER_WINDOW,\n1167:   STALENESS_THRESHOLD_DAYS,\n1168:   DECAY_STRENGTH_AMOUNT,\n1169:   DECAY_PERIOD_DAYS,\n1170: \n1171:   init,\n1172:   isAutoEdgeCreator,\n1173:   getLastInsertEdgeOutcome,\n1174:   enforceRelationWindowCap,\n1175:   insertEdge,\n1176:   insertEdgesBatch,\n1177:   bulkInsertEdges,\n1178:   getEdgesFrom,\n1179:   getEdgesTo,\n1180:   getAllEdges,\n1181:   getCausalChain,\n1182:   updateEdge,\n1183:   deleteEdge,\n1184:   deleteEdgesForMemory,\n1185:   getGraphStats,\n1186:   findOrphanedEdges,\n1187:   cleanupOrphanedEdges,\n1188:   createSpecDocumentChain,\n1189: \n1190:   // Weight history & audit\n1191:   logWeightChange,\n1192:   getWeightHistory,\n1193:   rollbackWeights,\n1194: \n1195:   // N3-lite: Edge bounds & counting\n1196:   countEdgesForNode,\n1197:   touchEdgeAccess,\n1198:   getStaleEdges,\n1199: \n1200:   // Generation counter for memory_search cache invalidation\n1201:   getCausalEdgesGeneration,\n1202:   bumpCausalEdgesGeneration,\n1203: };\n1204: \n1205: /**\n1206:  * Re-exports related public types.\n1207:  */\n1208: export type {\n1209:   RelationType,\n1210:   CausalEdge,\n1211:   EdgeQueryResult,\n1212:   WeightHistoryEntry,\n1213:   GraphStats,\n1214:   CausalChainNode,\n1215:   CausalEdgeSweepResult,\n1216: };\n\n(End of file - total 1216 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\nimport type { CausalEdgeSweepResult } from '../causal/sweep.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\nimport type { CausalEdgeSweepResult } from '../causal/sweep.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst RELATION_TYPES = Object.freeze({\n  CAUSED: 'caused',\n  ENABLED: 'enabled',\n  SUPERSEDES: 'supersedes',\n  CONTRADICTS: 'contradicts',\n  DERIVED_FROM: 'derived_from',\n  SUPPORTS: 'supports',\n} as const);\n\ntype RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n\n/**\n * C138: Relation weight multipliers applied during traversal scoring.\n * Higher values amplify the propagated strength; values < 1.0 dampen it.\n */\nconst RELATION_WEIGHTS: Record<string, number> = {\n  supersedes:   1.5,  // Strongest signal — new info replaces old\n  caused:       1.3,  // Strong causal link\n  enabled:      1.1,  // Weak causal link\n  supports:     1.0,  // Neutral / default\n  derived_from: 1.0,  // Neutral / default\n  contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n};\n\nconst DEFAULT_MAX_DEPTH = 3;\nconst MAX_EDGES_LIMIT = 100;\n\n// Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\nconst MAX_EDGES_PER_NODE = 20;\nconst MAX_AUTO_STRENGTH = 0.5;\nconst MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\nconst WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\nconst CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\nconst STALENESS_THRESHOLD_DAYS = 90;\nconst DECAY_STRENGTH_AMOUNT = 0.1;\nconst DECAY_PERIOD_DAYS = 30;\n\nfunction parsePositiveIntegerEnv(name: string, fallback: number): number {\n  const value = process.env[name];\n  if (!value) return fallback;\n  const parsed = Number.parseInt(value, 10);\n  return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isFiniteNumber(value: unknown): value is number {\n  return typeof value === 'number' && Number.isFinite(value);\n}\n\n/**\n * Classify edge provenance as automatic. Covers the legacy 'auto' creator and\n * namespaced automatic creators such as 'auto-session'. Shared by the insert\n * cap path and the consolidation strengthening cap so the two sites cannot\n * drift. Non-auto values ('manual', 'automatic', 'author') must not match.\n */\nfunction isAutoEdgeCreator(createdBy: string | null | undefined): boolean {\n  return createdBy === 'auto'\n    || (typeof createdBy === 'string' && createdBy.startsWith('auto-'));\n}\n\nfunction clampStrength(strength: number): number | null {\n  if (!Number.isFinite(strength)) return null;\n  return Math.max(0, Math.min(1, strength));\n}\n\nfunction normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n  return {\n    id: Number(row.id),\n    source_id: String(row.source_id),\n    target_id: String(row.target_id),\n    source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n    target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n    relation: String(row.relation) as RelationType,\n    strength: Number(row.strength),\n    evidence: row.evidence == null ? null : String(row.evidence),\n    extracted_at: String(row.extracted_at),\n    created_by: String(row.created_by ?? 'manual'),\n    last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CausalEdge {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor: string | null;\n  target_anchor: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ninterface CausalEdgeRow extends Record<string, unknown> {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor?: string | null;\n  target_anchor?: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ntype EdgeQueryResult = CausalEdge[] & {\n  truncated: boolean;\n  limit: number;\n};\n\ninterface WeightHistoryEntry {\n  id: number;\n  edge_id: number;\n  old_strength: number;\n  new_strength: number;\n  changed_by: string;\n  changed_at: string;\n  reason: string | null;\n}\n\ninterface GraphStats {\n  totalEdges: number;\n  byRelation: Record<string, number>;\n  avgStrength: number;\n  uniqueSources: number;\n  uniqueTargets: number;\n}\n\ninterface DeleteEdgeOptions {\n  reason?: string;\n  command?: string;\n  restoreContext?: Record<string, unknown>;\n}\n\ninterface InsertEdgeMetadataOptions {\n  confidence?: number;\n  extractionMethod?: string;\n}\n\ninterface InsertEdgeOutcome {\n  status: 'inserted' | 'updated' | 'skipped';\n  reason: string | null;\n  edgeId: number | null;\n}\n\ninterface CausalChainNode {\n  id: string;\n  edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n  depth: number;\n  relation: RelationType;\n  strength: number;\n  children: CausalChainNode[];\n  truncated?: boolean;\n  truncationLimit?: number | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet lastInsertEdgeOutcome: InsertEdgeOutcome | null = null;\n\n/**\n * Monotonically-increasing generation counter bumped on every causal-edge\n * mutation (insert/update/delete/rollback). Read-only callers can include this\n * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n * cached responses derived from the causal graph become stale on the next\n * lookup without requiring a wholesale tool-cache invalidation.\n *\n * targeted memory_search cache invalidation.\n */\n// Counter lives in causal-generation.ts so the tombstone sweep (which this\n// module imports) can bump it without a circular import.\n\nfunction setLastInsertEdgeOutcome(outcome: InsertEdgeOutcome): void {\n  lastInsertEdgeOutcome = outcome;\n}\n\nfunction getLastInsertEdgeOutcome(): InsertEdgeOutcome | null {\n  return lastInsertEdgeOutcome;\n}\n\nfunction invalidateDegreeCache(): void {\n  // bump the causal-edges generation FIRST so any cache key that\n  // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n  // stale on the next read without invalidating unrelated tool entries.\n  bumpCausalEdgesGeneration();\n\n  try {\n    // Use db-specific cache invalidation instead of the no-op global version\n    if (db) {\n      clearDegreeCacheForDb(db);\n    }\n  } catch (_error: unknown) {\n    // Cache invalidation is best-effort; never block edge mutations\n  }\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signals cache invalidation is best-effort\n  }\n}\n\nfunction enforceRelationWindowCap(\n  relation: string,\n  database: Database.Database,\n  windowMs: number = WINDOW_MS,\n  capPerWindow: number = CAP_PER_WINDOW,\n): boolean {\n  try {\n    const windowStart = new Date(Date.now() - windowMs).toISOString();\n    const row = (database.prepare(`\n      SELECT COUNT(*) as count FROM causal_edges\n      WHERE relation = ?\n        AND datetime(extracted_at) >= datetime(?)\n    `) as Database.Statement).get(relation, windowStart) as { count: number };\n    const count = row.count;\n    if (count >= capPerWindow) {\n      console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] relation cap check failed for ${relation}: ${msg}`);\n    return true;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction init(database: Database.Database): void {\n  db = database;\n\n  // Defensive traversal indexes — the canonical creation lives in\n  // Vector-index-impl.ts migration v8. These IF NOT EXISTS guards\n  // Ensure the indexes are present even when the module is initialised outside\n  // The normal migration path (e.g. tests, standalone scripts).\n  try {\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n    ensureTemporalColumns(database);\n  } catch (_e: unknown) {\n    // Best-effort: table may not exist yet during early startup sequencing\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EDGE OPERATIONS\n----------------------------------------------------------------*/\n\nfunction insertEdge(\n  sourceId: string,\n  targetId: string,\n  relation: RelationType,\n  strength: number = 1.0,\n  evidence: string | null = null,\n  shouldInvalidateCache: boolean = true,\n  createdBy: string = 'manual',\n  anchors: { sourceAnchor?: string | null; targetAnchor?: string | null } = {},\n  metadata: InsertEdgeMetadataOptions = {},\n): number | null {\n  lastInsertEdgeOutcome = null;\n  if (!db) {\n    console.warn('[causal-edges] Database not initialized. Server may still be starting up.');\n    setLastInsertEdgeOutcome({ status: 'skipped', reason: 'database not initialized', edgeId: null });\n    return null;\n  }\n  const database = db;\n\n  // NFR-R01: Auto edges capped at MAX_AUTO_STRENGTH\n  const effectiveStrength = isAutoEdgeCreator(createdBy)\n    ? Math.min(strength, MAX_AUTO_STRENGTH)\n    : strength;\n\n  // Prevent self-loops\n  if (sourceId === targetId) {\n    setLastInsertEdgeOutcome({ status: 'skipped', reason: 'self-loop', edgeId: null });\n    return null;\n  }\n\n  // FK check deferred — test environments use synthetic IDs not in memory_index.\n  // Implementing FK validation would require seeding memory_index in 20+ causal edge tests.\n\n  // NFR-R01: Edge bounds — reject if node already has MAX_EDGES_PER_NODE auto edges\n  if (isAutoEdgeCreator(createdBy)) {\n    const edgeCount = countEdgesForNode(sourceId);\n    if (edgeCount >= MAX_EDGES_PER_NODE) {\n      console.warn(`[causal-edges] Edge bounds: node ${sourceId} has ${edgeCount} edges (max ${MAX_EDGES_PER_NODE}), rejecting auto edge`);\n      setLastInsertEdgeOutcome({ status: 'skipped', reason: 'edge bounds exceeded', edgeId: null });\n      return null;\n    }\n  }\n\n  try {\n    const clampedStrength = clampStrength(effectiveStrength);\n    if (clampedStrength === null) {\n      console.warn('[causal-edges] insertEdge rejected non-finite strength');\n      setLastInsertEdgeOutcome({ status: 'skipped', reason: 'non-finite strength', edgeId: null });\n      return null;\n    }\n\n    // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n    const rowId = database.transaction(() => {\n      if (isTemporalEdgesEnabled()) {\n        detectContradictions(\n          database,\n          Number.parseInt(sourceId, 10),\n          Number.parseInt(targetId, 10),\n          relation,\n        );\n      }\n\n      // Check if edge exists (for weight_history logging on conflict update).\n      // This SELECT is intentional: we need the old strength to decide whether\n      // To write a weight_history row after the upsert. The subsequent INSERT\n      // Uses last_insert_rowid() to avoid a second post-upsert SELECT.\n      const existing = (database.prepare(`\n        SELECT id, strength, evidence, created_by FROM causal_edges\n        WHERE source_id = ? AND target_id = ? AND relation = ?\n          AND COALESCE(source_anchor, '') = COALESCE(?, '')\n          AND COALESCE(target_anchor, '') = COALESCE(?, '')\n      `) as Database.Statement).get(\n        sourceId,\n        targetId,\n        relation,\n        anchors.sourceAnchor ?? null,\n        anchors.targetAnchor ?? null,\n      ) as { id: number; strength: number; evidence: string | null; created_by: string | null } | undefined;\n\n      // Manual/curated edges must never be overwritten by automatic writers:\n      // an auto upsert against a non-auto row is skipped so curated provenance\n      // and strength survive. Auto-to-auto updates remain allowed under caps.\n      if (existing && isAutoEdgeCreator(createdBy) && !isAutoEdgeCreator(existing.created_by ?? 'manual')) {\n        console.warn(\n          `[causal-edges] skipped manual edge ${existing.id} (created_by=${existing.created_by ?? 'manual'}); skipped overwrite by ${createdBy}`,\n        );\n        setLastInsertEdgeOutcome({ status: 'skipped', reason: 'skipped manual edge', edgeId: existing.id });\n        return 0;\n      }\n\n      const columns = new Set((database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n        .map((column) => column.name));\n\n      if (existing) {\n        const assignments = [\n          'strength = ?',\n          'evidence = COALESCE(?, evidence)',\n          'created_by = ?',\n        ];\n        const params: unknown[] = [clampedStrength, evidence, createdBy];\n        if (columns.has('confidence') && metadata.confidence !== undefined) {\n          assignments.push('confidence = ?');\n          params.push(metadata.confidence);\n        }\n        if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n          assignments.push('extraction_method = ?');\n          params.push(metadata.extractionMethod);\n        }\n        params.push(existing.id);\n\n        (database.prepare(`\n          UPDATE causal_edges\n          SET ${assignments.join(',\\n              ')}\n          WHERE id = ?\n        `) as Database.Statement).run(...params);\n        setLastInsertEdgeOutcome({ status: 'updated', reason: null, edgeId: existing.id });\n      } else {\n        if (!enforceRelationWindowCap(relation, database)) {\n          setLastInsertEdgeOutcome({ status: 'skipped', reason: 'relation cap exceeded', edgeId: null });\n          return 0;\n        }\n\n        const insertColumns = [\n          'source_id',\n          'target_id',\n          'source_anchor',\n          'target_anchor',\n          'relation',\n          'strength',\n          'evidence',\n          'created_by',\n        ];\n        const insertValues: unknown[] = [\n          sourceId,\n          targetId,\n          anchors.sourceAnchor ?? null,\n          anchors.targetAnchor ?? null,\n          relation,\n          clampedStrength,\n          evidence,\n          createdBy,\n        ];\n        if (columns.has('confidence') && metadata.confidence !== undefined) {\n          insertColumns.push('confidence');\n          insertValues.push(metadata.confidence);\n        }\n        if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n          insertColumns.push('extraction_method');\n          insertValues.push(metadata.extractionMethod);\n        }\n\n        (database.prepare(`\n          INSERT INTO causal_edges (\n            ${insertColumns.join(',\\n            ')}\n          )\n          VALUES (${insertColumns.map(() => '?').join(', ')})\n        `) as Database.Statement).run(...insertValues);\n      }\n\n      const row = (database.prepare(`\n        SELECT id FROM causal_edges\n        WHERE source_id = ? AND target_id = ? AND relation = ?\n          AND COALESCE(source_anchor, '') = COALESCE(?, '')\n          AND COALESCE(target_anchor, '') = COALESCE(?, '')\n      `) as Database.Statement).get(\n        sourceId,\n        targetId,\n        relation,\n        anchors.sourceAnchor ?? null,\n        anchors.targetAnchor ?? null,\n      ) as { id: number } | undefined;\n      const rowId = row ? row.id : 0;\n      if (!existing && rowId) {\n        setLastInsertEdgeOutcome({ status: 'inserted', reason: null, edgeId: rowId });\n      }\n\n      // Log weight change on conflict update\n      if (existing && rowId && isFiniteNumber(existing.strength) && existing.strength !== clampedStrength) {\n        logWeightChange(rowId, existing.strength, clampedStrength, createdBy, 'insert-upsert');\n      }\n\n      return rowId;\n    })();\n\n    if (shouldInvalidateCache) {\n      invalidateDegreeCache();\n    }\n\n    return rowId || null;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] insertEdge error: ${msg}`);\n    setLastInsertEdgeOutcome({ status: 'skipped', reason: msg, edgeId: null });\n    if (/SQLITE_BUSY|SQLITE_LOCKED|database is locked/i.test(msg)) {\n      throw error;\n    }\n    return null;\n  }\n}\n\nfunction insertEdgesBatch(\n  edges: Array<{\n    sourceId: string;\n    targetId: string;\n    relation: RelationType;\n    strength?: number;\n    evidence?: string | null;\n    createdBy?: string;\n    sourceAnchor?: string | null;\n    targetAnchor?: string | null;\n    confidence?: number;\n    extractionMethod?: string;\n  }>\n): { inserted: number; failed: number; skippedManual: number } {\n  if (!db) return { inserted: 0, failed: edges.length, skippedManual: 0 };\n\n  let inserted = 0;\n  let failed = 0;\n  let skippedManual = 0;\n\n  const insertTx = db.transaction(() => {\n    for (const edge of edges) {\n      const id = insertEdge(\n        edge.sourceId,\n        edge.targetId,\n        edge.relation,\n        edge.strength ?? 1.0,\n        edge.evidence ?? null,\n        false,\n        edge.createdBy ?? 'manual',\n        {\n          sourceAnchor: edge.sourceAnchor ?? null,\n          targetAnchor: edge.targetAnchor ?? null,\n        },\n        {\n          confidence: edge.confidence,\n          extractionMethod: edge.extractionMethod,\n        },\n      );\n      if (id !== null) inserted++;\n      else {\n        failed++;\n        if (getLastInsertEdgeOutcome()?.reason === 'skipped manual edge') {\n          skippedManual++;\n        }\n      }\n    }\n  });\n\n  try {\n    insertTx();\n    if (inserted > 0) {\n      invalidateDegreeCache();\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] insertEdgesBatch error: ${msg}`);\n  }\n\n  return { inserted, failed, skippedManual };\n}\n\nfunction bulkInsertEdges(edges: Array<Record<string, unknown>>): { inserted: number; failed: number } {\n  if (!db) return { inserted: 0, failed: edges.length };\n\n  const database = db;\n  let inserted = 0;\n  let failed = 0;\n\n  try {\n    const edgeColumns = (database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n      .map((column) => column.name)\n      .filter((name) => typeof name === 'string' && name.length > 0 && name !== 'id');\n\n    if (edgeColumns.length === 0) {\n      return { inserted: 0, failed: edges.length };\n    }\n\n    const insertEdgeStmt = database.prepare(`\n      INSERT OR IGNORE INTO causal_edges (${edgeColumns.join(', ')})\n      VALUES (${edgeColumns.map(() => '?').join(', ')})\n    `) as Database.Statement;\n\n    const insertTx = database.transaction(() => {\n      for (const edge of edges) {\n        if (!edge || typeof edge.source_id !== 'string' || typeof edge.target_id !== 'string') {\n          failed++;\n          continue;\n        }\n        if (typeof edge.relation !== 'string' || edge.relation.trim().length === 0) {\n          failed++;\n          continue;\n        }\n        if (edge.source_id === edge.target_id) {\n          failed++;\n          continue;\n        }\n        if (!enforceRelationWindowCap(edge.relation, database)) {\n          failed++;\n          continue;\n        }\n\n        const result = insertEdgeStmt.run(...edgeColumns.map((column) => edge[column] ?? null)) as { changes: number };\n        if (result.changes > 0) {\n          inserted++;\n        }\n      }\n    });\n\n    insertTx();\n    if (inserted > 0) {\n      invalidateDegreeCache();\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] bulkInsertEdges error: ${msg}`);\n  }\n\n  return { inserted, failed };\n}\n\nfunction createEdgeQueryResult(\n  edges: CausalEdge[],\n  limit: number,\n  truncated: boolean,\n): EdgeQueryResult {\n  const result = edges as EdgeQueryResult;\n  result.truncated = truncated;\n  result.limit = limit;\n  return result;\n}\n\nfunction getEdgesFrom(sourceId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n  if (!db) return createEdgeQueryResult([], limit, false);\n\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      WHERE source_id = ?\n      ORDER BY strength DESC\n      LIMIT ?\n    `) as Database.Statement).all(sourceId, limit + 1) as CausalEdgeRow[];\n    const truncated = rows.length > limit;\n    const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n    for (const edge of edges) {\n      try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n        console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n      }\n    }\n    return createEdgeQueryResult(edges, limit, truncated);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getEdgesFrom error: ${msg}`);\n    return createEdgeQueryResult([], limit, false);\n  }\n}\n\nfunction getEdgesTo(targetId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n  if (!db) return createEdgeQueryResult([], limit, false);\n\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      WHERE target_id = ?\n      ORDER BY strength DESC\n      LIMIT ?\n    `) as Database.Statement).all(targetId, limit + 1) as CausalEdgeRow[];\n    const truncated = rows.length > limit;\n    const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n    for (const edge of edges) {\n      try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n        console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n      }\n    }\n    return createEdgeQueryResult(edges, limit, truncated);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getEdgesTo error: ${msg}`);\n    return createEdgeQueryResult([], limit, false);\n  }\n}\n\nfunction getAllEdges(limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n  if (!db) return createEdgeQueryResult([], limit, false);\n\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      ORDER BY extracted_at DESC\n      LIMIT ?\n    `) as Database.Statement).all(limit + 1) as CausalEdgeRow[];\n    const truncated = rows.length > limit;\n    const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n    return createEdgeQueryResult(edges, limit, truncated);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getAllEdges error: ${msg}`);\n    return createEdgeQueryResult([], limit, false);\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. GRAPH TRAVERSAL\n----------------------------------------------------------------*/\n\nfunction getCausalChain(\n  rootId: string,\n  maxDepth: number = DEFAULT_MAX_DEPTH,\n  direction: 'forward' | 'backward' = 'forward',\n  edgeLimit: number = MAX_EDGES_LIMIT,\n): CausalChainNode {\n  const root: CausalChainNode = {\n    id: rootId,\n    depth: 0,\n    relation: RELATION_TYPES.CAUSED,\n    strength: 1.0,\n    children: [],\n    truncated: false,\n    truncationLimit: null,\n  };\n\n  if (!db) return root;\n\n  function traverse(node: CausalChainNode, depth: number, path: Set<string>): void {\n    if (depth >= maxDepth) return;\n\n    const edges = direction === 'forward'\n      ? getEdgesFrom(node.id, edgeLimit)\n      : getEdgesTo(node.id, edgeLimit);\n\n    if (edges.truncated) {\n      root.truncated = true;\n      root.truncationLimit = edgeLimit;\n    }\n\n    for (const edge of edges) {\n      const nextId = direction === 'forward' ? edge.target_id : edge.source_id;\n      if (path.has(nextId)) continue;\n\n      // C138: apply cumulative path strength with relation weight multiplier,\n      // then clamp back to [0, 1].\n      const weight = RELATION_WEIGHTS[edge.relation] ?? 1.0;\n      const weightedStrength = clampStrength(node.strength * edge.strength * weight) ?? 0;\n\n      const child: CausalChainNode = {\n        id: nextId,\n        edgeId: edge.id,               // Preserve edge ID for unlink workflow\n        depth: depth + 1,\n        relation: edge.relation,\n        strength: weightedStrength,\n        children: [],\n      };\n\n      node.children.push(child);\n      const nextPath = new Set(path);\n      nextPath.add(nextId);\n      traverse(child, depth + 1, nextPath);\n    }\n  }\n\n  traverse(root, 0, new Set([rootId]));\n  return root;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. EDGE MANAGEMENT\n----------------------------------------------------------------*/\n\nfunction updateEdge(\n  edgeId: number,\n  updates: { strength?: number; evidence?: string; sourceAnchor?: string | null; targetAnchor?: string | null },\n  changedBy: string = 'manual',\n  reason: string | null = null,\n): boolean {\n  if (!db) return false;\n  const database = db;\n\n  try {\n    const parts: string[] = [];\n    const params: unknown[] = [];\n    let nextStrength: number | undefined;\n\n    if (updates.strength !== undefined) {\n      const clampedStrength = clampStrength(updates.strength);\n      if (clampedStrength === null) {\n        console.warn('[causal-edges] updateEdge rejected non-finite strength');\n        return false;\n      }\n      nextStrength = clampedStrength;\n      parts.push('strength = ?');\n      params.push(clampedStrength);\n    }\n    if (updates.evidence !== undefined) {\n      parts.push('evidence = ?');\n      params.push(updates.evidence);\n    }\n    if (updates.sourceAnchor !== undefined) {\n      parts.push('source_anchor = ?');\n      params.push(updates.sourceAnchor);\n    }\n    if (updates.targetAnchor !== undefined) {\n      parts.push('target_anchor = ?');\n      params.push(updates.targetAnchor);\n    }\n\n    if (parts.length === 0) return false;\n\n    params.push(edgeId);\n\n    // Wrap SELECT + UPDATE + logWeightChange in a transaction for atomicity\n    const changed = database.transaction(() => {\n      // Capture old strength for weight_history logging\n      let oldStrength: number | undefined;\n      if (updates.strength !== undefined) {\n        const existing = (database.prepare(\n          'SELECT strength FROM causal_edges WHERE id = ?'\n        ) as Database.Statement).get(edgeId) as { strength: number } | undefined;\n        oldStrength = existing?.strength;\n      }\n\n      // String interpolation constructs IN(?,?,?) placeholder list only —\n      // All user values are parameterized. Accepted exception per audit H-08.\n      const result = (database.prepare(\n        `UPDATE causal_edges SET ${parts.join(', ')} WHERE id = ?`\n      ) as Database.Statement).run(...params);\n\n      const changed = (result as { changes: number }).changes > 0;\n\n      // Log weight change to weight_history\n      if (changed && nextStrength !== undefined && isFiniteNumber(oldStrength)) {\n        if (oldStrength !== nextStrength) {\n          logWeightChange(edgeId, oldStrength, nextStrength, changedBy, reason);\n        }\n      }\n\n      return changed;\n    })();\n\n    if (changed) {\n      invalidateDegreeCache();\n    }\n\n    return changed;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] updateEdge error: ${msg}`);\n    return false;\n  }\n}\n\nfunction deleteEdge(edgeId: number, options: DeleteEdgeOptions = {}): boolean {\n  if (!db) return false;\n\n  try {\n    const result = sweepCausalEdges(db, {\n      edgeIds: [edgeId],\n      reason: options.reason ?? 'causal edge unlink',\n      command: options.command ?? 'causal_edges.deleteEdge',\n      restoreContext: options.restoreContext,\n      invalidateCaches: false,\n    });\n    if (result.deleted > 0) {\n      invalidateDegreeCache();\n    }\n    return result.deleted > 0;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] deleteEdge error: ${msg}`);\n    return false;\n  }\n}\n\n// Let errors propagate so callers inside transactions see failures.\n// Previously errors were caught and swallowed, which hid edge-cleanup failures\n// From transactional callers (e.g., memory-bulk-delete, memory-crud-delete).\nfunction deleteEdgesForMemory(memoryId: string, options: DeleteEdgeOptions = {}): number {\n  if (!db) return 0;\n\n  const result = sweepCausalEdges(db, {\n    memoryIds: [memoryId],\n    reason: options.reason ?? 'memory delete causal cleanup',\n    command: options.command ?? 'causal_edges.deleteEdgesForMemory',\n    restoreContext: {\n      memoryId,\n      ...(options.restoreContext ?? {}),\n    },\n    invalidateCaches: false,\n  });\n  if (result.deleted > 0) {\n    invalidateDegreeCache();\n  }\n  return result.deleted;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. STATS & QUERIES\n----------------------------------------------------------------*/\n\nfunction getGraphStats(): GraphStats {\n  if (!db) {\n    return { totalEdges: 0, byRelation: {}, avgStrength: 0, uniqueSources: 0, uniqueTargets: 0 };\n  }\n\n  try {\n    const total = (db.prepare('SELECT COUNT(*) as count FROM causal_edges') as Database.Statement).get() as { count: number };\n    const byRelation = (db.prepare('SELECT relation, COUNT(*) as count FROM causal_edges GROUP BY relation') as Database.Statement).all() as Array<{ relation: string; count: number }>;\n    const avgStrength = (db.prepare('SELECT AVG(strength) as avg FROM causal_edges') as Database.Statement).get() as { avg: number | null };\n    const sources = (db.prepare('SELECT COUNT(DISTINCT source_id) as count FROM causal_edges') as Database.Statement).get() as { count: number };\n    const targets = (db.prepare('SELECT COUNT(DISTINCT target_id) as count FROM causal_edges') as Database.Statement).get() as { count: number };\n\n    const relationMap: Record<string, number> = {};\n    for (const row of byRelation) {\n      relationMap[row.relation] = row.count;\n    }\n\n    return {\n      totalEdges: total.count,\n      byRelation: relationMap,\n      avgStrength: Math.round((avgStrength.avg || 0) * 100) / 100,\n      uniqueSources: sources.count,\n      uniqueTargets: targets.count,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getGraphStats error: ${msg}`);\n    return { totalEdges: 0, byRelation: {}, avgStrength: 0, uniqueSources: 0, uniqueTargets: 0 };\n  }\n}\n\nfunction findOrphanedEdges(): CausalEdge[] {\n  if (!db) return [];\n\n  try {\n    return (db.prepare(`\n      SELECT ce.* FROM causal_edges ce\n      WHERE NOT EXISTS (SELECT 1 FROM memory_index m WHERE CAST(m.id AS TEXT) = ce.source_id)\n        OR NOT EXISTS (SELECT 1 FROM memory_index m WHERE CAST(m.id AS TEXT) = ce.target_id)\n    `) as Database.Statement).all().map((row) => normalizeCausalEdgeRow(row as Record<string, unknown>)) as CausalEdge[];\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] findOrphanedEdges error: ${msg}`);\n    return [];\n  }\n}\n\n// Automated orphan edge cleanup\nfunction cleanupOrphanedEdges(): { deleted: number; tombstoned: number; edgeIds: number[] } {\n  if (!db) return { deleted: 0, tombstoned: 0, edgeIds: [] };\n  try {\n    const orphaned = findOrphanedEdges();\n    const result = runInTransaction(db, () => {\n      if (orphaned.length === 0) {\n        return { deleted: 0, tombstoned: 0, edgeIds: [] };\n      }\n      return sweepCausalEdges(db!, {\n        edgeIds: orphaned.map((edge) => edge.id),\n        reason: 'orphan causal edge cleanup',\n        command: 'causal_edges.cleanupOrphanedEdges',\n        restoreContext: {\n          orphanedEndpoints: orphaned.map((edge) => ({\n            edgeId: edge.id,\n            sourceId: edge.source_id,\n            targetId: edge.target_id,\n          })),\n        },\n        invalidateCaches: false,\n      });\n    });\n    if (result.deleted > 0) {\n      invalidateDegreeCache();\n    }\n    return { deleted: result.deleted, tombstoned: result.tombstoned, edgeIds: result.edgeIds };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] cleanupOrphanedEdges error: ${msg}`);\n    return { deleted: 0, tombstoned: 0, edgeIds: [] };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SPEC DOCUMENT CHAINS\n----------------------------------------------------------------*/\n\n/**\n * Create causal relationship chain between spec folder documents.\n * Links: spec -> plan (CAUSED), plan -> tasks (CAUSED), tasks -> impl-summary (CAUSED)\n * Also: checklist SUPPORTS spec, decision-record SUPPORTS plan, research SUPPORTS spec\n *\n * @param documentIds Map of document_type -> memory_index.id for documents in the same spec folder\n */\nfunction createSpecDocumentChain(documentIds: Record<string, number>): { inserted: number; failed: number } {\n  if (!db) return { inserted: 0, failed: 0 };\n\n  const edges: Array<{\n    sourceId: string;\n    targetId: string;\n    relation: RelationType;\n    strength?: number;\n    evidence?: string | null;\n  }> = [];\n\n  const ids = documentIds;\n\n  // Primary chain: spec -> plan -> tasks -> implementation_summary\n  if (ids.spec && ids.plan) {\n    edges.push({ sourceId: String(ids.spec), targetId: String(ids.plan), relation: RELATION_TYPES.CAUSED, strength: 0.9, evidence: 'Spec 126: spec -> plan chain' });\n  }\n  if (ids.plan && ids.tasks) {\n    edges.push({ sourceId: String(ids.plan), targetId: String(ids.tasks), relation: RELATION_TYPES.CAUSED, strength: 0.9, evidence: 'Spec 126: plan -> tasks chain' });\n  }\n  if (ids.tasks && ids.implementation_summary) {\n    edges.push({ sourceId: String(ids.tasks), targetId: String(ids.implementation_summary), relation: RELATION_TYPES.CAUSED, strength: 0.8, evidence: 'Spec 126: tasks -> impl-summary chain' });\n  }\n\n  // Support relationships\n  if (ids.checklist && ids.spec) {\n    edges.push({ sourceId: String(ids.checklist), targetId: String(ids.spec), relation: RELATION_TYPES.SUPPORTS, strength: 0.7, evidence: 'Spec 126: checklist supports spec' });\n  }\n  if (ids.decision_record && ids.plan) {\n    edges.push({ sourceId: String(ids.decision_record), targetId: String(ids.plan), relation: RELATION_TYPES.SUPPORTS, strength: 0.8, evidence: 'Spec 126: decision-record supports plan' });\n  }\n  if (ids.research && ids.spec) {\n    edges.push({ sourceId: String(ids.research), targetId: String(ids.spec), relation: RELATION_TYPES.SUPPORTS, strength: 0.7, evidence: 'Spec 126: research supports spec' });\n  }\n\n  if (edges.length === 0) return { inserted: 0, failed: 0 };\n\n  return insertEdgesBatch(edges);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   WEIGHT HISTORY & AUDIT\n----------------------------------------------------------------*/\n\nfunction logWeightChange(\n  edgeId: number,\n  oldStrength: number,\n  newStrength: number,\n  changedBy: string = 'manual',\n  reason: string | null = null,\n): void {\n  if (!db) return;\n  (db.prepare(`\n    INSERT INTO weight_history (edge_id, old_strength, new_strength, changed_by, reason)\n    VALUES (?, ?, ?, ?, ?)\n  `) as Database.Statement).run(edgeId, oldStrength, newStrength, changedBy, reason);\n}\n\nfunction getWeightHistory(edgeId: number, limit: number = 50): WeightHistoryEntry[] {\n  if (!db) return [];\n  try {\n    return (db.prepare(`\n      SELECT * FROM weight_history\n      WHERE edge_id = ?\n      ORDER BY changed_at DESC, id DESC\n      LIMIT ?\n    `) as Database.Statement).all(edgeId, limit) as WeightHistoryEntry[];\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getWeightHistory error: ${msg}`);\n    return [];\n  }\n}\n\nfunction rollbackWeights(edgeId: number, toTimestamp: string): boolean {\n  if (!db) return false;\n  const database = db;\n  try {\n    // Wrap SELECTs + UPDATE + logWeightChange in a transaction for atomicity\n    const changed = database.transaction(() => {\n      // Get current strength before rollback\n      const current = (database.prepare(\n        'SELECT strength FROM causal_edges WHERE id = ?'\n      ) as Database.Statement).get(edgeId) as { strength: number } | undefined;\n      if (!current) return null;\n\n      // Prefer the latest exact-timestamp row to make same-second\n      // History entries deterministic when callers pass a value from getWeightHistory().\n      let entry = (database.prepare(`\n        SELECT old_strength FROM weight_history\n        WHERE edge_id = ? AND changed_at = ?\n        ORDER BY id DESC LIMIT 1\n      `) as Database.Statement).get(edgeId, toTimestamp) as { old_strength: number } | undefined;\n\n      // Find the earliest history entry strictly after the target timestamp.\n      // This preserves legacy \"rollback to before next change\" semantics for\n      // Timestamps that do not exactly match a stored history row.\n      if (!entry) {\n        entry = (database.prepare(`\n        SELECT old_strength FROM weight_history\n        WHERE edge_id = ? AND changed_at > ?\n        ORDER BY changed_at ASC, id ASC LIMIT 1\n      `) as Database.Statement).get(edgeId, toTimestamp) as { old_strength: number } | undefined;\n      }\n\n      if (!entry) {\n        // Fall back: get the oldest entry's old_strength (pre-change baseline)\n        entry = (database.prepare(`\n          SELECT old_strength FROM weight_history\n          WHERE edge_id = ?\n          ORDER BY changed_at ASC, id ASC LIMIT 1\n        `) as Database.Statement).get(edgeId) as { old_strength: number } | undefined;\n      }\n      if (!entry) return null;\n\n      // Restore the edge to the old_strength value\n      const result = (database.prepare(\n        'UPDATE causal_edges SET strength = ? WHERE id = ?'\n      ) as Database.Statement).run(entry.old_strength, edgeId);\n\n      // Log the rollback\n      if (isFiniteNumber(current.strength) && current.strength !== entry.old_strength) {\n        logWeightChange(edgeId, current.strength, entry.old_strength, 'rollback', `rollback to ${toTimestamp}`);\n      }\n\n      return (result as { changes: number }).changes > 0;\n    })();\n\n    if (changed === null) return false;\n    invalidateDegreeCache();\n    return changed;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] rollbackWeights error: ${msg}`);\n    return false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   11. EDGE BOUNDS & COUNTING (N3-lite NFR-R01)\n----------------------------------------------------------------*/\n\nfunction countEdgesForNode(nodeId: string): number {\n  if (!db) return 0;\n  try {\n    const row = (db.prepare(`\n      SELECT COUNT(*) as count FROM causal_edges\n      WHERE source_id = ? OR target_id = ?\n    `) as Database.Statement).get(nodeId, nodeId) as { count: number };\n    return row.count;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] countEdgesForNode error: ${msg}`);\n    return 0;\n  }\n}\n\nfunction touchEdgeAccess(edgeId: number): void {\n  if (!db) return;\n  (db.prepare(\n    \"UPDATE causal_edges SET last_accessed = datetime('now') WHERE id = ?\"\n  ) as Database.Statement).run(edgeId);\n}\n\nfunction getStaleEdges(thresholdDays: number = STALENESS_THRESHOLD_DAYS): CausalEdge[] {\n  if (!db) return [];\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      WHERE (last_accessed IS NULL AND extracted_at < datetime('now', '-' || ? || ' days'))\n         OR (last_accessed IS NOT NULL AND last_accessed < datetime('now', '-' || ? || ' days'))\n      ORDER BY COALESCE(last_accessed, extracted_at) ASC\n    `) as Database.Statement).all(thresholdDays, thresholdDays) as CausalEdgeRow[];\n    return rows.map(normalizeCausalEdgeRow);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getStaleEdges error: ${msg}`);\n    return [];\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   12. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  RELATION_TYPES,\n  RELATION_WEIGHTS,\n  DEFAULT_MAX_DEPTH,\n  MAX_EDGES_LIMIT,\n  MAX_EDGES_PER_NODE,\n  MAX_AUTO_STRENGTH,\n  MAX_STRENGTH_INCREASE_PER_CYCLE,\n  WINDOW_MS,\n  CAP_PER_WINDOW,\n  STALENESS_THRESHOLD_DAYS,\n  DECAY_STRENGTH_AMOUNT,\n  DECAY_PERIOD_DAYS,\n\n  init,\n  isAutoEdgeCreator,\n  getLastInsertEdgeOutcome,\n  enforceRelationWindowCap,\n  insertEdge,\n  insertEdgesBatch,\n  bulkInsertEdges,\n  getEdgesFrom,\n  getEdgesTo,\n  getAllEdges,\n  getCausalChain,\n  updateEdge,\n  deleteEdge,\n  deleteEdgesForMemory,\n  getGraphStats,\n  findOrphanedEdges,\n  cleanupOrphanedEdges,\n  createSpecDocumentChain,\n\n  // Weight history & audit\n  logWeightChange,\n  getWeightHistory,\n  rollbackWeights,\n\n  // N3-lite: Edge bounds & counting\n  countEdgesForNode,\n  touchEdgeAccess,\n  getStaleEdges,\n\n  // Generation counter for memory_search cache invalidation\n  getCausalEdgesGeneration,\n  bumpCausalEdgesGeneration,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  RelationType,\n  CausalEdge,\n  EdgeQueryResult,\n  WeightHistoryEntry,\n  GraphStats,\n  CausalChainNode,\n  CausalEdgeSweepResult,\n};","lineStart":1,"lineEnd":1216,"totalLines":1216,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","time":{"start":1781763858186,"end":1781763858201}},"metadata":{"openai":{"itemId":"fc_0790af5bc91d46de016a338f1202a8819197579c33014d924a"}},"id":"prt_ed966df08001a6Ud2Sdluprx7W","sessionID":"ses_1269ae15dffeJ9ZwFh8bDvLSxu","messageID":"msg_ed966b3aa001EJftVGhbS0o1FS"}}
