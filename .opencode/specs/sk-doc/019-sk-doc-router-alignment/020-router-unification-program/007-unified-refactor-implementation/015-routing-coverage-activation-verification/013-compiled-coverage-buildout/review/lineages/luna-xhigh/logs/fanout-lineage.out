{"type":"tool_use","timestamp":1784692605624,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_Gx1KyviwOADDM8wqnvkWkzv5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-route-manifest.cjs","offset":500,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-route-manifest.cjs</path>\n<type>file</type>\n<content>\n500:   }\n501:   const manifest = {\n502:     schemaVersion: 'V1',\n503:     selectedPolicy: {\n504:       effectivePolicyHash: currentPolicy.effectivePolicyHash,\n505:       generation: 1,\n506:     },\n507:     servingAuthority: 'legacy',\n508:     shadowOnly: true,\n509:   };\n510:   const manifestBytes = artifactBytes(manifest);\n511:   let created = false;\n512:   try {\n513:     ensureActivationDirectory(path.dirname(paths.absolutePath));\n514:     fs.writeFileSync(paths.absolutePath, manifestBytes, { flag: 'wx', mode: 0o600 });\n515:     created = true;\n516:   } catch (error) {\n517:     if (error && error.code === 'EEXIST') {\n518:       const existingBytes = readManifestBytes(paths.absolutePath);\n519:       const inspected = validateCanonicalManifestBytes({ hubId, manifestBytes: existingBytes });\n520:       return failureRecord(hubId, 'already-exists', {\n521:         ...inspected,\n522:         manifestValid: inspected.manifestValid,\n523:         manifest: inspected.manifest,\n524:         created: false,\n525:       });\n526:     }\n527:     return failureRecord(hubId, causeFrom(error), { created });\n528:   }\n529:   return {\n530:     ...checkCanonicalManifestFreshness({ hubId, skillRoot }),\n531:     created: true,\n532:   };\n533: }\n534: \n535: /**\n536:  * Recompile current hub inputs one generation ahead and overwrite an existing\n537:  * manifest in place, preserving servingAuthority and shadowOnly untouched.\n538:  * Refuses a missing manifest outright — use mintCanonicalManifest for that.\n539:  *\n540:  * @param {Object} input - Hub identity and current authored source root.\n541:  * @returns {Object} Stable freshness record with a refreshed flag.\n542:  */\n543: function refreshCanonicalManifest({ hubId, skillRoot }) {\n544:   let paths;\n545:   try {\n546:     paths = canonicalManifestPath({ hubId });\n547:   } catch (error) {\n548:     return failureRecord(hubId, causeFrom(error, 'unsafe-path'), { refreshed: false });\n549:   }\n550:   let existingBytes;\n551:   try {\n552:     existingBytes = readManifestBytes(paths.absolutePath);\n553:   } catch (error) {\n554:     return failureRecord(hubId, causeFrom(error, 'invalid-manifest'), { refreshed: false });\n555:   }\n556:   if (existingBytes === null) {\n557:     return failureRecord(hubId, 'missing-manifest', { refreshed: false });\n558:   }\n559:   const inspected = validateCanonicalManifestBytes({ hubId, manifestBytes: existingBytes });\n560:   if (!inspected.manifestValid) {\n561:     return failureRecord(hubId, 'invalid-manifest', { ...inspected, refreshed: false });\n562:   }\n563:   const existingManifest = inspected.manifest;\n564:   const newGeneration = existingManifest.selectedPolicy.generation + 1;\n565:   let currentPolicy;\n566:   try {\n567:     currentPolicy = compileCanonicalParent({ hubId, skillRoot, generation: newGeneration });\n568:   } catch (error) {\n569:     return failureRecord(hubId, causeFrom(error), {\n570:       ...inspected,\n571:       manifestValid: true,\n572:       manifest: inspected.manifest,\n573:       refreshed: false,\n574:     });\n575:   }\n576:   const manifest = {\n577:     schemaVersion: 'V1',\n578:     selectedPolicy: {\n579:       effectivePolicyHash: currentPolicy.effectivePolicyHash,\n580:       generation: newGeneration,\n581:     },\n582:     servingAuthority: existingManifest.servingAuthority,\n583:     shadowOnly: existingManifest.shadowOnly,\n584:   };\n585:   const manifestBytes = artifactBytes(manifest);\n586:   try {\n587:     ensureActivationDirectory(path.dirname(paths.absolutePath));\n588:     fs.writeFileSync(paths.absolutePath, manifestBytes, { mode: 0o600 });\n589:   } catch (error) {\n590:     return failureRecord(hubId, causeFrom(error), { refreshed: false });\n591:   }\n592:   return {\n593:     ...checkCanonicalManifestFreshness({ hubId, skillRoot }),\n594:     refreshed: true,\n595:   };\n596: }\n597: \n598: // ─────────────────────────────────────────────────────────────────────────────\n599: // 5. EXPORTS\n600: // ─────────────────────────────────────────────────────────────────────────────\n601: \n602: module.exports = {\n603:   ACTIVATION_ROOT,\n604:   canonicalManifestPath,\n605:   checkCanonicalManifestFreshness,\n606:   evaluateManifestFreshness,\n607:   isCanonicalHubId,\n608:   mintCanonicalManifest,\n609:   refreshCanonicalManifest,\n610:   validateCanonicalManifestBytes,\n611: };\n\n(End of file - total 611 lines)\n</content>","metadata":{"preview":"  }\n  const manifest = {\n    schemaVersion: 'V1',\n    selectedPolicy: {\n      effectivePolicyHash: currentPolicy.effectivePolicyHash,\n      generation: 1,\n    },\n    servingAuthority: 'legacy',\n    shadowOnly: true,\n  };\n  const manifestBytes = artifactBytes(manifest);\n  let created = false;\n  try {\n    ensureActivationDirectory(path.dirname(paths.absolutePath));\n    fs.writeFileSync(paths.absolutePath, manifestBytes, { flag: 'wx', mode: 0o600 });\n    created = true;\n  } catch (error) {\n    if (error && error.code === 'EEXIST') {\n      const existingBytes = readManifestBytes(paths.absolutePath);\n      const inspected = validateCanonicalManifestBytes({ hubId, manifestBytes: existingBytes });","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-route-manifest.cjs","text":"  }\n  const manifest = {\n    schemaVersion: 'V1',\n    selectedPolicy: {\n      effectivePolicyHash: currentPolicy.effectivePolicyHash,\n      generation: 1,\n    },\n    servingAuthority: 'legacy',\n    shadowOnly: true,\n  };\n  const manifestBytes = artifactBytes(manifest);\n  let created = false;\n  try {\n    ensureActivationDirectory(path.dirname(paths.absolutePath));\n    fs.writeFileSync(paths.absolutePath, manifestBytes, { flag: 'wx', mode: 0o600 });\n    created = true;\n  } catch (error) {\n    if (error && error.code === 'EEXIST') {\n      const existingBytes = readManifestBytes(paths.absolutePath);\n      const inspected = validateCanonicalManifestBytes({ hubId, manifestBytes: existingBytes });\n      return failureRecord(hubId, 'already-exists', {\n        ...inspected,\n        manifestValid: inspected.manifestValid,\n        manifest: inspected.manifest,\n        created: false,\n      });\n    }\n    return failureRecord(hubId, causeFrom(error), { created });\n  }\n  return {\n    ...checkCanonicalManifestFreshness({ hubId, skillRoot }),\n    created: true,\n  };\n}\n\n/**\n * Recompile current hub inputs one generation ahead and overwrite an existing\n * manifest in place, preserving servingAuthority and shadowOnly untouched.\n * Refuses a missing manifest outright — use mintCanonicalManifest for that.\n *\n * @param {Object} input - Hub identity and current authored source root.\n * @returns {Object} Stable freshness record with a refreshed flag.\n */\nfunction refreshCanonicalManifest({ hubId, skillRoot }) {\n  let paths;\n  try {\n    paths = canonicalManifestPath({ hubId });\n  } catch (error) {\n    return failureRecord(hubId, causeFrom(error, 'unsafe-path'), { refreshed: false });\n  }\n  let existingBytes;\n  try {\n    existingBytes = readManifestBytes(paths.absolutePath);\n  } catch (error) {\n    return failureRecord(hubId, causeFrom(error, 'invalid-manifest'), { refreshed: false });\n  }\n  if (existingBytes === null) {\n    return failureRecord(hubId, 'missing-manifest', { refreshed: false });\n  }\n  const inspected = validateCanonicalManifestBytes({ hubId, manifestBytes: existingBytes });\n  if (!inspected.manifestValid) {\n    return failureRecord(hubId, 'invalid-manifest', { ...inspected, refreshed: false });\n  }\n  const existingManifest = inspected.manifest;\n  const newGeneration = existingManifest.selectedPolicy.generation + 1;\n  let currentPolicy;\n  try {\n    currentPolicy = compileCanonicalParent({ hubId, skillRoot, generation: newGeneration });\n  } catch (error) {\n    return failureRecord(hubId, causeFrom(error), {\n      ...inspected,\n      manifestValid: true,\n      manifest: inspected.manifest,\n      refreshed: false,\n    });\n  }\n  const manifest = {\n    schemaVersion: 'V1',\n    selectedPolicy: {\n      effectivePolicyHash: currentPolicy.effectivePolicyHash,\n      generation: newGeneration,\n    },\n    servingAuthority: existingManifest.servingAuthority,\n    shadowOnly: existingManifest.shadowOnly,\n  };\n  const manifestBytes = artifactBytes(manifest);\n  try {\n    ensureActivationDirectory(path.dirname(paths.absolutePath));\n    fs.writeFileSync(paths.absolutePath, manifestBytes, { mode: 0o600 });\n  } catch (error) {\n    return failureRecord(hubId, causeFrom(error), { refreshed: false });\n  }\n  return {\n    ...checkCanonicalManifestFreshness({ hubId, skillRoot }),\n    refreshed: true,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  ACTIVATION_ROOT,\n  canonicalManifestPath,\n  checkCanonicalManifestFreshness,\n  evaluateManifestFreshness,\n  isCanonicalHubId,\n  mintCanonicalManifest,\n  refreshCanonicalManifest,\n  validateCanonicalManifestBytes,\n};","lineStart":500,"lineEnd":611,"totalLines":611,"truncated":false}},"title":".opencode/bin/lib/compiled-route-manifest.cjs","time":{"start":1784692605608,"end":1784692605622}},"metadata":{"openai":{"itemId":"fc_01ddd159cbe91627016a603f7d709c8191a90bb9e18d7779dd"}},"id":"prt_f87f802a2001ipcRt1x67TRs18","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f7ac75001uzglMhGOJ6LMVr"}}
{"type":"tool_use","timestamp":1784692605736,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_wG9TQbxgkLY71IQQO8ZN1wcb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-route-manifest.cjs","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-route-manifest.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ╔══════════════════════════════════════════════════════════════════════════╗\n3: // ║ CLI: CANONICAL COMPILED-ROUTE MANIFEST                                  ║\n4: // ╚══════════════════════════════════════════════════════════════════════════╝\n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const {\n12:   checkCanonicalManifestFreshness,\n13:   mintCanonicalManifest,\n14:   refreshCanonicalManifest,\n15: } = require('./lib/compiled-route-manifest.cjs');\n16: \n17: // ─────────────────────────────────────────────────────────────────────────────\n18: // 2. CONSTANTS\n19: // ─────────────────────────────────────────────────────────────────────────────\n20: \n21: const USAGE = 'usage: compiled-route-manifest.cjs <mint|refresh|freshness> '\n22:   + '--hub <hub-id> --skill-root <path> [--pretty]';\n23: \n24: // ─────────────────────────────────────────────────────────────────────────────\n25: // 3. HELPERS\n26: // ─────────────────────────────────────────────────────────────────────────────\n27: \n28: function parseArgs(argv) {\n29:   const verb = argv[0];\n30:   if (verb !== 'mint' && verb !== 'refresh' && verb !== 'freshness') return null;\n31:   const values = { verb, pretty: false };\n32:   const seen = new Set();\n33:   for (let index = 1; index < argv.length; index += 1) {\n34:     const arg = argv[index];\n35:     if (arg === '--pretty') {\n36:       if (seen.has(arg)) return null;\n37:       seen.add(arg);\n38:       values.pretty = true;\n39:       continue;\n40:     }\n41:     if (arg !== '--hub' && arg !== '--skill-root') return null;\n42:     if (seen.has(arg) || index + 1 >= argv.length || argv[index + 1].startsWith('--')) {\n43:       return null;\n44:     }\n45:     seen.add(arg);\n46:     values[arg === '--hub' ? 'hubId' : 'skillRoot'] = argv[index + 1];\n47:     index += 1;\n48:   }\n49:   if (!values.hubId || !values.skillRoot) return null;\n50:   return values;\n51: }\n52: \n53: // ─────────────────────────────────────────────────────────────────────────────\n54: // 4. CLI\n55: // ─────────────────────────────────────────────────────────────────────────────\n56: \n57: /**\n58:  * Run one manifest operation and emit a single JSON record.\n59:  *\n60:  * @param {string[]} argv - CLI arguments after the executable path.\n61:  * @returns {number} Process exit code.\n62:  */\n63: function main(argv = process.argv.slice(2)) {\n64:   const parsed = parseArgs(argv);\n65:   if (!parsed) {\n66:     process.stderr.write(`${USAGE}\\n`);\n67:     return 2;\n68:   }\n69:   const input = { hubId: parsed.hubId, skillRoot: parsed.skillRoot };\n70:   const result = parsed.verb === 'mint'\n71:     ? mintCanonicalManifest(input)\n72:     : parsed.verb === 'refresh'\n73:       ? refreshCanonicalManifest(input)\n74:       : checkCanonicalManifestFreshness(input);\n75:   const output = parsed.pretty ? JSON.stringify(result, null, 2) : JSON.stringify(result);\n76:   process.stdout.write(`${output}\\n`);\n77:   return result.manifestValid && result.fresh ? 0 : 1;\n78: }\n79: \n80: if (require.main === module) {\n81:   try {\n82:     process.exitCode = main();\n83:   } catch {\n84:     process.stderr.write('[compiled-route-manifest] operation failed\\n');\n85:     process.exitCode = 1;\n86:   }\n87: }\n88: \n89: module.exports = { main, parseArgs, USAGE };\n\n(End of file - total 89 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ CLI: CANONICAL COMPILED-ROUTE MANIFEST                                  ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst {\n  checkCanonicalManifestFreshness,\n  mintCanonicalManifest,\n  refreshCanonicalManifest,\n} = require('./lib/compiled-route-manifest.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-route-manifest.cjs","text":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ CLI: CANONICAL COMPILED-ROUTE MANIFEST                                  ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst {\n  checkCanonicalManifestFreshness,\n  mintCanonicalManifest,\n  refreshCanonicalManifest,\n} = require('./lib/compiled-route-manifest.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst USAGE = 'usage: compiled-route-manifest.cjs <mint|refresh|freshness> '\n  + '--hub <hub-id> --skill-root <path> [--pretty]';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv) {\n  const verb = argv[0];\n  if (verb !== 'mint' && verb !== 'refresh' && verb !== 'freshness') return null;\n  const values = { verb, pretty: false };\n  const seen = new Set();\n  for (let index = 1; index < argv.length; index += 1) {\n    const arg = argv[index];\n    if (arg === '--pretty') {\n      if (seen.has(arg)) return null;\n      seen.add(arg);\n      values.pretty = true;\n      continue;\n    }\n    if (arg !== '--hub' && arg !== '--skill-root') return null;\n    if (seen.has(arg) || index + 1 >= argv.length || argv[index + 1].startsWith('--')) {\n      return null;\n    }\n    seen.add(arg);\n    values[arg === '--hub' ? 'hubId' : 'skillRoot'] = argv[index + 1];\n    index += 1;\n  }\n  if (!values.hubId || !values.skillRoot) return null;\n  return values;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CLI\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Run one manifest operation and emit a single JSON record.\n *\n * @param {string[]} argv - CLI arguments after the executable path.\n * @returns {number} Process exit code.\n */\nfunction main(argv = process.argv.slice(2)) {\n  const parsed = parseArgs(argv);\n  if (!parsed) {\n    process.stderr.write(`${USAGE}\\n`);\n    return 2;\n  }\n  const input = { hubId: parsed.hubId, skillRoot: parsed.skillRoot };\n  const result = parsed.verb === 'mint'\n    ? mintCanonicalManifest(input)\n    : parsed.verb === 'refresh'\n      ? refreshCanonicalManifest(input)\n      : checkCanonicalManifestFreshness(input);\n  const output = parsed.pretty ? JSON.stringify(result, null, 2) : JSON.stringify(result);\n  process.stdout.write(`${output}\\n`);\n  return result.manifestValid && result.fresh ? 0 : 1;\n}\n\nif (require.main === module) {\n  try {\n    process.exitCode = main();\n  } catch {\n    process.stderr.write('[compiled-route-manifest] operation failed\\n');\n    process.exitCode = 1;\n  }\n}\n\nmodule.exports = { main, parseArgs, USAGE };","lineStart":1,"lineEnd":89,"totalLines":89,"truncated":false}},"title":".opencode/bin/compiled-route-manifest.cjs","time":{"start":1784692605687,"end":1784692605735}},"metadata":{"openai":{"itemId":"fc_01ddd159cbe91627016a603f7d70a4819194f7ddd530fce70a"}},"id":"prt_f87f802b0001vYz0tpNe5L2YSz","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f7ac75001uzglMhGOJ6LMVr"}}
{"type":"tool_use","timestamp":1784692605778,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"grep","callID":"call_jxAXI8fsNU02KdATHqlhNu3n","state":{"status":"completed","input":{"pattern":"DEFAULT_ON_HUBS|SPECKIT_COMPILED_ROUTING|servingAuthority|compiled-serving","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs"},"output":"Found 14 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs:\n  Line 7: //   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n\n  Line 26: const FLAG = 'SPECKIT_COMPILED_ROUTING';\n\n  Line 27: const DEBUG_FLAG = 'SPECKIT_COMPILED_ROUTING_DEBUG';\n\n  Line 30: // compiled-serving (Lane C parity: compiled byte-identical to legacy on every\n\n  Line 32: // resolves to compiled for every eligible hub. SPECKIT_COMPILED_ROUTING=0\n\n  Line 34: const DEFAULT_ON_HUBS = new Set([\n\n  Line 70:   if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n\n  Line 94: function servingAuthority(hubId) {\n\n  Line 96:   return (manifest && manifest.servingAuthority) || 'legacy';\n\n  Line 106:   if (!manifest || manifest.servingAuthority !== 'compiled') return null;\n\n  Line 127:   servingAuthority,\n\n  Line 131:   DEFAULT_ON_HUBS,\n\n  Line 137: // CLI front door: the invocable entry a compiled-serving hub's SKILL.md routing\n\n  Line 150:   process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\\n`);\n","metadata":{"matches":14,"truncated":false},"title":"DEFAULT_ON_HUBS|SPECKIT_COMPILED_ROUTING|servingAuthority|compiled-serving","time":{"start":1784692605762,"end":1784692605777}},"metadata":{"openai":{"itemId":"fc_01ddd159cbe91627016a603f7d70ac8191ae2a50b6ad68c6e0"}},"id":"prt_f87f80324001bXIewUlUAumKTS","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f7ac75001uzglMhGOJ6LMVr"}}
{"type":"tool_use","timestamp":1784692605835,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_wENUJB4P92iYiBoVQNvjjhtl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/compiled-route-manifest.test.cjs","offset":420,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/compiled-route-manifest.test.cjs</path>\n<type>file</type>\n<content>\n420:       () => sync.captureExternalActivationManifests(invalidRoot),\n421:       /sync-conflict/,\n422:     );\n423: \n424:     const conflictRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'activation-conflict-'));\n425:     const conflictHub = 'conflicting-retained-hub';\n426:     const conflictPath = path.join(conflictRoot, conflictHub, 'manifest.json');\n427:     fs.mkdirSync(path.dirname(conflictPath));\n428:     fs.writeFileSync(conflictPath, validManifestBytes('b'.repeat(64)));\n429:     assert.throws(\n430:       () => sync.restoreExternalActivationManifests([{\n431:         hubId: conflictHub,\n432:         manifestBytes: validManifestBytes('c'.repeat(64)),\n433:         manifestFingerprint: 'unused',\n434:       }], conflictRoot),\n435:       /sync-conflict/,\n436:     );\n437:     const linkedRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'activation-linked-'));\n438:     const linkedHub = 'linked-retained-hub';\n439:     const linkedPath = path.join(linkedRoot, linkedHub, 'manifest.json');\n440:     const linkedTarget = path.join(TEMP_ROOT, 'linked-retained-manifest.json');\n441:     fs.mkdirSync(path.dirname(linkedPath));\n442:     fs.writeFileSync(linkedTarget, validManifestBytes());\n443:     fs.symlinkSync(linkedTarget, linkedPath);\n444:     assert.throws(\n445:       () => sync.restoreExternalActivationManifests([{\n446:         hubId: linkedHub,\n447:         manifestBytes: validManifestBytes(),\n448:         manifestFingerprint: 'unused',\n449:       }], linkedRoot),\n450:       /sync-conflict/,\n451:     );\n452:     fs.rmSync(invalidRoot, { recursive: true, force: true });\n453:     fs.rmSync(conflictRoot, { recursive: true, force: true });\n454:     fs.rmSync(linkedRoot, { recursive: true, force: true });\n455:   });\n456: \n457:   test('uses atomic create-if-absent under concurrent writers', async () => {\n458:     const raceRoot = createParentFixture(RACE_HUB);\n459:     removeManifestDirectory(RACE_HUB);\n460:     const args = ['mint', '--hub', RACE_HUB, '--skill-root', raceRoot];\n461:     const results = await Promise.all([\n462:       runManifestCliAsync(args),\n463:       runManifestCliAsync(args),\n464:     ]);\n465:     assert.deepEqual(results.map((result) => result.code).sort(), [0, 1]);\n466:     assert.deepEqual(\n467:       results.map((result) => result.json.causeCode).sort(),\n468:       ['already-exists', 'fresh'],\n469:     );\n470:     assert.equal(results.find((result) => result.code === 0).json.created, true);\n471:     assert.equal(results.find((result) => result.code === 1).json.created, false);\n472:     removeManifestDirectory(RACE_HUB);\n473:   });\n474: \n475:   test('refuses an existing committed manifest before reading source inputs', () => {\n476:     const manifestPath = manifestContract.canonicalManifestPath({ hubId: 'sk-code' }).absolutePath;\n477:     const beforeBytes = fs.readFileSync(manifestPath);\n478:     const result = manifestContract.mintCanonicalManifest({\n479:       hubId: 'sk-code',\n480:       skillRoot: path.join(TEMP_ROOT, 'does-not-exist'),\n481:     });\n482:     assert.equal(result.causeCode, 'already-exists');\n483:     assert.equal(result.created, false);\n484:     assert.deepEqual(fs.readFileSync(manifestPath), beforeBytes);\n485:   });\n486: \n487:   test('keeps fixed routing maps unchanged; default cohort now serves the 7 promoted hubs compiled', () => {\n488:     delete process.env.SPECKIT_COMPILED_ROUTING;\n489:     assert.equal(resolver.DEFAULT_ON_HUBS.size, 7);\n490:     assert.equal(Object.prototype.hasOwnProperty.call(engine.HUB_CHILD, PRIMARY_HUB), false);\n491:     assert.equal(resolver.resolveRoute(PRIMARY_HUB, 'quality review'), null);\n492:     const records = status.computeAllStatus({ probeEngine: false });\n493:     for (const hubId of FIXED_HUBS) {\n494:       const record = records.find((candidate) => candidate.hubId === hubId);\n495:       assert.ok(record, hubId);\n496:       assert.equal(record.causeCode, 'compiled-serving', hubId);\n497:       assert.equal(typeof record.manifestFreshness, 'object', hubId);\n498:     }\n499:   });\n500: \n501:   test('refreshes a stale manifest to fresh through the CLI, bumping generation and preserving defaults', () => {\n502:     const refreshHub = `manifest-refresh-${process.pid}`;\n503:     const refreshRoot = createParentFixture(refreshHub);\n504:     removeManifestDirectory(refreshHub);\n505:     const minted = manifestContract.mintCanonicalManifest({ hubId: refreshHub, skillRoot: refreshRoot });\n506:     assert.equal(minted.created, true, minted.causeCode);\n507:     assert.equal(minted.selectedPolicy.generation, 1);\n508: \n509:     const skillPath = path.join(refreshRoot, 'SKILL.md');\n510:     const originalSkillMarkdown = fs.readFileSync(skillPath);\n511:     fs.writeFileSync(skillPath, Buffer.concat([originalSkillMarkdown, Buffer.from('\\n')]));\n512:     const stale = manifestContract.checkCanonicalManifestFreshness({\n513:       hubId: refreshHub,\n514:       skillRoot: refreshRoot,\n515:     });\n516:     assert.equal(stale.causeCode, 'stale-manifest');\n517:     assert.equal(stale.selectedPolicy.generation, 1);\n518: \n519:     const refreshed = runManifestCli(['refresh', '--hub', refreshHub, '--skill-root', refreshRoot]);\n520:     assert.equal(refreshed.status, 0, refreshed.stderr);\n521:     assert.equal(refreshed.json.refreshed, true);\n522:     assert.equal(refreshed.json.fresh, true);\n523:     assert.equal(refreshed.json.causeCode, 'fresh');\n524:     assert.equal(refreshed.json.selectedPolicy.generation, 2);\n525:     assert.notEqual(\n526:       refreshed.json.selectedPolicy.effectivePolicyHash,\n527:       minted.selectedPolicy.effectivePolicyHash,\n528:     );\n529: \n530:     const manifestPath = manifestContract.canonicalManifestPath({ hubId: refreshHub }).absolutePath;\n531:     const manifest = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));\n532:     assert.equal(manifest.servingAuthority, 'legacy');\n533:     assert.equal(manifest.shadowOnly, true);\n534:     assert.equal(manifest.selectedPolicy.generation, 2);\n535: \n536:     // Restoring the pre-drift input now drifts the *refreshed* (post-drift)\n537:     // manifest in turn, proving the new hash truly captured the drifted\n538:     // content rather than reusing the generation-one hash under a new number.\n539:     fs.writeFileSync(skillPath, originalSkillMarkdown);\n540:     const afterRestore = manifestContract.checkCanonicalManifestFreshness({\n541:       hubId: refreshHub,\n542:       skillRoot: refreshRoot,\n543:     });\n544:     assert.equal(afterRestore.causeCode, 'stale-manifest');\n545:   });\n546: \n547:   test('refuses to refresh unsafe hub identities and a missing manifest without writing anything', () => {\n548:     for (const hubId of ['../escape', '/absolute', 'Upper-Case', 'two--hyphens', '.']) {\n549:       const result = manifestContract.refreshCanonicalManifest({ hubId, skillRoot: primaryRoot });\n550:       assert.equal(result.causeCode, 'unsafe-path', hubId);\n551:       assert.equal(result.refreshed, false, hubId);\n552:       assert.equal(result.manifestValid, false, hubId);\n553:       assert.equal(result.fresh, false, hubId);\n554:     }\n555: \n556:     const neverMintedHub = `manifest-refresh-missing-${process.pid}`;\n557:     const neverMintedRoot = createParentFixture(neverMintedHub);\n558:     removeManifestDirectory(neverMintedHub);\n559:     const missing = manifestContract.refreshCanonicalManifest({\n560:       hubId: neverMintedHub,\n561:       skillRoot: neverMintedRoot,\n562:     });\n563:     assert.equal(missing.causeCode, 'missing-manifest');\n564:     assert.equal(missing.refreshed, false);\n565:     assert.equal(missing.manifestValid, false);\n566:     assert.equal(\n567:       fs.existsSync(manifestContract.canonicalManifestPath({ hubId: neverMintedHub }).absolutePath),\n568:       false,\n569:     );\n570: \n571:     const cliMissing = runManifestCli([\n572:       'refresh', '--hub', neverMintedHub, '--skill-root', neverMintedRoot,\n573:     ]);\n574:     assert.equal(cliMissing.status, 1);\n575:     assert.equal(cliMissing.json.causeCode, 'missing-manifest');\n576:     assert.equal(cliMissing.json.refreshed, false);\n577:   });\n578: \n579:   test('preserves a non-default shadowOnly value through refresh rather than hardcoding it', () => {\n580:     const preserveHub = `manifest-refresh-preserve-${process.pid}`;\n581:     const preserveRoot = createParentFixture(preserveHub);\n582:     removeManifestDirectory(preserveHub);\n583:     const manifestPath = manifestContract.canonicalManifestPath({ hubId: preserveHub }).absolutePath;\n584:     fs.mkdirSync(path.dirname(manifestPath), { recursive: true });\n585:     fs.writeFileSync(manifestPath, `${JSON.stringify({\n586:       schemaVersion: 'V1',\n587:       selectedPolicy: { effectivePolicyHash: 'a'.repeat(64), generation: 3 },\n588:       servingAuthority: 'legacy',\n589:       shadowOnly: false,\n590:     })}\\n`);\n591: \n592:     const result = manifestContract.refreshCanonicalManifest({\n593:       hubId: preserveHub,\n594:       skillRoot: preserveRoot,\n595:     });\n596:     assert.equal(result.refreshed, true, result.causeCode);\n597:     assert.equal(result.fresh, true, result.causeCode);\n598:     assert.equal(result.selectedPolicy.generation, 4);\n599:     assert.notEqual(result.selectedPolicy.effectivePolicyHash, 'a'.repeat(64));\n600: \n601:     const manifest = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));\n602:     assert.equal(manifest.servingAuthority, 'legacy');\n603:     assert.equal(manifest.shadowOnly, false);\n604:     assert.equal(manifest.selectedPolicy.generation, 4);\n605:   });\n606: \n607:   test('keeps the CLI thin, machine-readable, and usage-safe', () => {\n608:     const usage = runManifestCli(['mint', '--hub', PRIMARY_HUB]);\n609:     assert.equal(usage.status, 2);\n610:     assert.equal(usage.stdout, '');\n611:     assert.match(usage.stderr, /^usage:/);\n612:     const source = fs.readFileSync(\n613:       path.join(REPO_ROOT, '.opencode', 'bin', 'lib', 'compiled-route-manifest.cjs'),\n614:       'utf8',\n615:     );\n616:     assert.match(source, /registry-compiler\\.cjs/);\n617:     assert.match(source, /compileRegistry\\(\\{/);\n618:     assert.match(source, /checkCanonicalManifestFreshness\\(\\{ hubId, skillRoot \\}\\)/);\n619:     assert.doesNotMatch(source, /computeEffectivePolicyHash/);\n620:   });\n621: });\n\n(End of file - total 621 lines)\n</content>","metadata":{"preview":"      () => sync.captureExternalActivationManifests(invalidRoot),\n      /sync-conflict/,\n    );\n\n    const conflictRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'activation-conflict-'));\n    const conflictHub = 'conflicting-retained-hub';\n    const conflictPath = path.join(conflictRoot, conflictHub, 'manifest.json');\n    fs.mkdirSync(path.dirname(conflictPath));\n    fs.writeFileSync(conflictPath, validManifestBytes('b'.repeat(64)));\n    assert.throws(\n      () => sync.restoreExternalActivationManifests([{\n        hubId: conflictHub,\n        manifestBytes: validManifestBytes('c'.repeat(64)),\n        manifestFingerprint: 'unused',\n      }], conflictRoot),\n      /sync-conflict/,\n    );\n    const linkedRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'activation-linked-'));\n    const linkedHub = 'linked-retained-hub';\n    const linkedPath = path.join(linkedRoot, linkedHub, 'manifest.json');","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/compiled-route-manifest.test.cjs","text":"      () => sync.captureExternalActivationManifests(invalidRoot),\n      /sync-conflict/,\n    );\n\n    const conflictRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'activation-conflict-'));\n    const conflictHub = 'conflicting-retained-hub';\n    const conflictPath = path.join(conflictRoot, conflictHub, 'manifest.json');\n    fs.mkdirSync(path.dirname(conflictPath));\n    fs.writeFileSync(conflictPath, validManifestBytes('b'.repeat(64)));\n    assert.throws(\n      () => sync.restoreExternalActivationManifests([{\n        hubId: conflictHub,\n        manifestBytes: validManifestBytes('c'.repeat(64)),\n        manifestFingerprint: 'unused',\n      }], conflictRoot),\n      /sync-conflict/,\n    );\n    const linkedRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'activation-linked-'));\n    const linkedHub = 'linked-retained-hub';\n    const linkedPath = path.join(linkedRoot, linkedHub, 'manifest.json');\n    const linkedTarget = path.join(TEMP_ROOT, 'linked-retained-manifest.json');\n    fs.mkdirSync(path.dirname(linkedPath));\n    fs.writeFileSync(linkedTarget, validManifestBytes());\n    fs.symlinkSync(linkedTarget, linkedPath);\n    assert.throws(\n      () => sync.restoreExternalActivationManifests([{\n        hubId: linkedHub,\n        manifestBytes: validManifestBytes(),\n        manifestFingerprint: 'unused',\n      }], linkedRoot),\n      /sync-conflict/,\n    );\n    fs.rmSync(invalidRoot, { recursive: true, force: true });\n    fs.rmSync(conflictRoot, { recursive: true, force: true });\n    fs.rmSync(linkedRoot, { recursive: true, force: true });\n  });\n\n  test('uses atomic create-if-absent under concurrent writers', async () => {\n    const raceRoot = createParentFixture(RACE_HUB);\n    removeManifestDirectory(RACE_HUB);\n    const args = ['mint', '--hub', RACE_HUB, '--skill-root', raceRoot];\n    const results = await Promise.all([\n      runManifestCliAsync(args),\n      runManifestCliAsync(args),\n    ]);\n    assert.deepEqual(results.map((result) => result.code).sort(), [0, 1]);\n    assert.deepEqual(\n      results.map((result) => result.json.causeCode).sort(),\n      ['already-exists', 'fresh'],\n    );\n    assert.equal(results.find((result) => result.code === 0).json.created, true);\n    assert.equal(results.find((result) => result.code === 1).json.created, false);\n    removeManifestDirectory(RACE_HUB);\n  });\n\n  test('refuses an existing committed manifest before reading source inputs', () => {\n    const manifestPath = manifestContract.canonicalManifestPath({ hubId: 'sk-code' }).absolutePath;\n    const beforeBytes = fs.readFileSync(manifestPath);\n    const result = manifestContract.mintCanonicalManifest({\n      hubId: 'sk-code',\n      skillRoot: path.join(TEMP_ROOT, 'does-not-exist'),\n    });\n    assert.equal(result.causeCode, 'already-exists');\n    assert.equal(result.created, false);\n    assert.deepEqual(fs.readFileSync(manifestPath), beforeBytes);\n  });\n\n  test('keeps fixed routing maps unchanged; default cohort now serves the 7 promoted hubs compiled', () => {\n    delete process.env.SPECKIT_COMPILED_ROUTING;\n    assert.equal(resolver.DEFAULT_ON_HUBS.size, 7);\n    assert.equal(Object.prototype.hasOwnProperty.call(engine.HUB_CHILD, PRIMARY_HUB), false);\n    assert.equal(resolver.resolveRoute(PRIMARY_HUB, 'quality review'), null);\n    const records = status.computeAllStatus({ probeEngine: false });\n    for (const hubId of FIXED_HUBS) {\n      const record = records.find((candidate) => candidate.hubId === hubId);\n      assert.ok(record, hubId);\n      assert.equal(record.causeCode, 'compiled-serving', hubId);\n      assert.equal(typeof record.manifestFreshness, 'object', hubId);\n    }\n  });\n\n  test('refreshes a stale manifest to fresh through the CLI, bumping generation and preserving defaults', () => {\n    const refreshHub = `manifest-refresh-${process.pid}`;\n    const refreshRoot = createParentFixture(refreshHub);\n    removeManifestDirectory(refreshHub);\n    const minted = manifestContract.mintCanonicalManifest({ hubId: refreshHub, skillRoot: refreshRoot });\n    assert.equal(minted.created, true, minted.causeCode);\n    assert.equal(minted.selectedPolicy.generation, 1);\n\n    const skillPath = path.join(refreshRoot, 'SKILL.md');\n    const originalSkillMarkdown = fs.readFileSync(skillPath);\n    fs.writeFileSync(skillPath, Buffer.concat([originalSkillMarkdown, Buffer.from('\\n')]));\n    const stale = manifestContract.checkCanonicalManifestFreshness({\n      hubId: refreshHub,\n      skillRoot: refreshRoot,\n    });\n    assert.equal(stale.causeCode, 'stale-manifest');\n    assert.equal(stale.selectedPolicy.generation, 1);\n\n    const refreshed = runManifestCli(['refresh', '--hub', refreshHub, '--skill-root', refreshRoot]);\n    assert.equal(refreshed.status, 0, refreshed.stderr);\n    assert.equal(refreshed.json.refreshed, true);\n    assert.equal(refreshed.json.fresh, true);\n    assert.equal(refreshed.json.causeCode, 'fresh');\n    assert.equal(refreshed.json.selectedPolicy.generation, 2);\n    assert.notEqual(\n      refreshed.json.selectedPolicy.effectivePolicyHash,\n      minted.selectedPolicy.effectivePolicyHash,\n    );\n\n    const manifestPath = manifestContract.canonicalManifestPath({ hubId: refreshHub }).absolutePath;\n    const manifest = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));\n    assert.equal(manifest.servingAuthority, 'legacy');\n    assert.equal(manifest.shadowOnly, true);\n    assert.equal(manifest.selectedPolicy.generation, 2);\n\n    // Restoring the pre-drift input now drifts the *refreshed* (post-drift)\n    // manifest in turn, proving the new hash truly captured the drifted\n    // content rather than reusing the generation-one hash under a new number.\n    fs.writeFileSync(skillPath, originalSkillMarkdown);\n    const afterRestore = manifestContract.checkCanonicalManifestFreshness({\n      hubId: refreshHub,\n      skillRoot: refreshRoot,\n    });\n    assert.equal(afterRestore.causeCode, 'stale-manifest');\n  });\n\n  test('refuses to refresh unsafe hub identities and a missing manifest without writing anything', () => {\n    for (const hubId of ['../escape', '/absolute', 'Upper-Case', 'two--hyphens', '.']) {\n      const result = manifestContract.refreshCanonicalManifest({ hubId, skillRoot: primaryRoot });\n      assert.equal(result.causeCode, 'unsafe-path', hubId);\n      assert.equal(result.refreshed, false, hubId);\n      assert.equal(result.manifestValid, false, hubId);\n      assert.equal(result.fresh, false, hubId);\n    }\n\n    const neverMintedHub = `manifest-refresh-missing-${process.pid}`;\n    const neverMintedRoot = createParentFixture(neverMintedHub);\n    removeManifestDirectory(neverMintedHub);\n    const missing = manifestContract.refreshCanonicalManifest({\n      hubId: neverMintedHub,\n      skillRoot: neverMintedRoot,\n    });\n    assert.equal(missing.causeCode, 'missing-manifest');\n    assert.equal(missing.refreshed, false);\n    assert.equal(missing.manifestValid, false);\n    assert.equal(\n      fs.existsSync(manifestContract.canonicalManifestPath({ hubId: neverMintedHub }).absolutePath),\n      false,\n    );\n\n    const cliMissing = runManifestCli([\n      'refresh', '--hub', neverMintedHub, '--skill-root', neverMintedRoot,\n    ]);\n    assert.equal(cliMissing.status, 1);\n    assert.equal(cliMissing.json.causeCode, 'missing-manifest');\n    assert.equal(cliMissing.json.refreshed, false);\n  });\n\n  test('preserves a non-default shadowOnly value through refresh rather than hardcoding it', () => {\n    const preserveHub = `manifest-refresh-preserve-${process.pid}`;\n    const preserveRoot = createParentFixture(preserveHub);\n    removeManifestDirectory(preserveHub);\n    const manifestPath = manifestContract.canonicalManifestPath({ hubId: preserveHub }).absolutePath;\n    fs.mkdirSync(path.dirname(manifestPath), { recursive: true });\n    fs.writeFileSync(manifestPath, `${JSON.stringify({\n      schemaVersion: 'V1',\n      selectedPolicy: { effectivePolicyHash: 'a'.repeat(64), generation: 3 },\n      servingAuthority: 'legacy',\n      shadowOnly: false,\n    })}\\n`);\n\n    const result = manifestContract.refreshCanonicalManifest({\n      hubId: preserveHub,\n      skillRoot: preserveRoot,\n    });\n    assert.equal(result.refreshed, true, result.causeCode);\n    assert.equal(result.fresh, true, result.causeCode);\n    assert.equal(result.selectedPolicy.generation, 4);\n    assert.notEqual(result.selectedPolicy.effectivePolicyHash, 'a'.repeat(64));\n\n    const manifest = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));\n    assert.equal(manifest.servingAuthority, 'legacy');\n    assert.equal(manifest.shadowOnly, false);\n    assert.equal(manifest.selectedPolicy.generation, 4);\n  });\n\n  test('keeps the CLI thin, machine-readable, and usage-safe', () => {\n    const usage = runManifestCli(['mint', '--hub', PRIMARY_HUB]);\n    assert.equal(usage.status, 2);\n    assert.equal(usage.stdout, '');\n    assert.match(usage.stderr, /^usage:/);\n    const source = fs.readFileSync(\n      path.join(REPO_ROOT, '.opencode', 'bin', 'lib', 'compiled-route-manifest.cjs'),\n      'utf8',\n    );\n    assert.match(source, /registry-compiler\\.cjs/);\n    assert.match(source, /compileRegistry\\(\\{/);\n    assert.match(source, /checkCanonicalManifestFreshness\\(\\{ hubId, skillRoot \\}\\)/);\n    assert.doesNotMatch(source, /computeEffectivePolicyHash/);\n  });\n});","lineStart":420,"lineEnd":621,"totalLines":621,"truncated":false}},"title":".opencode/bin/tests/compiled-route-manifest.test.cjs","time":{"start":1784692605822,"end":1784692605831}},"metadata":{"openai":{"itemId":"fc_01ddd159cbe91627016a603f7d70b4819190769a5c17341581"}},"id":"prt_f87f8037c001rH3d7P3U4akME6","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f7ac75001uzglMhGOJ6LMVr"}}
{"type":"tool_use","timestamp":1784692605840,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_V9pNjmOUa2nnGveG311vYUPW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: // Serving-authority resolver — the safety gate around the compiled engine.\n5: //\n6: // The compiled route is authoritative for a hub ONLY when all three hold:\n7: //   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n8: //      unset lets the per-hub default-on cohort decide, and 0/false/off is the\n9: //      explicit fleet-wide kill-switch back to legacy;\n10: //   2. the hub's activation manifest has serving authority flipped to 'compiled';\n11: //   3. the routed snapshot's identity (effectivePolicyHash + generation) matches\n12: //      the manifest's selected policy — a drifted rollout artifact fails safe.\n13: //\n14: // Otherwise `resolveRoute` returns null and the caller keeps legacy routing.\n15: // The cutover stays reversible two ways — set the flag to 0 (fleet-wide) or flip\n16: // a hub's serving authority back to 'legacy' (per hub).\n17: \n18: const fs = require('fs');\n19: const path = require('path');\n20: const { compiledRoute } = require('./compiled-route.cjs');\n21: \n22: // Activation state root. Tests point SPECKIT_ACTIVATION_ROOT_OVERRIDE at a temp\n23: // copy so the harness never reads or mutates live committed state.\n24: const ACTIVATION_ROOT = process.env.SPECKIT_ACTIVATION_ROOT_OVERRIDE\n25:   || path.resolve(__dirname, '..', '..', '010-live-activation', 'activation');\n26: const FLAG = 'SPECKIT_COMPILED_ROUTING';\n27: const DEBUG_FLAG = 'SPECKIT_COMPILED_ROUTING_DEBUG';\n28: \n29: // Per-hub default-on cohort. All seven compiled-eligible hubs are verified\n30: // compiled-serving (Lane C parity: compiled byte-identical to legacy on every\n31: // scenario, 0 drift) and have been cut over together, so an unset flag now\n32: // resolves to compiled for every eligible hub. SPECKIT_COMPILED_ROUTING=0\n33: // remains the explicit fleet-wide kill-switch back to legacy.\n34: const DEFAULT_ON_HUBS = new Set([\n35:   'sk-code',\n36:   'system-deep-loop',\n37:   'mcp-tooling',\n38:   'cli-external-orchestration',\n39:   'sk-prompt',\n40:   'sk-design',\n41:   'sk-doc',\n42: ]);\n43: \n44: // Emit-only diagnostic. Gated behind an explicit debug flag and written to\n45: // stderr, so it never reaches stdout (the routing channel) or the TUI.\n46: function breadcrumb(message) {\n47:   if (process.env[DEBUG_FLAG]) {\n48:     process.stderr.write(`[compiled-routing] ${message}\\n`);\n49:   }\n50: }\n51: \n52: // Tri-state parse of the runtime flag:\n53: //   'force-on'     '1'                    serve compiled where a hub is eligible\n54: //   'force-legacy' '0' | 'false' | 'off'  explicit fleet-wide kill-switch\n55: //   'default'      unset                  per-hub cohort decides (empty => legacy)\n56: //   'invalid'      anything else          fail closed to legacy with a breadcrumb\n57: function parseFlagMode(raw) {\n58:   if (raw === undefined || raw === '') return 'default';\n59:   if (raw === '1') return 'force-on';\n60:   if (raw === '0' || raw === 'false' || raw === 'off') return 'force-legacy';\n61:   return 'invalid';\n62: }\n63: \n64: // Whether the flag permits compiled serving for this hub. The manifest\n65: // serving-authority gate in resolveRoute still applies on top of this, so a\n66: // permitted hub without a compiled manifest still routes legacy.\n67: function flagPermitsCompiled(hubId) {\n68:   const mode = parseFlagMode(process.env[FLAG]);\n69:   if (mode === 'force-on') return true;\n70:   if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n71:   if (mode === 'invalid') {\n72:     breadcrumb(`ignoring invalid ${FLAG}=${JSON.stringify(process.env[FLAG])}; serving legacy`);\n73:     return false;\n74:   }\n75:   return false; // force-legacy\n76: }\n77: \n78: // Retained export: true only when the operator forced the flag on, which is the\n79: // exact bi-state meaning callers of this predicate relied on before tri-state.\n80: function flagEnabled() {\n81:   return parseFlagMode(process.env[FLAG]) === 'force-on';\n82: }\n83: \n84: function readManifest(hubId) {\n85:   const manifest = path.join(ACTIVATION_ROOT, hubId, 'manifest.json');\n86:   if (!fs.existsSync(manifest)) return null;\n87:   try {\n88:     return JSON.parse(fs.readFileSync(manifest, 'utf8'));\n89:   } catch {\n90:     return null;\n91:   }\n92: }\n93: \n94: function servingAuthority(hubId) {\n95:   const manifest = readManifest(hubId);\n96:   return (manifest && manifest.servingAuthority) || 'legacy';\n97: }\n98: \n99: // Returns a normalized compiled decision when this hub is served by the compiled\n100: // contract and the flag is on; otherwise null (use legacy routing). Fails safe:\n101: // any error resolving the compiled route returns null rather than throwing into\n102: // a routing hot path.\n103: function resolveRoute(hubId, taskText) {\n104:   if (!flagPermitsCompiled(hubId)) return null;\n105:   const manifest = readManifest(hubId);\n106:   if (!manifest || manifest.servingAuthority !== 'compiled') return null;\n107:   try {\n108:     const route = compiledRoute(hubId, taskText);\n109:     // Serve-time identity binding: the snapshot we routed through MUST be the\n110:     // exact generation the manifest selected. If a rollout artifact drifted after\n111:     // the flip, the identities diverge — fail safe to legacy rather than serve an\n112:     // unselected policy on the routing hot path.\n113:     const selected = manifest.selectedPolicy || {};\n114:     if (route.effectivePolicyHash !== selected.effectivePolicyHash\n115:       || route.generation !== selected.generation) {\n116:       return null;\n117:     }\n118:     return route;\n119:   } catch (err) {\n120:     breadcrumb(`resolveRoute fell back to legacy for hub=${hubId}: ${err && err.message}`);\n121:     return null;\n122:   }\n123: }\n124: \n125: module.exports = {\n126:   resolveRoute,\n127:   servingAuthority,\n128:   flagEnabled,\n129:   flagPermitsCompiled,\n130:   parseFlagMode,\n131:   DEFAULT_ON_HUBS,\n132:   FLAG,\n133:   DEBUG_FLAG,\n134:   ACTIVATION_ROOT,\n135: };\n136: \n137: // CLI front door: the invocable entry a compiled-serving hub's SKILL.md routing\n138: // directive calls. Prints the compiled decision when authoritative, else a\n139: // legacy sentinel so the caller falls back to the prose smart-router.\n140: if (require.main === module) {\n141:   const args = process.argv.slice(2);\n142:   const hub = args[args.indexOf('--hub') + 1];\n143:   const promptIdx = args.indexOf('--prompt');\n144:   const prompt = promptIdx >= 0 ? args[promptIdx + 1] : '';\n145:   if (!hub) {\n146:     process.stderr.write('usage: resolve.cjs --hub <hubId> --prompt <text>\\n');\n147:     process.exit(2);\n148:   }\n149:   const route = resolveRoute(hub, prompt);\n150:   process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\\n`);\n151: }\n\n(End of file - total 151 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n// Serving-authority resolver — the safety gate around the compiled engine.\n//\n// The compiled route is authoritative for a hub ONLY when all three hold:\n//   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n//      unset lets the per-hub default-on cohort decide, and 0/false/off is the\n//      explicit fleet-wide kill-switch back to legacy;\n//   2. the hub's activation manifest has serving authority flipped to 'compiled';\n//   3. the routed snapshot's identity (effectivePolicyHash + generation) matches\n//      the manifest's selected policy — a drifted rollout artifact fails safe.\n//\n// Otherwise `resolveRoute` returns null and the caller keeps legacy routing.\n// The cutover stays reversible two ways — set the flag to 0 (fleet-wide) or flip\n// a hub's serving authority back to 'legacy' (per hub).\n\nconst fs = require('fs');\nconst path = require('path');\nconst { compiledRoute } = require('./compiled-route.cjs');","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs","text":"#!/usr/bin/env node\n'use strict';\n\n// Serving-authority resolver — the safety gate around the compiled engine.\n//\n// The compiled route is authoritative for a hub ONLY when all three hold:\n//   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n//      unset lets the per-hub default-on cohort decide, and 0/false/off is the\n//      explicit fleet-wide kill-switch back to legacy;\n//   2. the hub's activation manifest has serving authority flipped to 'compiled';\n//   3. the routed snapshot's identity (effectivePolicyHash + generation) matches\n//      the manifest's selected policy — a drifted rollout artifact fails safe.\n//\n// Otherwise `resolveRoute` returns null and the caller keeps legacy routing.\n// The cutover stays reversible two ways — set the flag to 0 (fleet-wide) or flip\n// a hub's serving authority back to 'legacy' (per hub).\n\nconst fs = require('fs');\nconst path = require('path');\nconst { compiledRoute } = require('./compiled-route.cjs');\n\n// Activation state root. Tests point SPECKIT_ACTIVATION_ROOT_OVERRIDE at a temp\n// copy so the harness never reads or mutates live committed state.\nconst ACTIVATION_ROOT = process.env.SPECKIT_ACTIVATION_ROOT_OVERRIDE\n  || path.resolve(__dirname, '..', '..', '010-live-activation', 'activation');\nconst FLAG = 'SPECKIT_COMPILED_ROUTING';\nconst DEBUG_FLAG = 'SPECKIT_COMPILED_ROUTING_DEBUG';\n\n// Per-hub default-on cohort. All seven compiled-eligible hubs are verified\n// compiled-serving (Lane C parity: compiled byte-identical to legacy on every\n// scenario, 0 drift) and have been cut over together, so an unset flag now\n// resolves to compiled for every eligible hub. SPECKIT_COMPILED_ROUTING=0\n// remains the explicit fleet-wide kill-switch back to legacy.\nconst DEFAULT_ON_HUBS = new Set([\n  'sk-code',\n  'system-deep-loop',\n  'mcp-tooling',\n  'cli-external-orchestration',\n  'sk-prompt',\n  'sk-design',\n  'sk-doc',\n]);\n\n// Emit-only diagnostic. Gated behind an explicit debug flag and written to\n// stderr, so it never reaches stdout (the routing channel) or the TUI.\nfunction breadcrumb(message) {\n  if (process.env[DEBUG_FLAG]) {\n    process.stderr.write(`[compiled-routing] ${message}\\n`);\n  }\n}\n\n// Tri-state parse of the runtime flag:\n//   'force-on'     '1'                    serve compiled where a hub is eligible\n//   'force-legacy' '0' | 'false' | 'off'  explicit fleet-wide kill-switch\n//   'default'      unset                  per-hub cohort decides (empty => legacy)\n//   'invalid'      anything else          fail closed to legacy with a breadcrumb\nfunction parseFlagMode(raw) {\n  if (raw === undefined || raw === '') return 'default';\n  if (raw === '1') return 'force-on';\n  if (raw === '0' || raw === 'false' || raw === 'off') return 'force-legacy';\n  return 'invalid';\n}\n\n// Whether the flag permits compiled serving for this hub. The manifest\n// serving-authority gate in resolveRoute still applies on top of this, so a\n// permitted hub without a compiled manifest still routes legacy.\nfunction flagPermitsCompiled(hubId) {\n  const mode = parseFlagMode(process.env[FLAG]);\n  if (mode === 'force-on') return true;\n  if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n  if (mode === 'invalid') {\n    breadcrumb(`ignoring invalid ${FLAG}=${JSON.stringify(process.env[FLAG])}; serving legacy`);\n    return false;\n  }\n  return false; // force-legacy\n}\n\n// Retained export: true only when the operator forced the flag on, which is the\n// exact bi-state meaning callers of this predicate relied on before tri-state.\nfunction flagEnabled() {\n  return parseFlagMode(process.env[FLAG]) === 'force-on';\n}\n\nfunction readManifest(hubId) {\n  const manifest = path.join(ACTIVATION_ROOT, hubId, 'manifest.json');\n  if (!fs.existsSync(manifest)) return null;\n  try {\n    return JSON.parse(fs.readFileSync(manifest, 'utf8'));\n  } catch {\n    return null;\n  }\n}\n\nfunction servingAuthority(hubId) {\n  const manifest = readManifest(hubId);\n  return (manifest && manifest.servingAuthority) || 'legacy';\n}\n\n// Returns a normalized compiled decision when this hub is served by the compiled\n// contract and the flag is on; otherwise null (use legacy routing). Fails safe:\n// any error resolving the compiled route returns null rather than throwing into\n// a routing hot path.\nfunction resolveRoute(hubId, taskText) {\n  if (!flagPermitsCompiled(hubId)) return null;\n  const manifest = readManifest(hubId);\n  if (!manifest || manifest.servingAuthority !== 'compiled') return null;\n  try {\n    const route = compiledRoute(hubId, taskText);\n    // Serve-time identity binding: the snapshot we routed through MUST be the\n    // exact generation the manifest selected. If a rollout artifact drifted after\n    // the flip, the identities diverge — fail safe to legacy rather than serve an\n    // unselected policy on the routing hot path.\n    const selected = manifest.selectedPolicy || {};\n    if (route.effectivePolicyHash !== selected.effectivePolicyHash\n      || route.generation !== selected.generation) {\n      return null;\n    }\n    return route;\n  } catch (err) {\n    breadcrumb(`resolveRoute fell back to legacy for hub=${hubId}: ${err && err.message}`);\n    return null;\n  }\n}\n\nmodule.exports = {\n  resolveRoute,\n  servingAuthority,\n  flagEnabled,\n  flagPermitsCompiled,\n  parseFlagMode,\n  DEFAULT_ON_HUBS,\n  FLAG,\n  DEBUG_FLAG,\n  ACTIVATION_ROOT,\n};\n\n// CLI front door: the invocable entry a compiled-serving hub's SKILL.md routing\n// directive calls. Prints the compiled decision when authoritative, else a\n// legacy sentinel so the caller falls back to the prose smart-router.\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const hub = args[args.indexOf('--hub') + 1];\n  const promptIdx = args.indexOf('--prompt');\n  const prompt = promptIdx >= 0 ? args[promptIdx + 1] : '';\n  if (!hub) {\n    process.stderr.write('usage: resolve.cjs --hub <hubId> --prompt <text>\\n');\n    process.exit(2);\n  }\n  const route = resolveRoute(hub, prompt);\n  process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\\n`);\n}","lineStart":1,"lineEnd":151,"totalLines":151,"truncated":false}},"title":".opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs","time":{"start":1784692605819,"end":1784692605836}},"metadata":{"openai":{"itemId":"fc_01ddd159cbe91627016a603f7d70b0819188bec8d06122fa5f"}},"id":"prt_f87f80372001x1WVtnnH0tohRh","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f7ac75001uzglMhGOJ6LMVr"}}
{"type":"tool_use","timestamp":1784692605847,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"grep","callID":"call_twGozcwOMhLukuQvBbE6lDkp","state":{"status":"completed","input":{"pattern":"refresh|unsafe|zero bytes|servingAuthority|shadowOnly","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/compiled-route-manifest.test.cjs"},"output":"Found 52 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/compiled-route-manifest.test.cjs:\n  Line 115:     servingAuthority: 'legacy',\n\n  Line 116:     shadowOnly: true,\n\n  Line 147:   test('rejects unsafe identities and reports a missing safe manifest', () => {\n\n  Line 151:         /unsafe-path/,\n\n  Line 210:     }).causeCode, 'unsafe-path');\n\n  Line 220:     }).causeCode, 'unsafe-path');\n\n  Line 237:     }).causeCode, 'unsafe-path');\n\n  Line 245:     }).causeCode, 'unsafe-path');\n\n  Line 268:       'schemaVersion', 'selectedPolicy', 'servingAuthority', 'shadowOnly',\n\n  Line 272:     assert.equal(manifest.servingAuthority, 'legacy');\n\n  Line 273:     assert.equal(manifest.shadowOnly, true);\n\n  Line 280:       servingAuthority: 'legacy',\n\n  Line 358:     assert.equal(record.servingAuthority, 'legacy');\n\n  Line 501:   test('refreshes a stale manifest to fresh through the CLI, bumping generation and preserving defaults', () => {\n\n  Line 502:     const refreshHub = `manifest-refresh-${process.pid}`;\n\n  Line 503:     const refreshRoot = createParentFixture(refreshHub);\n\n  Line 504:     removeManifestDirectory(refreshHub);\n\n  Line 505:     const minted = manifestContract.mintCanonicalManifest({ hubId: refreshHub, skillRoot: refreshRoot });\n\n  Line 509:     const skillPath = path.join(refreshRoot, 'SKILL.md');\n\n  Line 513:       hubId: refreshHub,\n\n  Line 514:       skillRoot: refreshRoot,\n\n  Line 519:     const refreshed = runManifestCli(['refresh', '--hub', refreshHub, '--skill-root', refreshRoot]);\n\n  Line 520:     assert.equal(refreshed.status, 0, refreshed.stderr);\n\n  Line 521:     assert.equal(refreshed.json.refreshed, true);\n\n  Line 522:     assert.equal(refreshed.json.fresh, true);\n\n  Line 523:     assert.equal(refreshed.json.causeCode, 'fresh');\n\n  Line 524:     assert.equal(refreshed.json.selectedPolicy.generation, 2);\n\n  Line 526:       refreshed.json.selectedPolicy.effectivePolicyHash,\n\n  Line 530:     const manifestPath = manifestContract.canonicalManifestPath({ hubId: refreshHub }).absolutePath;\n\n  Line 532:     assert.equal(manifest.servingAuthority, 'legacy');\n\n  Line 533:     assert.equal(manifest.shadowOnly, true);\n\n  Line 536:     // Restoring the pre-drift input now drifts the *refreshed* (post-drift)\n\n  Line 541:       hubId: refreshHub,\n\n  Line 542:       skillRoot: refreshRoot,\n\n  Line 547:   test('refuses to refresh unsafe hub identities and a missing manifest without writing anything', () => {\n\n  Line 549:       const result = manifestContract.refreshCanonicalManifest({ hubId, skillRoot: primaryRoot });\n\n  Line 550:       assert.equal(result.causeCode, 'unsafe-path', hubId);\n\n  Line 551:       assert.equal(result.refreshed, false, hubId);\n\n  Line 556:     const neverMintedHub = `manifest-refresh-missing-${process.pid}`;\n\n  Line 559:     const missing = manifestContract.refreshCanonicalManifest({\n\n  Line 564:     assert.equal(missing.refreshed, false);\n\n  Line 572:       'refresh', '--hub', neverMintedHub, '--skill-root', neverMintedRoot,\n\n  Line 576:     assert.equal(cliMissing.json.refreshed, false);\n\n  Line 579:   test('preserves a non-default shadowOnly value through refresh rather than hardcoding it', () => {\n\n  Line 580:     const preserveHub = `manifest-refresh-preserve-${process.pid}`;\n\n  Line 588:       servingAuthority: 'legacy',\n\n  Line 589:       shadowOnly: false,\n\n  Line 592:     const result = manifestContract.refreshCanonicalManifest({\n\n  Line 596:     assert.equal(result.refreshed, true, result.causeCode);\n\n  Line 602:     assert.equal(manifest.servingAuthority, 'legacy');\n\n  Line 603:     assert.equal(manifest.shadowOnly, false);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/worktree-session.test.sh:\n  Line 85: expect \"traversal entry emits a skip warning\" grep -F \"unsafe shared path: ../../victim\" \"$F1_STDERR\"\n","metadata":{"matches":52,"truncated":false},"title":"refresh|unsafe|zero bytes|servingAuthority|shadowOnly","time":{"start":1784692605825,"end":1784692605841}},"metadata":{"openai":{"itemId":"fc_01ddd159cbe91627016a603f7d70b88191a7394f296801d150"}},"id":"prt_f87f8037f001lmLFCfQ2O5fHnC","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f7ac75001uzglMhGOJ6LMVr"}}
