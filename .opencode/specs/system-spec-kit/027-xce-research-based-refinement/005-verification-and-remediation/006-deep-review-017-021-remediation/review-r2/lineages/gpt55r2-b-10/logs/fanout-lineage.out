(row): HybridSearchResult | null => {\n752:         const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n753:         const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n754:         if (matchScore <= 0) return null;\n755: \n756:         const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n757:           ? Math.max(0, Math.min(1, row.importance_weight))\n758:           : 0.5;\n759:         const recency = timestampBoost(row.updated_at ?? row.created_at);\n760:         const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n761: \n762:         return {\n763:           ...row,\n764:           id: row.id as number,\n765:           score,\n766:           triggerScore: matchScore,\n767:           source: 'trigger',\n768:         };\n769:       })\n770:       .filter((row): row is HybridSearchResult => row !== null)\n771:       .sort((a, b) => {\n772:         const scoreDelta = b.score - a.score;\n773:         if (scoreDelta !== 0) return scoreDelta;\n774:         const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n775:         const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n776:         return bTime - aTime;\n777:       })\n778:       .slice(0, limit);\n779:   } catch (error: unknown) {\n780:     const msg = error instanceof Error ? error.message : String(error);\n781:     console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n782:     return [];\n783:   }\n784: }\n785: \n786: type RawChannelList = {\n787:   source: string;\n788:   results: Array<{ id: number | string; [key: string]: unknown }>;\n789: };\n790: \n791: function resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n792:   if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n793:     return result.score;\n794:   }\n795:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n796:     return result.similarity / 100;\n797:   }\n798:   return 0;\n799: }\n800: \n801: function getCandidateSources(result: HybridSearchResult): string[] {\n802:   const sourceList = (result as { sources?: unknown }).sources;\n803:   if (Array.isArray(sourceList)) {\n804:     return sourceList.filter((value): value is string => typeof value === 'string');\n805:   }\n806:   return typeof result.source === 'string' && result.source.length > 0\n807:     ? [result.source]\n808:     : [];\n809: }\n\n(Showing lines 720-809 of 2972. Use offset=810 to continue.)\n</content>","metadata":{"preview":"    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE ${conditions.join(' AND ')}\n      ORDER BY\n        CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n        COALESCE(m.updated_at, m.created_at, '') DESC\n      LIMIT ${candidateLimit}\n    `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n\n    return rows\n      .map((row): HybridSearchResult | null => {\n        const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n        const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n        if (matchScore <= 0) return null;\n\n        const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n          ? Math.max(0, Math.min(1, row.importance_weight))\n          : 0.5;\n        const recency = timestampBoost(row.updated_at ?? row.created_at);\n        const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n\n        return {\n          ...row,\n          id: row.id as number,\n          score,\n          triggerScore: matchScore,\n          source: 'trigger',\n        };\n      })\n      .filter((row): row is HybridSearchResult => row !== null)\n      .sort((a, b) => {\n        const scoreDelta = b.score - a.score;\n        if (scoreDelta !== 0) return scoreDelta;\n        const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n        const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n        return bTime - aTime;\n      })\n      .slice(0, limit);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n    return [];\n  }\n}\n\ntype RawChannelList = {\n  source: string;\n  results: Array<{ id: number | string; [key: string]: unknown }>;\n};\n\nfunction resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n    return result.score;\n  }\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n    return result.similarity / 100;\n  }\n  return 0;\n}\n\nfunction getCandidateSources(result: HybridSearchResult): string[] {\n  const sourceList = (result as { sources?: unknown }).sources;\n  if (Array.isArray(sourceList)) {\n    return sourceList.filter((value): value is string => typeof value === 'string');\n  }\n  return typeof result.source === 'string' && result.source.length > 0\n    ? [result.source]\n    : [];\n}","lineStart":720,"lineEnd":809,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781764539422,"end":1781764539426}},"metadata":{"openai":{"itemId":"fc_0d1720205fe8e78f016a3391bb23d081919b08b8b7377af885"}},"id":"prt_ed97143dd001r8GwegUp23WPGK","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed970f394001uqlhSOw0rIuuYx"}}
{"type":"tool_use","timestamp":1781764539450,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_3F2ogbLnXYNpCPOdc83TrZIN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Sqlite Fts\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Semantic and lexical search (memory_search)\n5: // Weighted BM25 scoring for FTS5 full-text search.\n6: // Extracted from hybrid-search.ts ftsSearch() for independent\n7: // Testing and future delegation.\n8: \n9: import { BM25_FTS5_WEIGHTS } from './bm25-index.js';\n10: import { specFolderLikePattern } from './vector-index-types.js';\n11: import { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\n12: import { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\n13: import type Database from 'better-sqlite3';\n14: \n15: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n16: // 2. INTERFACES\n17: \n18: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n19: interface FtsBm25Result {\n20:   id: number;\n21:   fts_score: number;\n22:   [key: string]: unknown;\n23: }\n24: \n25: interface FtsBm25Options {\n26:   limit?: number;\n27:   specFolder?: string;\n28:   includeArchived?: boolean;\n29: }\n30: \n31: type LexicalPath = 'fts5' | 'like' | 'unavailable';\n32: type FallbackState =\n33:   | 'ok'\n34:   | 'compile_probe_miss'\n35:   | 'missing_table'\n36:   | 'no_such_module_fts5'\n37:   | 'bm25_runtime_failure';\n38: \n39: interface LexicalCapabilitySnapshot {\n40:   lexicalPath: LexicalPath;\n41:   fallbackState: FallbackState;\n42: }\n43: \n44: let lastLexicalCapabilitySnapshot: LexicalCapabilitySnapshot | null = null;\n45: \n46: function cloneLexicalCapabilitySnapshot(\n47:   snapshot: LexicalCapabilitySnapshot | null\n48: ): LexicalCapabilitySnapshot | null {\n49:   return snapshot ? { ...snapshot } : null;\n50: }\n51: \n52: function setLastLexicalCapabilitySnapshot(snapshot: LexicalCapabilitySnapshot): void {\n53:   lastLexicalCapabilitySnapshot = { ...snapshot };\n54: }\n55: \n56: function getLastLexicalCapabilitySnapshot(): LexicalCapabilitySnapshot | null {\n57:   return cloneLexicalCapabilitySnapshot(lastLexicalCapabilitySnapshot);\n58: }\n59: \n60: function resetLastLexicalCapabilitySnapshot(): void {\n61:   lastLexicalCapabilitySnapshot = null;\n62: }\n63: \n64: function toErrorMessage(error: unknown): string {\n65:   return error instanceof Error ? error.message : String(error);\n66: }\n67: \n68: function readCompileOptionValue(row: unknown): string | null {\n69:   if (typeof row === 'string') {\n70:     return row;\n71:   }\n72:   if (!row || typeof row !== 'object') {\n73:     return null;\n74:   }\n75: \n76:   const record = row as Record<string, unknown>;\n77:   const direct = record.compile_options;\n78:   if (typeof direct === 'string') {\n79:     return direct;\n80:   }\n81: \n82:   const firstString = Object.values(record).find((value) => typeof value === 'string');\n83:   return typeof firstString === 'string' ? firstString : null;\n84: }\n85: \n86: function isNoSuchModuleFts5Error(error: unknown): boolean {\n87:   return toErrorMessage(error).toLowerCase().includes('no such module: fts5');\n88: }\n89: \n90: function isBm25RuntimeFailure(error: unknown): boolean {\n91:   const message = toErrorMessage(error).toLowerCase();\n92:   return message.includes('bm25');\n93: }\n94: \n95: function probeFts5Capability(db: Database.Database): LexicalCapabilitySnapshot {\n96:   try {\n97:     const compileRows = (db.prepare('PRAGMA compile_options') as Database.Statement).all() as unknown[];\n98:     const hasFts5CompileFlag = compileRows\n99:       .map(readCompileOptionValue)\n100:       .some((value) => typeof value === 'string' && value.toUpperCase().includes('ENABLE_FTS5'));\n101: \n102:     if (!hasFts5CompileFlag) {\n103:       return {\n104:         lexicalPath: 'unavailable',\n105:         fallbackState: 'compile_probe_miss',\n106:       };\n107:     }\n108:   } catch {\n109:     return {\n110:       lexicalPath: 'unavailable',\n111:       fallbackState: 'compile_probe_miss',\n112:     };\n113:   }\n114: \n115:   try {\n116:     const result = (db.prepare(\n117:       `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n118:     ) as Database.Statement).get() as { name: string } | undefined;\n119: \n120:     if (!result) {\n121:       return {\n122:         lexicalPath: 'unavailable',\n123:         fallbackState: 'missing_table',\n124:       };\n125:     }\n126:   } catch (error: unknown) {\n127:     if (isNoSuchModuleFts5Error(error)) {\n128:       return {\n129:         lexicalPath: 'unavailable',\n130:         fallbackState: 'no_such_module_fts5',\n131:       };\n132:     }\n133:     return {\n134:       lexicalPath: 'unavailable',\n135:       fallbackState: 'missing_table',\n136:     };\n137:   }\n138: \n139:   return {\n140:     lexicalPath: 'fts5',\n141:     fallbackState: 'ok',\n142:   };\n143: }\n144: \n145: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n146: // 3. CORE FUNCTION\n147: \n148: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n149: /**\n150:  * Execute a weighted BM25 FTS5 search against memory_fts.\n151:  *\n152:  * Uses SQLite FTS5's built-in bm25() ranking function with\n153:  * per-column weights instead of the default `rank` pseudo-column.\n154:  * This gives title matches 10x weight, trigger_phrases 5x, etc.\n155:  *\n156:  * @param db - SQLite database connection\n157:  * @param query - Raw search query (will be sanitized)\n158:  * @param options - Search options (limit, specFolder, includeArchived)\n159:  * @returns Array of results with BM25 scores (higher = better)\n160:  * @example\n161:  * ```ts\n162:  * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n163:  * ```\n164:  */\n165: function fts5Bm25Search(\n166:   db: Database.Database,\n167:   query: string,\n168:   options: FtsBm25Options = {}\n169: ): FtsBm25Result[] {\n170:   const { limit = 20, specFolder, includeArchived = false } = options;\n171:   // Include cold/deprecated-tier rows by default (or on explicit includeArchived) вҖ”\n172:   // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n173:   const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n174: \n175:   // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n176:   const sanitized = normalizeLexicalQueryTokens(query).fts;\n177: \n178:   if (!sanitized) {\n179:     setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n180:     return [];\n181:   }\n182: \n183:   const folderFilter = specFolder\n184:     ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n185:     : '';\n186:   const deprecatedTierFilter = includeCold\n187:     ? ''\n188:     : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n189: \n190:   const params: (string | number)[] = specFolder\n191:     ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n192:     : [sanitized, limit];\n193: \n194:   // Bm25() returns negative scores (lower = better), so we negate\n195:   // To produce positive scores where higher = better match.\n196:   const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n197:   const sql = `\n198:     SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n199:     FROM memory_fts\n200:     JOIN memory_index m ON m.id = memory_fts.rowid\n201:     WHERE memory_fts MATCH ?\n202:       ${folderFilter}\n203:       ${deprecatedTierFilter}\n204:     ORDER BY fts_score DESC\n205:     LIMIT ?\n206:   `;\n207: \n208:   const capability = probeFts5Capability(db);\n209:   setLastLexicalCapabilitySnapshot(capability);\n210:   if (capability.fallbackState !== 'ok') {\n211:     console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n212:     return [];\n213:   }\n214: \n215:   try {\n216:     const rows = (db.prepare(sql) as Database.Statement).all(\n217:       ...params\n218:     ) as Array<Record<string, unknown>>;\n219: \n220:     const normalizedRows = rows.map(row => ({\n221:       ...row,\n222:       id: row.id as number,\n223:       fts_score: (row.fts_score as number) || 0,\n224:     }));\n225:     setLastLexicalCapabilitySnapshot({\n226:       lexicalPath: 'fts5',\n227:       fallbackState: 'ok',\n228:     });\n229:     return normalizedRows;\n230:   } catch (error: unknown) {\n231:     const msg = error instanceof Error ? error.message : String(error);\n232:     const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n233:       ? {\n234:           lexicalPath: 'unavailable',\n235:           fallbackState: 'no_such_module_fts5',\n236:         }\n237:       : isBm25RuntimeFailure(error)\n238:         ? {\n239:             lexicalPath: 'unavailable',\n240:             fallbackState: 'bm25_runtime_failure',\n241:           }\n242:         : msg.toLowerCase().includes('no such table: memory_fts')\n243:           ? {\n244:               lexicalPath: 'unavailable',\n245:               fallbackState: 'missing_table',\n246:             }\n247:           : {\n248:               lexicalPath: 'unavailable',\n249:               fallbackState: 'bm25_runtime_failure',\n250:             };\n251:     setLastLexicalCapabilitySnapshot(failureSnapshot);\n252:     console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n253:     return [];\n254:   }\n255: }\n256: \n257: /**\n258:  * Check if the memory_fts FTS5 virtual table exists in the database.\n259:  *\n260:  * Used as a feature-detect before calling fts5Bm25Search, since FTS5\n\n(Showing lines 1-260 of 299. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Sqlite Fts\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Semantic and lexical search (memory_search)\n// Weighted BM25 scoring for FTS5 full-text search.\n// Extracted from hybrid-search.ts ftsSearch() for independent\n// Testing and future delegation.\n\nimport { BM25_FTS5_WEIGHTS } from './bm25-index.js';\nimport { specFolderLikePattern } from './vector-index-types.js';\nimport { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\nimport { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\nimport type Database from 'better-sqlite3';\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// 2. INTERFACES\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ninterface FtsBm25Result {\n  id: number;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Sqlite Fts\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Semantic and lexical search (memory_search)\n// Weighted BM25 scoring for FTS5 full-text search.\n// Extracted from hybrid-search.ts ftsSearch() for independent\n// Testing and future delegation.\n\nimport { BM25_FTS5_WEIGHTS } from './bm25-index.js';\nimport { specFolderLikePattern } from './vector-index-types.js';\nimport { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\nimport { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\nimport type Database from 'better-sqlite3';\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// 2. INTERFACES\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ninterface FtsBm25Result {\n  id: number;\n  fts_score: number;\n  [key: string]: unknown;\n}\n\ninterface FtsBm25Options {\n  limit?: number;\n  specFolder?: string;\n  includeArchived?: boolean;\n}\n\ntype LexicalPath = 'fts5' | 'like' | 'unavailable';\ntype FallbackState =\n  | 'ok'\n  | 'compile_probe_miss'\n  | 'missing_table'\n  | 'no_such_module_fts5'\n  | 'bm25_runtime_failure';\n\ninterface LexicalCapabilitySnapshot {\n  lexicalPath: LexicalPath;\n  fallbackState: FallbackState;\n}\n\nlet lastLexicalCapabilitySnapshot: LexicalCapabilitySnapshot | null = null;\n\nfunction cloneLexicalCapabilitySnapshot(\n  snapshot: LexicalCapabilitySnapshot | null\n): LexicalCapabilitySnapshot | null {\n  return snapshot ? { ...snapshot } : null;\n}\n\nfunction setLastLexicalCapabilitySnapshot(snapshot: LexicalCapabilitySnapshot): void {\n  lastLexicalCapabilitySnapshot = { ...snapshot };\n}\n\nfunction getLastLexicalCapabilitySnapshot(): LexicalCapabilitySnapshot | null {\n  return cloneLexicalCapabilitySnapshot(lastLexicalCapabilitySnapshot);\n}\n\nfunction resetLastLexicalCapabilitySnapshot(): void {\n  lastLexicalCapabilitySnapshot = null;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction readCompileOptionValue(row: unknown): string | null {\n  if (typeof row === 'string') {\n    return row;\n  }\n  if (!row || typeof row !== 'object') {\n    return null;\n  }\n\n  const record = row as Record<string, unknown>;\n  const direct = record.compile_options;\n  if (typeof direct === 'string') {\n    return direct;\n  }\n\n  const firstString = Object.values(record).find((value) => typeof value === 'string');\n  return typeof firstString === 'string' ? firstString : null;\n}\n\nfunction isNoSuchModuleFts5Error(error: unknown): boolean {\n  return toErrorMessage(error).toLowerCase().includes('no such module: fts5');\n}\n\nfunction isBm25RuntimeFailure(error: unknown): boolean {\n  const message = toErrorMessage(error).toLowerCase();\n  return message.includes('bm25');\n}\n\nfunction probeFts5Capability(db: Database.Database): LexicalCapabilitySnapshot {\n  try {\n    const compileRows = (db.prepare('PRAGMA compile_options') as Database.Statement).all() as unknown[];\n    const hasFts5CompileFlag = compileRows\n      .map(readCompileOptionValue)\n      .some((value) => typeof value === 'string' && value.toUpperCase().includes('ENABLE_FTS5'));\n\n    if (!hasFts5CompileFlag) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'compile_probe_miss',\n      };\n    }\n  } catch {\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'compile_probe_miss',\n    };\n  }\n\n  try {\n    const result = (db.prepare(\n      `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n    ) as Database.Statement).get() as { name: string } | undefined;\n\n    if (!result) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'missing_table',\n      };\n    }\n  } catch (error: unknown) {\n    if (isNoSuchModuleFts5Error(error)) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'no_such_module_fts5',\n      };\n    }\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'missing_table',\n    };\n  }\n\n  return {\n    lexicalPath: 'fts5',\n    fallbackState: 'ok',\n  };\n}\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// 3. CORE FUNCTION\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n/**\n * Execute a weighted BM25 FTS5 search against memory_fts.\n *\n * Uses SQLite FTS5's built-in bm25() ranking function with\n * per-column weights instead of the default `rank` pseudo-column.\n * This gives title matches 10x weight, trigger_phrases 5x, etc.\n *\n * @param db - SQLite database connection\n * @param query - Raw search query (will be sanitized)\n * @param options - Search options (limit, specFolder, includeArchived)\n * @returns Array of results with BM25 scores (higher = better)\n * @example\n * ```ts\n * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n * ```\n */\nfunction fts5Bm25Search(\n  db: Database.Database,\n  query: string,\n  options: FtsBm25Options = {}\n): FtsBm25Result[] {\n  const { limit = 20, specFolder, includeArchived = false } = options;\n  // Include cold/deprecated-tier rows by default (or on explicit includeArchived) вҖ”\n  // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n  const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n\n  // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n  const sanitized = normalizeLexicalQueryTokens(query).fts;\n\n  if (!sanitized) {\n    setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n    return [];\n  }\n\n  const folderFilter = specFolder\n    ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n    : '';\n  const deprecatedTierFilter = includeCold\n    ? ''\n    : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n\n  const params: (string | number)[] = specFolder\n    ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n    : [sanitized, limit];\n\n  // Bm25() returns negative scores (lower = better), so we negate\n  // To produce positive scores where higher = better match.\n  const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n  const sql = `\n    SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n    FROM memory_fts\n    JOIN memory_index m ON m.id = memory_fts.rowid\n    WHERE memory_fts MATCH ?\n      ${folderFilter}\n      ${deprecatedTierFilter}\n    ORDER BY fts_score DESC\n    LIMIT ?\n  `;\n\n  const capability = probeFts5Capability(db);\n  setLastLexicalCapabilitySnapshot(capability);\n  if (capability.fallbackState !== 'ok') {\n    console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n    return [];\n  }\n\n  try {\n    const rows = (db.prepare(sql) as Database.Statement).all(\n      ...params\n    ) as Array<Record<string, unknown>>;\n\n    const normalizedRows = rows.map(row => ({\n      ...row,\n      id: row.id as number,\n      fts_score: (row.fts_score as number) || 0,\n    }));\n    setLastLexicalCapabilitySnapshot({\n      lexicalPath: 'fts5',\n      fallbackState: 'ok',\n    });\n    return normalizedRows;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n      ? {\n          lexicalPath: 'unavailable',\n          fallbackState: 'no_such_module_fts5',\n        }\n      : isBm25RuntimeFailure(error)\n        ? {\n            lexicalPath: 'unavailable',\n            fallbackState: 'bm25_runtime_failure',\n          }\n        : msg.toLowerCase().includes('no such table: memory_fts')\n          ? {\n              lexicalPath: 'unavailable',\n              fallbackState: 'missing_table',\n            }\n          : {\n              lexicalPath: 'unavailable',\n              fallbackState: 'bm25_runtime_failure',\n            };\n    setLastLexicalCapabilitySnapshot(failureSnapshot);\n    console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check if the memory_fts FTS5 virtual table exists in the database.\n *\n * Used as a feature-detect before calling fts5Bm25Search, since FTS5","lineStart":1,"lineEnd":260,"totalLines":299,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","time":{"start":1781764539446,"end":1781764539449}},"metadata":{"openai":{"itemId":"fc_0d1720205fe8e78f016a3391bb23f08191a671656f9ea91259"}},"id":"prt_ed9714423001OssMzZ417xfTZj","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed970f394001uqlhSOw0rIuuYx"}}
{"type":"tool_use","timestamp":1781764539465,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_zJpiLUKm9gDz61xyXGOhaHZv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts","offset":150,"limit":75},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts</path>\n<type>file</type>\n<content>\n150: /**\n151:  * FTS5-backed causal edge query. Finds memory IDs via the memory_fts\n152:  * virtual table, then retrieves causal edges connected to those memories.\n153:  * Scores incorporate both edge strength and FTS5 BM25 relevance.\n154:  */\n155: function queryCausalEdgesFTS5(\n156:   database: Database.Database,\n157:   query: string,\n158:   limit: number\n159: ): Array<Record<string, unknown>> {\n160:   const sanitized = sanitizeFTS5Query(query);\n161:   if (!sanitized) return [];\n162:   const oversampleLimit = limit * 3;\n163: \n164:   // BM25-inspired weights: title(10) highest signal, content(5), triggers(2), folder(1).\n165:   // Query shape:\n166:   // 1) Materialize matched memory rowids once (no OR join against memory_fts)\n167:   // 2) UNION ALL source-side and target-side edge lookups\n168:   // 3) Collapse duplicate edge hits in SQL (MAX fts_score per edge)\n169:   const rows = (database.prepare(`\n170:     WITH matched_memories AS (\n171:       SELECT\n172:         rowid AS memory_id,\n173:         -bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) AS fts_score\n174:       FROM memory_fts\n175:       WHERE memory_fts MATCH ?\n176:       ORDER BY fts_score DESC\n177:       LIMIT ?\n178:     ),\n179:     edge_hits AS (\n180:       SELECT ce.id, ce.source_id, ce.target_id, ce.relation, ce.strength, mm.fts_score\n181:       FROM matched_memories mm\n182:       JOIN causal_edges ce ON ce.source_id = CAST(mm.memory_id AS TEXT)\n183:       UNION ALL\n184:       SELECT ce.id, ce.source_id, ce.target_id, ce.relation, ce.strength, mm.fts_score\n185:       FROM matched_memories mm\n186:       JOIN causal_edges ce ON ce.target_id = CAST(mm.memory_id AS TEXT)\n187:     ),\n188:     scored_edges AS (\n189:       SELECT\n190:         id,\n191:         source_id,\n192:         target_id,\n193:         relation,\n194:         strength,\n195:         MAX(fts_score) AS fts_score\n196:       FROM edge_hits\n197:       GROUP BY id, source_id, target_id, relation, strength\n198:     )\n199:     SELECT id, source_id, target_id, relation, strength, fts_score\n200:     FROM scored_edges\n201:     ORDER BY (strength * fts_score) DESC\n202:     LIMIT ?\n203:   `) as Database.Statement).all(\n204:     sanitized,\n205:     oversampleLimit,\n206:     oversampleLimit,\n207:   ) as Array<CausalEdgeRow & { fts_score: number }>;\n208: \n209:   // Return one candidate entry per memory node (source_id and target_id) with\n210:   // Numeric IDs matching memory_index.id (INTEGER column) in the hybrid search\n211:   // Pipeline (MMR reranking filters with typeof id === 'number').\n212:   const candidates: Array<Record<string, unknown>> = [];\n213:   for (const row of rows) {\n214:     const edgeStrength = typeof row.strength === 'number'\n215:       ? Math.min(1, Math.max(0, row.strength))\n216:       : 0;\n217:     const ftsScore = typeof row.fts_score === 'number' && Number.isFinite(row.fts_score)\n218:       ? row.fts_score\n219:       : 0;\n220:     const score = edgeStrength * ftsScore;\n221:     const title = `${row.source_id} -> ${row.target_id}`;\n222: \n223:     const sourceNum = Number(row.source_id);\n224:     if (!Number.isNaN(sourceNum)) {\n\n(Showing lines 150-224 of 706. Use offset=225 to continue.)\n</content>","metadata":{"preview":"/**\n * FTS5-backed causal edge query. Finds memory IDs via the memory_fts\n * virtual table, then retrieves causal edges connected to those memories.\n * Scores incorporate both edge strength and FTS5 BM25 relevance.\n */\nfunction queryCausalEdgesFTS5(\n  database: Database.Database,\n  query: string,\n  limit: number\n): Array<Record<string, unknown>> {\n  const sanitized = sanitizeFTS5Query(query);\n  if (!sanitized) return [];\n  const oversampleLimit = limit * 3;\n\n  // BM25-inspired weights: title(10) highest signal, content(5), triggers(2), folder(1).\n  // Query shape:\n  // 1) Materialize matched memory rowids once (no OR join against memory_fts)\n  // 2) UNION ALL source-side and target-side edge lookups\n  // 3) Collapse duplicate edge hits in SQL (MAX fts_score per edge)\n  const rows = (database.prepare(`","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts","text":"/**\n * FTS5-backed causal edge query. Finds memory IDs via the memory_fts\n * virtual table, then retrieves causal edges connected to those memories.\n * Scores incorporate both edge strength and FTS5 BM25 relevance.\n */\nfunction queryCausalEdgesFTS5(\n  database: Database.Database,\n  query: string,\n  limit: number\n): Array<Record<string, unknown>> {\n  const sanitized = sanitizeFTS5Query(query);\n  if (!sanitized) return [];\n  const oversampleLimit = limit * 3;\n\n  // BM25-inspired weights: title(10) highest signal, content(5), triggers(2), folder(1).\n  // Query shape:\n  // 1) Materialize matched memory rowids once (no OR join against memory_fts)\n  // 2) UNION ALL source-side and target-side edge lookups\n  // 3) Collapse duplicate edge hits in SQL (MAX fts_score per edge)\n  const rows = (database.prepare(`\n    WITH matched_memories AS (\n      SELECT\n        rowid AS memory_id,\n        -bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) AS fts_score\n      FROM memory_fts\n      WHERE memory_fts MATCH ?\n      ORDER BY fts_score DESC\n      LIMIT ?\n    ),\n    edge_hits AS (\n      SELECT ce.id, ce.source_id, ce.target_id, ce.relation, ce.strength, mm.fts_score\n      FROM matched_memories mm\n      JOIN causal_edges ce ON ce.source_id = CAST(mm.memory_id AS TEXT)\n      UNION ALL\n      SELECT ce.id, ce.source_id, ce.target_id, ce.relation, ce.strength, mm.fts_score\n      FROM matched_memories mm\n      JOIN causal_edges ce ON ce.target_id = CAST(mm.memory_id AS TEXT)\n    ),\n    scored_edges AS (\n      SELECT\n        id,\n        source_id,\n        target_id,\n        relation,\n        strength,\n        MAX(fts_score) AS fts_score\n      FROM edge_hits\n      GROUP BY id, source_id, target_id, relation, strength\n    )\n    SELECT id, source_id, target_id, relation, strength, fts_score\n    FROM scored_edges\n    ORDER BY (strength * fts_score) DESC\n    LIMIT ?\n  `) as Database.Statement).all(\n    sanitized,\n    oversampleLimit,\n    oversampleLimit,\n  ) as Array<CausalEdgeRow & { fts_score: number }>;\n\n  // Return one candidate entry per memory node (source_id and target_id) with\n  // Numeric IDs matching memory_index.id (INTEGER column) in the hybrid search\n  // Pipeline (MMR reranking filters with typeof id === 'number').\n  const candidates: Array<Record<string, unknown>> = [];\n  for (const row of rows) {\n    const edgeStrength = typeof row.strength === 'number'\n      ? Math.min(1, Math.max(0, row.strength))\n      : 0;\n    const ftsScore = typeof row.fts_score === 'number' && Number.isFinite(row.fts_score)\n      ? row.fts_score\n      : 0;\n    const score = edgeStrength * ftsScore;\n    const title = `${row.source_id} -> ${row.target_id}`;\n\n    const sourceNum = Number(row.source_id);\n    if (!Number.isNaN(sourceNum)) {","lineStart":150,"lineEnd":224,"totalLines":706,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/graph-search-fn.ts","time":{"start":1781764539459,"end":1781764539465}},"metadata":{"openai":{"itemId":"fc_0d1720205fe8e78f016a3391bb240081918049fcfefbe1dc5b"}