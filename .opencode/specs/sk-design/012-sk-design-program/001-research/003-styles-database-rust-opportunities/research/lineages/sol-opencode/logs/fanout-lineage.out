ster/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-research-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-command-benchmark-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-command-benchmark-auto.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-review-auto.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-agent-improvement-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-research-auto.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-agent-improvement-auto.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-ai-council-auto.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-review-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-alignment-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-ai-council-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-skill-benchmark-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/speckit/assets/speckit-implement-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/speckit/assets/speckit-resume-auto.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/speckit/assets/speckit-plan-confirm.yaml\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/speckit/assets/specki