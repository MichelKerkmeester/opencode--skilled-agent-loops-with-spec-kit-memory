0: function restoreCheckpoint(\n2931:   nameOrId: string | number,\n2932:   clearExisting: boolean = false,\n2933:   scope: ScopeContext = {},\n2934:   opts: RestoreCheckpointV2Options = {},\n2935: ): RestoreResult {\n2936:   const database = getDatabase();\n2937:   const result: RestoreResult = {\n2938:     restored: 0,\n2939:     skipped: 0,\n2940:     errors: [],\n2941:     workingMemoryRestored: 0,\n2942:     partialFailure: false,\n2943:     rolledBackTables: [],\n2944:   };\n2945: \n2946:   let restoreBarrierHeld = false;\n2947:   const governanceAudits: GovernanceAuditEntry[] = [];\n2948:   const tierDowngradeAudits: TierDowngradeAuditParams[] = [];\n2949: \n2950:   try {\n2951:     const checkpoint = getCheckpoint(nameOrId, scope);\n2952:     if (checkpoint?.snapshot_format === 'v2' && checkpoint.snapshot_path) {\n2953:       return restoreCheckpointV2(database, checkpoint, scope, opts);\n2954:     }\n2955: \n2956:     if (!checkpoint || !checkpoint.memory_snapshot) {\n2957:       result.errors.push('Checkpoint not found or empty');\n2958:       return result;\n2959:     }\n2960: \n2961:     // Decompress snapshot\n2962:     const decompressed = zlib.gunzipSync(checkpoint.memory_snapshot);\n2963:     let parsedSnapshot: unknown;\n2964:     try {\n2965:       parsedSnapshot = JSON.parse(decompressed.toString());\n2966:     } catch (parseError: unknown) {\n2967:       const message = parseError instanceof Error ? parseError.message : String(parseError);\n2968:       result.errors.push(`Invalid snapshot JSON: ${message}`);\n2969:       return result;\n2970:     }\n2971: \n2972:     // Validate the snapshot envelope against\n2973:     // CheckpointSnapshotSchema before restore. Failures route into\n2974:     // `result.errors` as a single `Malformed snapshot row N: <reason>`\n2975:     // entry per failing path so callers see exactly which structural\n2976:     // expectation was violated instead of inheriting a runtime cast bug.\n2977:     const snapshotValidation = CheckpointSnapshotSchema.safeParse(parsedSnapshot);\n2978:     if (!snapshotValidation.success) {\n2979:       for (const issue of snapshotValidation.error.issues) {\n2980:         const pathStr = issue.path.length > 0 ? issue.path.join('.') : 'root';\n2981:         result.errors.push(`Malformed snapshot row ${pathStr}: ${issue.message}`);\n2982:       }\n2983:       return result;\n2984:     }\n2985:     const snapshot = snapshotValidation.data as CheckpointSnapshot;\n2986:     const tableSnapshots = getSnapshotTables(snapshot);\n2987:     const memorySnapshot = tableSnapshots.memory_index;\n2988:     const memoryRows = memorySnapshot?.rows ?? snapshot.memories;\n2989: \n2990:     if (!Array.isArray(memoryRows)) {\n2991:       result.errors.push('Invalid snapshot format');\n2992:       return result;\n2993:     }\n2994: \n2995:     const checkpointSpecFolder = checkpoint.spec_folder ?? null;\n2996:     const snapshotMemoryIds = getMemoryIds(memoryRows);\n2997:     const { normalizedScope } = getScopeFilterContext(database, scope);\n2998:     const currentScopedMemoryIds = checkpointSpecFolder\n2999:       ? getCurrentScopedMemoryIds(database, checkpointSpecFolder, normalizedScope)\n3000:       : getCurrentScopedMemoryIds(database, null, normalizedScope);\n3001:     const scopedMemoryIdsToReplace = Array.from(\n3002:       new Set([...currentScopedMemoryIds, ...snapshotMemoryIds])\n3003:     );\n3004:     const edgeIds = getEdgeIds(tableSnapshots.causal_edges?.rows ?? []);\n3005: \n3006:     const memoryRestoreColumns = memoryRows.length > 0\n3007:       ? getMemoryRestoreColumns(database, memoryRows)\n3008:       : [];\n3009:     if (memoryRows.length > 0 && memoryRestoreColumns.length === 0) {\n3010:       result.errors.push('No compatible memory_index columns found for restore');\n3011:       return result;\n3012:     }\n3013: \n3014:     // FIX: Split INSERT strategy by restore mode.\n3015:     // ClearExisting mode: INSERT OR REPLACE is safe (table was already emptied).\n3016:     // Merge mode: INSERT OR REPLACE triggers CASCADE DELETE on working_memory\n3017:     // Via the FOREIGN KEY (memory_id) REFERENCES memory_index(id) ON DELETE CASCADE.\n3018:     // Use INSERT OR IGNORE + explicit UPDATE to avoid the delete-reinsert cycle.\n3019:     const memoryInsertStmt = memoryRestoreColumns.length > 0\n3020:       ? database.prepare(`\n3021:           INSERT OR ${clearExisting ? 'REPLACE' : 'IGNORE'} INTO memory_index (${memoryRestoreColumns.join(', ')})\n3022:           VALUES (${memoryRestoreColumns.map(() => '?').join(', ')})\n3023:         `) as Database.Statement\n3024:       : null;\n3025: \n3026:     const nonIdColumns = memoryRestoreColumns.filter(c => c !== 'id');\n3027:     const memoryUpdateStmt = (!clearExisting && nonIdColumns.length > 0)\n3028:       ? database.prepare(`\n3029:           UPDATE memory_index SET ${nonIdColumns.map(c => `${c} = ?`).join(', ')}\n3030:           WHERE id = ?\n3031:         `) as Database.Statement\n3032:       : null;\n3033: \n3034:     // Ensure working_memory table schema is ready BEFORE the transaction.\n3035:     // DDL (CREATE TABLE, ALTER TABLE) causes SQLite to auto-commit, which would\n3036:     // Corrupt a surrounding transaction. Run DDL outside the transaction boundary.\n3037:     if (tableSnapshots.working_memory) {\n3038:       ensureWorkingMemorySchema(database);\n3039:     }\n3040: \n3041:     acquireRestoreBarrier();\n3042:     restoreBarrierHeld = true;\n3043: \n3044:     // Transaction-wrap checkpoint restore to prevent data loss.\n3045:     // When clearExisting=true, the DELETE and all INSERTs must be atomic.\n3046:     // If any INSERT fails after DELETE, ROLLBACK restores original data.\n3047:     // Previously, individual insert errors were silently swallowed inside\n3048:     // The transaction, allowing COMMIT after DELETE + partial inserts = data loss.\n3049:     const restoreTx = database.transaction(() => {\n3050:       if (memoryRows.length > 0)