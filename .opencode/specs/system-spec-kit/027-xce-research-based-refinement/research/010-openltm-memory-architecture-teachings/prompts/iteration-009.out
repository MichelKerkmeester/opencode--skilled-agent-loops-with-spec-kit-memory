s ADD COLUMN created_by TEXT DEFAULT 'manual'\");\n1048:         logger.info('Migration v18: Added created_by column to causal_edges');\n1049:       } catch (e: unknown) {\n1050:         if (!get_error_message(e).includes('duplicate column')) {\n1051:           console.warn('[VectorIndex] Migration v18 warning (created_by):', get_error_message(e));\n1052:         }\n1053:       }\n1054:       try {\n1055:         database.exec('ALTER TABLE causal_edges ADD COLUMN last_accessed TEXT');\n1056:         logger.info('Migration v18: Added last_accessed column to causal_edges');\n1057:       } catch (e: unknown) {\n1058:         if (!get_error_message(e).includes('duplicate column')) {\n1059:           console.warn('[VectorIndex] Migration v18 warning (last_accessed):', get_error_message(e));\n1060:         }\n1061:       }\n1062: \n1063:       try {\n1064:         database.exec(\"ALTER TABLE memory_index ADD COLUMN encoding_intent TEXT DEFAULT 'document'\");\n1065:         database.exec('CREATE INDEX IF NOT EXISTS idx_encoding_intent ON memory_index(encoding_intent)');\n1066:         logger.info('Migration v18: Added encoding_intent column to memory_index (R16)');\n1067:       } catch (e: unknown) {\n1068:         if (!get_error_message(e).includes('duplicate column')) {\n1069:           console.warn('[VectorIndex] Migration v18 warning (encoding_intent):', get_error_message(e));\n1070:         }\n1071:       }\n1072:     },\n1073: \n1074:     19: () => {\n1075:       try {\n1076:         database.exec(`\n1077:           CREATE TABLE IF NOT EXISTS degree_snapshots (\n1078:             id INTEGER PRIMARY KEY AUTOINCREMENT,\n1079:             memory_id INTEGER NOT NULL,\n1080:             degree_count INTEGER NOT NULL DEFAULT 0,\n1081:             snapshot_date TEXT NOT NULL DEFAULT (date('now')),\n1082:             UNIQUE(memory_id, snapshot_date)\n1083:           )\n1084:         `);\n1085:         database.exec('CREATE INDEX IF NOT EXISTS idx_degree_snapshots_memory ON degree_snapshots(memory_id)');\n1086:         database.exec('CREATE INDEX IF NOT EXISTS idx_degree_snapshots_date ON degree_snapshots(snapshot_date DESC)');\n1087:         logger.info('Migration v19: Created degree_snapshots table (N2a)');\n1088:       } catch (e: unknown) {\n1089:         if (!get_error_message(e).includes('already exists')) {\n1090:           console.warn('[VectorIndex] Migration v19 warning (degree_snapshots):', get_error_message(e));\n1091:         }\n1092:       }\n1093: \n1094:       try {\n1095:         database.exec(`\n1096:           CREATE TABLE IF NOT EXISTS community_assignments (\n1097:             id INTEGER PRIMARY KEY AUTOINCREMENT,\n1098:             memory_id INTEGER NOT NULL UNIQUE,\n1099:             community_id INTEGER NOT NULL,\n1100:             algorithm TEXT NOT NULL DEFAULT 'bfs',\n1101:             computed_at TEXT DEFAULT (datetime('now'))\n1102:           )\n1103:         `);\n1104:         database.exec('CREATE INDEX IF NOT EXISTS idx_community_assignments_community ON community_assignments(community_id)');\n1105:         logger.info('Migration v19: Created community_assignments table (N2c)');\n1106:       } catch (e: unknown) {\n1107:         if (!get_error_message(e).includes('already exists')) {\n1108:           console.warn('[VectorIndex] Migration v19 warning (community_assignments):', get_error_message(e));\n1109:         }\n1110:       }\n1111:     },\n1112: \n1113:     20: () => {\n1114:       try {\n1115:         database.exec(`\n1116:           CREATE TABLE IF NOT EXISTS memory_summaries (\n1117:             id INTEGER PRIMARY KEY AUTOINCREMENT,\n1118:             memory_id INTEGER NOT NULL UNIQUE,\n1119:             summary_text TEXT NOT NULL,\n1120:             summary_embedding BLOB,\n1121:             key_sentences TEXT DEFAULT '[]',\n1122:             created_at TEXT DEFAULT (datetime('now')),\n1123:             updated_at TEXT DEFAULT (datetime('now'))\n1124:           )\n1125:         `);\n1126:        