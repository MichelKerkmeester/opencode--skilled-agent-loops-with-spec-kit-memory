{"type":"tool_use","timestamp":1781761436049,"sessionID":"ses_126bff004ffeidXJpk4781In70","part":{"type":"tool","tool":"grep","callID":"call_iRPAgvKZ2ZaswgUPJY81JfCZ","state":{"status":"completed","input":{"pattern":"limit|tenantId|userId|agentId|includeArchived|scope|embedding|vector|fts|bm25|confidence","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search","include":"*.ts"},"output":"Found 100 matches (more matches available)\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:\n  Line 4: // Combines vector, FTS, and BM25 search with fallback\n\n  Line 13: } from './bm25-index.js';\n\n  Line 19: import { fts5Bm25Search } from './sqlite-fts.js';\n\n  Line 46: } from './confidence-truncation.js';\n\n  Line 69: import { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n\n  Line 80: import type { TruncationResult } from './confidence-truncation.js';\n\n  Line 85:   embedding: Float32Array | number[],\n\n  Line 90:   limit?: number;\n\n  Line 97:   includeArchived?: boolean;\n\n  Line 101:    * When true, preserve the requested top-K window by bypassing confidence\n\n  Line 131:    * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n\n  Line 132:    * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n\n  Line 133:    * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n\n  Line 159:     id: 'includeArchived-default',\n\n  Line 161:     channel: 'vector/fts',\n\n  Line 162:     predicate: 'includeArchived defaults to false',\n\n  Line 167:     id: 'fts-deprecated-tier',\n\n  Line 169:     channel: 'fts',\n\n  Line 175:     id: 'bm25-deprecated-tier',\n\n  Line 177:     channel: 'bm25',\n\n  Line 244:     confidence: string;\n\n  Line 311: /** Default result limit when none is specified by the caller. */\n\n  Line 313: /** Primary vector similarity floor for hybrid fallback passes (percentage units). */\n\n  Line 315: /** Secondary vector similarity floor for adaptive retry passes (percentage units). */\n\n  Line 317: /** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\n\n  Line 339: let vectorSearchFn: VectorSearchFn | null = null;\n\n  Line 401:  * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n\n  Line 403:  * @param vectorFn - Optional vector search function for semantic similarity.\n\n  Line 408:   vectorFn: VectorSearchFn | null = null,\n\n  Line 412:   vectorSearchFn = vectorFn;\n\n  Line 421:  * @param options - Optional limit and specFolder filter.\n\n  Line 422:  * @returns Array of BM25-scored results tagged with source 'bm25'.\n\n  Line 424: function bm25Search(\n\n  Line 426:   options: { limit?: number; specFolder?: string } = {}\n\n  Line 429:     console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n\n  Line 433:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n\n  Line 437:       return ftsSearch(query, {\n\n  Line 438:         limit,\n\n  Line 442:         bm25_score: result.score,\n\n  Line 443:         source: 'bm25',\n\n  Line 450:           'fts',\n\n  Line 451:           'bm25',\n\n  Line 456:     // Spec-folder scope can only be resolved from DB metadata; fail closed before\n\n  Line 460:       console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n\n  Line 467:       : limit;\n\n  Line 477:     // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n\n  Line 478:     // resolution returns [] rather than leaking unscoped BM25 candidates.\n\n  Line 483:           const error = new Error('Database unavailable for spec-folder scope lookup');\n\n  Line 484:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped re