kpoint-tools.ts\ncontext-tools.ts\nindex.ts\nlifecycle-tools.ts\nmemory-tools.ts\ntypes.ts\nENV_REFERENCE.md\nINSTALL_GUIDE.md\nLICENSE\nREADME.md\napi\nbenchmarks\ncli.ts\nconfigs\ncontext-server.ts\ncore\ndata\ndatabase\ndist\neslint.config.mjs\nformatters\nhandlers\nhooks\nlib\nmatrix_runners\nnode_modules\nast-parser.d.ts\nast-parser.d.ts.map\nast-parser.js\nast-parser.js.map\nbackfill-frontmatter.d.ts\nbackfill-frontmatter.d.ts.map\nbackfill-frontmatter.js\nbackfill-frontmatter.js.map\nbackfill-research-metadata.d.ts\nbackfill-research-metadata.d.ts.map\nbackfill-research-metadata.js\nbackfill-research-metadata.js.map\ncleanup-index-scope-violations.d.ts\ncleanup-index-scope-violations.d.ts.map\ncleanup-index-scope-violations.js\ncleanup-index-scope-violations.js.map\ncleanup-orphaned-vectors.d.ts\ncleanup-orphaned-vectors.d.ts.map\ncleanup-orphaned-vectors.js\ncleanup-orphaned-vectors.js.map\ngenerate-context.d.ts\ngenerate-context.d.ts.map\ngenerate-context.js\ngenerate-context.js.map\nmigrate-trigger-phrase-residual.d.ts\nmigrate-trigger-phrase-residual.d.ts.map\nmigrate-trigger-phrase-residual.js\nmigrate-trigger-phrase-residual.js.map\nrank-memories.d.ts\nrank-memories.d.ts.map\n","exit":0,"description":"List MCP server and CLI scripts","truncated":false},"title":"List MCP server and CLI scripts","time":{"start":1780736014339,"end":1780736014340}},"id":"prt_e9c2330090016aKnPjP5noYiAS","sessionID":"ses_163de1863ffeLd3K58IkmWaFwL","messageID":"msg_e9c2311a6001D5d2vdgoNAde3u"}}
