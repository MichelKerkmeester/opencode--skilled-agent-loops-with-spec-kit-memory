{"type":"tool_use","timestamp":1780738241654,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_UaSc8NwvWdCrczMPaHfFrMGF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","offset":450,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts</path>\n<type>file</type>\n<content>\n450:  * whole upgrade batch rolls back and the schema wedges. To advance safely we retire the\n451:  * duplicates first — deprecate, never delete — by setting the losers' importance_tier to\n452:  * 'deprecated' (the same retirement the runtime reindex guard uses), which removes them\n453:  * from the partial index predicate so the UNIQUE index can be built. Within each duplicate\n454:  * group the winner is the highest importance tier, then the most recently updated row.\n455:  *\n456:  * Grouping mirrors the index exactly. Tolerant when a scope/anchor column is absent on an\n457:  * older schema (the group key falls back to the empty string for the missing column, the\n458:  * same as the index's COALESCE), and a no-op when the table or needed columns are missing.\n459:  */\n460: function deprecateDuplicateActiveLogicalKeysBeforeUniqueIndex(database: Database.Database): void {\n461:   if (!hasTable(database, 'memory_index')) {\n462:     return;\n463:   }\n464: \n465:   const columns = new Set(getTableColumns(database, 'memory_index'));\n466:   // canonical_file_path / file_path and importance_tier are required to form the key and\n467:   // pick a winner; without them this DB predates the guarded schema and there is nothing\n468:   // to reconcile here.\n469:   if (!columns.has('importance_tier') || (!columns.has('canonical_file_path') && !columns.has('file_path'))) {\n470:     return;\n471:   }\n472: \n473:   // Build per-column key fragments that match the index's COALESCE expressions, degrading\n474:   // to a literal '' for columns this older schema does not have (so the key shape is stable).\n475:   const pathExpr = columns.has('canonical_file_path')\n476:     ? \"COALESCE(NULLIF(canonical_file_path, ''), file_path)\"\n477:     : 'file_path';\n478:   const anchorExpr = columns.has('anchor_id')\n479:     ? \"COALESCE(NULLIF(TRIM(anchor_id), ''), '_')\"\n480:     : \"'_'\";\n481:   const scopeExpr = (col: string): string => (columns.has(col) ? `COALESCE(${col}, '')` : \"''\");\n482: \n483:   const keyExpr = [\n484:     'spec_folder',\n485:     pathExpr,\n486:     anchorExpr,\n487:     scopeExpr('tenant_id'),\n488:     scopeExpr('user_id'),\n489:     scopeExpr('agent_id'),\n490:     scopeExpr('session_id'),\n491:   ].join(\" || '\\\\u0000' || \");\n492: \n493:   // Active = the same predicate the unique index uses (excludes constitutional + deprecated).\n494:   const activePredicate = \"COALESCE(importance_tier, 'normal') NOT IN ('constitutional', 'deprecated')\";\n495: \n496:   // Tier rank mirrors IMPORTANCE_TIERS values so the highest-priority active row wins.\n497:   const tierRankExpr = `CASE COALESCE(importance_tier, 'normal')\n498:         WHEN 'critical' THEN 5\n499:         WHEN 'important' THEN 4\n500:         WHEN 'normal' THEN 3\n501:         WHEN 'temporary' THEN 2\n502:         ELSE 1\n503:       END`;\n504: \n505:   // Find groups with more than one active row, then deprecate every row except the winner\n506:   // (highest tier rank, then most recently updated, then highest id as a stable tiebreak).\n507:   const retireStmt = database.prepare(`\n508:     UPDATE memory_index\n509:     SET importance_tier = 'deprecated',\n510:         updated_at = datetime('now')\n511:     WHERE id IN (\n512:       SELECT id FROM (\n513:         SELECT id,\n514:                (${keyExpr}) AS logical_key,\n515:                ROW_NUMBER() OVER (\n516:                  PARTITION BY (${keyExpr})\n517:                  ORDER BY ${tierRankExpr} DESC, updated_at DESC, id DESC\n518:                ) AS rn\n519:         FROM memory_index\n520:         WHERE ${activePredicate}\n521:       )\n522:       WHERE rn > 1\n523:     )\n524:   `);\n525: \n526:   const result = retireStmt.run() as { changes: number };\n527:   if (result.changes > 0) {\n528:     logger.warn(\n529:       `Migration v28: deprecated ${result.changes} duplicate active row(s) before building idx_memory_logical_key_active_unique`,\n530:     );\n531:   }\n532: }\n533: \n534: // Run schema migrations from one version to another\n535: // Each migration is idempotent - safe to run multiple times\n536: // BUG-019 FIX: Wrap migrations in transaction for atomicity\n537: /**\n538:  * Runs schema migrations between two schema versions.\n539:  * @param database - The database connection to migrate.\n540:  * @param from_version - The current schema version.\n541:  * @param to_version - The target schema version.\n542:  * @returns Nothing.\n543:  */\n544: export function run_migrations(database: Database.Database, from_version: number, to_version: number): void {\n545:   const migrations: Record<number, () => void> = {\n546:     1: () => {\n547:       // V0 -> v1: Initial schema (already exists via create_schema)\n548:     },\n549:     2: () => {\n550:       // V1 -> v2: Add idx_history_timestamp index\n551:       try {\n552:         database.exec('CREATE INDEX IF NOT EXISTS idx_history_timestamp ON memory_history(timestamp DESC)');\n553:         logger.info('Migration v2: Created idx_history_timestamp index');\n554:       } catch (e: unknown) {\n555:         if (!get_error_message(e).includes('already exists')) {\n556:           console.warn('[VectorIndex] Migration v2 warning:', get_error_message(e));\n557:         }\n558:       }\n559:     },\n560:     3: () => {\n561:       // V2 -> v3: Add related_memories column\n562:       try {\n563:         database.exec('ALTER TABLE memory_index ADD COLUMN related_memories TEXT');\n564:         logger.info('Migration v3: Added related_memories column');\n565:       } catch (e: unknown) {\n566:         if (!get_error_message(e).includes('duplicate column')) {\n567:           console.warn('[VectorIndex] Migration v3 warning:', get_error_message(e));\n568:         }\n569:       }\n570:     },\n571:     4: () => {\n572:       // V3 -> v4: Add FSRS (Free Spaced Repetition Scheduler) columns for cognitive memory\n573:       // These columns enable spaced repetition-based memory retrieval prioritization\n574:       const fsrs_columns = [\n575:         { name: 'stability', sql: 'ALTER TABLE memory_index ADD COLUMN stability REAL DEFAULT 1.0' },\n576:         { name: 'difficulty', sql: 'ALTER TABLE memory_index ADD COLUMN difficulty REAL DEFAULT 5.0' },\n577:         { name: 'last_review', sql: 'ALTER TABLE memory_index ADD COLUMN last_review TEXT' },\n578:         { name: 'review_count', sql: 'ALTER TABLE memory_index ADD COLUMN review_count INTEGER DEFAULT 0' }\n579:       ];\n\n(Showing lines 450-579 of 2784. Use offset=580 to continue.)\n</content>","metadata":{"preview":" * whole upgrade batch rolls back and the schema wedges. To advance safely we retire the\n * duplicates first — deprecate, never delete — by setting the losers' importance_tier to\n * 'deprecated' (the same retirement the runtime reindex guard uses), which removes them\n * from the partial index predicate so the UNIQUE index can be built. Within each duplicate\n * group the winner is the highest importance tier, then the most recently updated row.\n *\n * Grouping mirrors the index exactly. Tolerant when a scope/anchor column is absent on an\n * older schema (the group key falls back to the empty string for the missing column, the\n * same as the index's COALESCE), and a no-op when the table or needed columns are missing.\n */\nfunction deprecateDuplicateActiveLogicalKeysBeforeUniqueIndex(database: Database.Database): void {\n  if (!hasTable(database, 'memory_index')) {\n    return;\n  }\n\n  const columns = new Set(getTableColumns(database, 'memory_index'));\n  // canonical_file_path / file_path and importance_tier are required to form the key and\n  // pick a winner; without them this DB predates the guarded schema and there is nothing\n  // to reconcile here.\n  if (!columns.has('importance_tier') || (!columns.has('canonical_file_path') && !columns.has('file_path'))) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","text":" * whole upgrade batch rolls back and the schema wedges. To advance safely we retire the\n * duplicates first — deprecate, never delete — by setting the losers' importance_tier to\n * 'deprecated' (the same retirement the runtime reindex guard uses), which removes them\n * from the partial index predicate so the UNIQUE index can be built. Within each duplicate\n * group the winner is the highest importance tier, then the most recently updated row.\n *\n * Grouping mirrors the index exactly. Tolerant when a scope/anchor column is absent on an\n * older schema (the group key falls back to the empty string for the missing column, the\n * same as the index's COALESCE), and a no-op when the table or needed columns are missing.\n */\nfunction deprecateDuplicateActiveLogicalKeysBeforeUniqueIndex(database: Database.Database): void {\n  if (!hasTable(database, 'memory_index')) {\n    return;\n  }\n\n  const columns = new Set(getTableColumns(database, 'memory_index'));\n  // canonical_file_path / file_path and importance_tier are required to form the key and\n  // pick a winner; without them this DB predates the guarded schema and there is nothing\n  // to reconcile here.\n  if (!columns.has('importance_tier') || (!columns.has('canonical_file_path') && !columns.has('file_path'))) {\n    return;\n  }\n\n  // Build per-column key fragments that match the index's COALESCE expressions, degrading\n  // to a literal '' for columns this older schema does not have (so the key shape is stable).\n  const pathExpr = columns.has('canonical_file_path')\n    ? \"COALESCE(NULLIF(canonical_file_path, ''), file_path)\"\n    : 'file_path';\n  const anchorExpr = columns.has('anchor_id')\n    ? \"COALESCE(NULLIF(TRIM(anchor_id), ''), '_')\"\n    : \"'_'\";\n  const scopeExpr = (col: string): string => (columns.has(col) ? `COALESCE(${col}, '')` : \"''\");\n\n  const keyExpr = [\n    'spec_folder',\n    pathExpr,\n    anchorExpr,\n    scopeExpr('tenant_id'),\n    scopeExpr('user_id'),\n    scopeExpr('agent_id'),\n    scopeExpr('session_id'),\n  ].join(\" || '\\\\u0000' || \");\n\n  // Active = the same predicate the unique index uses (excludes constitutional + deprecated).\n  const activePredicate = \"COALESCE(importance_tier, 'normal') NOT IN ('constitutional', 'deprecated')\";\n\n  // Tier rank mirrors IMPORTANCE_TIERS values so the highest-priority active row wins.\n  const tierRankExpr = `CASE COALESCE(importance_tier, 'normal')\n        WHEN 'critical' THEN 5\n        WHEN 'important' THEN 4\n        WHEN 'normal' THEN 3\n        WHEN 'temporary' THEN 2\n        ELSE 1\n      END`;\n\n  // Find groups with more than one active row, then deprecate every row except the winner\n  // (highest tier rank, then most recently updated, then highest id as a stable tiebreak).\n  const retireStmt = database.prepare(`\n    UPDATE memory_index\n    SET importance_tier = 'deprecated',\n        updated_at = datetime('now')\n    WHERE id IN (\n      SELECT id FROM (\n        SELECT id,\n               (${keyExpr}) AS logical_key,\n               ROW_NUMBER() OVER (\n                 PARTITION BY (${keyExpr})\n                 ORDER BY ${tierRankExpr} DESC, updated_at DESC, id DESC\n               ) AS rn\n        FROM memory_index\n        WHERE ${activePredicate}\n      )\n      WHERE rn > 1\n    )\n  `);\n\n  const result = retireStmt.run() as { changes: number };\n  if (result.changes > 0) {\n    logger.warn(\n      `Migration v28: deprecated ${result.changes} duplicate active row(s) before building idx_memory_logical_key_active_unique`,\n    );\n  }\n}\n\n// Run schema migrations from one version to another\n// Each migration is idempotent - safe to run multiple times\n// BUG-019 FIX: Wrap migrations in transaction for atomicity\n/**\n * Runs schema migrations between two schema versions.\n * @param database - The database connection to migrate.\n * @param from_version - The current schema version.\n * @param to_version - The target schema version.\n * @returns Nothing.\n */\nexport function run_migrations(database: Database.Database, from_version: number, to_version: number): void {\n  const migrations: Record<number, () => void> = {\n    1: () => {\n      // V0 -> v1: Initial schema (already exists via create_schema)\n    },\n    2: () => {\n      // V1 -> v2: Add idx_history_timestamp index\n      try {\n        database.exec('CREATE INDEX IF NOT EXISTS idx_history_timestamp ON memory_history(timestamp DESC)');\n        logger.info('Migration v2: Created idx_history_timestamp index');\n      } catch (e: unknown) {\n        if (!get_error_message(e).includes('already exists')) {\n          console.warn('[VectorIndex] Migration v2 warning:', get_error_message(e));\n        }\n      }\n    },\n    3: () => {\n      // V2 -> v3: Add related_memories column\n      try {\n        database.exec('ALTER TABLE memory_index ADD COLUMN related_memories TEXT');\n        logger.info('Migration v3: Added related_memories column');\n      } catch (e: unknown) {\n        if (!get_error_message(e).includes('duplicate column')) {\n          console.warn('[VectorIndex] Migration v3 warning:', get_error_message(e));\n        }\n      }\n    },\n    4: () => {\n      // V3 -> v4: Add FSRS (Free Spaced Repetition Scheduler) columns for cognitive memory\n      // These columns enable spaced repetition-based memory retrieval prioritization\n      const fsrs_columns = [\n        { name: 'stability', sql: 'ALTER TABLE memory_index ADD COLUMN stability REAL DEFAULT 1.0' },\n        { name: 'difficulty', sql: 'ALTER TABLE memory_index ADD COLUMN difficulty REAL DEFAULT 5.0' },\n        { name: 'last_review', sql: 'ALTER TABLE memory_index ADD COLUMN last_review TEXT' },\n        { name: 'review_count', sql: 'ALTER TABLE memory_index ADD COLUMN review_count INTEGER DEFAULT 0' }\n      ];","lineStart":450,"lineEnd":579,"totalLines":2784,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","time":{"start":1780738241648,"end":1780738241653}},"metadata":{"openai":{"itemId":"fc_02c54eb278c2def9016a23e8c19c9c81919f063fba1c79d8df"}},"id":"prt_e9c45346c001ybKgqHFMUscxYK","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c45101a001IFKvp8Hf3MsQNL"}}
