rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }\n\n  if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    runScanInvalidationHooks({\n      indexed: results.indexed,\n      updated: results.updated,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n        ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n        : {}),\n      ...(results.postInsertEnrichmentRepaired > 0\n        ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n        : {}),\n      ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n        ? {\n            orphanSwept: results.orphanSwept,\n            orphanSweepFailed: results.orphanSweepFailed,\n          }\n        : {}),\n    }, scanAppliedActions);\n  }\n\n  runScanHygieneSubscribers(scanAppliedActions);\n\n  const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n\n  const hints: string[] = [];\n  if (results.failed > 0) {\n    hints.push(`${results.failed} files failed to index - check file format`);\n  }\n  if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n    hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n  }\n  if (results.staleDeleted > 0) {\n    hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n  }\n  if (results.staleDeleteFailed > 0) {\n    hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n  }\n  if (results.orphanSwept > 0) {\n    hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n  }\n  if (results.postInsertEnrichmentRepaired > 0) {\n    hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n  }\n  if (results.nearDuplicateRepaired > 0) {\n    hints.push(`Repaired ${results.nearDuplicateRepaired} near-duplicate marker(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.readyRows) {\n    hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.failedRows) {\n    hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n  }\n  if (results.orphanSweepFailed > 0) {\n    hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n  }\n  if (results.dedup.duplicatesSkipped > 0) {\n    hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n  }\n  if (results.aliasConflicts.groups > 0) {\n    hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n  }\n  if (results.aliasConflicts.divergentHashGroups > 0) {\n    hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n  }\n  if (results.divergenceReconcile.retriesScheduled > 0) {\n    hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n  }\n  if (results.divergenceReconcile.escalated > 0) {\n    hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n  }\n  if (results.divergenceReconcile.errors.length > 0) {\n    hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n  }\n  if (results.checkpointRepair.cleared) {\n    hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n  }\n  if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n    hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n  }\n  if (results.checkpointRepair.error) {\n    hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n  }\n  if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n    hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n  }\n  if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n    hints.push('All files already up-to-date. Use force: true to re-index');\n  }\n\n  await releaseScanLease();\n\n  recordMaintenanceRun('memory_index_scan', {\n    status: 'success',\n    counts: {\n      scanned: results.scanned,\n      indexed: results.indexed,\n      updated: results.updated,\n      unchanged: results.unchanged,\n      failed: results.failed,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      orphanSwept: results.orphanSwept,\n    },\n    staleCandidates: filesToDelete.length,\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})\n    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_index_scan = handleMemoryIndexScan;\nconst index_single_file = indexSingleFile;\nconst find_constitutional_files = findConstitutionalFiles;\nconst find_spec_documents = findSpecDocuments;\nconst detect_spec_level = detectSpecLevel;\nconst summarize_alias_conflicts = summarizeAliasConflicts;\nconst run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n\nexport {\n  handle_memory_index_scan,\n  index_single_file,\n  find_constitutional_files,\n  find_spec_documents,\n  detect_spec_level,\n  summarize_alias_conflicts,\n  run_divergence_reconcile_hooks,\n};","lineStart":1316,"lineEnd":1598,"totalLines":1598,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781763537016,"end":1781763537029}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e91c81919a8e80ba5c79135c"}},"id":"prt_ed961f84e001VejuWmtSrJw0X6","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537033,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_jLpHfzWkJCiBNtaneyW6M4Ug","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see — aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n341: \n342: function appendRetentionLedger(\n343:   database: Database.Database,\n344:   deletedIds: number[],\n345:   candidates: RetentionExpiredRow[],\n346: ): boolean {\n347:   try {\n348:     mutationLedger.initLedger(database);\n349:     mutationLedger.appendEntry(database, {\n350:       mutation_type: 'delete',\n351:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n352:       prior_hash: null,\n353:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n354:       linked_memory_ids: deletedIds.slice(0, 50),\n355:       decision_meta: {\n356:         tool: 'memory_retention_sweep',\n357:         reason: 'retention_expired',\n358:         totalDeleted: deletedIds.length,\n359:         originalDeleteAfter: candidates\n360:           .filter((candidate) => deletedIds.includes(candidate.id))\n361:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n362:       },\n363:       actor: 'mcp:memory_retention_sweep',\n364:     });\n365:     return true;\n366:   } catch (error: unknown) {\n367:     const message = error instanceof Error ? error.message : String(error);\n368:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n369:     return false;\n370:   }\n371: }\n372: \n373: function runPostDeleteMaintenance(database: Database.Database): void {\n374:   try {\n375:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n376:   } catch (error: unknown) {\n377:     const message = error instanceof Error ? error.message : String(error);\n378:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n379:   }\n380: \n381:   const maintenance = new BetterSqliteMaintenance(database, {\n382:     onMaintenanceError: reportRetentionMaintenanceError,\n383:   });\n384:   maintenance.vacuum();\n385:   maintenance.checkpoint({ mode: 'truncate' });\n386: }\n387: \n388: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n389:   const message = error instanceof Error ? error.message : String(error);\n390:   if (operation === 'auto_vacuum') {\n391:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n392:   } else if (operation === 'incremental_vacuum') {\n393:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n394:   } else if (operation === 'wal_checkpoint') {\n395:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n396:   }\n397: }\n398: \n399: /**\n400:  * Sweep expired governed memory rows.\n401:  *\n402:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n403:  * to enforce the ISO timestamps persisted by governed ingest.\n404:  */\n405: export function runMemoryRetentionSweep(\n406:   database: Database.Database,\n407:   args: MemoryRetentionSweepArgs = {},\n408: ): MemoryRetentionSweepResult {\n409:   const startTime = Date.now();\n410:   const dryRun = args.dryRun === true;\n411:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n412: \n413:   if (!hasTable(database, 'memory_index')) {\n414:     return {\n415:       swept: 0,\n416:       retained: 0,\n417:       protectedCount: 0,\n418:       dryRun,\n419:       durationMs: Date.now() - startTime,\n420:       candidates: [],\n421:       deletedIds: [],\n422:       protectedIds: [],\n423:       ledgerRecorded: null,\n424:       tombstoneState: {\n425:         usesPurgeablePartition: false,\n426:         usingPurgeableIndex: false,\n427:         candidateCount: 0,\n428:         deletedCount: 0,\n429:       },\n430:       edgeState: {\n431:         causalEdgesTablePresent: false,\n432:         candidateEdgeCount: 0,\n433:       },\n434:     };\n435:   }\n436: \n437:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n438:   const initialEdgeState = buildEdgeState(database, candidates);\n439:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n440:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n441:     : null;\n442: \n443:   if (dryRun || candidates.length === 0) {\n444:     const totalRows = countRows(database);\n445:     const dryRunProtectedIds = candidates\n446:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n447:       .map((candidate) => candidate.id);\n448:     return {\n449:       swept: 0,\n450:       retained: totalRows,\n451:       protectedCount: dryRunProtectedIds.length,\n452:       dryRun,\n453:       durationMs: Date.now() - startTime,\n454:       candidates,\n455:       deletedIds: [],\n456:       protectedIds: dryRunProtectedIds,\n457:       ledgerRecorded: null,\n458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n459:       edgeState: initialEdgeState,\n460:       ...(feedbackRetention ? { feedbackRetention } : {}),\n461:     };\n462:   }\n463: \n464:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n465:     const auditTx = database.transaction(() => {\n466:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n467:         database,\n468:         candidates,\n469:         feedbackRetention,\n470:         false,\n471:       );\n472:     });\n473:     auditTx();\n474: \n475:     return {\n476:       swept: 0,\n477:       retained: countRows(database),\n478:       protectedCount: feedbackRetention.protectedIds.length,\n479:       dryRun,\n480:       durationMs: Date.now() - startTime,\n481:       candidates,\n482:       deletedIds: [],\n483:       protectedIds: feedbackRetention.protectedIds,\n484:       extendedIds: [],\n485:       ledgerRecorded: null,\n486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n487:       edgeState: initialEdgeState,\n488:       feedbackRetention,\n489:     };\n490:   }\n491: \n492:   initHistory(database);\n493: \n494:   const deletedIds: number[] = [];\n495:   const protectedIds: number[] = [];\n496:   const extendedIds: number[] = [];\n497:   let ledgerRecorded: boolean | null = null;\n498: \n499:   const sweepTx = database.transaction(() => {\n500:     for (const candidate of candidates) {\n501:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n502:       const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n503:       if (!currentCandidate) {\n504:         continue;\n505:       }\n506:       let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n507:       if (feedbackRetention) {\n508:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n509:         if (!decision) {\n510:           continue;\n511:         }\n512: \n513:         if (decision.decision === 'protect') {\n514:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n515:           protectedIds.push(candidate.id);\n516:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n517:             mode: feedbackRetention.mode,\n518:             applied: true,\n519:             activeGatePassed: feedbackRetention.activeGatePassed,\n520:           });\n521:           feedbackRetention.auditCount += 1;\n522:           continue;\n523:         }\n524: \n525:         if (decision.decision === 'extend') {\n526:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n527:             decision.nextDeleteAfter,\n528:             candidate.id,\n529:           );\n530:           extendedIds.push(candidate.id);\n531:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n532:             mode: feedbackRetention.mode,\n533:             applied: true,\n534:             activeGatePassed: feedbackRetention.activeGatePassed,\n535:           });\n536:           feedbackRetention.auditCount += 1;\n537:           continue;\n538:         }\n539:         feedbackDeleteDecision = decision;\n540:       }\n541:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n542:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n543:       if (isProtectedFromRetentionDelete(currentCandidate)) {\n544:         if (feedbackRetention && feedbackDeleteDecision) {\n545:           recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n546:             mode: feedbackRetention.mode,\n547:             applied: false,\n548:             activeGatePassed: feedbackRetention.activeGatePassed,\n549:           });\n550:           feedbackRetention.auditCount += 1;\n551:         }\n552:         protectedIds.push(currentCandidate.id);\n553:         recordGovernanceAudit(database, {\n554:           action: 'retention_sweep',\n555:           decision: 'deny',\n556:           memoryId: currentCandidate.id,\n557:           logicalKey: currentCandidate.filePath,\n558:           tenantId: currentCandidate.tenantId ?? undefined,\n559:           userId: currentCandidate.userId ?? undefined,\n560:           agentId: currentCandidate.agentId ?? undefined,\n561:           sessionId: currentCandidate.sessionId ?? undefined,\n562:           reason: 'retention_tier_protected',\n563:           metadata: {\n564:             originalDeleteAfter: currentCandidate.deleteAfter,\n565:             importanceTier: currentCandidate.importanceTier,\n566:             isPinned: currentCandidate.isPinned,\n567:             specFolder: currentCandidate.specFolder,\n568:             filePath: currentCandidate.filePath,\n569:           },\n570:         });\n571:         continue;\n572:       }\n573:       if (feedbackRetention && feedbackDeleteDecision) {\n574:         recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n575:           mode: feedbackRetention.mode,\n576:           applied: true,\n577:           activeGatePassed: feedbackRetention.activeGatePassed,\n578:         });\n579:         feedbackRetention.auditCount += 1;\n580:       }\n581:       const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n582:       if (!deleted) {\n583:         continue;\n584:       }\n585: \n586:       deletedIds.push(currentCandidate.id);\n587: \n588:       recordHistory(\n589:         currentCandidate.id,\n590:         'DELETE',\n591:         {\n592:           reason: 'retention_expired',\n593:           deleteAfter: currentCandidate.deleteAfter,\n594:           filePath: currentCandidate.filePath,\n595:         },\n596:         null,\n597:         'mcp:memory_retention_sweep',\n598:         currentCandidate.specFolder,\n599:       );\n600: \n601:       recordGovernanceAudit(database, {\n602:         action: 'retention_sweep',\n603:         decision: 'delete',\n604:         memoryId: currentCandidate.id,\n605:         logicalKey: currentCandidate.filePath,\n606:         tenantId: currentCandidate.tenantId ?? undefined,\n607:         userId: currentCandidate.userId ?? undefined,\n608:         agentId: currentCandidate.agentId ?? undefined,\n609:         sessionId: currentCandidate.sessionId ?? undefined,\n610:         reason: 'retention_expired',\n611:         metadata: {\n612:           originalDeleteAfter: currentCandidate.deleteAfter,\n613:           delete_after: currentCandidate.deleteAfter,\n614:           specFolder: currentCandidate.specFolder,\n615:           filePath: currentCandidate.filePath,\n616:         },\n617:       });\n618:     }\n619: \n620:     if (deletedIds.length > 0) {\n621:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n622:     }\n623:   });\n624: \n625:   sweepTx();\n626:   if (deletedIds.length > 0) {\n627:     runPostDeleteMaintenance(database);\n628:   }\n629:   if (feedbackRetention) {\n630:     feedbackRetention.extendedIds = extendedIds;\n631:     feedbackRetention.protectedIds = protectedIds;\n632:     feedbackRetention.deletedIds = deletedIds;\n633:   }\n634: \n635:   return {\n636:     swept: deletedIds.length,\n637:     retained: countRows(database),\n638:     protectedCount: protectedIds.length,\n639:     dryRun,\n640:     durationMs: Date.now() - startTime,\n641:     candidates,\n642:     deletedIds,\n643:     protectedIds,\n644:     ledgerRecorded,\n645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n646:     edgeState: initialEdgeState,\n647:     ...(feedbackRetention ? { extendedIds } : {}),\n648:     ...(feedbackRetention ? { feedbackRetention } : {}),\n649:   };\n650: }\n\n(End of file - total 650 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see — aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n      if (!currentCandidate) {\n        continue;\n      }\n      let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n        feedbackDeleteDecision = decision;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(currentCandidate)) {\n        if (feedbackRetention && feedbackDeleteDecision) {\n          recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n            mode: feedbackRetention.mode,\n            applied: false,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n        }\n        protectedIds.push(currentCandidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: currentCandidate.id,\n          logicalKey: currentCandidate.filePath,\n          tenantId: currentCandidate.tenantId ?? undefined,\n          userId: currentCandidate.userId ?? undefined,\n          agentId: currentCandidate.agentId ?? undefined,\n          sessionId: currentCandidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: currentCandidate.deleteAfter,\n            importanceTier: currentCandidate.importanceTier,\n            isPinned: currentCandidate.isPinned,\n            specFolder: currentCandidate.specFolder,\n            filePath: currentCandidate.filePath,\n          },\n        });\n        continue;\n      }\n      if (feedbackRetention && feedbackDeleteDecision) {\n        recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(currentCandidate.id);\n\n      recordHistory(\n        currentCandidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: currentCandidate.deleteAfter,\n          filePath: currentCandidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        currentCandidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: currentCandidate.id,\n        logicalKey: currentCandidate.filePath,\n        tenantId: currentCandidate.tenantId ?? undefined,\n        userId: currentCandidate.userId ?? undefined,\n        agentId: currentCandidate.agentId ?? undefined,\n        sessionId: currentCandidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: currentCandidate.deleteAfter,\n          delete_after: currentCandidate.deleteAfter,\n          specFolder: currentCandidate.specFolder,\n          filePath: currentCandidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),\n    ...(feedbackRetention ? { feedbackRetention } : {}),\n  };\n}","lineStart":1,"lineEnd":650,"totalLines":650,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781763537025,"end":1781763537031}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e92c8191bfb54d842152e10a"}},"id":"prt_ed961f87a0015sxMAUesUwpTJN","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537058,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_pCzqwJPRXa4n5efy775lt4dE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n261:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n262:           mutationType: 'delete',\n263:           reason: 'memory_delete: bulk delete by spec folder',\n264:           priorHash: snapshot?.content_hash ?? null,\n265:           newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n266:           linkedMemoryIds: [deletedId],\n267:           decisionMeta: {\n268:             tool: 'memory_delete',\n269:             bulk: true,\n270:             specFolder,\n271:             checkpoint: checkpointName,\n272:             memoryId: deletedId,\n273:             filePath: snapshot?.file_path ?? null,\n274:           },\n275:           actor: 'mcp:memory_delete',\n276:         });\n277:         if (!ledgerRecorded) {\n278:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n279:         }\n280:       }\n281:     });\n282:     bulkDeleteTx();\n283:   }\n284: \n285:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n286:   if (deletedCount > 0) {\n287:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n288:     try {\n289:       postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n290:     } catch (hookError: unknown) {\n291:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n292:       postMutationHooks = {\n293:         latencyMs: 0, triggerCacheCleared: false,\n294:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n295:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n296:         errors: [msg],\n297:       };\n298:     }\n299:     postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n300:   }\n301: \n302:   const summary = deletedCount > 0\n303:     ? `Deleted ${deletedCount} memory(s)`\n304:     : 'No spec-doc records found to delete';\n305: \n306:   const hints: string[] = [];\n307:   if (checkpointName) {\n308:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n309:   }\n310:   if (deletedCount === 0) {\n311:     hints.push('Use memory_list() to find existing memories');\n312:   }\n313:   if (postMutationFeedback) {\n314:     hints.push(...postMutationFeedback.hints);\n315:   }\n316:   if (mutationLedgerWarning) {\n317:     hints.push(mutationLedgerWarning);\n318:   }\n319: \n320:   const data: Record<string, unknown> = { deleted: deletedCount };\n321:   if (checkpointName) {\n322:     data.checkpoint = checkpointName;\n323:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n324:   }\n325:   if (postMutationFeedback) {\n326:     data.postMutationHooks = postMutationFeedback.data;\n327:   }\n328:   if (mutationLedgerWarning) {\n329:     data.warning = mutationLedgerWarning;\n330:   }\n331: \n332:   return createMCPSuccessResponse({\n333:     tool: 'memory_delete',\n334:     summary,\n335:     data,\n336:     hints,\n337:   });\n338: }\n339: \n340: /* ───────────────────────────────────────────────────────────────\n341:    EXPORTS\n342: ──────────────────────────────────────────────────────────────── */\n343: \n344: export { handleMemoryDelete };\n\n(End of file - total 344 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: bulk delete by spec folder',\n          priorHash: snapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n          linkedMemoryIds: [deletedId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: true,\n            specFolder,\n            checkpoint: checkpointName,\n            memoryId: deletedId,\n            filePath: snapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    });\n    bulkDeleteTx();\n  }\n\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n  }\n\n  const summary = deletedCount > 0\n    ? `Deleted ${deletedCount} memory(s)`\n    : 'No spec-doc records found to delete';\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  }\n  if (deletedCount === 0) {\n    hints.push('Use memory_list() to find existing memories');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n\n  const data: Record<string, unknown> = { deleted: deletedCount };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (mutationLedgerWarning) {\n    data.warning = mutationLedgerWarning;\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryDelete };","lineStart":1,"lineEnd":344,"totalLines":344,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781763537045,"end":1781763537055}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e9348191ba5c9f9be78c0753"}},"id":"prt_ed961f88c001kcaBPt1KPooFvC","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537058,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_24yXPhK5y6Ohh6KhREqJaT5U","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Update Handler\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { randomUUID } from 'node:crypto';\n10: import { checkDatabaseUpdated } from '../core/index.js';\n11: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n12: import * as vectorIndex from '../lib/search/vector-index.js';\n13: import type { UpdateMemoryParams } from '../lib/search/vector-index.js';\n14: import * as embeddings from '../lib/providers/embeddings.js';\n15: import * as bm25Index from '../lib/search/bm25-index.js';\n16: import { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\n17: import { MemoryError, ErrorCodes } from '../lib/errors.js';\n18: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n19: import { runInTransaction } from '../lib/storage/transaction-manager.js';\n20: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n21: import {\n22:   buildGovernanceLogicalKey,\n23:   recordTierDowngradeAudit,\n24: } from '../lib/governance/scope-governance.js';\n25: import { isConstitutionalPath } from '../lib/utils/index-scope.js';\n26: import { scrubSecrets, SecretScrubberError } from '../lib/parsing/secret-scrubber.js';\n27: import { toErrorMessage } from '../utils/index.js';\n28: import {\n29:   deleteIdempotencyReceiptByKey,\n30:   extractMemoryIdFromResponse,\n31:   isMemoryIdempotencyEnabled,\n32:   lookupIdempotencyReceipt,\n33:   lookupIdempotencyReceiptByKey,\n34:   markResponseWithReceiptStoreConflict,\n35:   storeIdempotencyReceipt,\n36:   type IdempotencyReceiptKey,\n37: } from '../lib/storage/idempotency-receipts.js';\n38: \n39: import { recordHistory } from '../lib/storage/history.js';\n40: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n41: import { runPostMutationHooks } from './mutation-hooks.js';\n42: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n43: import {\n44:   deriveSourceKindFromContext,\n45:   normalizeSourceKind,\n46:   persistProvenanceMetadata,\n47:   persistSourceKind,\n48:   type SourceKind,\n49: } from '../lib/storage/write-provenance.js';\n50: \n51: import type { MCPResponse } from './types.js';\n52: import type { UpdateArgs } from './memory-crud-types.js';\n53: \n54: // Feature catalog: Memory metadata update (memory_update)\n55: // Feature catalog: Validation feedback (memory_validate)\n56: // Feature catalog: Transaction wrappers on mutation handlers\n57: // Feature catalog: Per-memory history log\n58: \n59: \n60: /* ───────────────────────────────────────────────────────────────\n61:    CORE LOGIC\n62: ──────────────────────────────────────────────────────────────── */\n63: \n64: const PROTECTED_AUTOMATED_UPDATE_FIELDS = new Set(['title', 'triggerPhrases', 'importanceTier']);\n65: const SKIPPED_MANUAL_PROTECTION_HINT = 'skipped to protect manual data';\n66: \n67: interface ProvenanceGuardResult {\n68:   updateParams: UpdateMemoryParams;\n69:   requestedFields: string[];\n70:   persistedFields: string[];\n71:   skippedFields: string[];\n72:   sourceKind: SourceKind;\n73:   storedSourceKind: SourceKind;\n74:   hint: string | null;\n75: }\n76: \n77: function getInternalProvenanceContext(args: UpdateArgs): Record<string, unknown> {\n78:   const rawArgs = args as unknown as Record<string, unknown>;\n79:   const context = rawArgs.__provenanceContext;\n80:   return context && typeof context === 'object' && !Array.isArray(context)\n81:     ? context as Record<string, unknown>\n82:     : {};\n83: }\n84: \n85: function isProtectedExistingRow(existing: Record<string, unknown>): boolean {\n86:   const existingSourceKind = normalizeSourceKind(existing.source_kind);\n87:   const importanceTier = typeof existing.importance_tier === 'string' ? existing.importance_tier : null;\n88:   const isPinned = existing.is_pinned === true || existing.is_pinned === 1;\n89:   const pathCandidate = [existing.canonical_file_path, existing.file_path]\n90:     .find((value) => typeof value === 'string' && value.length > 0);\n91:   const rowPath = typeof pathCandidate === 'string' ? pathCandidate : null;\n92:   return existingSourceKind === null\n93:     || existingSourceKind === 'human'\n94:     || importanceTier === 'constitutional'\n95:     || importanceTier === 'critical'\n96:     || isPinned\n97:     || (rowPath !== null && isConstitutionalPath(rowPath));\n98: }\n99: \n100: function buildGuardedUpdateParams(\n101:   args: UpdateArgs,\n102:   existing: Record<string, unknown>,\n103: ): ProvenanceGuardResult {\n104:   const internalContext = getInternalProvenanceContext(args);\n105:   const sourceKind = deriveSourceKindFromContext({\n106:     provenanceSource: internalContext.provenanceSource ?? internalContext.provenance_source,\n107:     provenanceActor: internalContext.provenanceActor ?? internalContext.provenance_actor,\n108:     tool: internalContext.tool,\n109:   });\n110:   const existingSourceKind = normalizeSourceKind(existing.source_kind);\n111:   const automated = sourceKind !== 'human';\n112:   const protectExisting = automated && isProtectedExistingRow(existing);\n113:   const updateParams: UpdateMemoryParams = { id: args.id };\n114:   const requestedFields: string[] = [];\n115:   const persistedFields: string[] = [];\n116:   const skippedFields: string[] = [];\n117: \n118:   const maybeAssign = <K extends keyof UpdateMemoryParams>(field: K, value: UpdateMemoryParams[K]): void => {\n119:     if (value === undefined) {\n120:       return;\n121:     }\n122:     requestedFields.push(field);\n123:     if (protectExisting && PROTECTED_AUTOMATED_UPDATE_FIELDS.has(field)) {\n124:       skippedFields.push(field);\n125:       return;\n126:     }\n127:     updateParams[field] = value;\n128:     persistedFields.push(field);\n129:   };\n130: \n131:   maybeAssign('title', args.title);\n132:   maybeAssign('triggerPhrases', args.triggerPhrases);\n133:   maybeAssign('importanceWeight', args.importanceWeight);\n134:   maybeAssign('importanceTier', args.importanceTier);\n135: \n136:   const storedSourceKind = sourceKind === 'human'\n137:     ? 'human'\n138:     : (protectExisting ? (existingSourceKind ?? 'human') : sourceKind);\n139: \n140:   return {\n141:     updateParams,\n142:     requestedFields,\n143:     persistedFields,\n144:     skippedFields,\n145:     sourceKind,\n146:     storedSourceKind,\n147:     hint: skippedFields.length > 0 ? SKIPPED_MANUAL_PROTECTION_HINT : null,\n148:   };\n149: }\n150: \n151: /** Handle memory_update tool -- updates metadata fields and optionally regenerates embeddings. */\n152: async function handleMemoryUpdate(args: UpdateArgs): Promise<MCPResponse> {\n153:   await ensureMemoryRuntimeInitialized('handler:memory_update');\n154:   // Generate requestId for incident correlation in error responses\n155:   const requestId = randomUUID();\n156:   await checkDatabaseUpdated();\n157: \n158:   const {\n159:     id,\n160:     title: rawTitle,\n161:     triggerPhrases: rawTriggerPhrases,\n162:     importanceWeight,\n163:     importanceTier,\n164:     allowPartialUpdate = false,\n165:   } = args;\n166: \n167:   if (typeof id !== 'number') {\n168:     throw new MemoryError(ErrorCodes.MISSING_REQUIRED_PARAM, 'id is required', { param: 'id' });\n169:   }\n170: \n171:   // Title and trigger phrases are persisted/indexed fields written outside\n172:   // the parse path, so they get the same pre-index secret redaction. A\n173:   // scrubber failure refuses this write (fail-closed) rather than persisting\n174:   // potentially unscrubbed text.\n175:   let title = rawTitle;\n176:   let triggerPhrases = rawTriggerPhrases;\n177:   try {\n178:     if (typeof title === 'string') {\n179:       title = scrubSecrets(title);\n180:     }\n181:     if (Array.isArray(triggerPhrases)) {\n182:       triggerPhrases = triggerPhrases.map((phrase) => (\n183:         typeof phrase === 'string' ? scrubSecrets(phrase) : phrase\n184:       ));\n185:     }\n186:   } catch (error: unknown) {\n187:     if (error instanceof SecretScrubberError) {\n188:       throw new MemoryError(\n189:         ErrorCodes.INVALID_PARAMETER,\n190:         `Update refused: ${error.message}`,\n191:         { param: 'title/triggerPhrases', memoryId: id },\n192:       );\n193:     }\n194:     throw error;\n195:   }\n196: \n197:   if (importanceWeight !== undefined && (typeof importanceWeight !== 'number' || importanceWeight < 0 || importanceWeight > 1)) {\n198:     throw new MemoryError(\n199:       ErrorCodes.INVALID_PARAMETER,\n200:       'importanceWeight must be a number between 0 and 1',\n201:       { param: 'importanceWeight', value: importanceWeight }\n202:     );\n203:   }\n204: \n205:   if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n206:     throw new MemoryError(\n207:       ErrorCodes.INVALID_PARAMETER,\n208:       `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n209:       { param: 'importanceTier', value: importanceTier }\n210:     );\n211:   }\n212: \n213:   const existing = vectorIndex.getMemory(id);\n214:   if (!existing) {\n215:     throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n216:   }\n217: \n218:   const database = vectorIndex.getDb();\n219:   const priorSnapshot = getMemoryHashSnapshot(database, id);\n220: \n221:   const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n222:   const updateParams = guard.updateParams;\n223:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n224: \n225:   if (database && isMemoryIdempotencyEnabled()) {\n226:     try {\n227:       const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n228:       const logicalMutation = {\n229:         id,\n230:         title: updateParams.title ?? null,\n231:         triggerPhrases: updateParams.triggerPhrases ?? null,\n232:         importanceWeight: updateParams.importanceWeight ?? null,\n233:         importanceTier: updateParams.importanceTier ?? null,\n234:         contentHash,\n235:       };\n236:       const lookup = lookupIdempotencyReceipt(database, {\n237:         operation: 'memory_update',\n238:         contentHash,\n239:         requestFingerprint: {\n240:           id,\n241:           contentHash,\n242:           logicalMutation,\n243:         },\n244:         // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n245:         // payloadHash always equals requestFingerprintHash and the receiptKey is\n246:         // derived from it. Consequence: distinct logical updates always produce\n247:         // distinct keys, so the same-key/different-payload 'conflict' status can\n248:         // never fire from this caller; the conflict branch below is fail-safe\n249:         // defense-in-depth, not active protection. To make conflicts detectable\n250:         // the payload would have to carry MORE than the key material (e.g.\n251:         // execution-mode flags like allowPartialUpdate); it deliberately does\n252:         // not, so a benign flag flip cannot become a false hard conflict.\n253:         payload: {\n254:           id,\n255:           contentHash,\n256:           logicalMutation,\n257:         },\n258:       });\n259:       idempotencyKey = lookup.key;\n260:       if (lookup.status === 'replay') {\n261:         // A receipt is a replay cache, not proof the cached response still\n262:         // describes the live row. Re-read this id's current content_hash and\n263:         // honor the replay ONLY when it still matches the receipt's content_hash\n264:         // AND the cached response still reports this same id; an A->B->A content\n265:         // revert leaves the receipt for A intact while the row moved on, and a\n266:         // delete-then-recreate can leave the cached response naming a stale id,\n267:         // so replaying it would diverge from the row.\n268:         const liveRow = database\n269:           .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n270:           .get(id) as { content_hash: string | null } | undefined;\n271:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n272:         if (\n273:           liveRow\n274:           && liveRow.content_hash === lookup.key.contentHash\n275:           && (replayMemoryId == null || replayMemoryId === id)\n276:         ) {\n277:           return lookup.response;\n278:         }\n279:         // Stale receipt for this attempt: drop the cache entry so the live\n280:         // update stores its current response (the post-write store uses\n281:         // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n282:         // stale receipt), then fall through to the normal update path.\n283:         deleteIdempotencyReceiptByKey(database, lookup.key);\n284:       } else if (lookup.status === 'conflict') {\n285:         // Unreachable from this caller: payload is a structural copy of\n286:         // requestFingerprint (above), so a key match implies a payload match and\n287:         // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n288:         // case the key material and payload ever diverge.\n289:         return createMCPErrorResponse({\n290:           tool: 'memory_update',\n291:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n292:           code: 'idempotency_key_conflict',\n293:           details: { requestId, receiptKey: lookup.key.receiptKey, id },\n294:           recovery: {\n295:             hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n296:             severity: 'warning',\n297:           },\n298:         });\n299:       }\n300:     } catch (error: unknown) {\n301:       console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n302:       idempotencyKey = null;\n303:     }\n304:   }\n305: \n306:   let embeddingRegenerated = false;\n307:   let embeddingMarkedForReindex = false;\n308:   let embeddingStatusNeedsPendingWrite = false;\n309:   let mutationLedgerWarning: string | null = null;\n310: \n311:   if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n312:     console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n313:     let newEmbedding: Float32Array | null = null;\n314: \n315:     try {\n316:       // Embed title + content_text, not title alone.\n317:       // This produces better semantic embeddings that capture the full memory context.\n318:       const contentText = existing.content_text || '';\n319:       const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n320:       newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n321:     } catch (err: unknown) {\n322:       const message = toErrorMessage(err);\n323:       if (allowPartialUpdate) {\n324:         console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n325:         embeddingStatusNeedsPendingWrite = true;\n326:         embeddingMarkedForReindex = true;\n327:       } else {\n328:         console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n329:         throw new MemoryError(\n330:           ErrorCodes.EMBEDDING_FAILED,\n331:           'Embedding regeneration failed, update rolled back. No changes were made.',\n332:           { originalError: message, memoryId: id }\n333:         );\n334:       }\n335:     }\n336: \n337:     if (newEmbedding) {\n338:       updateParams.embedding = newEmbedding;\n339:       embeddingRegenerated = true;\n340:     } else if (!embeddingMarkedForReindex) {\n341:       if (allowPartialUpdate) {\n342:         console.warn('[memory-update] Embedding returned null, marking for re-index');\n343:         embeddingStatusNeedsPendingWrite = true;\n344:         embeddingMarkedForReindex = true;\n345:       } else {\n346:         throw new MemoryError(\n347:           ErrorCodes.EMBEDDING_FAILED,\n348:           'Failed to regenerate embedding (null result), update rolled back. No changes were made.',\n349:           { memoryId: id }\n350:         );\n351:       }\n352:     }\n353:   }\n354: \n355:   // transaction wrapper — wraps all synchronous mutation steps (DB update,\n356:   // Cache invalidation, BM25 re-index, ledger append) in a single transaction for atomicity.\n357:   // Embedding generation (async) runs before this block; its result feeds into updateParams.\n358:   const fields = guard.persistedFields;\n359: \n360:   if (database) {\n361:     runInTransaction(database, () => {\n362:       if (embeddingStatusNeedsPendingWrite) {\n363:         vectorIndex.updateEmbeddingStatus(id, 'pending');\n364:       }\n365: \n366:       if (fields.length > 0 || updateParams.embedding !== undefined) {\n367:         vectorIndex.updateMemory(updateParams);\n368:       }\n369:       persistSourceKind(database, id, guard.storedSourceKind);\n370:       persistProvenanceMetadata(database, id, getInternalProvenanceContext(args));\n371: \n372:       if (updateParams.importanceTier !== undefined) {\n373:         const updated = vectorIndex.getMemory(id) as (Record<string, unknown> | null);\n374:         const previousTier = typeof existing.importance_tier === 'string'\n375:           ? existing.importance_tier\n376:           : undefined;\n377:         const nextTier = typeof updated?.importance_tier === 'string'\n378:           ? updated.importance_tier\n379:           : (previousTier ?? updateParams.importanceTier);\n380:         const guardPathCandidate = [\n381:           updated?.canonical_file_path,\n382:           updated?.file_path,\n383:           existing.canonical_file_path,\n384:           existing.file_path,\n385:         ].find((value) => typeof value === 'string' && value.length > 0);\n386:         const guardPath = typeof guardPathCandidate === 'string' ? guardPathCandidate : null;\n387: \n388:         if (\n389:           guardPath\n390:           && !isConstitutionalPath(guardPath)\n391:           && previousTier === 'constitutional'\n392:           && nextTier !== 'constitutional'\n393:         ) {\n394:           try {\n395:             const specFolder = typeof updated?.spec_folder === 'string'\n396:               ? updated.spec_folder\n397:               : (typeof existing.spec_folder === 'string' ? existing.spec_folder : null);\n398:             const anchorIdCandidate = typeof updated?.anchor_id === 'string'\n399:               ? updated.anchor_id\n400:               : (typeof existing.anchor_id === 'string' ? existing.anchor_id : null);\n401:             const anchorId = typeof anchorIdCandidate === 'string' ? anchorIdCandidate : null;\n402:             const updatedFilePath = typeof updated?.file_path === 'string'\n403:               ? updated.file_path\n404:               : (typeof existing.file_path === 'string' ? existing.file_path : null);\n405:             const updatedCanonicalFilePath = typeof updated?.canonical_file_path === 'string'\n406:               ? updated.canonical_file_path\n407:               : (typeof existing.canonical_file_path === 'string' ? existing.canonical_file_path : null);\n408:             recordTierDowngradeAudit(database, {\n409:               memoryId: id,\n410:               logicalKey: buildGovernanceLogicalKey(specFolder, guardPath, anchorId),\n411:               requestedTier: updateParams.importanceTier,\n412:               previousTier,\n413:               nextTier,\n414:               source: 'memory_update',\n415:               filePath: updatedFilePath,\n416:               canonicalFilePath: updatedCanonicalFilePath,\n417:             });\n418:           } catch (error: unknown) {\n419:             console.warn(\n420:               `[memory-crud-update] governance_audit insert failed for memory ${id}: ${toErrorMessage(error)}`,\n421:             );\n422:           }\n423:         }\n424:       }\n425: \n426:       // BM25 index stores title + trigger phrases; must re-index when either changes\n427:       // so keyword search reflects the updated content.\n428:       // BM25 re-index failure now rolls back the transaction when the index is operational.\n429:       // Infrastructure failures (BM25 not available, DB missing prepare) are non-fatal warnings.\n430:       if ((updateParams.title !== undefined || updateParams.triggerPhrases !== undefined) && bm25Index.isBm25Enabled()) {\n431:         try {\n432:           const bm25Idx = bm25Index.getIndex();\n433:           const row = database.prepare(\n434:             'SELECT title, content_text, trigger_phrases, file_path FROM memory_index WHERE id = ?'\n435:           ).get(id) as { title: string | null; content_text: string | null; trigger_phrases: string | null; file_path: string | null } | undefined;\n436:           if (row) {\n437:             const text = bm25Index.buildBm25DocumentText(row);\n438:             if (text.trim()) {\n439:               bm25Idx.addDocument(String(id), text);\n440:             }\n441:           }\n442:         } catch (e: unknown) {\n443:           const bm25ErrMsg = e instanceof Error ? e.message : String(e);\n444:           // Distinguish infrastructure failures from data failures.\n445:           // Infrastructure failures mean the BM25 subsystem is unavailable or torn down —\n446:           // These are non-fatal warnings. Data failures mean the index IS operational but rejected\n447:           // The input — those must re-throw to roll back the transaction.\n448:           const isBm25InfraFailure = (msg: string): boolean =>\n449:             msg.includes('not a function') ||\n450:             msg.includes('not initialized') ||\n451:             msg.includes('Cannot read properties') ||\n452:             msg.includes('is not defined') ||\n453:             msg.includes('database is closed') ||\n454:             msg.includes('no such table');\n455:           if (isBm25InfraFailure(bm25ErrMsg)) {\n456:             console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n457:           } else {\n458:             console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n459:             throw new Error(`BM25 re-index failed: ${bm25ErrMsg}`);\n460:           }\n461:         }\n462:       }\n463: \n464:       // Record UPDATE history after successful mutation\n465:       try {\n466:         recordHistory(\n467:           id, 'UPDATE',\n468:           existing.title ?? null,\n469:           updateParams.title ?? existing.title ?? null,\n470:           'mcp:memory_update'\n471:         );\n472:       } catch (_histErr: unknown) {\n473:         // History recording is best-effort\n474:       }\n475: \n476:       const ledgerRecorded = appendMutationLedgerSafe(database, {\n477:         mutationType: 'update',\n478:         reason: 'memory_update: metadata update',\n479:         priorHash: priorSnapshot?.content_hash ?? (existing.content_hash as string | null) ?? null,\n480:         newHash: mutationLedger.computeHash(JSON.stringify({\n481:           id,\n482:           title: updateParams.title ?? existing.title ?? null,\n483:           triggerPhrases: updateParams.triggerPhrases ?? null,\n484:           importanceWeight: updateParams.importanceWeight ?? null,\n485:           importanceTier: updateParams.importanceTier ?? null,\n486:         })),\n487:         linkedMemoryIds: [id],\n488:         decisionMeta: {\n489:           tool: 'memory_update',\n490:           fields,\n491:           requestedFields: guard.requestedFields,\n492:           skippedFields: guard.skippedFields,\n493:           sourceKind: guard.sourceKind,\n494:           storedSourceKind: guard.storedSourceKind,\n495:           embeddingRegenerated,\n496:           embeddingMarkedForReindex,\n497:           allowPartialUpdate,\n498:         },\n499:         actor: 'mcp:memory_update',\n500:       });\n501:       if (!ledgerRecorded) {\n502:         mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n503:       }\n504:     });\n505:   } else {\n506:     // No database handle means we cannot guarantee transactional\n507:     // Consistency. Abort early rather than risk partial state.\n508:     console.warn('[memory-crud-update] No database handle, aborting update to prevent partial state');\n509:     return createMCPErrorResponse({\n510:       tool: 'memory_update',\n511:       error: `Memory ${id} update aborted: database unavailable`,\n512:       code: 'E_DB_UNAVAILABLE',\n513:       details: { updated: null, fields, skippedFields: guard.skippedFields },\n514:       recovery: {\n515:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n516:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n517:         severity: 'error',\n518:       },\n519:     });\n520:   }\n521: \n522:   let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n523:   try {\n524:     postMutationHooks = runPostMutationHooks('update', {\n525:       database,\n526:       memoryId: id,\n527:       sourceKind: guard.sourceKind,\n528:       actor: 'mcp:memory_update',\n529:       auditReason: `memory_update:${id}:${fields.slice().sort().join(',') || 'source_kind'}`,\n530:     });\n531:   } catch (hookError: unknown) {\n532:     const msg = hookError instanceof Error ? hookError.message : String(hookError);\n533:     postMutationHooks = {\n534:       latencyMs: 0, triggerCacheCleared: false,\n535:       constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n536:       graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n537:       errors: [msg],\n538:     };\n539:   }\n540:   const postMutationFeedback = buildMutationHookFeedback('update', postMutationHooks);\n541: \n542:   const summary = embeddingMarkedForReindex\n543:     ? `Memory ${id} updated (embedding pending re-index)`\n544:     : `Memory ${id} updated successfully`;\n545: \n546:   const hints: string[] = [];\n547:   if (embeddingMarkedForReindex) {\n548:     hints.push('Run memory_index_scan() to regenerate embeddings');\n549:   }\n550:   if (embeddingRegenerated) {\n551:     hints.push('Embedding regenerated - search results may differ');\n552:   }\n553:   if (mutationLedgerWarning) {\n554:     hints.push(mutationLedgerWarning);\n555:   }\n556:   if (guard.hint) {\n557:     hints.push(guard.hint);\n558:   }\n559:   hints.push(...postMutationFeedback.hints);\n560: \n561:   const data: Record<string, unknown> = {\n562:     updated: id,\n563:     fields,\n564:     skippedFields: guard.skippedFields,\n565:     provenance: {\n566:       sourceKind: guard.sourceKind,\n567:       storedSourceKind: guard.storedSourceKind,\n568:     },\n569:     embeddingRegenerated,\n570:     postMutationHooks: postMutationFeedback.data,\n571:   };\n572: \n573:   if (embeddingMarkedForReindex) {\n574:     data.warning = 'Embedding regeneration failed, memory marked for re-indexing';\n575:     data.embeddingStatus = 'pending';\n576:   }\n577:   if (mutationLedgerWarning) {\n578:     data.mutationLedgerWarning = mutationLedgerWarning;\n579:   }\n580: \n581:   const response = createMCPSuccessResponse({\n582:     tool: 'memory_update',\n583:     summary,\n584:     data,\n585:     hints,\n586:   });\n587:   if (database && idempotencyKey) {\n588:     try {\n589:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n590:       if (!won) {\n591:         // Same lost-store semantics as memory_save: a same-payload loser\n592:         // replays the canonical winner; a different-payload loser already\n593:         // mutated, so it returns its own response with the conflict made\n594:         // visible rather than silently diverging from the receipt.\n595:         const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n596:         if (winner.status === 'replay') {\n597:           return winner.response;\n598:         }\n599:         if (winner.status === 'conflict') {\n600:           return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n601:         }\n602:       }\n603:     } catch (error: unknown) {\n604:       console.warn(`[memory-crud-update] idempotency receipt store failed; continuing without replay receipt: ${toErrorMessage(error)}`);\n605:     }\n606:   }\n607:   return response;\n608: }\n609: \n610: /* ───────────────────────────────────────────────────────────────\n611:    EXPORTS\n612: ──────────────────────────────────────────────────────────────── */\n613: \n614: export { handleMemoryUpdate };\n\n(End of file - total 614 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Update Handler\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { UpdateMemoryParams } from '../lib/search/vector-index.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\nimport { MemoryError, ErrorCodes } from '../lib/errors.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport { runInTransaction } from '../lib/storage/transaction-manager.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Update Handler\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { UpdateMemoryParams } from '../lib/search/vector-index.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\nimport { MemoryError, ErrorCodes } from '../lib/errors.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport { runInTransaction } from '../lib/storage/transaction-manager.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../lib/governance/scope-governance.js';\nimport { isConstitutionalPath } from '../lib/utils/index-scope.js';\nimport { scrubSecrets, SecretScrubberError } from '../lib/parsing/secret-scrubber.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport {\n  deleteIdempotencyReceiptByKey,\n  extractMemoryIdFromResponse,\n  isMemoryIdempotencyEnabled,\n  lookupIdempotencyReceipt,\n  lookupIdempotencyReceiptByKey,\n  markResponseWithReceiptStoreConflict,\n  storeIdempotencyReceipt,\n  type IdempotencyReceiptKey,\n} from '../lib/storage/idempotency-receipts.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport {\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  persistProvenanceMetadata,\n  persistSourceKind,\n  type SourceKind,\n} from '../lib/storage/write-provenance.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { UpdateArgs } from './memory-crud-types.js';\n\n// Feature catalog: Memory metadata update (memory_update)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nconst PROTECTED_AUTOMATED_UPDATE_FIELDS = new Set(['title', 'triggerPhrases', 'importanceTier']);\nconst SKIPPED_MANUAL_PROTECTION_HINT = 'skipped to protect manual data';\n\ninterface ProvenanceGuardResult {\n  updateParams: UpdateMemoryParams;\n  requestedFields: string[];\n  persistedFields: string[];\n  skippedFields: string[];\n  sourceKind: SourceKind;\n  storedSourceKind: SourceKind;\n  hint: string | null;\n}\n\nfunction getInternalProvenanceContext(args: UpdateArgs): Record<string, unknown> {\n  const rawArgs = args as unknown as Record<string, unknown>;\n  const context = rawArgs.__provenanceContext;\n  return context && typeof context === 'object' && !Array.isArray(context)\n    ? context as Record<string, unknown>\n    : {};\n}\n\nfunction isProtectedExistingRow(existing: Record<string, unknown>): boolean {\n  const existingSourceKind = normalizeSourceKind(existing.source_kind);\n  const importanceTier = typeof existing.importance_tier === 'string' ? existing.importance_tier : null;\n  const isPinned = existing.is_pinned === true || existing.is_pinned === 1;\n  const pathCandidate = [existing.canonical_file_path, existing.file_path]\n    .find((value) => typeof value === 'string' && value.length > 0);\n  const rowPath = typeof pathCandidate === 'string' ? pathCandidate : null;\n  return existingSourceKind === null\n    || existingSourceKind === 'human'\n    || importanceTier === 'constitutional'\n    || importanceTier === 'critical'\n    || isPinned\n    || (rowPath !== null && isConstitutionalPath(rowPath));\n}\n\nfunction buildGuardedUpdateParams(\n  args: UpdateArgs,\n  existing: Record<string, unknown>,\n): ProvenanceGuardResult {\n  const internalContext = getInternalProvenanceContext(args);\n  const sourceKind = deriveSourceKindFromContext({\n    provenanceSource: internalContext.provenanceSource ?? internalContext.provenance_source,\n    provenanceActor: internalContext.provenanceActor ?? internalContext.provenance_actor,\n    tool: internalContext.tool,\n  });\n  const existingSourceKind = normalizeSourceKind(existing.source_kind);\n  const automated = sourceKind !== 'human';\n  const protectExisting = automated && isProtectedExistingRow(existing);\n  const updateParams: UpdateMemoryParams = { id: args.id };\n  const requestedFields: string[] = [];\n  const persistedFields: string[] = [];\n  const skippedFields: string[] = [];\n\n  const maybeAssign = <K extends keyof UpdateMemoryParams>(field: K, value: UpdateMemoryParams[K]): void => {\n    if (value === undefined) {\n      return;\n    }\n    requestedFields.push(field);\n    if (protectExisting && PROTECTED_AUTOMATED_UPDATE_FIELDS.has(field)) {\n      skippedFields.push(field);\n      return;\n    }\n    updateParams[field] = value;\n    persistedFields.push(field);\n  };\n\n  maybeAssign('title', args.title);\n  maybeAssign('triggerPhrases', args.triggerPhrases);\n  maybeAssign('importanceWeight', args.importanceWeight);\n  maybeAssign('importanceTier', args.importanceTier);\n\n  const storedSourceKind = sourceKind === 'human'\n    ? 'human'\n    : (protectExisting ? (existingSourceKind ?? 'human') : sourceKind);\n\n  return {\n    updateParams,\n    requestedFields,\n    persistedFields,\n    skippedFields,\n    sourceKind,\n    storedSourceKind,\n    hint: skippedFields.length > 0 ? SKIPPED_MANUAL_PROTECTION_HINT : null,\n  };\n}\n\n/** Handle memory_update tool -- updates metadata fields and optionally regenerates embeddings. */\nasync function handleMemoryUpdate(args: UpdateArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_update');\n  // Generate requestId for incident correlation in error responses\n  const requestId = randomUUID();\n  await checkDatabaseUpdated();\n\n  const {\n    id,\n    title: rawTitle,\n    triggerPhrases: rawTriggerPhrases,\n    importanceWeight,\n    importanceTier,\n    allowPartialUpdate = false,\n  } = args;\n\n  if (typeof id !== 'number') {\n    throw new MemoryError(ErrorCodes.MISSING_REQUIRED_PARAM, 'id is required', { param: 'id' });\n  }\n\n  // Title and trigger phrases are persisted/indexed fields written outside\n  // the parse path, so they get the same pre-index secret redaction. A\n  // scrubber failure refuses this write (fail-closed) rather than persisting\n  // potentially unscrubbed text.\n  let title = rawTitle;\n  let triggerPhrases = rawTriggerPhrases;\n  try {\n    if (typeof title === 'string') {\n      title = scrubSecrets(title);\n    }\n    if (Array.isArray(triggerPhrases)) {\n      triggerPhrases = triggerPhrases.map((phrase) => (\n        typeof phrase === 'string' ? scrubSecrets(phrase) : phrase\n      ));\n    }\n  } catch (error: unknown) {\n    if (error instanceof SecretScrubberError) {\n      throw new MemoryError(\n        ErrorCodes.INVALID_PARAMETER,\n        `Update refused: ${error.message}`,\n        { param: 'title/triggerPhrases', memoryId: id },\n      );\n    }\n    throw error;\n  }\n\n  if (importanceWeight !== undefined && (typeof importanceWeight !== 'number' || importanceWeight < 0 || importanceWeight > 1)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      'importanceWeight must be a number between 0 and 1',\n      { param: 'importanceWeight', value: importanceWeight }\n    );\n  }\n\n  if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n      { param: 'importanceTier', value: importanceTier }\n    );\n  }\n\n  const existing = vectorIndex.getMemory(id);\n  if (!existing) {\n    throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n  }\n\n  const database = vectorIndex.getDb();\n  const priorSnapshot = getMemoryHashSnapshot(database, id);\n\n  const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n  const updateParams = guard.updateParams;\n  let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  if (database && isMemoryIdempotencyEnabled()) {\n    try {\n      const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n      const logicalMutation = {\n        id,\n        title: updateParams.title ?? null,\n        triggerPhrases: updateParams.triggerPhrases ?? null,\n        importanceWeight: updateParams.importanceWeight ?? null,\n        importanceTier: updateParams.importanceTier ?? null,\n        contentHash,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_update',\n        contentHash,\n        requestFingerprint: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n        // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n        // payloadHash always equals requestFingerprintHash and the receiptKey is\n        // derived from it. Consequence: distinct logical updates always produce\n        // distinct keys, so the same-key/different-payload 'conflict' status can\n        // never fire from this caller; the conflict branch below is fail-safe\n        // defense-in-depth, not active protection. To make conflicts detectable\n        // the payload would have to carry MORE than the key material (e.g.\n        // execution-mode flags like allowPartialUpdate); it deliberately does\n        // not, so a benign flag flip cannot become a false hard conflict.\n        payload: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live row. Re-read this id's current content_hash and\n        // honor the replay ONLY when it still matches the receipt's content_hash\n        // AND the cached response still reports this same id; an A->B->A content\n        // revert leaves the receipt for A intact while the row moved on, and a\n        // delete-then-recreate can leave the cached response naming a stale id,\n        // so replaying it would diverge from the row.\n        const liveRow = database\n          .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n          .get(id) as { content_hash: string | null } | undefined;\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          liveRow\n          && liveRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || replayMemoryId === id)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the live\n        // update stores its current response (the post-write store uses\n        // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n        // stale receipt), then fall through to the normal update path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload is a structural copy of\n        // requestFingerprint (above), so a key match implies a payload match and\n        // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n        // case the key material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_update',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey, id },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n      idempotencyKey = null;\n    }\n  }\n\n  let embeddingRegenerated = false;\n  let embeddingMarkedForReindex = false;\n  let embeddingStatusNeedsPendingWrite = false;\n  let mutationLedgerWarning: string | null = null;\n\n  if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n    console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n    let newEmbedding: Float32Array | null = null;\n\n    try {\n      // Embed title + content_text, not title alone.\n      // This produces better semantic embeddings that capture the full memory context.\n      const contentText = existing.content_text || '';\n      const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n      newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      if (allowPartialUpdate) {\n        console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n        embeddingStatusNeedsPendingWrite = true;\n        embeddingMarkedForReindex = true;\n      } else {\n        console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n        throw new MemoryError(\n          ErrorCodes.EMBEDDING_FAILED,\n          'Embedding regeneration failed, update rolled back. No changes were made.',\n          { originalError: message, memoryId: id }\n        );\n      }\n    }\n\n    if (newEmbedding) {\n      updateParams.embedding = newEmbedding;\n      embeddingRegenerated = true;\n    } else if (!embeddingMarkedForReindex) {\n      if (allowPartialUpdate) {\n        console.warn('[memory-update] Embedding returned null, marking for re-index');\n        embeddingStatusNeedsPendingWrite = true;\n        embeddingMarkedForReindex = true;\n      } else {\n        throw new MemoryError(\n          ErrorCodes.EMBEDDING_FAILED,\n          'Failed to regenerate embedding (null result), update rolled back. No changes were made.',\n          { memoryId: id }\n        );\n      }\n    }\n  }\n\n  // transaction wrapper — wraps all synchronous mutation steps (DB update,\n  // Cache invalidation, BM25 re-index, ledger append) in a single transaction for atomicity.\n  // Embedding generation (async) runs before this block; its result feeds into updateParams.\n  const fields = guard.persistedFields;\n\n  if (database) {\n    runInTransaction(database, () => {\n      if (embeddingStatusNeedsPendingWrite) {\n        vectorIndex.updateEmbeddingStatus(id, 'pending');\n      }\n\n      if (fields.length > 0 || updateParams.embedding !== undefined) {\n        vectorIndex.updateMemory(updateParams);\n      }\n      persistSourceKind(database, id, guard.storedSourceKind);\n      persistProvenanceMetadata(database, id, getInternalProvenanceContext(args));\n\n      if (updateParams.importanceTier !== undefined) {\n        const updated = vectorIndex.getMemory(id) as (Record<string, unknown> | null);\n        const previousTier = typeof existing.importance_tier === 'string'\n          ? existing.importance_tier\n          : undefined;\n        const nextTier = typeof updated?.importance_tier === 'string'\n          ? updated.importance_tier\n          : (previousTier ?? updateParams.importanceTier);\n        const guardPathCandidate = [\n          updated?.canonical_file_path,\n          updated?.file_path,\n          existing.canonical_file_path,\n          existing.file_path,\n        ].find((value) => typeof value === 'string' && value.length > 0);\n        const guardPath = typeof guardPathCandidate === 'string' ? guardPathCandidate : null;\n\n        if (\n          guardPath\n          && !isConstitutionalPath(guardPath)\n          && previousTier === 'constitutional'\n          && nextTier !== 'constitutional'\n        ) {\n          try {\n            const specFolder = typeof updated?.spec_folder === 'string'\n              ? updated.spec_folder\n              : (typeof existing.spec_folder === 'string' ? existing.spec_folder : null);\n            const anchorIdCandidate = typeof updated?.anchor_id === 'string'\n              ? updated.anchor_id\n              : (typeof existing.anchor_id === 'string' ? existing.anchor_id : null);\n            const anchorId = typeof anchorIdCandidate === 'string' ? anchorIdCandidate : null;\n            const updatedFilePath = typeof updated?.file_path === 'string'\n              ? updated.file_path\n              : (typeof existing.file_path === 'string' ? existing.file_path : null);\n            const updatedCanonicalFilePath = typeof updated?.canonical_file_path === 'string'\n              ? updated.canonical_file_path\n              : (typeof existing.canonical_file_path === 'string' ? existing.canonical_file_path : null);\n            recordTierDowngradeAudit(database, {\n              memoryId: id,\n              logicalKey: buildGovernanceLogicalKey(specFolder, guardPath, anchorId),\n              requestedTier: updateParams.importanceTier,\n              previousTier,\n              nextTier,\n              source: 'memory_update',\n              filePath: updatedFilePath,\n              canonicalFilePath: updatedCanonicalFilePath,\n            });\n          } catch (error: unknown) {\n            console.warn(\n              `[memory-crud-update] governance_audit insert failed for memory ${id}: ${toErrorMessage(error)}`,\n            );\n          }\n        }\n      }\n\n      // BM25 index stores title + trigger phrases; must re-index when either changes\n      // so keyword search reflects the updated content.\n      // BM25 re-index failure now rolls back the transaction when the index is operational.\n      // Infrastructure failures (BM25 not available, DB missing prepare) are non-fatal warnings.\n      if ((updateParams.title !== undefined || updateParams.triggerPhrases !== undefined) && bm25Index.isBm25Enabled()) {\n        try {\n          const bm25Idx = bm25Index.getIndex();\n          const row = database.prepare(\n            'SELECT title, content_text, trigger_phrases, file_path FROM memory_index WHERE id = ?'\n          ).get(id) as { title: string | null; content_text: string | null; trigger_phrases: string | null; file_path: string | null } | undefined;\n          if (row) {\n            const text = bm25Index.buildBm25DocumentText(row);\n            if (text.trim()) {\n              bm25Idx.addDocument(String(id), text);\n            }\n          }\n        } catch (e: unknown) {\n          const bm25ErrMsg = e instanceof Error ? e.message : String(e);\n          // Distinguish infrastructure failures from data failures.\n          // Infrastructure failures mean the BM25 subsystem is unavailable or torn down —\n          // These are non-fatal warnings. Data failures mean the index IS operational but rejected\n          // The input — those must re-throw to roll back the transaction.\n          const isBm25InfraFailure = (msg: string): boolean =>\n            msg.includes('not a function') ||\n            msg.includes('not initialized') ||\n            msg.includes('Cannot read properties') ||\n            msg.includes('is not defined') ||\n            msg.includes('database is closed') ||\n            msg.includes('no such table');\n          if (isBm25InfraFailure(bm25ErrMsg)) {\n            console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n          } else {\n            console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n            throw new Error(`BM25 re-index failed: ${bm25ErrMsg}`);\n          }\n        }\n      }\n\n      // Record UPDATE history after successful mutation\n      try {\n        recordHistory(\n          id, 'UPDATE',\n          existing.title ?? null,\n          updateParams.title ?? existing.title ?? null,\n          'mcp:memory_update'\n        );\n      } catch (_histErr: unknown) {\n        // History recording is best-effort\n      }\n\n      const ledgerRecorded = appendMutationLedgerSafe(database, {\n        mutationType: 'update',\n        reason: 'memory_update: metadata update',\n        priorHash: priorSnapshot?.content_hash ?? (existing.content_hash as string | null) ?? null,\n        newHash: mutationLedger.computeHash(JSON.stringify({\n          id,\n          title: updateParams.title ?? existing.title ?? null,\n          triggerPhrases: updateParams.triggerPhrases ?? null,\n          importanceWeight: updateParams.importanceWeight ?? null,\n          importanceTier: updateParams.importanceTier ?? null,\n        })),\n        linkedMemoryIds: [id],\n        decisionMeta: {\n          tool: 'memory_update',\n          fields,\n          requestedFields: guard.requestedFields,\n          skippedFields: guard.skippedFields,\n          sourceKind: guard.sourceKind,\n          storedSourceKind: guard.storedSourceKind,\n          embeddingRegenerated,\n          embeddingMarkedForReindex,\n          allowPartialUpdate,\n        },\n        actor: 'mcp:memory_update',\n      });\n      if (!ledgerRecorded) {\n        mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n      }\n    });\n  } else {\n    // No database handle means we cannot guarantee transactional\n    // Consistency. Abort early rather than risk partial state.\n    console.warn('[memory-crud-update] No database handle, aborting update to prevent partial state');\n    return createMCPErrorResponse({\n      tool: 'memory_update',\n      error: `Memory ${id} update aborted: database unavailable`,\n      code: 'E_DB_UNAVAILABLE',\n      details: { updated: null, fields, skippedFields: guard.skippedFields },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n  try {\n    postMutationHooks = runPostMutationHooks('update', {\n      database,\n      memoryId: id,\n      sourceKind: guard.sourceKind,\n      actor: 'mcp:memory_update',\n      auditReason: `memory_update:${id}:${fields.slice().sort().join(',') || 'source_kind'}`,\n    });\n  } catch (hookError: unknown) {\n    const msg = hookError instanceof Error ? hookError.message : String(hookError);\n    postMutationHooks = {\n      latencyMs: 0, triggerCacheCleared: false,\n      constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n      graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n      errors: [msg],\n    };\n  }\n  const postMutationFeedback = buildMutationHookFeedback('update', postMutationHooks);\n\n  const summary = embeddingMarkedForReindex\n    ? `Memory ${id} updated (embedding pending re-index)`\n    : `Memory ${id} updated successfully`;\n\n  const hints: string[] = [];\n  if (embeddingMarkedForReindex) {\n    hints.push('Run memory_index_scan() to regenerate embeddings');\n  }\n  if (embeddingRegenerated) {\n    hints.push('Embedding regenerated - search results may differ');\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n  if (guard.hint) {\n    hints.push(guard.hint);\n  }\n  hints.push(...postMutationFeedback.hints);\n\n  const data: Record<string, unknown> = {\n    updated: id,\n    fields,\n    skippedFields: guard.skippedFields,\n    provenance: {\n      sourceKind: guard.sourceKind,\n      storedSourceKind: guard.storedSourceKind,\n    },\n    embeddingRegenerated,\n    postMutationHooks: postMutationFeedback.data,\n  };\n\n  if (embeddingMarkedForReindex) {\n    data.warning = 'Embedding regeneration failed, memory marked for re-indexing';\n    data.embeddingStatus = 'pending';\n  }\n  if (mutationLedgerWarning) {\n    data.mutationLedgerWarning = mutationLedgerWarning;\n  }\n\n  const response = createMCPSuccessResponse({\n    tool: 'memory_update',\n    summary,\n    data,\n    hints,\n  });\n  if (database && idempotencyKey) {\n    try {\n      const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n      if (!won) {\n        // Same lost-store semantics as memory_save: a same-payload loser\n        // replays the canonical winner; a different-payload loser already\n        // mutated, so it returns its own response with the conflict made\n        // visible rather than silently diverging from the receipt.\n        const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n        if (winner.status === 'replay') {\n          return winner.response;\n        }\n        if (winner.status === 'conflict') {\n          return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n        }\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt store failed; continuing without replay receipt: ${toErrorMessage(error)}`);\n    }\n  }\n  return response;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryUpdate };","lineStart":1,"lineEnd":614,"totalLines":614,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","time":{"start":1781763537047,"end":1781763537056}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e93c819181c55364f5506073"}},"id":"prt_ed961f896001r6H9TMNnO1E1RA","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537159,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_LTHFqOzBsNoYKQMXeY3D3rjx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Ingest Handlers\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    1. IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import fs from 'node:fs';\n10: import path from 'node:path';\n11: \n12: import { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\n13: import { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\n14: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n15: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n16: import {\n17:   createIngestJob,\n18:   enqueueIngestJob,\n19:   getIngestJob,\n20:   cancelIngestJob,\n21:   getIngestProgressPercent,\n22:   getIngestForecast,\n23:   type IngestJob,\n24: } from '../lib/ops/job-queue.js';\n25: import * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n26: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n27: import { createJobId } from '../lib/ops/job-store.js';\n28: \n29: import type { MCPResponse } from './types.js';\n30: \n31: // Feature catalog: Async ingestion job lifecycle\n32: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n33: \n34: /* ───────────────────────────────────────────────────────────────\n35:    2. TYPES\n36: ──────────────────────────────────────────────────────────────── */\n37: \n38: interface MemoryIngestStartArgs {\n39:   paths: string[];\n40:   specFolder?: string;\n41:   tenantId?: string;\n42:   userId?: string;\n43:   agentId?: string;\n44:   sessionId?: string;\n45:   provenanceSource?: string;\n46:   provenanceActor?: string;\n47:   governedAt?: string;\n48:   retentionPolicy?: 'keep' | 'ephemeral';\n49:   deleteAfter?: string;\n50: }\n51: \n52: interface MemoryIngestStatusArgs {\n53:   jobId: string;\n54: }\n55: \n56: interface MemoryIngestCancelArgs {\n57:   jobId: string;\n58: }\n59: \n60: /* ───────────────────────────────────────────────────────────────\n61:    3. CONSTANTS\n62: ──────────────────────────────────────────────────────────────── */\n63: \n64: const MAX_PATH_LENGTH = 500;\n65: \n66: /* ───────────────────────────────────────────────────────────────\n67:    4. HELPERS\n68: ──────────────────────────────────────────────────────────────── */\n69: \n70: function hasTraversalSegment(inputPath: string): boolean {\n71:   return inputPath.split(/[\\\\/]+/).includes('..');\n72: }\n73: \n74: function toPublicPathLabel(filePath: string): string {\n75:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n76: }\n77: \n78: function mapJobForResponse(job: IngestJob): Record<string, unknown> {\n79:   let forecast: Record<string, unknown>;\n80:   try {\n81:     forecast = getIngestForecast(job) as unknown as Record<string, unknown>;\n82:   } catch (error: unknown) {\n83:     const message = error instanceof Error ? error.message : String(error);\n84:     forecast = {\n85:       etaSeconds: null,\n86:       etaConfidence: null,\n87:       failureRisk: null,\n88:       riskSignals: [],\n89:       caveat: `Forecast unavailable: ${message}`,\n90:     };\n91:   }\n92: \n93:   let telemetryPayload: Record<string, unknown> | undefined;\n94:   if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n95:     const telemetry = retrievalTelemetry.createTelemetry();\n96:     retrievalTelemetry.recordLifecycleForecastDiagnostics(telemetry, forecast, {\n97:       state: job.state,\n98:       progress: getIngestProgressPercent(job),\n99:       filesProcessed: job.filesProcessed,\n100:       filesTotal: job.filesTotal,\n101:     });\n102:     telemetryPayload = retrievalTelemetry.toJSON(telemetry);\n103:   }\n104: \n105:   return {\n106:     jobId: job.id,\n107:     state: job.state,\n108:     specFolder: job.specFolder,\n109:     paths: job.paths.map((entry) => toPublicPathLabel(entry)),\n110:     filesTotal: job.filesTotal,\n111:     filesProcessed: job.filesProcessed,\n112:     progress: getIngestProgressPercent(job),\n113:     errors: job.errors.map((entry) => ({\n114:       ...entry,\n115:       filePath: toPublicPathLabel(entry.filePath),\n116:     })),\n117:     createdAt: job.createdAt,\n118:     updatedAt: job.updatedAt,\n119:     forecast: forecast as unknown as Record<string, unknown>,\n120:     ...(telemetryPayload ? { _telemetry: telemetryPayload } : {}),\n121:   };\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    5. HANDLERS\n126: ──────────────────────────────────────────────────────────────── */\n127: \n128: /** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n129:  * @param args - Ingest arguments (paths, scope, options)\n130:  * @returns MCP response with job ID and forecast\n131:  */\n132: async function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n133:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n134:   await checkDatabaseUpdated();\n135:   const governedIngest = requiresGovernedIngest(args);\n136:   const governanceDecision = validateGovernedIngest(args);\n137:   if (!governanceDecision.allowed) {\n138:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n139:   }\n140: \n141:   let paths = Array.isArray(args.paths)\n142:     ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n143:     : [];\n144: \n145:   if (paths.length === 0) {\n146:     throw new Error('paths must be a non-empty array of file paths');\n147:   }\n148: \n149:   if (paths.length > MAX_INGEST_PATHS) {\n150:     throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n151:   }\n152: \n153:   const overlengthPaths = paths\n154:     .filter((entry) => entry.length > MAX_PATH_LENGTH)\n155:     .map((entry) => ({\n156:       filePath: toPublicPathLabel(entry),\n157:       reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n158:     }));\n159:   const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n160:   if (withinLength.length !== paths.length) {\n161:     console.warn(\n162:       `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n163:     );\n164:   }\n165:   paths = withinLength;\n166: \n167:   if (paths.length === 0) {\n168:     throw new Error('paths must be a non-empty array of file paths');\n169:   }\n170: \n171:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n172:   const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n173:     ? path.resolve(process.cwd(), configuredMemoryRoot)\n174:     : path.resolve(path.dirname(DATABASE_PATH));\n175:   const allowedBasePaths = Array.from(\n176:     new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n177:   );\n178: \n179:   const normalizedPaths: string[] = [];\n180:   const invalidPaths: Array<{ input: string; reason: string }> = [];\n181: \n182:   for (const inputPath of paths) {\n183:     const trimmedPath = inputPath.trim();\n184: \n185:     if (hasTraversalSegment(trimmedPath)) {\n186:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n187:       continue;\n188:     }\n189: \n190:     const resolvedPath = path.resolve(trimmedPath);\n191: \n192:     const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n193:     if (hasTraversalAfterResolve) {\n194:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n195:       continue;\n196:     }\n197: \n198:     // Resolve symlinks so traversal checks apply to canonical targets.\n199:     let realPath: string;\n200:     try {\n201:       realPath = fs.realpathSync(resolvedPath);\n202:     } catch {\n203:       // Fall back to resolvedPath during pre-validation when target does not yet exist.\n204:       realPath = resolvedPath;\n205:     }\n206: \n207:     const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n208:       realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n209:     ));\n210:     if (!isWithinAllowedBase) {\n211:       invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n212:       continue;\n213:     }\n214: \n215:     normalizedPaths.push(realPath);\n216:   }\n217: \n218:   if (invalidPaths.length > 0) {\n219:     return createMCPErrorResponse({\n220:       tool: 'memory_ingest_start',\n221:       error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n222:       code: 'E_VALIDATION',\n223:       details: {\n224:         allowedBasePathCount: allowedBasePaths.length,\n225:         allowedPathPolicy: 'configured-memory-roots',\n226:         rejectedCount: invalidPaths.length,\n227:       },\n228:       recovery: {\n229:         hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n230:         actions: ['Use absolute paths rooted in the configured memory base path'],\n231:         severity: 'warning',\n232:       },\n233:     });\n234:   }\n235: \n236:   const deduplicatedPaths: string[] = [];\n237:   const seenPaths = new Set<string>();\n238:   let duplicatePathCount = 0;\n239: \n240:   for (const normalizedPath of normalizedPaths) {\n241:     if (seenPaths.has(normalizedPath)) {\n242:       duplicatePathCount++;\n243:       continue;\n244:     }\n245: \n246:     seenPaths.add(normalizedPath);\n247:     deduplicatedPaths.push(normalizedPath);\n248:   }\n249: \n250:   paths = deduplicatedPaths;\n251: \n252:   const jobId = createJobId();\n253:   const job = await createIngestJob({\n254:     id: jobId,\n255:     paths,\n256:     specFolder: args.specFolder,\n257:     governance: governedIngest ? governanceDecision : null,\n258:   });\n259: \n260:   enqueueIngestJob(job.id);\n261: \n262:   return createMCPSuccessResponse({\n263:     tool: 'memory_ingest_start',\n264:     summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n265:     data: {\n266:       jobId: job.id,\n267:       state: job.state,\n268:       filesTotal: job.filesTotal,\n269:       acceptedPathCount: paths.length,\n270:       rejectedPathCount: overlengthPaths.length,\n271:       ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n272:       ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n273:     },\n274:     hints: [\n275:       'Use memory_ingest_status with jobId to poll progress',\n276:       'Use memory_ingest_cancel with jobId to stop processing',\n277:       ...(duplicatePathCount > 0\n278:         ? ['Duplicate input paths were deduplicated before queueing']\n279:         : []),\n280:       ...(overlengthPaths.length > 0\n281:         ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n282:         : []),\n283:     ],\n284:   });\n285: }\n286: \n287: async function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n288:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n289:   await checkDatabaseUpdated();\n290: \n291:   if (!args.jobId || typeof args.jobId !== 'string') {\n292:     throw new Error('jobId is required and must be a string');\n293:   }\n294: \n295:   const job = getIngestJob(args.jobId);\n296:   if (!job) {\n297:     return createMCPErrorResponse({\n298:       tool: 'memory_ingest_status',\n299:       error: `Ingest job not found: ${args.jobId}`,\n300:       code: 'E404',\n301:       details: { jobId: args.jobId },\n302:       recovery: {\n303:         hint: 'Verify the jobId and retry.',\n304:         actions: ['Call memory_ingest_start to create a new ingest job'],\n305:         severity: 'warning',\n306:       },\n307:     });\n308:   }\n309: \n310:   return createMCPSuccessResponse({\n311:     tool: 'memory_ingest_status',\n312:     summary: `Ingest job ${job.id}: ${job.state} (${job.filesProcessed}/${job.filesTotal})`,\n313:     data: mapJobForResponse(job),\n314:   });\n315: }\n316: \n317: async function handleMemoryIngestCancel(args: MemoryIngestCancelArgs): Promise<MCPResponse> {\n318:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_cancel');\n319:   await checkDatabaseUpdated();\n320: \n321:   if (!args.jobId || typeof args.jobId !== 'string') {\n322:     throw new Error('jobId is required and must be a string');\n323:   }\n324: \n325:   const job = getIngestJob(args.jobId);\n326:   if (!job) {\n327:     return createMCPErrorResponse({\n328:       tool: 'memory_ingest_cancel',\n329:       error: `Ingest job not found: ${args.jobId}`,\n330:       code: 'E404',\n331:       details: { jobId: args.jobId },\n332:       recovery: {\n333:         hint: 'Verify the jobId and retry.',\n334:         actions: ['Call memory_ingest_status with a known jobId'],\n335:         severity: 'warning',\n336:       },\n337:     });\n338:   }\n339: \n340:   if (job.state === 'complete' || job.state === 'failed' || job.state === 'cancelled') {\n341:     return createMCPSuccessResponse({\n342:       tool: 'memory_ingest_cancel',\n343:       summary: `Ingest job ${job.id} is already terminal (${job.state})`,\n344:       data: mapJobForResponse(job),\n345:     });\n346:   }\n347: \n348:   const cancelled = await cancelIngestJob(args.jobId);\n349:   const summary = cancelled.state === 'cancelled'\n350:     ? `Cancelled ingest job ${cancelled.id}`\n351:     : `Ingest job ${cancelled.id} is already terminal (${cancelled.state})`;\n352: \n353:   return createMCPSuccessResponse({\n354:     tool: 'memory_ingest_cancel',\n355:     summary,\n356:     data: mapJobForResponse(cancelled),\n357:   });\n358: }\n359: \n360: /* ───────────────────────────────────────────────────────────────\n361:    6. EXPORTS\n362: ──────────────────────────────────────────────────────────────── */\n363: \n364: const handle_memory_ingest_start = handleMemoryIngestStart;\n365: const handle_memory_ingest_status = handleMemoryIngestStatus;\n366: const handle_memory_ingest_cancel = handleMemoryIngestCancel;\n367: \n368: export {\n369:   handleMemoryIngestStart,\n370:   handleMemoryIngestStatus,\n371:   handleMemoryIngestCancel,\n372:   handle_memory_ingest_start,\n373:   handle_memory_ingest_status,\n374:   handle_memory_ingest_cancel,\n375: };\n\n(End of file - total 375 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Ingest Handlers\n// ───────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\n\nimport { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\nimport { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  createIngestJob,\n  enqueueIngestJob,\n  getIngestJob,\n  cancelIngestJob,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Ingest Handlers\n// ───────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\n\nimport { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\nimport { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  createIngestJob,\n  enqueueIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  getIngestProgressPercent,\n  getIngestForecast,\n  type IngestJob,\n} from '../lib/ops/job-queue.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { createJobId } from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Async ingestion job lifecycle\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface MemoryIngestStartArgs {\n  paths: string[];\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\ninterface MemoryIngestStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIngestCancelArgs {\n  jobId: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst MAX_PATH_LENGTH = 500;\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction hasTraversalSegment(inputPath: string): boolean {\n  return inputPath.split(/[\\\\/]+/).includes('..');\n}\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction mapJobForResponse(job: IngestJob): Record<string, unknown> {\n  let forecast: Record<string, unknown>;\n  try {\n    forecast = getIngestForecast(job) as unknown as Record<string, unknown>;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    forecast = {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals: [],\n      caveat: `Forecast unavailable: ${message}`,\n    };\n  }\n\n  let telemetryPayload: Record<string, unknown> | undefined;\n  if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n    const telemetry = retrievalTelemetry.createTelemetry();\n    retrievalTelemetry.recordLifecycleForecastDiagnostics(telemetry, forecast, {\n      state: job.state,\n      progress: getIngestProgressPercent(job),\n      filesProcessed: job.filesProcessed,\n      filesTotal: job.filesTotal,\n    });\n    telemetryPayload = retrievalTelemetry.toJSON(telemetry);\n  }\n\n  return {\n    jobId: job.id,\n    state: job.state,\n    specFolder: job.specFolder,\n    paths: job.paths.map((entry) => toPublicPathLabel(entry)),\n    filesTotal: job.filesTotal,\n    filesProcessed: job.filesProcessed,\n    progress: getIngestProgressPercent(job),\n    errors: job.errors.map((entry) => ({\n      ...entry,\n      filePath: toPublicPathLabel(entry.filePath),\n    })),\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n    forecast: forecast as unknown as Record<string, unknown>,\n    ...(telemetryPayload ? { _telemetry: telemetryPayload } : {}),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. HANDLERS\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n * @param args - Ingest arguments (paths, scope, options)\n * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  if (paths.length > MAX_INGEST_PATHS) {\n    throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n  }\n\n  const overlengthPaths = paths\n    .filter((entry) => entry.length > MAX_PATH_LENGTH)\n    .map((entry) => ({\n      filePath: toPublicPathLabel(entry),\n      reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n    }));\n  const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n  if (withinLength.length !== paths.length) {\n    console.warn(\n      `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n    );\n  }\n  paths = withinLength;\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n  const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n    ? path.resolve(process.cwd(), configuredMemoryRoot)\n    : path.resolve(path.dirname(DATABASE_PATH));\n  const allowedBasePaths = Array.from(\n    new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n  );\n\n  const normalizedPaths: string[] = [];\n  const invalidPaths: Array<{ input: string; reason: string }> = [];\n\n  for (const inputPath of paths) {\n    const trimmedPath = inputPath.trim();\n\n    if (hasTraversalSegment(trimmedPath)) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    const resolvedPath = path.resolve(trimmedPath);\n\n    const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n    if (hasTraversalAfterResolve) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    // Resolve symlinks so traversal checks apply to canonical targets.\n    let realPath: string;\n    try {\n      realPath = fs.realpathSync(resolvedPath);\n    } catch {\n      // Fall back to resolvedPath during pre-validation when target does not yet exist.\n      realPath = resolvedPath;\n    }\n\n    const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n      realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n    ));\n    if (!isWithinAllowedBase) {\n      invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n      continue;\n    }\n\n    normalizedPaths.push(realPath);\n  }\n\n  if (invalidPaths.length > 0) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_start',\n      error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n      code: 'E_VALIDATION',\n      details: {\n        allowedBasePathCount: allowedBasePaths.length,\n        allowedPathPolicy: 'configured-memory-roots',\n        rejectedCount: invalidPaths.length,\n      },\n      recovery: {\n        hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n        actions: ['Use absolute paths rooted in the configured memory base path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const deduplicatedPaths: string[] = [];\n  const seenPaths = new Set<string>();\n  let duplicatePathCount = 0;\n\n  for (const normalizedPath of normalizedPaths) {\n    if (seenPaths.has(normalizedPath)) {\n      duplicatePathCount++;\n      continue;\n    }\n\n    seenPaths.add(normalizedPath);\n    deduplicatedPaths.push(normalizedPath);\n  }\n\n  paths = deduplicatedPaths;\n\n  const jobId = createJobId();\n  const job = await createIngestJob({\n    id: jobId,\n    paths,\n    specFolder: args.specFolder,\n    governance: governedIngest ? governanceDecision : null,\n  });\n\n  enqueueIngestJob(job.id);\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_start',\n    summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n    data: {\n      jobId: job.id,\n      state: job.state,\n      filesTotal: job.filesTotal,\n      acceptedPathCount: paths.length,\n      rejectedPathCount: overlengthPaths.length,\n      ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n      ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n    },\n    hints: [\n      'Use memory_ingest_status with jobId to poll progress',\n      'Use memory_ingest_cancel with jobId to stop processing',\n      ...(duplicatePathCount > 0\n        ? ['Duplicate input paths were deduplicated before queueing']\n        : []),\n      ...(overlengthPaths.length > 0\n        ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n        : []),\n    ],\n  });\n}\n\nasync function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getIngestJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_status',\n      error: `Ingest job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_ingest_start to create a new ingest job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_status',\n    summary: `Ingest job ${job.id}: ${job.state} (${job.filesProcessed}/${job.filesTotal})`,\n    data: mapJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIngestCancel(args: MemoryIngestCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getIngestJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_cancel',\n      error: `Ingest job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_ingest_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (job.state === 'complete' || job.state === 'failed' || job.state === 'cancelled') {\n    return createMCPSuccessResponse({\n      tool: 'memory_ingest_cancel',\n      summary: `Ingest job ${job.id} is already terminal (${job.state})`,\n      data: mapJobForResponse(job),\n    });\n  }\n\n  const cancelled = await cancelIngestJob(args.jobId);\n  const summary = cancelled.state === 'cancelled'\n    ? `Cancelled ingest job ${cancelled.id}`\n    : `Ingest job ${cancelled.id} is already terminal (${cancelled.state})`;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_cancel',\n    summary,\n    data: mapJobForResponse(cancelled),\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nconst handle_memory_ingest_start = handleMemoryIngestStart;\nconst handle_memory_ingest_status = handleMemoryIngestStatus;\nconst handle_memory_ingest_cancel = handleMemoryIngestCancel;\n\nexport {\n  handleMemoryIngestStart,\n  handleMemoryIngestStatus,\n  handleMemoryIngestCancel,\n  handle_memory_ingest_start,\n  handle_memory_ingest_status,\n  handle_memory_ingest_cancel,\n};","lineStart":1,"lineEnd":375,"totalLines":375,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","time":{"start":1781763537151,"end":1781763537156}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e94481919defac3787d1fa78"}},"id":"prt_ed961f899001HJT5fkvOE0zxvh","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537167,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_Pa5wVmjeK98hMVn34LJ9TXu6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Atomic Index Memory\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import { randomUUID } from 'node:crypto';\n8: \n9: import * as transactionManager from '../../lib/storage/transaction-manager.js';\n10: \n11: import type {\n12:   AtomicSaveOptions,\n13:   AtomicSaveParams,\n14:   AtomicSaveResult,\n15:   IndexResult,\n16: } from './types.js';\n17: import { withSpecFolderLock } from './spec-folder-mutex.js';\n18: \n19: // Feature catalog: Memory indexing (memory_save)\n20: // Feature catalog: Atomic-save parity and partial-indexing hints\n21: \n22: interface AtomicIndexOriginalState {\n23:   existed: boolean;\n24:   content: string | null;\n25: }\n26: \n27: interface AtomicIndexPendingCleanupResult {\n28:   cleaned: boolean;\n29:   existed: boolean;\n30:   error?: string;\n31: }\n32: \n33: interface AtomicIndexRestoreResult {\n34:   restored: boolean;\n35:   error?: string;\n36: }\n37: \n38: export interface AtomicIndexReady<TPrepared = unknown> {\n39:   status: 'ready';\n40:   prepared: TPrepared;\n41:   specFolder: string;\n42:   persistedContent?: string;\n43:   persistedFilePath?: string;\n44: }\n45: \n46: export interface AtomicIndexTerminal {\n47:   status: 'abort' | 'rejected';\n48:   result: AtomicSaveResult;\n49: }\n50: \n51: export type AtomicIndexPreparation<TPrepared = unknown> =\n52:   | AtomicIndexReady<TPrepared>\n53:   | AtomicIndexTerminal;\n54: \n55: export interface AtomicIndexAttemptContext {\n56:   attempt: number;\n57:   force: boolean;\n58: }\n59: \n60: export interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n61:   params: AtomicSaveParams;\n62:   ready: AtomicIndexReady<TPrepared>;\n63:   specFolderLockAlreadyHeld: true;\n64: }\n65: \n66: export interface AtomicIndexDependencies<TPrepared = unknown> {\n67:   prepare: (\n68:     params: AtomicSaveParams,\n69:     context: AtomicIndexAttemptContext,\n70:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n71:   prepareLocked?: (\n72:     context: AtomicIndexLockedContext<TPrepared>,\n73:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n74:   indexPrepared: (\n75:     context: AtomicIndexLockedContext<TPrepared>,\n76:   ) => Promise<IndexResult> | IndexResult;\n77:   mapSuccessResult?: (\n78:     indexResult: IndexResult,\n79:     context: AtomicIndexLockedContext<TPrepared>,\n80:   ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n81:   maxIndexAttempts?: number;\n82:   getPendingPath?: (filePath: string) => string;\n83:   withSpecFolderLock?: typeof withSpecFolderLock;\n84:   captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n85:   restoreOriginalState?: (\n86:     filePath: string,\n87:     originalState: AtomicIndexOriginalState,\n88:   ) => AtomicIndexRestoreResult;\n89:   cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n90:   writePendingFile?: (pendingPath: string, content: string) => void;\n91:   promotePendingFile?: (pendingPath: string, filePath: string) => void;\n92: }\n93: \n94: function toErrorMessage(error: unknown): string {\n95:   return error instanceof Error ? error.message : String(error);\n96: }\n97: \n98: function deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n99:   const existed = fs.existsSync(filePath);\n100:   if (!existed) {\n101:     return { deleted: false, existed: false };\n102:   }\n103: \n104:   try {\n105:     fs.unlinkSync(filePath);\n106:     return { deleted: true, existed: true };\n107:   } catch (error: unknown) {\n108:     return {\n109:       deleted: false,\n110:       existed: true,\n111:       error: toErrorMessage(error),\n112:     };\n113:   }\n114: }\n115: \n116: function captureOriginalState(filePath: string): AtomicIndexOriginalState {\n117:   if (!fs.existsSync(filePath)) {\n118:     return { existed: false, content: null };\n119:   }\n120: \n121:   return {\n122:     existed: true,\n123:     content: fs.readFileSync(filePath, 'utf-8'),\n124:   };\n125: }\n126: \n127: function restoreOriginalState(\n128:   filePath: string,\n129:   originalState: AtomicIndexOriginalState,\n130: ): AtomicIndexRestoreResult {\n131:   try {\n132:     if (!originalState.existed) {\n133:       const deleteResult = deleteFileIfPresent(filePath);\n134:       if (!deleteResult.existed || deleteResult.deleted) {\n135:         return { restored: true };\n136:       }\n137:       return {\n138:         restored: false,\n139:         error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n140:       };\n141:     }\n142: \n143:     if (typeof originalState.content !== 'string') {\n144:       return { restored: false, error: 'Original file content is unavailable for rollback' };\n145:     }\n146: \n147:     fs.mkdirSync(path.dirname(filePath), { recursive: true });\n148:     fs.writeFileSync(filePath, originalState.content, 'utf-8');\n149:     return { restored: true };\n150:   } catch (error: unknown) {\n151:     return {\n152:       restored: false,\n153:       error: toErrorMessage(error),\n154:     };\n155:   }\n156: }\n157: \n158: function cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n159:   const deleteResult = deleteFileIfPresent(pendingPath);\n160:   if (!deleteResult.existed || deleteResult.deleted) {\n161:     return {\n162:       cleaned: true,\n163:       existed: deleteResult.existed,\n164:     };\n165:   }\n166:   return {\n167:     cleaned: false,\n168:     existed: deleteResult.existed,\n169:     error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n170:   };\n171: }\n172: \n173: function writePendingFile(pendingPath: string, content: string): void {\n174:   fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n175:   fs.writeFileSync(pendingPath, content, 'utf-8');\n176: }\n177: \n178: function promotePendingFile(pendingPath: string, filePath: string): void {\n179:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n180:   fs.renameSync(pendingPath, filePath);\n181: }\n182: \n183: function defaultPendingPath(filePath: string): string {\n184:   const basePendingPath = transactionManager.getPendingPath(filePath);\n185:   return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n186: }\n187: \n188: function buildRejectedResult(\n189:   filePath: string,\n190:   indexResult: IndexResult,\n191:   rollbackSucceeded: boolean,\n192:   errorMetadata: Record<string, string> | null,\n193: ): AtomicSaveResult {\n194:   return {\n195:     success: false,\n196:     filePath,\n197:     status: 'rejected',\n198:     id: indexResult.id,\n199:     specFolder: indexResult.specFolder,\n200:     title: indexResult.title,\n201:     summary: rollbackSucceeded\n202:       ? 'Atomic index rejected before file promotion'\n203:       : 'Atomic index rejected but pending file cleanup failed',\n204:     message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n205:     embeddingStatus: indexResult.embeddingStatus,\n206:     hints: [\n207:       rollbackSucceeded\n208:         ? 'Pending file was removed because the save was rejected before promotion'\n209:         : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n210:     ],\n211:     ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n212:     ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n213:   };\n214: }\n215: \n216: function buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n217:   const message = indexResult.message ?? (\n218:     indexResult.status === 'duplicate'\n219:       ? 'Memory skipped (duplicate content)'\n220:       : `Memory ${indexResult.status} successfully`\n221:   );\n222: \n223:   const hints: string[] = [];\n224:   if (indexResult.embeddingStatus === 'pending') {\n225:     hints.push('Memory will be fully indexed when embedding provider becomes available');\n226:   }\n227:   if (indexResult.embeddingStatus === 'partial') {\n228:     hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n229:   }\n230: \n231:   const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n232: \n233:   return {\n234:     success: true,\n235:     filePath,\n236:     status: indexResult.status,\n237:     id: indexResult.id,\n238:     specFolder: indexResult.specFolder,\n239:     title: indexResult.title,\n240:     summary: message,\n241:     message,\n242:     embeddingStatus: indexResult.embeddingStatus,\n243:     ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n244:       ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n245:       : {}),\n246:     ...(hints.length > 0 ? { hints } : {}),\n247:   };\n248: }\n249: \n250: function buildRetryFailureResult(\n251:   filePath: string,\n252:   indexError: Error | null,\n253:   rollbackSucceeded: boolean,\n254:   errorMetadata: Record<string, string> | null,\n255: ): AtomicSaveResult {\n256:   const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n257:   const finalErrorMetadata = errorMetadata ?? {};\n258: \n259:   return {\n260:     success: false,\n261:     filePath,\n262:     status: 'error',\n263:     summary: rollbackSucceeded\n264:       ? 'Atomic index failed after retry and restored original file state'\n265:       : 'Atomic index failed after retry and rollback was incomplete',\n266:     message: indexError?.message ?? 'Indexing failed after retry',\n267:     hints: [\n268:       rollbackSucceeded\n269:         ? 'Original file content was preserved or restored because indexing failed before completion'\n270:         : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n271:       'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n272:     ],\n273:     error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n274:     ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n275:   };\n276: }\n277: \n278: export async function atomicIndexMemory<TPrepared = unknown>(\n279:   params: AtomicSaveParams,\n280:   options: AtomicSaveOptions = {},\n281:   dependencies: AtomicIndexDependencies<TPrepared>,\n282: ): Promise<AtomicSaveResult> {\n283:   const { file_path, content } = params;\n284:   const { force = false } = options;\n285: \n286:   const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n287: \n288:   let indexResult: IndexResult | null = null;\n289:   let indexError: Error | null = null;\n290:   let restoredOriginalAfterFailure = false;\n291:   let anyPromotionAttempted = false;\n292:   let errorMetadata: Record<string, string> | null = null;\n293:   let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n294:   let lastEffectiveFilePath = file_path;\n295:   let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n296: \n297:   const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n298:     if (!entry) {\n299:       return;\n300:     }\n301:     errorMetadata = {\n302:       ...(errorMetadata ?? {}),\n303:       ...entry,\n304:     };\n305:   };\n306: \n307:   for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n308:     let promotedToFinalPath = false;\n309:     let handledFailureWhileLocked = false;\n310:     let rollbackSucceededAfterRejectedSave = false;\n311:     let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n312: \n313:     try {\n314:       const prepared = await dependencies.prepare(params, { attempt, force });\n315:       if (prepared.status !== 'ready') {\n316:         return prepared.result;\n317:       }\n318: \n319:       const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n320:       const lockedResult = await runWithLock(prepared.specFolder, async () => {\n321:         let effectiveFilePath = lastEffectiveFilePath;\n322:         let pendingPath = lastPendingPath;\n323:         let originalState: AtomicIndexOriginalState | null = null;\n324:         try {\n325:           let ready = prepared;\n326:           lockedContext = {\n327:             attempt,\n328:             force,\n329:             params,\n330:             ready,\n331:             specFolderLockAlreadyHeld: true,\n332:           };\n333: \n334:           if (dependencies.prepareLocked) {\n335:             const preparedLocked = await dependencies.prepareLocked(lockedContext);\n336:             if (preparedLocked.status !== 'ready') {\n337:               return {\n338:                 kind: 'terminal',\n339:                 result: preparedLocked.result,\n340:               } as const;\n341:             }\n342: \n343:             ready = preparedLocked;\n344:             lockedContext = {\n345:               attempt,\n346:               force,\n347:               params,\n348:               ready,\n349:               specFolderLockAlreadyHeld: true,\n350:             };\n351:           }\n352: \n353:           effectiveFilePath = ready.persistedFilePath ?? file_path;\n354:           const persistedContent = ready.persistedContent ?? content;\n355:           pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n356:           originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n357:           lastEffectiveFilePath = effectiveFilePath;\n358:           lastPendingPath = pendingPath;\n359: \n360:           (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n361: \n362:           const lockedIndexResult = await dependencies.indexPrepared(lockedContext);\n363: \n364:           if (lockedIndexResult.status === 'rejected') {\n365:             handledFailureWhileLocked = true;\n366:             const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n367:             rollbackSucceededAfterRejectedSave = pendingCleanupResult.cleaned;\n368:             if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n369:               mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n370:             }\n371:             return {\n372:               kind: 'indexed',\n373:               indexResult: lockedIndexResult,\n374:               context: lockedContext,\n375:             } as const;\n376:           }\n377: \n378:           (dependencies.promotePendingFile ?? promotePendingFile)(pendingPath, effectiveFilePath);\n379:           promotedToFinalPath = true;\n380:           anyPromotionAttempted = true;\n381: \n382:           return {\n383:             kind: 'indexed',\n384:             indexResult: lockedIndexResult,\n385:             context: lockedContext,\n386:           } as const;\n387:         } catch (lockedError: unknown) {\n388:           handledFailureWhileLocked = true;\n389:           const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n390:           if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n391:             mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n392:           }\n393: \n394:           if (promotedToFinalPath) {\n395:             const rollbackResult = (dependencies.restoreOriginalState ?? restoreOriginalState)(\n396:               effectiveFilePath,\n397:               originalState ?? captureOriginalState(effectiveFilePath),\n398:             );\n399:             restoredOriginalAfterFailure = rollbackResult.restored;\n400:             if (!rollbackResult.restored && rollbackResult.error) {\n401:               mergeErrorMetadata({ rollbackError: rollbackResult.error });\n402:             }\n403:             if (!restoredOriginalAfterFailure) {\n404:               const message = toErrorMessage(lockedError);\n405:               throw new Error(`Original file rollback failed after promote-before-index path: ${message}`);\n406:             }\n407:           }\n408: \n409:           throw lockedError;\n410:         }\n411:       });\n412: \n413:       if (lockedResult.kind === 'terminal') {\n414:         return lockedResult.result;\n415:       }\n416: \n417:       indexResult = lockedResult.indexResult;\n418: \n419:       if (indexResult.status === 'error') {\n420:         throw new Error(indexResult.message ?? indexResult.error ?? 'atomicIndexMemory indexPrepared returned status=error');\n421:       }\n422: \n423:       if (indexResult.status === 'rejected') {\n424:         return buildRejectedResult(lastEffectiveFilePath, indexResult, rollbackSucceededAfterRejectedSave, errorMetadata);\n425:       }\n426: \n427:       successfulLockedContext = lockedResult.context;\n428:       indexError = null;\n429:       break;\n430:     } catch (error: unknown) {\n431:       if (!handledFailureWhileLocked) {\n432:         const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(lastPendingPath);\n433:         if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n434:           mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n435:         }\n436:       }\n437:       indexError = error instanceof Error ? error : new Error(toErrorMessage(error));\n438:       if (attempt === maxIndexAttempts) {\n439:         break;\n440:       }\n441:     }\n442:   }\n443: \n444:   if (!indexResult || indexError) {\n445:     return buildRetryFailureResult(\n446:       lastEffectiveFilePath,\n447:       indexError,\n448:       anyPromotionAttempted ? restoredOriginalAfterFailure : true,\n449:       errorMetadata,\n450:     );\n451:   }\n452: \n453:   if (dependencies.mapSuccessResult && successfulLockedContext) {\n454:     return await dependencies.mapSuccessResult(indexResult, successfulLockedContext);\n455:   }\n456: \n457:   return buildSuccessResult(successfulLockedContext?.ready.persistedFilePath ?? file_path, indexResult);\n458: }\n459: \n460: const atomic_index_memory = atomicIndexMemory;\n461: \n462: export { atomic_index_memory };\n\n(End of file - total 462 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\ninterface AtomicIndexOriginalState {\n  existed: boolean;\n  content: string | null;\n}\n\ninterface AtomicIndexPendingCleanupResult {\n  cleaned: boolean;\n  existed: boolean;\n  error?: string;\n}\n\ninterface AtomicIndexRestoreResult {\n  restored: boolean;\n  error?: string;\n}\n\nexport interface AtomicIndexReady<TPrepared = unknown> {\n  status: 'ready';\n  prepared: TPrepared;\n  specFolder: string;\n  persistedContent?: string;\n  persistedFilePath?: string;\n}\n\nexport interface AtomicIndexTerminal {\n  status: 'abort' | 'rejected';\n  result: AtomicSaveResult;\n}\n\nexport type AtomicIndexPreparation<TPrepared = unknown> =\n  | AtomicIndexReady<TPrepared>\n  | AtomicIndexTerminal;\n\nexport interface AtomicIndexAttemptContext {\n  attempt: number;\n  force: boolean;\n}\n\nexport interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n  params: AtomicSaveParams;\n  ready: AtomicIndexReady<TPrepared>;\n  specFolderLockAlreadyHeld: true;\n}\n\nexport interface AtomicIndexDependencies<TPrepared = unknown> {\n  prepare: (\n    params: AtomicSaveParams,\n    context: AtomicIndexAttemptContext,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  prepareLocked?: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  indexPrepared: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<IndexResult> | IndexResult;\n  mapSuccessResult?: (\n    indexResult: IndexResult,\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n  maxIndexAttempts?: number;\n  getPendingPath?: (filePath: string) => string;\n  withSpecFolderLock?: typeof withSpecFolderLock;\n  captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n  restoreOriginalState?: (\n    filePath: string,\n    originalState: AtomicIndexOriginalState,\n  ) => AtomicIndexRestoreResult;\n  cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n  writePendingFile?: (pendingPath: string, content: string) => void;\n  promotePendingFile?: (pendingPath: string, filePath: string) => void;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n  const existed = fs.existsSync(filePath);\n  if (!existed) {\n    return { deleted: false, existed: false };\n  }\n\n  try {\n    fs.unlinkSync(filePath);\n    return { deleted: true, existed: true };\n  } catch (error: unknown) {\n    return {\n      deleted: false,\n      existed: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction captureOriginalState(filePath: string): AtomicIndexOriginalState {\n  if (!fs.existsSync(filePath)) {\n    return { existed: false, content: null };\n  }\n\n  return {\n    existed: true,\n    content: fs.readFileSync(filePath, 'utf-8'),\n  };\n}\n\nfunction restoreOriginalState(\n  filePath: string,\n  originalState: AtomicIndexOriginalState,\n): AtomicIndexRestoreResult {\n  try {\n    if (!originalState.existed) {\n      const deleteResult = deleteFileIfPresent(filePath);\n      if (!deleteResult.existed || deleteResult.deleted) {\n        return { restored: true };\n      }\n      return {\n        restored: false,\n        error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n      };\n    }\n\n    if (typeof originalState.content !== 'string') {\n      return { restored: false, error: 'Original file content is unavailable for rollback' };\n    }\n\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, originalState.content, 'utf-8');\n    return { restored: true };\n  } catch (error: unknown) {\n    return {\n      restored: false,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n  const deleteResult = deleteFileIfPresent(pendingPath);\n  if (!deleteResult.existed || deleteResult.deleted) {\n    return {\n      cleaned: true,\n      existed: deleteResult.existed,\n    };\n  }\n  return {\n    cleaned: false,\n    existed: deleteResult.existed,\n    error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n  };\n}\n\nfunction writePendingFile(pendingPath: string, content: string): void {\n  fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n  fs.writeFileSync(pendingPath, content, 'utf-8');\n}\n\nfunction promotePendingFile(pendingPath: string, filePath: string): void {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.renameSync(pendingPath, filePath);\n}\n\nfunction defaultPendingPath(filePath: string): string {\n  const basePendingPath = transactionManager.getPendingPath(filePath);\n  return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n}\n\nfunction buildRejectedResult(\n  filePath: string,\n  indexResult: IndexResult,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  return {\n    success: false,\n    filePath,\n    status: 'rejected',\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: rollbackSucceeded\n      ? 'Atomic index rejected before file promotion'\n      : 'Atomic index rejected but pending file cleanup failed',\n    message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n    embeddingStatus: indexResult.embeddingStatus,\n    hints: [\n      rollbackSucceeded\n        ? 'Pending file was removed because the save was rejected before promotion'\n        : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n    ],\n    ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n    ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n  };\n}\n\nfunction buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n  const message = indexResult.message ?? (\n    indexResult.status === 'duplicate'\n      ? 'Memory skipped (duplicate content)'\n      : `Memory ${indexResult.status} successfully`\n  );\n\n  const hints: string[] = [];\n  if (indexResult.embeddingStatus === 'pending') {\n    hints.push('Memory will be fully indexed when embedding provider becomes available');\n  }\n  if (indexResult.embeddingStatus === 'partial') {\n    hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n  }\n\n  const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n\n  return {\n    success: true,\n    filePath,\n    status: indexResult.status,\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: message,\n    message,\n    embeddingStatus: indexResult.embeddingStatus,\n    ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n      ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n      : {}),\n    ...(hints.length > 0 ? { hints } : {}),\n  };\n}\n\nfunction buildRetryFailureResult(\n  filePath: string,\n  indexError: Error | null,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n  const finalErrorMetadata = errorMetadata ?? {};\n\n  return {\n    success: false,\n    filePath,\n    status: 'error',\n    summary: rollbackSucceeded\n      ? 'Atomic index failed after retry and restored original file state'\n      : 'Atomic index failed after retry and rollback was incomplete',\n    message: indexError?.message ?? 'Indexing failed after retry',\n    hints: [\n      rollbackSucceeded\n        ? 'Original file content was preserved or restored because indexing failed before completion'\n        : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n      'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n    ],\n    error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n    ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n  };\n}\n\nexport async function atomicIndexMemory<TPrepared = unknown>(\n  params: AtomicSaveParams,\n  options: AtomicSaveOptions = {},\n  dependencies: AtomicIndexDependencies<TPrepared>,\n): Promise<AtomicSaveResult> {\n  const { file_path, content } = params;\n  const { force = false } = options;\n\n  const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n\n  let indexResult: IndexResult | null = null;\n  let indexError: Error | null = null;\n  let restoredOriginalAfterFailure = false;\n  let anyPromotionAttempted = false;\n  let errorMetadata: Record<string, string> | null = null;\n  let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n  let lastEffectiveFilePath = file_path;\n  let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n\n  const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n    if (!entry) {\n      return;\n    }\n    errorMetadata = {\n      ...(errorMetadata ?? {}),\n      ...entry,\n    };\n  };\n\n  for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n    let promotedToFinalPath = false;\n    let handledFailureWhileLocked = false;\n    let rollbackSucceededAfterRejectedSave = false;\n    let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n\n    try {\n      const prepared = await dependencies.prepare(params, { attempt, force });\n      if (prepared.status !== 'ready') {\n        return prepared.result;\n      }\n\n      const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n      const lockedResult = await runWithLock(prepared.specFolder, async () => {\n        let effectiveFilePath = lastEffectiveFilePath;\n        let pendingPath = lastPendingPath;\n        let originalState: AtomicIndexOriginalState | null = null;\n        try {\n          let ready = prepared;\n          lockedContext = {\n            attempt,\n            force,\n            params,\n            ready,\n            specFolderLockAlreadyHeld: true,\n          };\n\n          if (dependencies.prepareLocked) {\n            const preparedLocked = await dependencies.prepareLocked(lockedContext);\n            if (preparedLocked.status !== 'ready') {\n              return {\n                kind: 'terminal',\n                result: preparedLocked.result,\n              } as const;\n            }\n\n            ready = preparedLocked;\n            lockedContext = {\n              attempt,\n              force,\n              params,\n              ready,\n              specFolderLockAlreadyHeld: true,\n            };\n          }\n\n          effectiveFilePath = ready.persistedFilePath ?? file_path;\n          const persistedContent = ready.persistedContent ?? content;\n          pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n          originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n          lastEffectiveFilePath = effectiveFilePath;\n          lastPendingPath = pendingPath;\n\n          (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n\n          const lockedIndexResult = await dependencies.indexPrepared(lockedContext);\n\n          if (lockedIndexResult.status === 'rejected') {\n            handledFailureWhileLocked = true;\n            const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n            rollbackSucceededAfterRejectedSave = pendingCleanupResult.cleaned;\n            if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n              mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n            }\n            return {\n              kind: 'indexed',\n              indexResult: lockedIndexResult,\n              context: lockedContext,\n            } as const;\n          }\n\n          (dependencies.promotePendingFile ?? promotePendingFile)(pendingPath, effectiveFilePath);\n          promotedToFinalPath = true;\n          anyPromotionAttempted = true;\n\n          return {\n            kind: 'indexed',\n            indexResult: lockedIndexResult,\n            context: lockedContext,\n          } as const;\n        } catch (lockedError: unknown) {\n          handledFailureWhileLocked = true;\n          const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n          if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n            mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n          }\n\n          if (promotedToFinalPath) {\n            const rollbackResult = (dependencies.restoreOriginalState ?? restoreOriginalState)(\n              effectiveFilePath,\n              originalState ?? captureOriginalState(effectiveFilePath),\n            );\n            restoredOriginalAfterFailure = rollbackResult.restored;\n            if (!rollbackResult.restored && rollbackResult.error) {\n              mergeErrorMetadata({ rollbackError: rollbackResult.error });\n            }\n            if (!restoredOriginalAfterFailure) {\n              const message = toErrorMessage(lockedError);\n              throw new Error(`Original file rollback failed after promote-before-index path: ${message}`);\n            }\n          }\n\n          throw lockedError;\n        }\n      });\n\n      if (lockedResult.kind === 'terminal') {\n        return lockedResult.result;\n      }\n\n      indexResult = lockedResult.indexResult;\n\n      if (indexResult.status === 'error') {\n        throw new Error(indexResult.message ?? indexResult.error ?? 'atomicIndexMemory indexPrepared returned status=error');\n      }\n\n      if (indexResult.status === 'rejected') {\n        return buildRejectedResult(lastEffectiveFilePath, indexResult, rollbackSucceededAfterRejectedSave, errorMetadata);\n      }\n\n      successfulLockedContext = lockedResult.context;\n      indexError = null;\n      break;\n    } catch (error: unknown) {\n      if (!handledFailureWhileLocked) {\n        const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(lastPendingPath);\n        if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n          mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n        }\n      }\n      indexError = error instanceof Error ? error : new Error(toErrorMessage(error));\n      if (attempt === maxIndexAttempts) {\n        break;\n      }\n    }\n  }\n\n  if (!indexResult || indexError) {\n    return buildRetryFailureResult(\n      lastEffectiveFilePath,\n      indexError,\n      anyPromotionAttempted ? restoredOriginalAfterFailure : true,\n      errorMetadata,\n    );\n  }\n\n  if (dependencies.mapSuccessResult && successfulLockedContext) {\n    return await dependencies.mapSuccessResult(indexResult, successfulLockedContext);\n  }\n\n  return buildSuccessResult(successfulLockedContext?.ready.persistedFilePath ?? file_path, indexResult);\n}\n\nconst atomic_index_memory = atomicIndexMemory;\n\nexport { atomic_index_memory };","lineStart":1,"lineEnd":462,"totalLines":462,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","time":{"start":1781763537157,"end":1781763537161}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e94c81918b77f37712143f06"}},"id":"prt_ed961f900001VRWmOIJjDt28M3","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537170,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_rj9wBwtlrilKcvRDAJLpl59a","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Create Record\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import * as vectorIndex from '../../lib/search/vector-index.js';\n8: import * as bm25Index from '../../lib/search/bm25-index.js';\n9: import * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\n10: import * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\n11: import * as incrementalIndex from '../../lib/storage/incremental-index.js';\n12: import * as causalEdges from '../../lib/storage/causal-edges.js';\n13: import type * as memoryParser from '../../lib/parsing/memory-parser.js';\n14: import { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\n15: import { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\n16: import { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\n17: import { toErrorMessage } from '../../utils/index.js';\n18: \n19: import { recordHistory } from '../../lib/storage/history.js';\n20: import { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';\n21: import { detectSpecLevelFromParsed } from '../handler-utils.js';\n22: import { classifyEncodingIntent } from '../../lib/search/encoding-intent.js';\n23: import { isEncodingIntentEnabled } from '../../lib/search/search-flags.js';\n24: import { applyPostInsertMetadata } from './db-helpers.js';\n25: import { inferDocumentTypeFromPath } from '../../lib/config/memory-types.js';\n26: import {\n27:   applyWriteProvenance,\n28:   deriveSourceKindFromContext,\n29:   normalizeSourceKind,\n30:   persistSourceKind,\n31:   type SourceKind,\n32:   type WriteProvenanceContext,\n33: } from '../../lib/storage/write-provenance.js';\n34: \n35: // Feature catalog: Memory indexing (memory_save)\n36: // Feature catalog: Per-memory history log\n37: // Feature catalog: Prediction-error save arbitration\n38: \n39: \n40: import type { PeDecision, MemoryScopeMatch } from './types.js';\n41: import { normalizeScopeMatchValue } from './types.js';\n42: export type { MemoryScopeMatch };\n43: \n44: export const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n45: \n46: export interface CreateRecordIdentityHints {\n47:   targetDocPath?: string | null;\n48:   canonicalFilePath?: string | null;\n49:   targetAnchorId?: string | null;\n50:   routeAs?: string | null;\n51:   continuitySourceKey?: string | null;\n52: }\n53: \n54: export interface ResolvedCreateRecordIdentity {\n55:   targetDocPath: string;\n56:   canonicalFilePath: string;\n57:   targetAnchorId: string | null;\n58:   routeAs: string | null;\n59:   continuitySourceKey: string | null;\n60: }\n61: \n62: interface LineageRoutingDecision {\n63:   predecessorMemoryId: number | null;\n64:   transitionEvent: 'CREATE' | 'UPDATE' | 'SUPERSEDE';\n65:   causalSupersedesMemoryId: number | null;\n66: }\n67: \n68: type ScopePostInsertMetadata = Partial<{\n69:   tenant_id: string;\n70:   user_id: string;\n71:   agent_id: string;\n72:   session_id: string;\n73: }>;\n74: \n75: export {\n76:   deriveSourceKindFromContext,\n77:   normalizeSourceKind,\n78:   type SourceKind,\n79: };\n80: \n81: function normalizeOptionalString(value: unknown): string | null {\n82:   if (typeof value !== 'string') {\n83:     return null;\n84:   }\n85:   const normalized = value.trim();\n86:   return normalized.length > 0 ? normalized : null;\n87: }\n88: \n89: function pickFirstString(...values: unknown[]): string | null {\n90:   for (const value of values) {\n91:     const normalized = normalizeOptionalString(value);\n92:     if (normalized) {\n93:       return normalized;\n94:     }\n95:   }\n96:   return null;\n97: }\n98: \n99: function getParsedIdentityValue(parsed: ReturnType<typeof memoryParser.parseMemoryFile>, ...keys: string[]): string | null {\n100:   const parsedRecord = parsed as unknown as Record<string, unknown>;\n101:   for (const key of keys) {\n102:     const normalized = normalizeOptionalString(parsedRecord[key]);\n103:     if (normalized) {\n104:       return normalized;\n105:     }\n106:   }\n107:   return null;\n108: }\n109: \n110: export function resolveCreateRecordIdentity(\n111:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n112:   filePath: string,\n113:   hints: CreateRecordIdentityHints = {},\n114: ): ResolvedCreateRecordIdentity {\n115:   const targetDocPath = pickFirstString(\n116:     hints.targetDocPath,\n117:     getParsedIdentityValue(parsed, 'targetDocPath', 'target_doc_path', 'targetFilePath', 'target_file_path', 'routedDocPath', 'routed_doc_path'),\n118:     filePath,\n119:   ) ?? filePath;\n120: \n121:   const routeAs = pickFirstString(\n122:     hints.routeAs,\n123:     getParsedIdentityValue(parsed, 'routeAs', 'route_as'),\n124:   );\n125:   const continuitySourceKey = pickFirstString(\n126:     hints.continuitySourceKey,\n127:     getParsedIdentityValue(parsed, 'continuitySourceKey', 'continuity_source_key', 'sourceKey', 'source_key'),\n128:   );\n129:   const targetAnchorId = pickFirstString(\n130:     hints.targetAnchorId,\n131:     getParsedIdentityValue(parsed, 'targetAnchorId', 'target_anchor_id', 'anchorId', 'anchor_id'),\n132:   ) ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? CONTINUITY_ANCHOR_ID : null);\n133: \n134:   return {\n135:     targetDocPath,\n136:     canonicalFilePath: pickFirstString(hints.canonicalFilePath, getCanonicalPathKey(targetDocPath)) ?? getCanonicalPathKey(targetDocPath),\n137:     targetAnchorId,\n138:     routeAs,\n139:     continuitySourceKey,\n140:   };\n141: }\n142: \n143: export function resolveCreateRecordLineage(\n144:   peDecision: PeDecision,\n145:   samePathExistingId: number | null,\n146: ): LineageRoutingDecision {\n147:   if (peDecision.action === predictionErrorGate.ACTION.SUPERSEDE && peDecision.existingMemoryId != null) {\n148:     return {\n149:       predecessorMemoryId: samePathExistingId,\n150:       transitionEvent: samePathExistingId != null ? 'SUPERSEDE' : 'CREATE',\n151:       causalSupersedesMemoryId: samePathExistingId === peDecision.existingMemoryId\n152:         ? null\n153:         : peDecision.existingMemoryId,\n154:     };\n155:   }\n156: \n157:   if (samePathExistingId != null) {\n158:     return {\n159:       predecessorMemoryId: samePathExistingId,\n160:       transitionEvent: 'UPDATE',\n161:       causalSupersedesMemoryId: null,\n162:     };\n163:   }\n164: \n165:   return {\n166:     predecessorMemoryId: null,\n167:     transitionEvent: 'CREATE',\n168:     causalSupersedesMemoryId: null,\n169:   };\n170: }\n171: \n172: export function buildScopePostInsertMetadata(\n173:   scope: MemoryScopeMatch = {},\n174: ): ScopePostInsertMetadata {\n175:   const tenantId = normalizeScopeMatchValue(scope.tenantId);\n176:   const userId = normalizeScopeMatchValue(scope.userId);\n177:   const agentId = normalizeScopeMatchValue(scope.agentId);\n178:   const sessionId = normalizeScopeMatchValue(scope.sessionId);\n179: \n180:   return {\n181:     ...(tenantId ? { tenant_id: tenantId } : {}),\n182:     ...(userId ? { user_id: userId } : {}),\n183:     ...(agentId ? { agent_id: agentId } : {}),\n184:     ...(sessionId ? { session_id: sessionId } : {}),\n185:   };\n186: }\n187: \n188: function recordCrossPathSupersedesEdge(\n189:   database: BetterSqlite3.Database,\n190:   memoryId: number,\n191:   supersededMemoryId: number | null,\n192:   reason: string | null | undefined,\n193: ): void {\n194:   if (supersededMemoryId == null) {\n195:     return;\n196:   }\n197: \n198:   causalEdges.init(database);\n199:   const evidence = reason && reason.trim().length > 0\n200:     ? reason.trim()\n201:     : 'Prediction-error contradiction across different file paths';\n202:   causalEdges.insertEdge(\n203:     String(memoryId),\n204:     String(supersededMemoryId),\n205:     causalEdges.RELATION_TYPES.SUPERSEDES,\n206:     1.0,\n207:     evidence,\n208:     true,\n209:     'auto',\n210:   );\n211: }\n212: \n213: export function findSamePathExistingMemory(\n214:   database: BetterSqlite3.Database,\n215:   specFolder: string,\n216:   canonicalFilePath: string,\n217:   filePath: string,\n218:   scope: MemoryScopeMatch = {},\n219:   identityHints: CreateRecordIdentityHints = {},\n220: ): { id: number; title: string | null; content_hash?: string | null } | undefined {\n221:   const tenantId = normalizeScopeMatchValue(scope.tenantId);\n222:   const userId = normalizeScopeMatchValue(scope.userId);\n223:   const agentId = normalizeScopeMatchValue(scope.agentId);\n224:   const sessionId = normalizeScopeMatchValue(scope.sessionId);\n225:   const resolvedCanonicalFilePath = normalizeOptionalString(identityHints.canonicalFilePath) ?? canonicalFilePath;\n226:   const resolvedFilePath = normalizeOptionalString(identityHints.targetDocPath) ?? filePath;\n227:   const resolvedAnchorId = normalizeOptionalString(identityHints.targetAnchorId);\n228:   const hasIdentityOverride = resolvedCanonicalFilePath !== canonicalFilePath\n229:     || resolvedFilePath !== filePath\n230:     || identityHints.targetAnchorId !== undefined\n231:     || identityHints.canonicalFilePath !== undefined\n232:     || identityHints.targetDocPath !== undefined;\n233: \n234:   const anchorClause = resolvedAnchorId !== null\n235:     ? 'AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))'\n236:     : hasIdentityOverride\n237:       ? 'AND anchor_id IS NULL'\n238:       : '';\n239: \n240:   const params: Array<string | null> = [\n241:     specFolder,\n242:     resolvedCanonicalFilePath,\n243:     resolvedFilePath,\n244:   ];\n245:   if (resolvedAnchorId !== null) {\n246:     params.push(resolvedAnchorId, resolvedAnchorId);\n247:   }\n248:   params.push(\n249:     tenantId,\n250:     tenantId,\n251:     userId,\n252:     userId,\n253:     agentId,\n254:     agentId,\n255:     sessionId,\n256:     sessionId,\n257:   );\n258: \n259:   return database.prepare(`\n260:     SELECT id, title, content_hash\n261:     FROM memory_index\n262:     WHERE spec_folder = ?\n263:       AND parent_id IS NULL\n264:       AND (canonical_file_path = ? OR file_path = ?)\n265:       ${anchorClause}\n266:       AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n267:       AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n268:       AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n269:       AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n270:     ORDER BY id DESC\n271:     LIMIT 1\n272:   `).get(...params) as { id: number; title: string | null; content_hash?: string | null } | undefined;\n273: }\n274: \n275: /**\n276:  * Creates a memory row with metadata, optional BM25 entry, and save history.\n277:  * Returns the persisted memory id for downstream save handlers.\n278:  */\n279: export function createMemoryRecord(\n280:   database: BetterSqlite3.Database,\n281:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n282:   filePath: string,\n283:   embedding: Float32Array | null,\n284:   embeddingFailureReason: string | null,\n285:   peDecision: PeDecision,\n286:   scope: MemoryScopeMatch = {},\n287:   identityHints: CreateRecordIdentityHints = {},\n288:   provenance: WriteProvenanceContext = {},\n289: ): number {\n290:   const recordIdentity = resolveCreateRecordIdentity(parsed, filePath, identityHints);\n291:   const routedDocumentType = inferDocumentTypeFromPath(recordIdentity.targetDocPath);\n292:   const persistedDocumentType = routedDocumentType !== 'memory'\n293:     ? routedDocumentType\n294:     : (parsed.documentType || 'memory');\n295: \n296:   if (!embedding) {\n297:     console.error(`[memory-save] Using deferred indexing for ${path.basename(recordIdentity.targetDocPath)}`);\n298:   }\n299: \n300:   // Detect spec level for spec documents.\n301:   const specLevel = isSpecDocumentType(persistedDocumentType)\n302:     ? detectSpecLevelFromParsed(recordIdentity.targetDocPath)\n303:     : null;\n304:   const encodingIntent = isEncodingIntentEnabled()\n305:     ? classifyEncodingIntent(parsed.content)\n306:     : undefined;\n307:   // Security: raw provider errors sanitized before persistence/response\n308:   const persistedEmbeddingFailureReason = sanitizeEmbeddingFailureMessage(embeddingFailureReason);\n309: \n310:   const indexWithMetadata = database.transaction(() => {\n311:     // Determine importance weight based on document type.\n312:     const importanceWeight = calculateDocumentWeight(recordIdentity.targetDocPath, parsed.documentType);\n313:     const samePathExisting = findSamePathExistingMemory(\n314:       database,\n315:       parsed.specFolder,\n316:       recordIdentity.canonicalFilePath,\n317:       recordIdentity.targetDocPath,\n318:       scope,\n319:       recordIdentity,\n320:     );\n321:     const lineageRouting = resolveCreateRecordLineage(peDecision, samePathExisting?.id ?? null);\n322:     const predecessorMemoryId = lineageRouting.predecessorMemoryId;\n323:     const transitionEvent = lineageRouting.transitionEvent;\n324: \n325:     // Retire the same-key predecessor before inserting the new active version so the\n326:     // active-row uniqueness guard holds at insert time; lineage and history persist.\n327:     // The carry surfaces a human's tier/source-kind to re-stamp on the successor.\n328:     const reindexCarry = predecessorMemoryId != null\n329:       ? retirePredecessorForActiveReindex(database, predecessorMemoryId)\n330:       : null;\n331: \n332:     const memory_id: number = embedding\n333:       ? vectorIndex.indexMemory({\n334:           specFolder: parsed.specFolder,\n335:           filePath: recordIdentity.targetDocPath,\n336:           anchorId: recordIdentity.targetAnchorId,\n337:           title: parsed.title,\n338:           triggerPhrases: parsed.triggerPhrases,\n339:           importanceWeight,\n340:           embedding,\n341:           encodingIntent,\n342:           documentType: persistedDocumentType,\n343:           specLevel,\n344:           contentText: parsed.content,\n345:           qualityScore: parsed.qualityScore,\n346:           qualityFlags: parsed.qualityFlags,\n347:           appendOnly: predecessorMemoryId != null,\n348:           scope,\n349:         })\n350:       : vectorIndex.indexMemoryDeferred({\n351:           specFolder: parsed.specFolder,\n352:           filePath: recordIdentity.targetDocPath,\n353:           anchorId: recordIdentity.targetAnchorId,\n354:           title: parsed.title,\n355:           triggerPhrases: parsed.triggerPhrases,\n356:           importanceWeight,\n357:           failureReason: persistedEmbeddingFailureReason,\n358:           encodingIntent,\n359:           documentType: persistedDocumentType,\n360:           specLevel,\n361:           contentText: parsed.content,\n362:           qualityScore: parsed.qualityScore,\n363:           qualityFlags: parsed.qualityFlags,\n364:           appendOnly: predecessorMemoryId != null,\n365:           scope,\n366:         });\n367: \n368:     const fileMetadata = incrementalIndex.getFileMetadata(recordIdentity.targetDocPath);\n369:     const fileMtimeMs = fileMetadata ? fileMetadata.mtime : null;\n370:     applyWriteProvenance(database, memory_id, {\n371:       tool: 'memory_save',\n372:       filePath: recordIdentity.targetDocPath,\n373:       scope,\n374:       ...provenance,\n375:     });\n376: \n377:     applyPostInsertMetadata(database, memory_id, {\n378:       content_hash: parsed.contentHash,\n379:       context_type: parsed.contextType,\n380:       importance_tier: parsed.importanceTier,\n381:       memory_type: parsed.memoryType,\n382:       type_inference_source: parsed.memoryTypeSource,\n383:       stability: fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n384:       difficulty: fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n385:       file_mtime_ms: fileMtimeMs,\n386:       encoding_intent: encodingIntent,\n387:       document_type: persistedDocumentType,\n388:       spec_level: specLevel,\n389:       quality_score: parsed.qualityScore ?? 0,\n390:       quality_flags: JSON.stringify(parsed.qualityFlags ?? []),\n391:       ...buildScopePostInsertMetadata(scope),\n392:     });\n393: \n394:     // Re-stamp after the metadata write so a manual predecessor's tier and human\n395:     // source-kind carry to the successor instead of being reset to the incoming\n396:     // default — keeping the automated-writers-never-overwrite-manual guarantee.\n397:     if (reindexCarry != null) {\n398:       database\n399:         .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n400:         .run(reindexCarry.importanceTier, memory_id);\n401:       persistSourceKind(database, memory_id, reindexCarry.sourceKind as SourceKind);\n402:     }\n403: \n404:     if (embedding && peDecision.action === predictionErrorGate.ACTION.CREATE_LINKED && peDecision.existingMemoryId != null) {\n405:       try {\n406:         database.prepare(`\n407:           UPDATE memory_index\n408:           SET related_memories = ?\n409:           WHERE id = ?\n410:         `).run(JSON.stringify([peDecision.existingMemoryId]), memory_id);\n411:       } catch (err: unknown) {\n412:         const message = toErrorMessage(err);\n413:         console.error('[PE-Gate] Could not store related memories:', message);\n414:       }\n415:     }\n416: \n417:     recordLineageTransition(database, memory_id, {\n418:       actor: 'mcp:memory_save',\n419:       predecessorMemoryId,\n420:       transitionEvent,\n421:     });\n422:     recordCrossPathSupersedesEdge(\n423:       database,\n424:       memory_id,\n425:       lineageRouting.causalSupersedesMemoryId,\n426:       peDecision.reason,\n427:     );\n428: \n429:     if (bm25Index.isBm25Enabled()) {\n430:       try {\n431:         const bm25 = bm25Index.getIndex();\n432:         bm25.addDocument(String(memory_id), bm25Index.buildBm25DocumentText({\n433:           title: parsed.title,\n434:           content_text: parsed.content,\n435:           trigger_phrases: parsed.triggerPhrases,\n436:           file_path: filePath,\n437:         }));\n438:       } catch (bm25_err: unknown) {\n439:         const message = toErrorMessage(bm25_err);\n440:         console.warn(embedding\n441:           ? `[memory-save] BM25 indexing failed: ${message}`\n442:           : `[memory-save] BM25 indexing failed (deferred path): ${message}`);\n443:       }\n444:     }\n445: \n446:     // Append-first writes add a new row for every new current version.\n447:     try {\n448:       recordHistory(memory_id, 'ADD', null, parsed.title ?? filePath, 'mcp:memory_save');\n449:       if (predecessorMemoryId != null) {\n450:         recordHistory(\n451:           predecessorMemoryId,\n452:           'UPDATE',\n453:           samePathExisting?.title ?? null,\n454:           parsed.title ?? recordIdentity.targetDocPath,\n455:           'mcp:memory_save',\n456:         );\n457:       }\n458:     } catch (_histErr: unknown) {\n459:       // History recording is best-effort during save\n460:     }\n461: \n462:     return memory_id;\n463:   });\n464: \n465:   return indexWithMetadata();\n466: }\n\n(End of file - total 466 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Create Record\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport * as vectorIndex from '../../lib/search/vector-index.js';\nimport * as bm25Index from '../../lib/search/bm25-index.js';\nimport * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\nimport * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\nimport * as incrementalIndex from '../../lib/storage/incremental-index.js';\nimport * as causalEdges from '../../lib/storage/causal-edges.js';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\nimport { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\nimport { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\nimport { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\nimport { recordHistory } from '../../lib/storage/history.js';\nimport { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Create Record\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport * as vectorIndex from '../../lib/search/vector-index.js';\nimport * as bm25Index from '../../lib/search/bm25-index.js';\nimport * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\nimport * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\nimport * as incrementalIndex from '../../lib/storage/incremental-index.js';\nimport * as causalEdges from '../../lib/storage/causal-edges.js';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\nimport { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\nimport { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\nimport { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\nimport { recordHistory } from '../../lib/storage/history.js';\nimport { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';\nimport { detectSpecLevelFromParsed } from '../handler-utils.js';\nimport { classifyEncodingIntent } from '../../lib/search/encoding-intent.js';\nimport { isEncodingIntentEnabled } from '../../lib/search/search-flags.js';\nimport { applyPostInsertMetadata } from './db-helpers.js';\nimport { inferDocumentTypeFromPath } from '../../lib/config/memory-types.js';\nimport {\n  applyWriteProvenance,\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  persistSourceKind,\n  type SourceKind,\n  type WriteProvenanceContext,\n} from '../../lib/storage/write-provenance.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Per-memory history log\n// Feature catalog: Prediction-error save arbitration\n\n\nimport type { PeDecision, MemoryScopeMatch } from './types.js';\nimport { normalizeScopeMatchValue } from './types.js';\nexport type { MemoryScopeMatch };\n\nexport const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n\nexport interface CreateRecordIdentityHints {\n  targetDocPath?: string | null;\n  canonicalFilePath?: string | null;\n  targetAnchorId?: string | null;\n  routeAs?: string | null;\n  continuitySourceKey?: string | null;\n}\n\nexport interface ResolvedCreateRecordIdentity {\n  targetDocPath: string;\n  canonicalFilePath: string;\n  targetAnchorId: string | null;\n  routeAs: string | null;\n  continuitySourceKey: string | null;\n}\n\ninterface LineageRoutingDecision {\n  predecessorMemoryId: number | null;\n  transitionEvent: 'CREATE' | 'UPDATE' | 'SUPERSEDE';\n  causalSupersedesMemoryId: number | null;\n}\n\ntype ScopePostInsertMetadata = Partial<{\n  tenant_id: string;\n  user_id: string;\n  agent_id: string;\n  session_id: string;\n}>;\n\nexport {\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  type SourceKind,\n};\n\nfunction normalizeOptionalString(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction pickFirstString(...values: unknown[]): string | null {\n  for (const value of values) {\n    const normalized = normalizeOptionalString(value);\n    if (normalized) {\n      return normalized;\n    }\n  }\n  return null;\n}\n\nfunction getParsedIdentityValue(parsed: ReturnType<typeof memoryParser.parseMemoryFile>, ...keys: string[]): string | null {\n  const parsedRecord = parsed as unknown as Record<string, unknown>;\n  for (const key of keys) {\n    const normalized = normalizeOptionalString(parsedRecord[key]);\n    if (normalized) {\n      return normalized;\n    }\n  }\n  return null;\n}\n\nexport function resolveCreateRecordIdentity(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  filePath: string,\n  hints: CreateRecordIdentityHints = {},\n): ResolvedCreateRecordIdentity {\n  const targetDocPath = pickFirstString(\n    hints.targetDocPath,\n    getParsedIdentityValue(parsed, 'targetDocPath', 'target_doc_path', 'targetFilePath', 'target_file_path', 'routedDocPath', 'routed_doc_path'),\n    filePath,\n  ) ?? filePath;\n\n  const routeAs = pickFirstString(\n    hints.routeAs,\n    getParsedIdentityValue(parsed, 'routeAs', 'route_as'),\n  );\n  const continuitySourceKey = pickFirstString(\n    hints.continuitySourceKey,\n    getParsedIdentityValue(parsed, 'continuitySourceKey', 'continuity_source_key', 'sourceKey', 'source_key'),\n  );\n  const targetAnchorId = pickFirstString(\n    hints.targetAnchorId,\n    getParsedIdentityValue(parsed, 'targetAnchorId', 'target_anchor_id', 'anchorId', 'anchor_id'),\n  ) ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? CONTINUITY_ANCHOR_ID : null);\n\n  return {\n    targetDocPath,\n    canonicalFilePath: pickFirstString(hints.canonicalFilePath, getCanonicalPathKey(targetDocPath)) ?? getCanonicalPathKey(targetDocPath),\n    targetAnchorId,\n    routeAs,\n    continuitySourceKey,\n  };\n}\n\nexport function resolveCreateRecordLineage(\n  peDecision: PeDecision,\n  samePathExistingId: number | null,\n): LineageRoutingDecision {\n  if (peDecision.action === predictionErrorGate.ACTION.SUPERSEDE && peDecision.existingMemoryId != null) {\n    return {\n      predecessorMemoryId: samePathExistingId,\n      transitionEvent: samePathExistingId != null ? 'SUPERSEDE' : 'CREATE',\n      causalSupersedesMemoryId: samePathExistingId === peDecision.existingMemoryId\n        ? null\n        : peDecision.existingMemoryId,\n    };\n  }\n\n  if (samePathExistingId != null) {\n    return {\n      predecessorMemoryId: samePathExistingId,\n      transitionEvent: 'UPDATE',\n      causalSupersedesMemoryId: null,\n    };\n  }\n\n  return {\n    predecessorMemoryId: null,\n    transitionEvent: 'CREATE',\n    causalSupersedesMemoryId: null,\n  };\n}\n\nexport function buildScopePostInsertMetadata(\n  scope: MemoryScopeMatch = {},\n): ScopePostInsertMetadata {\n  const tenantId = normalizeScopeMatchValue(scope.tenantId);\n  const userId = normalizeScopeMatchValue(scope.userId);\n  const agentId = normalizeScopeMatchValue(scope.agentId);\n  const sessionId = normalizeScopeMatchValue(scope.sessionId);\n\n  return {\n    ...(tenantId ? { tenant_id: tenantId } : {}),\n    ...(userId ? { user_id: userId } : {}),\n    ...(agentId ? { agent_id: agentId } : {}),\n    ...(sessionId ? { session_id: sessionId } : {}),\n  };\n}\n\nfunction recordCrossPathSupersedesEdge(\n  database: BetterSqlite3.Database,\n  memoryId: number,\n  supersededMemoryId: number | null,\n  reason: string | null | undefined,\n): void {\n  if (supersededMemoryId == null) {\n    return;\n  }\n\n  causalEdges.init(database);\n  const evidence = reason && reason.trim().length > 0\n    ? reason.trim()\n    : 'Prediction-error contradiction across different file paths';\n  causalEdges.insertEdge(\n    String(memoryId),\n    String(supersededMemoryId),\n    causalEdges.RELATION_TYPES.SUPERSEDES,\n    1.0,\n    evidence,\n    true,\n    'auto',\n  );\n}\n\nexport function findSamePathExistingMemory(\n  database: BetterSqlite3.Database,\n  specFolder: string,\n  canonicalFilePath: string,\n  filePath: string,\n  scope: MemoryScopeMatch = {},\n  identityHints: CreateRecordIdentityHints = {},\n): { id: number; title: string | null; content_hash?: string | null } | undefined {\n  const tenantId = normalizeScopeMatchValue(scope.tenantId);\n  const userId = normalizeScopeMatchValue(scope.userId);\n  const agentId = normalizeScopeMatchValue(scope.agentId);\n  const sessionId = normalizeScopeMatchValue(scope.sessionId);\n  const resolvedCanonicalFilePath = normalizeOptionalString(identityHints.canonicalFilePath) ?? canonicalFilePath;\n  const resolvedFilePath = normalizeOptionalString(identityHints.targetDocPath) ?? filePath;\n  const resolvedAnchorId = normalizeOptionalString(identityHints.targetAnchorId);\n  const hasIdentityOverride = resolvedCanonicalFilePath !== canonicalFilePath\n    || resolvedFilePath !== filePath\n    || identityHints.targetAnchorId !== undefined\n    || identityHints.canonicalFilePath !== undefined\n    || identityHints.targetDocPath !== undefined;\n\n  const anchorClause = resolvedAnchorId !== null\n    ? 'AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))'\n    : hasIdentityOverride\n      ? 'AND anchor_id IS NULL'\n      : '';\n\n  const params: Array<string | null> = [\n    specFolder,\n    resolvedCanonicalFilePath,\n    resolvedFilePath,\n  ];\n  if (resolvedAnchorId !== null) {\n    params.push(resolvedAnchorId, resolvedAnchorId);\n  }\n  params.push(\n    tenantId,\n    tenantId,\n    userId,\n    userId,\n    agentId,\n    agentId,\n    sessionId,\n    sessionId,\n  );\n\n  return database.prepare(`\n    SELECT id, title, content_hash\n    FROM memory_index\n    WHERE spec_folder = ?\n      AND parent_id IS NULL\n      AND (canonical_file_path = ? OR file_path = ?)\n      ${anchorClause}\n      AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n      AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n      AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n      AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n    ORDER BY id DESC\n    LIMIT 1\n  `).get(...params) as { id: number; title: string | null; content_hash?: string | null } | undefined;\n}\n\n/**\n * Creates a memory row with metadata, optional BM25 entry, and save history.\n * Returns the persisted memory id for downstream save handlers.\n */\nexport function createMemoryRecord(\n  database: BetterSqlite3.Database,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  filePath: string,\n  embedding: Float32Array | null,\n  embeddingFailureReason: string | null,\n  peDecision: PeDecision,\n  scope: MemoryScopeMatch = {},\n  identityHints: CreateRecordIdentityHints = {},\n  provenance: WriteProvenanceContext = {},\n): number {\n  const recordIdentity = resolveCreateRecordIdentity(parsed, filePath, identityHints);\n  const routedDocumentType = inferDocumentTypeFromPath(recordIdentity.targetDocPath);\n  const persistedDocumentType = routedDocumentType !== 'memory'\n    ? routedDocumentType\n    : (parsed.documentType || 'memory');\n\n  if (!embedding) {\n    console.error(`[memory-save] Using deferred indexing for ${path.basename(recordIdentity.targetDocPath)}`);\n  }\n\n  // Detect spec level for spec documents.\n  const specLevel = isSpecDocumentType(persistedDocumentType)\n    ? detectSpecLevelFromParsed(recordIdentity.targetDocPath)\n    : null;\n  const encodingIntent = isEncodingIntentEnabled()\n    ? classifyEncodingIntent(parsed.content)\n    : undefined;\n  // Security: raw provider errors sanitized before persistence/response\n  const persistedEmbeddingFailureReason = sanitizeEmbeddingFailureMessage(embeddingFailureReason);\n\n  const indexWithMetadata = database.transaction(() => {\n    // Determine importance weight based on document type.\n    const importanceWeight = calculateDocumentWeight(recordIdentity.targetDocPath, parsed.documentType);\n    const samePathExisting = findSamePathExistingMemory(\n      database,\n      parsed.specFolder,\n      recordIdentity.canonicalFilePath,\n      recordIdentity.targetDocPath,\n      scope,\n      recordIdentity,\n    );\n    const lineageRouting = resolveCreateRecordLineage(peDecision, samePathExisting?.id ?? null);\n    const predecessorMemoryId = lineageRouting.predecessorMemoryId;\n    const transitionEvent = lineageRouting.transitionEvent;\n\n    // Retire the same-key predecessor before inserting the new active version so the\n    // active-row uniqueness guard holds at insert time; lineage and history persist.\n    // The carry surfaces a human's tier/source-kind to re-stamp on the successor.\n    const reindexCarry = predecessorMemoryId != null\n      ? retirePredecessorForActiveReindex(database, predecessorMemoryId)\n      : null;\n\n    const memory_id: number = embedding\n      ? vectorIndex.indexMemory({\n          specFolder: parsed.specFolder,\n          filePath: recordIdentity.targetDocPath,\n          anchorId: recordIdentity.targetAnchorId,\n          title: parsed.title,\n          triggerPhrases: parsed.triggerPhrases,\n          importanceWeight,\n          embedding,\n          encodingIntent,\n          documentType: persistedDocumentType,\n          specLevel,\n          contentText: parsed.content,\n          qualityScore: parsed.qualityScore,\n          qualityFlags: parsed.qualityFlags,\n          appendOnly: predecessorMemoryId != null,\n          scope,\n        })\n      : vectorIndex.indexMemoryDeferred({\n          specFolder: parsed.specFolder,\n          filePath: recordIdentity.targetDocPath,\n          anchorId: recordIdentity.targetAnchorId,\n          title: parsed.title,\n          triggerPhrases: parsed.triggerPhrases,\n          importanceWeight,\n          failureReason: persistedEmbeddingFailureReason,\n          encodingIntent,\n          documentType: persistedDocumentType,\n          specLevel,\n          contentText: parsed.content,\n          qualityScore: parsed.qualityScore,\n          qualityFlags: parsed.qualityFlags,\n          appendOnly: predecessorMemoryId != null,\n          scope,\n        });\n\n    const fileMetadata = incrementalIndex.getFileMetadata(recordIdentity.targetDocPath);\n    const fileMtimeMs = fileMetadata ? fileMetadata.mtime : null;\n    applyWriteProvenance(database, memory_id, {\n      tool: 'memory_save',\n      filePath: recordIdentity.targetDocPath,\n      scope,\n      ...provenance,\n    });\n\n    applyPostInsertMetadata(database, memory_id, {\n      content_hash: parsed.contentHash,\n      context_type: parsed.contextType,\n      importance_tier: parsed.importanceTier,\n      memory_type: parsed.memoryType,\n      type_inference_source: parsed.memoryTypeSource,\n      stability: fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n      difficulty: fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n      file_mtime_ms: fileMtimeMs,\n      encoding_intent: encodingIntent,\n      document_type: persistedDocumentType,\n      spec_level: specLevel,\n      quality_score: parsed.qualityScore ?? 0,\n      quality_flags: JSON.stringify(parsed.qualityFlags ?? []),\n      ...buildScopePostInsertMetadata(scope),\n    });\n\n    // Re-stamp after the metadata write so a manual predecessor's tier and human\n    // source-kind carry to the successor instead of being reset to the incoming\n    // default — keeping the automated-writers-never-overwrite-manual guarantee.\n    if (reindexCarry != null) {\n      database\n        .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n        .run(reindexCarry.importanceTier, memory_id);\n      persistSourceKind(database, memory_id, reindexCarry.sourceKind as SourceKind);\n    }\n\n    if (embedding && peDecision.action === predictionErrorGate.ACTION.CREATE_LINKED && peDecision.existingMemoryId != null) {\n      try {\n        database.prepare(`\n          UPDATE memory_index\n          SET related_memories = ?\n          WHERE id = ?\n        `).run(JSON.stringify([peDecision.existingMemoryId]), memory_id);\n      } catch (err: unknown) {\n        const message = toErrorMessage(err);\n        console.error('[PE-Gate] Could not store related memories:', message);\n      }\n    }\n\n    recordLineageTransition(database, memory_id, {\n      actor: 'mcp:memory_save',\n      predecessorMemoryId,\n      transitionEvent,\n    });\n    recordCrossPathSupersedesEdge(\n      database,\n      memory_id,\n      lineageRouting.causalSupersedesMemoryId,\n      peDecision.reason,\n    );\n\n    if (bm25Index.isBm25Enabled()) {\n      try {\n        const bm25 = bm25Index.getIndex();\n        bm25.addDocument(String(memory_id), bm25Index.buildBm25DocumentText({\n          title: parsed.title,\n          content_text: parsed.content,\n          trigger_phrases: parsed.triggerPhrases,\n          file_path: filePath,\n        }));\n      } catch (bm25_err: unknown) {\n        const message = toErrorMessage(bm25_err);\n        console.warn(embedding\n          ? `[memory-save] BM25 indexing failed: ${message}`\n          : `[memory-save] BM25 indexing failed (deferred path): ${message}`);\n      }\n    }\n\n    // Append-first writes add a new row for every new current version.\n    try {\n      recordHistory(memory_id, 'ADD', null, parsed.title ?? filePath, 'mcp:memory_save');\n      if (predecessorMemoryId != null) {\n        recordHistory(\n          predecessorMemoryId,\n          'UPDATE',\n          samePathExisting?.title ?? null,\n          parsed.title ?? recordIdentity.targetDocPath,\n          'mcp:memory_save',\n        );\n      }\n    } catch (_histErr: unknown) {\n      // History recording is best-effort during save\n    }\n\n    return memory_id;\n  });\n\n  return indexWithMetadata();\n}","lineStart":1,"lineEnd":466,"totalLines":466,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","time":{"start":1781763537163,"end":1781763537169}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e9508191b409f23f89f9934c"}},"id":"prt_ed961f906001w14rMWBaG3U4cd","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
{"type":"tool_use","timestamp":1781763537172,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_GrM5znOJILTtnTFjNKaawtN3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Incremental Index\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Deferred lexical-only indexing\n5: // Mtime-based incremental indexing for fast re-indexing\n6: // Node stdlib\n7: import { createHash } from 'node:crypto';\n8: import * as fs from 'fs';\n9: import * as path from 'path';\n10: \n11: // External packages\n12: import type Database from 'better-sqlite3';\n13: \n14: // Internal modules\n15: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n16: import { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\n17: import { canonicalFingerprint } from './canonical-fingerprint.js';\n18: import { createMemoStore } from './memo.js';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. CONSTANTS\n22: ----------------------------------------------------------------*/\n23: \n24: const MTIME_FAST_PATH_MS = 1000; // Skip if mtime within 1 second\n25: const DEFAULT_ORPHAN_SWEEP_LIMIT = 200;\n26: \n27: /* ───────────────────────────────────────────────────────────────\n28:    2. INTERFACES\n29: ----------------------------------------------------------------*/\n30: \n31: interface FileMetadata {\n32:   path: string;\n33:   mtime: number;\n34:   size: number;\n35:   exists: boolean;\n36: }\n37: \n38: interface StoredMetadata {\n39:   file_path: string;\n40:   canonical_file_path?: string | null;\n41:   file_mtime_ms: number | null;\n42:   content_hash: string | null;\n43:   embedding_status: string;\n44: }\n45: \n46: type IndexDecision = 'skip' | 'reindex' | 'new' | 'deleted' | 'modified' | 'unknown';\n47: \n48: interface CategorizedFiles {\n49:   toIndex: string[];\n50:   toUpdate: string[];\n51:   toSkip: string[];\n52:   toDelete: string[];\n53: }\n54: \n55: interface IndexedPathRow {\n56:   file_path: string;\n57:   canonical_file_path?: string | null;\n58: }\n59: \n60: interface IndexedRecordRow extends IndexedPathRow {\n61:   id: number;\n62: }\n63: \n64: interface OrphanSweepOptions {\n65:   limit?: number;\n66:   cursor?: number;\n67: }\n68: \n69: interface OrphanSweepResult {\n70:   swept: number;\n71:   nextCursor: number | null;\n72:   scannedRows: number;\n73:   orphanRecordIds: number[];\n74: }\n75: \n76: /* ───────────────────────────────────────────────────────────────\n77:    3. MODULE STATE\n78: ----------------------------------------------------------------*/\n79: \n80: let db: Database.Database | null = null;\n81: let canonicalPathColumnAvailable: boolean | null = null;\n82: let documentTypeColumnAvailable: boolean | null = null;\n83: \n84: function init(database: Database.Database): void {\n85:   db = database;\n86:   canonicalPathColumnAvailable = null;\n87:   documentTypeColumnAvailable = null;\n88: }\n89: \n90: function hasCanonicalPathColumn(): boolean {\n91:   if (!db) return false;\n92: \n93:   if (canonicalPathColumnAvailable !== null) {\n94:     return canonicalPathColumnAvailable;\n95:   }\n96: \n97:   try {\n98:     const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n99:     canonicalPathColumnAvailable = columns.some((column) => column.name === 'canonical_file_path');\n100:   } catch {\n101:     canonicalPathColumnAvailable = false;\n102:   }\n103: \n104:   return canonicalPathColumnAvailable;\n105: }\n106: \n107: function hasDocumentTypeColumn(): boolean {\n108:   if (!db) return false;\n109: \n110:   if (documentTypeColumnAvailable !== null) {\n111:     return documentTypeColumnAvailable;\n112:   }\n113: \n114:   try {\n115:     const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n116:     documentTypeColumnAvailable = columns.some((column) => column.name === 'document_type');\n117:   } catch {\n118:     documentTypeColumnAvailable = false;\n119:   }\n120: \n121:   return documentTypeColumnAvailable;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    4. FILE METADATA\n126: ----------------------------------------------------------------*/\n127: \n128: function getFileMetadata(filePath: string): FileMetadata {\n129:   try {\n130:     const stats = fs.statSync(filePath);\n131:     return {\n132:       path: filePath,\n133:       mtime: stats.mtimeMs,\n134:       size: stats.size,\n135:       exists: true,\n136:     };\n137:   } catch {\n138:     return {\n139:       path: filePath,\n140:       mtime: 0,\n141:       size: 0,\n142:       exists: false,\n143:     };\n144:   }\n145: }\n146: \n147: function getStoredMetadata(filePath: string): StoredMetadata | null {\n148:   if (!db) return null;\n149: \n150:   try {\n151:     const canonicalPath = getCanonicalPathKey(filePath);\n152: \n153:     const row = hasCanonicalPathColumn()\n154:       ? (db.prepare(`\n155:           SELECT file_path, canonical_file_path, file_mtime_ms, content_hash, embedding_status\n156:           FROM memory_index\n157:           WHERE canonical_file_path = ? OR file_path = ?\n158:           ORDER BY CASE WHEN canonical_file_path = ? THEN 0 ELSE 1 END, id DESC\n159:           LIMIT 1\n160:         `) as Database.Statement).get(canonicalPath, filePath, canonicalPath) as StoredMetadata | undefined\n161:       : (db.prepare(`\n162:           SELECT file_path, file_mtime_ms, content_hash, embedding_status\n163:           FROM memory_index\n164:           WHERE file_path = ?\n165:         `) as Database.Statement).get(filePath) as StoredMetadata | undefined;\n166: \n167:     return row || null;\n168:   } catch (error: unknown) {\n169:     const msg = error instanceof Error ? error.message : String(error);\n170:     console.warn(`[incremental-index] getStoredMetadata error: ${msg}`);\n171:     return null;\n172:   }\n173: }\n174: \n175: function computeFileContentHash(filePath: string): string | null {\n176:   try {\n177:     const content = fs.readFileSync(filePath);\n178:     return createHash('sha256').update(content).digest('hex');\n179:   } catch {\n180:     return null;\n181:   }\n182: }\n183: \n184: /* ───────────────────────────────────────────────────────────────\n185:    5. DECISION LOGIC\n186: ----------------------------------------------------------------*/\n187: \n188: /**\n189:  * 6-path decision logic for whether a file needs re-indexing.\n190:  */\n191: function shouldReindex(filePath: string): IndexDecision {\n192:   const fileInfo = getFileMetadata(filePath);\n193: \n194:   // Path 1: File doesn't exist on disk\n195:   if (!fileInfo.exists) {\n196:     const stored = getStoredMetadata(filePath);\n197:     if (stored) return 'deleted';\n198:     return 'skip';\n199:   }\n200: \n201:   // Path 2: No stored metadata (new file)\n202:   const stored = getStoredMetadata(filePath);\n203:   if (!stored) return 'new';\n204: \n205:   // Path 3: No stored mtime (legacy entry, needs re-indexing)\n206:   if (stored.file_mtime_ms === null) return 'reindex';\n207: \n208:   // Path 4: Mtime unchanged (fast path - skip)\n209:   if (Math.abs(fileInfo.mtime - stored.file_mtime_ms) < MTIME_FAST_PATH_MS) {\n210:     // Still check if embedding status is pending\n211:     if (stored.embedding_status === 'pending' || stored.embedding_status === 'failed') {\n212:       return 'reindex';\n213:     }\n214: \n215:     if (stored.content_hash) {\n216:       const currentContentHash = computeFileContentHash(filePath);\n217:       if (currentContentHash && currentContentHash !== stored.content_hash) {\n218:         return 'modified';\n219:       }\n220:     }\n221: \n222:     return 'skip';\n223:   }\n224: \n225:   // Path 5: Mtime changed (file modified)\n226:   return 'modified';\n227: }\n228: \n229: /* ───────────────────────────────────────────────────────────────\n230:    6. MTIME MANAGEMENT\n231: ----------------------------------------------------------------*/\n232: \n233: function updateFileMtime(filePath: string, mtimeMs: number): boolean {\n234:   if (!db) return false;\n235: \n236:   try {\n237:     const canonicalPath = getCanonicalPathKey(filePath);\n238: \n239:     const result = hasCanonicalPathColumn()\n240:       ? (db.prepare(`\n241:           UPDATE memory_index\n242:           SET file_mtime_ms = ?\n243:           WHERE canonical_file_path = ? OR file_path = ?\n244:         `) as Database.Statement).run(mtimeMs, canonicalPath, filePath)\n245:       : (db.prepare(`\n246:           UPDATE memory_index\n247:           SET file_mtime_ms = ?\n248:           WHERE file_path = ?\n249:         `) as Database.Statement).run(mtimeMs, filePath);\n250: \n251:     return (result as { changes: number }).changes > 0;\n252:   } catch (error: unknown) {\n253:     const msg = error instanceof Error ? error.message : String(error);\n254:     console.warn(`[incremental-index] updateFileMtime error: ${msg}`);\n255:     return false;\n256:   }\n257: }\n258: \n259: function setIndexedMtime(filePath: string): boolean {\n260:   const fileInfo = getFileMetadata(filePath);\n261:   if (!fileInfo.exists) return false;\n262:   return updateFileMtime(filePath, fileInfo.mtime);\n263: }\n264: \n265: /* ───────────────────────────────────────────────────────────────\n266:    7. BATCH OPERATIONS\n267: ----------------------------------------------------------------*/\n268: \n269: function categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n270:   const result: CategorizedFiles = {\n271:     toIndex: [],\n272:     toUpdate: [],\n273:     toSkip: [],\n274:     toDelete: [],\n275:   };\n276: \n277:   for (const filePath of filePaths) {\n278:     const decision = shouldReindex(filePath);\n279: \n280:     switch (decision) {\n281:       case 'new':\n282:         result.toIndex.push(filePath);\n283:         break;\n284:       case 'modified':\n285:       case 'reindex':\n286:         result.toUpdate.push(filePath);\n287:         break;\n288:       case 'deleted':\n289:         result.toDelete.push(filePath);\n290:         break;\n291:       case 'skip':\n292:       default:\n293:         result.toSkip.push(filePath);\n294:         break;\n295:     }\n296:   }\n297: \n298:   // Include stale indexed paths that are no longer discovered on disk.\n299:   // Without this pass, removed files never enter toDelete during normal scans\n300:   // Because discovery only returns files that currently exist.\n301:   const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n302:   if (staleIndexedPaths.length > 0) {\n303:     const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n304:     for (const stalePath of staleIndexedPaths) {\n305:       const staleKey = getCanonicalPathKey(stalePath);\n306:       if (!seenDeleteKeys.has(staleKey)) {\n307:         result.toDelete.push(stalePath);\n308:         seenDeleteKeys.add(staleKey);\n309:       }\n310:     }\n311:   }\n312: \n313:   return result;\n314: }\n315: \n316: function listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n317:   if (!db) return [];\n318: \n319:   const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n320:   const stalePaths = new Set<string>();\n321: \n322:   try {\n323:     const rows = hasCanonicalPathColumn()\n324:       ? (db.prepare(`\n325:           SELECT DISTINCT file_path, canonical_file_path\n326:           FROM memory_index\n327:           WHERE file_path IS NOT NULL AND file_path != ''\n328:         `) as Database.Statement).all() as IndexedPathRow[]\n329:       : (db.prepare(`\n330:           SELECT DISTINCT file_path\n331:           FROM memory_index\n332:           WHERE file_path IS NOT NULL AND file_path != ''\n333:         `) as Database.Statement).all() as IndexedPathRow[];\n334: \n335:     for (const row of rows) {\n336:       if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n337:         continue;\n338:       }\n339: \n340:       const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n341:         ? row.canonical_file_path\n342:         : getCanonicalPathKey(row.file_path);\n343: \n344:       if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n345:         continue;\n346:       }\n347: \n348:       const filePathExists = getFileMetadata(row.file_path).exists;\n349:       const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n350:         ? getFileMetadata(row.canonical_file_path).exists\n351:         : false;\n352: \n353:       if (!filePathExists && !canonicalPathExists) {\n354:         stalePaths.add(row.file_path);\n355:       }\n356:     }\n357:   } catch (error: unknown) {\n358:     const msg = error instanceof Error ? error.message : String(error);\n359:     console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n360:   }\n361: \n362:   return Array.from(stalePaths);\n363: }\n364: \n365: function listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n366:   if (!db || filePaths.length === 0) return [];\n367: \n368:   const ids = new Set<number>();\n369:   const seenLookupKeys = new Set<string>();\n370: \n371:   try {\n372:     for (const filePath of filePaths) {\n373:       if (typeof filePath !== 'string' || filePath.length === 0) {\n374:         continue;\n375:       }\n376: \n377:       const canonicalPath = getCanonicalPathKey(filePath);\n378:       const lookupKey = `${canonicalPath}::${filePath}`;\n379:       if (seenLookupKeys.has(lookupKey)) {\n380:         continue;\n381:       }\n382:       seenLookupKeys.add(lookupKey);\n383: \n384:       const rows = hasCanonicalPathColumn()\n385:         ? (db.prepare(`\n386:             SELECT id, file_path, canonical_file_path\n387:             FROM memory_index\n388:             WHERE canonical_file_path = ? OR file_path = ?\n389:           `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n390:         : (db.prepare(`\n391:             SELECT id, file_path\n392:             FROM memory_index\n393:             WHERE file_path = ?\n394:           `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n395: \n396:       for (const row of rows) {\n397:         if (!row || typeof row.id !== 'number') {\n398:           continue;\n399:         }\n400: \n401:         const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n402:           ? getFileMetadata(row.file_path).exists\n403:           : false;\n404:         const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n405:           ? getFileMetadata(row.canonical_file_path).exists\n406:           : false;\n407: \n408:         if (rowFileExists || rowCanonicalExists) {\n409:           continue;\n410:         }\n411: \n412:         ids.add(row.id);\n413:       }\n414:     }\n415:   } catch (error: unknown) {\n416:     const msg = error instanceof Error ? error.message : String(error);\n417:     console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n418:     return [];\n419:   }\n420: \n421:   return Array.from(ids).sort((a, b) => a - b);\n422: }\n423: \n424: function normalizeOrphanSweepLimit(limit?: number): number {\n425:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n426:     return DEFAULT_ORPHAN_SWEEP_LIMIT;\n427:   }\n428: \n429:   return Math.max(1, Math.floor(limit));\n430: }\n431: \n432: function indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n433:   const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n434:     ? getFileMetadata(row.file_path).exists\n435:     : false;\n436:   const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n437:     ? getFileMetadata(row.canonical_file_path).exists\n438:     : false;\n439: \n440:   return !rowFileExists && !rowCanonicalExists;\n441: }\n442: \n443: function sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n444:   if (!db) {\n445:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n446:   }\n447: \n448:   const limit = normalizeOrphanSweepLimit(options.limit);\n449:   const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n450:     ? Math.floor(options.cursor)\n451:     : 0;\n452: \n453:   try {\n454:     const rows = hasCanonicalPathColumn()\n455:       ? (db.prepare(`\n456:           SELECT id, file_path, canonical_file_path\n457:           FROM memory_index\n458:           WHERE id > ?\n459:             AND file_path IS NOT NULL\n460:             AND file_path != ''\n461:           ORDER BY id ASC\n462:           LIMIT ?\n463:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n464:       : (db.prepare(`\n465:           SELECT id, file_path\n466:           FROM memory_index\n467:           WHERE id > ?\n468:             AND file_path IS NOT NULL\n469:             AND file_path != ''\n470:           ORDER BY id ASC\n471:           LIMIT ?\n472:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n473: \n474:     const orphanRecordIds: number[] = [];\n475:     for (const row of rows) {\n476:       if (!row || typeof row.id !== 'number') {\n477:         continue;\n478:       }\n479:       if (indexedRecordIsAbsent(row)) {\n480:         orphanRecordIds.push(row.id);\n481:       }\n482:     }\n483: \n484:     return {\n485:       swept: orphanRecordIds.length,\n486:       nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n487:       scannedRows: rows.length,\n488:       orphanRecordIds,\n489:     };\n490:   } catch (error: unknown) {\n491:     const msg = error instanceof Error ? error.message : String(error);\n492:     console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n493:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n494:   }\n495: }\n496: \n497: /* ───────────────────────────────────────────────────────────────\n498:    7b. MOVE RECONCILIATION\n499: ----------------------------------------------------------------*/\n500: \n501: interface MoveReconcileCandidate {\n502:   oldPath: string;\n503:   newPath: string;\n504:   rowId: number;\n505:   docType: string;\n506: }\n507: \n508: interface ReconcileMovesResult {\n509:   reconciled: MoveReconcileCandidate[];\n510:   filteredToDelete: string[];\n511:   filteredToIndex: string[];\n512: }\n513: \n514: interface IncrementalChunkFingerprint {\n515:   chunkId: string;\n516:   chunkFingerprint: string;\n517: }\n518: \n519: interface MemoizedPlanningInput {\n520:   componentPath: string;\n521:   canonicalInput: unknown;\n522:   codeHash: string;\n523:   chunks?: IncrementalChunkFingerprint[];\n524: }\n525: \n526: interface MemoizedPlanningOptions {\n527:   invalidateDependents?: boolean;\n528: }\n529: \n530: interface MemoizedPlanningResult {\n531:   memoHits: number;\n532:   memoMisses: number;\n533:   chunkHits: number;\n534:   chunkMisses: number;\n535:   dependencyInvalidated: number;\n536:   changedComponentPaths: string[];\n537:   unchangedComponentPaths: string[];\n538:   invalidatedComponentPaths: string[];\n539: }\n540: \n541: function reconcileMoves(\n542:   toDelete: string[],\n543:   toIndex: string[],\n544: ): ReconcileMovesResult {\n545:   if (!db || toDelete.length === 0 || toIndex.length === 0) {\n546:     return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n547:   }\n548: \n549:   // Build a map: packet_id → [{newPath, docType, newGrandparent}] from the toIndex files.\n550:   // Reads graph-metadata.json from the NEW location only — the old one may be gone after a move.\n551:   const newByPacketId = new Map<string, Array<{ newPath: string; docType: string; newGrandparent: string }>>();\n552:   for (const newPath of toIndex) {\n553:     try {\n554:       const newSpecFolder = path.dirname(newPath);\n555:       const graphMetaPath = path.join(newSpecFolder, 'graph-metadata.json');\n556:       if (!fs.existsSync(graphMetaPath)) continue;\n557:       const raw = fs.readFileSync(graphMetaPath, 'utf-8');\n558:       const meta = JSON.parse(raw) as { packet_id?: string };\n559:       const packetId = meta?.packet_id;\n560:       if (typeof packetId !== 'string' || packetId.length === 0) continue;\n561:       const docType = path.basename(newPath, path.extname(newPath));\n562:       const newGrandparent = path.dirname(newSpecFolder);\n563:       if (!newByPacketId.has(packetId)) newByPacketId.set(packetId, []);\n564:       newByPacketId.get(packetId)!.push({ newPath, docType, newGrandparent });\n565:     } catch {\n566:       // skip unreadable or non-JSON graph-metadata\n567:     }\n568:   }\n569: \n570:   if (newByPacketId.size === 0) {\n571:     return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n572:   }\n573: \n574:   const reconciledOldPaths = new Set<string>();\n575:   const reconciledNewPaths = new Set<string>();\n576:   const reconciled: MoveReconcileCandidate[] = [];\n577: \n578:   // Iterate from the NEW side: for each new path whose folder still carries a packet_id,\n579:   // find the corresponding old path in toDelete by matching grandparent directory + basename\n580:   // (a sibling folder rename within the same parent). The packet_id only gates which new\n581:   // paths are eligible — the actual old→new pairing is grandparent + basename plus the\n582:   // DB uniqueness guards below; it does NOT match the old row by its packet_id (the old\n583:   // graph-metadata.json may be gone, and memory_index has no packet_id column). To avoid\n584:   // repointing across mismatched document kinds, the stored document_type is cross-checked\n585:   // against the doc type derived from the new path before the in-place update.\n586:   const docTypeAvailable = hasDocumentTypeColumn();\n587:   const selectSql = docTypeAvailable\n588:     ? `SELECT id, document_type FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`\n589:     : `SELECT id FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`;\n590:   for (const [, newCandidates] of newByPacketId) {\n591:     for (const { newPath, docType, newGrandparent } of newCandidates) {\n592:       if (reconciledNewPaths.has(newPath)) continue;\n593: \n594:       const newBasename = path.basename(newPath);\n595: \n596:       // Find toDelete paths that are sibling renames: same grandparent dir, same basename.\n597:       // A sibling rename means only the immediate spec folder name changed (e.g. 012-old → 012-new).\n598:       const siblingDeleted = toDelete.filter(oldPath =>\n599:         !reconciledOldPaths.has(oldPath) &&\n600:         path.basename(oldPath) === newBasename &&\n601:         path.dirname(path.dirname(oldPath)) === newGrandparent\n602:       );\n603: \n604:       if (siblingDeleted.length !== 1) continue; // uniqueness required\n605: \n606:       const oldPath = siblingDeleted[0];\n607:       const canonicalOld = getCanonicalPathKey(oldPath);\n608: \n609:       // Verify in DB: exactly one live row for this old path (uniqueness guard).\n610:       const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n611:       if (rows.length !== 1) continue;\n612: \n613:       // Cross-verify document kind: the stored document_type must agree with the doc type\n614:       // derived from the new path. Skip rows whose stored type diverged from the new file\n615:       // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n616:       // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n617:       if (docTypeAvailable) {\n618:         const storedDocType = rows[0].document_type ?? null;\n619:         if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;\n620:       }\n621: \n622:       const rowId = rows[0].id;\n623:       const newCanonical = getCanonicalPathKey(newPath);\n624:       const newSpecFolder = extractSpecFolder(newPath);\n625:       const newMtime = (() => {\n626:         try { return fs.statSync(newPath).mtimeMs; } catch { return null; }\n627:       })();\n628: \n629:       // Update the row's path in place (preserves embedding, id, history). A reconciled\n630:       // move is a folder rename, so spec_folder is repointed with the same canonicalization\n631:       // indexMemoryFile/migration 23 use — otherwise WHERE spec_folder=? grouping goes stale.\n632:       const updated = db!.prepare(`\n633:         UPDATE memory_index\n634:         SET file_path = ?,\n635:             canonical_file_path = ?,\n636:             spec_folder = ?,\n637:             file_mtime_ms = ?,\n638:             updated_at = datetime('now')\n639:         WHERE id = ?\n640:           AND embedding_status != 'failed'\n641:       `).run(newPath, newCanonical, newSpecFolder, newMtime, rowId);\n642: \n643:       if ((updated as { changes: number }).changes !== 1) continue;\n644: \n645:       reconciledOldPaths.add(oldPath);\n646:       reconciledNewPaths.add(newPath);\n647:       reconciled.push({ oldPath, newPath, rowId, docType });\n648:       console.error(`[incremental-index] Move reconciled: ${newBasename} ${oldPath} → ${newPath} (row ${rowId}, embedding preserved)`);\n649:     }\n650:   }\n651: \n652:   return {\n653:     reconciled,\n654:     filteredToDelete: toDelete.filter(p => !reconciledOldPaths.has(p)),\n655:     filteredToIndex: toIndex.filter(p => !reconciledNewPaths.has(p)),\n656:   };\n657: }\n658: \n659: function batchUpdateMtimes(filePaths: string[]): { updated: number; failed: number } {\n660:   if (!db) return { updated: 0, failed: filePaths.length };\n661: \n662:   let updated = 0;\n663:   let failed = 0;\n664: \n665:   const updateTx = db.transaction(() => {\n666:     for (const filePath of filePaths) {\n667:       if (setIndexedMtime(filePath)) {\n668:         updated++;\n669:       } else {\n670:         failed++;\n671:       }\n672:     }\n673:   });\n674: \n675:   try {\n676:     updateTx();\n677:   } catch (error: unknown) {\n678:     const msg = error instanceof Error ? error.message : String(error);\n679:     console.warn(`[incremental-index] batchUpdateMtimes error: ${msg}`);\n680:   }\n681: \n682:   return { updated, failed };\n683: }\n684: \n685: function countChunkFingerprintHits(database: Database.Database, input: MemoizedPlanningInput): { hits: number; misses: number } {\n686:   if (!input.chunks || input.chunks.length === 0) {\n687:     return { hits: 0, misses: 0 };\n688:   }\n689: \n690:   try {\n691:     const stmt = database.prepare(`\n692:       SELECT 1 AS hit\n693:       FROM memory_index\n694:       WHERE (canonical_file_path = ? OR file_path = ?)\n695:         AND chunk_id = ?\n696:         AND chunk_fingerprint = ?\n697:       LIMIT 1\n698:     `);\n699:     const canonicalPath = getCanonicalPathKey(input.componentPath);\n700:     let hits = 0;\n701:     let misses = 0;\n702:     for (const chunk of input.chunks) {\n703:       const row = stmt.get(canonicalPath, input.componentPath, chunk.chunkId, chunk.chunkFingerprint) as { hit?: number } | undefined;\n704:       if (row?.hit === 1) {\n705:         hits++;\n706:       } else {\n707:         misses++;\n708:       }\n709:     }\n710:     return { hits, misses };\n711:   } catch (error: unknown) {\n712:     const msg = error instanceof Error ? error.message : String(error);\n713:     console.warn(`[incremental-index] countChunkFingerprintHits error: ${msg}`);\n714:     return { hits: 0, misses: input.chunks.length };\n715:   }\n716: }\n717: \n718: function planMemoizedIndexing(\n719:   inputs: readonly MemoizedPlanningInput[],\n720:   options: MemoizedPlanningOptions = {},\n721:   database: Database.Database | null = db,\n722: ): MemoizedPlanningResult {\n723:   const result: MemoizedPlanningResult = {\n724:     memoHits: 0,\n725:     memoMisses: 0,\n726:     chunkHits: 0,\n727:     chunkMisses: 0,\n728:     dependencyInvalidated: 0,\n729:     changedComponentPaths: [],\n730:     unchangedComponentPaths: [],\n731:     invalidatedComponentPaths: [],\n732:   };\n733: \n734:   if (!database) {\n735:     result.changedComponentPaths = inputs.map((input) => input.componentPath);\n736:     result.memoMisses = inputs.length;\n737:     result.chunkMisses = inputs.reduce((count, input) => count + (input.chunks?.length ?? 0), 0);\n738:     return result;\n739:   }\n740: \n741:   const memoStore = createMemoStore(database);\n742:   const changedPaths: string[] = [];\n743:   for (const input of inputs) {\n744:     // An unfingerprintable input (e.g. a non-finite number) must not abort the\n745:     // whole batch plan — treat it as a memo miss for this one input so the\n746:     // remaining inputs are still planned.\n747:     let inputFingerprint: string | null = null;\n748:     try {\n749:       inputFingerprint = canonicalFingerprint(input.canonicalInput);\n750:     } catch (_error: unknown) {\n751:       inputFingerprint = null;\n752:     }\n753:     const memo = inputFingerprint === null\n754:       ? undefined\n755:       : memoStore.getMemoRecord(input.componentPath, inputFingerprint, input.codeHash);\n756:     if (memo) {\n757:       result.memoHits++;\n758:       result.unchangedComponentPaths.push(input.componentPath);\n759:     } else {\n760:       result.memoMisses++;\n761:       result.changedComponentPaths.push(input.componentPath);\n762:       changedPaths.push(input.componentPath);\n763:     }\n764: \n765:     const chunkCounts = countChunkFingerprintHits(database, input);\n766:     result.chunkHits += chunkCounts.hits;\n767:     result.chunkMisses += chunkCounts.misses;\n768:   }\n769: \n770:   if (options.invalidateDependents !== false && changedPaths.length > 0) {\n771:     const invalidation = memoStore.invalidateDependents(changedPaths);\n772:     result.invalidatedComponentPaths = invalidation.invalidatedPaths;\n773:     result.dependencyInvalidated = invalidation.invalidatedPaths.length;\n774:   }\n775: \n776:   return result;\n777: }\n778: \n779: /* ───────────────────────────────────────────────────────────────\n780:    8. EXPORTS\n781: ----------------------------------------------------------------*/\n782: \n783: export {\n784:   MTIME_FAST_PATH_MS,\n785: \n786:   init,\n787:   getFileMetadata,\n788:   getStoredMetadata,\n789:   shouldReindex,\n790:   updateFileMtime,\n791:   setIndexedMtime,\n792:   categorizeFilesForIndexing,\n793:   listStaleIndexedPaths,\n794:   listIndexedRecordIdsForDeletedPaths,\n795:   sweepOrphanIndexRows,\n796:   reconcileMoves,\n797:   batchUpdateMtimes,\n798:   planMemoizedIndexing,\n799: };\n800: \n801: /**\n802:  * Re-exports related public types.\n803:  */\n804: export type {\n805:   FileMetadata,\n806:   StoredMetadata,\n807:   IndexDecision,\n808:   CategorizedFiles,\n809:   OrphanSweepOptions,\n810:   OrphanSweepResult,\n811:   MoveReconcileCandidate,\n812:   ReconcileMovesResult,\n813:   IncrementalChunkFingerprint,\n814:   MemoizedPlanningInput,\n815:   MemoizedPlanningOptions,\n816:   MemoizedPlanningResult,\n817: };\n\n(End of file - total 817 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Incremental Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Deferred lexical-only indexing\n// Mtime-based incremental indexing for fast re-indexing\n// Node stdlib\nimport { createHash } from 'node:crypto';\nimport * as fs from 'fs';\nimport * as path from 'path';\n\n// External packages\nimport type Database from 'better-sqlite3';\n\n// Internal modules\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\nimport { canonicalFingerprint } from './canonical-fingerprint.js';\nimport { createMemoStore } from './memo.js';\n\n/* ───────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Incremental Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Deferred lexical-only indexing\n// Mtime-based incremental indexing for fast re-indexing\n// Node stdlib\nimport { createHash } from 'node:crypto';\nimport * as fs from 'fs';\nimport * as path from 'path';\n\n// External packages\nimport type Database from 'better-sqlite3';\n\n// Internal modules\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\nimport { canonicalFingerprint } from './canonical-fingerprint.js';\nimport { createMemoStore } from './memo.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MTIME_FAST_PATH_MS = 1000; // Skip if mtime within 1 second\nconst DEFAULT_ORPHAN_SWEEP_LIMIT = 200;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface FileMetadata {\n  path: string;\n  mtime: number;\n  size: number;\n  exists: boolean;\n}\n\ninterface StoredMetadata {\n  file_path: string;\n  canonical_file_path?: string | null;\n  file_mtime_ms: number | null;\n  content_hash: string | null;\n  embedding_status: string;\n}\n\ntype IndexDecision = 'skip' | 'reindex' | 'new' | 'deleted' | 'modified' | 'unknown';\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface IndexedPathRow {\n  file_path: string;\n  canonical_file_path?: string | null;\n}\n\ninterface IndexedRecordRow extends IndexedPathRow {\n  id: number;\n}\n\ninterface OrphanSweepOptions {\n  limit?: number;\n  cursor?: number;\n}\n\ninterface OrphanSweepResult {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds: number[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet canonicalPathColumnAvailable: boolean | null = null;\nlet documentTypeColumnAvailable: boolean | null = null;\n\nfunction init(database: Database.Database): void {\n  db = database;\n  canonicalPathColumnAvailable = null;\n  documentTypeColumnAvailable = null;\n}\n\nfunction hasCanonicalPathColumn(): boolean {\n  if (!db) return false;\n\n  if (canonicalPathColumnAvailable !== null) {\n    return canonicalPathColumnAvailable;\n  }\n\n  try {\n    const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n    canonicalPathColumnAvailable = columns.some((column) => column.name === 'canonical_file_path');\n  } catch {\n    canonicalPathColumnAvailable = false;\n  }\n\n  return canonicalPathColumnAvailable;\n}\n\nfunction hasDocumentTypeColumn(): boolean {\n  if (!db) return false;\n\n  if (documentTypeColumnAvailable !== null) {\n    return documentTypeColumnAvailable;\n  }\n\n  try {\n    const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n    documentTypeColumnAvailable = columns.some((column) => column.name === 'document_type');\n  } catch {\n    documentTypeColumnAvailable = false;\n  }\n\n  return documentTypeColumnAvailable;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. FILE METADATA\n----------------------------------------------------------------*/\n\nfunction getFileMetadata(filePath: string): FileMetadata {\n  try {\n    const stats = fs.statSync(filePath);\n    return {\n      path: filePath,\n      mtime: stats.mtimeMs,\n      size: stats.size,\n      exists: true,\n    };\n  } catch {\n    return {\n      path: filePath,\n      mtime: 0,\n      size: 0,\n      exists: false,\n    };\n  }\n}\n\nfunction getStoredMetadata(filePath: string): StoredMetadata | null {\n  if (!db) return null;\n\n  try {\n    const canonicalPath = getCanonicalPathKey(filePath);\n\n    const row = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT file_path, canonical_file_path, file_mtime_ms, content_hash, embedding_status\n          FROM memory_index\n          WHERE canonical_file_path = ? OR file_path = ?\n          ORDER BY CASE WHEN canonical_file_path = ? THEN 0 ELSE 1 END, id DESC\n          LIMIT 1\n        `) as Database.Statement).get(canonicalPath, filePath, canonicalPath) as StoredMetadata | undefined\n      : (db.prepare(`\n          SELECT file_path, file_mtime_ms, content_hash, embedding_status\n          FROM memory_index\n          WHERE file_path = ?\n        `) as Database.Statement).get(filePath) as StoredMetadata | undefined;\n\n    return row || null;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] getStoredMetadata error: ${msg}`);\n    return null;\n  }\n}\n\nfunction computeFileContentHash(filePath: string): string | null {\n  try {\n    const content = fs.readFileSync(filePath);\n    return createHash('sha256').update(content).digest('hex');\n  } catch {\n    return null;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. DECISION LOGIC\n----------------------------------------------------------------*/\n\n/**\n * 6-path decision logic for whether a file needs re-indexing.\n */\nfunction shouldReindex(filePath: string): IndexDecision {\n  const fileInfo = getFileMetadata(filePath);\n\n  // Path 1: File doesn't exist on disk\n  if (!fileInfo.exists) {\n    const stored = getStoredMetadata(filePath);\n    if (stored) return 'deleted';\n    return 'skip';\n  }\n\n  // Path 2: No stored metadata (new file)\n  const stored = getStoredMetadata(filePath);\n  if (!stored) return 'new';\n\n  // Path 3: No stored mtime (legacy entry, needs re-indexing)\n  if (stored.file_mtime_ms === null) return 'reindex';\n\n  // Path 4: Mtime unchanged (fast path - skip)\n  if (Math.abs(fileInfo.mtime - stored.file_mtime_ms) < MTIME_FAST_PATH_MS) {\n    // Still check if embedding status is pending\n    if (stored.embedding_status === 'pending' || stored.embedding_status === 'failed') {\n      return 'reindex';\n    }\n\n    if (stored.content_hash) {\n      const currentContentHash = computeFileContentHash(filePath);\n      if (currentContentHash && currentContentHash !== stored.content_hash) {\n        return 'modified';\n      }\n    }\n\n    return 'skip';\n  }\n\n  // Path 5: Mtime changed (file modified)\n  return 'modified';\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MTIME MANAGEMENT\n----------------------------------------------------------------*/\n\nfunction updateFileMtime(filePath: string, mtimeMs: number): boolean {\n  if (!db) return false;\n\n  try {\n    const canonicalPath = getCanonicalPathKey(filePath);\n\n    const result = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          UPDATE memory_index\n          SET file_mtime_ms = ?\n          WHERE canonical_file_path = ? OR file_path = ?\n        `) as Database.Statement).run(mtimeMs, canonicalPath, filePath)\n      : (db.prepare(`\n          UPDATE memory_index\n          SET file_mtime_ms = ?\n          WHERE file_path = ?\n        `) as Database.Statement).run(mtimeMs, filePath);\n\n    return (result as { changes: number }).changes > 0;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] updateFileMtime error: ${msg}`);\n    return false;\n  }\n}\n\nfunction setIndexedMtime(filePath: string): boolean {\n  const fileInfo = getFileMetadata(filePath);\n  if (!fileInfo.exists) return false;\n  return updateFileMtime(filePath, fileInfo.mtime);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. BATCH OPERATIONS\n----------------------------------------------------------------*/\n\nfunction categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n  const result: CategorizedFiles = {\n    toIndex: [],\n    toUpdate: [],\n    toSkip: [],\n    toDelete: [],\n  };\n\n  for (const filePath of filePaths) {\n    const decision = shouldReindex(filePath);\n\n    switch (decision) {\n      case 'new':\n        result.toIndex.push(filePath);\n        break;\n      case 'modified':\n      case 'reindex':\n        result.toUpdate.push(filePath);\n        break;\n      case 'deleted':\n        result.toDelete.push(filePath);\n        break;\n      case 'skip':\n      default:\n        result.toSkip.push(filePath);\n        break;\n    }\n  }\n\n  // Include stale indexed paths that are no longer discovered on disk.\n  // Without this pass, removed files never enter toDelete during normal scans\n  // Because discovery only returns files that currently exist.\n  const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n  if (staleIndexedPaths.length > 0) {\n    const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n    for (const stalePath of staleIndexedPaths) {\n      const staleKey = getCanonicalPathKey(stalePath);\n      if (!seenDeleteKeys.has(staleKey)) {\n        result.toDelete.push(stalePath);\n        seenDeleteKeys.add(staleKey);\n      }\n    }\n  }\n\n  return result;\n}\n\nfunction listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n  if (!db) return [];\n\n  const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n  const stalePaths = new Set<string>();\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT DISTINCT file_path, canonical_file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[]\n      : (db.prepare(`\n          SELECT DISTINCT file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[];\n\n    for (const row of rows) {\n      if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n        continue;\n      }\n\n      const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? row.canonical_file_path\n        : getCanonicalPathKey(row.file_path);\n\n      if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n        continue;\n      }\n\n      const filePathExists = getFileMetadata(row.file_path).exists;\n      const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? getFileMetadata(row.canonical_file_path).exists\n        : false;\n\n      if (!filePathExists && !canonicalPathExists) {\n        stalePaths.add(row.file_path);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n  }\n\n  return Array.from(stalePaths);\n}\n\nfunction listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n  if (!db || filePaths.length === 0) return [];\n\n  const ids = new Set<number>();\n  const seenLookupKeys = new Set<string>();\n\n  try {\n    for (const filePath of filePaths) {\n      if (typeof filePath !== 'string' || filePath.length === 0) {\n        continue;\n      }\n\n      const canonicalPath = getCanonicalPathKey(filePath);\n      const lookupKey = `${canonicalPath}::${filePath}`;\n      if (seenLookupKeys.has(lookupKey)) {\n        continue;\n      }\n      seenLookupKeys.add(lookupKey);\n\n      const rows = hasCanonicalPathColumn()\n        ? (db.prepare(`\n            SELECT id, file_path, canonical_file_path\n            FROM memory_index\n            WHERE canonical_file_path = ? OR file_path = ?\n          `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n        : (db.prepare(`\n            SELECT id, file_path\n            FROM memory_index\n            WHERE file_path = ?\n          `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n\n      for (const row of rows) {\n        if (!row || typeof row.id !== 'number') {\n          continue;\n        }\n\n        const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n          ? getFileMetadata(row.file_path).exists\n          : false;\n        const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n          ? getFileMetadata(row.canonical_file_path).exists\n          : false;\n\n        if (rowFileExists || rowCanonicalExists) {\n          continue;\n        }\n\n        ids.add(row.id);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n    return [];\n  }\n\n  return Array.from(ids).sort((a, b) => a - b);\n}\n\nfunction normalizeOrphanSweepLimit(limit?: number): number {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return DEFAULT_ORPHAN_SWEEP_LIMIT;\n  }\n\n  return Math.max(1, Math.floor(limit));\n}\n\nfunction indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n  const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n    ? getFileMetadata(row.file_path).exists\n    : false;\n  const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n    ? getFileMetadata(row.canonical_file_path).exists\n    : false;\n\n  return !rowFileExists && !rowCanonicalExists;\n}\n\nfunction sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n  if (!db) {\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n\n  const limit = normalizeOrphanSweepLimit(options.limit);\n  const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n    ? Math.floor(options.cursor)\n    : 0;\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT id, file_path, canonical_file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n      : (db.prepare(`\n          SELECT id, file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n\n    const orphanRecordIds: number[] = [];\n    for (const row of rows) {\n      if (!row || typeof row.id !== 'number') {\n        continue;\n      }\n      if (indexedRecordIsAbsent(row)) {\n        orphanRecordIds.push(row.id);\n      }\n    }\n\n    return {\n      swept: orphanRecordIds.length,\n      nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n      scannedRows: rows.length,\n      orphanRecordIds,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7b. MOVE RECONCILIATION\n----------------------------------------------------------------*/\n\ninterface MoveReconcileCandidate {\n  oldPath: string;\n  newPath: string;\n  rowId: number;\n  docType: string;\n}\n\ninterface ReconcileMovesResult {\n  reconciled: MoveReconcileCandidate[];\n  filteredToDelete: string[];\n  filteredToIndex: string[];\n}\n\ninterface IncrementalChunkFingerprint {\n  chunkId: string;\n  chunkFingerprint: string;\n}\n\ninterface MemoizedPlanningInput {\n  componentPath: string;\n  canonicalInput: unknown;\n  codeHash: string;\n  chunks?: IncrementalChunkFingerprint[];\n}\n\ninterface MemoizedPlanningOptions {\n  invalidateDependents?: boolean;\n}\n\ninterface MemoizedPlanningResult {\n  memoHits: number;\n  memoMisses: number;\n  chunkHits: number;\n  chunkMisses: number;\n  dependencyInvalidated: number;\n  changedComponentPaths: string[];\n  unchangedComponentPaths: string[];\n  invalidatedComponentPaths: string[];\n}\n\nfunction reconcileMoves(\n  toDelete: string[],\n  toIndex: string[],\n): ReconcileMovesResult {\n  if (!db || toDelete.length === 0 || toIndex.length === 0) {\n    return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n  }\n\n  // Build a map: packet_id → [{newPath, docType, newGrandparent}] from the toIndex files.\n  // Reads graph-metadata.json from the NEW location only — the old one may be gone after a move.\n  const newByPacketId = new Map<string, Array<{ newPath: string; docType: string; newGrandparent: string }>>();\n  for (const newPath of toIndex) {\n    try {\n      const newSpecFolder = path.dirname(newPath);\n      const graphMetaPath = path.join(newSpecFolder, 'graph-metadata.json');\n      if (!fs.existsSync(graphMetaPath)) continue;\n      const raw = fs.readFileSync(graphMetaPath, 'utf-8');\n      const meta = JSON.parse(raw) as { packet_id?: string };\n      const packetId = meta?.packet_id;\n      if (typeof packetId !== 'string' || packetId.length === 0) continue;\n      const docType = path.basename(newPath, path.extname(newPath));\n      const newGrandparent = path.dirname(newSpecFolder);\n      if (!newByPacketId.has(packetId)) newByPacketId.set(packetId, []);\n      newByPacketId.get(packetId)!.push({ newPath, docType, newGrandparent });\n    } catch {\n      // skip unreadable or non-JSON graph-metadata\n    }\n  }\n\n  if (newByPacketId.size === 0) {\n    return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n  }\n\n  const reconciledOldPaths = new Set<string>();\n  const reconciledNewPaths = new Set<string>();\n  const reconciled: MoveReconcileCandidate[] = [];\n\n  // Iterate from the NEW side: for each new path whose folder still carries a packet_id,\n  // find the corresponding old path in toDelete by matching grandparent directory + basename\n  // (a sibling folder rename within the same parent). The packet_id only gates which new\n  // paths are eligible — the actual old→new pairing is grandparent + basename plus the\n  // DB uniqueness guards below; it does NOT match the old row by its packet_id (the old\n  // graph-metadata.json may be gone, and memory_index has no packet_id column). To avoid\n  // repointing across mismatched document kinds, the stored document_type is cross-checked\n  // against the doc type derived from the new path before the in-place update.\n  const docTypeAvailable = hasDocumentTypeColumn();\n  const selectSql = docTypeAvailable\n    ? `SELECT id, document_type FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`\n    : `SELECT id FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`;\n  for (const [, newCandidates] of newByPacketId) {\n    for (const { newPath, docType, newGrandparent } of newCandidates) {\n      if (reconciledNewPaths.has(newPath)) continue;\n\n      const newBasename = path.basename(newPath);\n\n      // Find toDelete paths that are sibling renames: same grandparent dir, same basename.\n      // A sibling rename means only the immediate spec folder name changed (e.g. 012-old → 012-new).\n      const siblingDeleted = toDelete.filter(oldPath =>\n        !reconciledOldPaths.has(oldPath) &&\n        path.basename(oldPath) === newBasename &&\n        path.dirname(path.dirname(oldPath)) === newGrandparent\n      );\n\n      if (siblingDeleted.length !== 1) continue; // uniqueness required\n\n      const oldPath = siblingDeleted[0];\n      const canonicalOld = getCanonicalPathKey(oldPath);\n\n      // Verify in DB: exactly one live row for this old path (uniqueness guard).\n      const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n      if (rows.length !== 1) continue;\n\n      // Cross-verify document kind: the stored document_type must agree with the doc type\n      // derived from the new path. Skip rows whose stored type diverged from the new file\n      // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n      // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n      if (docTypeAvailable) {\n        const storedDocType = rows[0].document_type ?? null;\n        if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;\n      }\n\n      const rowId = rows[0].id;\n      const newCanonical = getCanonicalPathKey(newPath);\n      const newSpecFolder = extractSpecFolder(newPath);\n      const newMtime = (() => {\n        try { return fs.statSync(newPath).mtimeMs; } catch { return null; }\n      })();\n\n      // Update the row's path in place (preserves embedding, id, history). A reconciled\n      // move is a folder rename, so spec_folder is repointed with the same canonicalization\n      // indexMemoryFile/migration 23 use — otherwise WHERE spec_folder=? grouping goes stale.\n      const updated = db!.prepare(`\n        UPDATE memory_index\n        SET file_path = ?,\n            canonical_file_path = ?,\n            spec_folder = ?,\n            file_mtime_ms = ?,\n            updated_at = datetime('now')\n        WHERE id = ?\n          AND embedding_status != 'failed'\n      `).run(newPath, newCanonical, newSpecFolder, newMtime, rowId);\n\n      if ((updated as { changes: number }).changes !== 1) continue;\n\n      reconciledOldPaths.add(oldPath);\n      reconciledNewPaths.add(newPath);\n      reconciled.push({ oldPath, newPath, rowId, docType });\n      console.error(`[incremental-index] Move reconciled: ${newBasename} ${oldPath} → ${newPath} (row ${rowId}, embedding preserved)`);\n    }\n  }\n\n  return {\n    reconciled,\n    filteredToDelete: toDelete.filter(p => !reconciledOldPaths.has(p)),\n    filteredToIndex: toIndex.filter(p => !reconciledNewPaths.has(p)),\n  };\n}\n\nfunction batchUpdateMtimes(filePaths: string[]): { updated: number; failed: number } {\n  if (!db) return { updated: 0, failed: filePaths.length };\n\n  let updated = 0;\n  let failed = 0;\n\n  const updateTx = db.transaction(() => {\n    for (const filePath of filePaths) {\n      if (setIndexedMtime(filePath)) {\n        updated++;\n      } else {\n        failed++;\n      }\n    }\n  });\n\n  try {\n    updateTx();\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] batchUpdateMtimes error: ${msg}`);\n  }\n\n  return { updated, failed };\n}\n\nfunction countChunkFingerprintHits(database: Database.Database, input: MemoizedPlanningInput): { hits: number; misses: number } {\n  if (!input.chunks || input.chunks.length === 0) {\n    return { hits: 0, misses: 0 };\n  }\n\n  try {\n    const stmt = database.prepare(`\n      SELECT 1 AS hit\n      FROM memory_index\n      WHERE (canonical_file_path = ? OR file_path = ?)\n        AND chunk_id = ?\n        AND chunk_fingerprint = ?\n      LIMIT 1\n    `);\n    const canonicalPath = getCanonicalPathKey(input.componentPath);\n    let hits = 0;\n    let misses = 0;\n    for (const chunk of input.chunks) {\n      const row = stmt.get(canonicalPath, input.componentPath, chunk.chunkId, chunk.chunkFingerprint) as { hit?: number } | undefined;\n      if (row?.hit === 1) {\n        hits++;\n      } else {\n        misses++;\n      }\n    }\n    return { hits, misses };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] countChunkFingerprintHits error: ${msg}`);\n    return { hits: 0, misses: input.chunks.length };\n  }\n}\n\nfunction planMemoizedIndexing(\n  inputs: readonly MemoizedPlanningInput[],\n  options: MemoizedPlanningOptions = {},\n  database: Database.Database | null = db,\n): MemoizedPlanningResult {\n  const result: MemoizedPlanningResult = {\n    memoHits: 0,\n    memoMisses: 0,\n    chunkHits: 0,\n    chunkMisses: 0,\n    dependencyInvalidated: 0,\n    changedComponentPaths: [],\n    unchangedComponentPaths: [],\n    invalidatedComponentPaths: [],\n  };\n\n  if (!database) {\n    result.changedComponentPaths = inputs.map((input) => input.componentPath);\n    result.memoMisses = inputs.length;\n    result.chunkMisses = inputs.reduce((count, input) => count + (input.chunks?.length ?? 0), 0);\n    return result;\n  }\n\n  const memoStore = createMemoStore(database);\n  const changedPaths: string[] = [];\n  for (const input of inputs) {\n    // An unfingerprintable input (e.g. a non-finite number) must not abort the\n    // whole batch plan — treat it as a memo miss for this one input so the\n    // remaining inputs are still planned.\n    let inputFingerprint: string | null = null;\n    try {\n      inputFingerprint = canonicalFingerprint(input.canonicalInput);\n    } catch (_error: unknown) {\n      inputFingerprint = null;\n    }\n    const memo = inputFingerprint === null\n      ? undefined\n      : memoStore.getMemoRecord(input.componentPath, inputFingerprint, input.codeHash);\n    if (memo) {\n      result.memoHits++;\n      result.unchangedComponentPaths.push(input.componentPath);\n    } else {\n      result.memoMisses++;\n      result.changedComponentPaths.push(input.componentPath);\n      changedPaths.push(input.componentPath);\n    }\n\n    const chunkCounts = countChunkFingerprintHits(database, input);\n    result.chunkHits += chunkCounts.hits;\n    result.chunkMisses += chunkCounts.misses;\n  }\n\n  if (options.invalidateDependents !== false && changedPaths.length > 0) {\n    const invalidation = memoStore.invalidateDependents(changedPaths);\n    result.invalidatedComponentPaths = invalidation.invalidatedPaths;\n    result.dependencyInvalidated = invalidation.invalidatedPaths.length;\n  }\n\n  return result;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  MTIME_FAST_PATH_MS,\n\n  init,\n  getFileMetadata,\n  getStoredMetadata,\n  shouldReindex,\n  updateFileMtime,\n  setIndexedMtime,\n  categorizeFilesForIndexing,\n  listStaleIndexedPaths,\n  listIndexedRecordIdsForDeletedPaths,\n  sweepOrphanIndexRows,\n  reconcileMoves,\n  batchUpdateMtimes,\n  planMemoizedIndexing,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  FileMetadata,\n  StoredMetadata,\n  IndexDecision,\n  CategorizedFiles,\n  OrphanSweepOptions,\n  OrphanSweepResult,\n  MoveReconcileCandidate,\n  ReconcileMovesResult,\n  IncrementalChunkFingerprint,\n  MemoizedPlanningInput,\n  MemoizedPlanningOptions,\n  MemoizedPlanningResult,\n};","lineStart":1,"lineEnd":817,"totalLines":817,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","time":{"start":1781763537165,"end":1781763537171}},"metadata":{"openai":{"itemId":"fc_0c7f0d34804e8883016a338dd0e9588191b63fbd7ef8644f09"}},"id":"prt_ed961f90c001tUGLzwtWm3NKM9","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed961c2cd001IXicaEfwAgJdoJ"}}
