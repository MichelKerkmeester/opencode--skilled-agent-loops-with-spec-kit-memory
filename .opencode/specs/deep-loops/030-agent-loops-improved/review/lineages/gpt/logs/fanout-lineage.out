cription\": \"Validates cross-skill wikilinks when explicitly enabled.\"\n  },\n  {\n    \"rule_id\": \"SECTION_COUNTS\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-section-counts.sh\",\n    \"severity\": \"error\",\n    \"category\": \"authored_template\",\n    \"description\": \"Checks section-count expectations for authored spec documents.\"\n  },\n  {\n    \"rule_id\": \"SPEC_DOC_INTEGRITY\",\n    \"aliases\": [\"DOC_INTEGRITY\"],\n    \"script_path\": \"rules/check-spec-doc-integrity.sh\",\n    \"severity\": \"error\",\n    \"category\": \"authored_template\",\n    \"description\": \"Verifies inline markdown references resolve within spec docs.\"\n  },\n  {\n    \"rule_id\": \"TEMPLATE_SOURCE\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-template-source.sh\",\n    \"severity\": \"error\",\n    \"category\": \"authored_template\",\n    \"description\": \"Checks SPECKIT_TEMPLATE_SOURCE provenance markers.\"\n  },\n  {\n    \"rule_id\": \"TEMPLATE_HEADERS\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-template-headers.sh\",\n    \"severity\": \"error\",\n    \"category\": \"authored_template\",\n    \"description\": \"Checks required template header order and naming.\"\n  },\n  {\n    \"rule_id\": \"CANONICAL_SAVE_ROOT_SPEC_REQUIRED\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-canonical-save.sh\",\n    \"severity\": \"error\",\n    \"category\": \"operational_runtime\",\n    \"description\": \"Ensures canonical saves include a root spec reference.\"\n  },\n  {\n    \"rule_id\": \"CANONICAL_SAVE_SOURCE_DOCS_REQUIRED\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-canonical-save.sh\",\n    \"severity\": \"error\",\n    \"category\": \"operational_runtime\",\n    \"description\": \"Ensures canonical saves include source document references.\"\n  },\n  {\n    \"rule_id\": \"CANONICAL_SAVE_LINEAGE_REQUIRED\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-canonical-save.sh\",\n    \"severity\": \"error\",\n    \"category\": \"operational_runtime\",\n    \"description\": \"Ensures canonical save lineage metadata is present.\"\n  },\n  {\n    \"rule_id\": \"CANONICAL_SAVE_PACKET_IDENTITY_NORMALIZED\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-canonical-save.sh\",\n    \"severity\": \"error\",\n    \"category\": \"operational_runtime\",\n    \"description\": \"Checks canonical save packet identity normalization.\"\n  },\n  {\n    \"rule_id\": \"CANONICAL_SAVE_DESCRIPTION_GRAPH_FRESHNESS\",\n    \"aliases\": [],\n    \"script_path\": \"rules/check-canonical-save.sh\",\n    \"severity\": \"error\",\n    \"category\": \"operational_runtime\",\n    \"description\": \"Checks generated description/graph freshness for canonical saves.\"\n  },\n  {\n    \"rule_id\": \"CONTINUITY_FRESHNESS\",\n    \"aliases\": [],\n    \"script_path\": \"validation/continuity-freshness.ts\",\n    \"severity\": \"warn\",\n    \"category\": \"operational_runtime\",\n    \"strict_only\": true,\n    \"description\": \"Strict-mode freshness check for continuity frontmatter.\"\n  },\n  {\n    \"rule_id\": \"EVIDENCE_MARKER_LINT\",\n    \"aliases\": [],\n    \"script_path\": \"validation/evidence-marker-lint.ts\",\n    \"severity\": \"warn\",\n    \"category\": \"operational_runtime\",\n    \"strict_only\": true,\n    \"description\": \"Strict-mode lint for evidence marker formatting.\"\n  },\n  {\n    \"rule_id\": \"GENERATED_METADATA_INTEGRITY\",\n    \"aliases\": [\"GENERATED_METADATA\", \"METADATA_INTEGRITY\"],\n    \"script_path\": \"validation/generated-metadata-integrity.ts\",\n    \"severity\": \"error\",\n    \"category\": \"structural\",\n    \"strict_only\": true,\n    \"description\": \"Validates description.json and graph-metadata.json through the shared schemas plus path-prefix and status-enum invariants, error under strict behind a grandfather report mode.\"\n  },\n  {\n    \"rule_id\": \"GENERATED_METADATA_DRIFT\",\n    \"aliases\": [\"METADATA_DRIFT\