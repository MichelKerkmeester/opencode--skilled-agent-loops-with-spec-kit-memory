{"type":"tool_use","timestamp":1781718652915,"sessionID":"ses_1294e112dffeF8UlfEsNhSrzCb","part":{"type":"tool","tool":"read","callID":"tool_6iwxnnUF36sxOJ8QIxHMsvU6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-store.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-store.vitest.ts</path>\n<type>file</type>\n<content>\n1: // TEST: Maintenance Job Store\n2: import { afterEach, describe, expect, it, vi } from 'vitest';\n3: \n4: import Database from 'better-sqlite3';\n5: \n6: type JobStoreModule = typeof import('../lib/ops/job-store');\n7: \n8: const databases: Array<Database.Database> = [];\n9: \n10: function createTestDb(): Database.Database {\n11:   const db = new Database(':memory:');\n12:   databases.push(db);\n13:   return db;\n14: }\n15: \n16: async function loadJobStoreModule(db: Database.Database): Promise<JobStoreModule> {\n17:   vi.resetModules();\n18:   vi.doMock('../utils', () => ({\n19:     requireDb: () => db,\n20:     toErrorMessage: (error: unknown) => (error instanceof Error ? error.message : String(error)),\n21:   }));\n22:   return await import('../lib/ops/job-store');\n23: }\n24: \n25: function seedJob(db: Database.Database, row: { id: string; kind: string; state: string }): void {\n26:   db.prepare(`\n27:     INSERT INTO maintenance_jobs (\n28:       id, kind, state, phase, progress_total, progress_processed,\n29:       cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n30:     ) VALUES (?, ?, ?, NULL, 0, 0, 0, '[]', NULL, NULL, 'seed', 'seed')\n31:   `).run(row.id, row.kind, row.state);\n32: }\n33: \n34: afterEach(() => {\n35:   while (databases.length > 0) {\n36:     const db = databases.pop();\n37:     if (db) db.close();\n38:   }\n39:   vi.resetModules();\n40:   vi.restoreAllMocks();\n41: });\n42: \n43: describe('maintenance job store crash recovery', () => {\n44:   it('marks running index_scan jobs failed and leaves other kinds untouched', async () => {\n45:     const db = createTestDb();\n46:     const mod = await loadJobStoreModule(db);\n47:     mod.ensureMaintenanceJobsTable();\n48: \n49:     seedJob(db, { id: 'job_scan_running', kind: 'index_scan', state: 'running' });\n50:     seedJob(db, { id: 'job_scan_queued', kind: 'index_scan', state: 'queued' });\n51:     seedJob(db, { id: 'job_scan_done', kind: 'index_scan', state: 'complete' });\n52:     seedJob(db, { id: 'job_ingest_running', kind: 'ingest', state: 'running' });\n53: \n54:     const reset = mod.resetRunningJobsForKind('index_scan', { to: 'failed' });\n55:     expect(reset.sort()).toEqual(['job_scan_queued', 'job_scan_running']);\n56: \n57:     expect(mod.getMaintenanceJob('job_scan_running')?.state).toBe('failed');\n58:     expect(mod.getMaintenanceJob('job_scan_queued')?.state).toBe('failed');\n59:     // Terminal scan job and the unrelated ingest job are not rewritten.\n60:     expect(mod.getMaintenanceJob('job_scan_done')?.state).toBe('complete');\n61:     expect(mod.getMaintenanceJob('job_ingest_running')?.state).toBe('running');\n62:   });\n63: });\n64: \n65: describe('maintenance job store SQLITE_BUSY retry', () => {\n66:   it('retries INSERT/UPDATE under SQLITE_BUSY so writes still land', async () => {\n67:     const db = createTestDb();\n68: \n69:     let writeCallCount = 0;\n70:     const FAILURES_BEFORE_SUCCESS = 2;\n71:     const originalPrepare = db.prepare.bind(db);\n72: \n73:     db.prepare = function (sql: string) {\n74:       const stmt = originalPrepare(sql);\n75:       if (/^\\s*(INSERT|UPDATE)\\b/i.test(sql)) {\n76:         const originalRun = stmt.run.bind(stmt);\n77:         stmt.run = function (...args: unknown[]) {\n78:           writeCallCount += 1;\n79:           if (writeCallCount <= FAILURES_BEFORE_SUCCESS) {\n80:             const busyError = new Error('SQLITE_BUSY: database is locked');\n81:             (busyError as unknown as { code: string }).code = 'SQLITE_BUSY';\n82:             throw busyError;\n83:           }\n84:           return originalRun(...args);\n85:         };\n86:       }\n87:       return stmt;\n88:     } as typeof db.prepare;\n89: \n90:     const mod = await loadJobStoreModule(db);\n91:     // CREATE TABLE/INDEX run via db.exec, which the prepare interceptor does not touch.\n92:     mod.ensureMaintenanceJobsTable();\n93: \n94:     const job = await mod.createMaintenanceJob({ id: 'job_busy', kind: 'index_scan' });\n95:     expect(job.state).toBe('queued');\n96:     expect(writeCallCount).toBeGreaterThan(FAILURES_BEFORE_SUCCESS);\n97:     expect(mod.getMaintenanceJob('job_busy')?.state).toBe('queued');\n98: \n99:     // Reset the failure budget so the UPDATE path (setJobState), not just the\n100:     // INSERT, is forced through the busy-retry loop and proven to land.\n101:     writeCallCount = 0;\n102:     const updated = await mod.setJobState('job_busy', 'running');\n103:     expect(updated.state).toBe('running');\n104:     expect(writeCallCount).toBeGreaterThan(FAILURES_BEFORE_SUCCESS);\n105:     expect(mod.getMaintenanceJob('job_busy')?.state).toBe('running');\n106:   });\n107: });\n108: \n109: describe('maintenance job store transitions', () => {\n110:   it('rejects illegal transitions and supports the cancel flag', async () => {\n111:     const db = createTestDb();\n112:     const mod = await loadJobStoreModule(db);\n113:     mod.ensureMaintenanceJobsTable();\n114: \n115:     await mod.createMaintenanceJob({ id: 'job_done', kind: 'index_scan' });\n116:     await mod.setJobState('job_done', 'running');\n117:     const completed = await mod.completeJob('job_done', { state: 'complete', result: { indexed: 3 } });\n118:     expect(completed.state).toBe('complete');\n119:     // Terminal state echoes the stored result for status polling.\n120:     expect(mod.getMaintenanceJob('job_done')?.result).toEqual({ indexed: 3 });\n121: \n122:     // Illegal: a terminal job cannot transition back to running.\n123:     await expect(mod.setJobState('job_done', 'running')).rejects.toThrow(/Invalid maintenance job state transition/);\n124: \n125:     await mod.createMaintenanceJob({ id: 'job_cancel', kind: 'index_scan' });\n126:     await mod.setJobState('job_cancel', 'running');\n127:     expect(mod.isCancelRequested('job_cancel')).toBe(false);\n128:     await mod.requestCancel('job_cancel');\n129:     expect(mod.isCancelRequested('job_cancel')).toBe(true);\n130: \n131:     const cancelled = await mod.setJobState('job_cancel', 'cancelled');\n132:     expect(cancelled.state).toBe('cancelled');\n133:     expect(mod.isTerminalJobState('cancelled')).toBe(true);\n134:   });\n135: });\n136: \n137: describe('maintenance job store error truncation', () => {\n138:   it('caps stored errors with a truncation-notice head', async () => {\n139:     const db = createTestDb();\n140:     const mod = await loadJobStoreModule(db);\n141:     mod.ensureMaintenanceJobsTable();\n142: \n143:     await mod.createMaintenanceJob({ id: 'job_errors', kind: 'index_scan' });\n144: \n145:     const overflow = mod.MAX_STORED_ERRORS + 10;\n146:     for (let i = 0; i < overflow; i += 1) {\n147:       await mod.appendJobError('job_errors', `source-${i}`, new Error(`boom ${i}`));\n148:     }\n149: \n150:     const job = mod.getMaintenanceJob('job_errors');\n151:     expect(job?.errors).toHaveLength(mod.MAX_STORED_ERRORS);\n152:     expect(job?.errors[0]?.source).toBe('__job__');\n153:     expect(job?.errors[0]?.message).toMatch(/error log truncated/);\n154:     // The most recent error is retained in the truncated tail.\n155:     expect(job?.errors[job.errors.length - 1]?.message).toBe(`boom ${overflow - 1}`);\n156:   });\n157: });\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"// TEST: Maintenance Job Store\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport Database from 'better-sqlite3';\n\ntype JobStoreModule = typeof import('../lib/ops/job-store');\n\nconst databases: Array<Database.Database> = [];\n\nfunction createTestDb(): Database.Database {\n  const db = new Database(':memory:');\n  databases.push(db);\n  return db;\n}\n\nasync function loadJobStoreModule(db: Database.Database): Promise<JobStoreModule> {\n  vi.resetModules();\n  vi.doMock('../utils', () => ({\n    requireDb: () => db,\n    toErrorMessage: (error: unknown) => (error instanceof Error ? error.message : String(error)),","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-store.vitest.ts","text":"// TEST: Maintenance Job Store\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport Database from 'better-sqlite3';\n\ntype JobStoreModule = typeof import('../lib/ops/job-store');\n\nconst databases: Array<Database.Database> = [];\n\nfunction createTestDb(): Database.Database {\n  const db = new Database(':memory:');\n  databases.push(db);\n  return db;\n}\n\nasync function loadJobStoreModule(db: Database.Database): Promise<JobStoreModule> {\n  vi.resetModules();\n  vi.doMock('../utils', () => ({\n    requireDb: () => db,\n    toErrorMessage: (error: unknown) => (error instanceof Error ? error.message : String(error)),\n  }));\n  return await import('../lib/ops/job-store');\n}\n\nfunction seedJob(db: Database.Database, row: { id: string; kind: string; state: string }): void {\n  db.prepare(`\n    INSERT INTO maintenance_jobs (\n      id, kind, state, phase, progress_total, progress_processed,\n      cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n    ) VALUES (?, ?, ?, NULL, 0, 0, 0, '[]', NULL, NULL, 'seed', 'seed')\n  `).run(row.id, row.kind, row.state);\n}\n\nafterEach(() => {\n  while (databases.length > 0) {\n    const db = databases.pop();\n    if (db) db.close();\n  }\n  vi.resetModules();\n  vi.restoreAllMocks();\n});\n\ndescribe('maintenance job store crash recovery', () => {\n  it('marks running index_scan jobs failed and leaves other kinds untouched', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    seedJob(db, { id: 'job_scan_running', kind: 'index_scan', state: 'running' });\n    seedJob(db, { id: 'job_scan_queued', kind: 'index_scan', state: 'queued' });\n    seedJob(db, { id: 'job_scan_done', kind: 'index_scan', state: 'complete' });\n    seedJob(db, { id: 'job_ingest_running', kind: 'ingest', state: 'running' });\n\n    const reset = mod.resetRunningJobsForKind('index_scan', { to: 'failed' });\n    expect(reset.sort()).toEqual(['job_scan_queued', 'job_scan_running']);\n\n    expect(mod.getMaintenanceJob('job_scan_running')?.state).toBe('failed');\n    expect(mod.getMaintenanceJob('job_scan_queued')?.state).toBe('failed');\n    // Terminal scan job and the unrelated ingest job are not rewritten.\n    expect(mod.getMaintenanceJob('job_scan_done')?.state).toBe('complete');\n    expect(mod.getMaintenanceJob('job_ingest_running')?.state).toBe('running');\n  });\n});\n\ndescribe('maintenance job store SQLITE_BUSY retry', () => {\n  it('retries INSERT/UPDATE under SQLITE_BUSY so writes still land', async () => {\n    const db = createTestDb();\n\n    let writeCallCount = 0;\n    const FAILURES_BEFORE_SUCCESS = 2;\n    const originalPrepare = db.prepare.bind(db);\n\n    db.prepare = function (sql: string) {\n      const stmt = originalPrepare(sql);\n      if (/^\\s*(INSERT|UPDATE)\\b/i.test(sql)) {\n        const originalRun = stmt.run.bind(stmt);\n        stmt.run = function (...args: unknown[]) {\n          writeCallCount += 1;\n          if (writeCallCount <= FAILURES_BEFORE_SUCCESS) {\n            const busyError = new Error('SQLITE_BUSY: database is locked');\n            (busyError as unknown as { code: string }).code = 'SQLITE_BUSY';\n            throw busyError;\n          }\n          return originalRun(...args);\n        };\n      }\n      return stmt;\n    } as typeof db.prepare;\n\n    const mod = await loadJobStoreModule(db);\n    // CREATE TABLE/INDEX run via db.exec, which the prepare interceptor does not touch.\n    mod.ensureMaintenanceJobsTable();\n\n    const job = await mod.createMaintenanceJob({ id: 'job_busy', kind: 'index_scan' });\n    expect(job.state).toBe('queued');\n    expect(writeCallCount).toBeGreaterThan(FAILURES_BEFORE_SUCCESS);\n    expect(mod.getMaintenanceJob('job_busy')?.state).toBe('queued');\n\n    // Reset the failure budget so the UPDATE path (setJobState), not just the\n    // INSERT, is forced through the busy-retry loop and proven to land.\n    writeCallCount = 0;\n    const updated = await mod.setJobState('job_busy', 'running');\n    expect(updated.state).toBe('running');\n    expect(writeCallCount).toBeGreaterThan(FAILURES_BEFORE_SUCCESS);\n    expect(mod.getMaintenanceJob('job_busy')?.state).toBe('running');\n  });\n});\n\ndescribe('maintenance job store transitions', () => {\n  it('rejects illegal transitions and supports the cancel flag', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    await mod.createMaintenanceJob({ id: 'job_done', kind: 'index_scan' });\n    await mod.setJobState('job_done', 'running');\n    const completed = await mod.completeJob('job_done', { state: 'complete', result: { indexed: 3 } });\n    expect(completed.state).toBe('complete');\n    // Terminal state echoes the stored result for status polling.\n    expect(mod.getMaintenanceJob('job_done')?.result).toEqual({ indexed: 3 });\n\n    // Illegal: a terminal job cannot transition back to running.\n    await expect(mod.setJobState('job_done', 'running')).rejects.toThrow(/Invalid maintenance job state transition/);\n\n    await mod.createMaintenanceJob({ id: 'job_cancel', kind: 'index_scan' });\n    await mod.setJobState('job_cancel', 'running');\n    expect(mod.isCancelRequested('job_cancel')).toBe(false);\n    await mod.requestCancel('job_cancel');\n    expect(mod.isCancelRequested('job_cancel')).toBe(true);\n\n    const cancelled = await mod.setJobState('job_cancel', 'cancelled');\n    expect(cancelled.state).toBe('cancelled');\n    expect(mod.isTerminalJobState('cancelled')).toBe(true);\n  });\n});\n\ndescribe('maintenance job store error truncation', () => {\n  it('caps stored errors with a truncation-notice head', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    await mod.createMaintenanceJob({ id: 'job_errors', kind: 'index_scan' });\n\n    const overflow = mod.MAX_STORED_ERRORS + 10;\n    for (let i = 0; i < overflow; i += 1) {\n      await mod.appendJobError('job_errors', `source-${i}`, new Error(`boom ${i}`));\n    }\n\n    const job = mod.getMaintenanceJob('job_errors');\n    expect(job?.errors).toHaveLength(mod.MAX_STORED_ERRORS);\n    expect(job?.errors[0]?.source).toBe('__job__');\n    expect(job?.errors[0]?.message).toMatch(/error log truncated/);\n    // The most recent error is retained in the truncated tail.\n    expect(job?.errors[job.errors.length - 1]?.message).toBe(`boom ${overflow - 1}`);\n  });\n});","lineStart":1,"lineEnd":157,"totalLines":157,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/job-store.vitest.ts","time":{"start":1781718652904,"end":1781718652913}},"id":"prt_ed6b51579001724uWvIdqV6TYe","sessionID":"ses_1294e112dffeF8UlfEsNhSrzCb","messageID":"msg_ed6b4e7f3001ltttkyoSxKgJWc"}}
