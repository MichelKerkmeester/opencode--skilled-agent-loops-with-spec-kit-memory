 [['sk-code', 0.65]],\n88:   inp: [['sk-code', 0.65]],\n89:   lcp: [['sk-code', 0.55]],\n90:   fcp: [['sk-code', 0.55]],\n91:   cls: [['sk-code', 0.55]],\n92:   motion: [['sk-code', 0.6]],\n93:   observer: [['sk-code', 0.4]],\n94:   intersection: [['sk-code', 0.4]],\n95:   classifier: [['sk-code', 0.45]],\n96:   fixture: [['sk-code', 0.55]],\n97:   'gate-3-classifier': [['sk-code', 0.95]],\n98:   'negative-trigger': [['sk-code', 0.8]],\n99: };\n100: \n101: const PHRASE_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n102:   '/create:agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n103:   '/create:manual-testing-playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n104:   '/memory:save': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n105:   '/deep:start-research-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n106:   '/deep:start-review-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n107:   '/deep:start-model-benchmark-loop': [['deep-model-benchmark', 1.6], ['command-spec-kit', 0.45]],\n108:   '/deep:start-agent-improvement-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n109:   '/speckit:resume': [['system-spec-kit', 0.9], ['command-spec-kit', 0.75]],\n110:   'auto review release readiness': [['deep-loop-workflows', 1]],\n111:   // Colon-command syntax (\":review:auto\") is a deep-review LOOP invocation,\n112:   // distinct from natural-language \"auto review this PR\" (which routes to\n113:   // sk-code's code-review mode). Strong direct-evidence anchor + a bounded\n114:   // penalty on the single-pass skill so the loop skill wins the rank.\n115:   ':review:auto': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n116:   ':review:confirm': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n117:   // Domain phrase anchors (multi-token, so they lift confidence via the direct\n118:   // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n119:   'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n120:   'cms collection': [['mcp-code-mode', 1.4]],\n121:   'structural search': [['system-code-graph', 1.5]],\n122:   'code graph search': [['system-code-graph', 1.5]],\n123:   'find code that': [['system-code-graph', 1.4]],\n124:   'code that handles': [['system-code-graph', 1.4]],\n125:   '5d scoring': [['deep-loop-workflows', 1.5]],\n126:   '5-dimension agent scoring': [['deep-loop-workflows', 1.6]],\n127:   'integration scan': [['deep-loop-workflows', 1.5]],\n128:   'dynamic profile': [['deep-loop-workflows', 1.5]],\n129:   // Lane B (model-benchmark) command anchors. These benchmark or optimize a\n130:   // model / prompt framework against fixtures, routed by the\n131:   // /deep:start-model-benchmark-loop command (canonical deep-model-benchmark).\n132:   // Lane B runs as a MODE of the agent-improvement skill, now folded into\n133:   // deep-loop-workflows. The projection exposes that merged node, so the\n134:   // disambiguation penalty must target deep-loop-workflows to actually lower the\n135:   // ranked Lane A candidate; an alias-shaped target is not a projection node and\n136:   // its penalty would be inert. The bounded penalty keeps benchmark phrasing\n137:   // from out-ranking deep-model-benchmark.\n138:   'benchmark a model': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n139:   'benchmark a prompt framework': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n140:   'benchmark a prompt': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n141:   'optimize a model': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n142:   'optimize a prompt framework': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n143:   'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.4]],\n144:   'model benchmark': [['deep