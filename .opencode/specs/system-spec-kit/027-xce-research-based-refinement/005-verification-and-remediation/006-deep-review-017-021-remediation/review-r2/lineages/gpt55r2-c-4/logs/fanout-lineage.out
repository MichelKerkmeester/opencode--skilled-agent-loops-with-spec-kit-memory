{"type":"tool_use","timestamp":1781762444494,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_xbn03Q59dCZJ80H2P3moz5gC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts","offset":1,"limit":460},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC Socket Server (multi-client launcher bridge)\n3: // ───────────────────────────────────────────────────────────────\n4: // Canonical bridge logic shared by every daemon launcher (memory,\n5: // code-index, skill-advisor). Each service supplies its own socket/db\n6: // PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n7: // and race-safety contract stays identical across services.\n8: \n9: import fs from 'node:fs';\n10: import net from 'node:net';\n11: import os from 'node:os';\n12: import path from 'node:path';\n13: \n14: import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n15: \n16: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n17: // Every live session's launcher holds one persistent slot, and multi-seat\n18: // fan-outs run well past 8 concurrent sessions. A refused connection is\n19: // accepted then closed, which probes cannot distinguish from a dead daemon,\n20: // so the cap must exceed any realistic session fleet.\n21: const DEFAULT_MAX_SECONDARY_CLIENTS = 64;\n22: const TCP_EADDRINUSE_RETRY_DELAYS_MS = [100, 250, 500, 1000, 1500] as const;\n23: \n24: interface IpcBridgeStats {\n25:   socket_path: string | null;\n26:   secondary_clients_count: number;\n27:   total_secondary_messages_in: number;\n28:   total_secondary_messages_out: number;\n29: }\n30: \n31: // Structural shape of the only MCP server capability this bridge uses. Typed structurally (a\n32: // method, so its transport param is bivariant) rather than against a concrete `Server` import so\n33: // every consuming package satisfies it with its own `@modelcontextprotocol/sdk` copy — the three\n34: // daemons each install the SDK separately and its private members make the classes nominally\n35: // distinct, which a concrete import would reject across package boundaries.\n36: interface McpServerLike {\n37:   connect(transport: StdioServerTransport): Promise<void>;\n38: }\n39: \n40: interface IpcSocketServerOptions {\n41:   readonly socketPath: string;\n42:   readonly createServer: () => McpServerLike;\n43:   readonly maxClients?: number;\n44:   readonly log?: (message: string) => void;\n45:   readonly onActivity?: () => void;\n46: }\n47: \n48: interface IpcSocketServerHandle {\n49:   readonly socketPath: string;\n50:   readonly close: () => Promise<void>;\n51: }\n52: \n53: let activeServer: net.Server | null = null;\n54: let activeSocketPath: string | null = null;\n55: const activeSockets = new Set<net.Socket>();\n56: const activeTransports = new Map<net.Socket, StdioServerTransport>();\n57: let totalSecondaryMessagesIn = 0;\n58: let totalSecondaryMessagesOut = 0;\n59: \n60: function countJsonRpcFrames(chunk: unknown): number {\n61:   const text = Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n62:   const newlineCount = text.split('\\n').length - 1;\n63:   return Math.max(1, newlineCount);\n64: }\n65: \n66: function parseMaxClients(rawValue = process.env.SPECKIT_MAX_SECONDARY_CLIENTS): number {\n67:   if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') {\n68:     return DEFAULT_MAX_SECONDARY_CLIENTS;\n69:   }\n70:   const parsed = Number.parseInt(String(rawValue), 10);\n71:   if (!Number.isFinite(parsed) || parsed < 1) {\n72:     return DEFAULT_MAX_SECONDARY_CLIENTS;\n73:   }\n74:   return parsed;\n75: }\n76: \n77: function sleep(ms: number): Promise<void> {\n78:   return new Promise((resolve) => setTimeout(resolve, ms));\n79: }\n80: \n81: // Canonicalize a path via realpath, even when the leaf does not exist yet. realpath the nearest\n82: // existing ancestor (so symlinked roots like macOS `/tmp` -> `/private/tmp` normalize) and\n83: // re-append the missing tail. Without ancestor canonicalization, a socket dir that was cleared\n84: // (e.g. `/tmp/<service>` after a reboot) stays literal `/tmp/...` and fails the allowed-root\n85: // check below — which canonicalizes `/tmp` to `/private/tmp` — crashing the server.\n86: // Fail closed: an existing ancestor that cannot be canonicalized (permission/loop error) must\n87: // abort rather than return a non-canonical path, which would weaken the allowed-root containment\n88: // check that downstream binds rely on.\n89: function canonicalizePath(target: string): string {\n90:   const resolved = path.resolve(target);\n91:   const tail: string[] = [];\n92:   let current = resolved;\n93:   while (!fs.existsSync(current)) {\n94:     const parent = path.dirname(current);\n95:     if (parent === current) {\n96:       return resolved;\n97:     }\n98:     tail.unshift(path.basename(current));\n99:     current = parent;\n100:   }\n101:   return path.join(fs.realpathSync.native(current), ...tail);\n102: }\n103: \n104: // Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it.\n105: // Both inputs MUST already be canonicalized. Inlined here so the shared bridge carries no\n106: // cross-module dependency for a single containment call.\n107: function isWithinRoot(root: string, candidate: string): boolean {\n108:   if (candidate === root) {\n109:     return true;\n110:   }\n111:   const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n112:   return candidate.startsWith(prefix);\n113: }\n114: \n115: // Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n116: // The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n117: // `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n118: // `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n119: // the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n120: // `canUnlinkExistingSocket` preserves the unlink-hardening intent.\n121: function allowedSocketRoots(): string[] {\n122:   const roots = new Set<string>();\n123:   roots.add(canonicalizePath(process.cwd()));\n124:   roots.add(canonicalizePath(os.tmpdir()));\n125:   roots.add(canonicalizePath('/tmp'));\n126:   return [...roots];\n127: }\n128: \n129: function isWithinAllowedSocketRoot(candidate: string): boolean {\n130:   return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n131: }\n132: \n133: function resolveIpcSocketPath(dbDir: string): string {\n134:   const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n135:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n136:     : path.resolve(dbDir);\n137:   const socketDir = canonicalizePath(rawSocketDir);\n138:   if (!isWithinAllowedSocketRoot(socketDir)) {\n139:     throw new Error(\n140:       `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n141:     );\n142:   }\n143:   return path.join(socketDir, SOCKET_FILE_NAME);\n144: }\n145: \n146: // Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n147: // inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n148: // Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n149: // socket they own at the bind path.\n150: function canUnlinkExistingSocket(socketPath: string): boolean {\n151:   let parent: string;\n152:   try {\n153:     parent = fs.realpathSync.native(path.dirname(socketPath));\n154:   } catch (error: unknown) {\n155:     // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n156:     // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n157:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n158:       return true;\n159:     }\n160:     throw error;\n161:   }\n162:   if (!isWithinAllowedSocketRoot(parent)) {\n163:     return false;\n164:   }\n165:   try {\n166:     const stat = fs.lstatSync(socketPath);\n167:     if (!stat.isSocket()) {\n168:       return false;\n169:     }\n170:     if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n171:       return false;\n172:     }\n173:     return true;\n174:   } catch (error: unknown) {\n175:     // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n176:     // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n177:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n178:       return true;\n179:     }\n180:     throw error;\n181:   }\n182: }\n183: \n184: function getIpcBridgeStats(): IpcBridgeStats {\n185:   return {\n186:     socket_path: activeSocketPath,\n187:     secondary_clients_count: activeSockets.size,\n188:     total_secondary_messages_in: totalSecondaryMessagesIn,\n189:     total_secondary_messages_out: totalSecondaryMessagesOut,\n190:   };\n191: }\n192: \n193: async function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n194:   await new Promise<void>((resolve, reject) => {\n195:     const onError = (error: NodeJS.ErrnoException) => {\n196:       server.off('listening', onListening);\n197:       reject(error);\n198:     };\n199:     const onListening = () => {\n200:       server.off('error', onError);\n201:       resolve();\n202:     };\n203:     server.once('error', onError);\n204:     server.once('listening', onListening);\n205:     if (socketPath.startsWith('tcp://')) {\n206:       const url = new URL(socketPath);\n207:       server.listen(Number.parseInt(url.port, 10), url.hostname);\n208:       return;\n209:     }\n210:     server.listen(socketPath);\n211:   });\n212: }\n213: \n214: // TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n215: // unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n216: // few times before giving up. Returns true once a retry binds, false if the port stays in use.\n217: async function retryTcpListenAfterEaddrInUse(\n218:   server: net.Server,\n219:   socketPath: string,\n220:   log: (message: string) => void,\n221: ): Promise<boolean> {\n222:   for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n223:     log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n224:     await sleep(delayMs);\n225:     try {\n226:       await listenOnce(server, socketPath);\n227:       return true;\n228:     } catch (error: unknown) {\n229:       const err = error as NodeJS.ErrnoException;\n230:       if (err.code !== 'EADDRINUSE') {\n231:         throw err;\n232:       }\n233:     }\n234:   }\n235:   return false;\n236: }\n237: \n238: // Tear down any server still registered in the module-global slots before a new bind reuses them.\n239: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n240: // dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n241: // shared stats. Re-entrancy must close the prior server first.\n242: async function disposeActiveServer(): Promise<void> {\n243:   const priorServer = activeServer;\n244:   for (const socket of activeSockets) {\n245:     socket.destroy();\n246:   }\n247:   activeSockets.clear();\n248:   activeTransports.clear();\n249:   if (priorServer) {\n250:     await new Promise<void>((resolve) => {\n251:       priorServer.close(() => resolve());\n252:     });\n253:   }\n254:   activeServer = null;\n255:   activeSocketPath = null;\n256: }\n257: \n258: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n259:   if (activeServer) {\n260:     await disposeActiveServer();\n261:   }\n262:   const socketPath = options.socketPath.startsWith('tcp://')\n263:     ? options.socketPath\n264:     : path.resolve(options.socketPath);\n265:   const log = options.log ?? ((message: string) => console.error(message));\n266:   const maxClients = options.maxClients ?? parseMaxClients();\n267:   const onActivity = options.onActivity ?? (() => undefined);\n268:   if (!socketPath.startsWith('tcp://')) {\n269:     const socketDir = path.dirname(socketPath);\n270:     fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n271:     // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n272:     // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n273:     // so refuse to bind under a dir not owned by us or that is group/world-writable.\n274:     try {\n275:       const st = fs.statSync(socketDir);\n276:       const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n277:       if (uid !== null && st.uid !== uid) {\n278:         throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n279:       }\n280:       if ((st.mode & 0o022) !== 0) {\n281:         throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n282:       }\n283:     } catch (error: unknown) {\n284:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n285:       if (code !== 'ENOENT') throw error;\n286:     }\n287:     // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n288:     // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n289:     // protection so a symlink whose target we would later chmod cannot be used to redirect the\n290:     // permission change onto an arbitrary file.\n291:     try {\n292:       const linkStat = fs.lstatSync(socketPath);\n293:       if (linkStat.isSymbolicLink()) {\n294:         throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n295:       }\n296:     } catch (error: unknown) {\n297:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n298:       if (code !== 'ENOENT') throw error;\n299:     }\n300:   }\n301: \n302:   const server = net.createServer((socket) => {\n303:     if (activeSockets.size >= maxClients) {\n304:       log(`[ipc-bridge] refusing secondary connection: max clients ${maxClients} reached`);\n305:       socket.end();\n306:       socket.destroy();\n307:       return;\n308:     }\n309: \n310:     activeSockets.add(socket);\n311:     onActivity();\n312:     log('[ipc-bridge] secondary connected pid=?');\n313: \n314:     const originalWrite = socket.write.bind(socket);\n315:     socket.write = ((chunk: unknown, ...args: unknown[]) => {\n316:       onActivity();\n317:       totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n318:       return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n319:     }) as typeof socket.write;\n320: \n321:     socket.on('data', (chunk) => {\n322:       onActivity();\n323:       totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n324:     });\n325: \n326:     const transport = new StdioServerTransport(socket, socket);\n327:     activeTransports.set(socket, transport);\n328:     const secondaryServer = options.createServer();\n329:     secondaryServer.connect(transport).catch((error: unknown) => {\n330:       const message = error instanceof Error ? error.message : String(error);\n331:       log(`[ipc-bridge] secondary connect error: ${message}`);\n332:       socket.destroy();\n333:     });\n334: \n335:     socket.once('close', () => {\n336:       activeSockets.delete(socket);\n337:       activeTransports.delete(socket);\n338:       void transport.close();\n339:       log('[ipc-bridge] disconnect');\n340:     });\n341:     socket.once('error', (error) => {\n342:       log(`[ipc-bridge] socket error: ${error.message}`);\n343:     });\n344:   });\n345: \n346:   try {\n347:     await listenOnce(server, socketPath);\n348:   } catch (error: unknown) {\n349:     const err = error as NodeJS.ErrnoException;\n350:     if (err.code !== 'EADDRINUSE') {\n351:       throw err;\n352:     }\n353:     if (socketPath.startsWith('tcp://')) {\n354:       // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n355:       // never frees, run without the secondary bridge rather than aborting the whole daemon.\n356:       const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n357:       if (!listened) {\n358:         log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n359:         return {\n360:           socketPath,\n361:           close: async () => {\n362:             for (const socket of activeSockets) {\n363:               socket.destroy();\n364:             }\n365:             activeSockets.clear();\n366:             activeTransports.clear();\n367:           },\n368:         };\n369:       }\n370:     } else {\n371:       // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n372:       // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n373:       // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n374:       if (!canUnlinkExistingSocket(socketPath)) {\n375:         throw err;\n376:       }\n377:       try {\n378:         fs.unlinkSync(socketPath);\n379:       } catch (unlinkError: unknown) {\n380:         const unlinkErr = unlinkError as NodeJS.ErrnoException;\n381:         if (unlinkErr.code !== 'ENOENT') {\n382:           throw unlinkErr;\n383:         }\n384:       }\n385:       await listenOnce(server, socketPath);\n386:     }\n387:   }\n388: \n389:   const address = server.address();\n390:   const listenedPath = typeof address === 'object' && address\n391:     ? `tcp://${address.address}:${address.port}`\n392:     : socketPath;\n393:   if (!socketPath.startsWith('tcp://')) {\n394:     // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n395:     // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n396:     const boundStat = fs.lstatSync(socketPath);\n397:     if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n398:       throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n399:     }\n400:     fs.chmodSync(socketPath, 0o600);\n401:   }\n402:   activeServer = server;\n403:   activeSocketPath = listenedPath;\n404:   log(`[ipc-bridge] socket listening at ${listenedPath}`);\n405: \n406:   return {\n407:     socketPath: listenedPath,\n408:     close: async () => {\n409:       for (const socket of activeSockets) {\n410:         socket.destroy();\n411:       }\n412:       activeSockets.clear();\n413:       activeTransports.clear();\n414:       await new Promise<void>((resolve) => {\n415:         server.close(() => resolve());\n416:       });\n417:       if (activeServer === server) {\n418:         activeServer = null;\n419:         activeSocketPath = null;\n420:       }\n421:       if (!socketPath.startsWith('tcp://')) {\n422:         try {\n423:           fs.unlinkSync(socketPath);\n424:         } catch (error: unknown) {\n425:           const err = error as NodeJS.ErrnoException;\n426:           if (err.code !== 'ENOENT') {\n427:             throw err;\n428:           }\n429:         }\n430:       }\n431:     },\n432:   };\n433: }\n434: \n435: export {\n436:   canUnlinkExistingSocket,\n437:   getIpcBridgeStats,\n438:   parseMaxClients,\n439:   resolveIpcSocketPath,\n440:   startIpcSocketServer,\n441: };\n442: \n443: export type {\n444:   IpcBridgeStats,\n445:   IpcSocketServerHandle,\n446:   IpcSocketServerOptions,\n447: };\n\n(End of file - total 447 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Canonical bridge logic shared by every daemon launcher (memory,\n// code-index, skill-advisor). Each service supplies its own socket/db\n// PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n// and race-safety contract stays identical across services.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\n// Every live session's launcher holds one persistent slot, and multi-seat\n// fan-outs run well past 8 concurrent sessions. A refused connection is\n// accepted then closed, which probes cannot distinguish from a dead daemon,\n// so the cap must exceed any realistic session fleet.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Canonical bridge logic shared by every daemon launcher (memory,\n// code-index, skill-advisor). Each service supplies its own socket/db\n// PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n// and race-safety contract stays identical across services.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\n// Every live session's launcher holds one persistent slot, and multi-seat\n// fan-outs run well past 8 concurrent sessions. A refused connection is\n// accepted then closed, which probes cannot distinguish from a dead daemon,\n// so the cap must exceed any realistic session fleet.\nconst DEFAULT_MAX_SECONDARY_CLIENTS = 64;\nconst TCP_EADDRINUSE_RETRY_DELAYS_MS = [100, 250, 500, 1000, 1500] as const;\n\ninterface IpcBridgeStats {\n  socket_path: string | null;\n  secondary_clients_count: number;\n  total_secondary_messages_in: number;\n  total_secondary_messages_out: number;\n}\n\n// Structural shape of the only MCP server capability this bridge uses. Typed structurally (a\n// method, so its transport param is bivariant) rather than against a concrete `Server` import so\n// every consuming package satisfies it with its own `@modelcontextprotocol/sdk` copy — the three\n// daemons each install the SDK separately and its private members make the classes nominally\n// distinct, which a concrete import would reject across package boundaries.\ninterface McpServerLike {\n  connect(transport: StdioServerTransport): Promise<void>;\n}\n\ninterface IpcSocketServerOptions {\n  readonly socketPath: string;\n  readonly createServer: () => McpServerLike;\n  readonly maxClients?: number;\n  readonly log?: (message: string) => void;\n  readonly onActivity?: () => void;\n}\n\ninterface IpcSocketServerHandle {\n  readonly socketPath: string;\n  readonly close: () => Promise<void>;\n}\n\nlet activeServer: net.Server | null = null;\nlet activeSocketPath: string | null = null;\nconst activeSockets = new Set<net.Socket>();\nconst activeTransports = new Map<net.Socket, StdioServerTransport>();\nlet totalSecondaryMessagesIn = 0;\nlet totalSecondaryMessagesOut = 0;\n\nfunction countJsonRpcFrames(chunk: unknown): number {\n  const text = Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n  const newlineCount = text.split('\\n').length - 1;\n  return Math.max(1, newlineCount);\n}\n\nfunction parseMaxClients(rawValue = process.env.SPECKIT_MAX_SECONDARY_CLIENTS): number {\n  if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') {\n    return DEFAULT_MAX_SECONDARY_CLIENTS;\n  }\n  const parsed = Number.parseInt(String(rawValue), 10);\n  if (!Number.isFinite(parsed) || parsed < 1) {\n    return DEFAULT_MAX_SECONDARY_CLIENTS;\n  }\n  return parsed;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n// Canonicalize a path via realpath, even when the leaf does not exist yet. realpath the nearest\n// existing ancestor (so symlinked roots like macOS `/tmp` -> `/private/tmp` normalize) and\n// re-append the missing tail. Without ancestor canonicalization, a socket dir that was cleared\n// (e.g. `/tmp/<service>` after a reboot) stays literal `/tmp/...` and fails the allowed-root\n// check below — which canonicalizes `/tmp` to `/private/tmp` — crashing the server.\n// Fail closed: an existing ancestor that cannot be canonicalized (permission/loop error) must\n// abort rather than return a non-canonical path, which would weaken the allowed-root containment\n// check that downstream binds rely on.\nfunction canonicalizePath(target: string): string {\n  const resolved = path.resolve(target);\n  const tail: string[] = [];\n  let current = resolved;\n  while (!fs.existsSync(current)) {\n    const parent = path.dirname(current);\n    if (parent === current) {\n      return resolved;\n    }\n    tail.unshift(path.basename(current));\n    current = parent;\n  }\n  return path.join(fs.realpathSync.native(current), ...tail);\n}\n\n// Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it.\n// Both inputs MUST already be canonicalized. Inlined here so the shared bridge carries no\n// cross-module dependency for a single containment call.\nfunction isWithinRoot(root: string, candidate: string): boolean {\n  if (candidate === root) {\n    return true;\n  }\n  const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n  return candidate.startsWith(prefix);\n}\n\n// Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n// The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n// `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n// `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n// the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n// `canUnlinkExistingSocket` preserves the unlink-hardening intent.\nfunction allowedSocketRoots(): string[] {\n  const roots = new Set<string>();\n  roots.add(canonicalizePath(process.cwd()));\n  roots.add(canonicalizePath(os.tmpdir()));\n  roots.add(canonicalizePath('/tmp'));\n  return [...roots];\n}\n\nfunction isWithinAllowedSocketRoot(candidate: string): boolean {\n  return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n}\n\nfunction resolveIpcSocketPath(dbDir: string): string {\n  const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(dbDir);\n  const socketDir = canonicalizePath(rawSocketDir);\n  if (!isWithinAllowedSocketRoot(socketDir)) {\n    throw new Error(\n      `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n    );\n  }\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\n// Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n// inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n// Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n// socket they own at the bind path.\nfunction canUnlinkExistingSocket(socketPath: string): boolean {\n  let parent: string;\n  try {\n    parent = fs.realpathSync.native(path.dirname(socketPath));\n  } catch (error: unknown) {\n    // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n    // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n  if (!isWithinAllowedSocketRoot(parent)) {\n    return false;\n  }\n  try {\n    const stat = fs.lstatSync(socketPath);\n    if (!stat.isSocket()) {\n      return false;\n    }\n    if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n    // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n}\n\nfunction getIpcBridgeStats(): IpcBridgeStats {\n  return {\n    socket_path: activeSocketPath,\n    secondary_clients_count: activeSockets.size,\n    total_secondary_messages_in: totalSecondaryMessagesIn,\n    total_secondary_messages_out: totalSecondaryMessagesOut,\n  };\n}\n\nasync function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n  await new Promise<void>((resolve, reject) => {\n    const onError = (error: NodeJS.ErrnoException) => {\n      server.off('listening', onListening);\n      reject(error);\n    };\n    const onListening = () => {\n      server.off('error', onError);\n      resolve();\n    };\n    server.once('error', onError);\n    server.once('listening', onListening);\n    if (socketPath.startsWith('tcp://')) {\n      const url = new URL(socketPath);\n      server.listen(Number.parseInt(url.port, 10), url.hostname);\n      return;\n    }\n    server.listen(socketPath);\n  });\n}\n\n// TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n// unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n// few times before giving up. Returns true once a retry binds, false if the port stays in use.\nasync function retryTcpListenAfterEaddrInUse(\n  server: net.Server,\n  socketPath: string,\n  log: (message: string) => void,\n): Promise<boolean> {\n  for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n    log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n    await sleep(delayMs);\n    try {\n      await listenOnce(server, socketPath);\n      return true;\n    } catch (error: unknown) {\n      const err = error as NodeJS.ErrnoException;\n      if (err.code !== 'EADDRINUSE') {\n        throw err;\n      }\n    }\n  }\n  return false;\n}\n\n// Tear down any server still registered in the module-global slots before a new bind reuses them.\n// startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n// dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n// shared stats. Re-entrancy must close the prior server first.\nasync function disposeActiveServer(): Promise<void> {\n  const priorServer = activeServer;\n  for (const socket of activeSockets) {\n    socket.destroy();\n  }\n  activeSockets.clear();\n  activeTransports.clear();\n  if (priorServer) {\n    await new Promise<void>((resolve) => {\n      priorServer.close(() => resolve());\n    });\n  }\n  activeServer = null;\n  activeSocketPath = null;\n}\n\nasync function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n  if (activeServer) {\n    await disposeActiveServer();\n  }\n  const socketPath = options.socketPath.startsWith('tcp://')\n    ? options.socketPath\n    : path.resolve(options.socketPath);\n  const log = options.log ?? ((message: string) => console.error(message));\n  const maxClients = options.maxClients ?? parseMaxClients();\n  const onActivity = options.onActivity ?? (() => undefined);\n  if (!socketPath.startsWith('tcp://')) {\n    const socketDir = path.dirname(socketPath);\n    fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n    // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n    // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n    // so refuse to bind under a dir not owned by us or that is group/world-writable.\n    try {\n      const st = fs.statSync(socketDir);\n      const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n      if (uid !== null && st.uid !== uid) {\n        throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n      }\n      if ((st.mode & 0o022) !== 0) {\n        throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n    // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n    // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n    // protection so a symlink whose target we would later chmod cannot be used to redirect the\n    // permission change onto an arbitrary file.\n    try {\n      const linkStat = fs.lstatSync(socketPath);\n      if (linkStat.isSymbolicLink()) {\n        throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n  }\n\n  const server = net.createServer((socket) => {\n    if (activeSockets.size >= maxClients) {\n      log(`[ipc-bridge] refusing secondary connection: max clients ${maxClients} reached`);\n      socket.end();\n      socket.destroy();\n      return;\n    }\n\n    activeSockets.add(socket);\n    onActivity();\n    log('[ipc-bridge] secondary connected pid=?');\n\n    const originalWrite = socket.write.bind(socket);\n    socket.write = ((chunk: unknown, ...args: unknown[]) => {\n      onActivity();\n      totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n      return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n    }) as typeof socket.write;\n\n    socket.on('data', (chunk) => {\n      onActivity();\n      totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n    });\n\n    const transport = new StdioServerTransport(socket, socket);\n    activeTransports.set(socket, transport);\n    const secondaryServer = options.createServer();\n    secondaryServer.connect(transport).catch((error: unknown) => {\n      const message = error instanceof Error ? error.message : String(error);\n      log(`[ipc-bridge] secondary connect error: ${message}`);\n      socket.destroy();\n    });\n\n    socket.once('close', () => {\n      activeSockets.delete(socket);\n      activeTransports.delete(socket);\n      void transport.close();\n      log('[ipc-bridge] disconnect');\n    });\n    socket.once('error', (error) => {\n      log(`[ipc-bridge] socket error: ${error.message}`);\n    });\n  });\n\n  try {\n    await listenOnce(server, socketPath);\n  } catch (error: unknown) {\n    const err = error as NodeJS.ErrnoException;\n    if (err.code !== 'EADDRINUSE') {\n      throw err;\n    }\n    if (socketPath.startsWith('tcp://')) {\n      // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n      // never frees, run without the secondary bridge rather than aborting the whole daemon.\n      const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n      if (!listened) {\n        log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n        return {\n          socketPath,\n          close: async () => {\n            for (const socket of activeSockets) {\n              socket.destroy();\n            }\n            activeSockets.clear();\n            activeTransports.clear();\n          },\n        };\n      }\n    } else {\n      // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n      // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n      // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n      if (!canUnlinkExistingSocket(socketPath)) {\n        throw err;\n      }\n      try {\n        fs.unlinkSync(socketPath);\n      } catch (unlinkError: unknown) {\n        const unlinkErr = unlinkError as NodeJS.ErrnoException;\n        if (unlinkErr.code !== 'ENOENT') {\n          throw unlinkErr;\n        }\n      }\n      await listenOnce(server, socketPath);\n    }\n  }\n\n  const address = server.address();\n  const listenedPath = typeof address === 'object' && address\n    ? `tcp://${address.address}:${address.port}`\n    : socketPath;\n  if (!socketPath.startsWith('tcp://')) {\n    // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n    // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n    const boundStat = fs.lstatSync(socketPath);\n    if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n      throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n    }\n    fs.chmodSync(socketPath, 0o600);\n  }\n  activeServer = server;\n  activeSocketPath = listenedPath;\n  log(`[ipc-bridge] socket listening at ${listenedPath}`);\n\n  return {\n    socketPath: listenedPath,\n    close: async () => {\n      for (const socket of activeSockets) {\n        socket.destroy();\n      }\n      activeSockets.clear();\n      activeTransports.clear();\n      await new Promise<void>((resolve) => {\n        server.close(() => resolve());\n      });\n      if (activeServer === server) {\n        activeServer = null;\n        activeSocketPath = null;\n      }\n      if (!socketPath.startsWith('tcp://')) {\n        try {\n          fs.unlinkSync(socketPath);\n        } catch (error: unknown) {\n          const err = error as NodeJS.ErrnoException;\n          if (err.code !== 'ENOENT') {\n            throw err;\n          }\n        }\n      }\n    },\n  };\n}\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n};\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,\n  IpcSocketServerOptions,\n};","lineStart":1,"lineEnd":447,"totalLines":447,"truncated":false}},"title":".opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts","time":{"start":1781762444474,"end":1781762444492}},"metadata":{"openai":{"itemId":"fc_0480beb90931291e016a33898c53b0819182705ddb084046be"}},"id":"prt_ed9514c5c001R225Y0k142s2vT","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9510203001rTfUhdGitGPM89"}}
{"type":"tool_use","timestamp":1781762444496,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_PwOa3P3PplbjrIdzmkLJzHdm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":80,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n80: // Lib modules (for initialization only)\n81: import * as vectorIndex from './lib/search/vector-index.js';\n82: import { acquireDbInstanceLock } from './lib/search/db-instance-lock.js';\n83: import { VectorIndexError, VectorIndexErrorCode } from './lib/search/vector-index-types.js';\n84: import * as _embeddings from './lib/providers/embeddings.js';\n85: import * as checkpointsLib from './lib/storage/checkpoints.js';\n86: import * as accessTracker from './lib/storage/access-tracker.js';\n87: import { runLineageBackfill, backfillColdOrphanProjection } from './lib/storage/lineage-state.js';\n88: import * as hybridSearch from './lib/search/hybrid-search.js';\n89: import { createUnifiedGraphSearchFn } from './lib/search/graph-search-fn.js';\n90: import { isGraphUnifiedEnabled } from './lib/search/graph-flags.js';\n91: import { callCodeGraphTool } from './lib/code-graph-boundary.js';\n92: import { detectRuntime, type RuntimeInfo } from './lib/runtime-detection.js';\n93: import {\n94:   ensureMemoryRuntimeInitialized,\n95:   isMemoryRuntimeInitialized,\n96:   registerInitTasks,\n97: } from './lib/runtime/memory-runtime-guard.js';\n98: import * as sessionBoost from './lib/search/session-boost.js';\n99: import * as causalBoost from './lib/search/causal-boost.js';\n100: import * as bm25Index from './lib/search/bm25-index.js';\n101: import { getSpecsBasePaths } from './lib/search/folder-discovery.js';\n102: import {\n103:   registerGlobalRefreshFn,\n104:   getDirtyNodes,\n105:   clearDirtyNodes,\n106:   recomputeLocal,\n107:   cancelScheduledRefresh,\n108:   scheduleGlobalRefresh,\n109: } from './lib/search/graph-lifecycle.js';\n110: import {\n111:   isDegreeBoostEnabled,\n112:   isDynamicInitEnabled,\n113:   isFileWatcherEnabled,\n114: } from './lib/search/search-flags.js';\n115: import { runCleanupStep, runAsyncCleanupStep } from './lib/utils/cleanup-helpers.js';\n116: import { clearAllTimers, clearRegisteredTimer, registerInterval, registerTimeout } from './lib/runtime/timer-registry.js';\n117: import { runShutdownHooks } from './lib/runtime/shutdown-hooks.js';\n118: import {\n119:   getIpcBridgeStats,\n120:   resolveIpcSocketPath,\n121:   startIpcSocketServer,\n122:   type IpcSocketServerHandle,\n123: } from './lib/ipc/socket-server.js';\n124: import {\n125:   createLauncherIdleMonitor,\n126:   type LauncherIdleMonitor,\n127: } from './lib/ipc/launcher-idle-timeout.js';\n128: import * as workingMemory from './lib/cognitive/working-memory.js';\n129: import * as attentionDecay from './lib/cognitive/attention-decay.js';\n130: import * as coActivation from './lib/cognitive/co-activation.js';\n131: import { initScoringObservability } from './lib/telemetry/scoring-observability.js';\n132: import { rebindScoringObservability } from './lib/telemetry/scoring-observability.js';\n133: // Retry manager for background embedding retry job\n134: import * as retryManager from './lib/providers/retry-manager.js';\n135: import { buildErrorResponse, getDefaultErrorCodeForTool, getRecoveryHint } from './lib/errors.js';\n136: // Session deduplication\n137: import * as sessionManager from './lib/session/session-manager.js';\n138: import * as shadowEvaluationRuntime from './lib/feedback/shadow-evaluation-runtime.js';\n139: // Context metrics — lightweight session quality tracking\n140: import { recordMetricEvent } from './lib/session/context-metrics.js';\n141: \n142: // P4-12/P4-19: Incremental index (passed to db-state for stale handle refresh)\n143: import * as incrementalIndex from './lib/storage/incremental-index.js';\n144: // Transaction manager for pending file recovery on startup\n145: import * as transactionManager from './lib/storage/transaction-manager.js';\n146: // KL-4: Tool cache cleanup on shutdown\n147: import * as toolCache from './lib/cache/tool-cache.js';\n148: import { initExtractionAdapter, rebindExtractionAdapter } from './lib/extraction/extraction-adapter.js';\n149: import { migrateLearnedTriggers, verifyFts5Isolation } from './lib/storage/learned-triggers-schema.js';\n150: import { isLearnedFeedbackEnabled } from './lib/search/learned-feedback.js';\n151: import { initIngestJobQueue, stopWorker as stopIngestWorker } from './lib/ops/job-queue.js';\n152: import { ensureMaintenanceJobsTable, resetRunningJobsForKind } from './lib/ops/job-store.js';\n153: import { startFileWatcher, type FSWatcher } from './lib/ops/file-watcher.js';\n154: import { getCanonicalPathKey } from './lib/utils/canonical-path.js';\n155: import { runBatchLearning } from './lib/feedback/batch-learning.js';\n156: import { getSessionSnapshot } from './lib/session/session-snapshot.js';\n157: import { resumeReindexJobs } from './lib/embedders/reindex.js';\n158: import { ensureActiveEmbedder } from './lib/embedders/schema.js';\n159: \n160: /* ───────────────────────────────────────────────────────────────\n161:    2. TYPES\n162: ──────────────────────────────────────────────────────────────── */\n163: \n164: interface IndexResult {\n165:   status: string;\n166:   error?: string;\n167:   [key: string]: unknown;\n168: }\n169: \n170: interface PendingRecoveryResult {\n171:   found: number;\n172:   processed: number;\n173:   recovered: number;\n174:   failed: number;\n175:   results: unknown[];\n176: }\n177: \n178: interface ApiKeyValidation {\n179:   valid: boolean;\n180:   provider?: string;\n181:   error?: string;\n182:   errorCode?: string;\n183:   warning?: string;\n184:   actions?: string[];\n185:   networkError?: boolean;\n186: }\n187: \n188: interface AutoSurfaceResult {\n189:   constitutional: unknown[];\n190:   triggered: unknown[];\n191:   codeGraphStatus?: {\n192:     status: 'ok' | 'error';\n193:     data?: Record<string, unknown>;\n194:     error?: string;\n195:   };\n196:   sessionPrimed?: boolean;\n197:   primedTool?: string;\n198:   /** Structured Prime Package for non-hook CLI auto-priming */\n199:   primePackage?: {\n200:     specFolder: string | null;\n201:     currentTask: string | null;\n202:     codeGraphStatus: 'fresh' | 'stale' | 'empty';\n203:     recommendedCalls: string[];\n204:   };\n205:   surfaced_at?: string;\n206:   latencyMs?: number;\n207: }\n208: \n209: interface ToolCallResponse {\n210:   content: Array<{ type: string; text: string }>;\n211:   isError?: boolean;\n212:   structuredContent?: unknown;\n213:   [key: string]: unknown;\n214: }\n215: \n216: interface DynamicMemoryStats {\n217:   totalMemories: number;\n218:   specFolderCount: number;\n219:   activeCount: number;\n220:   staleCount: number;\n221: }\n222: \n223: type AfterToolCallback = (tool: string, callId: string, result: unknown) => Promise<void>;\n224: type BootFtsIntegrityHealth = 'unknown' | 'skipped' | 'ok' | 'corrupt' | 'repaired';\n225: \n226: const afterToolCallbacks: Array<AfterToolCallback> = [];\n227: \n228: /** Timeout (ms) for API key validation during startup. */\n229: const API_KEY_VALIDATION_TIMEOUT_MS = 5_000;\n230: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n231: const FTS_CORRUPTION_RUNBOOK =\n232:   '.opencode/specs/system-spec-kit/026-graph-and-context-optimization/004-code-graph/012-empty-graph-first-time-auto-scan/bug-report-memory-db-corruption.md';\n233: \n234: const GRAPH_ENRICHMENT_TIMEOUT_MS = 250;\n235: const GRAPH_ENRICHMENT_OUTLINE_LIMIT = 6;\n236: const GRAPH_ENRICHMENT_NEIGHBOR_LIMIT = 6;\n237: const GRAPH_ENRICHMENT_SYMBOL_LIMIT = 4;\n238: const GRAPH_CONTEXT_EXCLUDED_TOOLS = new Set<string>([\n239:   ...MEMORY_AWARE_TOOLS,\n240:   // Code-graph MCP tools route through standalone mk-code-index\n241: ]);\n242: \n243: const MEMORY_RUNTIME_TOOL_NAMES = new Set<string>([\n244:   'memory_context',\n245:   'memory_search',\n246:   'memory_quick_search',\n247:   'memory_match_triggers',\n248:   'memory_save',\n249:   'memory_list',\n250:   'memory_stats',\n251:   'memory_delete',\n252:   'memory_update',\n253:   'memory_validate',\n254:   'memory_bulk_delete',\n255:   'memory_retention_sweep',\n256:   'memory_embedding_reconcile',\n257:   'memory_index_scan',\n258:   'memory_index_scan_status',\n259:   'memory_index_scan_cancel',\n260:   'memory_ingest_start',\n261:   'memory_ingest_status',\n262:   'memory_ingest_cancel',\n263:   'checkpoint_create',\n264:   'checkpoint_list',\n265:   'checkpoint_restore',\n266:   'checkpoint_delete',\n267:   'embedder_list',\n268:   'embedder_set',\n269:   'embedder_status',\n270:   'task_preflight',\n271:   'task_postflight',\n272:   'memory_get_learning_history',\n273:   'eval_run_ablation',\n274:   'eval_reporting_dashboard',\n275:   'memory_drift_why',\n276:   'memory_causal_link',\n277:   'memory_causal_stats',\n278:   'memory_causal_unlink',\n279: ]);\n280: \n281: interface GraphContextNeighborSummary {\n282:   filePath: string;\n283:   relationTypes: string[];\n284:   symbols: Array<{\n285:     name: string;\n286:     kind: string;\n287:     line: number;\n288:     direction: 'incoming' | 'outgoing';\n289:     relation: string;\n290:   }>;\n291: }\n292: \n293: interface GraphContextFileSummary {\n294:   filePath: string;\n295:   outline: Array<{\n296:     name: string;\n297:     kind: string;\n298:     line: number;\n299:   }>;\n300:   neighbors: GraphContextNeighborSummary[];\n301: }\n302: \n303: interface DispatchGraphContextMeta {\n304:   status: 'ok' | 'timeout' | 'unavailable';\n305:   source: 'tool-dispatch';\n306:   fileCount: number;\n307:   filePaths: string[];\n308:   latencyMs: number;\n309:   files?: GraphContextFileSummary[];\n310:   error?: string;\n311: }\n312: \n313: export interface StructuralRoutingNudge {\n314:   advisory: true;\n315:   readiness: 'ready';\n316:   preferredTool: 'mcp__mk_code_index__code_graph_query';\n317:   secondaryTool: 'mcp__mk_code_index__code_graph_context';\n318:   message: string;\n319:   preservesAuthority: 'session_bootstrap';\n320:   surface: 'response-hints' | 'session-bootstrap' | 'memory-context';\n321: }\n322: \n323: const STRUCTURAL_MISFIRE_PATTERNS = [\n324:   /\\b(?:who|what)\\s+calls?\\b/i,\n325:   /\\bcallers?\\s+of\\b/i,\n326:   /\\b(?:who|what)\\s+imports?\\b/i,\n327:   /\\bimports?\\s+of\\b/i,\n328:   /\\b(?:show|list)\\s+(?:the\\s+)?outline\\b/i,\n329:   /\\boutline\\s+of\\b/i,\n330:   /\\bdependenc(?:y|ies)\\b/i,\n331:   /\\bdependents?\\b/i,\n332:   /\\bwhat\\s+extends\\b/i,\n333: ];\n334: \n335: const NON_STRUCTURAL_SUPPRESS_PATTERNS = [\n336:   /\\bfind code\\b/i,\n337:   /\\bimplementation of\\b/i,\n338:   /\\bsimilar code\\b/i,\n339:   /\\bexplain\\b/i,\n\n(Showing lines 80-339 of 2341. Use offset=340 to continue.)\n</content>","metadata":{"preview":"// Lib modules (for initialization only)\nimport * as vectorIndex from './lib/search/vector-index.js';\nimport { acquireDbInstanceLock } from './lib/search/db-instance-lock.js';\nimport { VectorIndexError, VectorIndexErrorCode } from './lib/search/vector-index-types.js';\nimport * as _embeddings from './lib/providers/embeddings.js';\nimport * as checkpointsLib from './lib/storage/checkpoints.js';\nimport * as accessTracker from './lib/storage/access-tracker.js';\nimport { runLineageBackfill, backfillColdOrphanProjection } from './lib/storage/lineage-state.js';\nimport * as hybridSearch from './lib/search/hybrid-search.js';\nimport { createUnifiedGraphSearchFn } from './lib/search/graph-search-fn.js';\nimport { isGraphUnifiedEnabled } from './lib/search/graph-flags.js';\nimport { callCodeGraphTool } from './lib/code-graph-boundary.js';\nimport { detectRuntime, type RuntimeInfo } from './lib/runtime-detection.js';\nimport {\n  ensureMemoryRuntimeInitialized,\n  isMemoryRuntimeInitialized,\n  registerInitTasks,\n} from './lib/runtime/memory-runtime-guard.js';\nimport * as sessionBoost from './lib/search/session-boost.js';\nimport * as causalBoost from './lib/search/causal-boost.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"// Lib modules (for initialization only)\nimport * as vectorIndex from './lib/search/vector-index.js';\nimport { acquireDbInstanceLock } from './lib/search/db-instance-lock.js';\nimport { VectorIndexError, VectorIndexErrorCode } from './lib/search/vector-index-types.js';\nimport * as _embeddings from './lib/providers/embeddings.js';\nimport * as checkpointsLib from './lib/storage/checkpoints.js';\nimport * as accessTracker from './lib/storage/access-tracker.js';\nimport { runLineageBackfill, backfillColdOrphanProjection } from './lib/storage/lineage-state.js';\nimport * as hybridSearch from './lib/search/hybrid-search.js';\nimport { createUnifiedGraphSearchFn } from './lib/search/graph-search-fn.js';\nimport { isGraphUnifiedEnabled } from './lib/search/graph-flags.js';\nimport { callCodeGraphTool } from './lib/code-graph-boundary.js';\nimport { detectRuntime, type RuntimeInfo } from './lib/runtime-detection.js';\nimport {\n  ensureMemoryRuntimeInitialized,\n  isMemoryRuntimeInitialized,\n  registerInitTasks,\n} from './lib/runtime/memory-runtime-guard.js';\nimport * as sessionBoost from './lib/search/session-boost.js';\nimport * as causalBoost from './lib/search/causal-boost.js';\nimport * as bm25Index from './lib/search/bm25-index.js';\nimport { getSpecsBasePaths } from './lib/search/folder-discovery.js';\nimport {\n  registerGlobalRefreshFn,\n  getDirtyNodes,\n  clearDirtyNodes,\n  recomputeLocal,\n  cancelScheduledRefresh,\n  scheduleGlobalRefresh,\n} from './lib/search/graph-lifecycle.js';\nimport {\n  isDegreeBoostEnabled,\n  isDynamicInitEnabled,\n  isFileWatcherEnabled,\n} from './lib/search/search-flags.js';\nimport { runCleanupStep, runAsyncCleanupStep } from './lib/utils/cleanup-helpers.js';\nimport { clearAllTimers, clearRegisteredTimer, registerInterval, registerTimeout } from './lib/runtime/timer-registry.js';\nimport { runShutdownHooks } from './lib/runtime/shutdown-hooks.js';\nimport {\n  getIpcBridgeStats,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n  type IpcSocketServerHandle,\n} from './lib/ipc/socket-server.js';\nimport {\n  createLauncherIdleMonitor,\n  type LauncherIdleMonitor,\n} from './lib/ipc/launcher-idle-timeout.js';\nimport * as workingMemory from './lib/cognitive/working-memory.js';\nimport * as attentionDecay from './lib/cognitive/attention-decay.js';\nimport * as coActivation from './lib/cognitive/co-activation.js';\nimport { initScoringObservability } from './lib/telemetry/scoring-observability.js';\nimport { rebindScoringObservability } from './lib/telemetry/scoring-observability.js';\n// Retry manager for background embedding retry job\nimport * as retryManager from './lib/providers/retry-manager.js';\nimport { buildErrorResponse, getDefaultErrorCodeForTool, getRecoveryHint } from './lib/errors.js';\n// Session deduplication\nimport * as sessionManager from './lib/session/session-manager.js';\nimport * as shadowEvaluationRuntime from './lib/feedback/shadow-evaluation-runtime.js';\n// Context metrics — lightweight session quality tracking\nimport { recordMetricEvent } from './lib/session/context-metrics.js';\n\n// P4-12/P4-19: Incremental index (passed to db-state for stale handle refresh)\nimport * as incrementalIndex from './lib/storage/incremental-index.js';\n// Transaction manager for pending file recovery on startup\nimport * as transactionManager from './lib/storage/transaction-manager.js';\n// KL-4: Tool cache cleanup on shutdown\nimport * as toolCache from './lib/cache/tool-cache.js';\nimport { initExtractionAdapter, rebindExtractionAdapter } from './lib/extraction/extraction-adapter.js';\nimport { migrateLearnedTriggers, verifyFts5Isolation } from './lib/storage/learned-triggers-schema.js';\nimport { isLearnedFeedbackEnabled } from './lib/search/learned-feedback.js';\nimport { initIngestJobQueue, stopWorker as stopIngestWorker } from './lib/ops/job-queue.js';\nimport { ensureMaintenanceJobsTable, resetRunningJobsForKind } from './lib/ops/job-store.js';\nimport { startFileWatcher, type FSWatcher } from './lib/ops/file-watcher.js';\nimport { getCanonicalPathKey } from './lib/utils/canonical-path.js';\nimport { runBatchLearning } from './lib/feedback/batch-learning.js';\nimport { getSessionSnapshot } from './lib/session/session-snapshot.js';\nimport { resumeReindexJobs } from './lib/embedders/reindex.js';\nimport { ensureActiveEmbedder } from './lib/embedders/schema.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  error?: string;\n  [key: string]: unknown;\n}\n\ninterface PendingRecoveryResult {\n  found: number;\n  processed: number;\n  recovered: number;\n  failed: number;\n  results: unknown[];\n}\n\ninterface ApiKeyValidation {\n  valid: boolean;\n  provider?: string;\n  error?: string;\n  errorCode?: string;\n  warning?: string;\n  actions?: string[];\n  networkError?: boolean;\n}\n\ninterface AutoSurfaceResult {\n  constitutional: unknown[];\n  triggered: unknown[];\n  codeGraphStatus?: {\n    status: 'ok' | 'error';\n    data?: Record<string, unknown>;\n    error?: string;\n  };\n  sessionPrimed?: boolean;\n  primedTool?: string;\n  /** Structured Prime Package for non-hook CLI auto-priming */\n  primePackage?: {\n    specFolder: string | null;\n    currentTask: string | null;\n    codeGraphStatus: 'fresh' | 'stale' | 'empty';\n    recommendedCalls: string[];\n  };\n  surfaced_at?: string;\n  latencyMs?: number;\n}\n\ninterface ToolCallResponse {\n  content: Array<{ type: string; text: string }>;\n  isError?: boolean;\n  structuredContent?: unknown;\n  [key: string]: unknown;\n}\n\ninterface DynamicMemoryStats {\n  totalMemories: number;\n  specFolderCount: number;\n  activeCount: number;\n  staleCount: number;\n}\n\ntype AfterToolCallback = (tool: string, callId: string, result: unknown) => Promise<void>;\ntype BootFtsIntegrityHealth = 'unknown' | 'skipped' | 'ok' | 'corrupt' | 'repaired';\n\nconst afterToolCallbacks: Array<AfterToolCallback> = [];\n\n/** Timeout (ms) for API key validation during startup. */\nconst API_KEY_VALIDATION_TIMEOUT_MS = 5_000;\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\nconst FTS_CORRUPTION_RUNBOOK =\n  '.opencode/specs/system-spec-kit/026-graph-and-context-optimization/004-code-graph/012-empty-graph-first-time-auto-scan/bug-report-memory-db-corruption.md';\n\nconst GRAPH_ENRICHMENT_TIMEOUT_MS = 250;\nconst GRAPH_ENRICHMENT_OUTLINE_LIMIT = 6;\nconst GRAPH_ENRICHMENT_NEIGHBOR_LIMIT = 6;\nconst GRAPH_ENRICHMENT_SYMBOL_LIMIT = 4;\nconst GRAPH_CONTEXT_EXCLUDED_TOOLS = new Set<string>([\n  ...MEMORY_AWARE_TOOLS,\n  // Code-graph MCP tools route through standalone mk-code-index\n]);\n\nconst MEMORY_RUNTIME_TOOL_NAMES = new Set<string>([\n  'memory_context',\n  'memory_search',\n  'memory_quick_search',\n  'memory_match_triggers',\n  'memory_save',\n  'memory_list',\n  'memory_stats',\n  'memory_delete',\n  'memory_update',\n  'memory_validate',\n  'memory_bulk_delete',\n  'memory_retention_sweep',\n  'memory_embedding_reconcile',\n  'memory_index_scan',\n  'memory_index_scan_status',\n  'memory_index_scan_cancel',\n  'memory_ingest_start',\n  'memory_ingest_status',\n  'memory_ingest_cancel',\n  'checkpoint_create',\n  'checkpoint_list',\n  'checkpoint_restore',\n  'checkpoint_delete',\n  'embedder_list',\n  'embedder_set',\n  'embedder_status',\n  'task_preflight',\n  'task_postflight',\n  'memory_get_learning_history',\n  'eval_run_ablation',\n  'eval_reporting_dashboard',\n  'memory_drift_why',\n  'memory_causal_link',\n  'memory_causal_stats',\n  'memory_causal_unlink',\n]);\n\ninterface GraphContextNeighborSummary {\n  filePath: string;\n  relationTypes: string[];\n  symbols: Array<{\n    name: string;\n    kind: string;\n    line: number;\n    direction: 'incoming' | 'outgoing';\n    relation: string;\n  }>;\n}\n\ninterface GraphContextFileSummary {\n  filePath: string;\n  outline: Array<{\n    name: string;\n    kind: string;\n    line: number;\n  }>;\n  neighbors: GraphContextNeighborSummary[];\n}\n\ninterface DispatchGraphContextMeta {\n  status: 'ok' | 'timeout' | 'unavailable';\n  source: 'tool-dispatch';\n  fileCount: number;\n  filePaths: string[];\n  latencyMs: number;\n  files?: GraphContextFileSummary[];\n  error?: string;\n}\n\nexport interface StructuralRoutingNudge {\n  advisory: true;\n  readiness: 'ready';\n  preferredTool: 'mcp__mk_code_index__code_graph_query';\n  secondaryTool: 'mcp__mk_code_index__code_graph_context';\n  message: string;\n  preservesAuthority: 'session_bootstrap';\n  surface: 'response-hints' | 'session-bootstrap' | 'memory-context';\n}\n\nconst STRUCTURAL_MISFIRE_PATTERNS = [\n  /\\b(?:who|what)\\s+calls?\\b/i,\n  /\\bcallers?\\s+of\\b/i,\n  /\\b(?:who|what)\\s+imports?\\b/i,\n  /\\bimports?\\s+of\\b/i,\n  /\\b(?:show|list)\\s+(?:the\\s+)?outline\\b/i,\n  /\\boutline\\s+of\\b/i,\n  /\\bdependenc(?:y|ies)\\b/i,\n  /\\bdependents?\\b/i,\n  /\\bwhat\\s+extends\\b/i,\n];\n\nconst NON_STRUCTURAL_SUPPRESS_PATTERNS = [\n  /\\bfind code\\b/i,\n  /\\bimplementation of\\b/i,\n  /\\bsimilar code\\b/i,\n  /\\bexplain\\b/i,","lineStart":80,"lineEnd":339,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781762444485,"end":1781762444495}},"metadata":{"openai":{"itemId":"fc_0480beb90931291e016a33898c53c48191ae6ff67f9bb17813"}},"id":"prt_ed9514cc2001aXjcSFn9EWKML4","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9510203001rTfUhdGitGPM89"}}
{"type":"tool_use","timestamp":1781762444525,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_bGe754U8QR4G9RUIaimyOcLL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1540,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1540:       if ((indexed + updated + unchanged + failed) % 50 === 0) {\n1541:         await new Promise<void>((resolve) => setImmediate(resolve));\n1542:       }\n1543:     }\n1544: \n1545:     if (indexed > 0 || updated > 0) {\n1546:       console.error(`[context-server] Startup scan: ${indexed} new, ${updated} updated, ${unchanged} unchanged, ${failed} failed`);\n1547:     } else {\n1548:       console.error(`[context-server] Startup scan: all ${unchanged} files up to date`);\n1549:     }\n1550: \n1551:     if (indexed > 0 || updated > 0) {\n1552:       try {\n1553:         runPostMutationHooks('scan', {\n1554:           indexed,\n1555:           updated,\n1556:           staleDeleted: 0,\n1557:           staleDeleteFailed: 0,\n1558:           operation: 'startup-scan',\n1559:         });\n1560:       } catch (_error: unknown) {\n1561:         // Non-fatal: startup scan must continue even if invalidation hooks fail.\n1562:       }\n1563:     }\n1564: \n1565:     // Log atomicity metrics for monitoring\n1566:     const metrics = transactionManager.getMetrics();\n1567:     if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n1568:       console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n1569:     }\n1570:   } catch (error: unknown) {\n1571:     const message = error instanceof Error ? error.message : String(error);\n1572:     console.error(`[context-server] Startup scan error: ${message}`);\n1573:   } finally {\n1574:     startupScanInProgress = false;\n1575:   }\n1576: }\n1577: \n1578: /* ───────────────────────────────────────────────────────────────\n1579:    7. GRACEFUL SHUTDOWN\n1580: ──────────────────────────────────────────────────────────────── */\n1581: \n1582: let shuttingDown = false;\n1583: // Hoist transport to module scope so shutdown handlers can close it\n1584: let transport: StdioServerTransport | null = null;\n1585: let transportConnectedAt: string | null = null;\n1586: let fileWatcher: FSWatcher | null = null;\n1587: let ipcBridge: IpcSocketServerHandle | null = null;\n1588: let launcherIdleMonitor: LauncherIdleMonitor | null = null;\n1589: \n1590: /** Maximum time (ms) to wait for async cleanup before force-exiting. */\n1591: const SHUTDOWN_DEADLINE_MS = 5000;\n1592: \n1593: /**\n1594:  * Exit code telling the launcher \"another live process holds the database\n1595:  * single-writer lock\": bridge to that owner instead of counting this exit\n1596:  * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n1597:  * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n1598:  * mk-spec-memory-launcher.cjs.\n1599:  */\n1600: const EXIT_DB_LOCK_HELD = 86;\n1601: \n1602: export const __testables = {\n1603:   runCleanupStep,\n1604:   runAsyncCleanupStep,\n1605:   main: () => main(),\n1606:   getBootFtsIntegrityHealth,\n1607:   runCheckpointNeedsRebuildRepair,\n1608:   normalizeGraphFilePath,\n1609:   extractFilePathsFromToolArgs,\n1610: };\n1611: \n1612: async function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n1613:   if (shuttingDown) return;\n1614:   shuttingDown = true;\n1615:   console.error(`[context-server] ${reason}`);\n1616: \n1617:   runCleanupStep('sessionManager', () => sessionManager.shutdown());\n1618:   runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n1619:   // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n1620:   // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n1621:   // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n1622:   runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n1623:   runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n1624:   runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n1625:   runCleanupStep('accessTracker', () => accessTracker.reset());\n1626:   runCleanupStep('toolCache', () => toolCache.shutdown());\n1627:   runCleanupStep('launcherIdleMonitor', () => {\n1628:     if (launcherIdleMonitor) {\n1629:       launcherIdleMonitor.stop();\n1630:       launcherIdleMonitor = null;\n1631:     }\n1632:   });\n1633: \n1634:   let deadlineTimer: NodeJS.Timeout | undefined;\n1635:   const cleanup = (async () => {\n1636:     // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n1637:     // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n1638:     // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n1639:     await runAsyncCleanupStep('startupScan', async () => {\n1640:       if (startupScanPromise) await startupScanPromise;\n1641:     });\n1642:     // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n1643:     // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n1644:     // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n1645:     // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n1646:     // at rest and defeating the durability guarantee. closeDb() is\n1647:     // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n1648:     // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n1649:     // small even if a pathologically slow drain starves this step.\n1650:     await runAsyncCleanupStep('fileWatcher', async () => {\n1651:       if (fileWatcher) {\n1652:         await fileWatcher.close();\n1653:         fileWatcher = null;\n1654:       }\n1655:     });\n1656:     // Fence the ingest worker before closeDb for the same reason as the file\n1657:     // watcher above: the worker writes through the DB and would otherwise reopen\n1658:     // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n1659:     await runAsyncCleanupStep('ingestWorker', async () => {\n1660:       await stopIngestWorker();\n1661:     });\n1662:     runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n1663:     // Close MCP transport on shutdown\n1664:     runCleanupStep('transport', () => {\n1665:       if (transport) {\n1666:         transport.close();\n1667:         transport = null;\n1668:         transportConnectedAt = null;\n1669:       }\n1670:     });\n1671:     await runAsyncCleanupStep('ipcBridge', async () => {\n1672:       if (ipcBridge) {\n1673:         await ipcBridge.close();\n1674:         ipcBridge = null;\n1675:       }\n1676:     });\n1677:     await runAsyncCleanupStep('shutdownHooks', async () => {\n1678:       await runShutdownHooks();\n1679:     });\n1680:     runCleanupStep('registeredTimers', () => clearAllTimers());\n1681:   })();\n1682: \n1683:   const timedOut = await Promise.race([\n1684:     cleanup.then(() => false),\n1685:     new Promise<boolean>((resolve) => {\n1686:       deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n1687:     }),\n1688:   ]);\n1689: \n1690:   if (deadlineTimer) {\n1691:     clearRegisteredTimer(deadlineTimer);\n1692:   }\n1693: \n1694:   if (timedOut) {\n1695:     console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n1696:   }\n1697: \n1698:   process.exit(exitCode);\n1699: }\n1700: \n1701: /** Remove indexed rows for watcher delete and rename events. */\n1702: async function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n1703:   const database = vectorIndex.getDb();\n1704:   if (!database) {\n1705:     return;\n1706:   }\n1707: \n1708:   const canonicalPath = getCanonicalPathKey(filePath);\n1709:   let rows: Array<{ id: number; spec_folder: string | null }> = [];\n1710: \n1711:   try {\n1712:     rows = database.prepare(`\n1713:       SELECT id, spec_folder\n1714:       FROM memory_index\n1715:       WHERE canonical_file_path = ? OR file_path = ?\n1716:       ORDER BY id ASC\n1717:     `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n1718:   } catch (_error: unknown) {\n1719:     rows = database.prepare(`\n1720:       SELECT id, spec_folder\n1721:       FROM memory_index\n1722:       WHERE file_path = ?\n1723:       ORDER BY id ASC\n1724:     `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n1725:   }\n1726: \n1727:   let deletedCount = 0;\n1728:   for (const row of rows) {\n1729:     if (typeof row.id === 'number') {\n1730:       if (vectorIndex.deleteMemory(row.id)) {\n1731:         deletedCount += 1;\n1732:         // Record DELETE history only after confirmed deletion.\n1733:         try {\n1734:           recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n1735:         } catch (_histErr: unknown) {\n1736:           // History recording is best-effort in file-watcher path\n1737:         }\n1738:       }\n1739:     }\n1740:   }\n1741: \n1742:   if (deletedCount > 0) {\n1743:     try {\n1744:       runPostMutationHooks('delete', { filePath, deletedCount });\n1745:     } catch (_error: unknown) {\n1746:       // Non-throwing by design: file-watcher path must not crash the server.\n1747:     }\n1748:   }\n1749: }\n1750: \n1751: process.on('SIGTERM', () => {\n1752:   void fatalShutdown('Received SIGTERM, shutting down...', 0);\n1753: });\n1754: process.on('SIGINT', () => {\n1755:   void fatalShutdown('Received SIGINT, shutting down...', 0);\n1756: });\n1757: process.on('SIGHUP', () => {\n1758:   void fatalShutdown('Received SIGHUP, shutting down...', 0);\n1759: });\n\n(Showing lines 1540-1759 of 2341. Use offset=1760 to continue.)\n</content>","metadata":{"preview":"      if ((indexed + updated + unchanged + failed) % 50 === 0) {\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n    }\n\n    if (indexed > 0 || updated > 0) {\n      console.error(`[context-server] Startup scan: ${indexed} new, ${updated} updated, ${unchanged} unchanged, ${failed} failed`);\n    } else {\n      console.error(`[context-server] Startup scan: all ${unchanged} files up to date`);\n    }\n\n    if (indexed > 0 || updated > 0) {\n      try {\n        runPostMutationHooks('scan', {\n          indexed,\n          updated,\n          staleDeleted: 0,\n          staleDeleteFailed: 0,\n          operation: 'startup-scan',\n        });","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"      if ((indexed + updated + unchanged + failed) % 50 === 0) {\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n    }\n\n    if (indexed > 0 || updated > 0) {\n      console.error(`[context-server] Startup scan: ${indexed} new, ${updated} updated, ${unchanged} unchanged, ${failed} failed`);\n    } else {\n      console.error(`[context-server] Startup scan: all ${unchanged} files up to date`);\n    }\n\n    if (indexed > 0 || updated > 0) {\n      try {\n        runPostMutationHooks('scan', {\n          indexed,\n          updated,\n          staleDeleted: 0,\n          staleDeleteFailed: 0,\n          operation: 'startup-scan',\n        });\n      } catch (_error: unknown) {\n        // Non-fatal: startup scan must continue even if invalidation hooks fail.\n      }\n    }\n\n    // Log atomicity metrics for monitoring\n    const metrics = transactionManager.getMetrics();\n    if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n      console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Startup scan error: ${message}`);\n  } finally {\n    startupScanInProgress = false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. GRACEFUL SHUTDOWN\n──────────────────────────────────────────────────────────────── */\n\nlet shuttingDown = false;\n// Hoist transport to module scope so shutdown handlers can close it\nlet transport: StdioServerTransport | null = null;\nlet transportConnectedAt: string | null = null;\nlet fileWatcher: FSWatcher | null = null;\nlet ipcBridge: IpcSocketServerHandle | null = null;\nlet launcherIdleMonitor: LauncherIdleMonitor | null = null;\n\n/** Maximum time (ms) to wait for async cleanup before force-exiting. */\nconst SHUTDOWN_DEADLINE_MS = 5000;\n\n/**\n * Exit code telling the launcher \"another live process holds the database\n * single-writer lock\": bridge to that owner instead of counting this exit\n * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n * mk-spec-memory-launcher.cjs.\n */\nconst EXIT_DB_LOCK_HELD = 86;\n\nexport const __testables = {\n  runCleanupStep,\n  runAsyncCleanupStep,\n  main: () => main(),\n  getBootFtsIntegrityHealth,\n  runCheckpointNeedsRebuildRepair,\n  normalizeGraphFilePath,\n  extractFilePathsFromToolArgs,\n};\n\nasync function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  console.error(`[context-server] ${reason}`);\n\n  runCleanupStep('sessionManager', () => sessionManager.shutdown());\n  runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n  // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n  // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n  // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n  runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n  runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n  runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n  runCleanupStep('accessTracker', () => accessTracker.reset());\n  runCleanupStep('toolCache', () => toolCache.shutdown());\n  runCleanupStep('launcherIdleMonitor', () => {\n    if (launcherIdleMonitor) {\n      launcherIdleMonitor.stop();\n      launcherIdleMonitor = null;\n    }\n  });\n\n  let deadlineTimer: NodeJS.Timeout | undefined;\n  const cleanup = (async () => {\n    // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n    // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n    // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n    await runAsyncCleanupStep('startupScan', async () => {\n      if (startupScanPromise) await startupScanPromise;\n    });\n    // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n    // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n    // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n    // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n    // at rest and defeating the durability guarantee. closeDb() is\n    // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n    // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n    // small even if a pathologically slow drain starves this step.\n    await runAsyncCleanupStep('fileWatcher', async () => {\n      if (fileWatcher) {\n        await fileWatcher.close();\n        fileWatcher = null;\n      }\n    });\n    // Fence the ingest worker before closeDb for the same reason as the file\n    // watcher above: the worker writes through the DB and would otherwise reopen\n    // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n    await runAsyncCleanupStep('ingestWorker', async () => {\n      await stopIngestWorker();\n    });\n    runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n    // Close MCP transport on shutdown\n    runCleanupStep('transport', () => {\n      if (transport) {\n        transport.close();\n        transport = null;\n        transportConnectedAt = null;\n      }\n    });\n    await runAsyncCleanupStep('ipcBridge', async () => {\n      if (ipcBridge) {\n        await ipcBridge.close();\n        ipcBridge = null;\n      }\n    });\n    await runAsyncCleanupStep('shutdownHooks', async () => {\n      await runShutdownHooks();\n    });\n    runCleanupStep('registeredTimers', () => clearAllTimers());\n  })();\n\n  const timedOut = await Promise.race([\n    cleanup.then(() => false),\n    new Promise<boolean>((resolve) => {\n      deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n    }),\n  ]);\n\n  if (deadlineTimer) {\n    clearRegisteredTimer(deadlineTimer);\n  }\n\n  if (timedOut) {\n    console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n  }\n\n  process.exit(exitCode);\n}\n\n/** Remove indexed rows for watcher delete and rename events. */\nasync function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return;\n  }\n\n  const canonicalPath = getCanonicalPathKey(filePath);\n  let rows: Array<{ id: number; spec_folder: string | null }> = [];\n\n  try {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE canonical_file_path = ? OR file_path = ?\n      ORDER BY id ASC\n    `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n  } catch (_error: unknown) {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE file_path = ?\n      ORDER BY id ASC\n    `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n  }\n\n  let deletedCount = 0;\n  for (const row of rows) {\n    if (typeof row.id === 'number') {\n      if (vectorIndex.deleteMemory(row.id)) {\n        deletedCount += 1;\n        // Record DELETE history only after confirmed deletion.\n        try {\n          recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n        } catch (_histErr: unknown) {\n          // History recording is best-effort in file-watcher path\n        }\n      }\n    }\n  }\n\n  if (deletedCount > 0) {\n    try {\n      runPostMutationHooks('delete', { filePath, deletedCount });\n    } catch (_error: unknown) {\n      // Non-throwing by design: file-watcher path must not crash the server.\n    }\n  }\n}\n\nprocess.on('SIGTERM', () => {\n  void fatalShutdown('Received SIGTERM, shutting down...', 0);\n});\nprocess.on('SIGINT', () => {\n  void fatalShutdown('Received SIGINT, shutting down...', 0);\n});\nprocess.on('SIGHUP', () => {\n  void fatalShutdown('Received SIGHUP, shutting down...', 0);\n});","lineStart":1540,"lineEnd":1759,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781762444515,"end":1781762444524}},"metadata":{"openai":{"itemId":"fc_0480beb90931291e016a33898c53d081918def555f8adf3a79"}},"id":"prt_ed9514cc6001RrVFntqQ8QcqV9","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9510203001rTfUhdGitGPM89"}}
{"type":"tool_use","timestamp":1781762444613,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_tthpkx6ye73pqi61WhixqBJI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // All MCP tool definitions (names, descriptions, input schemas).\n5: // Extracted from context-server.ts for maintainability.\n6: import {\n7:   MAX_INGEST_PATHS,\n8:   MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n9: } from './schemas/tool-input-schemas.js';\n10: \n11: /**\n12:  * Re-export schema validation helpers used by the MCP tool entry points.\n13:  */\n14: export {\n15:   ToolSchemaValidationError,\n16:   formatZodError,\n17:   getToolSchema,\n18:   validateToolArgs,\n19:   getSchema,\n20: } from './schemas/tool-input-schemas.js';\n21: \n22: // ───────────────────────────────────────────────────────────────\n23: // 1. TYPES\n24: \n25: // ───────────────────────────────────────────────────────────────\n26: /**\n27:  * Normalized definition for a single MCP tool and its JSON schema.\n28:  */\n29: export interface ToolDefinition {\n30:   name: string;\n31:   description: string;\n32:   inputSchema: Record<string, unknown>;\n33:   outputSchema?: Record<string, unknown>;\n34: }\n35: \n36: export type ToolOwnershipStability = 'stable' | 'deprecated';\n37: \n38: export interface ToolOwnershipEntry {\n39:   name: string;\n40:   owner: string;\n41:   stability: ToolOwnershipStability;\n42:   level: string;\n43:   category: string;\n44: }\n45: \n46: export interface ToolOwnershipMap {\n47:   schemaVersion: 1;\n48:   generatedFrom: 'TOOL_DEFINITIONS';\n49:   tools: ToolOwnershipEntry[];\n50: }\n51: \n52: export interface ToolOwnershipDriftReport {\n53:   ok: boolean;\n54:   missingFromCommitted: string[];\n55:   extraInCommitted: string[];\n56:   changed: Array<{\n57:     name: string;\n58:     field: keyof Omit<ToolOwnershipEntry, 'name'>;\n59:     expected: string;\n60:     actual: string;\n61:   }>;\n62:   expectedMap: ToolOwnershipMap;\n63: }\n64: \n65: const TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n66:   Orchestration: 'memory-orchestration',\n67:   Core: 'memory-core',\n68:   Discovery: 'memory-discovery',\n69:   Mutation: 'memory-mutation',\n70:   Lifecycle: 'memory-lifecycle',\n71:   Analysis: 'memory-analysis',\n72:   Maintenance: 'memory-maintenance',\n73: });\n74: \n75: function readToolContract(definition: ToolDefinition): { level: string; category: string } {\n76:   const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n77:   if (!match) {\n78:     return { level: 'unclassified', category: 'unclassified' };\n79:   }\n80:   return {\n81:     level: match[1] ?? 'unclassified',\n82:     category: match[2] ?? 'unclassified',\n83:   };\n84: }\n85: \n86: function deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n87:   const contract = readToolContract(definition);\n88:   return {\n89:     name: definition.name,\n90:     owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n91:     stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n92:     level: contract.level,\n93:     category: contract.category,\n94:   };\n95: }\n96: \n97: function normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n98:   return {\n99:     schemaVersion: 1,\n100:     generatedFrom: 'TOOL_DEFINITIONS',\n101:     tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n102:   };\n103: }\n104: \n105: function isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n106:   if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n107:   const record = value as Record<string, unknown>;\n108:   return (\n109:     typeof record.name === 'string' &&\n110:     typeof record.owner === 'string' &&\n111:     (record.stability === 'stable' || record.stability === 'deprecated') &&\n112:     typeof record.level === 'string' &&\n113:     typeof record.category === 'string'\n114:   );\n115: }\n116: \n117: function parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n118:   let parsed: unknown;\n119:   try {\n120:     parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n121:   } catch (_error: unknown) {\n122:     return null;\n123:   }\n124:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n125:   const record = parsed as Record<string, unknown>;\n126:   if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n127:   if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n128:   return normalizeToolOwnershipMap({\n129:     schemaVersion: 1,\n130:     generatedFrom: 'TOOL_DEFINITIONS',\n131:     tools: record.tools,\n132:   });\n133: }\n134: \n135: /** Derive the deterministic tool ownership map from live tool definitions. */\n136: export function deriveToolOwnershipMap(\n137:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n138: ): ToolOwnershipMap {\n139:   return normalizeToolOwnershipMap({\n140:     schemaVersion: 1,\n141:     generatedFrom: 'TOOL_DEFINITIONS',\n142:     tools: toolDefinitions.map(deriveToolOwnershipEntry),\n143:   });\n144: }\n145: \n146: /** Serialize a derived ownership map for byte-identical generated output. */\n147: export function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n148:   return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n149: }\n150: \n151: /** Compare a committed ownership map with a fresh derivation. */\n152: export function lintToolOwnershipMapDrift(\n153:   committedMap: unknown,\n154:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n155: ): ToolOwnershipDriftReport {\n156:   const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n157:   const parsed = parseToolOwnershipMap(committedMap);\n158:   if (!parsed) {\n159:     return {\n160:       ok: false,\n161:       missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n162:       extraInCommitted: [],\n163:       changed: [],\n164:       expectedMap,\n165:     };\n166:   }\n167: \n168:   const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n169:   const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n170:   const missingFromCommitted = expectedMap.tools\n171:     .filter((tool) => !actualByName.has(tool.name))\n172:     .map((tool) => tool.name);\n173:   const extraInCommitted = parsed.tools\n174:     .filter((tool) => !expectedByName.has(tool.name))\n175:     .map((tool) => tool.name);\n176:   const changed: ToolOwnershipDriftReport['changed'] = [];\n177:   const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n178: \n179:   for (const expected of expectedMap.tools) {\n180:     const actual = actualByName.get(expected.name);\n181:     if (!actual) continue;\n182:     for (const field of fields) {\n183:       if (expected[field] !== actual[field]) {\n184:         changed.push({\n185:           name: expected.name,\n186:           field,\n187:           expected: expected[field],\n188:           actual: actual[field],\n189:         });\n190:       }\n191:     }\n192:   }\n193: \n194:   return {\n195:     ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n196:     missingFromCommitted,\n197:     extraInCommitted,\n198:     changed,\n199:     expectedMap,\n200:   };\n201: }\n202: \n203: // ───────────────────────────────────────────────────────────────\n204: // 2. TOOL DEFINITIONS\n205: \n206: // ───────────────────────────────────────────────────────────────\n207: // L1 Orchestration - Unified entry point (Token Budget: 3500)\n208: const memoryContext: ToolDefinition = {\n209:   name: 'memory_context',\n210:   description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n211:   inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n212: };\n213: \n214: // L2: Core - Primary operations (Token Budget: 3500)\n215: const memorySearch: ToolDefinition = {\n216:   name: 'memory_search',\n217:   description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n218:   inputSchema: {\n219:     type: 'object',\n220:     additionalProperties: false,\n221:     'x-requiredAnyOf': [['query'], ['concepts'], ['cursor']],\n222:     properties: {\n223:       cursor: {\n224:         type: 'string',\n225:         minLength: 1,\n226:         description: 'Opaque continuation cursor returned by progressive disclosure. When provided, resolves the next page without requiring a new query.'\n227:       },\n228:       query: { type: 'string', minLength: 2, maxLength: 1000, description: 'Natural language search query' },\n229:       concepts: {\n230:         type: 'array',\n231:         items: { type: 'string', minLength: 1 },\n232:         minItems: 2,\n233:         maxItems: 5,\n234:         description: 'Multiple concepts for AND search (requires 2-5 concepts). Results must match ALL concepts.'\n235:       },\n236:       specFolder: { type: 'string', description: 'Limit search to a specific spec folder (e.g., \"011-spec-kit-memory-upgrade\")' },\n237:       tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval. When provided with scope enforcement, results are isolated to this tenant.' },\n238:       userId: { type: 'string', description: 'User boundary for governed retrieval. Filters private user-scoped spec-doc records.' },\n239:       agentId: { type: 'string', description: 'Agent boundary for governed retrieval. Filters agent-scoped spec-doc records.' },\n240:       limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n241:       sessionId: {\n242:         type: 'string',\n243:         description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n244:       },\n245:       enableDedup: {\n246:         type: 'boolean',\n247:         default: true,\n248:         description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n249:       },\n250:       tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n251:       contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n252:       useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n253:       includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n254:       includeConstitutional: {\n255:         type: 'boolean',\n256:         default: true,\n257:         description: 'Include constitutional tier rules at top of results (default: true)'\n258:       },\n259:       enableSessionBoost: {\n260:         type: 'boolean',\n\n(Showing lines 1-260 of 955. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Normalized definition for a single MCP tool and its JSON schema.\n */\nexport interface ToolDefinition {\n  name: string;\n  description: string;\n  inputSchema: Record<string, unknown>;\n  outputSchema?: Record<string, unknown>;\n}\n\nexport type ToolOwnershipStability = 'stable' | 'deprecated';\n\nexport interface ToolOwnershipEntry {\n  name: string;\n  owner: string;\n  stability: ToolOwnershipStability;\n  level: string;\n  category: string;\n}\n\nexport interface ToolOwnershipMap {\n  schemaVersion: 1;\n  generatedFrom: 'TOOL_DEFINITIONS';\n  tools: ToolOwnershipEntry[];\n}\n\nexport interface ToolOwnershipDriftReport {\n  ok: boolean;\n  missingFromCommitted: string[];\n  extraInCommitted: string[];\n  changed: Array<{\n    name: string;\n    field: keyof Omit<ToolOwnershipEntry, 'name'>;\n    expected: string;\n    actual: string;\n  }>;\n  expectedMap: ToolOwnershipMap;\n}\n\nconst TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n  Orchestration: 'memory-orchestration',\n  Core: 'memory-core',\n  Discovery: 'memory-discovery',\n  Mutation: 'memory-mutation',\n  Lifecycle: 'memory-lifecycle',\n  Analysis: 'memory-analysis',\n  Maintenance: 'memory-maintenance',\n});\n\nfunction readToolContract(definition: ToolDefinition): { level: string; category: string } {\n  const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n  if (!match) {\n    return { level: 'unclassified', category: 'unclassified' };\n  }\n  return {\n    level: match[1] ?? 'unclassified',\n    category: match[2] ?? 'unclassified',\n  };\n}\n\nfunction deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n  const contract = readToolContract(definition);\n  return {\n    name: definition.name,\n    owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n    stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n    level: contract.level,\n    category: contract.category,\n  };\n}\n\nfunction normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n  return {\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n  };\n}\n\nfunction isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n  const record = value as Record<string, unknown>;\n  return (\n    typeof record.name === 'string' &&\n    typeof record.owner === 'string' &&\n    (record.stability === 'stable' || record.stability === 'deprecated') &&\n    typeof record.level === 'string' &&\n    typeof record.category === 'string'\n  );\n}\n\nfunction parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n  let parsed: unknown;\n  try {\n    parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n  } catch (_error: unknown) {\n    return null;\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n  const record = parsed as Record<string, unknown>;\n  if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n  if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: record.tools,\n  });\n}\n\n/** Derive the deterministic tool ownership map from live tool definitions. */\nexport function deriveToolOwnershipMap(\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipMap {\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: toolDefinitions.map(deriveToolOwnershipEntry),\n  });\n}\n\n/** Serialize a derived ownership map for byte-identical generated output. */\nexport function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n  return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n}\n\n/** Compare a committed ownership map with a fresh derivation. */\nexport function lintToolOwnershipMapDrift(\n  committedMap: unknown,\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipDriftReport {\n  const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n  const parsed = parseToolOwnershipMap(committedMap);\n  if (!parsed) {\n    return {\n      ok: false,\n      missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n      extraInCommitted: [],\n      changed: [],\n      expectedMap,\n    };\n  }\n\n  const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n  const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n  const missingFromCommitted = expectedMap.tools\n    .filter((tool) => !actualByName.has(tool.name))\n    .map((tool) => tool.name);\n  const extraInCommitted = parsed.tools\n    .filter((tool) => !expectedByName.has(tool.name))\n    .map((tool) => tool.name);\n  const changed: ToolOwnershipDriftReport['changed'] = [];\n  const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n\n  for (const expected of expectedMap.tools) {\n    const actual = actualByName.get(expected.name);\n    if (!actual) continue;\n    for (const field of fields) {\n      if (expected[field] !== actual[field]) {\n        changed.push({\n          name: expected.name,\n          field,\n          expected: expected[field],\n          actual: actual[field],\n        });\n      }\n    }\n  }\n\n  return {\n    ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n    missingFromCommitted,\n    extraInCommitted,\n    changed,\n    expectedMap,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. TOOL DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n// L1 Orchestration - Unified entry point (Token Budget: 3500)\nconst memoryContext: ToolDefinition = {\n  name: 'memory_context',\n  description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n};\n\n// L2: Core - Primary operations (Token Budget: 3500)\nconst memorySearch: ToolDefinition = {\n  name: 'memory_search',\n  description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: {\n    type: 'object',\n    additionalProperties: false,\n    'x-requiredAnyOf': [['query'], ['concepts'], ['cursor']],\n    properties: {\n      cursor: {\n        type: 'string',\n        minLength: 1,\n        description: 'Opaque continuation cursor returned by progressive disclosure. When provided, resolves the next page without requiring a new query.'\n      },\n      query: { type: 'string', minLength: 2, maxLength: 1000, description: 'Natural language search query' },\n      concepts: {\n        type: 'array',\n        items: { type: 'string', minLength: 1 },\n        minItems: 2,\n        maxItems: 5,\n        description: 'Multiple concepts for AND search (requires 2-5 concepts). Results must match ALL concepts.'\n      },\n      specFolder: { type: 'string', description: 'Limit search to a specific spec folder (e.g., \"011-spec-kit-memory-upgrade\")' },\n      tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval. When provided with scope enforcement, results are isolated to this tenant.' },\n      userId: { type: 'string', description: 'User boundary for governed retrieval. Filters private user-scoped spec-doc records.' },\n      agentId: { type: 'string', description: 'Agent boundary for governed retrieval. Filters agent-scoped spec-doc records.' },\n      limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n      sessionId: {\n        type: 'string',\n        description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n      },\n      enableDedup: {\n        type: 'boolean',\n        default: true,\n        description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n      },\n      tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n      contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n      useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n      includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n      includeConstitutional: {\n        type: 'boolean',\n        default: true,\n        description: 'Include constitutional tier rules at top of results (default: true)'\n      },\n      enableSessionBoost: {\n        type: 'boolean',","lineStart":1,"lineEnd":260,"totalLines":955,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1781762444610,"end":1781762444613}},"metadata":{"openai":{"itemId":"fc_0480beb90931291e016a33898c53d48191b40b09c5b1c25622"}},"id":"prt_ed9514cea0018JmgDQV5gc5a0j","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9510203001rTfUhdGitGPM89"}}
