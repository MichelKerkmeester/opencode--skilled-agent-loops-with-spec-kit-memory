\n75:         \"matcher\": \"\",\n76:         \"hooks\": [\n77:           {\n78:             \"type\": \"command\",\n79:             \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/system-spec-kit/mcp_server/dist/hooks/claude/session-stop.js ; stop_status=$? ; bash .opencode/scripts/session-cleanup.sh || true ; exit \\\"$stop_status\\\"'\",\n80:             \"timeout\": 10,\n81:             \"async\": true\n82:           }\n83:         ]\n84:       }\n85:     ],\n86:     \"PostToolUse\": [\n87:       {\n88:         \"matcher\": \"Write|Edit\",\n89:         \"hooks\": [\n90:           {\n91:             \"type\": \"command\",\n92:             \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && python3 .opencode/skills/sk-code/scripts/hooks/claude-posttooluse.sh'\",\n93:             \"timeout\": 10\n94:           }\n95:         ]\n96:       }\n97:     ]\n98:   }\n99: }\n\n(End of file - total 99 lines)\n</content>\n\n<system-reminder>\nInstructions from: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.claude/CLAUDE.md\n# Claude Runtime Routing\n\n## Tool Routing Enforcement\n\nSEARCH ROUTING: use Code Graph structural search (`mcp__mk_code_index__code_graph_query`) plus Grep for concept, similarity, implementation-pattern, and \"how does this work\" code discovery. Use Code Graph for callers, imports, dependencies, outlines, symbols, and impact questions. Use exact text search when the user gives a literal token, path, or regex. Use `memory_search` only for spec docs and saved memory, not arbitrary code.\n\n</system-reminder>","metadata":{"preview":"{\n  \"env\": {\n    \"SPECKIT_ABLATION\": \"true\",\n    \"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING\": \"1\",\n    \"ENABLE_TOOL_SEARCH\": \"true\",\n    \"MAX_THINKING_TOKENS\": \"999999\"\n  },\n  \"permissions\": {\n    \"allow\": [\n      \"mcp__sequential_thinking__sequentialthinking\",\n      \"Bash(echo \\\"EXIT_CODE=$?\\\")\",\n      \"Skill(update-config)\",\n      \"Skill(update-config:*)\",\n      \"Skill(cli-codex)\",\n      \"Bash(codex exec *)\",\n      \"Bash(git *)\",\n      \"Bash(mkdir -p /tmp/dr-009)\",\n      \"Bash(rm -rf /tmp/dr-009/*)\",\n      \"Bash(mkdir -p /tmp/docs-011)\",\n      \"Bash(rm -rf /tmp/docs-011/*)\",","truncated":false,"loaded":["/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.claude/CLAUDE.md"],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.claude/settings.local.json","text":"{\n  \"env\": {\n    \"SPECKIT_ABLATION\": \"true\",\n    \"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING\": \"1\",\n    \"ENABLE_TOOL_SEARCH\": \"true\",\n    \"MAX_THINKING_TOKENS\": \"999999\"\n  },\n  \"permissions\": {\n    \"allow\": [\n      \"mcp__sequential_thinking__sequentialthinking\",\n      \"Bash(echo \\\"EXIT_CODE=$?\\\")\",\n      \"Skill(update-config)\",\n      \"Skill(update-config:*)\",\n      \"Skill(cli-codex)\",\n      \"Bash(codex exec *)\",\n      \"Bash(git *)\",\n      \"Bash(mkdir -p /tmp/dr-009)\",\n      \"Bash(rm -rf /tmp/dr-009/*)\",\n      \"Bash(mkdir -p /tmp/docs-011)\",\n      \"Bash(rm -rf /tmp/docs-011/*)\",\n      \"Bash(awk '{printf \\\"PID=%s CPU%%=%s CPUtime=%s\\\\\\\\n\\\", $2, $3, $10}')\",\n      \"Bash(echo \\\"dispatched pid=$!\\\")\",\n      \"Bash(rm -rf state/eval-loop-state.jsonl state/best-variant.json state/mutation-coverage.json state/in-flight/* iterations/* synthesis.md)\",\n      \"Bash(EVAL_LOOP_SKIP_ITER1_REVIEW=true node scripts/loop.cjs --mock --mock-mode high-score --max-iters 3)\",\n      \"Bash(echo \\\"EXIT: $?\\\")\",\n      \"Bash(node .opencode/specs/skilled-agent-orchestration/114-small-ai-model-optimization/003-eval-loop/scripts/seed-fixtures.cjs)\",\n      \"Bash(echo \\\"exit: $?\\\")\",\n      \"Bash(bash .opencode/skills/system-spec-kit/scripts/spec/create.sh --phase --track skilled-agent-orchestration --number 130 --skip-branch --short-name prompt-knowledge-layering --phase-names design-architecture-and-data-contract,repair-and-extend-sync-substrate,land-recommended-frameworks-data,model-hub-and-priority-profiles,backfill-remaining-profiles,thin-and-standardize-cli-cards,wire-precedence-and-crosslinks,validate-sweep-changelog-reindex 'Prompt-knowledge layering across CLI skills, sk-prompt frameworks, and the sk-prompt-small-model model-craft hub')\"\n    ]\n  },\n  \"hooks\": {\n    \"UserPromptSubmit\": [\n      {\n        \"matcher\": \"\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/system-spec-kit/mcp_server/dist/hooks/claude/user-prompt-submit.js'\",\n            \"timeout\": 3\n          }\n        ]\n      }\n    ],\n    \"PreCompact\": [\n      {\n        \"matcher\": \"\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/system-spec-kit/mcp_server/dist/hooks/claude/compact-inject.js'\",\n            \"timeout\": 3\n          }\n        ]\n      }\n    ],\n    \"SessionStart\": [\n      {\n        \"matcher\": \"\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/system-spec-kit/mcp_server/dist/hooks/claude/session-prime.js'\",\n            \"timeout\": 3\n          },\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && bash .opencode/bin/worktree-guard.sh'\",\n            \"timeout\": 3\n          }\n        ]\n      }\n    ],\n    \"Stop\": [\n      {\n        \"matcher\": \"\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/system-spec-kit/mcp_server/dist/hooks/claude/session-stop.js ; stop_status=$? ; bash .opencode/scripts/session-cleanup.sh || true ; exit \\\"$stop_status\\\"'\",\n            \"timeout\": 10,\n            \"async\": true\n          }\n        ]\n      }\n    ],\n    \"PostToolUse\": [\n      {\n        \"matcher\": \"Write|Edit\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && python3 .opencode/skills/sk-code/scripts/hooks/claude-posttooluse.sh'\",\n            \"timeout\": 10\n          }\n        ]\n      }\n    ]\n  }\n}","lineStart":1,"lineEnd":99,"totalLines":99,"truncated":false}},"title":".claude/settings.local.json","time":{"start":1780906508882,"end":1780906508896}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad748191bffe03476c72897f"}},"id":"prt_ea64cc251001oJ0ALzaZ1kMeSS","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
{"type":"tool_use","timestamp":1780906508903,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_fD5Ya7pINlSgKiTVa5xkaTel","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","offset":630,"limit":310},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs</path>\n<type>file</type>\n<content>\n630: async function bridgeOrReportLeaseHeld(leaseResult, options = {}) {\n631:   const { maybeBridgeLeaseHolder } = loadBridgeModule();\n632:   const decision = await maybeBridgeLeaseHolder({\n633:     serviceName: 'mk-code-index',\n634:     leaseResult,\n635:     loggerPrefix: 'mk-code-index-launcher',\n636:     dbDir: resolvedDbDir(),\n637:     bridge: bridgeStdioThroughSessionProxy,\n638:   });\n639:   if (decision && decision.action === 'respawn') {\n640:     return await respawnAfterDeadSocket(leaseResult, decision, options);\n641:   }\n642:   return decision;\n643: }\n644: \n645: function writeLeaseFile() {\n646:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(leasePath())), PID_FILE_NAME);\n647:   const tmp = currentLeasePath + '.tmp.' + process.pid;\n648:   fs.writeFileSync(tmp, JSON.stringify({ pid: process.pid, startedAt: new Date().toISOString() }, null, 2), { mode: 0o600 });\n649:   fs.renameSync(tmp, currentLeasePath);\n650: }\n651: \n652: function clearLeaseFile() {\n653:   try {\n654:     const lease = readLeaseFile();\n655:     if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n656:   } catch {\n657:     // Idempotent cleanup.\n658:   }\n659: }\n660: \n661: function clearAllLeaseFiles() {\n662:   clearLeaseFile();\n663:   clearOwnerLeaseFile();\n664: }\n665: \n666: function run(command, args, options = {}) {\n667:   const result = spawnSync(command, args, {\n668:     cwd: options.cwd || root,\n669:     env: buildChildEnv(),\n670:     encoding: 'utf8',\n671:     stdio: ['ignore', 'pipe', 'pipe'],\n672:   });\n673: \n674:   if (result.stdout) {\n675:     process.stderr.write(result.stdout);\n676:   }\n677:   if (result.stderr) {\n678:     process.stderr.write(result.stderr);\n679:   }\n680:   if (result.error) {\n681:     throw result.error;\n682:   }\n683:   if (result.status !== 0) {\n684:     throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n685:   }\n686: }\n687: \n688: function buildChildEnv(extra = {}) {\n689:   const nextEnv = {};\n690:   for (const [key, value] of Object.entries(process.env)) {\n691:     if (BLOCKED_CHILD_ENV_RE.test(key)) continue;\n692:     nextEnv[key] = value;\n693:   }\n694:   return { ...nextEnv, ...extra };\n695: }\n696: \n697: function ensureLayout(actions) {\n698:   if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n699:     fs.renameSync(legacySkillDir, skillsDir);\n700:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n701:     actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n702:     refreshPaths();\n703:     return;\n704:   }\n705: \n706:   if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n707:     const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n708:     fs.renameSync(legacySkillDir, backup);\n709:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n710:     actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n711:     refreshPaths();\n712:     return;\n713:   }\n714: \n715:   // Compatibility symlink `.opencode/skill -> skills` removed: 096 packet cleaned\n716:   // up consumers of the singular path, so the bridge no longer needs to be\n717:   // recreated on every MCP startup. Migration paths above (rename / move-aside)\n718:   // still create the symlink when an actual legacy singular dir is present.\n719: }\n720: \n721: function requiredArtifacts() {\n722:   return [\n723:     path.join(kitDir, 'mcp_server', 'dist', 'index.js'),\n724:   ];\n725: }\n726: \n727: function artifactsReady() {\n728:   return requiredArtifacts().every(exists);\n729: }\n730: \n731: function localTscEntrypoint() {\n732:   return path.join(kitDir, 'node_modules', 'typescript', 'bin', 'tsc');\n733: }\n734: \n735: function buildIfNeeded(actions) {\n736:   if (artifactsReady()) {\n737:     return;\n738:   }\n739: \n740:   if (!exists(kitDir)) {\n741:     throw new Error(`mk-code-index skill (system-code-graph directory) not found at ${rel(kitDir)}`);\n742:   }\n743: \n744:   actions.push('installed dependencies and built @spec-kit/system-code-graph MCP server');\n745:   if (!exists(localTscEntrypoint())) {\n746:     const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n747:     run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n748:   }\n749:   run(process.execPath, [localTscEntrypoint(), '-p', 'tsconfig.json'], { cwd: kitDir });\n750: \n751:   const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n752:   if (missing.length > 0) {\n753:     throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n754:   }\n755: }\n756: \n757: async function acquireBootstrapLock(options = {}) {\n758:   const requireLock = options.requireLock === true;\n759:   fs.mkdirSync(dbDir, { recursive: true });\n760:   const deadline = Date.now() + 120000;\n761:   const STALE_LOCK_MS = 5 * 60 * 1000; // 5 minutes — covers SIGKILL'd prior launchers\n762:   while (true) {\n763:     try {\n764:       fs.mkdirSync(lockDir);\n765:       return true;\n766:     } catch (error) {\n767:       if (error.code !== 'EEXIST') {\n768:         throw error;\n769:       }\n770:       if (artifactsReady() && !requireLock) {\n771:         return false;\n772:       }\n773:       // Detect stale lockdir from SIGKILL'd predecessor.\n774:       // Existing process should refresh the dir; an mtime older than 5min\n775:       // implies the holder is gone. Remove and retry.\n776:       try {\n777:         const lockStat = fs.statSync(lockDir);\n778:         if (Date.now() - lockStat.mtimeMs > STALE_LOCK_MS) {\n779:           process.stderr.write(\n780:             `[mk-code-index-launcher] stale bootstrap lock (mtime ${Math.round((Date.now() - lockStat.mtimeMs) / 1000)}s old); reclaiming ${rel(lockDir)}\\n`\n781:           );\n782:           // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n783:           // racer wins the rename; a successor that mkdir's a fresh lockDir after our stat creates\n784:           // a NEW inode that our rename/rmSync cannot touch, so we never delete a live successor\n785:           // lock. A losing racer's rename throws ENOENT and falls through to the outer retry.\n786:           const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n787:           fs.renameSync(lockDir, staleClaim);\n788:           fs.rmSync(staleClaim, { recursive: true, force: true });\n789:           continue;\n790:         }\n791:       } catch {\n792:         // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n793:       }\n794:       if (Date.now() > deadline) {\n795:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n796:       }\n797:       await sleep(1000);\n798:     }\n799:   }\n800: }\n801: \n802: function launchServer() {\n803:   if (launchStarted) {\n804:     log('launchServer skipped: launch already started in this launcher process');\n805:     return false;\n806:   }\n807:   launchStarted = true;\n808:   // Set DB dir for the child process (operator-set env var wins).\n809:   if (!process.env.SPECKIT_CODE_GRAPH_DB_DIR) {\n810:     process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedDbDir();\n811:   }\n812: \n813:   const server = path.join(kitDir, 'mcp_server', 'dist', 'index.js');\n814:   childProcess = spawn(process.execPath, [server], {\n815:     cwd: root,\n816:     env: buildChildEnv(),\n817:     stdio: 'inherit',\n818:   });\n819: \n820:   if (typeof childProcess.pid === 'number') {\n821:     const refreshed = refreshOwnerLeaseFile(process.pid, {\n822:       ownerPid: childProcess.pid,\n823:       ppid: process.pid,\n824:       executablePath: process.execPath,\n825:     });\n826:     if (!refreshed) {\n827:       log('owner lease refresh to child pid failed; launcher pid remains the recorded owner');\n828:     }\n829:   }\n830: \n831:   childProcess.on('exit', (code, signal) => {\n832:     if (signal) {\n833:       // Clear the lease before mirroring the signal; process.on('exit') does not fire on SIGKILL.\n834:       clearAllLeaseFiles();\n835:       process.kill(process.pid, signal);\n836:       return;\n837:     }\n838:     clearAllLeaseFiles();\n839:     process.exit(code ?? 0);\n840:   });\n841: \n842:   childProcess.on('error', (error) => {\n843:     log(error.stack || error.message);\n844:     process.exit(1);\n845:   });\n846:   return true;\n847: }\n848: \n849: function installSignalHandlers() {\n850:   for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n851:     process.on(signal, () => {\n852:       if (childProcess && !childProcess.killed) {\n853:         childProcess.once('exit', () => {\n854:           clearLeaseFile();\n855:           process.exit(128);\n856:         });\n857:         childProcess.kill(signal);\n858:         setTimeout(() => {\n859:           clearAllLeaseFiles();\n860:           process.exit(128);\n861:         }, 5000).unref();\n862:         return;\n863:       }\n864:       clearAllLeaseFiles();\n865:       process.exit(128);\n866:     });\n867:   }\n868:   process.on('uncaughtException', (err) => {\n869:     try {\n870:       clearAllLeaseFiles();\n871:     } catch {\n872:       // Preserve default uncaughtException crash behavior.\n873:     }\n874:     throw err;\n875:   });\n876: }\n877: \n878: async function launcherMain() {\n879:   const started = now();\n880:   const actions = [];\n881:   let lockHeld = false;\n882: \n883:   try {\n884:     installSignalHandlers();\n885:     // Lease cleanup runs unconditionally regardless of child termination path.\n886:     process.on('exit', clearAllLeaseFiles);\n887:     refreshPaths();\n888:     ensureLayout(actions);\n889:     refreshPaths();\n890: \n891:     const strictSingleWriter = !isStrictModeDisabled(process.env.MK_CODE_INDEX_STRICT_SINGLE_WRITER);\n892:     if (strictSingleWriter) {\n893:       const ownerLeaseResult = acquireOwnerLeaseFile();\n894:       if (!ownerLeaseResult.acquired) {\n895:         // A live owner already holds the single-writer lease. Bridge this\n896:         // client's stdio to the owner's IPC socket so additional sessions and\n897:         // MCP reconnects share the one daemon (matches mk-spec-memory-launcher).\n898:         // maybeBridgeLeaseHolder falls back to a LEASE_HELD_BY diagnostic line\n899:         // only when the socket is missing/refused or bridging is disabled.\n900:         log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n901:         await bridgeOrReportLeaseHeld({\n902:           ownerPid: ownerLeaseResult.holder.ownerPid,\n903:           startedAt: ownerLeaseResult.holder.startedAtIso,\n904:         }, {\n905:           respawnChildPid: ownerLeaseResult.holder.ownerPid,\n906:         });\n907:         return;\n908:       }\n909: \n910:       const leaseResult = isLeaseHeld();\n911:       if (leaseResult.held && !leaseResult.staleReclaimable) {\n912:         clearOwnerLeaseFile();\n913:         await bridgeOrReportLeaseHeld(leaseResult);\n914:         return;\n915:       }\n916:       if (leaseResult.staleReclaimable) {\n917:         log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n918:       }\n919:     } else {\n920:       log('MK_CODE_INDEX_STRICT_SINGLE_WRITER is disabled; skipping lease check');\n921:     }\n922: \n923:     lockHeld = await acquireBootstrapLock();\n924:     if (lockHeld) {\n925:       // Auto-migrate DB from the former shared standalone location back to skill-local.\n926:       // The former DB is preserved as a backup (copy, not move).\n927:       // This block now runs ONLY for the single bootstrap-lock winner (lockHeld), AFTER the lock\n928:       // is held and BEFORE the DB is opened by the spawned child (launchServer, below). Previously\n929:       // it ran in the main IIFE before any lock, so two concurrent launchers could both pass the\n930:       // !exists(target) guard and both copy — a lagging copier truncate-overwriting the now-LIVE\n931:       // target DB out from under the winner's daemon (SQLite corruption). Gating on lockHeld makes\n932:       // only one launcher migrate; the COPYFILE_EXCL + pre-copy re-check below is the belt-and-\n933:       // suspenders guarantee that NO launcher ever overwrites an existing (possibly live) target DB.\n934:       // Never auto-seed/migrate into an explicit SPECKIT_CODE_GRAPH_DB_DIR override\n935:       //   (the operator chose that target); migrate only into the resolved default.\n936:       // Never copy a former DB that a live legacy owner could still be\n937:       //   writing — probe BOTH the former PID lease and the former owner lease for liveness first.\n938:       //   The former owner lease (.code-graph-owner.json) is intentionally NOT copied forward.\n939:       const formerSharedDbDir = path.join(opencodeDir, '.spec-kit', 'code-graph', 'database');\n\n(Showing lines 630-939 of 1022. Use offset=940 to continue.)\n</content>","metadata":{"preview":"async function bridgeOrReportLeaseHeld(leaseResult, options = {}) {\n  const { maybeBridgeLeaseHolder } = loadBridgeModule();\n  const decision = await maybeBridgeLeaseHolder({\n    serviceName: 'mk-code-index',\n    leaseResult,\n    loggerPrefix: 'mk-code-index-launcher',\n    dbDir: resolvedDbDir(),\n    bridge: bridgeStdioThroughSessionProxy,\n  });\n  if (decision && decision.action === 'respawn') {\n    return await respawnAfterDeadSocket(leaseResult, decision, options);\n  }\n  return decision;\n}\n\nfunction writeLeaseFile() {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(leasePath())), PID_FILE_NAME);\n  const tmp = currentLeasePath + '.tmp.' + process.pid;\n  fs.writeFileSync(tmp, JSON.stringify({ pid: process.pid, startedAt: new Date().toISOString() }, null, 2), { mode: 0o600 });\n  fs.renameSync(tmp, currentLeasePath);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","text":"async function bridgeOrReportLeaseHeld(leaseResult, options = {}) {\n  const { maybeBridgeLeaseHolder } = loadBridgeModule();\n  const decision = await maybeBridgeLeaseHolder({\n    serviceName: 'mk-code-index',\n    leaseResult,\n    loggerPrefix: 'mk-code-index-launcher',\n    dbDir: resolvedDbDir(),\n    bridge: bridgeStdioThroughSessionProxy,\n  });\n  if (decision && decision.action === 'respawn') {\n    return await respawnAfterDeadSocket(leaseResult, decision, options);\n  }\n  return decision;\n}\n\nfunction writeLeaseFile() {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(leasePath())), PID_FILE_NAME);\n  const tmp = currentLeasePath + '.tmp.' + process.pid;\n  fs.writeFileSync(tmp, JSON.stringify({ pid: process.pid, startedAt: new Date().toISOString() }, null, 2), { mode: 0o600 });\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction clearLeaseFile() {\n  try {\n    const lease = readLeaseFile();\n    if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction clearAllLeaseFiles() {\n  clearLeaseFile();\n  clearOwnerLeaseFile();\n}\n\nfunction run(command, args, options = {}) {\n  const result = spawnSync(command, args, {\n    cwd: options.cwd || root,\n    env: buildChildEnv(),\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n\n  if (result.stdout) {\n    process.stderr.write(result.stdout);\n  }\n  if (result.stderr) {\n    process.stderr.write(result.stderr);\n  }\n  if (result.error) {\n    throw result.error;\n  }\n  if (result.status !== 0) {\n    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n  }\n}\n\nfunction buildChildEnv(extra = {}) {\n  const nextEnv = {};\n  for (const [key, value] of Object.entries(process.env)) {\n    if (BLOCKED_CHILD_ENV_RE.test(key)) continue;\n    nextEnv[key] = value;\n  }\n  return { ...nextEnv, ...extra };\n}\n\nfunction ensureLayout(actions) {\n  if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    fs.renameSync(legacySkillDir, skillsDir);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n    refreshPaths();\n    return;\n  }\n\n  if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n    fs.renameSync(legacySkillDir, backup);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n    refreshPaths();\n    return;\n  }\n\n  // Compatibility symlink `.opencode/skill -> skills` removed: 096 packet cleaned\n  // up consumers of the singular path, so the bridge no longer needs to be\n  // recreated on every MCP startup. Migration paths above (rename / move-aside)\n  // still create the symlink when an actual legacy singular dir is present.\n}\n\nfunction requiredArtifacts() {\n  return [\n    path.join(kitDir, 'mcp_server', 'dist', 'index.js'),\n  ];\n}\n\nfunction artifactsReady() {\n  return requiredArtifacts().every(exists);\n}\n\nfunction localTscEntrypoint() {\n  return path.join(kitDir, 'node_modules', 'typescript', 'bin', 'tsc');\n}\n\nfunction buildIfNeeded(actions) {\n  if (artifactsReady()) {\n    return;\n  }\n\n  if (!exists(kitDir)) {\n    throw new Error(`mk-code-index skill (system-code-graph directory) not found at ${rel(kitDir)}`);\n  }\n\n  actions.push('installed dependencies and built @spec-kit/system-code-graph MCP server');\n  if (!exists(localTscEntrypoint())) {\n    const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n    run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n  }\n  run(process.execPath, [localTscEntrypoint(), '-p', 'tsconfig.json'], { cwd: kitDir });\n\n  const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n  if (missing.length > 0) {\n    throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n  }\n}\n\nasync function acquireBootstrapLock(options = {}) {\n  const requireLock = options.requireLock === true;\n  fs.mkdirSync(dbDir, { recursive: true });\n  const deadline = Date.now() + 120000;\n  const STALE_LOCK_MS = 5 * 60 * 1000; // 5 minutes — covers SIGKILL'd prior launchers\n  while (true) {\n    try {\n      fs.mkdirSync(lockDir);\n      return true;\n    } catch (error) {\n      if (error.code !== 'EEXIST') {\n        throw error;\n      }\n      if (artifactsReady() && !requireLock) {\n        return false;\n      }\n      // Detect stale lockdir from SIGKILL'd predecessor.\n      // Existing process should refresh the dir; an mtime older than 5min\n      // implies the holder is gone. Remove and retry.\n      try {\n        const lockStat = fs.statSync(lockDir);\n        if (Date.now() - lockStat.mtimeMs > STALE_LOCK_MS) {\n          process.stderr.write(\n            `[mk-code-index-launcher] stale bootstrap lock (mtime ${Math.round((Date.now() - lockStat.mtimeMs) / 1000)}s old); reclaiming ${rel(lockDir)}\\n`\n          );\n          // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n          // racer wins the rename; a successor that mkdir's a fresh lockDir after our stat creates\n          // a NEW inode that our rename/rmSync cannot touch, so we never delete a live successor\n          // lock. A losing racer's rename throws ENOENT and falls through to the outer retry.\n          const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n          fs.renameSync(lockDir, staleClaim);\n          fs.rmSync(staleClaim, { recursive: true, force: true });\n          continue;\n        }\n      } catch {\n        // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n      }\n      if (Date.now() > deadline) {\n        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n      }\n      await sleep(1000);\n    }\n  }\n}\n\nfunction launchServer() {\n  if (launchStarted) {\n    log('launchServer skipped: launch already started in this launcher process');\n    return false;\n  }\n  launchStarted = true;\n  // Set DB dir for the child process (operator-set env var wins).\n  if (!process.env.SPECKIT_CODE_GRAPH_DB_DIR) {\n    process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedDbDir();\n  }\n\n  const server = path.join(kitDir, 'mcp_server', 'dist', 'index.js');\n  childProcess = spawn(process.execPath, [server], {\n    cwd: root,\n    env: buildChildEnv(),\n    stdio: 'inherit',\n  });\n\n  if (typeof childProcess.pid === 'number') {\n    const refreshed = refreshOwnerLeaseFile(process.pid, {\n      ownerPid: childProcess.pid,\n      ppid: process.pid,\n      executablePath: process.execPath,\n    });\n    if (!refreshed) {\n      log('owner lease refresh to child pid failed; launcher pid remains the recorded owner');\n    }\n  }\n\n  childProcess.on('exit', (code, signal) => {\n    if (signal) {\n      // Clear the lease before mirroring the signal; process.on('exit') does not fire on SIGKILL.\n      clearAllLeaseFiles();\n      process.kill(process.pid, signal);\n      return;\n    }\n    clearAllLeaseFiles();\n    process.exit(code ?? 0);\n  });\n\n  childProcess.on('error', (error) => {\n    log(error.stack || error.message);\n    process.exit(1);\n  });\n  return true;\n}\n\nfunction installSignalHandlers() {\n  for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n    process.on(signal, () => {\n      if (childProcess && !childProcess.killed) {\n        childProcess.once('exit', () => {\n          clearLeaseFile();\n          process.exit(128);\n        });\n        childProcess.kill(signal);\n        setTimeout(() => {\n          clearAllLeaseFiles();\n          process.exit(128);\n        }, 5000).unref();\n        return;\n      }\n      clearAllLeaseFiles();\n      process.exit(128);\n    });\n  }\n  process.on('uncaughtException', (err) => {\n    try {\n      clearAllLeaseFiles();\n    } catch {\n      // Preserve default uncaughtException crash behavior.\n    }\n    throw err;\n  });\n}\n\nasync function launcherMain() {\n  const started = now();\n  const actions = [];\n  let lockHeld = false;\n\n  try {\n    installSignalHandlers();\n    // Lease cleanup runs unconditionally regardless of child termination path.\n    process.on('exit', clearAllLeaseFiles);\n    refreshPaths();\n    ensureLayout(actions);\n    refreshPaths();\n\n    const strictSingleWriter = !isStrictModeDisabled(process.env.MK_CODE_INDEX_STRICT_SINGLE_WRITER);\n    if (strictSingleWriter) {\n      const ownerLeaseResult = acquireOwnerLeaseFile();\n      if (!ownerLeaseResult.acquired) {\n        // A live owner already holds the single-writer lease. Bridge this\n        // client's stdio to the owner's IPC socket so additional sessions and\n        // MCP reconnects share the one daemon (matches mk-spec-memory-launcher).\n        // maybeBridgeLeaseHolder falls back to a LEASE_HELD_BY diagnostic line\n        // only when the socket is missing/refused or bridging is disabled.\n        log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n        await bridgeOrReportLeaseHeld({\n          ownerPid: ownerLeaseResult.holder.ownerPid,\n          startedAt: ownerLeaseResult.holder.startedAtIso,\n        }, {\n          respawnChildPid: ownerLeaseResult.holder.ownerPid,\n        });\n        return;\n      }\n\n      const leaseResult = isLeaseHeld();\n      if (leaseResult.held && !leaseResult.staleReclaimable) {\n        clearOwnerLeaseFile();\n        await bridgeOrReportLeaseHeld(leaseResult);\n        return;\n      }\n      if (leaseResult.staleReclaimable) {\n        log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n      }\n    } else {\n      log('MK_CODE_INDEX_STRICT_SINGLE_WRITER is disabled; skipping lease check');\n    }\n\n    lockHeld = await acquireBootstrapLock();\n    if (lockHeld) {\n      // Auto-migrate DB from the former shared standalone location back to skill-local.\n      // The former DB is preserved as a backup (copy, not move).\n      // This block now runs ONLY for the single bootstrap-lock winner (lockHeld), AFTER the lock\n      // is held and BEFORE the DB is opened by the spawned child (launchServer, below). Previously\n      // it ran in the main IIFE before any lock, so two concurrent launchers could both pass the\n      // !exists(target) guard and both copy — a lagging copier truncate-overwriting the now-LIVE\n      // target DB out from under the winner's daemon (SQLite corruption). Gating on lockHeld makes\n      // only one launcher migrate; the COPYFILE_EXCL + pre-copy re-check below is the belt-and-\n      // suspenders guarantee that NO launcher ever overwrites an existing (possibly live) target DB.\n      // Never auto-seed/migrate into an explicit SPECKIT_CODE_GRAPH_DB_DIR override\n      //   (the operator chose that target); migrate only into the resolved default.\n      // Never copy a former DB that a live legacy owner could still be\n      //   writing — probe BOTH the former PID lease and the former owner lease for liveness first.\n      //   The former owner lease (.code-graph-owner.json) is intentionally NOT copied forward.\n      const formerSharedDbDir = path.join(opencodeDir, '.spec-kit', 'code-graph', 'database');","lineStart":630,"lineEnd":939,"totalLines":1022,"truncated":true}},"title":".opencode/bin/mk-code-index-launcher.cjs","time":{"start":1780906508872,"end":1780906508901}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad488191a5b134aa343e915b"}},"id":"prt_ea64cc245001drdODc6K7iqHuf","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
{"type":"tool_use","timestamp":1780906508903,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_q1lhliofCowD3cDXQe3AZeW8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","offset":390,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs</path>\n<type>file</type>\n<content>\n390:   const currentOwnerLeasePath = ownerLeasePath();\n391:   const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n392: \n393:   if (existing) {\n394:     const classification = classifyOwnerLease(existing);\n395:     if (classification === 'live-owner' || classification === 'unknown-eperm') {\n396:       return { acquired: false, holder: existing, classification };\n397:     }\n398:     log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n399:   }\n400: \n401:   const lease = buildOwnerLease(process.pid);\n402:   if (!existing) {\n403:     if (!writeOwnerLeaseFileExclusive(lease)) {\n404:       const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n405:       return {\n406:         acquired: false,\n407:         holder: holder || lease,\n408:         classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n409:       };\n410:     }\n411:     ownerLeasePid = process.pid;\n412:     return { acquired: true, lease, reclaimed: existing };\n413:   }\n414: \n415:   // The reclaim path is last-writer-wins (writeOwnerLeaseFile is an atomic\n416:   // tmp+rename). Re-read after the rename and confirm we are the surviving owner; if a\n417:   // concurrent launcher reclaimed the same stale lease, exactly one will see its own pid.\n418:   writeOwnerLeaseFile(lease);\n419:   const reread = readOwnerLeaseFile(currentOwnerLeasePath);\n420:   if (!reread || reread.ownerPid !== process.pid) {\n421:     return {\n422:       acquired: false,\n423:       holder: reread || lease,\n424:       classification: reread ? classifyOwnerLease(reread) : 'live-owner',\n425:     };\n426:   }\n427:   ownerLeasePid = process.pid;\n428:   return { acquired: true, lease, reclaimed: existing };\n429: }\n430: \n431: function refreshOwnerLeaseFile(ownerPid, patch = {}) {\n432:   const lease = readOwnerLeaseFile();\n433:   if (!lease || lease.ownerPid !== ownerPid) return false;\n434:   const nextOwnerPid = patch.ownerPid ?? ownerPid;\n435:   writeOwnerLeaseFile({\n436:     ...lease,\n437:     ...patch,\n438:     lastHeartbeatIso: new Date().toISOString(),\n439:   });\n440:   // Re-read after the atomic write; if a concurrent reclaim superseded us between\n441:   // the ownership check and the write, do not claim the refresh succeeded.\n442:   const reread = readOwnerLeaseFile();\n443:   if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n444:   ownerLeasePid = nextOwnerPid;\n445:   return true;\n446: }\n447: \n448: function clearOwnerLeaseFile() {\n449:   if (!Number.isInteger(ownerLeasePid)) return;\n450:   try {\n451:     // Re-confirm ownership immediately before unlink so a successor lease written\n452:     // after the first read is not deleted by path. A residual sub-syscall window remains; fully\n453:     // closing it would require the launcher to share owner-lease.ts's mutation lock.\n454:     const lease = readOwnerLeaseFile();\n455:     if (lease && lease.ownerPid === ownerLeasePid\n456:         && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n457:       fs.unlinkSync(ownerLeasePath());\n458:     }\n459:   } catch {\n460:     // Idempotent cleanup.\n461:   } finally {\n462:     ownerLeasePid = null;\n463:   }\n464: }\n465: \n466: function clearOwnerLeaseFileIfOwner(ownerPid) {\n467:   try {\n468:     // Re-confirm ownership immediately before unlink (see clearOwnerLeaseFile).\n469:     const lease = readOwnerLeaseFile();\n470:     if (lease && lease.ownerPid === ownerPid\n471:         && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n472:       fs.unlinkSync(ownerLeasePath());\n473:     }\n474:   } catch {\n475:     // Idempotent cleanup.\n476:   }\n477: }\n478: \n479: function pidLiveAt(filePath, pidField) {\n\n(Showing lines 390-479 of 1022. Use offset=480 to continue.)\n</content>","metadata":{"preview":"  const currentOwnerLeasePath = ownerLeasePath();\n  const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n\n  if (existing) {\n    const classification = classifyOwnerLease(existing);\n    if (classification === 'live-owner' || classification === 'unknown-eperm') {\n      return { acquired: false, holder: existing, classification };\n    }\n    log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n  }\n\n  const lease = buildOwnerLease(process.pid);\n  if (!existing) {\n    if (!writeOwnerLeaseFileExclusive(lease)) {\n      const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n      return {\n        acquired: false,\n        holder: holder || lease,\n        classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n      };","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","text":"  const currentOwnerLeasePath = ownerLeasePath();\n  const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n\n  if (existing) {\n    const classification = classifyOwnerLease(existing);\n    if (classification === 'live-owner' || classification === 'unknown-eperm') {\n      return { acquired: false, holder: existing, classification };\n    }\n    log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n  }\n\n  const lease = buildOwnerLease(process.pid);\n  if (!existing) {\n    if (!writeOwnerLeaseFileExclusive(lease)) {\n      const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n      return {\n        acquired: false,\n        holder: holder || lease,\n        classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n      };\n    }\n    ownerLeasePid = process.pid;\n    return { acquired: true, lease, reclaimed: existing };\n  }\n\n  // The reclaim path is last-writer-wins (writeOwnerLeaseFile is an atomic\n  // tmp+rename). Re-read after the rename and confirm we are the surviving owner; if a\n  // concurrent launcher reclaimed the same stale lease, exactly one will see its own pid.\n  writeOwnerLeaseFile(lease);\n  const reread = readOwnerLeaseFile(currentOwnerLeasePath);\n  if (!reread || reread.ownerPid !== process.pid) {\n    return {\n      acquired: false,\n      holder: reread || lease,\n      classification: reread ? classifyOwnerLease(reread) : 'live-owner',\n    };\n  }\n  ownerLeasePid = process.pid;\n  return { acquired: true, lease, reclaimed: existing };\n}\n\nfunction refreshOwnerLeaseFile(ownerPid, patch = {}) {\n  const lease = readOwnerLeaseFile();\n  if (!lease || lease.ownerPid !== ownerPid) return false;\n  const nextOwnerPid = patch.ownerPid ?? ownerPid;\n  writeOwnerLeaseFile({\n    ...lease,\n    ...patch,\n    lastHeartbeatIso: new Date().toISOString(),\n  });\n  // Re-read after the atomic write; if a concurrent reclaim superseded us between\n  // the ownership check and the write, do not claim the refresh succeeded.\n  const reread = readOwnerLeaseFile();\n  if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n  ownerLeasePid = nextOwnerPid;\n  return true;\n}\n\nfunction clearOwnerLeaseFile() {\n  if (!Number.isInteger(ownerLeasePid)) return;\n  try {\n    // Re-confirm ownership immediately before unlink so a successor lease written\n    // after the first read is not deleted by path. A residual sub-syscall window remains; fully\n    // closing it would require the launcher to share owner-lease.ts's mutation lock.\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerLeasePid\n        && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  } finally {\n    ownerLeasePid = null;\n  }\n}\n\nfunction clearOwnerLeaseFileIfOwner(ownerPid) {\n  try {\n    // Re-confirm ownership immediately before unlink (see clearOwnerLeaseFile).\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerPid\n        && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction pidLiveAt(filePath, pidField) {","lineStart":390,"lineEnd":479,"totalLines":1022,"truncated":true}},"title":".opencode/bin/mk-code-index-launcher.cjs","time":{"start":1780906508866,"end":1780906508902}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad408191b2a66813edd60ddf"}},"id":"prt_ea64cc2000017TKChiLx4r4pUU","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
{"type":"tool_use","timestamp":1780906508907,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_uw4g3dBfkqbwg3Hlj63Z3MdK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","offset":120,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts</path>\n<type>file</type>\n<content>\n120:     });\n121:   }\n122:   function notify(method: string, params: unknown): void {\n123:     try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n124:   }\n125:   return { request, notify };\n126: }\n127: \n128: async function startSession(\n129:   paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n130:   enabled: boolean,\n131: ): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n132:   const child = spawn(process.execPath, [paths.launcher], {\n133:     cwd: paths.base,\n134:     env: {\n135:       ...process.env,\n136:       SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n137:       SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n138:       SPEC_KIT_DB_DIR: paths.dbDir,\n139:       SPECKIT_LAUNCHER_LOG: '1',\n140:       AI_SESSION_CHILD: '1',\n141:     },\n142:     stdio: ['pipe', 'pipe', 'pipe'],\n143:   });\n144:   track(child.pid);\n145:   const client = makeClient(child);\n146:   const init = await client.request('initialize', {\n147:     protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n148:   }, 30_000);\n149:   if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n150:   client.notify('notifications/initialized', {});\n151:   return { child, client };\n152: }\n153: \n154: function leaseDaemonPid(base: string): number | null {\n155:   const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n156:   try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n157: }\n158: async function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n159:   try {\n160:     const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n161:     return !r.error;\n162:   } catch { return false; }\n163: }\n164: async function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n165:   const deadline = Date.now() + timeoutMs;\n166:   while (isAlive(pid) && Date.now() < deadline) await delay(50);\n167: }\n168: \n169: afterEach(async () => {\n170:   for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n171:   await delay(150);\n172:   // Sweep any detached daemon / embed sidecar that reparented to init.\n173:   for (const dir of tempDirs) {\n174:     for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n175:   }\n176:   await delay(150);\n177:   trackedPids.clear();\n178:   for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n179:   tempDirs.clear();\n180: });\n181: \n182: describe('daemon re-election: live two-session adoption', () => {\n183:   it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n184:     const paths = buildFakeRoot();\n185: \n186:     const owner = await startSession(paths, true);\n187:     expect(await statsOk(owner.client)).toBe(true);\n188:     const daemonPid = leaseDaemonPid(paths.base);\n189:     expect(daemonPid).toBeTypeOf('number');\n190:     track(daemonPid!);\n191:     expect(isAlive(daemonPid!)).toBe(true);\n192: \n193:     // Secondary joins while the owner holds the lease and the socket is live.\n194:     const secondary = await startSession(paths, true);\n195:     expect(await statsOk(secondary.client)).toBe(true);\n196:     // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n197:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n198: \n199:     // Dispose the owner.\n200:     owner.child.kill('SIGTERM');\n201:     await waitForExit(owner.child.pid!, 8_000);\n202:     expect(isAlive(owner.child.pid!)).toBe(false);\n203:     await delay(1_200);\n204: \n205:     // The released daemon outlives its owner and the secondary keeps transport.\n206:     expect(isAlive(daemonPid!)).toBe(true);\n207:     expect(await statsOk(secondary.client)).toBe(true);\n208:   });\n209: \n210:   it('flag ON: a FRESH session after owner disposal reaps the released daemon (single writer)', async () => {\n211:     const paths = buildFakeRoot();\n212: \n213:     const owner = await startSession(paths, true);\n214:     expect(await statsOk(owner.client)).toBe(true);\n215:     const orphanPid = leaseDaemonPid(paths.base);\n216:     expect(orphanPid).toBeTypeOf('number');\n217:     track(orphanPid!);\n218: \n219:     // Dispose the owner: the daemon is RELEASED (survives), not killed.\n220:     owner.child.kill('SIGTERM');\n221:     await waitForExit(owner.child.pid!, 8_000);\n222:     await delay(1_200);\n223:     expect(isAlive(orphanPid!)).toBe(true);\n224: \n225:     // A brand-new session starts AFTER disposal. Without the reap-before-respawn fix it\n226:     // reclaims the stale lease and spawns a SECOND daemon on the same DB (double writer);\n227:     // with the fix it reaps the orphan first, so exactly one daemon writes the DB.\n228:     const fresh = await startSession(paths, true);\n229:     expect(await statsOk(fresh.client)).toBe(true);\n230:     const newPid = leaseDaemonPid(paths.base);\n231:     expect(newPid).toBeTypeOf('number');\n232:     track(newPid!);\n233:     await delay(800);\n234: \n235:     // Single-writer invariant: the orphan is reaped and only the new daemon survives.\n236:     expect(isAlive(orphanPid!)).toBe(false);\n237:     expect(newPid).not.toBe(orphanPid);\n238:     expect(isAlive(newPid!)).toBe(true);\n239: \n240:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n241:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n242:     expect(dbWriters.length).toBe(1);\n243:   });\n244: \n245:   it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n246:     const paths = buildFakeRoot();\n247: \n248:     const owner = await startSession(paths, false);\n249:     expect(await statsOk(owner.client)).toBe(true);\n250:     const daemonPid = leaseDaemonPid(paths.base);\n251:     expect(daemonPid).toBeTypeOf('number');\n252:     track(daemonPid!);\n253:     expect(isAlive(daemonPid!)).toBe(true);\n254: \n255:     const secondary = await startSession(paths, false);\n256:     expect(await statsOk(secondary.client)).toBe(true);\n257:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n258: \n259:     owner.child.kill('SIGTERM');\n260:     await waitForExit(owner.child.pid!, 8_000);\n261:     expect(isAlive(owner.child.pid!)).toBe(false);\n262:     await delay(1_200);\n263: \n264:     // With the flag off, the daemon dies with its owner and the secondary's next\n265:     // call fails (no surviving daemon to serve it) within a short window.\n266:     expect(isAlive(daemonPid!)).toBe(false);\n267:     expect(await statsOk(secondary.client, 6_000)).toBe(false);\n268:   });\n269: });\n\n(End of file - total 269 lines)\n</content>","metadata":{"preview":"    });\n  }\n  function notify(method: string, params: unknown): void {\n    try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n  }\n  return { request, notify };\n}\n\nasync function startSession(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  enabled: boolean,\n): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","text":"    });\n  }\n  function notify(method: string, params: unknown): void {\n    try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n  }\n  return { request, notify };\n}\n\nasync function startSession(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  enabled: boolean,\n): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',\n      AI_SESSION_CHILD: '1',\n    },\n    stdio: ['pipe', 'pipe', 'pipe'],\n  });\n  track(child.pid);\n  const client = makeClient(child);\n  const init = await client.request('initialize', {\n    protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n  }, 30_000);\n  if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n  client.notify('notifications/initialized', {});\n  return { child, client };\n}\n\nfunction leaseDaemonPid(base: string): number | null {\n  const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n  try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n}\nasync function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n  try {\n    const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n    return !r.error;\n  } catch { return false; }\n}\nasync function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  while (isAlive(pid) && Date.now() < deadline) await delay(50);\n}\n\nafterEach(async () => {\n  for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  await delay(150);\n  // Sweep any detached daemon / embed sidecar that reparented to init.\n  for (const dir of tempDirs) {\n    for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  }\n  await delay(150);\n  trackedPids.clear();\n  for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n  tempDirs.clear();\n});\n\ndescribe('daemon re-election: live two-session adoption', () => {\n  it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    // Secondary joins while the owner holds the lease and the socket is live.\n    const secondary = await startSession(paths, true);\n    expect(await statsOk(secondary.client)).toBe(true);\n    // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    // Dispose the owner.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // The released daemon outlives its owner and the secondary keeps transport.\n    expect(isAlive(daemonPid!)).toBe(true);\n    expect(await statsOk(secondary.client)).toBe(true);\n  });\n\n  it('flag ON: a FRESH session after owner disposal reaps the released daemon (single writer)', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // A brand-new session starts AFTER disposal. Without the reap-before-respawn fix it\n    // reclaims the stale lease and spawns a SECOND daemon on the same DB (double writer);\n    // with the fix it reaps the orphan first, so exactly one daemon writes the DB.\n    const fresh = await startSession(paths, true);\n    expect(await statsOk(fresh.client)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n    await delay(800);\n\n    // Single-writer invariant: the orphan is reaped and only the new daemon survives.\n    expect(isAlive(orphanPid!)).toBe(false);\n    expect(newPid).not.toBe(orphanPid);\n    expect(isAlive(newPid!)).toBe(true);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  });\n\n  it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, false);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    const secondary = await startSession(paths, false);\n    expect(await statsOk(secondary.client)).toBe(true);\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // With the flag off, the daemon dies with its owner and the secondary's next\n    // call fails (no surviving daemon to serve it) within a short window.\n    expect(isAlive(daemonPid!)).toBe(false);\n    expect(await statsOk(secondary.client, 6_000)).toBe(false);\n  });\n});","lineStart":120,"lineEnd":269,"totalLines":269,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","time":{"start":1780906508876,"end":1780906508904}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad688191ab518bb81ec3831e"}},"id":"prt_ea64cc249001mZpKzzH9j4fv1h","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
{"type":"tool_use","timestamp":1780906508907,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_d1MNm1gBFINOwCcHgEYN5eAx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // DURABILITY: daemon re-election RELEASE-vs-KILL (real OS-level integration)\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // Validates the OS-level contract the re-election feature depends on: with the\n6: // flag ON, when the OWNER disposes (SIGTERM) it RELEASES the detached daemon\n7: // (leaves it alive for a secondary to adopt); with the flag OFF it KILLS the\n8: // daemon. It uses the REAL exported production decision functions from the\n9: // launcher — contextServerSpawnIo() and shouldReleaseDaemonForReelection() —\n10: // driving a real detached child and real SIGTERM/reparent semantics.\n11: //\n12: // SAFETY: this never imports config, never opens any sqlite, and never reads\n13: // or writes a lease file or the IPC socket. The launcher's lease/socket dir is\n14: // hardcoded relative to its own script location with no env override, so spawning\n15: // the real repo launcher would bridge to (or clobber) the LIVE owner. Instead a\n16: // throwaway \"owner\" harness in an OS temp dir spawns a trivial sleeper \"daemon\"\n17: // stand-in using the real spawn-io the feature produces. Only processes this test\n18: // starts are signalled, tracked by pid, and force-reaped in teardown.\n19: \n20: import { spawn, type ChildProcess } from 'node:child_process';\n21: import { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\n22: import { createRequire } from 'node:module';\n23: import { tmpdir } from 'node:os';\n24: import { dirname, join, resolve } from 'node:path';\n25: import { fileURLToPath } from 'node:url';\n26: \n27: import { afterAll, afterEach, beforeAll, describe, expect, it } from 'vitest';\n28: \n29: const require = createRequire(import.meta.url);\n30: // stress_test/durability/<file> -> repo root is six levels up.\n31: const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\n32: const launcherPath = join(repoRoot, '.opencode/bin/mk-spec-memory-launcher.cjs');\n33: \n34: // The real production primitives under test. require() is side-effect-free here:\n35: // the launcher only runs main() under `require.main === module`, never on import.\n36: const launcher = require(launcherPath) as {\n37:   daemonReelectionEnabled: (env?: Record<string, string | undefined>) => boolean;\n38:   contextServerSpawnIo: (enabled: boolean) => { detached: boolean; stdio: [string, string, string] };\n39:   shouldReleaseDaemonForReelection: (a?: { enabled?: boolean; hasLiveDaemon?: boolean }) => boolean;\n40: };\n41: \n42: // A throwaway owner harness. It requires the REAL launcher, computes spawn-io and\n43: // the release-vs-kill decision from the production functions, spawns a trivial\n44: // long-lived \"daemon\" (a sleeper), prints its pid, and stays alive until SIGTERM.\n45: // On SIGTERM it applies the real decision: release (don't kill) or kill.\n46: const OWNER_HARNESS = String.raw`\n47: 'use strict';\n48: const { spawn } = require('node:child_process');\n49: const launcher = require(process.env.LAUNCHER_PATH);\n50: \n51: const enabled = launcher.daemonReelectionEnabled(process.env);\n52: const io = launcher.contextServerSpawnIo(enabled);\n53: \n54: // Trivial daemon stand-in: a sleeper that keeps its own event loop alive.\n55: const daemon = spawn(process.execPath, ['-e', 'setInterval(() => {}, 2147483647)'], {\n56:   detached: io.detached,\n57:   stdio: io.stdio,\n58: });\n59: // Re-election only: don't keep the detached daemon tethered to the owner (mirrors the launcher's unref()).\n60: if (enabled) daemon.unref();\n61: \n62: // Keep the owner alive and \"owning\" until it is disposed, independent of the daemon ref.\n63: const keepAlive = setInterval(() => {}, 2147483647);\n64: \n65: let shuttingDown = false;\n66: function shutdown() {\n67:   if (shuttingDown) return;\n68:   shuttingDown = true;\n69:   clearInterval(keepAlive);\n70:   const hasLiveDaemon = daemon.exitCode === null && daemon.signalCode === null && typeof daemon.pid === 'number';\n71:   if (launcher.shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon })) {\n72:     // RELEASE: leave the detached daemon alive for a secondary to adopt; just exit.\n73:     process.stdout.write('RELEASED\\n', () => process.exit(0));\n74:   } else {\n75:     // KILL: tear the daemon down, matching the non-reelection shutdown path.\n76:     try { daemon.kill('SIGTERM'); } catch (_) {}\n77:     process.stdout.write('KILLED\\n', () => process.exit(0));\n78:   }\n79: }\n80: for (const s of ['SIGTERM', 'SIGINT']) process.on(s, shutdown);\n81: \n82: // Announce readiness only once the daemon is live and handlers are installed.\n83: process.stdout.write('DAEMON_PID:' + daemon.pid + '\\n');\n84: `;\n85: \n86: const BOOT_TIMEOUT_MS = 15_000;\n87: const DEATH_TIMEOUT_MS = 8_000;\n88: const SURVIVAL_CONFIRM_MS = 2_000;\n89: \n90: let workDir: string;\n91: let harnessPath: string;\n92: const trackedPids = new Set<number>();\n93: \n94: function track(pid: number | undefined): void {\n95:   if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n96: }\n97: \n98: function isAlive(pid: number): boolean {\n99:   try {\n100:     process.kill(pid, 0);\n101:     return true;\n102:   } catch (err) {\n103:     // EPERM = the process exists but we may not signal it -> still alive.\n104:     return (err as NodeJS.ErrnoException).code === 'EPERM';\n105:   }\n106: }\n107: \n108: function delay(ms: number): Promise<void> {\n109:   return new Promise((r) => setTimeout(r, ms));\n110: }\n111: \n112: async function waitForDeath(pid: number, timeoutMs: number): Promise<boolean> {\n113:   const deadline = Date.now() + timeoutMs;\n114:   while (Date.now() < deadline) {\n115:     if (!isAlive(pid)) return true;\n116:     await delay(50);\n117:   }\n118:   return !isAlive(pid);\n119: }\n120: \n121: function waitForOwnerExit(owner: ChildProcess, timeoutMs: number): Promise<void> {\n122:   return new Promise((resolveExit, rejectExit) => {\n123:     if (owner.exitCode !== null || owner.signalCode !== null) return resolveExit();\n124:     const timer = setTimeout(() => rejectExit(new Error('owner did not exit in time')), timeoutMs);\n125:     owner.once('exit', () => {\n126:       clearTimeout(timer);\n127:       resolveExit();\n128:     });\n129:   });\n130: }\n131: \n132: // Spawn the owner harness and resolve with { owner, daemonPid } once it prints DAEMON_PID.\n133: function spawnOwner(enabled: boolean): Promise<{ owner: ChildProcess; daemonPid: number }> {\n134:   const owner = spawn(process.execPath, [harnessPath], {\n135:     cwd: workDir,\n136:     env: {\n137:       ...process.env,\n138:       LAUNCHER_PATH: launcherPath,\n139:       SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n140:     },\n141:     stdio: ['ignore', 'pipe', 'pipe'],\n142:   });\n143:   track(owner.pid);\n144: \n145:   return new Promise((resolveSpawn, rejectSpawn) => {\n146:     let stdout = '';\n147:     let stderr = '';\n148:     const timer = setTimeout(() => {\n149:       rejectSpawn(new Error(`owner never reported DAEMON_PID in ${BOOT_TIMEOUT_MS}ms; stderr: ${stderr}`));\n150:     }, BOOT_TIMEOUT_MS);\n151: \n152:     owner.stdout!.setEncoding('utf8');\n153:     owner.stderr!.setEncoding('utf8');\n154:     owner.stderr!.on('data', (chunk) => { stderr += chunk; });\n155:     owner.stdout!.on('data', (chunk) => {\n156:       stdout += chunk;\n157:       const m = stdout.match(/DAEMON_PID:(\\d+)/);\n158:       if (m) {\n159:         clearTimeout(timer);\n160:         const daemonPid = Number(m[1]);\n161:         track(daemonPid);\n162:         resolveSpawn({ owner, daemonPid });\n163:       }\n164:     });\n165:     owner.once('error', (err) => { clearTimeout(timer); rejectSpawn(err); });\n166:   });\n167: }\n168: \n169: beforeAll(() => {\n170:   workDir = mkdtempSync(join(tmpdir(), 'speckit-reelect-'));\n171:   harnessPath = join(workDir, 'owner-harness.cjs');\n172:   writeFileSync(harnessPath, OWNER_HARNESS, 'utf8');\n173: });\n174: \n175: afterEach(async () => {\n176:   // Force-reap ONLY processes this test started (owner + daemon stand-in). The\n177:   // detached flag-ON daemon has reparented to init, so SIGKILL by pid is required.\n178:   for (const pid of trackedPids) {\n179:     try { process.kill(pid, 'SIGKILL'); } catch (_) { /* already gone */ }\n180:   }\n181:   // Give the OS a moment to release the reaped pids before the next case.\n182:   await delay(100);\n183:   trackedPids.clear();\n184: });\n185: \n186: afterAll(() => {\n187:   rmSync(workDir, { recursive: true, force: true });\n188: });\n189: \n190: describe('daemon re-election: real release-vs-kill integration', () => {\n191:   it('uses the real exported production primitives (not a mock)', () => {\n192:     expect(typeof launcher.contextServerSpawnIo).toBe('function');\n193:     expect(typeof launcher.shouldReleaseDaemonForReelection).toBe('function');\n194:     expect(launcher.daemonReelectionEnabled({ SPECKIT_DAEMON_REELECTION: '1' })).toBe(true);\n195:     expect(launcher.contextServerSpawnIo(true)).toEqual({ detached: true, stdio: ['ignore', 'ignore', 'ignore'] });\n196:     expect(launcher.contextServerSpawnIo(false)).toEqual({ detached: false, stdio: ['ignore', 'ignore', 'inherit'] });\n197:   });\n198: \n199:   it('flag ON: owner SIGTERM RELEASES the detached daemon (it survives)', async () => {\n200:     const { owner, daemonPid } = await spawnOwner(true);\n201:     expect(isAlive(daemonPid)).toBe(true);\n202: \n203:     owner.kill('SIGTERM');\n204:     await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n205: \n206:     // The released daemon must outlive its owner. Confirm it stays alive across a window.\n207:     await delay(SURVIVAL_CONFIRM_MS);\n208:     expect(isAlive(daemonPid)).toBe(true);\n209:     expect(isAlive(owner.pid!)).toBe(false);\n210:   });\n211: \n212:   it('flag OFF: owner SIGTERM KILLS the daemon (it dies)', async () => {\n213:     const { owner, daemonPid } = await spawnOwner(false);\n214:     expect(isAlive(daemonPid)).toBe(true);\n215: \n216:     owner.kill('SIGTERM');\n217:     await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n218: \n219:     const died = await waitForDeath(daemonPid, DEATH_TIMEOUT_MS);\n220:     expect(died).toBe(true);\n221:     expect(isAlive(owner.pid!)).toBe(false);\n222:   });\n223: });\n\n(End of file - total 223 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election RELEASE-vs-KILL (real OS-level integration)\n// ───────────────────────────────────────────────────────────────\n//\n// Validates the OS-level contract the re-election feature depends on: with the\n// flag ON, when the OWNER disposes (SIGTERM) it RELEASES the detached daemon\n// (leaves it alive for a secondary to adopt); with the flag OFF it KILLS the\n// daemon. It uses the REAL exported production decision functions from the\n// launcher — contextServerSpawnIo() and shouldReleaseDaemonForReelection() —\n// driving a real detached child and real SIGTERM/reparent semantics.\n//\n// SAFETY: this never imports config, never opens any sqlite, and never reads\n// or writes a lease file or the IPC socket. The launcher's lease/socket dir is\n// hardcoded relative to its own script location with no env override, so spawning\n// the real repo launcher would bridge to (or clobber) the LIVE owner. Instead a\n// throwaway \"owner\" harness in an OS temp dir spawns a trivial sleeper \"daemon\"\n// stand-in using the real spawn-io the feature produces. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, type ChildProcess } from 'node:child_process';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election RELEASE-vs-KILL (real OS-level integration)\n// ───────────────────────────────────────────────────────────────\n//\n// Validates the OS-level contract the re-election feature depends on: with the\n// flag ON, when the OWNER disposes (SIGTERM) it RELEASES the detached daemon\n// (leaves it alive for a secondary to adopt); with the flag OFF it KILLS the\n// daemon. It uses the REAL exported production decision functions from the\n// launcher — contextServerSpawnIo() and shouldReleaseDaemonForReelection() —\n// driving a real detached child and real SIGTERM/reparent semantics.\n//\n// SAFETY: this never imports config, never opens any sqlite, and never reads\n// or writes a lease file or the IPC socket. The launcher's lease/socket dir is\n// hardcoded relative to its own script location with no env override, so spawning\n// the real repo launcher would bridge to (or clobber) the LIVE owner. Instead a\n// throwaway \"owner\" harness in an OS temp dir spawns a trivial sleeper \"daemon\"\n// stand-in using the real spawn-io the feature produces. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, type ChildProcess } from 'node:child_process';\nimport { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\nimport { createRequire } from 'node:module';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { afterAll, afterEach, beforeAll, describe, expect, it } from 'vitest';\n\nconst require = createRequire(import.meta.url);\n// stress_test/durability/<file> -> repo root is six levels up.\nconst repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\nconst launcherPath = join(repoRoot, '.opencode/bin/mk-spec-memory-launcher.cjs');\n\n// The real production primitives under test. require() is side-effect-free here:\n// the launcher only runs main() under `require.main === module`, never on import.\nconst launcher = require(launcherPath) as {\n  daemonReelectionEnabled: (env?: Record<string, string | undefined>) => boolean;\n  contextServerSpawnIo: (enabled: boolean) => { detached: boolean; stdio: [string, string, string] };\n  shouldReleaseDaemonForReelection: (a?: { enabled?: boolean; hasLiveDaemon?: boolean }) => boolean;\n};\n\n// A throwaway owner harness. It requires the REAL launcher, computes spawn-io and\n// the release-vs-kill decision from the production functions, spawns a trivial\n// long-lived \"daemon\" (a sleeper), prints its pid, and stays alive until SIGTERM.\n// On SIGTERM it applies the real decision: release (don't kill) or kill.\nconst OWNER_HARNESS = String.raw`\n'use strict';\nconst { spawn } = require('node:child_process');\nconst launcher = require(process.env.LAUNCHER_PATH);\n\nconst enabled = launcher.daemonReelectionEnabled(process.env);\nconst io = launcher.contextServerSpawnIo(enabled);\n\n// Trivial daemon stand-in: a sleeper that keeps its own event loop alive.\nconst daemon = spawn(process.execPath, ['-e', 'setInterval(() => {}, 2147483647)'], {\n  detached: io.detached,\n  stdio: io.stdio,\n});\n// Re-election only: don't keep the detached daemon tethered to the owner (mirrors the launcher's unref()).\nif (enabled) daemon.unref();\n\n// Keep the owner alive and \"owning\" until it is disposed, independent of the daemon ref.\nconst keepAlive = setInterval(() => {}, 2147483647);\n\nlet shuttingDown = false;\nfunction shutdown() {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  clearInterval(keepAlive);\n  const hasLiveDaemon = daemon.exitCode === null && daemon.signalCode === null && typeof daemon.pid === 'number';\n  if (launcher.shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon })) {\n    // RELEASE: leave the detached daemon alive for a secondary to adopt; just exit.\n    process.stdout.write('RELEASED\\n', () => process.exit(0));\n  } else {\n    // KILL: tear the daemon down, matching the non-reelection shutdown path.\n    try { daemon.kill('SIGTERM'); } catch (_) {}\n    process.stdout.write('KILLED\\n', () => process.exit(0));\n  }\n}\nfor (const s of ['SIGTERM', 'SIGINT']) process.on(s, shutdown);\n\n// Announce readiness only once the daemon is live and handlers are installed.\nprocess.stdout.write('DAEMON_PID:' + daemon.pid + '\\n');\n`;\n\nconst BOOT_TIMEOUT_MS = 15_000;\nconst DEATH_TIMEOUT_MS = 8_000;\nconst SURVIVAL_CONFIRM_MS = 2_000;\n\nlet workDir: string;\nlet harnessPath: string;\nconst trackedPids = new Set<number>();\n\nfunction track(pid: number | undefined): void {\n  if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n}\n\nfunction isAlive(pid: number): boolean {\n  try {\n    process.kill(pid, 0);\n    return true;\n  } catch (err) {\n    // EPERM = the process exists but we may not signal it -> still alive.\n    return (err as NodeJS.ErrnoException).code === 'EPERM';\n  }\n}\n\nfunction delay(ms: number): Promise<void> {\n  return new Promise((r) => setTimeout(r, ms));\n}\n\nasync function waitForDeath(pid: number, timeoutMs: number): Promise<boolean> {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() < deadline) {\n    if (!isAlive(pid)) return true;\n    await delay(50);\n  }\n  return !isAlive(pid);\n}\n\nfunction waitForOwnerExit(owner: ChildProcess, timeoutMs: number): Promise<void> {\n  return new Promise((resolveExit, rejectExit) => {\n    if (owner.exitCode !== null || owner.signalCode !== null) return resolveExit();\n    const timer = setTimeout(() => rejectExit(new Error('owner did not exit in time')), timeoutMs);\n    owner.once('exit', () => {\n      clearTimeout(timer);\n      resolveExit();\n    });\n  });\n}\n\n// Spawn the owner harness and resolve with { owner, daemonPid } once it prints DAEMON_PID.\nfunction spawnOwner(enabled: boolean): Promise<{ owner: ChildProcess; daemonPid: number }> {\n  const owner = spawn(process.execPath, [harnessPath], {\n    cwd: workDir,\n    env: {\n      ...process.env,\n      LAUNCHER_PATH: launcherPath,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n    },\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n  track(owner.pid);\n\n  return new Promise((resolveSpawn, rejectSpawn) => {\n    let stdout = '';\n    let stderr = '';\n    const timer = setTimeout(() => {\n      rejectSpawn(new Error(`owner never reported DAEMON_PID in ${BOOT_TIMEOUT_MS}ms; stderr: ${stderr}`));\n    }, BOOT_TIMEOUT_MS);\n\n    owner.stdout!.setEncoding('utf8');\n    owner.stderr!.setEncoding('utf8');\n    owner.stderr!.on('data', (chunk) => { stderr += chunk; });\n    owner.stdout!.on('data', (chunk) => {\n      stdout += chunk;\n      const m = stdout.match(/DAEMON_PID:(\\d+)/);\n      if (m) {\n        clearTimeout(timer);\n        const daemonPid = Number(m[1]);\n        track(daemonPid);\n        resolveSpawn({ owner, daemonPid });\n      }\n    });\n    owner.once('error', (err) => { clearTimeout(timer); rejectSpawn(err); });\n  });\n}\n\nbeforeAll(() => {\n  workDir = mkdtempSync(join(tmpdir(), 'speckit-reelect-'));\n  harnessPath = join(workDir, 'owner-harness.cjs');\n  writeFileSync(harnessPath, OWNER_HARNESS, 'utf8');\n});\n\nafterEach(async () => {\n  // Force-reap ONLY processes this test started (owner + daemon stand-in). The\n  // detached flag-ON daemon has reparented to init, so SIGKILL by pid is required.\n  for (const pid of trackedPids) {\n    try { process.kill(pid, 'SIGKILL'); } catch (_) { /* already gone */ }\n  }\n  // Give the OS a moment to release the reaped pids before the next case.\n  await delay(100);\n  trackedPids.clear();\n});\n\nafterAll(() => {\n  rmSync(workDir, { recursive: true, force: true });\n});\n\ndescribe('daemon re-election: real release-vs-kill integration', () => {\n  it('uses the real exported production primitives (not a mock)', () => {\n    expect(typeof launcher.contextServerSpawnIo).toBe('function');\n    expect(typeof launcher.shouldReleaseDaemonForReelection).toBe('function');\n    expect(launcher.daemonReelectionEnabled({ SPECKIT_DAEMON_REELECTION: '1' })).toBe(true);\n    expect(launcher.contextServerSpawnIo(true)).toEqual({ detached: true, stdio: ['ignore', 'ignore', 'ignore'] });\n    expect(launcher.contextServerSpawnIo(false)).toEqual({ detached: false, stdio: ['ignore', 'ignore', 'inherit'] });\n  });\n\n  it('flag ON: owner SIGTERM RELEASES the detached daemon (it survives)', async () => {\n    const { owner, daemonPid } = await spawnOwner(true);\n    expect(isAlive(daemonPid)).toBe(true);\n\n    owner.kill('SIGTERM');\n    await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n\n    // The released daemon must outlive its owner. Confirm it stays alive across a window.\n    await delay(SURVIVAL_CONFIRM_MS);\n    expect(isAlive(daemonPid)).toBe(true);\n    expect(isAlive(owner.pid!)).toBe(false);\n  });\n\n  it('flag OFF: owner SIGTERM KILLS the daemon (it dies)', async () => {\n    const { owner, daemonPid } = await spawnOwner(false);\n    expect(isAlive(daemonPid)).toBe(true);\n\n    owner.kill('SIGTERM');\n    await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n\n    const died = await waitForDeath(daemonPid, DEATH_TIMEOUT_MS);\n    expect(died).toBe(true);\n    expect(isAlive(owner.pid!)).toBe(false);\n  });\n});","lineStart":1,"lineEnd":223,"totalLines":223,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts","time":{"start":1780906508879,"end":1780906508905}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad6c81919f00e7183bcf12c2"}},"id":"prt_ea64cc24d001RkAqM6R7Re43EF","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
