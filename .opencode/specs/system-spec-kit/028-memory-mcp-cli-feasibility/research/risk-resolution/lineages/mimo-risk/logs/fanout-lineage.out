ystem-spec-kit/mcp_server/hooks/claude/hook-state.ts:\n  Line 340:     mkdirSync(getStateDir(), { recursive: true, mode: 0o700 });\n\n  Line 438:       mode: 0o600,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/heap-profiler.vitest.ts:\n  Line 91:       expect(dirMode).toBe(0o700);\n\n  Line 92:       expect(fileMode).toBe(0o600);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/db-shard-migration.ts:\n  Line 225:   fs.mkdirSync(path.dirname(canonicalPath), { recursive: true, mode: 0o700 });\n\n  Line 226:   fs.mkdirSync(path.dirname(shardPath), { recursive: true, mode: 0o700 });\n\n  Line 288:   fs.mkdirSync(migrationDir, { recursive: true, mode: 0o700 });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/telemetry/heap-profiler.ts:\n  Line 5: import { chmodSync, mkdirSync } from 'node:fs';\n\n  Line 103:   mkdirSync(resolvedDir, { recursive: true, mode: 0o700 });\n\n  Line 104:   chmodSync(resolvedDir, 0o700);\n\n  Line 110:   chmodSync(writtenPath, 0o600);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/codex/pre-tool-use.ts:\n  Line 78:   'chmod -R 777 /',\n","metadata":{"matches":57,"truncated":false},"title":"chmod|0o600|0o700|socket.*perm|SOCKET_FILE_NAME","time":{"start":1780741862100,"end":1780741862127}},"id":"prt_e9c7c72d2001yLxzKHM0RS6BIx","sessionID":"ses_16384c52effeHJzY2mg4EmA5Ud","messageID":"msg_e9c7c60a0001tF1OP5w8BcNkXk"}}
