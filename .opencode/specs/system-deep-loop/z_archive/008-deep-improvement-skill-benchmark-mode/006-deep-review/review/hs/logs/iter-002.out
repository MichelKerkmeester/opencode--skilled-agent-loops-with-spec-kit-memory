{"type":"text","timestamp":1780204645609,"sessionID":"ses_1838ab765ffeDkoguY5zw44Q55","part":{"id":"prt_e7c772b14001wyexfdvHfE6gxR","messageID":"msg_e7c7589b0001whz815q3I42FxV","sessionID":"ses_1838ab765ffeDkoguY5zw44Q55","type":"text","text":"Now let me check the d5-connectivity file for completeness, and look at how run-skill-benchmark handles certain edge cases:\n","time":{"start":1780204645140,"end":1780204645603}}}
{"type":"tool_use","timestamp":1780204645879,"sessionID":"ses_1838ab765ffeDkoguY5zw44Q55","part":{"type":"tool","tool":"read","callID":"call_function_ovxfdap8a93m_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d5-connectivity.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d5-connectivity.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * d5-connectivity.cjs — static structural scan, the D5 hard gate.\n6:  *\n7:  * Runs BEFORE any dispatch and caps the verdict regardless of weighted score.\n8:  * Catches the failure class that makes a skill structurally unusable: a\n9:  * RESOURCE_MAP path that does not exist (dead route), a RESOURCE_MAP key absent\n10:  * from INTENT_SIGNALS (dead intent key), a routed path escaping the skill root,\n11:  * and references present on disk but never reachable from any RESOURCE_MAP entry\n12:  * (orphans — reported, not gated). A router that cannot be parsed at all is the\n13:  * strongest gate failure.\n14:  */\n15: \n16: const fs = require('fs');\n17: const path = require('path');\n18: const { parseRouter } = require('./router-replay.cjs');\n19: \n20: function listMarkdownRefs(skillRoot) {\n21:   const out = [];\n22:   for (const dir of ['references', 'assets']) {\n23:     const base = path.join(skillRoot, dir);\n24:     if (!fs.existsSync(base)) continue;\n25:     const stack = [base];\n26:     while (stack.length) {\n27:       const cur = stack.pop();\n28:       for (const entry of fs.readdirSync(cur, { withFileTypes: true })) {\n29:         const full = path.join(cur, entry.name);\n30:         if (entry.isDirectory()) stack.push(full);\n31:         else if (entry.isFile() && /\\.md$/.test(entry.name)) out.push(path.relative(skillRoot, full));\n32:       }\n33:     }\n34:   }\n35:   return out;\n36: }\n37: \n38: /**\n39:  * @returns {{ score:number, gateFailed:boolean, findings:Array,\n40:  *   deadResourcePaths:string[], deadIntentKeys:string[], orphanReferences:string[],\n41:  *   pathEscapes:string[], routerParseable:boolean }}\n42:  */\n43: function scanConnectivity({ skillRoot }) {\n44:   const findings = [];\n45:   const skillMdPath = path.join(skillRoot, 'SKILL.md');\n46:   if (!fs.existsSync(skillMdPath)) {\n47:     return {\n48:       score: 0, gateFailed: true, routerParseable: false,\n49:       deadResourcePaths: [], deadIntentKeys: [], orphanReferences: [], pathEscapes: [],\n50:       findings: [{ class: 'missing_skill_md', severity: 'P0', detail: 'SKILL.md not found' }],\n51:     };\n52:   }\n53:   const router = parseRouter(fs.readFileSync(skillMdPath, 'utf8'));\n54:   const intentKeys = new Set(Object.keys(router.intentSignals));\n55:   const deadResourcePaths = [];\n56:   const deadIntentKeys = [];\n57:   const pathEscapes = [];\n58:   const routedRefs = new Set();\n59: \n60:   for (const [intent, resources] of Object.entries(router.resourceMap)) {\n61:     if (!intentKeys.has(intent)) {\n62:       deadIntentKeys.push(intent);\n63:       findings.push({ class: 'dead_intent_key', severity: 'P1', locus: `RESOURCE_MAP.${intent}`, detail: `${intent} has no INTENT_SIGNALS entry` });\n64:     }\n65:     for (const r of resources) {\n66:       routedRefs.add(r);\n67:       const resolved = path.resolve(skillRoot, r);\n68:       if (!resolved.startsWith(path.resolve(skillRoot))) {\n69:         pathEscapes.push(r);\n70:         findings.push({ class: 'path_escape', severity: 'P0', locus: r, detail: `${r} resolves outside skill root` });\n71:       } else if (!fs.existsSync(resolved)) {\n72:         deadResourcePaths.push(r);\n73:         findings.push({ class: 'dead_resource_path', severity: 'P0', locus: r, detail: `routed path ${r} does not exist` });\n74:       }\n75:     }\n76:   }\n77: \n78:   const orphanReferences = listMarkdownRefs(skillRoot).filter((ref) => !routedRefs.has(ref));\n79:   for (const orphan of orphanReferences) {\n80:     findings.push({ class: 'orphan_reference', severity: 'P2', locus: orphan, detail: `${orphan} is not reachable from any RESOURCE_MAP intent` });\n81:   }\n82: \n83:   // Hard gate: any P0 (dead path / escape / unparseable). Dead intent keys (P1)\n84:   // and orphans (P2) lower the score but do not gate by themselves.\n85:   const p0 = findings.filter((f) => f.severity === 'P0').length;\n86:   const gateFailed = p0 > 0 || !router.parseable;\n87:   if (!router.parseable) {\n88:     findings.push({ class: 'router_unparseable', severity: 'P0', detail: 'INTENT_SIGNALS / RESOURCE_MAP could not be parsed from SKILL.md' });\n89:   }\n90:   // Score: start at 100, subtract per finding by severity, floor 0.\n91:   const penalty = findings.reduce((acc, f) => acc + ({ P0: 40, P1: 12, P2: 3 }[f.severity] || 0), 0);\n92:   const score = Math.max(0, 100 - penalty);\n93: \n94:   return { score, gateFailed, routerParseable: router.parseable, deadResourcePaths, deadIntentKeys, orphanReferences, pathEscapes, findings };\n95: }\n96: \n97: module.exports = { scanConnectivity, listMarkdownRefs };\n98: \n99: if (require.main === module) {\n100:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n101:   if (!args.skill) {\n102:     process.stderr.write('usage: d5-connectivity.cjs --skill <skill-root>\\n');\n103:     process.exit(2);\n104:   }\n105:   const res = scanConnectivity({ skillRoot: args.skill });\n106:   process.stdout.write(JSON.stringify(res, null, 2) + '\\n');\n107:   process.exit(res.gateFailed ? 1 : 0);\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * d5-connectivity.cjs — static structural scan, the D5 hard gate.\n *\n * Runs BEFORE any dispatch and caps the verdict regardless of weighted score.\n * Catches the failure class that makes a skill structurally unusable: a\n * RESOURCE_MAP path that does not exist (dead route), a RESOURCE_MAP key absent\n * from INTENT_SIGNALS (dead intent key), a routed path escaping the skill root,\n * and references present on disk but never reachable from any RESOURCE_MAP entry\n * (orphans — reported, not gated). A router that cannot be parsed at all is the\n * strongest gate failure.\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst { parseRouter } = require('./router-replay.cjs');\n\nfunction listMarkdownRefs(skillRoot) {","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/d5-connectivity.cjs","time":{"start":1780204645860,"end":1780204645878}},"id":"prt_e7c772ce6001Jk2FykePM4yv4u","sessionID":"ses_1838ab765ffeDkoguY5zw44Q55","messageID":"msg_e7c7589b0001whz815q3I42FxV"}}
