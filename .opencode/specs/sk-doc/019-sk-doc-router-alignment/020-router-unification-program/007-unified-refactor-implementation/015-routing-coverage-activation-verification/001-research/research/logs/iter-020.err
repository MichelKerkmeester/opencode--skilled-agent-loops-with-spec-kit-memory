   225	]);
   226	
   227	function classifySkillAdvisorFrame(frame) {
   228	  const proxyModule = loadSessionProxyModule();
   229	  if (!proxyModule || typeof proxyModule.createClassifyFrame !== 'function') return false;
   230	  if (!skillAdvisorFrameClassifier) {
   231	    skillAdvisorFrameClassifier = proxyModule.createClassifyFrame({
   232	      replayableToolNames: SKILL_ADVISOR_REPLAYABLE_TOOL_NAMES,
   233	      unsafeToolNames: SKILL_ADVISOR_UNSAFE_TOOL_NAMES,
   234	    });
   235	  }
   236	  return skillAdvisorFrameClassifier(frame);
   237	}
