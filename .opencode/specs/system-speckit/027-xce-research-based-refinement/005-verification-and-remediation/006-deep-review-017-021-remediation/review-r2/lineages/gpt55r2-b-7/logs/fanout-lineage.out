nhanced_search,\n124:   cachedSearch,\n125:   clearSearchCache,\n126:   learnFromSelection,\n127:   linkRelatedOnSave,\n128:   recordAccess,\n129:   enhancedSearch,\n130:   getCacheKey,\n131: } from './vector-index-aliases.js';\n132: \n133: // Re-export store items that aren't re-exported by other modules\n134: export {\n135:   initializeDb,\n136:   initialize_db,\n137:   checkpointAllWal,\n138:   closeDb,\n139:   close_db,\n140:   getDb,\n\n(Showing lines 1-140 of 178. Use offset=141 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,\n  IndexMemoryParams,\n  UpdateMemoryParams,\n  VectorSearchOptions,\n  EnrichedSearchResult,\n} from './vector-index-types.js';\nexport {\n  SCHEMA_VERSION,\n  run_migrations,\n  ensure_schema_version,\n  migrate_confidence_columns,\n  ensure_canonical_file_path_support,\n  migrate_constitutional_tier,\n  create_common_indexes,\n  ensureCompanionTables,\n  create_schema,\n  ensureSchemaVersion,\n  runMigrations,\n  createSchema,\n  createCommonIndexes,\n  migrateConfidenceColumns,\n  ensureCanonicalFilePathSupport,\n  migrateConstitutionalTier,\n} from './vector-index-schema.js';\nexport {\n  index_memory,\n  index_memory_deferred,\n  update_memory,\n  delete_memory,\n  delete_memory_by_path,\n  delete_memories,\n  update_embedding_status,\n  update_confidence,\n  indexMemory,\n  indexMemoryDeferred,\n  updateMemory,\n  deleteMemory,\n  deleteMemoryByPath,\n  deleteMemories,\n  updateEmbeddingStatus,\n  updateConfidence,\n} from './vector-index-mutations.js';\nexport {\n  get_memory,\n  get_memories_by_folder,\n  get_memory_count,\n  get_status_counts,\n  get_stats,\n  vector_search,\n  get_constitutional_memories_public,\n  multi_concept_search,\n  extract_title,\n  extract_snippet,\n  extract_tags,\n  extract_date,\n  generate_query_embedding,\n  keyword_search,\n  vector_search_enriched,\n  multi_concept_search_enriched,\n  multi_concept_keyword_search,\n  parse_quoted_terms,\n  apply_smart_ranking,\n  apply_diversity,\n  get_related_memories,\n  get_usage_stats,\n  find_cleanup_candidates,\n  get_memory_preview,\n  verify_integrity,\n  getMemory,\n  getMemoriesByFolder,\n  getMemoryCount,\n  getStatusCounts,\n  getStats,\n  vectorSearch,\n  getConstitutionalMemories,\n  multiConceptSearch,\n  extractTitle,\n  extractSnippet,\n  extractTags,\n  extractDate,\n  generateQueryEmbedding,\n  keywordSearch,\n  vectorSearchEnriched,\n  multiConceptSearchEnriched,\n  multiConceptKeywordSearch,\n  parseQuotedTerms,\n  applySmartRanking,\n  applyDiversity,\n  getRelatedMemories,\n  getUsageStats,\n  findCleanupCandidates,\n  getMemoryPreview,\n  verifyIntegrity,\n} from './vector-index-queries.js';\nexport {\n  LRUCache,\n  get_query_cache,\n  get_cache_key,\n  cached_search,\n  clear_search_cache,\n  learn_from_selection,\n  link_related_on_save,\n  record_access,\n  enhanced_search,\n  cachedSearch,\n  clearSearchCache,\n  learnFromSelection,\n  linkRelatedOnSave,\n  recordAccess,\n  enhancedSearch,\n  getCacheKey,\n} from './vector-index-aliases.js';\n\n// Re-export store items that aren't re-exported by other modules\nexport {\n  initializeDb,\n  initialize_db,\n  checkpointAllWal,\n  closeDb,\n  close_db,\n  getDb,","lineStart":1,"lineEnd":140,"totalLines":178,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","time":{"start":1781763339408,"end":1781763339421}},"metadata":{"openai":{"itemId":"fc_0e25536fa0a2a6e5016a338d0b29bc8191942e918b9d0d8b44"}},"id":"prt_ed95ef451001XuFp0basCPZV7s","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95ed51a001S3xNq8v6rV32tT"}}
{"type":"tool_use","timestamp":1781763339443,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_muFSL5oDYPmIqzzgJ5j0PjkC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","offset":600,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts</path>\n<type>file</type>\n<content>\n600:         path.basename(oldPath) === newBasename &&\n601:         path.dirname(path.dirname(oldPath)) === newGrandparent\n602:       );\n603: \n604:       if (siblingDeleted.length !== 1) continue; // uniqueness required\n605: \n606:       const oldPath = siblingDeleted[0];\n607:       const canonicalOld = getCanonicalPathKey(oldPath);\n608: \n609:       // Verify in DB: exactly one live row for this old path (uniqueness guard).\n610:       const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n611:       if (rows.length !== 1) continue;\n612: \n613:       // Cross-verify document kind: the stored document_type must agree with the doc type\n614:       // derived from the new path. Skip rows whose stored type diverged from the new file\n615:       // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n616:       // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n617:       if (docTypeAvailable) {\n618:         const storedDocType = rows[0].document_type ?? null;\n619:         if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;\n620:       }\n621: \n622:       const rowId = rows[0].id;\n623:       const newCanonical = getCanonicalPathKey(newPath);\n624:       const newSpecFolder = extractSpecFolder(newPath);\n625:       const newMtime = (() => {\n626:         try { return fs.statSync(newPath).mtimeMs; } catch { return null; }\n627:       })();\n628: \n629:       // Update the row's path in place (preserves embedding, id, history). A reconciled\n630:       // move is a folder rename, so spec_folder is repointed with the same canonicalization\n631:       // indexMemoryFile/migration 23 use — otherwise WHERE spec_folder=? grouping goes stale.\n632:       const updated = db!.prepare(`\n633:         UPDATE memory_index\n634:         SET file_path = ?,\n635:             canonical_file_path = ?,\n636:             spec_folder = ?,\n637:             file_mtime_ms = ?,\n638:             updated_at = datetime('now')\n639:         WHERE id = ?\n640:           AND embedding_status != 'failed'\n641:       `).run(newPath, newCanonical, newSpecFolder, newMtime, rowId);\n642: \n643:       if ((updated as { changes: number }).changes !== 1) continue;\n644: \n645:       reconciledOldPaths.add(oldPath);\n646:       reconciledNewPaths.add(newPath);\n647:       reconciled.push({ oldPath, newPath, rowId, docType });\n648:       console.error(`[incremental-index] Move reconciled: ${newBasename} ${oldPath} → ${newPath} (row ${rowId}, embedding preserved)`);\n649:     }\n650:   }\n651: \n652:   return {\n653:     reconciled,\n654:     filteredToDelete: toDelete.filter(p => !reconciledOldPaths.has(p)),\n655:     filteredToIndex: toIndex.filter(p => !reconciledNewPaths.has(p)),\n656:   };\n657: }\n658: \n659: function batchUpdateMtimes(filePaths: string[]): { updated: number; failed: number } {\n660:   if (!db) return { updated: 0, failed: filePaths.length };\n661: \n662:   let updated = 0;\n663:   let failed = 0;\n664: \n665:   const updateTx = db.transaction(() => {\n666:     for (const filePath of filePaths) {\n667:       if (setIndexedMtime(filePath)) {\n668:         updated++;\n669:       } else {\n670:         failed++;\n671:       }\n672:     }\n673:   });\n674: \n675:   try {\n676:     updateTx();\n677:   } catch (error: unknown) {\n678:     const msg = error instanceof Error ? error.message : String(error);\n679:     console.warn(`[incremental-index] batchUpdateMtimes error: ${msg}`);\n680:   }\n681: \n682:   return { updated, failed };\n683: }\n684: \n685: function countChunkFingerprintHits(database: Database.Database, input: MemoizedPlanningInput): { hits: number; misses: number } {\n686:   if (!input.chunks || input.chunks.length === 0) {\n687:     return { hits: 0, misses: 0 };\n688:   }\n689: \n690:   try {\n691:     const stmt = database.prepare(`\n692:       SELECT 1 AS hit\n693:       FROM memory_index\n694:       WHERE (canonical_file_path = ? OR file_path = ?)\n695:         AND chunk_id = ?\n696:         AND chunk_fingerprint = ?\n697:       LIMIT 1\n698:     `);\n699:     const canonicalPath = getCanonicalPathKey(input.componentPath);\n700:     let hits = 0;\n701:     let misses = 0;\n702:     for (const chunk of input.chunks) {\n703:       const row = stmt.get(canonicalPath, input.componentPath, chunk.chunkId, chunk.chunkFingerprint) as { hit?: number } | undefined;\n704:       if (row?.hit === 1) {\n705:         hits++;\n706:       } else {\n707:         misses++;\n708:       }\n709:     }\n710:     return { hits, misses };\n711:   } catch (error: unknown) {\n712:     const msg = error instanceof Error ? error.message : String(error);\n713:     console.warn(`[incremental-index] countChunkFingerprintHits error: ${msg}`);\n714:     return { hits: 0, misses: input.chunks.length };\n715:   }\n716: }\n717: \n718: function planMemoizedIndexing(\n719:   inputs: readonly MemoizedPlanningInput[],\n720:   options: MemoizedPlanningOptions = {},\n721:   database: Database.Database | null = db,\n722: ): MemoizedPlanningResult {\n723:   const result: MemoizedPlanningResult = {\n724:     memoHits: 0,\n725:     memoMisses: 0,\n726:     chunkHits: 0,\n727:     chunkMisses: 0,\n728:     dependencyInvalidated: 0,\n729:     changedComponentPaths: [],\n730:     unchangedComponentPaths: [],\n731:     invalidatedComponentPaths: [],\n732:   };\n733: \n734:   if (!database) {\n735:     result.changedComponentPaths = inputs.map((input) => input.componentPath);\n736:     result.memoMisses = inputs.length;\n737:     result.chunkMisses = inputs.reduce((count, input) => count + (input.chunks?.length ?? 0), 0);\n738:     return result;\n739:   }\n740: \n741:   const memoStore = createMemoStore(database);\n742:   const changedPaths: string[] = [];\n743:   for (const input of inputs) {\n744:     // An unfingerprintable input (e.g. a non-finite number) must not abort the\n745:     // whole batch plan — treat it as a memo miss for this one input so the\n746:     // remaining inputs are still planned.\n747:     let inputFingerprint: string | null = null;\n748:     try {\n749:       inputFingerprint = canonicalFingerprint(input.canonicalInput);\n750:     } catch (_error: unknown) {\n751:       inputFingerprint = null;\n752:     }\n753:     const memo = inputFingerprint === null\n754:       ? undefined\n755:       : memoStore.getMemoRecord(input.componentPath, inputFingerprint, input.codeHash);\n756:     if (memo) {\n757:       result.memoHits++;\n758:       result.unchangedComponentPaths.push(input.componentPath);\n759:     } else {\n\n(Showing lines 600-759 of 817. Use offset=760 to continue.)\n</content>","metadata":{"preview":"        path.basename(oldPath) === newBasename &&\n        path.dirname(path.dirname(oldPath)) === newGrandparent\n      );\n\n      if (siblingDeleted.length !== 1) continue; // uniqueness required\n\n      const oldPath = siblingDeleted[0];\n      const canonicalOld = getCanonicalPathKey(oldPath);\n\n      // Verify in DB: exactly one live row for this old path (uniqueness guard).\n      const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n      if (rows.length !== 1) continue;\n\n      // Cross-verify document kind: the stored document_type must agree with the doc type\n      // derived from the new path. Skip rows whose stored type diverged from the new file\n      // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n      // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n      if (docTypeAvailable) {\n        const storedDocType = rows[0].document_type ?? null;\n        if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","text":"        path.basename(oldPath) === newBasename &&\n        path.dirname(path.dirname(oldPath)) === newGrandparent\n      );\n\n      if (siblingDeleted.length !== 1) continue; // uniqueness required\n\n      const oldPath = siblingDeleted[0];\n      const canonicalOld = getCanonicalPathKey(oldPath);\n\n      // Verify in DB: exactly one live row for this old path (uniqueness guard).\n      const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n      if (rows.length !== 1) continue;\n\n      // Cross-verify document kind: the stored document_type must agree with the doc type\n      // derived from the new path. Skip rows whose stored type diverged from the new file\n      // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n      // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n      if (docTypeAvailable) {\n        const storedDocType = rows[0].document_type ?? null;\n        if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;\n      }\n\n      const rowId = rows[0].id;\n      const newCanonical = getCanonicalPathKey(newPath);\n      const newSpecFolder = extractSpecFolder(newPath);\n      const newMtime = (() => {\n        try { return fs.statSync(newPath).mtimeMs; } catch { return null; }\n      })();\n\n      // Update the row's path in place (preserves embedding, id, history). A reconciled\n      // move is a folder rename, so spec_folder is repointed with the same canonicalization\n      // indexMemoryFile/migration 23 use — otherwise WHERE spec_folder=? grouping goes stale.\n      const updated = db!.prepare(`\n        UPDATE memory_index\n        SET file_path = ?,\n            canonical_file_path = ?,\n            spec_folder = ?,\n            file_mtime_ms = ?,\n            updated_at = datetime('now')\n        WHERE id = ?\n          AND embedding_status != 'failed'\n      `).run(newPath, newCanonical, newSpecFolder, newMtime, rowId);\n\n      if ((updated as { changes: number }).changes !== 1) continue;\n\n      reconciledOldPaths.add(oldPath);\n      reconciledNewPaths.add(newPath);\n      reconciled.push({ oldPath, newPath, rowId, docType });\n      console.error(`[incremental-index] Move reconciled: ${newBasename} ${oldPath} → ${newPath} (row ${rowId}, embedding preserved)`);\n    }\n  }\n\n  return {\n    reconciled,\n    filteredToDelete: toDelete.filter(p => !reconciledOldPaths.has(p)),\n    filteredToIndex: toIndex.filter(p => !reconciledNewPaths.has(p)),\n  };\n}\n\nfunction batchUpdateMtimes(filePaths: string[]): { updated: number; failed: number } {\n  if (!db) return { updated: 0, failed: filePaths.length };\n\n  let updated = 0;\n  let failed = 0;\n\n  const updateTx = db.transaction(() => {\n    for (const filePath of filePaths) {\n      if (setIndexedMtime(filePath)) {\n        updated++;\n      } else {\n        failed++;\n      }\n    }\n  });\n\n  try {\n    updateTx();\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] batchUpdateMtimes error: ${msg}`);\n  }\n\n  return { updated, failed };\n}\n\nfunction countChunkFingerprintHits(database: Database.Database, input: MemoizedPlanningInput): { hits: number; misses: number } {\n  if (!input.chunks || input.chunks.length === 0) {\n    return { hits: 0, misses: 0 };\n  }\n\n  try {\n    const stmt = database.prepare(`\n      SELECT 1 AS hit\n      FROM memory_index\n      WHERE (canonical_file_path = ? OR file_path = ?)\n        AND chunk_id = ?\n        AND chunk_fingerprint = ?\n      LIMIT 1\n    `);\n    const canonicalPath = getCanonicalPathKey(input.componentPath);\n    let hits = 0;\n    let misses = 0;\n    for (const chunk of input.chunks) {\n      const row = stmt.get(canonicalPath, input.componentPath, chunk.chunkId, chunk.chunkFingerprint) as { hit?: number } | undefined;\n      if (row?.hit === 1) {\n        hits++;\n      } else {\n        misses++;\n      }\n    }\n    return { hits, misses };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] countChunkFingerprintHits error: ${msg}`);\n    return { hits: 0, misses: input.chunks.length };\n  }\n}\n\nfunction planMemoizedIndexing(\n  inputs: readonly MemoizedPlanningInput[],\n  options: MemoizedPlanningOptions = {},\n  database: Database.Database | null = db,\n): MemoizedPlanningResult {\n  const result: MemoizedPlanningResult = {\n    memoHits: 0,\n    memoMisses: 0,\n    chunkHits: 0,\n    chunkMisses: 0,\n    dependencyInvalidated: 0,\n    changedComponentPaths: [],\n    unchangedComponentPaths: [],\n    invalidatedComponentPaths: [],\n  };\n\n  if (!database) {\n    result.changedComponentPaths = inputs.map((input) => input.componentPath);\n    result.memoMisses = inputs.length;\n    result.chunkMisses = inputs.reduce((count, input) => count + (input.chunks?.length ?? 0), 0);\n    return result;\n  }\n\n  const memoStore = createMemoStore(database);\n  const changedPaths: string[] = [];\n  for (const input of inputs) {\n    // An unfingerprintable input (e.g. a non-finite number) must not abort the\n    // whole batch plan — treat it as a memo miss for this one input so the\n    // remaining inputs are still planned.\n    let inputFingerprint: string | null = null;\n    try {\n      inputFingerprint = canonicalFingerprint(input.canonicalInput);\n    } catch (_error: unknown) {\n      inputFingerprint = null;\n    }\n    const memo = inputFingerprint === null\n      ? undefined\n      : memoStore.getMemoRecord(input.componentPath, inputFingerprint, input.codeHash);\n    if (memo) {\n      result.memoHits++;\n      result.unchangedComponentPaths.push(input.componentPath);\n    } else {","lineStart":600,"lineEnd":759,"totalLines":817,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","time":{"start":1781763339439,"end":1781763339442}},"metadata":{"openai":{"itemId":"fc_0e25536fa0a2a6e5016a338d0b29d48191bcd353a00d496b96"}},"id":"prt_ed95ef4aa001vRy4TjSJheEZpE","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95ed51a001S3xNq8v6rV32tT"}}
{"type":"tool_use","timestamp":1781763339453,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_VaIh6Pam2BZMT20pnjaKICiy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Causal Edges\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Causal edge creation (memory_causal_link)\n5: // Causal relationship graph for memory lineage\n6: import type Database from 'better-sqlite3';\n7: import { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\n8: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n9: import { detectContradictions } from '../graph/contradiction-detection.js';\n10: import { ensureTemporalColumns } from '../graph/temporal-edges.js';\n11: import { isTemporalEdgesEnabled } from '../search/search-flags.js';\n12: import { runInTransaction } from './transaction-manager.js';\n13: import { sweepCausalEdges } from '../causal/sweep.js';\n14: import { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\n15: import type { CausalEdgeSweepResult } from '../causal/sweep.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    1. CONSTANTS\n19: ----------------------------------------------------------------*/\n20: \n21: const RELATION_TYPES = Object.freeze({\n22:   CAUSED: 'caused',\n23:   ENABLED: 'enabled',\n24:   SUPERSEDES: 'supersedes',\n25:   CONTRADICTS: 'contradicts',\n26:   DERIVED_FROM: 'derived_from',\n27:   SUPPORTS: 'supports',\n28: } as const);\n29: \n30: type RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n31: \n32: /**\n33:  * C138: Relation weight multipliers applied during traversal scoring.\n34:  * Higher values amplify the propagated strength; values < 1.0 dampen it.\n35:  */\n36: const RELATION_WEIGHTS: Record<string, number> = {\n37:   supersedes:   1.5,  // Strongest signal — new info replaces old\n38:   caused:       1.3,  // Strong causal link\n39:   enabled:      1.1,  // Weak causal link\n40:   supports:     1.0,  // Neutral / default\n41:   derived_from: 1.0,  // Neutral / default\n42:   contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n43: };\n44: \n45: const DEFAULT_MAX_DEPTH = 3;\n46: const MAX_EDGES_LIMIT = 100;\n47: \n48: // Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\n49: const MAX_EDGES_PER_NODE = 20;\n50: const MAX_AUTO_STRENGTH = 0.5;\n51: const MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\n52: const WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\n53: const CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\n54: const STALENESS_THRESHOLD_DAYS = 90;\n55: const DECAY_STRENGTH_AMOUNT = 0.1;\n56: const DECAY_PERIOD_DAYS = 30;\n57: \n58: function parsePositiveIntegerEnv(name: string, fallback: number): number {\n59:   const value = process.env[name];\n60:   if (!value) return fallback;\n61:   const parsed = Number.parseInt(value, 10);\n62:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n63: }\n64: \n65: function isFiniteNumber(value: unknown): value is number {\n66:   return typeof value === 'number' && Number.isFinite(value);\n67: }\n68: \n69: /**\n70:  * Classify edge provenance as automatic. Covers the legacy 'auto' creator and\n71:  * namespaced automatic creators such as 'auto-session'. Shared by the insert\n72:  * cap path and the consolidation strengthening cap so the two sites cannot\n73:  * drift. Non-auto values ('manual', 'automatic', 'author') must not match.\n74:  */\n75: function isAutoEdgeCreator(createdBy: string | null | undefined): boolean {\n76:   return createdBy === 'auto'\n77:     || (typeof createdBy === 'string' && createdBy.startsWith('auto-'));\n78: }\n79: \n80: function clampStrength(strength: number): number | null {\n81:   if (!Number.isFinite(strength)) return null;\n82:   return Math.max(0, Math.min(1, strength));\n83: }\n84: \n85: function normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n86:   return {\n87:     id: Number(row.id),\n88:     source_id: String(row.source_id),\n89:     target_id: String(row.target_id),\n90:     source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n91:     target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n92:     relation: String(row.relation) as RelationType,\n93:     strength: Number(row.strength),\n94:     evidence: row.evidence == null ? null : String(row.evidence),\n95:     extracted_at: String(row.extracted_at),\n96:     created_by: String(row.created_by ?? 'manual'),\n97:     last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n98:   };\n99: }\n100: \n101: /* ───────────────────────────────────────────────────────────────\n102:    2. INTERFACES\n103: ----------------------------------------------------------------*/\n104: \n105: interface CausalEdge {\n106:   id: number;\n107:   source_id: string;\n108:   target_id: string;\n109:   source_anchor: string | null;\n110:   target_anchor: string | null;\n111:   relation: RelationType;\n112:   strength: number;\n113:   evidence: string | null;\n114:   extracted_at: string;\n115:   created_by: string;\n116:   last_accessed: string | null;\n117: }\n118: \n119: interface CausalEdgeRow extends Record<string, unknown> {\n120:   id: number;\n121:   source_id: string;\n122:   target_id: string;\n123:   source_anchor?: string | null;\n124:   target_anchor?: string | null;\n125:   relation: RelationType;\n126:   strength: number;\n127:   evidence: string | null;\n128:   extracted_at: string;\n129:   created_by: string;\n130:   last_accessed: string | null;\n131: }\n132: \n133: type EdgeQueryResult = CausalEdge[] & {\n134:   truncated: boolean;\n135:   limit: number;\n136: };\n137: \n138: interface WeightHistoryEntry {\n139:   id: number;\n140:   edge_id: number;\n141:   old_strength: number;\n142:   new_strength: number;\n143:   changed_by: string;\n144:   changed_at: string;\n145:   reason: string | null;\n146: }\n147: \n148: interface GraphStats {\n149:   totalEdges: number;\n150:   byRelation: Record<string, number>;\n151:   avgStrength: number;\n152:   uniqueSources: number;\n153:   uniqueTargets: number;\n154: }\n155: \n156: interface DeleteEdgeOptions {\n157:   reason?: string;\n158:   command?: string;\n159:   restoreContext?: Record<string, unknown>;\n160: }\n161: \n162: interface InsertEdgeMetadataOptions {\n163:   confidence?: number;\n164:   extractionMethod?: string;\n165: }\n166: \n167: interface InsertEdgeOutcome {\n168:   status: 'inserted' | 'updated' | 'skipped';\n169:   reason: string | null;\n170:   edgeId: number | null;\n171: }\n172: \n173: interface CausalChainNode {\n174:   id: string;\n175:   edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n176:   depth: number;\n177:   relation: RelationType;\n178:   strength: number;\n179:   children: CausalChainNode[];\n180:   truncated?: boolean;\n181:   truncationLimit?: number | null;\n182: }\n183: \n184: /* ───────────────────────────────────────────────────────────────\n185:    3. MODULE STATE\n186: ----------------------------------------------------------------*/\n187: \n188: let db: Database.Database | null = null;\n189: let lastInsertEdgeOutcome: InsertEdgeOutcome | null = null;\n190: \n191: /**\n192:  * Monotonically-increasing generation counter bumped on every causal-edge\n193:  * mutation (insert/update/delete/rollback). Read-only callers can include this\n194:  * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n195:  * cached responses derived from the causal graph become stale on the next\n196:  * lookup without requiring a wholesale tool-cache invalidation.\n197:  *\n198:  * targeted memory_search cache invalidation.\n199:  */\n200: // Counter lives in causal-generation.ts so the tombstone sweep (which this\n201: // module imports) can bump it without a circular import.\n202: \n203: function setLastInsertEdgeOutcome(outcome: InsertEdgeOutcome): void {\n204:   lastInsertEdgeOutcome = outcome;\n205: }\n206: \n207: function getLastInsertEdgeOutcome(): InsertEdgeOutcome | null {\n208:   return lastInsertEdgeOutcome;\n209: }\n210: \n211: function invalidateDegreeCache(): void {\n212:   // bump the causal-edges generation FIRST so any cache key that\n213:   // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n214:   // stale on the next read without invalidating unrelated tool entries.\n215:   bumpCausalEdgesGeneration();\n216: \n217:   try {\n218:     // Use db-specific cache invalidation instead of the no-op global version\n219:     if (db) {\n220:       clearDegreeCacheForDb(db);\n221:     }\n222:   } catch (_error: unknown) {\n223:     // Cache invalidation is best-effort; never block edge mutations\n224:   }\n225:   try {\n226:     clearGraphSignalsCache();\n227:   } catch (_error: unknown) {\n228:     // Graph signals cache invalidation is best-effort\n229:   }\n230: }\n231: \n232: function enforceRelationWindowCap(\n233:   relation: string,\n234:   database: Database.Database,\n235:   windowMs: number = WINDOW_MS,\n236:   capPerWindow: number = CAP_PER_WINDOW,\n237: ): boolean {\n238:   try {\n239:     const windowStart = new Date(Date.now() - windowMs).toISOString();\n240:     const row = (database.prepare(`\n241:       SELECT COUNT(*) as count FROM causal_edges\n242:       WHERE relation = ?\n243:         AND datetime(extracted_at) >= datetime(?)\n244:     `) as Database.Statement).get(relation, windowStart) as { count: number };\n245:     const count = row.count;\n246:     if (count >= capPerWindow) {\n247:       console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n248:       return false;\n249:     }\n250:     return true;\n251:   } catch (error: unknown) {\n252:     const msg = error instanceof Error ? error.message : String(error);\n253:     console.warn(`[causal-edges] relation cap check failed for ${relation}: ${msg}`);\n254:     return true;\n255:   }\n256: }\n257: \n258: /* ───────────────────────────────────────────────────────────────\n259:    4. INITIALIZATION\n260: ----------------------------------------------------------------*/\n\n(Showing lines 1-260 of 1216. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\nimport type { CausalEdgeSweepResult } from '../causal/sweep.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\nimport type { CausalEdgeSweepResult } from '../causal/sweep.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst RELATION_TYPES = Object.freeze({\n  CAUSED: 'caused',\n  ENABLED: 'enabled',\n  SUPERSEDES: 'supersedes',\n  CONTRADICTS: 'contradicts',\n  DERIVED_FROM: 'derived_from',\n  SUPPORTS: 'supports',\n} as const);\n\ntype RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n\n/**\n * C138: Relation weight multipliers applied during traversal scoring.\n * Higher values amplify the propagated strength; values < 1.0 dampen it.\n */\nconst RELATION_WEIGHTS: Record<string, number> = {\n  supersedes:   1.5,  // Strongest signal — new info replaces old\n  caused:       1.3,  // Strong causal link\n  enabled:      1.1,  // Weak causal link\n  supports:     1.0,  // Neutral / default\n  derived_from: 1.0,  // Neutral / default\n  contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n};\n\nconst DEFAULT_MAX_DEPTH = 3;\nconst MAX_EDGES_LIMIT = 100;\n\n// Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\nconst MAX_EDGES_PER_NODE = 20;\nconst MAX_AUTO_STRENGTH = 0.5;\nconst MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\nconst WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\nconst CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\nconst STALENESS_THRESHOLD_DAYS = 90;\nconst DECAY_STRENGTH_AMOUNT = 0.1;\nconst DECAY_PERIOD_DAYS = 30;\n\nfunction parsePositiveIntegerEnv(name: string, fallback: number): number {\n  const value = process.env[name];\n  if (!value) return fallback;\n  const parsed = Number.parseInt(value, 10);\n  return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isFiniteNumber(value: unknown): value is number {\n  return typeof value === 'number' && Number.isFinite(value);\n}\n\n/**\n * Classify edge provenance as automatic. Covers the legacy 'auto' creator and\n * namespaced automatic creators such as 'auto-session'. Shared by the insert\n * cap path and the consolidation strengthening cap so the two sites cannot\n * drift. Non-auto values ('manual', 'automatic', 'author') must not match.\n */\nfunction isAutoEdgeCreator(createdBy: string | null | undefined): boolean {\n  return createdBy === 'auto'\n    || (typeof createdBy === 'string' && createdBy.startsWith('auto-'));\n}\n\nfunction clampStrength(strength: number): number | null {\n  if (!Number.isFinite(strength)) return null;\n  return Math.max(0, Math.min(1, strength));\n}\n\nfunction normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n  return {\n    id: Number(row.id),\n    source_id: String(row.source_id),\n    target_id: String(row.target_id),\n    source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n    target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n    relation: String(row.relation) as RelationType,\n    strength: Number(row.strength),\n    evidence: row.evidence == null ? null : String(row.evidence),\n    extracted_at: String(row.extracted_at),\n    created_by: String(row.created_by ?? 'manual'),\n    last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CausalEdge {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor: string | null;\n  target_anchor: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ninterface CausalEdgeRow extends Record<string, unknown> {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor?: string | null;\n  target_anchor?: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ntype EdgeQueryResult = CausalEdge[] & {\n  truncated: boolean;\n  limit: number;\n};\n\ninterface WeightHistoryEntry {\n  id: number;\n  edge_id: number;\n  old_strength: number;\n  new_strength: number;\n  changed_by: string;\n  changed_at: string;\n  reason: string | null;\n}\n\ninterface GraphStats {\n  totalEdges: number;\n  byRelation: Record<string, number>;\n  avgStrength: number;\n  uniqueSources: number;\n  uniqueTargets: number;\n}\n\ninterface DeleteEdgeOptions {\n  reason?: string;\n  command?: string;\n  restoreContext?: Record<string, unknown>;\n}\n\ninterface InsertEdgeMetadataOptions {\n  confidence?: number;\n  extractionMethod?: string;\n}\n\ninterface InsertEdgeOutcome {\n  status: 'inserted' | 'updated' | 'skipped';\n  reason: string | null;\n  edgeId: number | null;\n}\n\ninterface CausalChainNode {\n  id: string;\n  edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n  depth: number;\n  relation: RelationType;\n  strength: number;\n  children: CausalChainNode[];\n  truncated?: boolean;\n  truncationLimit?: number | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet lastInsertEdgeOutcome: InsertEdgeOutcome | null = null;\n\n/**\n * Monotonically-increasing generation counter bumped on every causal-edge\n * mutation (insert/update/delete/rollback). Read-only callers can include this\n * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n * cached responses derived from the causal graph become stale on the next\n * lookup without requiring a wholesale tool-cache invalidation.\n *\n * targeted memory_search cache invalidation.\n */\n// Counter lives in causal-generation.ts so the tombstone sweep (which this\n// module imports) can bump it without a circular import.\n\nfunction setLastInsertEdgeOutcome(outcome: InsertEdgeOutcome): void {\n  lastInsertEdgeOutcome = outcome;\n}\n\nfunction getLastInsertEdgeOutcome(): InsertEdgeOutcome | null {\n  return lastInsertEdgeOutcome;\n}\n\nfunction invalidateDegreeCache(): void {\n  // bump the causal-edges generation FIRST so any cache key that\n  // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n  // stale on the next read without invalidating unrelated tool entries.\n  bumpCausalEdgesGeneration();\n\n  try {\n    // Use db-specific cache invalidation instead of the no-op global version\n    if (db) {\n      clearDegreeCacheForDb(db);\n    }\n  } catch (_error: unknown) {\n    // Cache invalidation is best-effort; never block edge mutations\n  }\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signals cache invalidation is best-effort\n  }\n}\n\nfunction enforceRelationWindowCap(\n  relation: string,\n  database: Database.Database,\n  windowMs: number = WINDOW_MS,\n  capPerWindow: number = CAP_PER_WINDOW,\n): boolean {\n  try {\n    const windowStart = new Date(Date.now() - windowMs).toISOString();\n    const row = (database.prepare(`\n      SELECT COUNT(*) as count FROM causal_edges\n      WHERE relation = ?\n        AND datetime(extracted_at) >= datetime(?)\n    `) as Database.Statement).get(relation, windowStart) as { count: number };\n    const count = row.count;\n    if (count >= capPerWindow) {\n      console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] relation cap check failed for ${relation}: ${msg}`);\n    return true;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INITIALIZATION\n----------------------------------------------------------------*/","lineStart":1,"lineEnd":260,"totalLines":1216,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","time":{"start":1781763339449,"end":1781763339452}},"metadata":{"openai":{"itemId":"fc_0e25536fa0a2a6e5016a338d0b2e1081919f1599287e3bf0a1"}},"id":"prt_ed95ef4af001KyQ9lhs5O1xkPf","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95ed51a001S3xNq8v6rV32tT"}}
{"type":"tool_use","timestamp":1781763339575,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_GVygZAmZVAzkuqjU1JlVa9C4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Causal Graph\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    0. DEPENDENCIES\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: // Lib modules\n10: import * as vectorIndex from '../lib/search/vector-index.js';\n11: import * as causalEdges from '../lib/storage/causal-edges.js';\n12: import type { CausalChainNode, CausalEdge } from '../lib/storage/causal-edges.js';\n13: import { buildRelationCoverageState } from '../lib/causal/relation-coverage.js';\n14: import { backfillRelationInference } from '../lib/causal/relation-backfill.js';\n15: \n16: // Core utilities\n17: import { checkDatabaseUpdated } from '../core/index.js';\n18: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n19: import { toErrorMessage } from '../utils/index.js';\n20: import { ErrorCodes, getRecoveryHint } from '../lib/errors.js';\n21: \n22: // Standardized response structure\n23: import { createMCPSuccessResponse, createMCPErrorResponse, createMCPEmptyResponse } from '../lib/response/envelope.js';\n24: \n25: // Governed retrieval scope (tenant/user/agent boundary — sessionId is NOT a boundary)\n26: import { createScopeFilterPredicate } from '../lib/governance/scope-governance.js';\n27: \n28: // Shared handler types\n29: import type { MCPResponse } from './types.js';\n30: \n31: // Shared post-mutation cache invalidation. A causal edge change alters graph\n32: // signals, node degree, and co-activation, so the graph-structure caches must be\n33: // cleared on link/unlink — otherwise they stay stale until their ~60s TTL.\n34: import { runPostMutationHooks } from './mutation-hooks.js';\n35: \n36: // Feature catalog: Causal graph statistics (memory_causal_stats)\n37: // Feature catalog: Causal chain tracing (memory_drift_why)\n38: \n39: \n40: /* ───────────────────────────────────────────────────────────────\n41:    1. TYPES\n42: ──────────────────────────────────────────────────────────────── */\n43: \n44: /** Flat edge representation for API responses */\n45: export interface FlatEdge {\n46:   id: number;               // causal_edges.id for unlink workflow\n47:   from: string;\n48:   to: string;\n49:   relation: string;\n50:   strength: number;\n51:   depth: number;\n52:   direction: 'incoming' | 'outgoing';\n53: }\n54: \n55: /** Flattened chain produced from CausalChainNode tree */\n56: export interface FlattenedChain {\n57:   all: FlatEdge[];\n58:   by_cause: FlatEdge[];\n59:   by_enabled: FlatEdge[];\n60:   by_supersedes: FlatEdge[];\n61:   by_contradicts: FlatEdge[];\n62:   by_derived_from: FlatEdge[];\n63:   by_supports: FlatEdge[];\n64:   total_edges: number;\n65:   max_depth_reached: boolean;\n66:   truncated: boolean;\n67:   truncation_limit: number | null;\n68: }\n69: \n70: interface DirectionalBuckets {\n71:   caused: FlatEdge[];\n72:   enabled: FlatEdge[];\n73:   supersedes: FlatEdge[];\n74:   contradicts: FlatEdge[];\n75:   derivedFrom: FlatEdge[];\n76:   supports: FlatEdge[];\n77:   allEdges: FlatEdge[];\n78:   totalEdges: number;\n79:   maxDepthReached: boolean;\n80:   truncated: boolean;\n81:   truncationLimit: number | null;\n82: }\n83: \n84: interface DriftWhyArgs {\n85:   memoryId: string | number;\n86:   maxDepth?: number;\n87:   direction?: string;\n88:   relations?: string[] | null;\n89:   includeMemoryDetails?: boolean;\n90:   // Optional governed retrieval scope. When supplied, traversal results are\n91:   // post-filtered so a caller cannot trace chains for out-of-scope memories.\n92:   tenantId?: string;\n93:   userId?: string;\n94:   agentId?: string;\n95: }\n96: \n97: interface CausalLinkArgs {\n98:   sourceId: string | number;\n99:   targetId: string | number;\n100:   relation: string;\n101:   strength?: number;\n102:   evidence?: string | null;\n103:   // Optional governed retrieval scope. When supplied, both endpoints must exist\n104:   // and match the scope before an edge is created.\n105:   tenantId?: string;\n106:   userId?: string;\n107:   agentId?: string;\n108: }\n109: \n110: interface CausalStatsArgs {\n111:   // Retained for structural compatibility with the tool-layer CausalStatsArgs\n112:   // (tools/types.ts), which the dispatcher passes through parseArgs.\n113:   _?: never;\n114:   /**\n115:    * Optional bounded relation-inference backfill. When present, the handler\n116:    * infers typed causal edges from strong existing signals (spec-document\n117:    * chains + lineage predecessor links) before computing stats. Defaults to a\n118:    * dry run (no writes); pass { dryRun: false } to commit bounded auto edges.\n119:    */\n120:   backfill?: {\n121:     dryRun?: boolean;\n122:     limit?: number;\n123:     actor?: string;\n124:     // OPT-IN collectors (default false): see backfillRelationInference.\n125:     similarity?: boolean;\n126:     contradicts?: boolean;\n127:     similarityThreshold?: number;\n128:   };\n129: }\n130: \n131: interface CausalUnlinkArgs {\n132:   edgeId: number;\n133: }\n134: \n135: type RelationBalance = {\n136:   deltaByRelation: Record<string, number>;\n137:   dominantRelation: string | null;\n138:   dominantRelationShare: number;\n139:   balanceStatus: 'balanced' | 'relation_skewed' | 'insufficient_data';\n140:   remediationHint?: string;\n141:   windowStartedAt: string;\n142: };\n143: \n144: const RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\n145: const RELATION_SKEW_SHARE_THRESHOLD = 0.80;\n146: const RELATION_SKEW_MIN_TOTAL = 50;\n147: const RELATION_INSUFFICIENT_TOTAL = 5;\n148: const VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n149: // Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n150: // `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\n151: const MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n152:   'supersedes',\n153:   'caused',\n154:   'supports',\n155:   'contradicts',\n156:   'enabled',\n157:   'derived_from',\n158: ] as const;\n159: \n160: function createZeroFilledRelationCounts(seed: Record<string, number> = {}): Record<string, number> {\n161:   const counts: Record<string, number> = {};\n162:   for (const relation of MEMORY_CAUSAL_OUTPUT_RELATIONS) {\n163:     counts[relation] = seed[relation] ?? 0;\n164:   }\n165:   for (const relation of VALID_CAUSAL_RELATIONS) {\n166:     counts[relation] = seed[relation] ?? 0;\n167:   }\n168:   return counts;\n169: }\n170: \n171: function parseEdgeTimestampMs(timestamp: string): number | null {\n172:   const normalized = timestamp.includes('T')\n173:     ? timestamp\n174:     : `${timestamp.replace(' ', 'T')}Z`;\n175:   const parsed = Date.parse(normalized);\n176:   return Number.isFinite(parsed) ? parsed : null;\n177: }\n178: \n179: function computeRelationBalance(\n180:   edges: CausalEdge[],\n181:   windowMs: number = RELATION_BALANCE_WINDOW_MS,\n182: ): RelationBalance {\n183:   const nowMs = Date.now();\n184:   const windowStartMs = nowMs - windowMs;\n185:   const deltaByRelation = createZeroFilledRelationCounts();\n186: \n187:   for (const edge of edges) {\n188:     const edgeMs = parseEdgeTimestampMs(edge.extracted_at);\n189:     if (edgeMs === null || edgeMs < windowStartMs || edgeMs > nowMs) {\n190:       continue;\n191:     }\n192:     if (Object.prototype.hasOwnProperty.call(deltaByRelation, edge.relation)) {\n193:       deltaByRelation[edge.relation] += 1;\n194:     }\n195:   }\n196: \n197:   const entries = Object.entries(deltaByRelation);\n198:   const total = entries.reduce((sum, [, count]) => sum + count, 0);\n199:   const [dominantRelation, dominantCount] = entries.reduce<[string | null, number]>(\n200:     (current, [relation, count]) => count > current[1] ? [relation, count] : current,\n201:     [null, 0],\n202:   );\n203:   const dominantRelationShare = total > 0 ? dominantCount / total : 0;\n204:   const balanceStatus = total < RELATION_INSUFFICIENT_TOTAL\n205:     ? 'insufficient_data'\n206:     : dominantRelationShare >= RELATION_SKEW_SHARE_THRESHOLD && total >= RELATION_SKEW_MIN_TOTAL\n207:       ? 'relation_skewed'\n208:       : 'balanced';\n209: \n210:   const result: RelationBalance = {\n211:     deltaByRelation,\n212:     dominantRelation,\n213:     dominantRelationShare,\n214:     balanceStatus,\n215:     windowStartedAt: new Date(windowStartMs).toISOString(),\n216:   };\n217: \n218:   if (balanceStatus === 'relation_skewed' && dominantRelation === causalEdges.RELATION_TYPES.SUPERSEDES) {\n219:     result.remediationHint = 'prediction-error supersedes burst — review create-record producer';\n220:   }\n221: \n222:   return result;\n223: }\n224: \n225: function readTopUnlinkedRecords(\n226:   db: import('better-sqlite3').Database,\n227:   limit = 5,\n228: ): Array<{ id: number | string; title: string; specFolder: string | null }> {\n229:   try {\n230:     const safeLimit = Math.max(1, Math.min(20, Math.floor(limit)));\n231:     return (db.prepare(`\n232:       SELECT id, COALESCE(title, file_path, CAST(id AS TEXT)) AS title, spec_folder AS specFolder\n233:       FROM memory_index m\n234:       WHERE NOT EXISTS (\n235:         SELECT 1 FROM causal_edges ce\n236:         WHERE ce.source_id = CAST(m.id AS TEXT)\n237:            OR ce.target_id = CAST(m.id AS TEXT)\n238:       )\n239:       ORDER BY COALESCE(importance_weight, 0) DESC, updated_at DESC, id DESC\n240:       LIMIT ?\n241:     `) as import('better-sqlite3').Statement).all(safeLimit) as Array<{ id: number | string; title: string; specFolder: string | null }>;\n242:   } catch {\n243:     return [];\n244:   }\n245: }\n246: \n247: function logCausalHandlerError(tool: string, error: unknown): void {\n248:   const message = error instanceof Error ? error.message : String(error);\n249:   console.error(`[${tool}] ${message}`);\n250: }\n251: \n252: function createSanitizedCausalError(\n253:   tool: 'memory_drift_why' | 'memory_causal_link' | 'memory_causal_stats' | 'memory_causal_unlink',\n254:   error: unknown,\n255:   code: string,\n256:   details: Record<string, unknown>,\n257:   startTime: number,\n258:   publicMessage: string,\n259: ): MCPResponse {\n260:   logCausalHandlerError(tool, error);\n\n(Showing lines 1-260 of 1218. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Causal Graph\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   0. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\n// Lib modules\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport type { CausalChainNode, CausalEdge } from '../lib/storage/causal-edges.js';\nimport { buildRelationCoverageState } from '../lib/causal/relation-coverage.js';\nimport { backfillRelationInference } from '../lib/causal/relation-backfill.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { ErrorCodes, getRecoveryHint } from '../lib/errors.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Causal Graph\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   0. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\n// Lib modules\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport type { CausalChainNode, CausalEdge } from '../lib/storage/causal-edges.js';\nimport { buildRelationCoverageState } from '../lib/causal/relation-coverage.js';\nimport { backfillRelationInference } from '../lib/causal/relation-backfill.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { ErrorCodes, getRecoveryHint } from '../lib/errors.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse, createMCPEmptyResponse } from '../lib/response/envelope.js';\n\n// Governed retrieval scope (tenant/user/agent boundary — sessionId is NOT a boundary)\nimport { createScopeFilterPredicate } from '../lib/governance/scope-governance.js';\n\n// Shared handler types\nimport type { MCPResponse } from './types.js';\n\n// Shared post-mutation cache invalidation. A causal edge change alters graph\n// signals, node degree, and co-activation, so the graph-structure caches must be\n// cleared on link/unlink — otherwise they stay stale until their ~60s TTL.\nimport { runPostMutationHooks } from './mutation-hooks.js';\n\n// Feature catalog: Causal graph statistics (memory_causal_stats)\n// Feature catalog: Causal chain tracing (memory_drift_why)\n\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/** Flat edge representation for API responses */\nexport interface FlatEdge {\n  id: number;               // causal_edges.id for unlink workflow\n  from: string;\n  to: string;\n  relation: string;\n  strength: number;\n  depth: number;\n  direction: 'incoming' | 'outgoing';\n}\n\n/** Flattened chain produced from CausalChainNode tree */\nexport interface FlattenedChain {\n  all: FlatEdge[];\n  by_cause: FlatEdge[];\n  by_enabled: FlatEdge[];\n  by_supersedes: FlatEdge[];\n  by_contradicts: FlatEdge[];\n  by_derived_from: FlatEdge[];\n  by_supports: FlatEdge[];\n  total_edges: number;\n  max_depth_reached: boolean;\n  truncated: boolean;\n  truncation_limit: number | null;\n}\n\ninterface DirectionalBuckets {\n  caused: FlatEdge[];\n  enabled: FlatEdge[];\n  supersedes: FlatEdge[];\n  contradicts: FlatEdge[];\n  derivedFrom: FlatEdge[];\n  supports: FlatEdge[];\n  allEdges: FlatEdge[];\n  totalEdges: number;\n  maxDepthReached: boolean;\n  truncated: boolean;\n  truncationLimit: number | null;\n}\n\ninterface DriftWhyArgs {\n  memoryId: string | number;\n  maxDepth?: number;\n  direction?: string;\n  relations?: string[] | null;\n  includeMemoryDetails?: boolean;\n  // Optional governed retrieval scope. When supplied, traversal results are\n  // post-filtered so a caller cannot trace chains for out-of-scope memories.\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface CausalLinkArgs {\n  sourceId: string | number;\n  targetId: string | number;\n  relation: string;\n  strength?: number;\n  evidence?: string | null;\n  // Optional governed retrieval scope. When supplied, both endpoints must exist\n  // and match the scope before an edge is created.\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface CausalStatsArgs {\n  // Retained for structural compatibility with the tool-layer CausalStatsArgs\n  // (tools/types.ts), which the dispatcher passes through parseArgs.\n  _?: never;\n  /**\n   * Optional bounded relation-inference backfill. When present, the handler\n   * infers typed causal edges from strong existing signals (spec-document\n   * chains + lineage predecessor links) before computing stats. Defaults to a\n   * dry run (no writes); pass { dryRun: false } to commit bounded auto edges.\n   */\n  backfill?: {\n    dryRun?: boolean;\n    limit?: number;\n    actor?: string;\n    // OPT-IN collectors (default false): see backfillRelationInference.\n    similarity?: boolean;\n    contradicts?: boolean;\n    similarityThreshold?: number;\n  };\n}\n\ninterface CausalUnlinkArgs {\n  edgeId: number;\n}\n\ntype RelationBalance = {\n  deltaByRelation: Record<string, number>;\n  dominantRelation: string | null;\n  dominantRelationShare: number;\n  balanceStatus: 'balanced' | 'relation_skewed' | 'insufficient_data';\n  remediationHint?: string;\n  windowStartedAt: string;\n};\n\nconst RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\nconst RELATION_SKEW_SHARE_THRESHOLD = 0.80;\nconst RELATION_SKEW_MIN_TOTAL = 50;\nconst RELATION_INSUFFICIENT_TOTAL = 5;\nconst VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n// Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n// `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\nconst MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n  'supersedes',\n  'caused',\n  'supports',\n  'contradicts',\n  'enabled',\n  'derived_from',\n] as const;\n\nfunction createZeroFilledRelationCounts(seed: Record<string, number> = {}): Record<string, number> {\n  const counts: Record<string, number> = {};\n  for (const relation of MEMORY_CAUSAL_OUTPUT_RELATIONS) {\n    counts[relation] = seed[relation] ?? 0;\n  }\n  for (const relation of VALID_CAUSAL_RELATIONS) {\n    counts[relation] = seed[relation] ?? 0;\n  }\n  return counts;\n}\n\nfunction parseEdgeTimestampMs(timestamp: string): number | null {\n  const normalized = timestamp.includes('T')\n    ? timestamp\n    : `${timestamp.replace(' ', 'T')}Z`;\n  const parsed = Date.parse(normalized);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction computeRelationBalance(\n  edges: CausalEdge[],\n  windowMs: number = RELATION_BALANCE_WINDOW_MS,\n): RelationBalance {\n  const nowMs = Date.now();\n  const windowStartMs = nowMs - windowMs;\n  const deltaByRelation = createZeroFilledRelationCounts();\n\n  for (const edge of edges) {\n    const edgeMs = parseEdgeTimestampMs(edge.extracted_at);\n    if (edgeMs === null || edgeMs < windowStartMs || edgeMs > nowMs) {\n      continue;\n    }\n    if (Object.prototype.hasOwnProperty.call(deltaByRelation, edge.relation)) {\n      deltaByRelation[edge.relation] += 1;\n    }\n  }\n\n  const entries = Object.entries(deltaByRelation);\n  const total = entries.reduce((sum, [, count]) => sum + count, 0);\n  const [dominantRelation, dominantCount] = entries.reduce<[string | null, number]>(\n    (current, [relation, count]) => count > current[1] ? [relation, count] : current,\n    [null, 0],\n  );\n  const dominantRelationShare = total > 0 ? dominantCount / total : 0;\n  const balanceStatus = total < RELATION_INSUFFICIENT_TOTAL\n    ? 'insufficient_data'\n    : dominantRelationShare >= RELATION_SKEW_SHARE_THRESHOLD && total >= RELATION_SKEW_MIN_TOTAL\n      ? 'relation_skewed'\n      : 'balanced';\n\n  const result: RelationBalance = {\n    deltaByRelation,\n    dominantRelation,\n    dominantRelationShare,\n    balanceStatus,\n    windowStartedAt: new Date(windowStartMs).toISOString(),\n  };\n\n  if (balanceStatus === 'relation_skewed' && dominantRelation === causalEdges.RELATION_TYPES.SUPERSEDES) {\n    result.remediationHint = 'prediction-error supersedes burst — review create-record producer';\n  }\n\n  return result;\n}\n\nfunction readTopUnlinkedRecords(\n  db: import('better-sqlite3').Database,\n  limit = 5,\n): Array<{ id: number | string; title: string; specFolder: string | null }> {\n  try {\n    const safeLimit = Math.max(1, Math.min(20, Math.floor(limit)));\n    return (db.prepare(`\n      SELECT id, COALESCE(title, file_path, CAST(id AS TEXT)) AS title, spec_folder AS specFolder\n      FROM memory_index m\n      WHERE NOT EXISTS (\n        SELECT 1 FROM causal_edges ce\n        WHERE ce.source_id = CAST(m.id AS TEXT)\n           OR ce.target_id = CAST(m.id AS TEXT)\n      )\n      ORDER BY COALESCE(importance_weight, 0) DESC, updated_at DESC, id DESC\n      LIMIT ?\n    `) as import('better-sqlite3').Statement).all(safeLimit) as Array<{ id: number | string; title: string; specFolder: string | null }>;\n  } catch {\n    return [];\n  }\n}\n\nfunction logCausalHandlerError(tool: string, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  console.error(`[${tool}] ${message}`);\n}\n\nfunction createSanitizedCausalError(\n  tool: 'memory_drift_why' | 'memory_causal_link' | 'memory_causal_stats' | 'memory_causal_unlink',\n  error: unknown,\n  code: string,\n  details: Record<string, unknown>,\n  startTime: number,\n  publicMessage: string,\n): MCPResponse {\n  logCausalHandlerError(tool, error);","lineStart":1,"lineEnd":260,"totalLines":1218,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","time":{"start":1781763339569,"end":1781763339574}},"metadata":{"openai":{"itemId":"fc_0e25536fa0a2a6e5016a338d0b314c8191aca49f93ee318fb1"}},"id":"prt_ed95ef4e1001tvUHYkgQipPhry","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95ed51a001S3xNq8v6rV32tT"}}
