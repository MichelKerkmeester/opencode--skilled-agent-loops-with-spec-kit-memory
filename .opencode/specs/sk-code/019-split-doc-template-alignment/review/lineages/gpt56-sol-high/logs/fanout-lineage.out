\"skipped\":0},\"evidence\":[\".opencode/specs/sk-code/019-split-doc-template-alignment/checklist.md:49-51\"],\"findingRefs\":[\"F002\"],\"summary\":\"The hub-wide link gate remains failed.\"}]},\"newFindingsRatio\":0.0,\"target_agent\":\"deep-review\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=review target_agent=deep-review\",\"sessionId\":\"fanout-gpt56-sol-high-1783912216470-zu43f5\",\"generation\":1,\"lineageMode\":\"new\",\"timestamp\":\"2026-07-13T03:48:00.000Z\",\"durationMs\":240000,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.6-sol-fast\",\"reasoningEffort\":\"high\",\"serviceTier\":null}}\n+{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":10,\"verdict\":\"FAIL\",\"activeP0\":0,\"activeP1\":2,\"activeP2\":0,\"dimensionCoverage\":1.0,\"stopReason\":\"maxIterationsReached\",\"hasAdvisories\":false,\"failedGates\":[\"spec_code\",\"checklist_evidence\"],\"timestamp\":\"2026-07-13T03:50:00.000Z\",\"sessionId\":\"fanout-gpt56-sol-high-1783912216470-zu43f5\",\"generation\":1}\n\nIndex: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/sk-code/019-split-doc-template-alignment/review/lineages/gpt56-sol-high/deep-review-findings-registry.json\n===================================================================\n--- /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/sk-code/019-split-doc-template-alignment/review/lineages/gpt56-sol-high/deep-review-findings-registry.json\n+++ /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/sk-code/019-split-doc-template-alignment/review/lineages/gpt56-sol-high/deep-review-findings-registry.json\n@@ -0,0 +1,49 @@\n+{\n+  \"sessionId\": \"fanout-gpt56-sol-high-1783912216470-zu43f5\",\n+  \"generation\": 1,\n+  \"lineageMode\": \"new\",\n+  \"openFindings\": [\n+    {\n+      \"findingId\": \"F001\",\n+      \"severity\": \"P1\",\n+      \"categor