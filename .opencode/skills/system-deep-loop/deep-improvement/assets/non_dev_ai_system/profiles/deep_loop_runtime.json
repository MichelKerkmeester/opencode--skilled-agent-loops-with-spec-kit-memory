{
  "$schema": "../packaging_config.schema.json",
  "packaging_root": ".opencode/skills/system-deep-loop/runtime",
  "system_name": "Deep Loop Runtime",
  "system_name_short": "deep-loop-runtime",
  "dimensions": {
    "S": {
      "floor": 4,
      "max": 5
    },
    "C": {
      "floor": 4,
      "max": 5
    },
    "V": {
      "floor": 4,
      "max": 5
    },
    "I": {
      "floor": 4,
      "max": 5
    },
    "O": {
      "floor": 4,
      "max": 5
    }
  },
  "score_total": 25,
  "ship_threshold": 20,
  "self_score_regex": "DEEP_LOOP_RUNTIME_SCORE[^\\d]{0,15}(\\d{1,2})\\s*/\\s*25",
  "frozen_surface": [
    {
      "frozen_name": "runtime-skill-contract.frozen.md",
      "live_relpath": "README.md",
      "section_anchor": "## 4. HOW IT WORKS",
      "in_rubric": true
    },
    {
      "frozen_name": "script-interface-contract.frozen.md",
      "live_relpath": "references/script_interface_contract.md",
      "section_anchor": null,
      "in_rubric": true
    },
    {
      "frozen_name": "runtime-convergence-harness.frozen.cjs",
      "live_relpath": "scripts/convergence.cjs",
      "section_anchor": null,
      "in_rubric": false
    }
  ],
  "anchors": [
    "JSON-only output to stdout",
    "loopType must be \"research\", \"review\", \"council\", or \"context\"",
    "loop-lock"
  ],
  "manifest_note": "Immutable runtime/ scorer and harness surfaces for self-target runs.",
  "derive_source_root": "references",
  "technique_doc_map": {
    "S": "references/state_format.md",
    "C": "references/script_interface_contract.md",
    "V": "references/integration_points.md",
    "I": "references/coverage_graph_schema.md",
    "O": "README.md"
  },
  "derived_copies": [],
  "synthesized_surfaces": [],
  "fixtures": {
    "visible": [
      "runtime-script-contract",
      "state-safety"
    ],
    "held_out": [
      "convergence-guard",
      "lock-integrity"
    ],
    "variants": [
      "skill"
    ]
  },
  "models": {
    "proposer": "openai/gpt-5-opencode",
    "grader": "anthropic/claude-sonnet-4.5",
    "proposer_family": "openai"
  },
  "harness": {
    "benchmark_mode_instructions": {
      "skill": "You are evaluating the system-deep-loop runtime/ layer as a self-targeted infrastructure packaging (nested, not an independent skill). Read {{CW}}/README.md, {{CW}}/references/script_interface_contract.md, {{CW}}/references/state_format.md, {{CW}}/references/integration_points.md and {{CW}}/references/coverage_graph_schema.md before answering. BENCHMARK MODE: do not edit files. Print the complete analysis, the DEEP_LOOP_RUNTIME_SCORE out of 25, and per-dimension notes."
    }
  },
  "lexicon": {
    "hard_blocker_words": [
      "unchecked",
      "fire-and-forget"
    ],
    "hard_blocker_patterns": [
      {
        "label": "mutation_without_lock",
        "regex": "write without (?:holding|acquiring) (?:the )?lock",
        "severity": "hard"
      }
    ],
    "soft_phrase_patterns": [
      "best effort",
      "probably safe"
    ]
  },
  "worktree_prefix": "deep-loop-runtime-loop-",
  "worktree_subdir": "runtime",
  "packaging_root_env": "DLR_ROOT",
  "frozenSurfaces": [
    {
      "id": "model-benchmark-scorer",
      "relpath": ".opencode/skills/system-deep-loop/deep-improvement/scripts/model-benchmark/run-benchmark.cjs",
      "surfaceType": "scorer",
      "reason": "Benchmark scoring must stay independent from the self-target candidate."
    },
    {
      "id": "promotion-gate",
      "relpath": ".opencode/skills/system-deep-loop/deep-improvement/scripts/shared/promote-candidate.cjs",
      "surfaceType": "scorer",
      "reason": "Promotion logic must not be optimized by the candidate it judges."
    },
    {
      "id": "runtime-convergence-harness",
      "relpath": ".opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs",
      "surfaceType": "harness",
      "reason": "Convergence output is the runtime contract under evaluation."
    },
    {
      "id": "runtime-lock",
      "relpath": ".opencode/skills/system-deep-loop/runtime/lib/deep-loop/loop-lock.ts",
      "surfaceType": "lock",
      "reason": "Single-writer safety must remain stable while technique guidance changes."
    }
  ],
  "editableTechDocs": [
    {
      "dimension": "S",
      "relpath": ".opencode/skills/system-deep-loop/runtime/references/state_format.md",
      "reason": "State-format guidance is technique-level and does not execute."
    },
    {
      "dimension": "C",
      "relpath": ".opencode/skills/system-deep-loop/runtime/references/script_interface_contract.md",
      "reason": "Script-interface guidance can improve operator behavior without changing scripts."
    },
    {
      "dimension": "V",
      "relpath": ".opencode/skills/system-deep-loop/runtime/references/integration_points.md",
      "reason": "Integration guidance is documentation-only technique surface."
    },
    {
      "dimension": "I",
      "relpath": ".opencode/skills/system-deep-loop/runtime/references/coverage_graph_schema.md",
      "reason": "Schema guidance can be clarified while the database code remains frozen."
    },
    {
      "dimension": "O",
      "relpath": ".opencode/skills/system-deep-loop/runtime/README.md",
      "reason": "Operator-facing overview is editable technique guidance."
    }
  ],
  "allowedDiffRelpaths": [
    ".opencode/skills/system-deep-loop/runtime/README.md",
    ".opencode/skills/system-deep-loop/runtime/references/coverage_graph_schema.md",
    ".opencode/skills/system-deep-loop/runtime/references/integration_points.md",
    ".opencode/skills/system-deep-loop/runtime/references/script_interface_contract.md",
    ".opencode/skills/system-deep-loop/runtime/references/state_format.md"
  ],
  "excludedSessionPrefixes": [
    "deep-loop-runtime-loop-",
    "deep-loop-runtime-scoring-",
    "deep-loop-runtime-merge-",
    "deep-loop-runtime-diag-"
  ],
  "kit_version": "1.3.0"
}
