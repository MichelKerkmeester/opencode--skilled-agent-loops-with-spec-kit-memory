:   let totalScore: number;\n\n  Line 59:     totalScore = (ftsRank * 0.40) + (semanticScore * 0.35) + (importanceBoost * 0.15) + (recencyBoost * 0.10);\n\n  Line 61:     totalScore = (ftsRank * 0.75) + (importanceBoost * 0.15) + (recencyBoost * 0.10);\n\n  Line 63:     totalScore = (semanticScore * 0.75) + (importanceBoost * 0.15) + (recencyBoost * 0.10);\n\n  Line 65:     totalScore = (importanceBoost * 0.15) + (recencyBoost * 0.10);\n\n  Line 73:     totalScore,\n","metadata":{"matches":17,"truncated":false},"title":"totalScore|buildExplainer|explainer|why_ranked","time":{"start":1780924967427,"end":1780924967455}},"metadata":{"openai":{"itemId":"fc_0eeb005d381e2a1a016a26c22718d88191a1a521359d76df67"}},"id":"prt_ea76668b40019xtEvhrKY6U85q","sessionID":"ses_1589b1327ffe3NF41ZJpTNBQ7B","messageID":"msg_ea7661f8b001KBYRQIATcrptLe"}}
