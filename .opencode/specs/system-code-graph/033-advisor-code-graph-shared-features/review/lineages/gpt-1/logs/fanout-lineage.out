(10).optional(),\n174:     includeAttribution: z.boolean().optional(),\n175:     includeAbstainReasons: z.boolean().optional(),\n176:     confidenceThreshold: z.number().min(0).max(1).optional(),\n177:     uncertaintyThreshold: z.number().min(0).max(1).optional(),\n178:   }).strict().optional(),\n179: }).strict();\n180: \n181: export const AdvisorRecommendationSchema = z.object({\n182:   skillId: z.string().min(1),\n183:   score: z.number().min(0),\n184:   confidence: z.number().min(0).max(1),\n185:   uncertainty: z.number().min(0).max(1),\n186:   dominantLane: AdvisorLaneSchema.nullable(),\n187:   laneBreakdown: z.array(laneBreakdownSchema).optional(),\n188:   why_recommended: whyRecommendedSchema.optional(),\n189:   redirectFrom: z.array(z.string().min(1)).optional(),\n190:   redirectTo: z.string().min(1).optional(),\n191:   status: z.enum(['active', 'deprecated', 'archived', 'future']).optional(),\n192: }).strict();\n193: \n194: export const AdvisorRecommendOutputSchema = z.object({\n195:   workspaceRoot: z.string().min(1),\n196:   effectiveThresholds: z.object({\n197:     confidenceThreshold: z.number().min(0).max(1),\n198:     uncertaintyThreshold: z.number().min(0).max(1),\n199:     confidenceOnly: z.boolean(),\n200:   }).strict(),\n201:   recommendations: z.array(AdvisorRecommendationSchema),\n202:   ambiguous: z.boolean().optional(),\n203:   freshness: AdvisorFreshnessSchema,\n204:   trustState: z.object({\n205:     state: AdvisorFreshnessSchema,\n206:     reason: z.string().nullable(),\n207:     generation: z.number().int().nonnegative(),\n208:     checkedAt: z.string().datetime(),\n209:     lastLiveAt: z.string().datetime().nullable(),\n210:   }).strict(),\n211:   generatedAt: z.string().datetime(),\n212:   cache: z.object({\n213:     hit: z.boolean(),\n214:     sourceSignaturePresent: z.boolean(),\n215:   }).strict(),\n216:   warnings: z.array(z.string()).optional(),\n217:   abstainReasons: z.array(z.string()).optional(),\n218:   _shadow: z.object({\n219: