{"type":"tool_use","timestamp":1783488130584,"sessionID":"ses_0bfd48e01ffew5W9Qhj3V2EB2W","part":{"type":"tool","tool":"read","callID":"call_1eff32bf33ed46169454bbab","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Fallback Router\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: // ───────────────────────────────────────────────────────────────────\n6: // 1. TYPE DEFINITIONS\n7: // ───────────────────────────────────────────────────────────────────\n8: \n9: export type FallbackAction = 'fallback' | 'fail-fast';\n10: \n11: /** Executor result category used by typed fallback route selection. */\n12: export type FallbackRouteOutcome = 'success' | 'failure';\n13: \n14: /** Failure classes that can select a targeted fallback route. */\n15: export type FallbackFailureKind =\n16:   | 'timeout'\n17:   | 'auth-failure'\n18:   | 'quota-exceeded'\n19:   | 'executor-error'\n20:   | (string & {});\n21: \n22: /** Per-failure target map for typed fallback routes. */\n23: export interface FallbackFailureTargets {\n24:   readonly default?: string;\n25:   readonly [failureKind: string]: string | undefined;\n26: }\n27: \n28: /** Fallback decision returned to dispatch callers. */\n29: export type FallbackRoute = {\n30:   readonly action: FallbackAction;\n31:   readonly target?: string;\n32:   readonly reason: string;\n33:   readonly failureKind?: FallbackFailureKind;\n34:   readonly routeGroupId?: string;\n35:   readonly hopIndex?: number;\n36: };\n37: \n38: /** Runtime context attached to a routed fallback decision. */\n39: export interface FallbackRouteContext {\n40:   readonly outcome?: FallbackRouteOutcome;\n41:   readonly failureKind?: FallbackFailureKind;\n42:   readonly routeGroupId?: string;\n43:   readonly hopIndex?: number;\n44: }\n45: \n46: /** Model routing profile used by fallback graph resolution. */\n47: export type ModelProfile = {\n48:   readonly id: string;\n49:   readonly quota_pool: string;\n50:   readonly fallback_target: string | null;\n51:   readonly failureKind?: FallbackFailureKind;\n52:   readonly onSuccessTarget?: string | null;\n53:   readonly onFailureTarget?: string | FallbackFailureTargets | null;\n54:   readonly routeScope?: string;\n55: };\n56: \n57: /** Registry of model profiles available to the fallback router. */\n58: export type ModelRegistry = {\n59:   readonly models: readonly ModelProfile[];\n60: };\n61: \n62: /** Configuration for validating fallback graph edges before dispatch. */\n63: export interface FallbackGraphValidationOptions {\n64:   readonly maxHops?: number;\n65: }\n66: \n67: /** Validated router that binds a registry after graph preflight. */\n68: export interface FallbackRouter {\n69:   resolve(\n70:     failedModelId: string,\n71:     approvedModelIds?: readonly string[],\n72:     context?: FallbackRouteContext,\n73:   ): FallbackRoute;\n74: }\n75: \n76: type TargetKind = 'legacy' | 'success' | 'failure';\n77: \n78: interface TargetSelection {\n79:   readonly target: string | null;\n80:   readonly kind: TargetKind;\n81:   readonly failureKind?: FallbackFailureKind;\n82: }\n83: \n84: interface FallbackEdge {\n85:   readonly source: ModelProfile;\n86:   readonly targetId: string;\n87:   readonly kind: TargetKind;\n88:   readonly failureKind?: string;\n89: }\n90: \n91: const DEFAULT_MAX_HOPS = 1;\n92: \n93: // ───────────────────────────────────────────────────────────────────\n94: // 2. HELPERS\n95: // ───────────────────────────────────────────────────────────────────\n96: \n97: function findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n98:   return registry.models.find((model) => model.id === modelId);\n99: }\n100: \n101: function isFailureTargets(\n102:   value: string | FallbackFailureTargets | null | undefined,\n103: ): value is FallbackFailureTargets {\n104:   return typeof value === 'object' && value !== null;\n105: }\n106: \n107: function selectFailureTarget(\n108:   failedModel: ModelProfile,\n109:   failureKind: FallbackFailureKind | undefined,\n110: ): TargetSelection {\n111:   const configuredTarget = failedModel.onFailureTarget;\n112:   const effectiveFailureKind = failureKind ?? failedModel.failureKind;\n113: \n114:   if (typeof configuredTarget === 'string') {\n115:     return { target: configuredTarget, kind: 'failure', failureKind: effectiveFailureKind };\n116:   }\n117: \n118:   if (isFailureTargets(configuredTarget)) {\n119:     const mappedTarget =\n120:       effectiveFailureKind === undefined\n121:         ? configuredTarget.default ?? null\n122:         : configuredTarget[effectiveFailureKind] ?? configuredTarget.default ?? null;\n123: \n124:     return {\n125:       target: mappedTarget,\n126:       kind: 'failure',\n127:       failureKind: effectiveFailureKind,\n128:     };\n129:   }\n130: \n131:   return {\n132:     target: failedModel.fallback_target,\n133:     kind: 'legacy',\n134:     failureKind: effectiveFailureKind,\n135:   };\n136: }\n137: \n138: function selectTarget(failedModel: ModelProfile, context: FallbackRouteContext | undefined): TargetSelection {\n139:   if (context?.outcome === 'success' && failedModel.onSuccessTarget !== undefined) {\n140:     return {\n141:       target: failedModel.onSuccessTarget,\n142:       kind: 'success',\n143:       failureKind: context.failureKind ?? failedModel.failureKind,\n144:     };\n145:   }\n146: \n147:   return selectFailureTarget(failedModel, context?.failureKind);\n148: }\n149: \n150: function createTrace(\n151:   failedModelId: string,\n152:   context: FallbackRouteContext | undefined,\n153: ): Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined {\n154:   if (context === undefined) return undefined;\n155: \n156:   return {\n157:     routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n158:     hopIndex: context.hopIndex ?? 0,\n159:   };\n160: }\n161: \n162: function withRouteMetadata(\n163:   route: FallbackRoute,\n164:   trace: Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined,\n165:   failureKind: FallbackFailureKind | undefined,\n166: ): FallbackRoute {\n167:   if (trace === undefined && failureKind === undefined) return route;\n168: \n169:   return {\n170:     ...route,\n171:     ...(failureKind === undefined ? {} : { failureKind }),\n172:     ...trace,\n173:   };\n174: }\n175: \n176: function describeTargetKind(selection: TargetSelection): string {\n177:   if (selection.kind === 'success') return 'success target';\n178:   if (selection.kind === 'failure') return 'failure target';\n179:   return 'fallback';\n180: }\n181: \n182: function collectTargets(profile: ModelProfile): readonly FallbackEdge[] {\n183:   const edges: FallbackEdge[] = [];\n184: \n185:   if (profile.fallback_target !== null) {\n186:     edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n187:   }\n188: \n189:   if (profile.onSuccessTarget !== undefined && profile.onSuccessTarget !== null) {\n190:     edges.push({ source: profile, targetId: profile.onSuccessTarget, kind: 'success' });\n191:   }\n192: \n193:   if (typeof profile.onFailureTarget === 'string') {\n194:     edges.push({\n195:       source: profile,\n196:       targetId: profile.onFailureTarget,\n197:       kind: 'failure',\n198:       failureKind: profile.failureKind,\n199:     });\n200:   } else if (isFailureTargets(profile.onFailureTarget)) {\n201:     for (const [failureKind, targetId] of Object.entries(profile.onFailureTarget)) {\n202:       if (targetId !== undefined) {\n203:         edges.push({ source: profile, targetId, kind: 'failure', failureKind });\n204:       }\n205:     }\n206:   }\n207: \n208:   return edges;\n209: }\n210: \n211: function buildEdges(registry: ModelRegistry): readonly FallbackEdge[] {\n212:   return registry.models.flatMap((profile) => collectTargets(profile));\n213: }\n214: \n215: function assertKnownTargets(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n216:   for (const edge of edges) {\n217:     if (findModel(registry, edge.targetId) === undefined) {\n218:       throw new Error(`fallback graph references missing ${edge.kind} target ${edge.targetId} from ${edge.source.id}`);\n219:     }\n220:   }\n221: }\n222: \n223: function assertScopesDoNotWiden(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n224:   for (const edge of edges) {\n225:     const target = findModel(registry, edge.targetId);\n226:     if (target === undefined) continue;\n227: \n228:     const hasScopedEdge = edge.source.routeScope !== undefined || target.routeScope !== undefined;\n229:     if (hasScopedEdge && edge.source.routeScope !== target.routeScope) {\n230:       throw new Error(`fallback graph cross-scope route rejected from ${edge.source.id} to ${target.id}`);\n231:     }\n232:   }\n233: }\n234: \n235: function assertNoCycles(edges: readonly FallbackEdge[]): void {\n236:   const adjacency = new Map<string, readonly string[]>();\n237:   for (const edge of edges) {\n238:     adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n239:   }\n240: \n241:   const visiting = new Set<string>();\n242:   const visited = new Set<string>();\n243: \n244:   function visit(modelId: string, path: readonly string[]): void {\n245:     if (visiting.has(modelId)) {\n246:       throw new Error(`fallback graph cycle detected: ${[...path, modelId].join(' -> ')}`);\n247:     }\n248: \n249:     if (visited.has(modelId)) return;\n250: \n251:     visiting.add(modelId);\n252:     for (const targetId of adjacency.get(modelId) ?? []) {\n253:       visit(targetId, [...path, modelId]);\n254:     }\n255:     visiting.delete(modelId);\n256:     visited.add(modelId);\n257:   }\n258: \n259:   for (const sourceId of adjacency.keys()) {\n260:     visit(sourceId, []);\n261:   }\n262: }\n263: \n264: function assertMaxHops(edges: readonly FallbackEdge[], maxHops: number): void {\n265:   const adjacency = new Map<string, readonly string[]>();\n266:   for (const edge of edges) {\n267:     adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n268:   }\n269: \n270:   function walk(sourceId: string, hopCount: number): void {\n271:     if (hopCount > maxHops) {\n272:       throw new Error(`fallback graph max-hop violation from ${sourceId}; allowed ${maxHops} hops`);\n273:     }\n274: \n275:     for (const targetId of adjacency.get(sourceId) ?? []) {\n276:       walk(targetId, hopCount + 1);\n277:     }\n278:   }\n279: \n280:   for (const sourceId of adjacency.keys()) {\n281:     walk(sourceId, 0);\n282:   }\n283: }\n284: \n285: // ───────────────────────────────────────────────────────────────────\n286: // 3. CORE LOGIC\n287: // ───────────────────────────────────────────────────────────────────\n288: \n289: /**\n290:  * Validate fallback graph edges before any dispatch uses them.\n291:  *\n292:  * Checks missing targets, cycles, cross-scope edges, and configured hop limits\n293:  * without mutating the registry.\n294:  *\n295:  * @param registry - The model registry with fallback configurations.\n296:  * @param options - Validation limits for graph traversal.\n297:  * @throws Error when the fallback graph is unsafe to dispatch.\n298:  */\n299: export function validateFallbackGraph(\n300:   registry: ModelRegistry,\n301:   options: FallbackGraphValidationOptions = {},\n302: ): void {\n303:   const edges = buildEdges(registry);\n304:   const maxHops = options.maxHops ?? DEFAULT_MAX_HOPS;\n305: \n306:   assertKnownTargets(registry, edges);\n307:   assertScopesDoNotWiden(registry, edges);\n308:   assertNoCycles(edges);\n309:   assertMaxHops(edges, maxHops);\n310: }\n311: \n312: /**\n313:  * Create a router after validating configured fallback edges.\n314:  *\n315:  * @param registry - The model registry with fallback configurations.\n316:  * @param options - Validation limits for graph traversal.\n317:  * @returns A router bound to the validated registry.\n318:  * @throws Error when the fallback graph is unsafe to dispatch.\n319:  */\n320: export function createFallbackRouter(\n321:   registry: ModelRegistry,\n322:   options: FallbackGraphValidationOptions = {},\n323: ): FallbackRouter {\n324:   validateFallbackGraph(registry, options);\n325: \n326:   return {\n327:     resolve(\n328:       failedModelId: string,\n329:       approvedModelIds?: readonly string[],\n330:       context?: FallbackRouteContext,\n331:     ): FallbackRoute {\n332:       return resolveFallback(failedModelId, registry, approvedModelIds, context);\n333:     },\n334:   };\n335: }\n336: \n337: /**\n338:  * Resolve the fallback route when a model exhausts its quota pool.\n339:  *\n340:  * Checks whether the failed model has a configured fallback target in a\n341:  * different quota pool and returns the appropriate route.\n342:  *\n343:  * The optional approval set closes the substitution gap: routing only ever\n344:  * resolves to a model the caller approved. The configured `fallback_target` is\n345:  * the approved route by definition, so the guard rejects only a target the\n346:  * caller never sanctioned, and never the legitimate cross-pool fallback. When\n347:  * the set is omitted, the configured target is treated as approved (existing\n348:  * behavior), so this is additive.\n349:  *\n350:  * @param failedModelId - The model ID that failed.\n351:  * @param registry - The model registry with fallback configurations.\n352:  * @param approvedModelIds - Optional set of model IDs the caller approved; when\n353:  *   provided, a target outside the set returns fail-fast instead of routing.\n354:  * @param context - Optional typed route context for failure kind and trace data.\n355:  * @returns A route indicating whether to fallback or fail-fast, with a reason.\n356:  */\n357: export function resolveFallback(\n358:   failedModelId: string,\n359:   registry: ModelRegistry,\n360:   approvedModelIds?: readonly string[],\n361:   context?: FallbackRouteContext,\n362: ): FallbackRoute {\n363:   const trace = createTrace(failedModelId, context);\n364:   const failedModel = findModel(registry, failedModelId);\n365:   if (failedModel === undefined) {\n366:     return withRouteMetadata(\n367:       {\n368:         action: 'fail-fast',\n369:         reason: `unknown model ${failedModelId}; no quota pool available for fallback routing`,\n370:       },\n371:       trace,\n372:       context?.failureKind,\n373:     );\n374:   }\n375: \n376:   const selection = selectTarget(failedModel, context);\n377:   if (selection.target === null) {\n378:     return withRouteMetadata(\n379:       {\n380:         action: 'fail-fast',\n381:         reason: `${failedModel.quota_pool} pool exhausted, no separate-pool fallback configured for ${failedModel.id}`,\n382:       },\n383:       trace,\n384:       selection.failureKind,\n385:     );\n386:   }\n387: \n388:   const targetModel = findModel(registry, selection.target);\n389:   if (targetModel === undefined) {\n390:     return withRouteMetadata(\n391:       {\n392:         action: 'fail-fast',\n393:         reason: `${failedModel.quota_pool} pool exhausted, configured ${describeTargetKind(selection)} ${selection.target} is not in the registry`,\n394:       },\n395:       trace,\n396:       selection.failureKind,\n397:     );\n398:   }\n399: \n400:   if (targetModel.quota_pool === failedModel.quota_pool) {\n401:     return withRouteMetadata(\n402:       {\n403:         action: 'fail-fast',\n404:         reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} shares the same pool; same-pool fallback rejected`,\n405:       },\n406:       trace,\n407:       selection.failureKind,\n408:     );\n409:   }\n410: \n411:   if (approvedModelIds !== undefined && !approvedModelIds.includes(targetModel.id)) {\n412:     return withRouteMetadata(\n413:       {\n414:         action: 'fail-fast',\n415:         reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} is not in the caller-approved model set; unapproved substitution rejected`,\n416:       },\n417:       trace,\n418:       selection.failureKind,\n419:     );\n420:   }\n421: \n422:   return withRouteMetadata(\n423:     {\n424:       action: 'fallback',\n425:       target: targetModel.id,\n426:       reason: `${failedModel.quota_pool} pool exhausted, routing ${failedModel.id} to separate ${targetModel.quota_pool} pool target ${targetModel.id}`,\n427:     },\n428:     trace,\n429:     selection.failureKind,\n430:   );\n431: }\n\n(End of file - total 431 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Fallback Router\n// ───────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport type FallbackAction = 'fallback' | 'fail-fast';\n\n/** Executor result category used by typed fallback route selection. */\nexport type FallbackRouteOutcome = 'success' | 'failure';\n\n/** Failure classes that can select a targeted fallback route. */\nexport type FallbackFailureKind =\n  | 'timeout'\n  | 'auth-failure'\n  | 'quota-exceeded'\n  | 'executor-error'\n  | (string & {});","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Fallback Router\n// ───────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport type FallbackAction = 'fallback' | 'fail-fast';\n\n/** Executor result category used by typed fallback route selection. */\nexport type FallbackRouteOutcome = 'success' | 'failure';\n\n/** Failure classes that can select a targeted fallback route. */\nexport type FallbackFailureKind =\n  | 'timeout'\n  | 'auth-failure'\n  | 'quota-exceeded'\n  | 'executor-error'\n  | (string & {});\n\n/** Per-failure target map for typed fallback routes. */\nexport interface FallbackFailureTargets {\n  readonly default?: string;\n  readonly [failureKind: string]: string | undefined;\n}\n\n/** Fallback decision returned to dispatch callers. */\nexport type FallbackRoute = {\n  readonly action: FallbackAction;\n  readonly target?: string;\n  readonly reason: string;\n  readonly failureKind?: FallbackFailureKind;\n  readonly routeGroupId?: string;\n  readonly hopIndex?: number;\n};\n\n/** Runtime context attached to a routed fallback decision. */\nexport interface FallbackRouteContext {\n  readonly outcome?: FallbackRouteOutcome;\n  readonly failureKind?: FallbackFailureKind;\n  readonly routeGroupId?: string;\n  readonly hopIndex?: number;\n}\n\n/** Model routing profile used by fallback graph resolution. */\nexport type ModelProfile = {\n  readonly id: string;\n  readonly quota_pool: string;\n  readonly fallback_target: string | null;\n  readonly failureKind?: FallbackFailureKind;\n  readonly onSuccessTarget?: string | null;\n  readonly onFailureTarget?: string | FallbackFailureTargets | null;\n  readonly routeScope?: string;\n};\n\n/** Registry of model profiles available to the fallback router. */\nexport type ModelRegistry = {\n  readonly models: readonly ModelProfile[];\n};\n\n/** Configuration for validating fallback graph edges before dispatch. */\nexport interface FallbackGraphValidationOptions {\n  readonly maxHops?: number;\n}\n\n/** Validated router that binds a registry after graph preflight. */\nexport interface FallbackRouter {\n  resolve(\n    failedModelId: string,\n    approvedModelIds?: readonly string[],\n    context?: FallbackRouteContext,\n  ): FallbackRoute;\n}\n\ntype TargetKind = 'legacy' | 'success' | 'failure';\n\ninterface TargetSelection {\n  readonly target: string | null;\n  readonly kind: TargetKind;\n  readonly failureKind?: FallbackFailureKind;\n}\n\ninterface FallbackEdge {\n  readonly source: ModelProfile;\n  readonly targetId: string;\n  readonly kind: TargetKind;\n  readonly failureKind?: string;\n}\n\nconst DEFAULT_MAX_HOPS = 1;\n\n// ───────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\nfunction findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n  return registry.models.find((model) => model.id === modelId);\n}\n\nfunction isFailureTargets(\n  value: string | FallbackFailureTargets | null | undefined,\n): value is FallbackFailureTargets {\n  return typeof value === 'object' && value !== null;\n}\n\nfunction selectFailureTarget(\n  failedModel: ModelProfile,\n  failureKind: FallbackFailureKind | undefined,\n): TargetSelection {\n  const configuredTarget = failedModel.onFailureTarget;\n  const effectiveFailureKind = failureKind ?? failedModel.failureKind;\n\n  if (typeof configuredTarget === 'string') {\n    return { target: configuredTarget, kind: 'failure', failureKind: effectiveFailureKind };\n  }\n\n  if (isFailureTargets(configuredTarget)) {\n    const mappedTarget =\n      effectiveFailureKind === undefined\n        ? configuredTarget.default ?? null\n        : configuredTarget[effectiveFailureKind] ?? configuredTarget.default ?? null;\n\n    return {\n      target: mappedTarget,\n      kind: 'failure',\n      failureKind: effectiveFailureKind,\n    };\n  }\n\n  return {\n    target: failedModel.fallback_target,\n    kind: 'legacy',\n    failureKind: effectiveFailureKind,\n  };\n}\n\nfunction selectTarget(failedModel: ModelProfile, context: FallbackRouteContext | undefined): TargetSelection {\n  if (context?.outcome === 'success' && failedModel.onSuccessTarget !== undefined) {\n    return {\n      target: failedModel.onSuccessTarget,\n      kind: 'success',\n      failureKind: context.failureKind ?? failedModel.failureKind,\n    };\n  }\n\n  return selectFailureTarget(failedModel, context?.failureKind);\n}\n\nfunction createTrace(\n  failedModelId: string,\n  context: FallbackRouteContext | undefined,\n): Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined {\n  if (context === undefined) return undefined;\n\n  return {\n    routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n    hopIndex: context.hopIndex ?? 0,\n  };\n}\n\nfunction withRouteMetadata(\n  route: FallbackRoute,\n  trace: Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined,\n  failureKind: FallbackFailureKind | undefined,\n): FallbackRoute {\n  if (trace === undefined && failureKind === undefined) return route;\n\n  return {\n    ...route,\n    ...(failureKind === undefined ? {} : { failureKind }),\n    ...trace,\n  };\n}\n\nfunction describeTargetKind(selection: TargetSelection): string {\n  if (selection.kind === 'success') return 'success target';\n  if (selection.kind === 'failure') return 'failure target';\n  return 'fallback';\n}\n\nfunction collectTargets(profile: ModelProfile): readonly FallbackEdge[] {\n  const edges: FallbackEdge[] = [];\n\n  if (profile.fallback_target !== null) {\n    edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n  }\n\n  if (profile.onSuccessTarget !== undefined && profile.onSuccessTarget !== null) {\n    edges.push({ source: profile, targetId: profile.onSuccessTarget, kind: 'success' });\n  }\n\n  if (typeof profile.onFailureTarget === 'string') {\n    edges.push({\n      source: profile,\n      targetId: profile.onFailureTarget,\n      kind: 'failure',\n      failureKind: profile.failureKind,\n    });\n  } else if (isFailureTargets(profile.onFailureTarget)) {\n    for (const [failureKind, targetId] of Object.entries(profile.onFailureTarget)) {\n      if (targetId !== undefined) {\n        edges.push({ source: profile, targetId, kind: 'failure', failureKind });\n      }\n    }\n  }\n\n  return edges;\n}\n\nfunction buildEdges(registry: ModelRegistry): readonly FallbackEdge[] {\n  return registry.models.flatMap((profile) => collectTargets(profile));\n}\n\nfunction assertKnownTargets(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n  for (const edge of edges) {\n    if (findModel(registry, edge.targetId) === undefined) {\n      throw new Error(`fallback graph references missing ${edge.kind} target ${edge.targetId} from ${edge.source.id}`);\n    }\n  }\n}\n\nfunction assertScopesDoNotWiden(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n  for (const edge of edges) {\n    const target = findModel(registry, edge.targetId);\n    if (target === undefined) continue;\n\n    const hasScopedEdge = edge.source.routeScope !== undefined || target.routeScope !== undefined;\n    if (hasScopedEdge && edge.source.routeScope !== target.routeScope) {\n      throw new Error(`fallback graph cross-scope route rejected from ${edge.source.id} to ${target.id}`);\n    }\n  }\n}\n\nfunction assertNoCycles(edges: readonly FallbackEdge[]): void {\n  const adjacency = new Map<string, readonly string[]>();\n  for (const edge of edges) {\n    adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n  }\n\n  const visiting = new Set<string>();\n  const visited = new Set<string>();\n\n  function visit(modelId: string, path: readonly string[]): void {\n    if (visiting.has(modelId)) {\n      throw new Error(`fallback graph cycle detected: ${[...path, modelId].join(' -> ')}`);\n    }\n\n    if (visited.has(modelId)) return;\n\n    visiting.add(modelId);\n    for (const targetId of adjacency.get(modelId) ?? []) {\n      visit(targetId, [...path, modelId]);\n    }\n    visiting.delete(modelId);\n    visited.add(modelId);\n  }\n\n  for (const sourceId of adjacency.keys()) {\n    visit(sourceId, []);\n  }\n}\n\nfunction assertMaxHops(edges: readonly FallbackEdge[], maxHops: number): void {\n  const adjacency = new Map<string, readonly string[]>();\n  for (const edge of edges) {\n    adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n  }\n\n  function walk(sourceId: string, hopCount: number): void {\n    if (hopCount > maxHops) {\n      throw new Error(`fallback graph max-hop violation from ${sourceId}; allowed ${maxHops} hops`);\n    }\n\n    for (const targetId of adjacency.get(sourceId) ?? []) {\n      walk(targetId, hopCount + 1);\n    }\n  }\n\n  for (const sourceId of adjacency.keys()) {\n    walk(sourceId, 0);\n  }\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 3. CORE LOGIC\n// ───────────────────────────────────────────────────────────────────\n\n/**\n * Validate fallback graph edges before any dispatch uses them.\n *\n * Checks missing targets, cycles, cross-scope edges, and configured hop limits\n * without mutating the registry.\n *\n * @param registry - The model registry with fallback configurations.\n * @param options - Validation limits for graph traversal.\n * @throws Error when the fallback graph is unsafe to dispatch.\n */\nexport function validateFallbackGraph(\n  registry: ModelRegistry,\n  options: FallbackGraphValidationOptions = {},\n): void {\n  const edges = buildEdges(registry);\n  const maxHops = options.maxHops ?? DEFAULT_MAX_HOPS;\n\n  assertKnownTargets(registry, edges);\n  assertScopesDoNotWiden(registry, edges);\n  assertNoCycles(edges);\n  assertMaxHops(edges, maxHops);\n}\n\n/**\n * Create a router after validating configured fallback edges.\n *\n * @param registry - The model registry with fallback configurations.\n * @param options - Validation limits for graph traversal.\n * @returns A router bound to the validated registry.\n * @throws Error when the fallback graph is unsafe to dispatch.\n */\nexport function createFallbackRouter(\n  registry: ModelRegistry,\n  options: FallbackGraphValidationOptions = {},\n): FallbackRouter {\n  validateFallbackGraph(registry, options);\n\n  return {\n    resolve(\n      failedModelId: string,\n      approvedModelIds?: readonly string[],\n      context?: FallbackRouteContext,\n    ): FallbackRoute {\n      return resolveFallback(failedModelId, registry, approvedModelIds, context);\n    },\n  };\n}\n\n/**\n * Resolve the fallback route when a model exhausts its quota pool.\n *\n * Checks whether the failed model has a configured fallback target in a\n * different quota pool and returns the appropriate route.\n *\n * The optional approval set closes the substitution gap: routing only ever\n * resolves to a model the caller approved. The configured `fallback_target` is\n * the approved route by definition, so the guard rejects only a target the\n * caller never sanctioned, and never the legitimate cross-pool fallback. When\n * the set is omitted, the configured target is treated as approved (existing\n * behavior), so this is additive.\n *\n * @param failedModelId - The model ID that failed.\n * @param registry - The model registry with fallback configurations.\n * @param approvedModelIds - Optional set of model IDs the caller approved; when\n *   provided, a target outside the set returns fail-fast instead of routing.\n * @param context - Optional typed route context for failure kind and trace data.\n * @returns A route indicating whether to fallback or fail-fast, with a reason.\n */\nexport function resolveFallback(\n  failedModelId: string,\n  registry: ModelRegistry,\n  approvedModelIds?: readonly string[],\n  context?: FallbackRouteContext,\n): FallbackRoute {\n  const trace = createTrace(failedModelId, context);\n  const failedModel = findModel(registry, failedModelId);\n  if (failedModel === undefined) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `unknown model ${failedModelId}; no quota pool available for fallback routing`,\n      },\n      trace,\n      context?.failureKind,\n    );\n  }\n\n  const selection = selectTarget(failedModel, context);\n  if (selection.target === null) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, no separate-pool fallback configured for ${failedModel.id}`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  const targetModel = findModel(registry, selection.target);\n  if (targetModel === undefined) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, configured ${describeTargetKind(selection)} ${selection.target} is not in the registry`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  if (targetModel.quota_pool === failedModel.quota_pool) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} shares the same pool; same-pool fallback rejected`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  if (approvedModelIds !== undefined && !approvedModelIds.includes(targetModel.id)) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} is not in the caller-approved model set; unapproved substitution rejected`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  return withRouteMetadata(\n    {\n      action: 'fallback',\n      target: targetModel.id,\n      reason: `${failedModel.quota_pool} pool exhausted, routing ${failedModel.id} to separate ${targetModel.quota_pool} pool target ${targetModel.id}`,\n    },\n    trace,\n    selection.failureKind,\n  );\n}","lineStart":1,"lineEnd":431,"totalLines":431,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","time":{"start":1783488130569,"end":1783488130579}},"id":"prt_f402d2e060017mBFhy14wg8WOw","sessionID":"ses_0bfd48e01ffew5W9Qhj3V2EB2W","messageID":"msg_f402d00ef001B7cYpUVMy0KQnn"}}
{"type":"tool_use","timestamp":1783488130584,"sessionID":"ses_0bfd48e01ffew5W9Qhj3V2EB2W","part":{"type":"tool","tool":"read","callID":"call_0f7f90c38e9a45d1b6fb44ae","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Executor Config\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: import { z } from 'zod';\n6: \n7: // ───────────────────────────────────────────────────────────────────\n8: // 1. TYPE DEFINITIONS\n9: // ───────────────────────────────────────────────────────────────────\n10: \n11: export const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\n12: export type ExecutorKind = typeof EXECUTOR_KINDS[number];\n13: \n14: export const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\n15: export type ReasoningEffort = typeof REASONING_EFFORTS[number];\n16: \n17: export const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\n18: export type ServiceTier = typeof SERVICE_TIERS[number];\n19: \n20: /** Fan-out assignment models accepted by the schema. */\n21: export const FANOUT_ASSIGNMENT_MODELS = ['flat_pool', 'wave'] as const;\n22: \n23: /** Fan-out assignment model selected for a lineage or fan-out block. */\n24: export type FanoutAssignmentModel = typeof FANOUT_ASSIGNMENT_MODELS[number];\n25: \n26: const SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;\n27: export type SandboxMode = typeof SANDBOX_MODES[number];\n28: export type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';\n29: \n30: // ───────────────────────────────────────────────────────────────────\n31: // 2. CONSTANTS\n32: // ───────────────────────────────────────────────────────────────────\n33: \n34: export const executorConfigSchema = z.object({\n35:   kind: z.enum(EXECUTOR_KINDS).default('native'),\n36:   model: z.string().min(1).nullable().default(null),\n37:   configDir: z.string().trim().min(1).nullable().default(null),\n38:   reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),\n39:   serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),\n40:   sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),\n41:   timeoutSeconds: z.number().int().positive().default(900),\n42:   // Optional fable-5 governor capsule for this executor's prompts. Universal and\n43:   // kind-agnostic on purpose: intentionally absent from EXECUTOR_KIND_FLAG_SUPPORT\n44:   // and the unsupported-field scan, so any executor kind may carry it. null = none.\n45:   governor: z.string().min(1).nullable().default(null),\n46: });\n47: \n48: export type ExecutorConfig = z.infer<typeof executorConfigSchema>;\n49: \n50: export const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {\n51:   native: [],\n52:   'cli-claude-code': ['model', 'configDir', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n53:   'cli-opencode': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n54: };\n55: \n56: // ───────────────────────────────────────────────────────────────────\n57: // 3. DOMAIN ERRORS\n58: // ───────────────────────────────────────────────────────────────────\n59: \n60: type ExecutorConfigIssue = {\n61:   path: PropertyKey[];\n62:   message: string;\n63: };\n64: \n65: /** Error thrown when a reserved executor kind is selected before wiring exists. */\n66: export class ExecutorNotWiredError extends Error {\n67:   kind: Extract<ExecutorKind, 'cli-claude-code'>;\n68: \n69:   constructor(kind: Extract<ExecutorKind, 'cli-claude-code'>) {\n70:     super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);\n71:     this.name = 'ExecutorNotWiredError';\n72:     this.kind = kind;\n73:   }\n74: }\n75: \n76: /** Error thrown when executor configuration validation fails. */\n77: export class ExecutorConfigError extends Error {\n78:   issues: ExecutorConfigIssue[];\n79: \n80:   constructor(input: { issues: ExecutorConfigIssue[] }) {\n81:     super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));\n82:     this.name = 'ExecutorConfigError';\n83:     this.issues = input.issues;\n84:   }\n85: }\n86: \n87: // ───────────────────────────────────────────────────────────────────\n88: // 4. HELPERS\n89: // ───────────────────────────────────────────────────────────────────\n90: \n91: function isRecord(value: unknown): value is Record<string, unknown> {\n92:   return value !== null && !Array.isArray(value) && typeof value === 'object';\n93: }\n94: \n95: function normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n96:   return mode ?? 'workspace-write';\n97: }\n98: \n99: function normalizeExecutorConfigInput(raw: unknown): unknown {\n100:   if (!isRecord(raw) || !Object.prototype.hasOwnProperty.call(raw, 'type')) {\n101:     return raw;\n102:   }\n103: \n104:   const legacyKind = raw.type;\n105:   if (typeof legacyKind !== 'string') {\n106:     return raw;\n107:   }\n108: \n109:   if (typeof raw.kind === 'string' && raw.kind !== legacyKind) {\n110:     throw new ExecutorConfigError({\n111:       issues: [{\n112:         path: ['type'],\n113:         message: `deprecated executor field 'type' conflicts with canonical kind '${raw.kind}'`,\n114:       }],\n115:     });\n116:   }\n117: \n118:   console.warn(\"[executor-config] Deprecated executor field 'type' was provided; use 'kind' instead.\");\n119:   const { type: _legacyType, ...rest } = raw;\n120:   return {\n121:     ...rest,\n122:     kind: typeof raw.kind === 'string' ? raw.kind : legacyKind,\n123:   };\n124: }\n125: \n126: function normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {\n127:   return error.issues.map((issue) => ({\n128:     path: issue.path,\n129:     message: issue.message,\n130:   }));\n131: }\n132: \n133: // ───────────────────────────────────────────────────────────────────\n134: // 5. EXPORTS\n135: // ───────────────────────────────────────────────────────────────────\n136: \n137: /**\n138:  * Map a generic sandbox mode to the executor-agnostic CLI sandbox mode.\n139:  *\n140:  * @param mode - Generic sandbox mode or undefined.\n141:  * @returns CLI-compatible sandbox mode.\n142:  */\n143: export function resolveSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n144:   return normalizeSandboxMode(mode);\n145: }\n146: \n147: /**\n148:  * Map a generic sandbox mode to the Claude Code permission mode.\n149:  *\n150:  * @param mode - Generic sandbox mode or undefined.\n151:  * @returns Claude-compatible permission mode.\n152:  */\n153: export function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {\n154:   switch (normalizeSandboxMode(mode)) {\n155:     case 'read-only':\n156:       return 'plan';\n157:     case 'danger-full-access':\n158:       return 'bypassPermissions';\n159:     default:\n160:       return 'acceptEdits';\n161:   }\n162: }\n163: \n164: /**\n165:  * Parse and validate a raw executor configuration.\n166:  *\n167:  * Normalizes legacy `type` fields, validates against the Zod schema,\n168:  * and enforces executor-kind-specific field support.\n169:  *\n170:  * @param raw - Raw input to parse (JSON-parsed object).\n171:  * @returns Validated ExecutorConfig.\n172:  * @throws {@link ExecutorConfigError} If validation fails.\n173:  */\n174: export function parseExecutorConfig(raw: unknown): ExecutorConfig {\n175:   const parsed = executorConfigSchema.safeParse(normalizeExecutorConfigInput(raw));\n176:   if (!parsed.success) {\n177:     throw new ExecutorConfigError({\n178:       issues: normalizeIssues(parsed.error),\n179:     });\n180:   }\n181: \n182:   const config = parsed.data;\n183:   const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];\n184:   const unsupportedFields: string[] = [];\n185:   const allOptionalFields: (keyof ExecutorConfig)[] = [\n186:     'model',\n187:     'configDir',\n188:     'reasoningEffort',\n189:     'serviceTier',\n190:     'sandboxMode',\n191:     'timeoutSeconds',\n192:   ];\n193: \n194:   for (const field of allOptionalFields) {\n195:     if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {\n196:       unsupportedFields.push(field);\n197:     }\n198:   }\n199: \n200:   if (unsupportedFields.length > 0) {\n201:     throw new ExecutorConfigError({\n202:       issues: unsupportedFields.map((field) => ({\n203:         path: [field],\n204:         message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${\n205:           supportedFlags.length ? supportedFlags.join(', ') : 'none'\n206:         }.`,\n207:       })),\n208:     });\n209:   }\n210: \n211:   return config;\n212: }\n213: \n214: /**\n215:  * Resolve an executor configuration by merging CLI and file sources.\n216:  *\n217:  * @param sources - CLI and file partial configs (CLI takes precedence).\n218:  * @returns Validated ExecutorConfig.\n219:  */\n220: export function resolveExecutorConfig(sources: {\n221:   cli?: Partial<ExecutorConfig>;\n222:   file?: Partial<ExecutorConfig>;\n223: }): ExecutorConfig {\n224:   const merged = {\n225:     ...(sources.file ?? {}),\n226:     ...(sources.cli ?? {}),\n227:   };\n228:   return parseExecutorConfig(merged);\n229: }\n230: \n231: // ───────────────────────────────────────────────────────────────────\n232: // 6. FAN-OUT CONFIG\n233: // ───────────────────────────────────────────────────────────────────\n234: //\n235: // Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n236: // the loop runs N executor \"lineages\" concurrently (capped), each running the\n237: // existing sequential loop in its own isolated sub-packet. The single-executor\n238: // path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n239: // default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n240: \n241: const LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n242: \n243: /**\n244:  * One fan-out lineage: a single executor config plus fan-out metadata.\n245:  *\n246:  * - `label`: directory-safe id for the lineage's isolated sub-packet.\n247:  * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n248:  * - `iterations`: per-lineage max-iterations override; null = packet default.\n249:  * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n250:  *   \"tidd-ec\") resolved against sk-prompt-models when a consumer renders the\n251:  *   lineage prompt. null = consumer default. Loop-type-agnostic and optional, so\n252:  *   research/review lineages that omit it are unaffected.\n253:  * - `assignment_model`: defaults to the existing flat pool; `wave` is accepted\n254:  *   only so the runtime guard can reject activation attempts explicitly.\n255:  * - `depends_on` / `touches`: reserved dependency and path-domain metadata for\n256:  *   a future guarded planner; flat-pool execution ignores them after logging.\n257:  */\n258: export const lineageExecutorSchema = executorConfigSchema.extend({\n259:   label: z.string().min(1).regex(LINEAGE_LABEL_PATTERN, {\n260:     message: \"label must match /^[a-z0-9][a-z0-9-]*$/ (lowercase, digits, hyphens; dir-safe)\",\n261:   }),\n262:   count: z.number().int().positive().default(1),\n263:   iterations: z.number().int().positive().nullable().default(null),\n264:   promptFramework: z.string().min(1).nullable().default(null),\n265:   assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n266:   depends_on: z.array(z.string().trim().min(1)).default([]),\n267:   touches: z.array(z.string().trim().min(1)).default([]),\n268: });\n269: \n270: export type LineageExecutor = z.infer<typeof lineageExecutorSchema>;\n271: \n272: export const fanoutConfigSchema = z.object({\n273:   executors: z.array(lineageExecutorSchema).min(1),\n274:   assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n275:   concurrency: z.number().int().positive().default(2),\n276:   maxRetries: z.number().int().nonnegative().default(5),\n277:   // Stall detection defaults ON: a lineage that stops emitting progress is aborted and\n278:   // requeued within the ceiling and fails loud, instead of hanging silently at 0% CPU\n279:   // until the hours-scale subprocess timeout. Set 0 to opt out.\n280:   lagCeilingMs: z.number().int().nonnegative().default(300000),\n281:   progressHeartbeatSeconds: z.number().nonnegative().default(60),\n282: });\n283: \n284: export type FanoutConfig = z.infer<typeof fanoutConfigSchema>;\n285: \n286: /**\n287:  * Parse and validate a raw fan-out configuration.\n288:  *\n289:  * Each entry's executor subset is routed through {@link parseExecutorConfig} so\n290:  * ALL existing kind/model/flag rules apply per lineage with zero duplication.\n291:  * Labels must be unique and base-label (count>1) expansion must not collide.\n292:  *\n293:  * @param raw - Raw input to parse (JSON-parsed object).\n294:  * @returns Validated FanoutConfig.\n295:  * @throws {@link ExecutorConfigError} If validation fails.\n296:  */\n297: export function parseFanoutConfig(raw: unknown): FanoutConfig {\n298:   const parsed = fanoutConfigSchema.safeParse(raw);\n299:   if (!parsed.success) {\n300:     throw new ExecutorConfigError({ issues: parsed.error.issues.map((issue) => ({ path: issue.path, message: issue.message })) });\n301:   }\n302: \n303:   const config = parsed.data;\n304: \n305:   // Reuse the canonical single-executor validator per entry (kind/model/flags).\n306:   config.executors.forEach((entry, index) => {\n307:     const {\n308:       label: _label,\n309:       count: _count,\n310:       iterations: _iterations,\n311:       promptFramework: _promptFramework,\n312:       assignment_model: _assignmentModel,\n313:       depends_on: _dependsOn,\n314:       touches: _touches,\n315:       ...executorSubset\n316:     } = entry;\n317:     try {\n318:       parseExecutorConfig(executorSubset);\n319:     } catch (err: unknown) {\n320:       if (err instanceof ExecutorConfigError) {\n321:         throw new ExecutorConfigError({\n322:           issues: err.issues.map((issue) => ({ path: ['executors', index, ...issue.path], message: issue.message })),\n323:         });\n324:       }\n325:       throw err;\n326:     }\n327:   });\n328: \n329:   // Labels must be unique among the declared lineages.\n330:   const seenLabels = new Set<string>();\n331:   config.executors.forEach((entry, index) => {\n332:     if (seenLabels.has(entry.label)) {\n333:       throw new ExecutorConfigError({\n334:         issues: [{ path: ['executors', index, 'label'], message: `duplicate lineage label '${entry.label}'` }],\n335:       });\n336:     }\n337:     seenLabels.add(entry.label);\n338:   });\n339: \n340:   // Expanded labels (count>1 → label-1, label-2, …) must not collide either.\n341:   const expandedLabels = new Set<string>();\n342:   for (const lineage of expandLineages(config)) {\n343:     if (expandedLabels.has(lineage.label)) {\n344:       throw new ExecutorConfigError({\n345:         issues: [{ path: ['executors'], message: `expanded lineage label '${lineage.label}' collides; rename base labels` }],\n346:       });\n347:     }\n348:     expandedLabels.add(lineage.label);\n349:   }\n350: \n351:   return config;\n352: }\n353: \n354: /**\n355:  * Expand a fan-out config into concrete per-replica lineages.\n356:  *\n357:  * A `count` of 1 keeps the base label; `count > 1` yields `${label}-1` …\n358:  * `${label}-N`. Each expanded lineage carries `count: 1` so downstream\n359:  * consumers see one runnable unit per element.\n360:  *\n361:  * @param config - Validated FanoutConfig.\n362:  * @returns Flat list of single-replica lineages (one runnable unit each).\n363:  */\n364: export function expandLineages(config: FanoutConfig): LineageExecutor[] {\n365:   const lineages: LineageExecutor[] = [];\n366:   for (const entry of config.executors) {\n367:     if (entry.count === 1) {\n368:       lineages.push({ ...entry, count: 1 });\n369:       continue;\n370:     }\n371:     for (let replica = 1; replica <= entry.count; replica += 1) {\n372:       lineages.push({ ...entry, label: `${entry.label}-${replica}`, count: 1 });\n373:     }\n374:   }\n375:   return lineages;\n376: }\n\n(End of file - total 376 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Executor Config\n// ───────────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\nexport type ExecutorKind = typeof EXECUTOR_KINDS[number];\n\nexport const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\nexport type ReasoningEffort = typeof REASONING_EFFORTS[number];\n\nexport const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\nexport type ServiceTier = typeof SERVICE_TIERS[number];\n\n/** Fan-out assignment models accepted by the schema. */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Executor Config\n// ───────────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\nexport type ExecutorKind = typeof EXECUTOR_KINDS[number];\n\nexport const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\nexport type ReasoningEffort = typeof REASONING_EFFORTS[number];\n\nexport const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\nexport type ServiceTier = typeof SERVICE_TIERS[number];\n\n/** Fan-out assignment models accepted by the schema. */\nexport const FANOUT_ASSIGNMENT_MODELS = ['flat_pool', 'wave'] as const;\n\n/** Fan-out assignment model selected for a lineage or fan-out block. */\nexport type FanoutAssignmentModel = typeof FANOUT_ASSIGNMENT_MODELS[number];\n\nconst SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;\nexport type SandboxMode = typeof SANDBOX_MODES[number];\nexport type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';\n\n// ───────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────────\n\nexport const executorConfigSchema = z.object({\n  kind: z.enum(EXECUTOR_KINDS).default('native'),\n  model: z.string().min(1).nullable().default(null),\n  configDir: z.string().trim().min(1).nullable().default(null),\n  reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),\n  serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),\n  sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),\n  timeoutSeconds: z.number().int().positive().default(900),\n  // Optional fable-5 governor capsule for this executor's prompts. Universal and\n  // kind-agnostic on purpose: intentionally absent from EXECUTOR_KIND_FLAG_SUPPORT\n  // and the unsupported-field scan, so any executor kind may carry it. null = none.\n  governor: z.string().min(1).nullable().default(null),\n});\n\nexport type ExecutorConfig = z.infer<typeof executorConfigSchema>;\n\nexport const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {\n  native: [],\n  'cli-claude-code': ['model', 'configDir', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n  'cli-opencode': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n};\n\n// ───────────────────────────────────────────────────────────────────\n// 3. DOMAIN ERRORS\n// ───────────────────────────────────────────────────────────────────\n\ntype ExecutorConfigIssue = {\n  path: PropertyKey[];\n  message: string;\n};\n\n/** Error thrown when a reserved executor kind is selected before wiring exists. */\nexport class ExecutorNotWiredError extends Error {\n  kind: Extract<ExecutorKind, 'cli-claude-code'>;\n\n  constructor(kind: Extract<ExecutorKind, 'cli-claude-code'>) {\n    super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);\n    this.name = 'ExecutorNotWiredError';\n    this.kind = kind;\n  }\n}\n\n/** Error thrown when executor configuration validation fails. */\nexport class ExecutorConfigError extends Error {\n  issues: ExecutorConfigIssue[];\n\n  constructor(input: { issues: ExecutorConfigIssue[] }) {\n    super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));\n    this.name = 'ExecutorConfigError';\n    this.issues = input.issues;\n  }\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return value !== null && !Array.isArray(value) && typeof value === 'object';\n}\n\nfunction normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n  return mode ?? 'workspace-write';\n}\n\nfunction normalizeExecutorConfigInput(raw: unknown): unknown {\n  if (!isRecord(raw) || !Object.prototype.hasOwnProperty.call(raw, 'type')) {\n    return raw;\n  }\n\n  const legacyKind = raw.type;\n  if (typeof legacyKind !== 'string') {\n    return raw;\n  }\n\n  if (typeof raw.kind === 'string' && raw.kind !== legacyKind) {\n    throw new ExecutorConfigError({\n      issues: [{\n        path: ['type'],\n        message: `deprecated executor field 'type' conflicts with canonical kind '${raw.kind}'`,\n      }],\n    });\n  }\n\n  console.warn(\"[executor-config] Deprecated executor field 'type' was provided; use 'kind' instead.\");\n  const { type: _legacyType, ...rest } = raw;\n  return {\n    ...rest,\n    kind: typeof raw.kind === 'string' ? raw.kind : legacyKind,\n  };\n}\n\nfunction normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {\n  return error.issues.map((issue) => ({\n    path: issue.path,\n    message: issue.message,\n  }));\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 5. EXPORTS\n// ───────────────────────────────────────────────────────────────────\n\n/**\n * Map a generic sandbox mode to the executor-agnostic CLI sandbox mode.\n *\n * @param mode - Generic sandbox mode or undefined.\n * @returns CLI-compatible sandbox mode.\n */\nexport function resolveSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n  return normalizeSandboxMode(mode);\n}\n\n/**\n * Map a generic sandbox mode to the Claude Code permission mode.\n *\n * @param mode - Generic sandbox mode or undefined.\n * @returns Claude-compatible permission mode.\n */\nexport function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {\n  switch (normalizeSandboxMode(mode)) {\n    case 'read-only':\n      return 'plan';\n    case 'danger-full-access':\n      return 'bypassPermissions';\n    default:\n      return 'acceptEdits';\n  }\n}\n\n/**\n * Parse and validate a raw executor configuration.\n *\n * Normalizes legacy `type` fields, validates against the Zod schema,\n * and enforces executor-kind-specific field support.\n *\n * @param raw - Raw input to parse (JSON-parsed object).\n * @returns Validated ExecutorConfig.\n * @throws {@link ExecutorConfigError} If validation fails.\n */\nexport function parseExecutorConfig(raw: unknown): ExecutorConfig {\n  const parsed = executorConfigSchema.safeParse(normalizeExecutorConfigInput(raw));\n  if (!parsed.success) {\n    throw new ExecutorConfigError({\n      issues: normalizeIssues(parsed.error),\n    });\n  }\n\n  const config = parsed.data;\n  const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];\n  const unsupportedFields: string[] = [];\n  const allOptionalFields: (keyof ExecutorConfig)[] = [\n    'model',\n    'configDir',\n    'reasoningEffort',\n    'serviceTier',\n    'sandboxMode',\n    'timeoutSeconds',\n  ];\n\n  for (const field of allOptionalFields) {\n    if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {\n      unsupportedFields.push(field);\n    }\n  }\n\n  if (unsupportedFields.length > 0) {\n    throw new ExecutorConfigError({\n      issues: unsupportedFields.map((field) => ({\n        path: [field],\n        message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${\n          supportedFlags.length ? supportedFlags.join(', ') : 'none'\n        }.`,\n      })),\n    });\n  }\n\n  return config;\n}\n\n/**\n * Resolve an executor configuration by merging CLI and file sources.\n *\n * @param sources - CLI and file partial configs (CLI takes precedence).\n * @returns Validated ExecutorConfig.\n */\nexport function resolveExecutorConfig(sources: {\n  cli?: Partial<ExecutorConfig>;\n  file?: Partial<ExecutorConfig>;\n}): ExecutorConfig {\n  const merged = {\n    ...(sources.file ?? {}),\n    ...(sources.cli ?? {}),\n  };\n  return parseExecutorConfig(merged);\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 6. FAN-OUT CONFIG\n// ───────────────────────────────────────────────────────────────────\n//\n// Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n// the loop runs N executor \"lineages\" concurrently (capped), each running the\n// existing sequential loop in its own isolated sub-packet. The single-executor\n// path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n// default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n\nconst LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n\n/**\n * One fan-out lineage: a single executor config plus fan-out metadata.\n *\n * - `label`: directory-safe id for the lineage's isolated sub-packet.\n * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n * - `iterations`: per-lineage max-iterations override; null = packet default.\n * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n *   \"tidd-ec\") resolved against sk-prompt-models when a consumer renders the\n *   lineage prompt. null = consumer default. Loop-type-agnostic and optional, so\n *   research/review lineages that omit it are unaffected.\n * - `assignment_model`: defaults to the existing flat pool; `wave` is accepted\n *   only so the runtime guard can reject activation attempts explicitly.\n * - `depends_on` / `touches`: reserved dependency and path-domain metadata for\n *   a future guarded planner; flat-pool execution ignores them after logging.\n */\nexport const lineageExecutorSchema = executorConfigSchema.extend({\n  label: z.string().min(1).regex(LINEAGE_LABEL_PATTERN, {\n    message: \"label must match /^[a-z0-9][a-z0-9-]*$/ (lowercase, digits, hyphens; dir-safe)\",\n  }),\n  count: z.number().int().positive().default(1),\n  iterations: z.number().int().positive().nullable().default(null),\n  promptFramework: z.string().min(1).nullable().default(null),\n  assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n  depends_on: z.array(z.string().trim().min(1)).default([]),\n  touches: z.array(z.string().trim().min(1)).default([]),\n});\n\nexport type LineageExecutor = z.infer<typeof lineageExecutorSchema>;\n\nexport const fanoutConfigSchema = z.object({\n  executors: z.array(lineageExecutorSchema).min(1),\n  assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n  concurrency: z.number().int().positive().default(2),\n  maxRetries: z.number().int().nonnegative().default(5),\n  // Stall detection defaults ON: a lineage that stops emitting progress is aborted and\n  // requeued within the ceiling and fails loud, instead of hanging silently at 0% CPU\n  // until the hours-scale subprocess timeout. Set 0 to opt out.\n  lagCeilingMs: z.number().int().nonnegative().default(300000),\n  progressHeartbeatSeconds: z.number().nonnegative().default(60),\n});\n\nexport type FanoutConfig = z.infer<typeof fanoutConfigSchema>;\n\n/**\n * Parse and validate a raw fan-out configuration.\n *\n * Each entry's executor subset is routed through {@link parseExecutorConfig} so\n * ALL existing kind/model/flag rules apply per lineage with zero duplication.\n * Labels must be unique and base-label (count>1) expansion must not collide.\n *\n * @param raw - Raw input to parse (JSON-parsed object).\n * @returns Validated FanoutConfig.\n * @throws {@link ExecutorConfigError} If validation fails.\n */\nexport function parseFanoutConfig(raw: unknown): FanoutConfig {\n  const parsed = fanoutConfigSchema.safeParse(raw);\n  if (!parsed.success) {\n    throw new ExecutorConfigError({ issues: parsed.error.issues.map((issue) => ({ path: issue.path, message: issue.message })) });\n  }\n\n  const config = parsed.data;\n\n  // Reuse the canonical single-executor validator per entry (kind/model/flags).\n  config.executors.forEach((entry, index) => {\n    const {\n      label: _label,\n      count: _count,\n      iterations: _iterations,\n      promptFramework: _promptFramework,\n      assignment_model: _assignmentModel,\n      depends_on: _dependsOn,\n      touches: _touches,\n      ...executorSubset\n    } = entry;\n    try {\n      parseExecutorConfig(executorSubset);\n    } catch (err: unknown) {\n      if (err instanceof ExecutorConfigError) {\n        throw new ExecutorConfigError({\n          issues: err.issues.map((issue) => ({ path: ['executors', index, ...issue.path], message: issue.message })),\n        });\n      }\n      throw err;\n    }\n  });\n\n  // Labels must be unique among the declared lineages.\n  const seenLabels = new Set<string>();\n  config.executors.forEach((entry, index) => {\n    if (seenLabels.has(entry.label)) {\n      throw new ExecutorConfigError({\n        issues: [{ path: ['executors', index, 'label'], message: `duplicate lineage label '${entry.label}'` }],\n      });\n    }\n    seenLabels.add(entry.label);\n  });\n\n  // Expanded labels (count>1 → label-1, label-2, …) must not collide either.\n  const expandedLabels = new Set<string>();\n  for (const lineage of expandLineages(config)) {\n    if (expandedLabels.has(lineage.label)) {\n      throw new ExecutorConfigError({\n        issues: [{ path: ['executors'], message: `expanded lineage label '${lineage.label}' collides; rename base labels` }],\n      });\n    }\n    expandedLabels.add(lineage.label);\n  }\n\n  return config;\n}\n\n/**\n * Expand a fan-out config into concrete per-replica lineages.\n *\n * A `count` of 1 keeps the base label; `count > 1` yields `${label}-1` …\n * `${label}-N`. Each expanded lineage carries `count: 1` so downstream\n * consumers see one runnable unit per element.\n *\n * @param config - Validated FanoutConfig.\n * @returns Flat list of single-replica lineages (one runnable unit each).\n */\nexport function expandLineages(config: FanoutConfig): LineageExecutor[] {\n  const lineages: LineageExecutor[] = [];\n  for (const entry of config.executors) {\n    if (entry.count === 1) {\n      lineages.push({ ...entry, count: 1 });\n      continue;\n    }\n    for (let replica = 1; replica <= entry.count; replica += 1) {\n      lineages.push({ ...entry, label: `${entry.label}-${replica}`, count: 1 });\n    }\n  }\n  return lineages;\n}","lineStart":1,"lineEnd":376,"totalLines":376,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","time":{"start":1783488130571,"end":1783488130581}},"id":"prt_f402d2e09001o4gldoURUvv1Qi","sessionID":"ses_0bfd48e01ffew5W9Qhj3V2EB2W","messageID":"msg_f402d00ef001B7cYpUVMy0KQnn"}}
