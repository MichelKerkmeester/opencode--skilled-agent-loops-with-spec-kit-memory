es.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/013_add_created_by.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/022_add_relevance_signal.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/019_user_note.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/003_embedding_index.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/004_graph_reasoning.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/016_memory_layout.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/011_add_decay_score_and_archive.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/020_fts_coverage.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/002_phase2_columns.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/006_temporal_metadata.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/008_add_memory_provenance.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/010_memory_embeddings_split.sql\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/014_update_audit_op_check.sql","metadata":{"count":22,"truncated":false},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main","time":{"start":1780925341877,"end":1780925341912}},"metadata":{"openai":{"itemId":"fc_0765f137e9f02783016a26c39daeb08191b3c98b7ac3005369"}},"id":"prt_ea76c20b4001LxXYJAz6i0xlbs","sessionID":"ses_158954ac9ffePahLx5YfsvlJLH","messageID":"msg_ea76be466001gwQJbddIXqivKi"}}
