s,\n1586:   parseProcessRows,\n1587:   processLiveness,\n1588:   reapProcessTreeGroups,\n1589:   refreshDescendantSnapshot,\n1590:   resolvedDbDir,\n1591:   uncleanShutdownMarkerPath,\n1592:   uncleanMarkerPresent,\n1593:   cleanCloseAfterReap,\n1594:   reapLeaseChildBeforeRespawn,\n1595:   recycleDaemonInPlace,\n1596:   resolveModelServerSocketPath,\n1597:   sampleProcessTreeRssMb,\n1598:   shouldAbortRelaunchOnFire,\n1599:   shouldReleaseDaemonForReelection,\n1600:   shouldSkipLaunch,\n1601:   signalProcess,\n1602:   startModelServerDemandListener,\n1603:   startRssWatchdog,\n1604:   stopModelServerDemandListener,\n1605:   superviseChildExit,\n1606:   writeLeaseFile,\n1607:   writeSharedModelServerPid,\n1608: };\n1609: \n1610: if (require.main === module) {\n1611:   void main();\n1612: }\n\n(End of file - total 1612 lines)\n</content>","metadata":{"preview":"    }\n    void startModelServerDemandListener().catch((error) => {\n      log(`hf-model-server demand listener failed: ${error.stack || error.message}`);\n    });\n  } catch (error) {\n    try {\n      writeState({\n        command: 'mk-spec-memory-launcher',\n        start: started,\n        end: now(),\n        status: 'failed',\n        actions,\n        error: error.message,\n      });\n    } catch {\n      // If state logging itself fails, stderr still carries the actionable error.\n    }\n    log(error.stack || error.message);\n    process.exit(1);\n  } finally {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"    }\n    void startModelServerDemandListener().catch((error) => {\n      log(`hf-model-server demand listener failed: ${error.stack || error.message}`);\n    });\n  } catch (error) {\n    try {\n      writeState({\n        command: 'mk-spec-memory-launcher',\n        start: started,\n        end: now(),\n        status: 'failed',\n        actions,\n        error: e