s = Array.isArray(reducerState.questionConflicts)\n2196:     ? reducerState.questionConflicts\n2197:     : [];\n2198:   const carriedForwardOpenQuestions = buildCarriedForwardOpenQuestions({\n2199:     iterationFiles,\n2200:     iterationRecords,\n2201:     machineOpenQuestions: openQuestions,\n2202:   });\n2203:   const suppressedCandidates = buildSuppressedNextFocusCandidates({\n2204:     openQuestions,\n2205:     carriedForwardOpenQuestions,\n2206:     promotedIdeas: ideaBacklog.promotedIdeas,\n2207:     iterationFiles,\n2208:     iterationRecords,\n2209:     blockedStopHistory,\n2210:     rejectedIndex: rejectedPatternIndex,\n2211:   });\n2212:   const uncoveredQuestions = keyedQuestions.filter((question) => !question.resolved).map((question) => question.text);\n2213: \n2214:   return {\n2215:     sessionId: lineage.sessionId || '',\n2216:     parentSessionId: lineage.parentSessionId ?? null,\n2217:     lineageMode: lineage.lineageMode || 'new',\n2218:     generation: lineage.generation ?? 1,\n2219:     continuedFromRun: lineage.continuedFromRun ?? null,\n2220:     terminalStop: reducerState.terminalStop || null,\n2221:     keyQuestions: keyedQuestions.map((question) => ({\n2222:       ...buildQuestionFields(question),\n2223:       resolved: question.resolved,\n2224:     })),\n2225:     openQuestions,\n2226:     resolvedQuestions: keyedQuestions.filter((question) => question.resolved).map((question) => ({\n2227:       ...buildQuestionFields(question),\n2228:     })),\n2229:     carriedForwardOpenQuestions,\n2230:     uncoveredQuestions,\n2231:     keyFindings,\n2232:     ruledOutDirections,\n2233:     rejectedPatterns,\n2234:     rejectedPatternIndex: {\n2235:       maxEntries: rejectedPatternIndex.maxEntries,\n2236:       fuzzyThreshold: rejectedPatternIndex.fuzzyThreshold,\n2237:       entries: rejectedPatterns,\n2238:     },\n2239:     rejectedPatternWarnings: rejectedPatternIndex.warnings,\n2240:     suppressedCandidates,\n2241:     minIdeaObservations: idea