  \"d3\": {\n222:           \"score\": 0,\n223:           \"routedCount\": 2,\n224:           \"wastedCount\": 2,\n225:           \"proxy\": \"router-overload\",\n226:           \"note\": \"Mode A proxy; live-mode replaces with calls/tokens-to-first-expected\"\n227:         },\n228:         \"d1inter\": {\n229:           \"score\": 0,\n230:           \"rank\": null,\n231:           \"topSkill\": \"sk-doc\"\n232:         },\n233:         \"d4\": {\n234:           \"score\": null,\n235:           \"unscored\": \"requires skill-on/off ablation (live mode)\"\n236:         }\n237:       },\n238:       \"firstFailingStage\": \"activated-inter\",\n239:       \"modeAScore\": 55,\n240:       \"applicable\": true,\n241:       \"classKind\": \"advisor\",\n242:       \"expectedSurface\": null,\n243:       \"observedSurface\": \"OPENCODE\",\n244:       \"surfaceMatch\": null,\n245:       \"traceMode\": \"live\",\n246:       \"liveEvidence\": {\n247:         \"eventCount\": 14,\n248:         \"activated\": true,\n249:         \"toolCalls\": [\n250:           \"skill\",\n251:           \"glob\",\n252:           \"glob\",\n253:           \"glob\",\n254:           \"read\"\n255:         ],\n256:         \"observedReads\": [\n257:           \"references/opencode/**/*\",\n258:           \"references/*.md\",\n259:           \"assets/opencode/**/*\",\n260:           \"references/smart_routing.md\"\n261:         ],\n262:         \"statedRoutingParsed\": true,\n263:         \"responseHead\": \"```json\\n{\\\"surface\\\":\\\"OPENCODE\\\",\\\"subLanguage\\\":\\\"none\\\",\\\"resources\\\":[\\\"references/opencode/shared/universal_patterns.md\\\",\\\"references/opencode/shared/code_organization.md\\\"],\\\"assets\\\":[],\\\"agent\\\":\\\"none\\\",\\\"disambiguation\\\":false}\\n```\"\n264:       }\n265:     },\n266:     {\n267:       \"mode\": \"browser\",\n268:       \"classKind\": \"browser\",\n269:       \"scenarioId\": \"MR-001\",\n270:       \"tier\": \"browser-gated\",\n271:       \"modeAScore\": 100,\n272:       \"firstFailingStage\": null,\n273:       \"dims\": {\n274:         \"d1intra\": {\n275:           \"score\": 1\n276:         },\n277:         \"d2\": {\n278:           \"score\": 1\n279:         },\n280:         \"d3\": {\n281:           \"score\": 1\n282:         },\n\n(Showing lines 193-282 of 382. Use offset=283 to continue.)\n</content>","metadata":{"preview":"        \"observedReads\": [\n          \"references/smart_routing.md\",\n          \"references/stack_detection.md\",\n          \"references/opencode/typescript/*\",\n          \"assets/opencode/checklists/*\",\n          \"references/universal/*\",\n          \"references/phase_detection.md\",\n          \"references/opencode/shared/*\"\n        ],\n        \"statedRoutingParsed\": true,\n        \"responseHead\": \"```json\\n{\\\"surface\\\":\\\"OPENCODE\\\",\\\"subLanguage\\\":\\\"TYPESCRIPT\\\",\\\"resources\\\":[\\\"references/stack_detection.md\\\",\\\"references/smart_routing.md\\\",\\\"references/phase_detection.md\\\",\\\"references/universal/code_quality_standards.md\\\",\\\"references/universal/error_recovery.md\\\",\\\"references/opencode/shared/universal_patterns\"\n      }\n    },\n    {\n      \"scenarioId\": \"RD-002\",\n      \"tier\": \"live\",\n      \"dims\": {\n        \"d1intra\": {\n          \"score\": 1,\n          \"intentRecall\": null,","truncated":true,"loaded":[]},"title":".opencode/skills/sk-code/benchmark/live-remediated/skill-benchmark-report.json","time":{"start":1780373463197,"end":1780373463217}},"metadata":{"openai":{"itemId":"fc_0cf2b0cdc3122f5e016a1e57d71b7481918beabbaf758370cf"}},"id":"prt_e868720710011pwxN95IfRDSXE","sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","messageID":"msg_e8686f883001MK1WtD0lelDIDD"}}
{"type":"tool_use","timestamp":1780373463222,"sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","part":{"type":"tool","tool":"read","callID":"call_F9nBcj7VntvT3RkVm03JfiGV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * load-playbook-scenarios.cjs — corpus loader for Lane C.\n6:  *\n7:  * A skill's manual_testing_playbook is its authored, live-execution contract\n8:  * (\"Every scenario MUST be executed against the live skill — no mocks\"). It is\n9:  * a far better benchmark corpus than synthetic decontaminated fixtures: real\n10:  * prompts with real expected-routing gold. This module parses that playbook\n11:  * into one normalized scenario shape the orchestrator scores against.\n12:  *\n13:  * Two source shapes are supported:\n14:  *   1. The sk-code shape: a root index table (§ \"FEATURE CATALOG CROSS-REFERENCE\n15:  *      INDEX\") enumerating {id, per-feature file, critical}, plus per-feature\n16:  *      files carrying the exact prompt + expected references/assets + pass rules.\n17:  *   2. The sk-doc shape: per-scenario files whose YAML frontmatter carries\n18:  *      expected_intent / expected_resources (no root index table).\n19:  *\n20:  * Gold is captured AS AUTHORED. We deliberately do NOT assert that an expected\n21:  * path exists on disk — a stale expectation (e.g. a renamed reference) is a real\n22:  * finding the scorer should surface as router↔gold drift, not silently drop.\n23:  */\n24: \n25: const fs = require('fs');\n26: const path = require('path');\n27: \n28: const ID_RE = /\\b([A-Z]{2})-(\\d{3})\\b/;\n29: \n30: // classKind selects the executor: routing/advisor run via router-replay or live\n31: // cli-opencode; browser scenarios need a real browser (bdg) and are routed out\n32: // of the text executors.\n33: function classifyKind(scenarioId, category, expectedSurface, passCriteria) {\n34:   const cat = (category || '').toLowerCase();\n35:   const prefix = (ID_RE.exec(scenarioId || '') || [])[1] || '';\n36:   if (/motion|animation|browser|performance|visual|compositing|cross-browser/.test(cat)\n37:       || prefix === 'MR' || prefix === 'CB') {\n38:     return 'browser';\n39:   }\n40:   // A scenario that asserts an in-skill SURFACE is a routing test (the advisor\n41:   // check is just its precondition). Advisor-class is reserved for scenarios\n42:   // whose WHOLE test is skill selection — no surface — run as a skill_advisor.py\n43:   // probe (SA-*, and the sk-code-vs-sk-doc anti-pattern).\n44:   if (expectedSurface) return 'routing';\n45:   const pass = (passCriteria || '').toLowerCase();\n46:   if (prefix === 'SA' || /top-1\\s*(!=|==)|routes? .* to sk-doc|advisor (top-1|wins)/.test(pass)) {\n47:     return 'advisor';\n48:   }\n49:   return 'routing';\n50: }\n51: \n52: function readFileSafe(p) {\n53:   try { return fs.readFileSync(p, 'utf8'); } catch { return null; }\n54: }\n55: \n56: // Pull every `references/...` / `assets/...` markdown-ish path token out of a\n57: // text block, deduped, order-preserving. Tolerates backticks, bullets, and\n58: // trailing parentheticals like \"(when intent is X)\".\n59: function extractPaths(block) {\n60:   if (!block) return [];\n61:   const out = [];\n62:   const seen = new Set();\n63:   const re = /(?:references|assets)\\/[A-Za-z0-9_./-]+\\.[a-z]{1,4}/g;\n64:   let m;\n65:   while ((m = re.exec(block)) !== null) {\n66:     const p = m[0];\n67:     if (!seen.has(p)) { seen.add(p); out.push(p); }\n68:   }\n69:   return out;\n70: }\n71: \n72: // Grab the text between a `**Label**` marker and the next bold marker / heading.\n73: function sectionAfter(text, labelRe) {\n74:   const start = text.search(labelRe);\n75:   if (start === -1) return '';\n76:   const rest = text.slice(start);\n77:   const endRel = rest.slice(1).search(/\\n\\s*(?:\\*\\*[A-Z]|#{1,3}\\s|\\d+\\.\\s+[A-Z])/);\n78:   return endRel === -1 ? rest : rest.slice(0, endRel + 1);\n79: }\n80: \n81: function parsePromptBlock(text) {\n82:   // ```[lang]\\n<prompt>\\n``` after the prompt marker. Per-feature files vary:\n83:   // SD/LS/RD use \"**Exact prompt**\", CS use \"**Realistic user prompt**\".\n84:   const m = /\\*\\*(?:Exact prompt|Realistic user prompt)\\*\\*:?\\s*\\n+```[a-z]*\\n([\\s\\S]*?)\\n```/i.exec(text);\n85:   if (m) return m[1].trim();\n86:   // sk-doc / inline shape: \"Prompt: ...\" line.\n87:   const inline = /(?:^|\\n)\\s*(?:\\*\\*)?Prompt(?:\\*\\*)?:\\s*(.+)/i.exec(text);\n88:   return inline ? inline[1].trim() : null;\n89: }\n90: \n91: // The root §7-13 tables carry the \"Exact Prompt\" column for every scenario in a\n92: // uniform 9-column shape — the authoritative prompt source when a per-feature\n93: // file uses a non-standard marker or omits the fenced block.\n94: function parseRootScenarioTables(rootText) {\n95:   const map = {};\n96:   for (const line of rootText.split('\\n')) {\n97:     if (!/^\\|/.test(line)) continue;\n98:     const cells = line.split('|').map((c) => c.trim());\n99:     // Leading/trailing empties from the bounding pipes -> cells[1] is Feature ID.\n100:     const idCell = (cells[1] || '').replace(/`/g, '');\n101:     if (!/^[A-Z]{2}-\\d{3}$/.test(idCell)) continue;\n102:     if (cells.length < 9) continue; // not a §7-13 scenario row\n103:     const prompt = (cells[4] || '').replace(/^`|`$/g, '').trim();\n104:     map[idCell] = {\n105:       prompt: /multi-prompt battery|see per-feature/i.test(prompt) ? null : (prompt || null),\n106:       expectedSignals: cells[6] || null,\n107:       passCriteria: cells[8] || null,\n108:     };\n109:   }\n110:   return map;\n111: }\n112: \n113: function parseFeatureFile(absPath, scenarioId, category, critical, rootEntry) {\n114:   const text = readFileSafe(absPath);\n115:   if (!text) return null;\n116: \n117:   const fmId = (/title:\\s*[\"']?([A-Z]{2}-\\d{3})/.exec(text) || [])[1];\n118:   const id = scenarioId || fmId;\n119:   if (!id) return null;\n120: \n121:   const prompt = parsePromptBlock(text) || (rootEntry && rootEntry.prompt) || null;\n122:   // Per-feature files vary: \"- Surface: `WEBFLOW`\" (SD/LS) vs \"**Expected surface**: `WEBFLOW`\" (CS).\n123:   const surfaceM = /(?:Expected\\s+)?Surface\\*{0,2}:\\s*`?([A-Za-z_]+)`?/i.exec(text);\n124:   const subLangM = /Sub-language:\\s*`?([A-Za-z]+)`?/i.exec(text);\n125:   const refBlock = sectionAfter(text, /\\*\\*Expected references loaded\\*\\*/i);\n126:   const assetBlock = sectionAfter(text, /\\*\\*Expected assets loaded\\*\\*/i);\n127:   const passM = /###?\\s*Pass\\/Fail Criteria\\s*([\\s\\S]*?)(?:\\n###?\\s|\\n##\\s|$)/i.exec(text);\n128:   const passCriteria = (passM ? passM[1].trim() : null) || (rootEntry && rootEntry.passCriteria) || null;\n129: \n130:   const KNOWN_SURFACES = new Set(['WEBFLOW', 'OPENCODE', 'UNKNOWN', 'MOTION_DEV', 'NONE']);\n131:   const surfaceRaw = surfaceM ? surfaceM[1].toUpperCase() : null;\n132:   const expectedSurface = KNOWN_SURFACES.has(surfaceRaw) ? surfaceRaw : null;\n133:   const expectedResources = extractPaths(refBlock);\n134:   const expectedAssets = extractPaths(assetBlock);\n135: \n136:   // Negative activation: the skill should NOT route here (UNKNOWN surface,\n137:   // disambiguation expected, or advisor must pick another skill).\n138:   const lowerPass = (passCriteria || '').toLowerCase();\n139:   const negativeActivation = expectedSurface === 'UNKNOWN'\n140:     || /disambiguation|must not|asks? for clarification|top-1\\s*!=\\s*sk-code|routes? .* to sk-doc/.test(lowerPass)\n141:     || /\\bUNKNOWN\\b/.test(text.split('\\n').slice(0, 30).join('\\n'));\n142: \n143:   const classKind = classifyKind(id, category, expectedSurface, passCriteria);\n144: \n145:   return {\n146:     scenarioId: id,\n147:     category: category || null,\n148:     prompt: prompt || null,\n149:     classKind,\n150:     expectedSurface,\n151:     expectedSubLanguage: subLangM ? subLangM[1].toUpperCase() : null,\n152:     expectedIntent: null,\n153:     expectedResources,\n154:     expectedAssets,\n155:     passCriteria,\n156:     critical: !!critical,\n157:     negativeActivation,\n158:     source: { featureFile: path.relative(path.dirname(path.dirname(absPath)), absPath), shape: 'sk-code' },\n159:     parseWarnings: prompt ? [] : ['missing-exact-prompt'],\n160:   };\n161: }\n162: \n163: // Parse the root index table mapping id -> {category, featureFile, critical}.\n164: function parseRootIndex(rootText) {\n165:   const idx = [];\n166:   const secStart = rootText.search(/##\\s+\\d+\\.\\s+FEATURE CATALOG CROSS-REFERENCE INDEX/i);\n167:   const scope = secStart === -1 ? rootText : rootText.slice(secStart);\n168:   for (const line of scope.split('\\n')) {\n169:     // Row shape parsed below: | <category> | <AA-000> | `<feature-file>.md` | <Yes|No> |\n170:     const m = /^\\|\\s*([^|]+?)\\s*\\|\\s*([A-Z]{2}-\\d{3})\\s*\\|\\s*`?([^|`]+?\\.md)`?\\s*\\|\\s*(Yes|No)\\s*\\|/.exec(line);\n171:     if (m) {\n172:       idx.push({\n173:         categoryLabel: m[1].trim(),\n174:         scenarioId: m[2],\n175:         featureFile: m[3].trim(),\n176:         critical: /yes/i.test(m[4]),\n177:       });\n178:     }\n179:   }\n180:   return idx;\n181: }\n182: \n183: // sk-doc shape: walk per-scenario files, read YAML frontmatter gold.\n184: function loadYamlFrontmatterScenarios(playbookDir) {\n185:   const out = [];\n186:   const stack = [playbookDir];\n187:   while (stack.length) {\n188:     const cur = stack.pop();\n189:     let entries;\n190:     try { entries = fs.readdirSync(cur, { withFileTypes: true }); } catch { continue; }\n191:     for (const e of entries) {\n192:       const full = path.join(cur, e.name);\n193:       if (e.isDirectory()) { stack.push(full); continue; }\n194:       if (!e.isFile() || !/^\\d{3}-.*\\.md$/.test(e.name)) continue;\n195:       const text = readFileSafe(full);\n196:       if (!text) continue;\n197:       const fm = /^---\\n([\\s\\S]*?)\\n---/.exec(text);\n198:       if (!fm) continue;\n199:       const block = fm[1];\n200:       const idM = /(?:^|\\n)id:\\s*[\"']?([A-Za-z0-9-]+)/.exec(block);\n201:       const intentM = /expected_intent:\\s*[\"']?([A-Za-z_]+)/.exec(block);\n202:       const resM = /expected_resources:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/.exec(block);\n203:       const resources = resM ? extractPaths(resM[1]) : [];\n204:       const category = path.basename(cur);\n205:       const prompt = parsePromptBlock(text);\n206:       const id = idM ? idM[1] : e.name.replace(/\\.md$/, '');\n207:       out.push({\n208:         scenarioId: id,\n209:         category,\n210:         prompt: prompt || null,\n211:         classKind: classifyKind(id, category, null, intentM ? intentM[1] : ''),\n212:         expectedSurface: null,\n213:         expectedSubLanguage: null,\n214:         expectedIntent: intentM ? intentM[1] : null,\n215:         expectedResources: resources,\n216:         expectedAssets: [],\n217:         passCriteria: null,\n218:         critical: false,\n219:         negativeActivation: false,\n220:         source: { featureFile: path.relative(playbookDir, full), shape: 'sk-doc' },\n221:         parseWarnings: prompt ? [] : ['missing-exact-prompt'],\n222:       });\n223:     }\n224:   }\n225:   return out;\n226: }\n227: \n228: /**\n229:  * @returns {{ scenarios: Array, shape: 'sk-code'|'sk-doc'|'none', warnings: string[] }}\n230:  */\n231: function loadPlaybookScenarios({ skillRoot, playbookDir } = {}) {\n232:   const dir = playbookDir || path.join(skillRoot, 'manual_testing_playbook');\n233:   const warnings = [];\n234:   if (!fs.existsSync(dir)) {\n235:     return { scenarios: [], shape: 'none', warnings: [`no playbook at ${dir}`] };\n236:   }\n237:   const rootPath = path.join(dir, 'manual_testing_playbook.md');\n238:   const rootText = readFileSafe(rootPath);\n239:   const index = rootText ? parseRootIndex(rootText) : [];\n240:   const rootMap = rootText ? parseRootScenarioTables(rootText) : {};\n241: \n242:   if (index.length > 0) {\n243:     const scenarios = [];\n244:     for (const row of index) {\n245:       const abs = path.join(dir, row.featureFile);\n246:       const parsed = parseFeatureFile(abs, row.scenarioId, row.categoryLabel, row.critical, rootMap[row.scenarioId]);\n247:       if (parsed) {\n248:         if (parsed.parseWarnings.length) warnings.push(`${row.scenarioId}: ${parsed.parseWarnings.join(',')}`);\n249:         scenarios.push(parsed);\n250:       } else {\n251:         warnings.push(`${row.scenarioId}: feature file unreadable (${row.featureFile})`);\n252:       }\n253:     }\n254:     return { scenarios, shape: 'sk-code', warnings };\n255:   }\n256: \n257:   // No root index table -> sk-doc YAML-frontmatter shape.\n258:   const scenarios = loadYamlFrontmatterScenarios(dir);\n259:   return { scenarios, shape: scenarios.length ? 'sk-doc' : 'none', warnings };\n260: }\n\n(Showing lines 1-260 of 271. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * load-playbook-scenarios.cjs — corpus loader for Lane C.\n *\n * A skill's manual_testing_playbook is its authored, live-execution contract\n * (\"Every scenario MUST be executed against the live skill — no mocks\"). It is\n * a far better benchmark corpus than synthetic decontaminated fixtures: real\n * prompts with real expected-routing gold. This module parses that playbook\n * into one normalized scenario shape the orchestrator scores against.\n *\n * Two source shapes are supported:\n *   1. The sk-code shape: a root index table (§ \"FEATURE CATALOG CROSS-REFERENCE\n *      INDEX\") enumerating {id, per-feature file, critical}, plus per-feature\n *      files carrying the exact prompt + expected references/assets + pass rules.\n *   2. The sk-doc shape: per-scenario files whose YAML frontmatter carries\n *      expected_intent / expected_resources (no root index table).\n *\n * Gold is captured AS AUTHORED. We deliberately do NOT assert that an expected","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","time":{"start":1780373463203,"end":1780373463219}},"metadata":{"openai":{"itemId":"fc_0cf2b0cdc3122f5e016a1e57d71b888191adf81d827a975d5b"}},"id":"prt_e8687209f001wjIthPsaGkSov0","sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","messageID":"msg_e8686f883001MK1WtD0lelDIDD"}}
{"type":"tool_use","timestamp":1780373463223,"sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","part":{"type":"tool","tool":"read","callID":"call_yOOK6KYa1dkPZAGEOVl4HRUm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/01--surface-detection/001-webflow-detection.md","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/01--surface-detection/001-webflow-detection.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"SD-001: WEBFLOW Surface Detection\"\n3: description: \"Verify sk-code routes vanilla-JS / animation-library prompts to the WEBFLOW surface and loads the webflow/* reference and asset trees.\"\n4: ---\n5: \n6: # SD-001: WEBFLOW Surface Detection\n7: \n8: ## 1. OVERVIEW\n9: \n10: This scenario verifies that sk-code's smart router correctly identifies WEBFLOW as the active code surface when the prompt references vanilla-JS animation libraries (motion.dev, GSAP, Lenis, HLS, Swiper, FilePond) or marker file paths (`src/2_javascript/`, `*.webflow.js`, `wrangler.toml`).\n11: \n12: WEBFLOW is the frontend HTML/CSS/JS surface for Webflow / vanilla-animation projects. When detected, sk-code MUST load `references/webflow/*` and `assets/webflow/*` and SHOULD NOT load any `references/opencode/*` resources.\n13: \n14: Detection markers are defined verbatim in `references/stack_detection.md:30-37`.\n15: \n16: ## 2. SCENARIO CONTRACT\n17: \n18: **Realistic user request**: A frontend developer working on a Webflow site asks the AI to add smooth-scroll behavior using the Lenis library, gated behind an IntersectionObserver so it only initializes once the user scrolls into the hero section.\n19: \n20: **Exact prompt**:\n21: ```\n22: Add Lenis smooth-scroll to src/2_javascript/scroll.js, gated by IntersectionObserver when the hero becomes visible.\n23: ```\n24: \n25: **Expected detection**:\n26: - Surface: `WEBFLOW`\n27: - Triggering markers: `src/2_javascript/` (path marker) AND `Lenis` (library marker) → either alone is sufficient per `code_surface_detection.md:30-37`.\n28: \n29: **Expected references loaded** (exact relative paths under `.opencode/skills/sk-code/`):\n30: - `references/stack_detection.md` (always loaded for router decision)\n31: - `references/smart_routing.md`\n32: - `references/smart_routing.md`\n33: - `references/phase_detection.md`\n34: - `references/universal/code_quality_standards.md`\n35: - `references/webflow/implementation/webflow_patterns.md`\n36: - `references/webflow/implementation/animation_workflows.md`\n37: - `references/webflow/implementation/observer_patterns.md`\n38: - `references/webflow/javascript/quality_standards.md`\n39: - `references/webflow/javascript/style_guide.md`\n40: - `references/webflow/css/style_guide.md`\n41: - `references/webflow/shared/cross_language_rules.md`\n42: \n43: **Expected assets loaded**:\n44: - `assets/webflow/checklists/code_quality_checklist.md`\n45: - `assets/webflow/patterns/interaction_gate_patterns.js` (when intent is implementation gating)\n46: \n47: **Expected NOT loaded**: any `references/opencode/*` or `assets/opencode/*` (would indicate misrouting).\n48: \n49: **Expected agent dispatch**: `@code` (LEAF) for the actual edit, dispatched ONLY by `@orchestrate`. If the user prompt is invoked directly without orchestration, the AI may apply the change inline using sk-code guidance without dispatching @code.\n50: \n51: **Desired user-visible outcome**: The AI applies the edit to `src/2_javascript/scroll.js`, citing webflow-specific patterns (IntersectionObserver gate from `assets/webflow/patterns/interaction_gate_patterns.js`) and confirming the modification with a Lenis initializer + observer fence.\n52: \n53: ## 3. TEST EXECUTION\n54: \n55: ### Preconditions\n56: \n57: 1. `.opencode/skills/sk-code/SKILL.md` is at HEAD-of-main.\n58: 2. `references/stack_detection.md:30-37` contains the WEBFLOW marker block (verify with `head -40 .opencode/skills/sk-code/references/stack_detection.md`).\n59: 3. Sandbox: create `/tmp/skc-SD001-sandbox/src/2_javascript/scroll.js` with placeholder content (the AI doesn't need to actually write — we're testing routing).\n60: 4. Skill advisor binary callable: `python3 .opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py --help` exits 0.\n61: \n62: ### Exact Command Sequence\n63: \n64: 1. **Skill advisor probe**:\n65:    ```\n66:    bash: python3 .opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py \"Add Lenis smooth-scroll to src/2_javascript/scroll.js, gated by IntersectionObserver when the hero becomes visible.\" --threshold 0.8 > /tmp/skc-SD001-advisor.txt\n67:    ```\n68: 2. **Verify advisor result**: top-1 == `sk-code`, score ≥ 0.80.\n69: 3. **Invoke sk-code** in the orchestrator runtime by feeding the same prompt.\n70: 4. **Capture sk-code output**: which surface did it report? Which references did it list as loaded?\n71: 5. **Persist evidence**: save the AI's response (including its surface-detection log line and its loaded-refs list) to `/tmp/skc-SD001-loaded-refs.txt`.\n72: \n73: ### Expected Signals (per step)\n74: \n75: | Step | Signal |\n76: |---|---|\n77: | 1 | Advisor returns JSON with `top_skill: \"sk-code\"`, `score: ≥ 0.80`. |\n78: | 2 | Pass — proceed. |\n79: | 3 | sk-code SKILL.md is loaded; the AI runs the smart router pseudocode and emits `SURFACE: WEBFLOW`. |\n80: | 4 | The AI lists `references/webflow/implementation/*` as loaded; lists `assets/webflow/checklists/code_quality_checklist.md` as loaded; does NOT list any `references/opencode/*`. |\n81: | 5 | Evidence file contains all of the above. |\n82: \n83: ### Pass/Fail Criteria\n84: \n85: - **PASS** iff:\n86:   - Advisor wins sk-code at score ≥ 0.80.\n87:   - sk-code reports surface == WEBFLOW.\n88:   - Loaded references include at least 3 paths under `references/webflow/implementation/`.\n89:   - Loaded references DO NOT include any `references/opencode/`.\n90: - **PARTIAL** iff:\n91:   - Surface correct, but the AI loads extra `universal/` resources beyond the listed expectations (acceptable drift).\n92: - **FAIL** iff:\n93:   - Advisor loses sk-code, OR surface != WEBFLOW, OR any `references/opencode/*` is loaded.\n94: \n95: ### Failure Triage\n96: \n97: 1. If advisor doesn't win sk-code: check `skill-graph.json` `sk-code.signals` array — ensure \"webflow\", \"frontend\", \"animation\" are present.\n98: 2. If surface != WEBFLOW: re-read `references/stack_detection.md:30-37` and verify the markers in the prompt actually match the regex/grep patterns.\n99: 3. If `references/opencode/*` is loaded: the router is mis-classifying. Check whether the CWD shell variable (`PWD`) accidentally contains `/.opencode/` (would trigger OPENCODE) — the marker priority is documented in SKILL.md smart router pseudocode.\n100: \n101: ## 4. SOURCE FILES\n102: \n103: - `.opencode/skills/sk-code/SKILL.md` — Smart router pseudocode (lines 53-68).\n104: - `.opencode/skills/sk-code/references/stack_detection.md` — WEBFLOW marker definitions (lines 30-37).\n105: - `.opencode/skills/sk-code/references/smart_routing.md` — Intent → resource-loading mapping.\n106: - `.opencode/skills/sk-code/references/webflow/implementation/webflow_patterns.md` — Expected-loaded reference.\n107: - `.opencode/skills/system-skill-advisor/mcp_server/scripts/skill-graph.json` — sk-code signals + adjacency.\n108: \n109: ## 5. SOURCE METADATA\n110: \n111: - **Created**: 2026-05-04\n112: - **Critical path**: Yes\n113: - **Destructive**: No (read-only routing test)\n114: - **Sandbox**: `/tmp/skc-SD001-sandbox/`\n115: - **Concurrent-safe**: Yes (no agent dispatch)\n116: - **Last validated**: pending first manual run\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"---\ntitle: \"SD-001: WEBFLOW Surface Detection\"\ndescription: \"Verify sk-code routes vanilla-JS / animation-library prompts to the WEBFLOW surface and loads the webflow/* reference and asset trees.\"\n---\n\n# SD-001: WEBFLOW Surface Detection\n\n## 1. OVERVIEW\n\nThis scenario verifies that sk-code's smart router correctly identifies WEBFLOW as the active code surface when the prompt references vanilla-JS animation libraries (motion.dev, GSAP, Lenis, HLS, Swiper, FilePond) or marker file paths (`src/2_javascript/`, `*.webflow.js`, `wrangler.toml`).\n\nWEBFLOW is the frontend HTML/CSS/JS surface for Webflow / vanilla-animation projects. When detected, sk-code MUST load `references/webflow/*` and `assets/webflow/*` and SHOULD NOT load any `references/opencode/*` resources.\n\nDetection markers are defined verbatim in `references/stack_detection.md:30-37`.\n\n## 2. SCENARIO CONTRACT\n\n**Realistic user request**: A frontend developer working on a Webflow site asks the AI to add smooth-scroll behavior using the Lenis library, gated behind an IntersectionObserver so it only initializes once the user scrolls into the hero section.\n\n**Exact prompt**:","truncated":false,"loaded":[]},"title":".opencode/skills/sk-code/manual_testing_playbook/01--surface-detection/001-webflow-detection.md","time":{"start":1780373463207,"end":1780373463220}},"metadata":{"openai":{"itemId":"fc_0cf2b0cdc3122f5e016a1e57d71b908191a04b3a48a7c2edfd"}},"id":"prt_e868720a4001MWCRkFPehhzPFt","sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","messageID":"msg_e8686f883001MK1WtD0lelDIDD"}}
{"type":"tool_use","timestamp":1780373463223,"sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","part":{"type":"tool","tool":"read","callID":"call_8Wrkh87oCsFdeRFGxQWhmWNF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/07--cross-stack-routing/018-webflow-plus-motion-dev.md","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/07--cross-stack-routing/018-webflow-plus-motion-dev.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"CS-001: WEBFLOW Plus Motion.dev Peer References\"\n3: description: \"Verify WEBFLOW animation work also loads cross-stack motion_dev references and assets when the user request uses Motion.dev APIs.\"\n4: ---\n5: \n6: # CS-001: WEBFLOW Plus Motion.dev Peer References\n7: \n8: ## 1. OVERVIEW\n9: \n10: This scenario verifies the primary cross-stack route: a Webflow frontend request still detects `WEBFLOW`, then loads `motion_dev/` as a peer resource category for Motion.dev API details. The AI must not treat `motion_dev/` as a third surface and must not skip Webflow implementation and verification guidance.\n11: \n12: ---\n13: \n14: ## 2. SCENARIO CONTRACT\n15: \n16: **Realistic user prompt**:\n17: ```text\n18: For a Webflow hero in src/2_javascript/hero.js, show the pinned Motion CDN pattern and in-view animation snippet.\n19: ```\n20: \n21: **Expected detection markers** (verbatim from `references/stack_detection.md`):\n22: ```bash\n23: # 2. WEBFLOW\n24: [ -d \"src/2_javascript\" ]\n25: ls *.webflow.js 2>/dev/null | head -1\n26: grep -lq \"Webflow\\.push\\|--vw-\" src/**/*.{js,css,html} 2>/dev/null\n27: grep -lqE \"window\\.Motion|window\\.gsap|gsap\\.(to|from|set|timeline|registerPlugin)|new Lenis|new Hls|new Swiper|FilePond\" \\\n28:   src/**/*.{js,mjs,ts,html} *.{js,mjs,ts,html} 2>/dev/null\n29: [ -f \"wrangler.toml\" ]\n30: ```\n31: \n32: **Expected surface**: `WEBFLOW`\n33: \n34: **Expected references loaded** (exact relative paths under `.opencode/skills/sk-code/`):\n35: - `references/stack_detection.md`\n36: - `references/smart_routing.md`\n37: - `references/smart_routing.md`\n38: - `references/webflow/implementation/animation_workflows.md`\n39: - `references/webflow/implementation/observer_patterns.md`\n40: - `references/webflow/implementation/third_party_integrations.md`\n41: - `references/webflow/verification/verification_workflows.md`\n42: - `references/motion_dev/quick_start.md`\n43: - `references/motion_dev/integration_patterns.md`\n44: - `references/motion_dev/scroll_and_gestures.md`\n45: - `references/motion_dev/performance_and_pitfalls.md`\n46: \n47: **Expected assets loaded**:\n48: - `assets/webflow/checklists/code_quality_checklist.md`\n49: - `assets/webflow/checklists/verification_checklist.md`\n50: - `assets/motion_dev/install_card.md`\n51: - `assets/motion_dev/snippets/in_view_reveal.js`\n52: - `assets/motion_dev/snippets/cdn_bootstrap.js`\n53: \n54: **Expected agent dispatch**: none for this read-only routing-analysis harness. If the same prompt were implementation work, `@code` could be dispatched by an orchestrator, but this scenario forbids dispatch.\n55: \n56: **Pass/fail criteria with binary grading**:\n57: - **PASS** iff surface is `WEBFLOW`, at least one `references/webflow/implementation/*` path loads, `references/motion_dev/quick_start.md` and `assets/motion_dev/snippets/in_view_reveal.js` load, and `agent_dispatched` is `none`.\n58: - **FAIL** iff surface is not `WEBFLOW`, Motion.dev peer references are omitted, or any agent is dispatched.\n59: \n60: **Failure triage**:\n61: 1. If surface is not `WEBFLOW`, verify the prompt includes `src/2_javascript/` and Webflow terms.\n62: 2. If Motion.dev paths are missing, inspect `references/smart_routing.md` Section 3.\n63: 3. If an agent was dispatched, verify the universal prompt says analyze only and \"DO NOT dispatch any agent.\"\n64: \n65: ---\n66: \n67: ## 3. TEST EXECUTION\n68: \n69: Run this scenario through the Phase 005 universal prompt using `SCENARIO_ID=CS-001`. Capture the runtime YAML result and raw transcript.\n70: \n71: Expected result files:\n72: - `/tmp/skc-CS-001-<cli>.txt`\n73: - `<spec-folder><cli>.yaml`\n74: \n75: ---\n76: \n77: ## 4. SOURCE FILES\n78: \n79: - `.opencode/skills/sk-code/references/stack_detection.md` - WEBFLOW marker block.\n80: - `.opencode/skills/sk-code/references/smart_routing.md` - WEBFLOW plus MOTION_DEV loading rules.\n81: - `.opencode/skills/sk-code/references/motion_dev/quick_start.md` - Motion install and import guidance.\n82: - `.opencode/skills/sk-code/assets/motion_dev/snippets/in_view_reveal.js` - Required snippet.\n83: \n84: ---\n85: \n86: ## 5. SOURCE METADATA\n87: \n88: - **Created**: 2026-05-05\n89: - **Critical path**: Yes\n90: - **Destructive**: No\n91: - **Sandbox**: read-only routing analysis\n92: - **Concurrent-safe**: Yes\n93: - **Last validated**: pending Phase D matrix\n\n(End of file - total 93 lines)\n</content>","metadata":{"preview":"---\ntitle: \"CS-001: WEBFLOW Plus Motion.dev Peer References\"\ndescription: \"Verify WEBFLOW animation work also loads cross-stack motion_dev references and assets when the user request uses Motion.dev APIs.\"\n---\n\n# CS-001: WEBFLOW Plus Motion.dev Peer References\n\n## 1. OVERVIEW\n\nThis scenario verifies the primary cross-stack route: a Webflow frontend request still detects `WEBFLOW`, then loads `motion_dev/` as a peer resource category for Motion.dev API details. The AI must not treat `motion_dev/` as a third surface and must not skip Webflow implementation and verification guidance.\n\n---\n\n## 2. SCENARIO CONTRACT\n\n**Realistic user prompt**:\n```text\nFor a Webflow hero in src/2_javascript/hero.js, show the pinned Motion CDN pattern and in-view animation snippet.\n```\n","truncated":false,"loaded":[]},"title":".opencode/skills/sk-code/manual_testing_playbook/07--cross-stack-routing/018-webflow-plus-motion-dev.md","time":{"start":1780373463211,"end":1780373463222}},"metadata":{"openai":{"itemId":"fc_0cf2b0cdc3122f5e016a1e57d71b988191a9b03bd9da50b0bd"}},"id":"prt_e868720a8001QhdqsjcgRYjSpN","sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","messageID":"msg_e8686f883001MK1WtD0lelDIDD"}}
{"type":"step_finish","timestamp":1780373463490,"sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","part":{"id":"prt_e868721c1001RnwjM5sfHe5qjl","reason":"tool-calls","snapshot":"635d89d24f31a5a2bd66533878db9d20269e1a76","messageID":"msg_e8686f883001MK1WtD0lelDIDD","sessionID":"ses_1797a1220ffefMR5XwHZad3Rpm","type":"step-finish","tokens":{"total":77653,"input":7575,"output":340,"reasoning":106,"cache":{"write":0,"read":69632}},"cost":0}}
