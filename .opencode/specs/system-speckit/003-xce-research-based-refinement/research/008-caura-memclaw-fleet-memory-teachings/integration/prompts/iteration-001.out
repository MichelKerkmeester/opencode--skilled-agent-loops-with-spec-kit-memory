r\nimport type { MCPCallerContext } from '../lib/context/caller-context.js';\n\nexport { contextTools, memoryTools, causalTools, checkpointTools, lifecycleTools };\n\nexport type { MCPResponse } from './types.js';\n\n/** All tool dispatch modules in priority order */\nexport const ALL_DISPATCHERS = [\n  contextTools,\n  memoryTools,\n  causalTools,\n  checkpointTools,\n  lifecycleTools,\n  // codeGraphTools intentionally omitted: standalone system_code_graph owns MCP dispatch\n  // skillGraphTools intentionally omitted: standalone mk_skill_advisor owns MCP dispatch\n] as const;\n\n/** Dispatch a tool call to the appropriate module. Returns null if unrecognized. */\nexport async function dispatchTool(\n  name: string,\n  args: Record<string, unknown>,\n  callerContext?: MCPCallerContext | null,\n): Promise<import('./types.js').MCPResponse | null> {\n  for (const dispatcher of ALL_DISPATCHERS) {\n    if (dispatcher.TOOL_NAMES.has(name)) {\n      return dispatcher.handleTool(name, args);\n    }\n  }\n  return null;\n}","lineStart":1,"lineEnd":40,"totalLines":40,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tools/index.ts","time":{"start":1780738287507,"end":1780738287529}},"metadata":{"openai":{"itemId":"fc_01ed494ef25e8706016a23e8ef7014819181436f4b1ad135a0"}},"id":"prt_e9c45e784001w5GTlioC9kmU52","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c45bf8d001TjF1lUiSO3kqX7"}}
{"type":"tool_use","timestamp":1780738287642,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_An9BVEQX5lnmu6GhwxiICxOh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/memory-tools.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/memory-tools.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Tools\n3: // ───────────────────────────────────────────────────────────────\n4: // Dispatch for L2-L4 memory tools: search, triggers, save,\n5: // List, stats, health, delete, update, validate.\n6: import {\n7:   handleMemorySearch,\n8:   handleMemoryMatchTriggers,\n9:   handleMemorySave,\n10:   handleMemoryList,\n11:   handleMemoryStats,\n12:   handleMemoryHealth,\n13:   handleMemoryDelete,\n14:   handleMemoryUpdate,\n15:   handleMemoryValidate,\n16:   handleMemoryBulkDelete,\n17:   handleMemoryRetentionSweep,\n18:   handleMemoryEmbeddingReconcile,\n19:   handleEmbedderList,\n20:   handleEmbedderSet,\n21:   handleEmbedderStatus,\n22: } from '../handlers/index.js';\n23: import { validateToolArgs } from '../schemas/tool-input-schemas.js';\n24: \n25: import { parseArgs } from './types.js';\n26: import type {\n27:   MCPResponse,\n28:   SearchArgs,\n29:   TriggerArgs,\n30:   SaveArgs,\n31:   ListArgs,\n32:   StatsArgs,\n33:   HealthArgs,\n34:   DeleteArgs,\n35:   UpdateArgs,\n36:   MemoryValidateArgs,\n37:   BulkDeleteArgs,\n38:   RetentionSweepArgs,\n39:   ReconcileArgs,\n40:   EmbedderSetArgs,\n41:   EmbedderStatusArgs,\n42: } from './types.js';\n43: \n44: /** Tool names handled by this module */\n45: export const TOOL_NAMES = new Set([\n46:   'memory_search',\n47:   'memory_quick_search',\n48:   'memory_match_triggers',\n49:   'memory_save',\n50:   'memory_list',\n51:   'memory_stats',\n52:   'memory_health',\n53:   'memory_delete',\n54:   'memory_update',\n55:   'memory_validate',\n56:   'memory_bulk_delete',\n57:   'memory_retention_sweep',\n58:   'memory_embedding_reconcile',\n59:   'embedder_list',\n60:   'embedder_set',\n61:   'embedder_status',\n62: ]);\n63: \n64: /** Dispatch a tool call. Returns null if tool name not handled. */\n65: export async function handleTool(name: string, args: Record<string, unknown>): Promise<MCPResponse | null> {\n66:   switch (name) {\n67:     case 'memory_search':         return handleMemorySearch(parseArgs<SearchArgs>(validateToolArgs('memory_search', args)));\n68:     case 'memory_quick_search': {\n69:       const validatedArgs = validateToolArgs('memory_quick_search', args);\n70:       const response = await handleMemorySearch(parseArgs<SearchArgs>({\n71:         ...validatedArgs,\n72:         autoDetectIntent: true,\n73:         enableDedup: true,\n74:         includeContent: true,\n75:         includeConstitutional: true,\n76:         rerank: true,\n77:       }));\n78:       if (response.content?.[0]?.text) {\n79:         try {\n80:           const payload = JSON.parse(response.content[0].text) as { meta?: Record<string, unknown> };\n81:           payload.meta = { ...(payload.meta ?? {}), tool: 'memory_quick_search' };\n82:           response.content[0].text = JSON.stringify(payload);\n83:         } catch {\n84:           // Non-JSON responses are returned unchanged.\n85:         }\n86:       }\n87:       return response;\n88:     }\n89:     case 'memory_match_triggers': return handleMemoryMatchTriggers(parseArgs<TriggerArgs>(validateToolArgs('memory_match_triggers', args)));\n90:     case 'memory_save':           return handleMemorySave(parseArgs<SaveArgs>(validateToolArgs('memory_save', args)));\n91:     case 'memory_list':           return handleMemoryList(parseArgs<ListArgs>(validateToolArgs('memory_list', args)));\n92:     case 'memory_stats':          return handleMemoryStats(parseArgs<StatsArgs>(validateToolArgs('memory_stats', args)));\n93:     case 'memory_health':         return handleMemoryHealth(parseArgs<HealthArgs>(validateToolArgs('memory_health', args)));\n94:     case 'memory_delete':         return handleMemoryDelete(parseArgs<DeleteArgs>(validateToolArgs('memory_delete', args)));\n95:     case 'memory_update':         return handleMemoryUpdate(parseArgs<UpdateArgs>(validateToolArgs('memory_update', args)));\n96:     case 'memory_validate':       return handleMemoryValidate(parseArgs<MemoryValidateArgs>(validateToolArgs('memory_validate', args)));\n97:     case 'memory_bulk_delete':    return handleMemoryBulkDelete(parseArgs<BulkDeleteArgs>(validateToolArgs('memory_bulk_delete', args)));\n98:     case 'memory_retention_sweep': return handleMemoryRetentionSweep(parseArgs<RetentionSweepArgs>(validateToolArgs('memory_retention_sweep', args)));\n99:     case 'memory_embedding_reconcile': return handleMemoryEmbeddingReconcile(parseArgs<ReconcileArgs>(validateToolArgs('memory_embedding_reconcile', args)));\n100:     case 'embedder_list':\n101:       validateToolArgs('embedder_list', args);\n102:       return handleEmbedderList();\n103:     case 'embedder_set':          return handleEmbedderSet(parseArgs<EmbedderSetArgs>(validateToolArgs('embedder_set', args)));\n104:     case 'embedder_status':       return handleEmbedderStatus(parseArgs<EmbedderStatusArgs>(validateToolArgs('embedder_status', args)));\n105:     default: return null;\n106:   }\n107: }\n\n(End of file - total 107 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Tools\n// ───────────────────────────────────────────────────────────────\n// Dispatch for L2-L4 memory tools: search, triggers, save,\n// List, stats, health, delete, update, validate.\nimport {\n  handleMemorySearch,\n  handleMemoryMatchTriggers,\n  handleMemorySave,\n  handleMemoryList,\n  handleMemoryStats,\n  handleMemoryHealth,\n  handleMemoryDelete,\n  handleMemoryUpdate,\n  handleMemoryValidate,\n  handleMemoryBulkDelete,\n  handleMemoryRetentionSweep,\n  handleMemoryEmbeddingReconcile,\n  handleEmbedderList,\n  handleEmbedderSet,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/memory-tools.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Tools\n// ───────────────────────────────────────────────────────────────\n// Dispatch for L2-L4 memory tools: search, triggers, save,\n// List, stats, health, delete, update, validate.\nimport {\n  handleMemorySearch,\n  handleMemoryMatchTriggers,\n  handleMemorySave,\n  handleMemoryList,\n  handleMemoryStats,\n  handleMemoryHealth,\n  handleMemoryDelete,\n  handleMemoryUpdate,\n  handleMemoryValidate,\n  handleMemoryBulkDelete,\n  handleMemoryRetentionSweep,\n  handleMemoryEmbeddingReconcile,\n  handleEmbedderList,\n  handleEmbedderSet,\n  handleEmbedderStatus,\n} from '../handlers/index.js';\nimport { validateToolArgs } from '../schemas/tool-input-schemas.js';\n\nimport { parseArgs } from './types.js';\nimport type {\n  MCPResponse,\n  SearchArgs,\n  TriggerArgs,\n  SaveArgs,\n  ListArgs,\n  StatsArgs,\n  HealthArgs,\n  DeleteArgs,\n  UpdateArgs,\n  MemoryValidateArgs,\n  BulkDeleteArgs,\n  RetentionSweepArgs,\n  ReconcileArgs,\n  EmbedderSetArgs,\n  EmbedderStatusArgs,\n} from './types.js';\n\n/** Tool names handled by this module */\nexport const TOOL_NAMES = new Set([\n  'memory_search',\n  'memory_quick_search',\n  'memory_match_triggers',\n  'memory_save',\n  'memory_list',\n  'memory_stats',\n  'memory_health',\n  'memory_delete',\n  'memory_update',\n  'memory_validate',\n  'memory_bulk_delete',\n  'memory_retention_sweep',\n  'memory_embedding_reconcile',\n  'embedder_list',\n  'embedder_set',\n  'embedder_status',\n]);\n\n/** Dispatch a tool call. Returns null if tool name not handled. */\nexport async function handleTool(name: string, args: Record<string, unknown>): Promise<MCPResponse | null> {\n  switch (name) {\n    case 'memory_search':         return handleMemorySearch(parseArgs<SearchArgs>(validateToolArgs('memory_search', args)));\n    case 'memory_quick_search': {\n      const validatedArgs = validateToolArgs('memory_quick_search', args);\n      const response = await handleMemorySearch(parseArgs<SearchArgs>({\n        ...validatedArgs,\n        autoDetectIntent: true,\n        enableDedup: true,\n        includeContent: true,\n        includeConstitutional: true,\n        rerank: true,\n      }));\n      if (response.content?.[0]?.text) {\n        try {\n          const payload = JSON.parse(response.content[0].text) as { meta?: Record<string, unknown> };\n          payload.meta = { ...(payload.meta ?? {}), tool: 'memory_quick_search' };\n          response.content[0].text = JSON.stringify(payload);\n        } catch {\n          // Non-JSON responses are returned unchanged.\n        }\n      }\n      return response;\n    }\n    case 'memory_match_triggers': return handleMemoryMatchTriggers(parseArgs<TriggerArgs>(validateToolArgs('memory_match_triggers', args)));\n    case 'memory_save':           return handleMemorySave(parseArgs<SaveArgs>(validateToolArgs('memory_save', args)));\n    case 'memory_list':           return handleMemoryList(parseArgs<ListArgs>(validateToolArgs('memory_list', args)));\n    case 'memory_stats':          return handleMemoryStats(parseArgs<StatsArgs>(validateToolArgs('memory_stats', args)));\n    case 'memory_health':         return handleMemoryHealth(parseArgs<HealthArgs>(validateToolArgs('memory_health', args)));\n    case 'memory_delete':         return handleMemoryDelete(parseArgs<DeleteArgs>(validateToolArgs('memory_delete', args)));\n    case 'memory_update':         return handleMemoryUpdate(parseArgs<UpdateArgs>(validateToolArgs('memory_update', args)));\n    case 'memory_validate':       return handleMemoryValidate(parseArgs<MemoryValidateArgs>(validateToolArgs('memory_validate', args)));\n    case 'memory_bulk_delete':    return handleMemoryBulkDelete(parseArgs<BulkDeleteArgs>(validateToolArgs('memory_bulk_delete', args)));\n    case 'memory_retention_sweep': return handleMemoryRetentionSweep(parseArgs<RetentionSweepArgs>(validateToolArgs('memory_retention_sweep', args)));\n    case 'memory_embedding_reconcile': return handleMemoryEmbeddingReconcile(parseArgs<ReconcileArgs>(validateToolArgs('memory_embedding_reconcile', args)));\n    case 'embedder_list':\n      validateToolArgs('embedder_list', args);\n      return handleEmbedderList();\n    case 'embedder_set':          return handleEmbedderSet(parseArgs<EmbedderSetArgs>(validateToolArgs('embedder_set', args)));\n    case 'embedder_status':       return handleEmbedderStatus(parseArgs<EmbedderStatusArgs>(validateToolArgs('embedder_status', args)));\n    default: return null;\n  }\n}","lineStart":1,"lineEnd":107,"totalLines":107,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tools/memory-tools.ts","time":{"start":1780738287611,"end":1780738287630}},"metadata":{"openai":{"itemId":"fc_01ed494ef25e8706016a23e8ef70248191964a6aa199fdffe9"}},"id":"prt_e9c45e7d2001gUo9hCd7tQQA3M","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c45bf8d001TjF1lUiSO3kqX7"}}
