velope with hints, triggers post-mutation hooks and runs N3-lite consolidation. |\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:53:1. dedup          -- Skip if unchanged or duplicate content hash\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:60:8. post-insert    -- Enrich with entities, summaries, causal links\\n.opencode/skills/system-spec-kit/mcp_server/utils/README.md:4:trigger_phrases:\\n.opencode/skills/system-spec-kit/mcp_server/api/search.ts:16:  fts5Bm25Search,\\n.opencode/skills/system-spec-kit/mcp_server/api/search.ts:18:} from '../lib/search/sqlite-fts.js';\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:8:// Extracts implementation guidance and step-by-step instructions from session observations\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:13:// O3-2: Use canonical types from session-types (no local duplicates)\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:20:} from '../types/session-types';\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:71:  return `topic-${digest}`;\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:88:    const topicSlug = slugify(baseTitle).substring(0, 40);\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:89:    return topicSlug || createTopicFallback(baseTitle || implObs.title);\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:131:        DESCRIPTION: description || 'Implemented during session'\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:200:        !existingDesc.toLowerCase().includes('modified during session')) {\\n.opencode/skills/system-spec-kit/scripts/spec/check-placeholders.sh:106:    # Memory/ contains generated session context markdown that legitimately\\n.