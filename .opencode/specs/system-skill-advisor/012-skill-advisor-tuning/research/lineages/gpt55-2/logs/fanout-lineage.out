urn { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n\n  Line 150:       return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n\n  Line 152:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n\n  Line 160:   queryClass: AdvisorQueryClass,\n\n  Line 162:   const multipliers = queryClassLaneMultipliers(queryClass);\n\n  Line 172:     .filter((lane) => lane !== 'explicit_author')\n\n  Line 174:   if (next.explicit_author < strongestOther) {\n\n  Line 175:     next.explicit_author = Number(strongestOther.toFixed(6));\n\n  Line 182:   queryClass: AdvisorQueryClass = 'unknown',\n\n  Line 195:   if (queryClass === 'unknown') return base;\n\n  Line 196:   return applyQueryClassLaneMultipliers(base, queryClass);\n\n  Line 319:     k: ADVISOR_RRF_K,\n\n  Line 335:   conflictIndex: LaneMatchIndex,\n\n  Line 338:   return conflictIndex.get(recommendation.skill)?.rawScore ?? 0;\n\n  Line 370:   return fusion?.rankBySkill.get(recommendation.skill) ?? NO_RRF_RANK;\n\n  Line 411:   selfRecommendationGuardEnabled: boolean;\n\n  Line 415:   if (!args.selfRecommendationGuardEnabled && args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n\n  Line 418:     guardEnabled: args.selfRecommendationGuardEnabled,\n\n  Line 461:     .filter((contribution) => contribution.lane === 'explicit_author' || contribution.lane === 'lexical')\n\n  Line 482:   if (!disabled.has('explicit_author')) {\n\n  Line 483:     scores.explicit_author = scoreExplicitLane(prompt, projection, { includeProducerIdentity });\n\n  Line 491:       ...scores.explicit_author,\n\n  Line 496:     graphConflictMatches = graphSplit.conflictMatches;\n\n  Line 502:   const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n\n  Line 554:   selfRecommendatio