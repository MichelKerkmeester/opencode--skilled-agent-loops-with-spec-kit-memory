lace(/_/g, '\\\\_');\n31: }\n32: \n33: /** Builds the escaped `<folder>/%` LIKE pattern for spec-folder scoping. */\n34: export function specFolderLikePattern(specFolder: string): string {\n35:   return `${escapeLikePattern(specFolder)}/%`;\n36: }\n37: \n38: /** Structured error used by vector-index query, mutation, and store helpers. */\n39: export class VectorIndexError extends Error {\n40:   code: VectorIndexErrorCode;\n41: \n42:   constructor(message: string, code: VectorIndexErrorCode) {\n43:     super(message);\n44:     this.name = 'VectorIndexError';\n45:     this.code = code;\n46:     Object.setPrototypeOf(this, new.target.prototype);\n47:   }\n48: }\n49: \n50: /** Represents a row from the memory index table. */\n51: export interface MemoryIndexRow {\n52:   id: number;\n53:   spec_folder?: string;\n54:   file_path?: string;\n55:   anchor_id?: string | null;\n56:   title?: string | null;\n57:   trigger_phrases?: string | string[] | null;\n58:   triggerPhrases?: string | string[];\n59:   importance_weight?: number;\n60:   created_at?: string;\n61:   updated_at?: string;\n62:   embedding_model?: string | null;\n63:   embedding_generated_at?: string | null;\n64:   embedding_status?: string;\n65:   retry_count?: number;\n66:   last_retry_at?: string | null;\n67:   failure_reason?: string | null;\n68:   importance_tier?: string;\n69:   access_count?: number;\n70:   last_accessed?: number;\n71:   confidence?: number;\n72:   validation_count?: number;\n73:   is_pinned?: number;\n74:   stability?: number;\n75:   difficulty?: number;\n76:   last_review?: string | null;\n77:   review_count?: number;\n78:   content_hash?: string | null;\n79:   related_memories?: string | null;\n80:   document_type?: string;\n81:   spec_level?: number | null;\n82:   quality_score?: number;\n83:   quality_flags?: string | string[] | null;\n84:   isConstitutional?: boolean;\n85:   similarity?: number;\n86:   keywordScore?: number;\n87:   [key: string]: unknown;\n88: }\n89: \n90: /** Represents a vector-search memory row shared by query and store helpers. */\n91: export interface MemoryRow {\n92:   id: number;\n93:   spec_folder: string;\n94:   file_path: string;\n95:   title?: string | null;\n96:   trigger_phrases?: string | string[] | null;\n97:   importance_tier?: string;\n98:   importance_weight?: number;\n99:   created_at?: string;\n100:   access_count?: number;\n101:   last_accessed?: number;\n102:   confidence?: number;\n103:   keyword_score?: number;\n104:   similarity?: number;\n105:   avg_similarity?: number;\n106:   concept_similarities?: number[];\n107:   smartScore?: number;\n108:   relationSimilarity?: number;\n109:   isConstitutional?: boolean;\n110:   [key: string]: unknown;\n111: }\n112: \n113: export interface MemoryScopeParams {\n114:   tenantId?: string | null;\n115:   userId?: string | null;\n116:   agentId?: string | null;\n117:   sessionId?: string | null;\n118: }\n119: \n120: /** Describes the inputs required to index a memory. */\n121: export interface IndexMemoryParams {\n122:   specFolder: string;\n123:   filePath: string;\n124:   parentId?: number | null;\n125:   anchorId?: string | null;\n126:   title?: string | null;\n127:   triggerPhrases?: string[];\n128:   importanceWeight?: number;\n129:   embedding: EmbeddingInput;\n130:   encodingIntent?: string;\n131:   documentType?: string;\n132:   specLevel?: number | null;\n133:   contentText?: string | null;\n134:   qualityScore?: number;\n135:   qualityFlags?: string[];\n136:   scope?: MemoryScopeParams;\n137: }\n138: \n139: /** Describes the fields that can be updated for a memory. */\n140: export interface UpdateMemoryParams {\n141:   id: number;\n142:   title?: string;\n143:   triggerPhrases?: string[];\n144:   importanceWeight?: number;\n145:   importanceTier?: string;\n146:   embedding?: EmbeddingInput;\n147:   encodingIntent?: string;\n148:   documentType?: string;\n149:   specLevel?: number | null;\n150:   contentText?: string | null;\n151:   qualityScore?: number;\n1