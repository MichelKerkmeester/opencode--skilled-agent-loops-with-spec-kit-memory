rence-research/research/lineages/gpt55-fast-10/iterations\\\" \\\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/deltas\\\" \\\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/dispatch-receipts\\\" && date -u +%Y-%m-%dT%H:%M:%SZ\",\"timeout\":120000,\"workdir\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public\"},\"output\":\"2026-07-08T05:20:03Z\\n\",\"metadata\":{\"output\":\"2026-07-08T05:20:03Z\\n\",\"exit\":0,\"truncated\":false},\"title\":\"mkdir -p \\\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/prompts\\\" \\\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/iterations\\\" \\\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/deltas\\\" \\\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/dispatch-receipts\\\" && date -u +%Y-%m-%dT%H:%M:%SZ\",\"time\":{\"start\":1783488003954,\"end\":1783488003956}},\"metadata\":{\"openai\":{\"itemId\":\"fc_0c8e9c94bbaf2953016a4dde019450819188e036d2d69b5e29\"}},\"id\":\"prt_f402b362a001Be4BO0McF2NOyM\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"messageID\":\"msg_f402aac08001akOmZME01Gc8gN\"}}\n40: {\"type\":\"step_finish\",\"timestamp\":1783488004281,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402b40b7001BSVdfWP9mQeaTX\",\"reason\":\"tool-calls\",\"snapshot\":\"1e8112f5d55f6ad49685f722007461011231f7bb\",\"messageID\":\"msg_f402aac08001akOmZME01Gc8gN\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":92406,\"input\":13271,\"output\":271,\"reasoning\":1552,\"cache\":{\"write\":0,\"read\":77312}},\"cost\":0}}\n41: {\"type\":\"step_start\",\"timestamp\":1783488005638,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402b4603001Qnsa25AXz7AlYo\",\"messageID\":\"msg_f402b420c0018tRGdBEKg3Ooma\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"1e8112f5d55f6ad49685f722007461011231f7bb\",\"type\":\"step-start\"}}\n42: {\"type\":\"text\",\"timestamp\":1783488014712,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402b5247001x670rNegXQv5by\",\"messageID\":\"msg_f402b420c0018tRGdBEKg3Ooma\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"text\",\"text\":\"Initializing state and beginning codebase evidence gathering for the merge-design stress test. \\n\",\"time\":{\"start\":1783488008775,\"end\":1783488014705},\"metadata\":{\"openai\":{\"itemId\":\"msg_06458034519feedb016a4dde08c7348191885cb83509870091\",\"phase\":\"commentary\"}}}}\n\n(Output capped at 50 KB. Showing lines 1-42. Use offset=43 to continue.)\n</content>","metadata":{"preview":"{\"type\":\"step_start\",\"timestamp\":1783487855273,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4028faa5001UXjTfvoNIAgBQn\",\"messageID\":\"msg_f4028d1a7001j3O93pJbYrT0Hv\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"385cbd668e98c6b89c3ad6015cc767600459de3b\",\"type\":\"step-start\"}}\n{\"type\":\"tool_use\",\"timestamp\":1783487910952,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"mk-spec-memory_memory_match_triggers\",\"callID\":\"call_huvGFMsyH5bHIuo0BQufmj4U\",\"state\":{\"status\":\"error\",\"input\":{\"prompt\":\"You are orchestrating the deep-research workflow YAML as a detached fan-out lineage.\\nThis is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.\\nUse the separate lineage directory and session id below as the detached state boundary.\\n\\n\\nRead .opencode/skills/deep-loop-workflows/deep-research/SKILL.md and execute the research loop with these parameters:\\n  spec_folder: .opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research\\n  config.fanout_lineage_artifact_dir: .opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10\\n  session_id: fanout-gpt55-fast-10-1783486518892-2qss01\\n  executor: cli-opencode model=openai/gpt-5.5-fast\\n  loop_type: research\\n  config.stopPolicy: convergence\\n  research_topic: Validate and stress-test the merge design for folding deep-loop-runtime into deep-loop-workflows as system-deep-loop: structural layout, bidirectional path-coupling repair, the system-spec-kit tooling-borrow, reference migration across commands/agents/READMEs/advisor-corpus, and whether fallback-router.ts should be wired for real GLM-5.2 to MiMo-v2.5-Pro fallback.\\n  config.maxIterations: 10\\nThe step_resolve_artifact_root step will bind artifact_dir to .opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10 via the\\nconfig.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node\\ncommand; bind artifact_dir directly to the override value.\\n\\nRun phase_init, phase_main_loop (to legal convergence OR config.maxIterations, whichever comes first), and phase_synthesis.\\nWrite all outputs to .opencode/specs/system-deep-loop/052-deep-loo... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1783487911270,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029d562001xm6ypbScysUfL4\",\"reason\":\"tool-calls\",\"snapshot\":\"f344bb06f3fc979b1d384c547685565dc4e6ac7c\",\"messageID\":\"msg_f4028d1a7001j3O93pJbYrT0Hv\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":32388,\"input\":15392,\"output\":608,\"reasoning\":516,\"cache\":{\"write\":0,\"read\":15872}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1783487912504,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029da34001271B3BOr9SgG5X\",\"messageID\":\"msg_f4029d6a1001ep4yBS3kHV0ovW\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"f344bb06f3fc979b1d384c547685565dc4e6ac7c\",\"type\":\"step-start\"}}\n{\"type\":\"text\",\"timestamp\":1783487918803,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029f299001rppvrOH1LXvrIu\",\"messageID\":\"msg_f4029d6a1001ep4yBS3kHV0ovW\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"text\",\"text\":\"SKILL ROUTING: User directed → deep-research. Binding `artifact_dir` directly to the provided fanout lineage override and keeping writes confined to that lineage directory. \\n\",\"time\":{\"start\":1783487918745,\"end\":1783487918801},\"metadata\":{\"openai\":{\"itemId\":\"msg_02d975a323cc3485016a4dddaec0008191b399fd1624a22ede\",\"phase\":\"commentary\"}}}}\n{\"type\":\"tool_use\",\"timestamp\":1783487918942,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"skill\",\"callID\":\"call_IuCAeQxIV4mqHYEk11OI8LuB\",\"state\":{\"status\":\"completed\",\"input\":{\"name\":\"deep-research\"},\"output\":\"<skill_content name=\\\"deep-research\\\">\\n# Skill: deep-research\\n\\n<!-- Keywords: autoresearch, deep-research, iterative-research, autonomous-loop, convergence-detection, externalized-state, fresh-context, research-agent, JSONL-state, strategy-file -->\\n\\n# Autonomous Deep Research Loop\\n\\nNote: `Task` is allowed for the command executor that manages the loop. The `@deep-research` agent itself is LEAF-only and does not dispatch sub-agents.\\n\\nIterative research protocol with fresh context per iteration, externalized state, and convergence detection for deep technical investigation.\\n\\nRuntime path resolution:\\n- OpenCode/Copilot runtime: `.opencode/agents/*.md`\\n- Claude runtime: `.claude/agents/*.md`\\n\\nOperator contract precedence for this skill surface:\\n- Command entrypoint syntax in `.opencode/commands/deep/research.md`\\n- Convergence math in `references/convergence/convergence.md` and the deep-research YAML workflow\\n- Runtime agent inventories from the checked-in runtime directories above\\n\\n### Convergence Threshold Semantics\\n\\n**Default:** 0.05 on newInfoRatio (fully-new=1.0, partially-new=0.5, +0.10 simplicity bonus, capped 1.0)\\n\\n**Semantic:** `convergenceThreshold` compares newly discovered information against accumulated research knowledge with negative-knowledge emphasis. Lower = more iterations / higher signal threshold.\\n\\n**NOT INTERCHANGEABLE with siblings:**\\n- `deep-review` uses 0.10 default on weighted P0/P1/P2 severity ratio\\n- `deep-ai-council` uses 0.20 default on adjudicator-verdict stability\\n\\nCarrying threshold expectations across siblings will cause unexpected iteration counts. See this skill's changelog and decision records for the cross-sibling threshold research and parity invariants that confirm ... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1783487919306,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029f4c8001U2b9QeSzonRFb9\",\"reason\":\"tool-calls\",\"snapshot\":\"13cce014decaa378a085eabad44044a6f1245061\",\"messageID\":\"msg_f4029d6a1001ep4yBS3kHV0ovW\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":24676,\"input\":24386,\"output\":63,\"reasoning\":227,\"cache\":{\"write\":0,\"read\":0}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1783487920569,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029f9b80010xiDhz9W7zfiBn\",\"messageID\":\"msg_f4029f604001HUPZkFBTFrg6hU\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"13cce014decaa378a085eabad44044a6f1245061\",\"type\":\"step-start\"}}\n{\"type\":\"text\",\"timestamp\":1783487940329,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402a28d5001IJJNnSMRq62rF7\",\"messageID\":\"msg_f4029f604001HUPZkFBTFrg6hU\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"text\",\"text\":\"Research workflow contract loaded. Next step is reading the command/workflow references and existing lineage state before writing any artifacts. \\n\",\"time\":{\"start\":1783487932629,\"end\":1783487940326},\"metadata\":{\"openai\":{\"itemId\":\"msg_057627ff7cd9a741016a4dddbca1bc8191aeccd37ea2fdf4ad\",\"phase\":\"commentary\"}}}}\n{\"type\":\"tool_use\",\"timestamp\":1783487940353,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_lmkXw0AfpDvsVGcC00IIAvxm\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Deep Research Quick Reference\\n3: description: One-page cheat sheet for the autonomous deep research loop.\\n4: trigger_phrases:\\n5:   - \\\"deep research quick reference\\\"\\n6:   - \\\"research loop cheat sheet\\\"\\n7:   - \\\"research iteration checklist\\\"\\n8:   - \\\"research loop troubleshooting\\\"\\n9:   - \\\"research tuning guide\\\"\\n10:   - \\\"research progress visualization\\\"\\n11: importance_tier: normal\\n12: contextType: general\\n13: version: 1.14.0.26\\n14: ---\\n15: \\n16: # Deep Research Quick Reference\\n17: \\n18: One-page operator cheat sheet for the autonomous deep research loop.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: Lookup surface during runs covering when to invoke the loop, what each phase produces, how convergence is computed, and where live state lives on disk. Defer to the full protocol and convergence references for deep reasoning.\\n25: \\n26: Operator contract source of truth for this page:\\n27: - command syntax: `.opencode/commands/deep/research.md`\\n28: - convergence stop contract: `references/convergence/convergence.md`, `references/convergence/convergence_signals.md`, and the deep-research YAML workflow\\n29: - state packet contract: `references/state/state_format.md`, `references/state/state_jsonl.md`, `references/state/state_outputs.md`, and `references/state/state_reducer_registry.md`\\n30: \\n31: ---\\n32: \\n33: ## 2. COMMANDS\\n34: \\n3... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940381,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_RQqwSGKjCoVApLf1YSVXgMi4\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Loop Protocol Reference\\n3: description: Canonical specification for the deep research loop lifecycle with 4 phases, reference-only wave orchestration, and error handling.\\n4: trigger_phrases:\\n5:   - \\\"research loop protocol\\\"\\n6:   - \\\"research loop lifecycle\\\"\\n7:   - \\\"research loop initialization\\\"\\n8:   - \\\"research auto resume protocol\\\"\\n9:   - \\\"research pause sentinel\\\"\\n10:   - \\\"research synthesis phase\\\"\\n11: importance_tier: important\\n12: contextType: implementation\\n13: version: 1.14.0.29\\n14: ---\\n15: \\n16: # Loop Protocol Reference\\n17: \\n18: Canonical specification for the deep research loop lifecycle. Use it as the lifecycle map for initialization, iteration, synthesis, save, and recovery.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: ### Purpose\\n25: \\n26: Define the lifecycle contract for deep-research initialization, iteration, synthesis, save, reference-only dispatch concepts, and error handling.\\n27: \\n28: ### When to Use\\n29: \\n30: Load this reference when running or validating the research loop lifecycle. Use `../convergence/convergence.md` for STOP decisions and `../state/state_format.md` for packet file schemas.\\n31: \\n32: ### Core Principle\\n33: \\n34: The YAML workflow owns lifecycle orchestration, `@deep-research` executes LEAF iterations, and the reducer synchronizes packet state after each iteration and lifecycle tr... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_VJ5bR7a2rqMKzY2vdVkp1mkZ\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: State Format Reference\\n3: description: Live state packet hub for the deep-research loop.\\n4: trigger_phrases:\\n5:   - \\\"research state format\\\"\\n6:   - \\\"research state packet hub\\\"\\n7:   - \\\"research file ownership model\\\"\\n8:   - \\\"research file protection rules\\\"\\n9:   - \\\"research packet location\\\"\\n10: importance_tier: important\\n11: contextType: implementation\\n12: version: 1.14.0.29\\n13: ---\\n14: \\n15: # State Format Reference\\n16: \\n17: Live state packet hub for deep-research files, mutability, and routed state references.\\n18: \\n19: ---\\n20: \\n21: ## 1. OVERVIEW\\n22: \\n23: ### Purpose\\n24: \\n25: Summarize the live deep-research packet files, mutability rules, and focused state references without carrying every JSON shape inline.\\n26: \\n27: ### When to Use\\n28: \\n29: Load this hub when navigating packet files, deciding file ownership, or choosing which detailed state reference to load next.\\n30: \\n31: ### Routed Details\\n32: \\n33: - `state_jsonl.md` for config, iteration, event, lifecycle, graph, and blocked-stop records.\\n34: - `state_outputs.md` for strategy, iteration markdown, `research.md`, dashboard, and resource-map output.\\n35: - `state_reducer_registry.md` for reducer ownership, findings registry, validation, reconstruction, and file protection.\\n36: \\n37: For iterative code review state, use `deep-review`. Review-mode state is not part of this... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_pTEWRjj8jyzhXUXLyea0LcNp\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Deep Research JSONL State Reference\\n3: description: Config, iteration, event, lineage, graph, and blocked-stop records for deep-research state logs.\\n4: trigger_phrases:\\n5:   - \\\"research state jsonl\\\"\\n6:   - \\\"research config record\\\"\\n7:   - \\\"research iteration records\\\"\\n8:   - \\\"research negative knowledge\\\"\\n9:   - \\\"research graph events\\\"\\n10:   - \\\"research event records\\\"\\n11: importance_tier: normal\\n12: contextType: implementation\\n13: version: 1.14.0.3\\n14: ---\\n15: \\n16: # Deep Research JSONL State Reference\\n17: \\n18: `deep-research-state.jsonl` is append-only. Each line is one JSON object. The first line is normally the config record, followed by iteration and event records.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: ### Purpose\\n25: \\n26: Define the append-only JSONL records used by deep-research config, iteration, lifecycle, graph, pause, stuck-recovery, and blocked-stop state.\\n27: \\n28: ### When to Use\\n29: \\n30: Load this reference when validating state logs, adding event records, reconstructing a packet, or mapping legacy stop labels to current values.\\n31: \\n32: ### Core Principle\\n33: \\n34: Raw JSONL is append-only evidence. Reducer-owned files derive from it, but they do not replace it.\\n35: \\n36: ---\\n37: \\n38: ## 2. CONFIG RECORD\\n39: \\n40: The config record captures the initialized loop contract.\\n41: \\n42: ```json\\n43: {\\n4... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_7eFnOUKcI4960jSRjOp9VogY\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Deep Research Output Files Reference\\n3: description: Markdown output structures for strategy, iterations, dashboard, synthesis, and resource-map artifacts.\\n4: trigger_phrases:\\n5:   - \\\"research output files\\\"\\n6:   - \\\"research iteration files\\\"\\n7:   - \\\"research synthesis document\\\"\\n8:   - \\\"research resource map\\\"\\n9:   - \\\"research strategy file\\\"\\n10:   - \\\"spec anchoring output\\\"\\n11: importance_tier: normal\\n12: contextType: implementation\\n13: version: 1.14.0.3\\n14: ---\\n15: \\n16: # Deep Research Output Files Reference\\n17: \\n18: This reference covers human-readable packet outputs. JSONL records live in `state_jsonl.md`; reducer ownership lives in `state_reducer_registry.md`.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: ### Purpose\\n25: \\n26: Define the human-readable deep-research packet outputs: strategy, iteration markdown, synthesis, dashboard, resource map, and bounded spec anchoring.\\n27: \\n28: ### When to Use\\n29: \\n30: Load this reference when writing or validating markdown outputs rather than JSONL records.\\n31: \\n32: ### Core Principle\\n33: \\n34: Human-readable outputs must stay synchronized with raw state and respect reducer ownership.\\n35: \\n36: ---\\n37: \\n38: ## 2. STRATEGY FILE\\n39: \\n40: `deep-research-strategy.md` is the persistent research plan. The reducer owns machine-managed sections.\\n41: \\n42: Required sections:\\n43: \\n... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_QNbL3y5G1PVkn5LSN51albmi\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Convergence Detection Reference\\n3: description: Live stop contract and navigation hub for deep-research convergence.\\n4: trigger_phrases:\\n5:   - \\\"research convergence detection\\\"\\n6:   - \\\"research stop contract\\\"\\n7:   - \\\"research stopreason values\\\"\\n8:   - \\\"research legal stop gates\\\"\\n9:   - \\\"research convergence decision order\\\"\\n10: importance_tier: important\\n11: contextType: implementation\\n12: version: 1.14.0.20\\n13: ---\\n14: \\n15: # Convergence Detection Reference\\n16: \\n17: Live stop-contract hub for deep-research convergence and routed convergence references.\\n18: \\n19: ---\\n20: \\n21: ## 1. OVERVIEW\\n22: \\n23: ### Purpose\\n24: \\n25: Keep the executable deep-research stop contract short enough to load during routing while pointing detailed signal, recovery, and graph behavior to focused references.\\n26: \\n27: ### When to Use\\n28: \\n29: Load this hub when deciding whether a deep-research loop should continue, recover, or stop.\\n30: \\n31: ### Key Sources\\n32: \\n33: - Command syntax: `.opencode/commands/deep/research.md`\\n34: - Workflow algorithm: `.opencode/commands/deep/assets/deep_research_auto.yaml` and `_confirm.yaml`\\n35: - Signal details: `references/convergence/convergence_signals.md`\\n36: - Recovery details: `references/convergence/convergence_recovery.md`\\n37: - Graph stop gates: `references/convergence/convergence_graph.md`\\n38... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940394,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_YIFnQMzNQjsY9hutxUMTwyCX\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Spec Check Protocol\\n3: description: Canonical contract for late-INIT spec.md detection, bounded mutation, advisory locking, and post-synthesis write-back in deep-research.\\n4: trigger_phrases:\\n5:   - \\\"spec check protocol\\\"\\n6:   - \\\"research advisory lock\\\"\\n7:   - \\\"spec folder state classification\\\"\\n8:   - \\\"post-synthesis write-back\\\"\\n9:   - \\\"research spec conflict detection\\\"\\n10: importance_tier: important\\n11: contextType: implementation\\n12: version: 1.14.0.9\\n13: ---\\n14: \\n15: # Spec Check Protocol\\n16: \\n17: Canonical contract for how `/deep:research` inspects and mutates `spec.md` without turning that work into an unbounded side effect.\\n18: \\n19: ---\\n20: \\n21: ## 1. OVERVIEW\\n22: \\n23: ### Purpose\\n24: Define the bounded `spec.md` integration points for deep-research:\\n25: - Late-INIT lock acquisition and folder-state detection\\n26: - Pre-init seed or context mutation before LOOP starts\\n27: - Post-synthesis generated-fence write-back before save or cancellation cleanup\\n28: \\n29: ### Scope\\n30: This protocol applies only to deep-research-owned `spec.md` mutations:\\n31: - Seeded Level 1 `spec.md` creation when no spec exists\\n32: - Anchor-bounded pre-init context updates to an existing `spec.md`\\n33: - One generated findings block written after synthesis\\n34: \\n35: This protocol does not own the shared intake contract in `.... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940395,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_ULgTIQUUEaI4544KCheW2Lme\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence_signals.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence_signals.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Convergence Signals Reference\\n3: description: Signal definitions, scoring rules, and reports for deep-research convergence.\\n4: trigger_phrases:\\n5:   - \\\"research convergence signals\\\"\\n6:   - \\\"research new info ratio\\\"\\n7:   - \\\"research stuck count\\\"\\n8:   - \\\"mad noise floor\\\"\\n9:   - \\\"question entropy\\\"\\n10:   - \\\"research composite score\\\"\\n11:   - \\\"convergence threshold tuning\\\"\\n12: importance_tier: normal\\n13: contextType: implementation\\n14: version: 1.14.0.3\\n15: ---\\n16: \\n17: # Convergence Signals Reference\\n18: \\n19: This reference defines the live deep-research convergence signals. The compact stop contract lives in `convergence.md`.\\n20: \\n21: ---\\n22: \\n23: ## 1. OVERVIEW\\n24: \\n25: ### Purpose\\n26: \\n27: Define the live convergence signals, scoring rules, threshold semantics, and reporting shape used by deep-research loops.\\n28: \\n29: ### When to Use\\n30: \\n31: Load this reference when calculating `newInfoRatio`, explaining a composite STOP vote, debugging stuck counts, or validating convergence dashboards.\\n32: \\n33: ### Core Principle\\n34: \\n35: Signals nominate STOP; legal-stop and graph gates authorize or block it.\\n36: \\n37: ---\\n38: \\n39: ## 2. SIGNAL MODEL\\n40: \\n41: The live model uses three weighted signals and normalizes by the weight of the signals that have enough data to run.\\n42: \\n43: | Signal | Weig... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1783487941064,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402a49c30013n15MiFvNHYTCi\",\"reason\":\"tool-calls\",\"snapshot\":\"b8297dd0bb6640d528d50aff20fdb72b498a99ed\",\"messageID\":\"msg_f4029f604001HUPZkFBTFrg6hU\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":32847,\"input\":7730,\"output\":537,\"reasoning\":516,\"cache\":{\"write\":0,\"read\":24064}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1783487942647,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402a4ff5001BWGypRtZSDNvVt\",\"messageID\":\"msg_f402a4bf0001Q8w265USGDe8D4\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"b8297dd0bb6640d528d50aff20fdb72b498a99ed\",\"type\":\"step-start\"}}\n{\"type\":\"tool_use\",\"timestamp\":1783487948529,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_pjqZEfyW9pjISu2Kfi0W2Up2\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research\",\"offset\":1,\"limit\":200},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research</path>\\n<type>directory</type>\\n<entries>\\nchecklist.md\\ndescription.json\\ngraph-metadata.json\\nplan.md\\nresearch/\\nspec.md\\ntasks.md\\n\\n(7 entries)\\n</entries>\",\"metadata\":{\"preview\":\"checklist.md\\ndescription.json\\ngraph-metadata.json\\nplan.md\\nresearch/\\nspec.md\\ntasks.md\",\"truncated\":false,\"loaded\":[],\"display\":{\"type\":\"directory\",\"path\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research\",\"entries\":[\"checklist.md\",\"description.json\",\"graph-metadata.json\",\"plan.md\",\"research/\",\"spec.md\",\"tasks.md\"],\"offset\":1,\"totalEntries\":7,\"truncated\":false}},\"title\":\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research\",\"time\":{\"start\":1783487948505,\"end\":1783487948511}},\"metadata\":{\"openai\":{\"itemId\":\"fc_04480d8c58061e49016a4dddcc709c81918cc82ec7ba247d23\"}},\"id\":\"prt_f402a66d4001U8668AEbajSmqD\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"messageID\":\"msg_f402a4bf0001Q8w265USGDe8D4\"}}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10/logs/fanout-lineage.out","text":"{\"type\":\"step_start\",\"timestamp\":1783487855273,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4028faa5001UXjTfvoNIAgBQn\",\"messageID\":\"msg_f4028d1a7001j3O93pJbYrT0Hv\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"385cbd668e98c6b89c3ad6015cc767600459de3b\",\"type\":\"step-start\"}}\n{\"type\":\"tool_use\",\"timestamp\":1783487910952,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"mk-spec-memory_memory_match_triggers\",\"callID\":\"call_huvGFMsyH5bHIuo0BQufmj4U\",\"state\":{\"status\":\"error\",\"input\":{\"prompt\":\"You are orchestrating the deep-research workflow YAML as a detached fan-out lineage.\\nThis is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.\\nUse the separate lineage directory and session id below as the detached state boundary.\\n\\n\\nRead .opencode/skills/deep-loop-workflows/deep-research/SKILL.md and execute the research loop with these parameters:\\n  spec_folder: .opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research\\n  config.fanout_lineage_artifact_dir: .opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10\\n  session_id: fanout-gpt55-fast-10-1783486518892-2qss01\\n  executor: cli-opencode model=openai/gpt-5.5-fast\\n  loop_type: research\\n  config.stopPolicy: convergence\\n  research_topic: Validate and stress-test the merge design for folding deep-loop-runtime into deep-loop-workflows as system-deep-loop: structural layout, bidirectional path-coupling repair, the system-spec-kit tooling-borrow, reference migration across commands/agents/READMEs/advisor-corpus, and whether fallback-router.ts should be wired for real GLM-5.2 to MiMo-v2.5-Pro fallback.\\n  config.maxIterations: 10\\nThe step_resolve_artifact_root step will bind artifact_dir to .opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-10 via the\\nconfig.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node\\ncommand; bind artifact_dir directly to the override value.\\n\\nRun phase_init, phase_main_loop (to legal convergence OR config.maxIterations, whichever comes first), and phase_synthesis.\\nWrite all outputs to .opencode/specs/system-deep-loop/052-deep-loo... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1783487911270,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029d562001xm6ypbScysUfL4\",\"reason\":\"tool-calls\",\"snapshot\":\"f344bb06f3fc979b1d384c547685565dc4e6ac7c\",\"messageID\":\"msg_f4028d1a7001j3O93pJbYrT0Hv\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":32388,\"input\":15392,\"output\":608,\"reasoning\":516,\"cache\":{\"write\":0,\"read\":15872}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1783487912504,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029da34001271B3BOr9SgG5X\",\"messageID\":\"msg_f4029d6a1001ep4yBS3kHV0ovW\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"f344bb06f3fc979b1d384c547685565dc4e6ac7c\",\"type\":\"step-start\"}}\n{\"type\":\"text\",\"timestamp\":1783487918803,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029f299001rppvrOH1LXvrIu\",\"messageID\":\"msg_f4029d6a1001ep4yBS3kHV0ovW\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"text\",\"text\":\"SKILL ROUTING: User directed → deep-research. Binding `artifact_dir` directly to the provided fanout lineage override and keeping writes confined to that lineage directory. \\n\",\"time\":{\"start\":1783487918745,\"end\":1783487918801},\"metadata\":{\"openai\":{\"itemId\":\"msg_02d975a323cc3485016a4dddaec0008191b399fd1624a22ede\",\"phase\":\"commentary\"}}}}\n{\"type\":\"tool_use\",\"timestamp\":1783487918942,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"skill\",\"callID\":\"call_IuCAeQxIV4mqHYEk11OI8LuB\",\"state\":{\"status\":\"completed\",\"input\":{\"name\":\"deep-research\"},\"output\":\"<skill_content name=\\\"deep-research\\\">\\n# Skill: deep-research\\n\\n<!-- Keywords: autoresearch, deep-research, iterative-research, autonomous-loop, convergence-detection, externalized-state, fresh-context, research-agent, JSONL-state, strategy-file -->\\n\\n# Autonomous Deep Research Loop\\n\\nNote: `Task` is allowed for the command executor that manages the loop. The `@deep-research` agent itself is LEAF-only and does not dispatch sub-agents.\\n\\nIterative research protocol with fresh context per iteration, externalized state, and convergence detection for deep technical investigation.\\n\\nRuntime path resolution:\\n- OpenCode/Copilot runtime: `.opencode/agents/*.md`\\n- Claude runtime: `.claude/agents/*.md`\\n\\nOperator contract precedence for this skill surface:\\n- Command entrypoint syntax in `.opencode/commands/deep/research.md`\\n- Convergence math in `references/convergence/convergence.md` and the deep-research YAML workflow\\n- Runtime agent inventories from the checked-in runtime directories above\\n\\n### Convergence Threshold Semantics\\n\\n**Default:** 0.05 on newInfoRatio (fully-new=1.0, partially-new=0.5, +0.10 simplicity bonus, capped 1.0)\\n\\n**Semantic:** `convergenceThreshold` compares newly discovered information against accumulated research knowledge with negative-knowledge emphasis. Lower = more iterations / higher signal threshold.\\n\\n**NOT INTERCHANGEABLE with siblings:**\\n- `deep-review` uses 0.10 default on weighted P0/P1/P2 severity ratio\\n- `deep-ai-council` uses 0.20 default on adjudicator-verdict stability\\n\\nCarrying threshold expectations across siblings will cause unexpected iteration counts. See this skill's changelog and decision records for the cross-sibling threshold research and parity invariants that confirm ... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1783487919306,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029f4c8001U2b9QeSzonRFb9\",\"reason\":\"tool-calls\",\"snapshot\":\"13cce014decaa378a085eabad44044a6f1245061\",\"messageID\":\"msg_f4029d6a1001ep4yBS3kHV0ovW\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":24676,\"input\":24386,\"output\":63,\"reasoning\":227,\"cache\":{\"write\":0,\"read\":0}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1783487920569,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f4029f9b80010xiDhz9W7zfiBn\",\"messageID\":\"msg_f4029f604001HUPZkFBTFrg6hU\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"13cce014decaa378a085eabad44044a6f1245061\",\"type\":\"step-start\"}}\n{\"type\":\"text\",\"timestamp\":1783487940329,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402a28d5001IJJNnSMRq62rF7\",\"messageID\":\"msg_f4029f604001HUPZkFBTFrg6hU\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"text\",\"text\":\"Research workflow contract loaded. Next step is reading the command/workflow references and existing lineage state before writing any artifacts. \\n\",\"time\":{\"start\":1783487932629,\"end\":1783487940326},\"metadata\":{\"openai\":{\"itemId\":\"msg_057627ff7cd9a741016a4dddbca1bc8191aeccd37ea2fdf4ad\",\"phase\":\"commentary\"}}}}\n{\"type\":\"tool_use\",\"timestamp\":1783487940353,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_lmkXw0AfpDvsVGcC00IIAvxm\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Deep Research Quick Reference\\n3: description: One-page cheat sheet for the autonomous deep research loop.\\n4: trigger_phrases:\\n5:   - \\\"deep research quick reference\\\"\\n6:   - \\\"research loop cheat sheet\\\"\\n7:   - \\\"research iteration checklist\\\"\\n8:   - \\\"research loop troubleshooting\\\"\\n9:   - \\\"research tuning guide\\\"\\n10:   - \\\"research progress visualization\\\"\\n11: importance_tier: normal\\n12: contextType: general\\n13: version: 1.14.0.26\\n14: ---\\n15: \\n16: # Deep Research Quick Reference\\n17: \\n18: One-page operator cheat sheet for the autonomous deep research loop.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: Lookup surface during runs covering when to invoke the loop, what each phase produces, how convergence is computed, and where live state lives on disk. Defer to the full protocol and convergence references for deep reasoning.\\n25: \\n26: Operator contract source of truth for this page:\\n27: - command syntax: `.opencode/commands/deep/research.md`\\n28: - convergence stop contract: `references/convergence/convergence.md`, `references/convergence/convergence_signals.md`, and the deep-research YAML workflow\\n29: - state packet contract: `references/state/state_format.md`, `references/state/state_jsonl.md`, `references/state/state_outputs.md`, and `references/state/state_reducer_registry.md`\\n30: \\n31: ---\\n32: \\n33: ## 2. COMMANDS\\n34: \\n3... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940381,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_RQqwSGKjCoVApLf1YSVXgMi4\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Loop Protocol Reference\\n3: description: Canonical specification for the deep research loop lifecycle with 4 phases, reference-only wave orchestration, and error handling.\\n4: trigger_phrases:\\n5:   - \\\"research loop protocol\\\"\\n6:   - \\\"research loop lifecycle\\\"\\n7:   - \\\"research loop initialization\\\"\\n8:   - \\\"research auto resume protocol\\\"\\n9:   - \\\"research pause sentinel\\\"\\n10:   - \\\"research synthesis phase\\\"\\n11: importance_tier: important\\n12: contextType: implementation\\n13: version: 1.14.0.29\\n14: ---\\n15: \\n16: # Loop Protocol Reference\\n17: \\n18: Canonical specification for the deep research loop lifecycle. Use it as the lifecycle map for initialization, iteration, synthesis, save, and recovery.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: ### Purpose\\n25: \\n26: Define the lifecycle contract for deep-research initialization, iteration, synthesis, save, reference-only dispatch concepts, and error handling.\\n27: \\n28: ### When to Use\\n29: \\n30: Load this reference when running or validating the research loop lifecycle. Use `../convergence/convergence.md` for STOP decisions and `../state/state_format.md` for packet file schemas.\\n31: \\n32: ### Core Principle\\n33: \\n34: The YAML workflow owns lifecycle orchestration, `@deep-research` executes LEAF iterations, and the reducer synchronizes packet state after each iteration and lifecycle tr... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_VJ5bR7a2rqMKzY2vdVkp1mkZ\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: State Format Reference\\n3: description: Live state packet hub for the deep-research loop.\\n4: trigger_phrases:\\n5:   - \\\"research state format\\\"\\n6:   - \\\"research state packet hub\\\"\\n7:   - \\\"research file ownership model\\\"\\n8:   - \\\"research file protection rules\\\"\\n9:   - \\\"research packet location\\\"\\n10: importance_tier: important\\n11: contextType: implementation\\n12: version: 1.14.0.29\\n13: ---\\n14: \\n15: # State Format Reference\\n16: \\n17: Live state packet hub for deep-research files, mutability, and routed state references.\\n18: \\n19: ---\\n20: \\n21: ## 1. OVERVIEW\\n22: \\n23: ### Purpose\\n24: \\n25: Summarize the live deep-research packet files, mutability rules, and focused state references without carrying every JSON shape inline.\\n26: \\n27: ### When to Use\\n28: \\n29: Load this hub when navigating packet files, deciding file ownership, or choosing which detailed state reference to load next.\\n30: \\n31: ### Routed Details\\n32: \\n33: - `state_jsonl.md` for config, iteration, event, lifecycle, graph, and blocked-stop records.\\n34: - `state_outputs.md` for strategy, iteration markdown, `research.md`, dashboard, and resource-map output.\\n35: - `state_reducer_registry.md` for reducer ownership, findings registry, validation, reconstruction, and file protection.\\n36: \\n37: For iterative code review state, use `deep-review`. Review-mode state is not part of this... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_pTEWRjj8jyzhXUXLyea0LcNp\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Deep Research JSONL State Reference\\n3: description: Config, iteration, event, lineage, graph, and blocked-stop records for deep-research state logs.\\n4: trigger_phrases:\\n5:   - \\\"research state jsonl\\\"\\n6:   - \\\"research config record\\\"\\n7:   - \\\"research iteration records\\\"\\n8:   - \\\"research negative knowledge\\\"\\n9:   - \\\"research graph events\\\"\\n10:   - \\\"research event records\\\"\\n11: importance_tier: normal\\n12: contextType: implementation\\n13: version: 1.14.0.3\\n14: ---\\n15: \\n16: # Deep Research JSONL State Reference\\n17: \\n18: `deep-research-state.jsonl` is append-only. Each line is one JSON object. The first line is normally the config record, followed by iteration and event records.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: ### Purpose\\n25: \\n26: Define the append-only JSONL records used by deep-research config, iteration, lifecycle, graph, pause, stuck-recovery, and blocked-stop state.\\n27: \\n28: ### When to Use\\n29: \\n30: Load this reference when validating state logs, adding event records, reconstructing a packet, or mapping legacy stop labels to current values.\\n31: \\n32: ### Core Principle\\n33: \\n34: Raw JSONL is append-only evidence. Reducer-owned files derive from it, but they do not replace it.\\n35: \\n36: ---\\n37: \\n38: ## 2. CONFIG RECORD\\n39: \\n40: The config record captures the initialized loop contract.\\n41: \\n42: ```json\\n43: {\\n4... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_7eFnOUKcI4960jSRjOp9VogY\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Deep Research Output Files Reference\\n3: description: Markdown output structures for strategy, iterations, dashboard, synthesis, and resource-map artifacts.\\n4: trigger_phrases:\\n5:   - \\\"research output files\\\"\\n6:   - \\\"research iteration files\\\"\\n7:   - \\\"research synthesis document\\\"\\n8:   - \\\"research resource map\\\"\\n9:   - \\\"research strategy file\\\"\\n10:   - \\\"spec anchoring output\\\"\\n11: importance_tier: normal\\n12: contextType: implementation\\n13: version: 1.14.0.3\\n14: ---\\n15: \\n16: # Deep Research Output Files Reference\\n17: \\n18: This reference covers human-readable packet outputs. JSONL records live in `state_jsonl.md`; reducer ownership lives in `state_reducer_registry.md`.\\n19: \\n20: ---\\n21: \\n22: ## 1. OVERVIEW\\n23: \\n24: ### Purpose\\n25: \\n26: Define the human-readable deep-research packet outputs: strategy, iteration markdown, synthesis, dashboard, resource map, and bounded spec anchoring.\\n27: \\n28: ### When to Use\\n29: \\n30: Load this reference when writing or validating markdown outputs rather than JSONL records.\\n31: \\n32: ### Core Principle\\n33: \\n34: Human-readable outputs must stay synchronized with raw state and respect reducer ownership.\\n35: \\n36: ---\\n37: \\n38: ## 2. STRATEGY FILE\\n39: \\n40: `deep-research-strategy.md` is the persistent research plan. The reducer owns machine-managed sections.\\n41: \\n42: Required sections:\\n43: \\n... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940393,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_QNbL3y5G1PVkn5LSN51albmi\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Convergence Detection Reference\\n3: description: Live stop contract and navigation hub for deep-research convergence.\\n4: trigger_phrases:\\n5:   - \\\"research convergence detection\\\"\\n6:   - \\\"research stop contract\\\"\\n7:   - \\\"research stopreason values\\\"\\n8:   - \\\"research legal stop gates\\\"\\n9:   - \\\"research convergence decision order\\\"\\n10: importance_tier: important\\n11: contextType: implementation\\n12: version: 1.14.0.20\\n13: ---\\n14: \\n15: # Convergence Detection Reference\\n16: \\n17: Live stop-contract hub for deep-research convergence and routed convergence references.\\n18: \\n19: ---\\n20: \\n21: ## 1. OVERVIEW\\n22: \\n23: ### Purpose\\n24: \\n25: Keep the executable deep-research stop contract short enough to load during routing while pointing detailed signal, recovery, and graph behavior to focused references.\\n26: \\n27: ### When to Use\\n28: \\n29: Load this hub when deciding whether a deep-research loop should continue, recover, or stop.\\n30: \\n31: ### Key Sources\\n32: \\n33: - Command syntax: `.opencode/commands/deep/research.md`\\n34: - Workflow algorithm: `.opencode/commands/deep/assets/deep_research_auto.yaml` and `_confirm.yaml`\\n35: - Signal details: `references/convergence/convergence_signals.md`\\n36: - Recovery details: `references/convergence/convergence_recovery.md`\\n37: - Graph stop gates: `references/convergence/convergence_graph.md`\\n38... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940394,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_YIFnQMzNQjsY9hutxUMTwyCX\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Spec Check Protocol\\n3: description: Canonical contract for late-INIT spec.md detection, bounded mutation, advisory locking, and post-synthesis write-back in deep-research.\\n4: trigger_phrases:\\n5:   - \\\"spec check protocol\\\"\\n6:   - \\\"research advisory lock\\\"\\n7:   - \\\"spec folder state classification\\\"\\n8:   - \\\"post-synthesis write-back\\\"\\n9:   - \\\"research spec conflict detection\\\"\\n10: importance_tier: important\\n11: contextType: implementation\\n12: version: 1.14.0.9\\n13: ---\\n14: \\n15: # Spec Check Protocol\\n16: \\n17: Canonical contract for how `/deep:research` inspects and mutates `spec.md` without turning that work into an unbounded side effect.\\n18: \\n19: ---\\n20: \\n21: ## 1. OVERVIEW\\n22: \\n23: ### Purpose\\n24: Define the bounded `spec.md` integration points for deep-research:\\n25: - Late-INIT lock acquisition and folder-state detection\\n26: - Pre-init seed or context mutation before LOOP starts\\n27: - Post-synthesis generated-fence write-back before save or cancellation cleanup\\n28: \\n29: ### Scope\\n30: This protocol applies only to deep-research-owned `spec.md` mutations:\\n31: - Seeded Level 1 `spec.md` creation when no spec exists\\n32: - Anchor-bounded pre-init context updates to an existing `spec.md`\\n33: - One generated findings block written after synthesis\\n34: \\n35: This protocol does not own the shared intake contract in `.... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783487940395,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_ULgTIQUUEaI4544KCheW2Lme\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence_signals.md\",\"offset\":1,\"limit\":2000},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence_signals.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: title: Convergence Signals Reference\\n3: description: Signal definitions, scoring rules, and reports for deep-research convergence.\\n4: trigger_phrases:\\n5:   - \\\"research convergence signals\\\"\\n6:   - \\\"research new info ratio\\\"\\n7:   - \\\"research stuck count\\\"\\n8:   - \\\"mad noise floor\\\"\\n9:   - \\\"question entropy\\\"\\n10:   - \\\"research composite score\\\"\\n11:   - \\\"convergence threshold tuning\\\"\\n12: importance_tier: normal\\n13: contextType: implementation\\n14: version: 1.14.0.3\\n15: ---\\n16: \\n17: # Convergence Signals Reference\\n18: \\n19: This reference defines the live deep-research convergence signals. The compact stop contract lives in `convergence.md`.\\n20: \\n21: ---\\n22: \\n23: ## 1. OVERVIEW\\n24: \\n25: ### Purpose\\n26: \\n27: Define the live convergence signals, scoring rules, threshold semantics, and reporting shape used by deep-research loops.\\n28: \\n29: ### When to Use\\n30: \\n31: Load this reference when calculating `newInfoRatio`, explaining a composite STOP vote, debugging stuck counts, or validating convergence dashboards.\\n32: \\n33: ### Core Principle\\n34: \\n35: Signals nominate STOP; legal-stop and graph gates authorize or block it.\\n36: \\n37: ---\\n38: \\n39: ## 2. SIGNAL MODEL\\n40: \\n41: The live model uses three weighted signals and normalizes by the weight of the signals that have enough data to run.\\n42: \\n43: | Signal | Weig... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1783487941064,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402a49c30013n15MiFvNHYTCi\",\"reason\":\"tool-calls\",\"snapshot\":\"b8297dd0bb6640d528d50aff20fdb72b498a99ed\",\"messageID\":\"msg_f4029f604001HUPZkFBTFrg6hU\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"type\":\"step-finish\",\"tokens\":{\"total\":32847,\"input\":7730,\"output\":537,\"reasoning\":516,\"cache\":{\"write\":0,\"read\":24064}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1783487942647,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"id\":\"prt_f402a4ff5001BWGypRtZSDNvVt\",\"messageID\":\"msg_f402a4bf0001Q8w265USGDe8D4\",\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"snapshot\":\"b8297dd0bb6640d528d50aff20fdb72b498a99ed\",\"type\":\"step-start\"}}\n{\"type\":\"tool_use\",\"timestamp\":1783487948529,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_pjqZEfyW9pjISu2Kfi0W2Up2\",\"state\":{\"status\":\"c