{"type":"step_start","timestamp":1781763342274,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"id":"prt_ed95effc0001TYAPZpofBxZu7R","messageID":"msg_ed95ef7c10016Q6PQfTaTF4ZBU","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","snapshot":"ed993180b59cb8cdc978524ce3a5bdfce4aee6ce","type":"step-start"}}
{"type":"tool_use","timestamp":1781763346325,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_un4OrJDtMtM7ICPGGcpaJUx4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Mutations\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL mutation functions:\n6: // Index, update, delete, and status/confidence updates.\n7: \n8: import * as embeddingsProvider from '../providers/embeddings.js';\n9: import {\n10:   buildGovernanceLogicalKey,\n11:   normalizeScopeValue,\n12:   recordTierDowngradeAudit,\n13: } from '../governance/scope-governance.js';\n14: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n15: import { recordHistory } from '../storage/history.js';\n16: import { buildMemoryLogicalKey } from '../storage/lineage-state.js';\n17: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n18: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n19: import { createLogger } from '../utils/logger.js';\n20: import { deleteByContentHash } from '../cache/embedding-cache.js';\n21: import { clearDegreeCacheForDb } from './graph-search-fn.js';\n22: import { sweepCausalEdges } from '../causal/sweep.js';\n23: import { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\n24: import * as bm25Index from './bm25-index.js';\n25: import {\n26:   clear_search_cache,\n27: } from './vector-index-aliases.js';\n28: import { invalidateEntityDensityCache } from './entity-density.js';\n29: import {\n30:   get_error_message,\n31:   to_embedding_buffer,\n32:   VectorIndexError,\n33:   VectorIndexErrorCode,\n34: } from './vector-index-types.js';\n35: import {\n36:   clear_constitutional_cache,\n37:   get_embedding_dim,\n38:   initialize_db,\n39:   init_prepared_statements,\n40:   refresh_interference_scores_for_folder,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource,\n43: } from './vector-index-store.js';\n44: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\n45: import type {\n46:   IndexMemoryParams as SharedIndexMemoryParams,\n47:   MemoryScopeParams,\n48:   UpdateMemoryParams as SharedUpdateMemoryParams,\n49: } from './vector-index-types.js';\n50: import type Database from 'better-sqlite3';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: function isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n55:   const message = get_error_message(error).toLowerCase();\n56:   return message.includes('no such table') && message.includes('vec_memories');\n57: }\n58: \n59: function activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n60:   try {\n61:     const row = database.prepare(`\n62:       SELECT 1 AS found\n63:       FROM ${activeVectorSource('sqlite_master')}\n64:       WHERE type = 'table' AND name = ?\n65:       LIMIT 1\n66:     `).get(tableName) as { found?: number } | undefined;\n67:     return row?.found === 1;\n68:   } catch (_error: unknown) {\n69:     return false;\n70:   }\n71: }\n72: \n73: function activeDimVectorSource(database: Database.Database): string | null {\n74:   const active = getActiveEmbedder(database);\n75:   if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n76:     return null;\n77:   }\n78:   const tableName = vecTableNameForDim(active.dim);\n79:   return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n80: }\n81: \n82: function writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n83:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n84:   database.prepare(`\n85:     INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n86:   `).run(id, embeddingBuffer);\n87: \n88:   const dimSource = activeDimVectorSource(database);\n89:   if (dimSource) {\n90:     database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n91:   }\n92: }\n93: \n94: function deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n95:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n96:   const dimSource = activeDimVectorSource(database);\n97:   if (dimSource) {\n98:     database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n99:   }\n100: }\n101: \n102: function invalidateGraphCaches(database: Database.Database): void {\n103:   // Bump the generation FIRST so every cache key that includes it (e.g.\n104:   // memory_search with causal boost) goes stale before the per-db caches clear;\n105:   // without this, memory-delete sweeps served stale causal-boosted search results.\n106:   bumpCausalEdgesGeneration();\n107: \n108:   try {\n109:     clearDegreeCacheForDb(database);\n110:   } catch (_error: unknown) {\n111:     // Degree cache invalidation is best-effort for legacy mutation paths.\n112:   }\n113: \n114:   try {\n115:     clearGraphSignalsCache();\n116:   } catch (_error: unknown) {\n117:     // Graph signal cache invalidation is best-effort for legacy mutation paths.\n118:   }\n119: }\n120: \n121: function tryRecordTierDowngradeAudit(\n122:   database: Database.Database,\n123:   params: {\n124:     memoryId: number;\n125:     specFolder: string | null | undefined;\n126:     anchorId: string | null | undefined;\n127:     filePath: string | null | undefined;\n128:     canonicalFilePath: string | null | undefined;\n129:     requestedTier?: string | null | undefined;\n130:     previousTier?: string | null | undefined;\n131:     nextTier: string;\n132:     source: string;\n133:   },\n134: ): void {\n135:   try {\n136:     recordTierDowngradeAudit(database, {\n137:       memoryId: params.memoryId,\n138:       logicalKey: buildGovernanceLogicalKey(\n139:         params.specFolder,\n140:         params.canonicalFilePath || params.filePath,\n141:         params.anchorId,\n142:       ),\n143:       requestedTier: params.requestedTier ?? undefined,\n144:       previousTier: params.previousTier ?? undefined,\n145:       nextTier: params.nextTier,\n146:       source: params.source,\n147:       filePath: params.filePath ?? null,\n148:       canonicalFilePath: params.canonicalFilePath ?? null,\n149:     });\n150:   } catch (error: unknown) {\n151:     logger.warn('Failed to record governance audit for tier downgrade', {\n152:       memoryId: params.memoryId,\n153:       source: params.source,\n154:       message: get_error_message(error),\n155:     });\n156:   }\n157: }\n158: \n159: function deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n160:   const ancillaryTables = [\n161:     'DELETE FROM degree_snapshots WHERE memory_id = ?',\n162:     'DELETE FROM community_assignments WHERE memory_id = ?',\n163:     'DELETE FROM memory_summaries WHERE memory_id = ?',\n164:     'DELETE FROM memory_entities WHERE memory_id = ?',\n165:     'DELETE FROM memory_lineage WHERE memory_id = ?',\n166:   ];\n167: \n168:   for (const sql of ancillaryTables) {\n169:     try {\n170:       const paramCount = (sql.match(/\\?/g) || []).length;\n171:       if (paramCount === 2) {\n172:         database.prepare(sql).run(id, id);\n173:       } else {\n174:         database.prepare(sql).run(id);\n175:       }\n176:     } catch (_error: unknown) {\n177:       // Best-effort for legacy databases that may not have these tables yet.\n178:     }\n179:   }\n180: \n181:   // Clean active_memory_projection rows referencing this memory.\n182:   try {\n183:     database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n184:   } catch (_error: unknown) {\n185:     // Best-effort for legacy databases that may not have projection tables yet.\n186:   }\n187: \n188:   try {\n189:     const result = sweepCausalEdges(database, {\n190:       memoryIds: [id, String(id)],\n191:       reason: 'memory row mutation cleanup',\n192:       command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n193:       restoreContext: { memoryId: id },\n194:       invalidateCaches: false,\n195:     });\n196:     if (result.deleted > 0) {\n197:       invalidateGraphCaches(database);\n198:     }\n199:   } catch (error: unknown) {\n200:     // Tolerate only legacy databases that predate the causal-edge tables. Scope\n201:     // the match to those table names so an unrelated missing-table error still\n202:     // propagates and rolls back the surrounding delete instead of committing a\n203:     // hard delete without its tombstone audit row.\n204:     const message = error instanceof Error ? error.message : String(error);\n205:     if (!/no such table:\\s*causal_edge/i.test(message)) {\n206:       throw error;\n207:     }\n208:   }\n209: }\n210: \n211: function upsert_active_projection(\n212:   database: ReturnType<typeof initialize_db>,\n213:   specFolder: string,\n214:   canonicalFilePath: string,\n215:   anchorId: string | null,\n216:   memoryId: number,\n217:   updatedAt: string,\n218:   scope: NormalizedMemoryScope,\n219: ): void {\n220:   const logicalKey = buildMemoryLogicalKey({\n221:     specFolder,\n222:     filePath: canonicalFilePath,\n223:     canonicalFilePath,\n224:     anchorId,\n225:     ...scope,\n226:   });\n227:   // Evict any stale projection row that maps a *different* logical_key to the\n228:   // same active_memory_id — prevents UNIQUE constraint violation on re-index\n229:   // when the logical_key changes (e.g. anchor or path normalization drift).\n230:   database.prepare(\n231:     'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n232:   ).run(memoryId, logicalKey);\n233:   database.prepare(`\n234:     INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n235:     VALUES (?, ?, ?, ?)\n236:     ON CONFLICT(logical_key) DO UPDATE SET\n237:       root_memory_id = excluded.root_memory_id,\n238:       active_memory_id = excluded.active_memory_id,\n239:       updated_at = excluded.updated_at\n240:   `).run(logicalKey, memoryId, memoryId, updatedAt);\n241: }\n242: \n243: // These mutation-local extensions are intentional until the shared query/store\n244: // contract adopts appendOnly and canonicalFilePath semantics.\n245: type IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n246:   readonly appendOnly?: boolean;\n247: };\n248: type IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n249:   readonly failureReason?: string | null;\n250: };\n251: type UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n252:   readonly canonicalFilePath?: string;\n253:   // Set when the row's document now lives at a new on-disk location, so a\n254:   // moved file repoints its existing row instead of leaving a stale path.\n255:   readonly filePath?: string;\n256: };\n257: \n258: type NormalizedMemoryScope = {\n259:   tenant_id: string | null;\n260:   user_id: string | null;\n261:   agent_id: string | null;\n262:   session_id: string | null;\n263: };\n264: \n265: function normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n266:   return {\n267:     tenant_id: normalizeScopeValue(scope?.tenantId),\n268:     user_id: normalizeScopeValue(scope?.userId),\n269:     agent_id: normalizeScopeValue(scope?.agentId),\n270:     session_id: normalizeScopeValue(scope?.sessionId),\n271:   };\n272: }\n273: \n274: /**\n275:  * Indexes a memory with an embedding payload.\n276:  * @param params - The memory values to index.\n277:  * @returns The indexed memory identifier.\n278:  * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n279:  * @example\n280:  * ```ts\n281:  * const id = index_memory({\n282:  *   specFolder: 'specs/001-demo',\n283:  *   filePath: 'spec.md',\n284:  *   embedding,\n285:  * });\n286:  * ```\n287:  */\n288: export function index_memory(\n289:   params: IndexMemoryParams,\n290:   database: Database.Database = initialize_db(),\n291: ): number {\n292:   const {\n293:     specFolder,\n294:     filePath,\n295:     parentId = null,\n296:     anchorId = null,\n297:     title = null,\n298:     triggerPhrases = [],\n299:     importanceWeight = 0.5,\n300:     embedding,\n301:     encodingIntent,\n302:     documentType = 'memory',\n303:     specLevel = null,\n304:     contentText = null,\n305:     qualityScore = 0,\n306:     qualityFlags = [],\n307:     appendOnly = false,\n308:   } = params;\n309:   const scope = normalizeMemoryScope(params.scope);\n310: \n311:   if (!embedding) {\n312:     throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n313:   }\n314: \n315:   const expected_dim = get_embedding_dim();\n316:   if (embedding.length !== expected_dim) {\n317:     console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n318:     throw new VectorIndexError(\n319:       `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n320:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n321:     );\n322:   }\n323: \n324:   const now = new Date().toISOString();\n325:   const triggers_json = JSON.stringify(triggerPhrases);\n326:   const embedding_buffer = to_embedding_buffer(embedding);\n327:   const canonicalFilePath = getCanonicalPathKey(filePath);\n328: \n329:   const stmts = init_prepared_statements(database);\n330:   const existing = appendOnly\n331:     ? null\n332:     : stmts.get_by_folder_and_path.get(\n333:         specFolder,\n334:         canonicalFilePath,\n335:         filePath,\n336:         canonicalFilePath,\n337:         filePath,\n338:         anchorId,\n339:         scope.tenant_id,\n340:         scope.user_id,\n341:         scope.agent_id,\n342:         scope.session_id,\n343:       );\n344: \n345:   if (existing && !appendOnly) {\n346:     return update_memory({\n347:       id: existing.id,\n348:       title: title ?? undefined,\n349:       triggerPhrases,\n350:       importanceWeight,\n351:       embedding,\n352:       encodingIntent,\n353:       documentType,\n354:       specLevel,\n355:       contentText,\n356:       qualityScore,\n357:       qualityFlags,\n358:       canonicalFilePath,\n359:       filePath,\n360:     }, database);\n\n(Showing lines 1-360 of 1021. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Mutations\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Mutations\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';\nimport { clearDegreeCacheForDb } from './graph-search-fn.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\nimport * as bm25Index from './bm25-index.js';\nimport {\n  clear_search_cache,\n} from './vector-index-aliases.js';\nimport { invalidateEntityDensityCache } from './entity-density.js';\nimport {\n  get_error_message,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  clear_constitutional_cache,\n  get_embedding_dim,\n  initialize_db,\n  init_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource,\n} from './vector-index-store.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\nimport type {\n  IndexMemoryParams as SharedIndexMemoryParams,\n  MemoryScopeParams,\n  UpdateMemoryParams as SharedUpdateMemoryParams,\n} from './vector-index-types.js';\nimport type Database from 'better-sqlite3';\n\nconst logger = createLogger('VectorIndex');\n\nfunction isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n  const message = get_error_message(error).toLowerCase();\n  return message.includes('no such table') && message.includes('vec_memories');\n}\n\nfunction activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n  try {\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM ${activeVectorSource('sqlite_master')}\n      WHERE type = 'table' AND name = ?\n      LIMIT 1\n    `).get(tableName) as { found?: number } | undefined;\n    return row?.found === 1;\n  } catch (_error: unknown) {\n    return false;\n  }\n}\n\nfunction activeDimVectorSource(database: Database.Database): string | null {\n  const active = getActiveEmbedder(database);\n  if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n    return null;\n  }\n  const tableName = vecTableNameForDim(active.dim);\n  return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n}\n\nfunction writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  database.prepare(`\n    INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n  `).run(id, embeddingBuffer);\n\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n  }\n}\n\nfunction deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n  }\n}\n\nfunction invalidateGraphCaches(database: Database.Database): void {\n  // Bump the generation FIRST so every cache key that includes it (e.g.\n  // memory_search with causal boost) goes stale before the per-db caches clear;\n  // without this, memory-delete sweeps served stale causal-boosted search results.\n  bumpCausalEdgesGeneration();\n\n  try {\n    clearDegreeCacheForDb(database);\n  } catch (_error: unknown) {\n    // Degree cache invalidation is best-effort for legacy mutation paths.\n  }\n\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signal cache invalidation is best-effort for legacy mutation paths.\n  }\n}\n\nfunction tryRecordTierDowngradeAudit(\n  database: Database.Database,\n  params: {\n    memoryId: number;\n    specFolder: string | null | undefined;\n    anchorId: string | null | undefined;\n    filePath: string | null | undefined;\n    canonicalFilePath: string | null | undefined;\n    requestedTier?: string | null | undefined;\n    previousTier?: string | null | undefined;\n    nextTier: string;\n    source: string;\n  },\n): void {\n  try {\n    recordTierDowngradeAudit(database, {\n      memoryId: params.memoryId,\n      logicalKey: buildGovernanceLogicalKey(\n        params.specFolder,\n        params.canonicalFilePath || params.filePath,\n        params.anchorId,\n      ),\n      requestedTier: params.requestedTier ?? undefined,\n      previousTier: params.previousTier ?? undefined,\n      nextTier: params.nextTier,\n      source: params.source,\n      filePath: params.filePath ?? null,\n      canonicalFilePath: params.canonicalFilePath ?? null,\n    });\n  } catch (error: unknown) {\n    logger.warn('Failed to record governance audit for tier downgrade', {\n      memoryId: params.memoryId,\n      source: params.source,\n      message: get_error_message(error),\n    });\n  }\n}\n\nfunction deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n  const ancillaryTables = [\n    'DELETE FROM degree_snapshots WHERE memory_id = ?',\n    'DELETE FROM community_assignments WHERE memory_id = ?',\n    'DELETE FROM memory_summaries WHERE memory_id = ?',\n    'DELETE FROM memory_entities WHERE memory_id = ?',\n    'DELETE FROM memory_lineage WHERE memory_id = ?',\n  ];\n\n  for (const sql of ancillaryTables) {\n    try {\n      const paramCount = (sql.match(/\\?/g) || []).length;\n      if (paramCount === 2) {\n        database.prepare(sql).run(id, id);\n      } else {\n        database.prepare(sql).run(id);\n      }\n    } catch (_error: unknown) {\n      // Best-effort for legacy databases that may not have these tables yet.\n    }\n  }\n\n  // Clean active_memory_projection rows referencing this memory.\n  try {\n    database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n  } catch (_error: unknown) {\n    // Best-effort for legacy databases that may not have projection tables yet.\n  }\n\n  try {\n    const result = sweepCausalEdges(database, {\n      memoryIds: [id, String(id)],\n      reason: 'memory row mutation cleanup',\n      command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n      restoreContext: { memoryId: id },\n      invalidateCaches: false,\n    });\n    if (result.deleted > 0) {\n      invalidateGraphCaches(database);\n    }\n  } catch (error: unknown) {\n    // Tolerate only legacy databases that predate the causal-edge tables. Scope\n    // the match to those table names so an unrelated missing-table error still\n    // propagates and rolls back the surrounding delete instead of committing a\n    // hard delete without its tombstone audit row.\n    const message = error instanceof Error ? error.message : String(error);\n    if (!/no such table:\\s*causal_edge/i.test(message)) {\n      throw error;\n    }\n  }\n}\n\nfunction upsert_active_projection(\n  database: ReturnType<typeof initialize_db>,\n  specFolder: string,\n  canonicalFilePath: string,\n  anchorId: string | null,\n  memoryId: number,\n  updatedAt: string,\n  scope: NormalizedMemoryScope,\n): void {\n  const logicalKey = buildMemoryLogicalKey({\n    specFolder,\n    filePath: canonicalFilePath,\n    canonicalFilePath,\n    anchorId,\n    ...scope,\n  });\n  // Evict any stale projection row that maps a *different* logical_key to the\n  // same active_memory_id — prevents UNIQUE constraint violation on re-index\n  // when the logical_key changes (e.g. anchor or path normalization drift).\n  database.prepare(\n    'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n  ).run(memoryId, logicalKey);\n  database.prepare(`\n    INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n    VALUES (?, ?, ?, ?)\n    ON CONFLICT(logical_key) DO UPDATE SET\n      root_memory_id = excluded.root_memory_id,\n      active_memory_id = excluded.active_memory_id,\n      updated_at = excluded.updated_at\n  `).run(logicalKey, memoryId, memoryId, updatedAt);\n}\n\n// These mutation-local extensions are intentional until the shared query/store\n// contract adopts appendOnly and canonicalFilePath semantics.\ntype IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n  readonly appendOnly?: boolean;\n};\ntype IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n  readonly failureReason?: string | null;\n};\ntype UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n  readonly canonicalFilePath?: string;\n  // Set when the row's document now lives at a new on-disk location, so a\n  // moved file repoints its existing row instead of leaving a stale path.\n  readonly filePath?: string;\n};\n\ntype NormalizedMemoryScope = {\n  tenant_id: string | null;\n  user_id: string | null;\n  agent_id: string | null;\n  session_id: string | null;\n};\n\nfunction normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n  return {\n    tenant_id: normalizeScopeValue(scope?.tenantId),\n    user_id: normalizeScopeValue(scope?.userId),\n    agent_id: normalizeScopeValue(scope?.agentId),\n    session_id: normalizeScopeValue(scope?.sessionId),\n  };\n}\n\n/**\n * Indexes a memory with an embedding payload.\n * @param params - The memory values to index.\n * @returns The indexed memory identifier.\n * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n * @example\n * ```ts\n * const id = index_memory({\n *   specFolder: 'specs/001-demo',\n *   filePath: 'spec.md',\n *   embedding,\n * });\n * ```\n */\nexport function index_memory(\n  params: IndexMemoryParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    specFolder,\n    filePath,\n    parentId = null,\n    anchorId = null,\n    title = null,\n    triggerPhrases = [],\n    importanceWeight = 0.5,\n    embedding,\n    encodingIntent,\n    documentType = 'memory',\n    specLevel = null,\n    contentText = null,\n    qualityScore = 0,\n    qualityFlags = [],\n    appendOnly = false,\n  } = params;\n  const scope = normalizeMemoryScope(params.scope);\n\n  if (!embedding) {\n    throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n  }\n\n  const expected_dim = get_embedding_dim();\n  if (embedding.length !== expected_dim) {\n    console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n    throw new VectorIndexError(\n      `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const now = new Date().toISOString();\n  const triggers_json = JSON.stringify(triggerPhrases);\n  const embedding_buffer = to_embedding_buffer(embedding);\n  const canonicalFilePath = getCanonicalPathKey(filePath);\n\n  const stmts = init_prepared_statements(database);\n  const existing = appendOnly\n    ? null\n    : stmts.get_by_folder_and_path.get(\n        specFolder,\n        canonicalFilePath,\n        filePath,\n        canonicalFilePath,\n        filePath,\n        anchorId,\n        scope.tenant_id,\n        scope.user_id,\n        scope.agent_id,\n        scope.session_id,\n      );\n\n  if (existing && !appendOnly) {\n    return update_memory({\n      id: existing.id,\n      title: title ?? undefined,\n      triggerPhrases,\n      importanceWeight,\n      embedding,\n      encodingIntent,\n      documentType,\n      specLevel,\n      contentText,\n      qualityScore,\n      qualityFlags,\n      canonicalFilePath,\n      filePath,\n    }, database);","lineStart":1,"lineEnd":360,"totalLines":1021,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","time":{"start":1781763346316,"end":1781763346323}},"metadata":{"openai":{"itemId":"fc_0f8906b8f1cc33b0016a338d112d388191bc20585561fcd8be"}},"id":"prt_ed95f0b37001Q6twoTg7fY9RPs","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95ef7c10016Q6PQfTaTF4ZBU"}}
