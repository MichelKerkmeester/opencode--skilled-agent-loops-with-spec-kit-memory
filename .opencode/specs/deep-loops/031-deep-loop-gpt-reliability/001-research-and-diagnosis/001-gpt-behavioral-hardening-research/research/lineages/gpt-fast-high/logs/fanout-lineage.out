:       \"runtimeLoopType\": \"council\",\n68:       \"backendKind\": \"runtime-loop-type\",\n69:       \"packet\": \"deep-ai-council\",\n70:       \"command\": \"/deep:ai-council\",\n71:       \"agent\": \"ai-council\",\n72:       \"artifactRoot\": \"ai-council/\",\n73:       \"aliases\": [\"deep-ai-council\", \"ai council deliberation\", \"multi-seat planning council\", \"council convergence\", \"planning council\"],\n74:       \"advisorRouting\": {\n75:         \"routingClass\": \"lexical\",\n76:         \"legacyAdvisorId\": \"deep-ai-council\",\n77:         \"legacyAliases\": [\"@deep-ai-council\", \"deep-ai-council\", \"deep ai council\", \"ai council\", \"planning council\", \"council deliberation\", \"multi-ai-council\"],\n78:         \"packetSkillName\": \"deep-ai-council\"\n79:       }\n80:     },\n81:     {\n82:       \"workflowMode\": \"agent-improvement\",\n83:       \"runtimeLoopType\": null,\n84:       \"backendKind\": \"improvement-host\",\n85:       \"packet\": \"deep-improvement\",\n86:       \"loopHostMode\": \"agent-improvement\",\n87:       \"command\": \"/deep:agent-improvement\",\n88:       \"agent\": \"deep-improvement\",\n89:       \"artifactRoot\": \"improvement/\",\n90:       \"mutating\": true,\n91:       \"aliases\": [\"improve agent\", \"evaluate agent\", \"agent scoring\", \"score agent candidate\", \"promote or rollback agent change\", \"agent-improvement\"],\n92:       \"advisorRouting\": {\n93:         \"routingClass\": \"alias-fold\",\n94:         \"legacyAdvisorId\": \"deep-improvement\",\n95:         \"advisorDefaultMode\": true,\n96:         \"legacyAliases\": [\"command-spec-kit-deep-agent-improvement\", \"/deep:start-agent-improvement-loop\", \"deep-agent-improvement\", \"sk-deep-agent-improvement\"],\n97:         \"packetSkillName\": \"deep-improvement\"\n98:       }\n99:     },\n100:     {\n101:       \"workflowMode\": \"model-benchmark\",\n102:       \"runtimeLoopType\": null,\n103:       \"backendKind\": \"improvement-host\