{"type":"tool_use","timestamp":1781764222408,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"glob","callID":"call_n1d6rvX5H8B8njAsEwtZM1Qk","state":{"status":"completed","input":{"pattern":".opencode/skills/system-spec-kit/mcp_server/formatters/**/*.ts","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/index.ts\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/token-metrics.ts","metadata":{"count":3,"truncated":false},"title":"","time":{"start":1781764222305,"end":1781764222407}},"metadata":{"openai":{"itemId":"fc_0f714f64a4c72345016a33907e265c8191990d4e098a876e09"}},"id":"prt_ed96c6d15001bnJJxS8jYYn4jc","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96c4776001TyUHMTZCKII5sP"}}
{"type":"tool_use","timestamp":1781764222502,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_qAhlt19QRQWfFNcr9Z1sYTLp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","offset":220,"limit":200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts</path>\n<type>file</type>\n<content>\n220: }\n221: \n222: /**\n223:  * Map status + reason to a recommended next action.\n224:  */\n225: function recommendAction(status: RecoveryStatus, reason: RecoveryReason): RecoveryAction {\n226:   if (status === 'no_results') {\n227:     if (reason === 'spec_filter_too_narrow') return 'retry_broader';\n228:     if (reason === 'low_signal_query') return 'switch_mode';\n229:     return 'refuse_without_evidence';\n230:   }\n231:   if (status === 'low_confidence') {\n232:     if (reason === 'knowledge_gap') return 'ask_user';\n233:     if (reason === 'low_signal_query') return 'ask_disambiguation';\n234:     return 'switch_mode';\n235:   }\n236:   // partial\n237:   return 'broaden_or_ask';\n238: }\n239: \n240: // -- Graph-Expanded Fallback -----------------------------------\n241: \n242: import type Database from 'better-sqlite3';\n243: import { routeQueryConcepts } from './entity-linker.js';\n244: import { isGraphFallbackEnabled } from './search-flags.js';\n245: \n246: /**\n247:  * Build graph-expanded fallback query terms on zero/weak results.\n248:  *\n249:  * When the search produces no results or low-confidence results, this function\n250:  * queries the causal_edges table for nodes related to the matched concepts from\n251:  * concept routing, returning up to 5 expanded query terms derived from neighbor\n252:  * node titles.\n253:  *\n254:  * Feature-gated by SPECKIT_GRAPH_FALLBACK (default ON).\n255:  * Fail-open: returns empty array on any error.\n256:  *\n257:  * @param ctx - Recovery context with query and result state.\n258:  * @param db - SQLite database instance for graph lookups.\n259:  * @returns Array of up to 5 expanded query terms from graph neighbors.\n260:  */\n261: export function buildGraphExpandedFallback(\n262:   ctx: RecoveryContext,\n263:   db: Database.Database,\n264: ): string[] {\n265:   if (!isGraphFallbackEnabled()) return [];\n266: \n267:   const status = classifyStatus(ctx);\n268:   if (status !== 'no_results' && status !== 'low_confidence') return [];\n269: \n270:   try {\n271:     const routing = routeQueryConcepts(ctx.query ?? '', db);\n272:     if (!routing.graphActivated || routing.concepts.length === 0) return [];\n273: \n274:     // Find memory IDs matching the routed concepts via title keyword search,\n275:     // then walk causal_edges to find neighbors with distinct titles.\n276: \n277:     // Step 1: Find seed memory IDs whose titles contain matched concepts\n278:     const likeClauses = routing.concepts.map(() => 'LOWER(mi.title) LIKE ?').join(' OR ');\n279:     const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n280: \n281:     const seedRows = (db.prepare(`\n282:       SELECT mi.id FROM memory_index mi\n283:       WHERE (${likeClauses})\n284:       LIMIT 10\n285:     `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n286: \n287:     if (seedRows.length === 0) return [];\n288: \n289:     const seedIds = seedRows.map((r) => String(r.id));\n290:     const seedPlaceholdersSql = seedIds.map(() => '?').join(', ');\n291: \n292:     // Step 2: Walk 1-hop causal edges from seeds to find neighbor nodes. The\n293:     // query binds the seed list once per IN(...) clause; build the param array\n294:     // from the same clause count so the placeholders and bound values cannot\n295:     // drift if a clause is added or removed.\n296:     const seedInClauseCount = 3; // source_id IN, target_id IN, NOT IN\n297:     const seedParams = Array.from({ length: seedInClauseCount }, () => seedIds).flat();\n298:     const neighborRows = (db.prepare(`\n299:       SELECT DISTINCT mi.title\n300:       FROM causal_edges ce\n301:       JOIN memory_index mi ON (\n302:         (ce.source_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.target_id AS INTEGER))\n303:         OR\n304:         (ce.target_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.source_id AS INTEGER))\n305:       )\n306:       WHERE mi.id NOT IN (${seedPlaceholdersSql})\n307:       LIMIT 10\n308:     `) as Database.Statement).all(...seedParams) as Array<{ title: string }>;\n309: \n310:     if (neighborRows.length === 0) return [];\n311: \n312:     // Step 3: Extract short keyword phrases from neighbor titles\n313:     const terms: string[] = [];\n314:     const seen = new Set<string>();\n315: \n316:     for (const row of neighborRows) {\n317:       if (!row.title || terms.length >= 5) break;\n318:       // Take the first 3 words of the title as a search term\n319:       const words = row.title.trim().split(/\\s+/).slice(0, 3).join(' ').toLowerCase();\n320:       if (words.length > 0 && !seen.has(words)) {\n321:         seen.add(words);\n322:         terms.push(words);\n323:       }\n324:     }\n325: \n326:     return terms;\n327:   } catch (error: unknown) {\n328:     const message = error instanceof Error ? error.message : String(error);\n329:     console.warn(`[recovery-payload] buildGraphExpandedFallback failed (fail-open): ${message}`);\n330:     return [];\n331:   }\n332: }\n333: \n334: // -- Public API --\n335: \n336: /**\n337:  * Build a structured recovery payload for a failed or weak retrieval.\n338:  *\n339:  * Call this when:\n340:  *  - No results are returned (resultCount === 0)\n341:  *  - Results are returned but avgConfidence < threshold\n342:  *  - Fewer than PARTIAL_RESULT_MIN results (partial match)\n343:  *\n344:  * @param ctx - Retrieval outcome context\n345:  * @returns Structured recovery payload\n346:  */\n347: export function buildRecoveryPayload(ctx: RecoveryContext): RecoveryPayload {\n348:   const status = classifyStatus(ctx);\n349:   const reason = classifyReason(ctx, status);\n350:   const recommendedAction = recommendAction(status, reason);\n351:   const generatedSuggestions = generateSuggestedQueries(ctx);\n352:   const suggestedQueries = recommendedAction === 'ask_user' && generatedSuggestions.length === 0\n353:     ? synthesizeBroadeningSuggestions(ctx)\n354:     : generatedSuggestions;\n355: \n356:   return {\n357:     status,\n358:     reason,\n359:     suggestedQueries,\n360:     recommendedAction,\n361:   };\n362: }\n363: \n364: /**\n365:  * Determine whether a search result set warrants recovery.\n366:  *\n367:  * Returns true when:\n368:  *  - No results returned, OR\n369:  *  - Average confidence below threshold, OR\n370:  *  - Fewer than PARTIAL_RESULT_MIN results and avgConfidence is below mid-range\n371:  *\n372:  * @param ctx - Retrieval outcome context\n373:  */\n374: export function shouldTriggerRecovery(ctx: RecoveryContext): boolean {\n375:   if (ctx.resultCount === 0) return true;\n376:   if (ctx.evidenceGap) return true;\n377: \n378:   const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n379: \n380:   if (\n381:     typeof ctx.avgConfidence === 'number' &&\n382:     Number.isFinite(ctx.avgConfidence) &&\n383:     ctx.avgConfidence < threshold\n384:   ) return true;\n385: \n386:   if (ctx.resultCount < PARTIAL_RESULT_MIN) return true;\n387: \n388:   return false;\n389: }\n390: \n391: /**\n392:  * Check whether the empty-result recovery feature flag is enabled.\n393:  * Default: ON (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n394:  */\n395: export { isEmptyResultRecoveryEnabled } from './search-flags.js';\n\n(End of file - total 395 lines)\n</content>","metadata":{"preview":"}\n\n/**\n * Map status + reason to a recommended next action.\n */\nfunction recommendAction(status: RecoveryStatus, reason: RecoveryReason): RecoveryAction {\n  if (status === 'no_results') {\n    if (reason === 'spec_filter_too_narrow') return 'retry_broader';\n    if (reason === 'low_signal_query') return 'switch_mode';\n    return 'refuse_without_evidence';\n  }\n  if (status === 'low_confidence') {\n    if (reason === 'knowledge_gap') return 'ask_user';\n    if (reason === 'low_signal_query') return 'ask_disambiguation';\n    return 'switch_mode';\n  }\n  // partial\n  return 'broaden_or_ask';\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","text":"}\n\n/**\n * Map status + reason to a recommended next action.\n */\nfunction recommendAction(status: RecoveryStatus, reason: RecoveryReason): RecoveryAction {\n  if (status === 'no_results') {\n    if (reason === 'spec_filter_too_narrow') return 'retry_broader';\n    if (reason === 'low_signal_query') return 'switch_mode';\n    return 'refuse_without_evidence';\n  }\n  if (status === 'low_confidence') {\n    if (reason === 'knowledge_gap') return 'ask_user';\n    if (reason === 'low_signal_query') return 'ask_disambiguation';\n    return 'switch_mode';\n  }\n  // partial\n  return 'broaden_or_ask';\n}\n\n// -- Graph-Expanded Fallback -----------------------------------\n\nimport type Database from 'better-sqlite3';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { isGraphFallbackEnabled } from './search-flags.js';\n\n/**\n * Build graph-expanded fallback query terms on zero/weak results.\n *\n * When the search produces no results or low-confidence results, this function\n * queries the causal_edges table for nodes related to the matched concepts from\n * concept routing, returning up to 5 expanded query terms derived from neighbor\n * node titles.\n *\n * Feature-gated by SPECKIT_GRAPH_FALLBACK (default ON).\n * Fail-open: returns empty array on any error.\n *\n * @param ctx - Recovery context with query and result state.\n * @param db - SQLite database instance for graph lookups.\n * @returns Array of up to 5 expanded query terms from graph neighbors.\n */\nexport function buildGraphExpandedFallback(\n  ctx: RecoveryContext,\n  db: Database.Database,\n): string[] {\n  if (!isGraphFallbackEnabled()) return [];\n\n  const status = classifyStatus(ctx);\n  if (status !== 'no_results' && status !== 'low_confidence') return [];\n\n  try {\n    const routing = routeQueryConcepts(ctx.query ?? '', db);\n    if (!routing.graphActivated || routing.concepts.length === 0) return [];\n\n    // Find memory IDs matching the routed concepts via title keyword search,\n    // then walk causal_edges to find neighbors with distinct titles.\n\n    // Step 1: Find seed memory IDs whose titles contain matched concepts\n    const likeClauses = routing.concepts.map(() => 'LOWER(mi.title) LIKE ?').join(' OR ');\n    const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n\n    const seedRows = (db.prepare(`\n      SELECT mi.id FROM memory_index mi\n      WHERE (${likeClauses})\n      LIMIT 10\n    `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n\n    if (seedRows.length === 0) return [];\n\n    const seedIds = seedRows.map((r) => String(r.id));\n    const seedPlaceholdersSql = seedIds.map(() => '?').join(', ');\n\n    // Step 2: Walk 1-hop causal edges from seeds to find neighbor nodes. The\n    // query binds the seed list once per IN(...) clause; build the param array\n    // from the same clause count so the placeholders and bound values cannot\n    // drift if a clause is added or removed.\n    const seedInClauseCount = 3; // source_id IN, target_id IN, NOT IN\n    const seedParams = Array.from({ length: seedInClauseCount }, () => seedIds).flat();\n    const neighborRows = (db.prepare(`\n      SELECT DISTINCT mi.title\n      FROM causal_edges ce\n      JOIN memory_index mi ON (\n        (ce.source_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.target_id AS INTEGER))\n        OR\n        (ce.target_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.source_id AS INTEGER))\n      )\n      WHERE mi.id NOT IN (${seedPlaceholdersSql})\n      LIMIT 10\n    `) as Database.Statement).all(...seedParams) as Array<{ title: string }>;\n\n    if (neighborRows.length === 0) return [];\n\n    // Step 3: Extract short keyword phrases from neighbor titles\n    const terms: string[] = [];\n    const seen = new Set<string>();\n\n    for (const row of neighborRows) {\n      if (!row.title || terms.length >= 5) break;\n      // Take the first 3 words of the title as a search term\n      const words = row.title.trim().split(/\\s+/).slice(0, 3).join(' ').toLowerCase();\n      if (words.length > 0 && !seen.has(words)) {\n        seen.add(words);\n        terms.push(words);\n      }\n    }\n\n    return terms;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[recovery-payload] buildGraphExpandedFallback failed (fail-open): ${message}`);\n    return [];\n  }\n}\n\n// -- Public API --\n\n/**\n * Build a structured recovery payload for a failed or weak retrieval.\n *\n * Call this when:\n *  - No results are returned (resultCount === 0)\n *  - Results are returned but avgConfidence < threshold\n *  - Fewer than PARTIAL_RESULT_MIN results (partial match)\n *\n * @param ctx - Retrieval outcome context\n * @returns Structured recovery payload\n */\nexport function buildRecoveryPayload(ctx: RecoveryContext): RecoveryPayload {\n  const status = classifyStatus(ctx);\n  const reason = classifyReason(ctx, status);\n  const recommendedAction = recommendAction(status, reason);\n  const generatedSuggestions = generateSuggestedQueries(ctx);\n  const suggestedQueries = recommendedAction === 'ask_user' && generatedSuggestions.length === 0\n    ? synthesizeBroadeningSuggestions(ctx)\n    : generatedSuggestions;\n\n  return {\n    status,\n    reason,\n    suggestedQueries,\n    recommendedAction,\n  };\n}\n\n/**\n * Determine whether a search result set warrants recovery.\n *\n * Returns true when:\n *  - No results returned, OR\n *  - Average confidence below threshold, OR\n *  - Fewer than PARTIAL_RESULT_MIN results and avgConfidence is below mid-range\n *\n * @param ctx - Retrieval outcome context\n */\nexport function shouldTriggerRecovery(ctx: RecoveryContext): boolean {\n  if (ctx.resultCount === 0) return true;\n  if (ctx.evidenceGap) return true;\n\n  const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n\n  if (\n    typeof ctx.avgConfidence === 'number' &&\n    Number.isFinite(ctx.avgConfidence) &&\n    ctx.avgConfidence < threshold\n  ) return true;\n\n  if (ctx.resultCount < PARTIAL_RESULT_MIN) return true;\n\n  return false;\n}\n\n/**\n * Check whether the empty-result recovery feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n */\nexport { isEmptyResultRecoveryEnabled } from './search-flags.js';","lineStart":220,"lineEnd":395,"totalLines":395,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","time":{"start":1781764222496,"end":1781764222501}},"metadata":{"openai":{"itemId":"fc_0f714f64a4c72345016a33907e2694819194d64729ab1a7c45"}},"id":"prt_ed96c6d9f001ljLbDjQtIUcmGr","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96c4776001TyUHMTZCKII5sP"}}
