     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ live-executor — Mode B live executor (cli-opencode)                      ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * live-executor.cjs — Mode B live executor (cli-opencode).
     9	 *
    10	 * Runs a playbook routing/advisor scenario through a real `opencode run` and
    11	 * reads back what actually happened, normalized into the observed-result shape
    12	 * the scorer consumes. Validated against the live event schema (see the Phase 0
    13	 * spike): NDJSON events of shape { type, timestamp, sessionID, part }, where
    14	 *   - tool_use:  part.tool (e.g. "skill","read","glob","grep","bash"),
    15	 *                part.state.input, part.state.output
    16	 *   - text:      part.text  (the model's final answer)
    17	 *
    18	 * KEY observability fact: opencode emits no startup "resources loaded" manifest.
    19	 * So we run scenarios as routing-ANALYSIS prompts — the model STATES its routing
    20	 * in a fenced JSON block, which we grade against gold. tool_use events
    21	 * corroborate (a `skill` call with input.name === skillId is hard activation
    22	 * evidence; read/glob/grep on the skill's tree is observed discovery).
    23	 *
    24	 * Self-contained dispatch (does not reuse dispatch-model.cjs): MiniMax models
    25	 * reject `--agent`, which that helper hardcodes, and we need `--format json`.
    26	 * Model + binary come from env so no machine-specific id is baked in.
    27	 */
    28	
    29	// ─────────────────────────────────────────────────────────────────────────────
    30	// 1. IMPORTS/REQUIRES
    31	// ─────────────────────────────────────────────────────────────────────────────
    32	
    33	const fs = require('fs');
    34	const path = require('path');
    35	const { spawnSync } = require('child_process');
    36	
    37	// ─────────────────────────────────────────────────────────────────────────────
    38	// 2. CONSTANTS
    39	// ─────────────────────────────────────────────────────────────────────────────
    40	
    41	const DEFAULT_MODEL = process.env.SKILL_BENCH_OPENCODE_MODEL || 'deepseek/deepseek-v4-pro';
    42	const DEFAULT_VARIANT = process.env.SKILL_BENCH_OPENCODE_VARIANT || 'high';
    43	const OPENCODE_BIN = process.env.OPENCODE_BIN || 'opencode';
    44	const DISPATCH_TIMEOUT_MS = Number(process.env.SKILL_BENCH_DISPATCH_TIMEOUT_MS || 360000);
    45	const GRADED_RESPONSE_MAX_CHARS = 8000;
    46	
    47	// ─────────────────────────────────────────────────────────────────────────────
    48	// 3. CORE LOGIC
    49	// ─────────────────────────────────────────────────────────────────────────────
    50	
    51	/**
    52	 * Wrap the scenario prompt as a routing-ANALYSIS task with a strict output
    53	 * contract. CS-* scenarios are already analysis-shaped; SD/LS/RD/SA get the
    54	 * reframe. Route-gold cases add a declaration line before the fenced json block
    55	 * the parser can read.
    56	 *
    57	 * @param {Object} scenario - Scenario being dispatched.
    58	 * @returns {string} The routing-analysis dispatch prompt.
    59	 */
    60	function buildLiveDispatchPrompt(scenario, skillId) {
    61	  const base = scenario.prompt || '';
    62	  const skill = skillId || 'the target skill';
    63	  const prompt = [
    64	    'You are analyzing skill routing only - do NOT edit files.',
    65	    `Task: ${base}`,
    66	    '',
    67	    `Within the \`${skill}\` skill ONLY (do not route to or read any other skill), `
    68	      + "consulting that skill's SKILL.md router, determine: (1) the detected SURFACE "
    69	      + 'if the skill defines one (e.g. WEBFLOW / OPENCODE), else "UNKNOWN", (2) the '
    70	      + 'sub-language if any, else "none", (3) the exact reference/asset file paths you '
    71	      + 'would load (relative to the skill root, e.g. references/... and assets/...), '
    72	      + '(4) the agent you would dispatch, or "none".',
    73	  ];
    74	
    75	  if (hasRouteGold(scenario && scenario.expected)) {
    76	    prompt.push(
    77	      'As the FIRST line of your answer, emit this exact declaration shape:',
    78	      'ROUTED: {"workflowMode": "<mode>", "intents": ["<mode>", "..."]}',
    79	      'Then emit ONLY a fenced ```json code block, nothing after it:',
    80	    );
    81	  } else {
    82	    prompt.push('Then emit ONLY a fenced ```json code block, nothing after it:');
    83	  }
    84	
    85	  prompt.push(
    86	    '{"surface": "...", "subLanguage": "...", "resources": ["references/..."], '
    87	      + '"assets": ["assets/..."], "agent": "none", "disambiguation": false}',
    88	  );
    89	
    90	  return prompt.join('\n');
    91	}
    92	
    93	function dispatchArgs(model, dir, variant) {
    94	  const args = ['run', '--model', model];
    95	  // No explicit --agent: on this opencode build `general` is classified as a
    96	  // subagent (warns + falls back), and MiniMax rejects --agent outright. The
    97	  // default primary agent loads skills fine for a routing-analysis dispatch.
    98	  // Reasoning effort (provider-specific, e.g. high/max). Forwarded for all
    99	  // models, including MiniMax-M3 which accepts --variant and would otherwise
   100	  // silently lose its reasoning-effort setting.
   101	  if (variant) args.push('--variant', variant);
   102	  args.push('--format', 'json', '--dir', dir);
   103	  return args;
   104	}
   105	
   106	/**
   107	 * Run one `opencode run` dispatch via spawnSync and capture its streams.
   108	 *
   109	 * @param {Object} args - Dispatch inputs.
   110	 * @param {string} args.prompt - Prompt to send to the model.
   111	 * @param {string} args.dir - Working directory / project dir for the run.
   112	 * @param {string} args.model - Model id to dispatch.
   113	 * @param {string} args.variant - Reasoning-effort variant.
   114	 * @param {Object} [args.extraEnv] - Extra environment variables to inject.
   115	 * @returns {{ status:number, stdout:string, stderr:string, timedOut:boolean }}
   116	 */
   117	function runDispatch({ prompt, dir, model, variant, extraEnv }) {
   118	  model = model || DEFAULT_MODEL;
   119	  const res = spawnSync(OPENCODE_BIN, [...dispatchArgs(model, dir, variant), prompt], {
   120	    cwd: dir,
   121	    stdio: ['ignore', 'pipe', 'pipe'], // closed stdin == the mandatory </dev/null
   122	    encoding: 'utf8',
   123	    timeout: DISPATCH_TIMEOUT_MS,
   124	    maxBuffer: 32 * 1024 * 1024,
   125	    env: { ...process.env, AI_SESSION_CHILD: '1', ...(extraEnv || {}) },
   126	  });
   127	  return { status: res.status, stdout: res.stdout || '', stderr: res.stderr || '', timedOut: res.signal === 'SIGTERM' };
   128	}
   129	
   130	/**
   131	 * Collect brace-balanced object candidates from prose.
   132	 *
   133	 * @param {string} text - Text to scan for JSON-looking objects.
   134	 * @returns {Array<string>} Complete object substrings in encounter order.
   135	 */
   136	function collectBraceBalancedObjects(text) {
   137	  const candidates = [];
   138	  let start = -1;
   139	  let depth = 0;
   140	  let inString = false;
   141	  let escaped = false;
   142	  for (let i = 0; i < text.length; i += 1) {
   143	    const ch = text[i];
   144	    if (inString) {
   145	      if (escaped) escaped = false;
   146	      else if (ch === '\\') escaped = true;
   147	      else if (ch === '"') inString = false;
   148	      continue;
   149	    }
   150	    if (ch === '"') {
   151	      inString = true;
   152	      continue;
   153	    }
   154	    if (ch === '{') {
   155	      if (depth === 0) start = i;
   156	      depth += 1;
   157	    } else if (ch === '}' && depth > 0) {
   158	      depth -= 1;
   159	      if (depth === 0 && start >= 0) {
   160	        candidates.push(text.slice(start, i + 1));
   161	        start = -1;
   162	      }
   163	    }
   164	  }
   165	  return candidates;
   166	}
   167	
   168	function parseEvents(stdout) {
   169	  const events = [];
   170	  for (const line of String(stdout).split('\n')) {
   171	    const t = line.trim();
   172	    if (!t) continue;
   173	    try { events.push(JSON.parse(t)); } catch { /* tolerate non-JSON log lines */ }
   174	  }
   175	  return events;
   176	}
   177	
   178	/**
   179	 * Cross-model robust extraction of the stated-routing JSON. Models vary: some
   180	 * emit ```json fences (MiniMax), some plain ``` fences or none (gpt-5.5). Try,
   181	 * in order: any-tag fenced block, then a bare brace-balanced object mentioning
   182	 * "surface". Returns the LAST valid routing object (models often restate).
   183	 *
   184	 * @param {string} text - The model's response text to scan.
   185	 * @returns {Object|null} The recovered routing object, or null if none found.
   186	 */
   187	function extractRoutingJson(text) {
   188	  const s = String(text);
   189	  const isRouting = (j) => j && typeof j === 'object' && ('surface' in j || 'resources' in j);
   190	  const fences = [...s.matchAll(/```[a-z]*\s*([\s\S]*?)```/gi)];
   191	  for (let i = fences.length - 1; i >= 0; i -= 1) {
   192	    try { const j = JSON.parse(fences[i][1].trim()); if (isRouting(j)) return j; } catch { /* next */ }
   193	  }
   194	  // Bare object: collect balanced candidates so nested routing payloads parse.
   195	  const objs = collectBraceBalancedObjects(s);
   196	  for (let i = objs.length - 1; i >= 0; i -= 1) {
   197	    if (!/surface/i.test(objs[i])) continue;
   198	    try { const j = JSON.parse(objs[i]); if (isRouting(j)) return j; } catch { /* next */ }
   199	  }
   200	  return null;
   201	}
   202	
   203	function normalizeStringList(value) {
   204	  const list = Array.isArray(value) ? value : [value];
   205	  return [...new Set(list
   206	    .filter((entry) => typeof entry === 'string')
   207	    .map((entry) => entry.trim())
   208	    .filter(Boolean))];
   209	}
   210	
   211	/**
   212	 * Extract the live route declaration emitted before the routing-analysis block.
   213	 * Returns the last valid declaration because models sometimes restate answers.
   214	 *
   215	 * @param {string} text - The model's response text to scan.
   216	 * @returns {Object} Parsed declaration metadata.
   217	 */
   218	function parseRoutedDeclaration(text) {
   219	  const s = String(text);
   220	  const matches = [...s.matchAll(/(^|\n)\s*ROUTED:\s*/gi)];
   221	  let last = null;
   222	
   223	  for (const match of matches) {
   224	    const afterPrefix = match.index + match[0].length;
   225	    const rest = s.slice(afterPrefix);
   226	    const firstNonSpace = /\S/.exec(rest);
   227	    if (!firstNonSpace || rest[firstNonSpace.index] !== '{') continue;
   228	
   229	    const objs = collectBraceBalancedObjects(rest.slice(firstNonSpace.index));
   230	    if (objs.length === 0) continue;
   231	
   232	    try {
   233	      const declaration = JSON.parse(objs[0]);
   234	      if (!declaration || typeof declaration !== 'object') continue;
   235	
   236	      const workflowMode = normalizeStringList(declaration.workflowMode);
   237	      let intents = normalizeStringList(declaration.intents);
   238	      if (intents.length === 0 && workflowMode.length > 0) intents = workflowMode;
   239	      if (workflowMode.length === 0 && intents.length === 0) continue;
   240	
   241	      last = {
   242	        present: true,
   243	        workflowMode: workflowMode.length > 0 ? workflowMode : intents,
   244	        intents,
   245	      };
   246	    } catch (_) {
   247	      // Malformed declarations are treated as absent.
   248	    }
   249	  }
   250	
   251	  return last || { present: false };
   252	}
   253	
   254	/**
   255	 * Last-resort prose fallback: when the model answered in prose with no JSON,
   256	 * recover the surface keyword and any referenced skill paths so the run still
   257	 * yields a (lower-confidence) signal instead of a null.
   258	 *
   259	 * @param {string} text - The model's prose response text.
   260	 * @returns {Object|null} Recovered routing-like object, or null if nothing found.
   261	 */
   262	function proseRoutingFallback(text) {
   263	  const s = String(text);
   264	  const surfM = /\b(WEBFLOW|OPENCODE|UNKNOWN|MOTION_DEV)\b/.exec(s.toUpperCase());
   265	  const resources = [...new Set((s.match(/(?:code-[a-z]+|references|assets)\/[A-Za-z0-9_./-]+\.[a-z]{1,4}/g) || []))];
   266	  if (!surfM && resources.length === 0) return null;
   267	  return { surface: surfM ? surfM[1] : null, resources, assets: [], _recovered: 'prose' };
   268	}
   269	
   270	/**
   271	 * Parse the live NDJSON event stream into the normalized observed result.
   272	 *
   273	 * @param {string} stdout - Raw NDJSON stdout from the dispatch.
   274	 * @param {Object} [opts] - Parse options.
   275	 * @param {string} [opts.skillId] - Skill id used to detect activation/reads.
   276	 * @param {boolean} [opts.requireRouteDeclaration] - Mark route-gold misses.
   277	 * @returns observed-result consumed by score-skill-benchmark.scoreScenario
   278	 */
   279	function parseLiveResult(stdout, { skillId, requireRouteDeclaration = false } = {}) {
   280	  const events = parseEvents(stdout);
   281	  const toolCalls = [];
   282	  let activated = false;
   283	  const observedReads = [];
   284	  const textParts = [];
   285	
   286	  for (const e of events) {
   287	    const p = e && e.part;
   288	    if (e && e.type === 'text' && p && typeof p.text === 'string') textParts.push(p.text);
   289	    if (e && e.type === 'tool_use' && p && p.tool) {
   290	      const input = (p.state && p.state.input) || {};
   291	      toolCalls.push({ tool: p.tool, input });
   292	      if (p.tool === 'skill' && skillId && input.name === skillId) activated = true;
   293	      if (/^(read|glob|grep|bash)$/i.test(p.tool)) {
   294	        const blob = JSON.stringify(input);
   295	        if (skillId && blob.includes(skillId)) {
   296	          const m = blob.match(/(?:code-[a-z]+|references|assets)\/[A-Za-z0-9_./*-]+/g);
   297	          if (m) observedReads.push(...m);
   298	        }
   299	      }
   300	    }
   301	  }
   302	
   303	  const responseText = textParts.join('');
   304	  const stated = extractRoutingJson(responseText) || proseRoutingFallback(responseText) || {};
   305	  const statedResources = Array.isArray(stated.resources) ? stated.resources : [];
   306	  const statedAssets = Array.isArray(stated.assets) ? stated.assets : [];
   307	  const surfaceRaw = (stated.surface || '').toString().toUpperCase();
   308	  const statedSurface = ['WEBFLOW', 'OPENCODE', 'UNKNOWN', 'MOTION_DEV', 'NONE'].includes(surfaceRaw) ? surfaceRaw : null;
   309	  const routed = parseRoutedDeclaration(responseText);
   310	
   311	  const result = {
   312	    mode: 'live',
   313	    parseable: events.length > 0,
   314	    observedIntents: routed.present ? routed.intents : [],
   315	    // The model's STATED routing is the primary discovery signal; observed file
   316	    // reads corroborate. References and assets are kept on SEPARATE channels:
   317	    // D2/D3 score references only, asset support is scored on its own lane. The
   318	    // router defers assets on demand, so counting a stated, useful asset as a
   319	    // routed reference made it read as efficiency waste — a measurement artifact.
   320	    observedResources: [...new Set(statedResources)],
   321	    observedAssets: [...new Set(statedAssets)],
   322	    observedSurface: statedSurface,
   323	    statedRoutingCorrect: null,
   324	    activation: { activated, topSkill: activated ? skillId : null },
   325	    missingResources: [],
   326	    raw: { eventCount: events.length, toolCalls, observedReads: [...new Set(observedReads)], stated, responseText: responseText.slice(0, GRADED_RESPONSE_MAX_CHARS) },
   327	  };
   328	
   329	  if (routed.present) {
   330	    result.observedWorkflowMode = routed.workflowMode.length === 1 ? routed.workflowMode[0] : routed.workflowMode;
   331	    result.routeDeclaration = { present: true };
   332	    result.raw.routeTelemetry = {
   333	      observed: true,
   334	      source: 'live-declaration',
   335	      workflowMode: routed.workflowMode,
   336	    };
   337	  } else if (requireRouteDeclaration) {
   338	    result.routeDeclaration = { present: false, reason: 'route-declaration-missing' };
   339	    result.raw.routeTelemetry = { observed: false, reason: 'route-declaration-missing' };
   340	  }
     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ executor-dispatch — orchestrator-to-executor seam, normalized results    ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * executor-dispatch.cjs — the seam between the orchestrator and the three
     9	 * scenario executors. It normalizes every executor's output into ONE observed
    10	 * result the scorer consumes, so the orchestrator never branches on executor
    11	 * internals.
    12	 *
    13	 *   classKind routing/advisor + trace-mode router          → routeSkillResources (deterministic)
    14	 *   classKind routing/advisor + trace-mode live            → live-executor.cjs (cli-opencode)
    15	 *   classKind routing/advisor + trace-mode live + codex    → codex-executor.cjs (cli-codex via runtime)
    16	 *   classKind browser                                      → browser-executor.cjs (bdg)
    17	 *
    18	 * The live/browser executors are lazy-required so router mode stays
    19	 * dependency-free and CI-safe even before those siblings ship.
    20	 */
    21	
    22	// ─────────────────────────────────────────────────────────────────────────────
    23	// 1. IMPORTS/REQUIRES
    24	// ─────────────────────────────────────────────────────────────────────────────
    25	
    26	const path = require('path');
    27	const { routeSkillResources } = require('./router-replay.cjs');
    28	
    29	// ─────────────────────────────────────────────────────────────────────────────
    30	// 2. CONSTANTS
    31	// ─────────────────────────────────────────────────────────────────────────────
    32	
    33	// Selected-map union bundle cap: a normal query stays inside the top two
    34	// selected workflow modes, mirroring validate-playbook-topology.cjs's own
    35	// simultaneous-mode cap. A fixed numeric cap on resource COUNT would break a
    36	// legitimate wide-bundle scenario (a mode can legitimately carry many leaves),
    37	// so the cap is structural (mode count) and bypassed only by the named
    38	// `fullInventoryIntent` flag below, never inferred from the resource count.
    39	const MAX_WORKFLOW_MODES = 2;
    40	
    41	// ─────────────────────────────────────────────────────────────────────────────
    42	// 3. RESOURCE-CONTRACT HELPERS
    43	// ─────────────────────────────────────────────────────────────────────────────
    44	
    45	/**
    46	 * Cap the router's selected workflow modes to the union bundle limit, in the
    47	 * router's own scored order, unless the scenario explicitly opts into the
    48	 * full-inventory intent.
    49	 *
    50	 * @param {Object} args - Cap inputs.
    51	 * @param {string[]} args.intents - Router-selected intents (workflowModes for a manifest-bearing skill).
    52	 * @param {boolean} args.fullInventoryIntent - Explicit bypass flag; never inferred.
    53	 * @returns {string[]} The capped (or full, when bypassed) workflow-mode selection.
    54	 */
    55	function cappedWorkflowModes({ intents, fullInventoryIntent }) {
    56	  const modes = Array.isArray(intents) ? intents : [];
    57	  return fullInventoryIntent ? modes : modes.slice(0, MAX_WORKFLOW_MODES);
    58	}
    59	
    60	/**
    61	 * Re-key the router's uncapped typed-pair bundle onto the capped workflow-mode
    62	 * selection. A no-op (returns null) unless the target skill produced a
    63	 * resourceContract at all, i.e. it ships a leaf-manifest.json — every other
    64	 * skill's dispatch stays exactly as it was before this contract existed.
    65	 *
    66	 * @param {Object} args - Bundle inputs.
    67	 * @param {Object} args.router - The routeSkillResources() result.
    68	 * @param {Object} args.scenario - The scenario being dispatched.
    69	 * @returns {{resourceContractVersion:number,workflowModes:string[],fullInventoryIntent:boolean,pairs:Array,unresolved:string[]}|null} Capped bundle, or null when not applicable.
    70	 */
    71	function buildTypedResourceContract({ router, scenario }) {
    72	  const uncapped = router && router.resourceContract;
    73	  if (!uncapped) return null;
    74	  // The workflow mode is a projection of the surface-resolved leaves, not an
    75	  // independent hub pick: advertise exactly the modes the emitted pairs belong
    76	  // to, so a loaded contract can never diverge from what it announces. The hub
    77	  // intents survive only as telemetry (observedIntents), never gating leaves.
    78	  const surfaceModes = [...new Set((uncapped.pairs || []).map((pair) => pair.workflowMode))];
    79	  const fullInventoryIntent = !!(scenario && scenario.fullInventoryIntent === true)
    80	    || (Array.isArray(router.surfaceIntents) && router.surfaceIntents.includes('FULL_INVENTORY'));
    81	  const workflowModes = cappedWorkflowModes({ intents: surfaceModes, fullInventoryIntent });
    82	  const selected = new Set(workflowModes);
    83	  const pairs = (uncapped.pairs || []).filter((pair) => selected.has(pair.workflowMode));
    84	  // Fail closed: a non-empty resolution that collapses to zero typed pairs is a
    85	  // routing bug, never a silent empty contract that reads as "nothing to load".
    86	  if (pairs.length === 0 && (uncapped.pairs || []).length > 0) {
    87	    throw new Error('typed resource contract collapsed to zero pairs from a non-empty leaf resolution');
    88	  }
    89	  return {
    90	    resourceContractVersion: uncapped.resourceContractVersion,
    91	    workflowModes,
    92	    fullInventoryIntent,
    93	    pairs,
    94	    unresolved: uncapped.unresolved,
    95	  };
    96	}
    97	
    98	// ─────────────────────────────────────────────────────────────────────────────
    99	// 4. CORE LOGIC
   100	// ─────────────────────────────────────────────────────────────────────────────
   101	
   102	/**
   103	 * Normalized observed-result the scorer consumes regardless of executor:
   104	 * {
   105	 *   mode, executor, classKind,
   106	 *   parseable: bool,
   107	 *   observedIntents: string[],
   108	 *   observedResources: string[],   // router: routed refs; live: stated/observed refs
   109	 *   observedSurface: string|null,
   110	 *   statedRoutingCorrect: bool|null,
   111	 *   activation: { activated: bool, topSkill: string|null } | null,
   112	 *   missingResources: string[],
   113	 *   routedOut?: bool, reason?: string, error?: string,
   114	 *   raw: object
   115	 * }
   116	 *
   117	 * @param {Object} [args] - Dispatch inputs.
   118	 * @param {Object} args.scenario - Scenario to execute.
   119	 * @param {string} args.skillRoot - Absolute path to the skill root.
   120	 * @param {string} args.traceMode - Trace mode ('live' or router/CI default).
   121	 * @param {string} [args.executor] - Optional executor override for live mode.
   122	 * @returns {Object} Normalized observed-result for the scorer.
   123	 */
   124	function dispatchScenario({ scenario, skillRoot, traceMode, executor } = {}) {
   125	  const classKind = scenario.classKind || 'routing';
   126	
   127	  if (classKind === 'browser') {
   128	    // Browser scenarios need a real browser (bdg). Run them only in live mode;
   129	    // in router (CI) mode keep them routed-out so the gate stays deterministic
   130	    // and offline.
   131	    if (traceMode !== 'live') {
   132	      return {
   133	        mode: 'browser', classKind, executor: 'browser-executor',
   134	        parseable: false, observedIntents: [], observedResources: [], observedSurface: null,
   135	        statedRoutingCorrect: null, activation: null, missingResources: [],
   136	        routedOut: true, reason: 'browser scenario — run in live mode (needs bdg)', raw: null,
   137	      };
   138	    }
   139	    return runOptionalExecutor('./browser-executor.cjs', 'executeBrowserScenario',
   140	      { scenario, skillRoot }, { mode: 'browser', classKind });
   141	  }
   142	
   143	  if (traceMode === 'live') {
   144	    // The codex transport dispatches through the runtime-owned helper (cli-codex
   145	    // single-adapter rule); the opencode transport spawns opencode directly.
   146	    if (executor === 'codex') {
   147	      return runOptionalExecutor('./codex-executor.cjs', 'runCodexScenario',
   148	        { scenario, skillRoot }, { mode: 'live', classKind, executor: 'codex-executor' });
   149	    }
   150	    return runOptionalExecutor('./live-executor.cjs', 'runLiveScenario',
   151	      { scenario, skillRoot, executor }, { mode: 'live', classKind });
   152	  }
   153	
   154	  // Default: deterministic router-replay (the CI gate path).
   155	  const router = routeSkillResources({ skillRoot, taskText: scenario.prompt || '' });
   156	  const resourceContract = buildTypedResourceContract({ router, scenario });
   157	  return {
   158	    mode: 'router',
   159	    executor: 'router-replay',
   160	    classKind,
   161	    parseable: router.parseable,
   162	    observedIntents: router.intents || [],
   163	    observedResources: router.resources || [],
   164	    observedSurface: null,
   165	    statedRoutingCorrect: null,
   166	    activation: null,
   167	    missingResources: router.missingResources || [],
   168	    raw: router,
   169	    ...(resourceContract ? { resourceContract } : {}),
   170	  };
   171	}
   172	
   173	// Lazy-load a sibling executor; if it is not built yet, degrade to a recorded
   174	// "executor-unavailable" observation rather than crashing the run.
   175	function runOptionalExecutor(moduleRel, fnName, callArgs, base) {
   176	  let mod;
   177	  try {
   178	    // eslint-disable-next-line global-require
   179	    mod = require(path.join(__dirname, moduleRel));
   180	  } catch (err) {
   181	    const reason = base.mode === 'browser'
   182	      ? 'browser harness not yet built (Phase 3)'
   183	      : 'live executor not yet built (Phase 2)';
   184	    return {
   185	      ...base, executor: moduleRel.replace(/^\.\/|\.cjs$/g, ''),
   186	      parseable: false, observedIntents: [], observedResources: [], observedSurface: null,
   187	      statedRoutingCorrect: null, activation: null, missingResources: [],
   188	      routedOut: base.mode === 'browser', reason, error: err.message,
   189	      raw: null,
   190	    };
   191	  }
   192	  const result = mod[fnName](callArgs);
   193	  // Trust the sibling to return the normalized shape; backfill base fields.
   194	  return { ...base, ...result };
   195	}
   196	
   197	// ─────────────────────────────────────────────────────────────────────────────
   198	// 5. EXPORTS
   199	// ─────────────────────────────────────────────────────────────────────────────
   200	
   201	module.exports = { dispatchScenario, cappedWorkflowModes, buildTypedResourceContract, MAX_WORKFLOW_MODES };
     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ run-skill-benchmark — Lane C orchestrator                                ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * run-skill-benchmark.cjs — Lane C orchestrator (loop-host --mode=skill-benchmark).
     9	 *
    10	 * Post-run join: private gold never crosses the dispatch boundary. Sequence:
    11	 *   1. resolve the target skill root (path or bare id under .opencode/skills/)
    12	 *   2. D5 static connectivity scan (the hard gate) — runs first, before any dispatch
    13	 *   3. load public/private fixture pairs
    14	 *   4. per scenario: contamination-lint the PUBLIC prompt (a leak is a fixture
    15	 *      failure), then router-replay (Mode A), then join with private gold to score
    16	 *   5. aggregate -> write report.json, then render report.md FROM it
    17	 *
    18	 * Mode A (router-replay) is the deterministic default and the CI gate. Live
    19	 * dispatch (Mode B) + D1-inter advisor scoring + D4 ablation are follow-on; this
    20	 * orchestrator emits a complete, honest Mode A report today.
    21	 */
    22	
    23	// ─────────────────────────────────────────────────────────────────────────────
    24	// 1. IMPORTS
    25	// ─────────────────────────────────────────────────────────────────────────────
    26	
    27	const fs = require('fs');
    28	const path = require('path');
    29	const crypto = require('crypto');
    30	const { routeSkillResources } = require('./router-replay.cjs');
    31	const { buildBannedVocab, lintFixture } = require('./contamination-lint.cjs');
    32	const { scanConnectivity, scanHubRegistry } = require('./d5-connectivity.cjs');
    33	const { scoreScenario, aggregate, evaluateRouteGold } = require('./score-skill-benchmark.cjs');
    34	const { probeAdvisor } = require('./advisor-probe.cjs');
    35	const { renderReport } = require('./build-report.cjs');
    36	const { loadPlaybookScenarios } = require('./load-playbook-scenarios.cjs');
    37	const { dispatchScenario } = require('./executor-dispatch.cjs');
    38	
    39	// ─────────────────────────────────────────────────────────────────────────────
    40	// 2. CONSTANTS
    41	// ─────────────────────────────────────────────────────────────────────────────
    42	
    43	const SKILLS_DIR = path.resolve(__dirname, '..', '..', '..', '..'); // .opencode/skills
    44	
    45	// ─────────────────────────────────────────────────────────────────────────────
    46	// 3. HELPERS
    47	// ─────────────────────────────────────────────────────────────────────────────
    48	
    49	/**
    50	 * Resolve a skill argument to an absolute root: a path/relative arg resolves
    51	 * as-is, a bare id resolves under .opencode/skills/.
    52	 *
    53	 * @param {string} skillArg - Skill path or bare id.
    54	 * @returns {string} Absolute skill root dir.
    55	 */
    56	function resolveSkillRoot(skillArg) {
    57	  if (skillArg.includes('/') || skillArg.startsWith('.')) return path.resolve(skillArg);
    58	  return path.join(SKILLS_DIR, skillArg);
    59	}
    60	
    61	function resolveSkillId(skillRoot) {
    62	  return path.basename(skillRoot);
    63	}
    64	
    65	// Hub-type detection for the route-gold gate default: a skill that ships a
    66	// hub-router.json routes between packets by contract, so its route gold is
    67	// enforced by default; flat skills opt in per run.
    68	function isHubTypeSkill(skillRoot) {
    69	  return fs.existsSync(path.join(skillRoot, 'hub-router.json'));
    70	}
    71	
    72	/**
    73	 * Resolve the route-gold gate flag: `--route-gold on|off|auto` (default auto).
    74	 * `auto` derives from the target: ON for hub-type skills, OFF otherwise.
    75	 * Gate ON means any route-gold violation (including a gold parse failure)
    76	 * fails the run verdict; the report records flag state and row count either way.
    77	 *
    78	 * @param {Object} args - Parsed CLI args.
    79	 * @param {string} skillRoot - Target skill root dir.
    80	 * @returns {{mode:'on'|'off'|'auto', enabled:boolean}} Gate configuration.
    81	 */
    82	function resolveRouteGold(args, skillRoot) {
    83	  const raw = args['route-gold'] == null ? 'auto' : String(args['route-gold']).toLowerCase();
    84	  if (!['on', 'off', 'auto'].includes(raw)) {
    85	    throw new Error(`invalid --route-gold value "${raw}" (expected on|off|auto)`);
    86	  }
    87	  const enabled = raw === 'on' || (raw === 'auto' && isHubTypeSkill(skillRoot));
    88	  return { mode: raw, enabled };
    89	}
    90	
    91	/**
    92	 * Digest a skill's committed leaf-manifest.json, when it has one. Used to
    93	 * detect a manifest edited out from under a run in progress; a skill with no
    94	 * manifest at all always digests to null and never engages the abort below.
    95	 *
    96	 * @param {string} skillRoot - Skill root dir.
    97	 * @returns {string|null} Hex sha256 digest, or null when no manifest exists.
    98	 */
    99	function readManifestDigest(skillRoot) {
   100	  const manifestPath = path.join(skillRoot, 'leaf-manifest.json');
   101	  if (!fs.existsSync(manifestPath)) return null;
   102	  return crypto.createHash('sha256').update(fs.readFileSync(manifestPath)).digest('hex');
   103	}
   104	
   105	/**
   106	 * Load public/private fixture pairs from a fixtures dir
   107	 * (assets/skill-benchmark/fixtures/<skill-id>/ with <id>.public.json +
   108	 * <id>.private.json pairs). Falls back to the --fixtures-dir override.
   109	 *
   110	 * @param {string} fixturesDir - Directory containing fixture pairs.
   111	 * @returns {Array<Object>} Loaded fixture rows (malformed pairs carry loadError).
   112	 */
   113	function loadFixtures(fixturesDir) {
   114	  const out = [];
   115	  if (!fs.existsSync(fixturesDir)) return out;
   116	  const publics = fs.readdirSync(fixturesDir).filter((f) => f.endsWith('.public.json'));
   117	  for (const pf of publics) {
   118	    const id = pf.replace(/\.public\.json$/, '');
   119	    // A malformed fixture is operator error this tool exists to surface, not a
   120	    // reason to crash the whole run. Degrade: record a load error and skip.
   121	    let pub; let priv;
   122	    try {
   123	      pub = JSON.parse(fs.readFileSync(path.join(fixturesDir, pf), 'utf8'));
   124	      const privPath = path.join(fixturesDir, `${id}.private.json`);
   125	      priv = fs.existsSync(privPath) ? JSON.parse(fs.readFileSync(privPath, 'utf8')) : { expected: {} };
   126	    } catch (err) {
   127	      out.push({ scenarioId: id, loadError: err.message });
   128	      continue;
   129	    }
   130	    out.push({ scenarioId: pub.scenarioId || id, tier: pub.tier || 'T1', public: pub.public || {}, expected: priv.expected || {}, rubric: priv.rubric });
   131	  }
   132	  return out;
   133	}
   134	
   135	// Legacy synthetic-fixture loop (kept for back-compat + malformed-fixture
   136	// surfacing). Used only when --fixtures-dir is given explicitly.
   137	function runLegacyFixtures({ fixturesDir, skillRoot, skillId, advisorMode, scenarioRows }) {
   138	  for (const fx of loadFixtures(fixturesDir)) {
   139	    if (fx.loadError) {
   140	      scenarioRows.push({
   141	        scenarioId: fx.scenarioId, tier: 'unknown', modeAScore: 0,
   142	        firstFailingStage: 'unparseable-fixture',
   143	        dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },
   144	        loadError: fx.loadError,
   145	      });
   146	      continue;
   147	    }
   148	    const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: fx.expected });
   149	    const lint = lintFixture({ publicText: fx.public.prompt || '', bannedVocab });
   150	    if (!lint.passed) {
   151	      scenarioRows.push({
   152	        scenarioId: fx.scenarioId, tier: fx.tier, modeAScore: 0,
   153	        firstFailingStage: 'contaminated-fixture',
   154	        dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },
   155	        contamination: lint.hardLeaks,
   156	      });
   157	      continue;
   158	    }
   159	    const routerResult = routeSkillResources({ skillRoot, taskText: fx.public.prompt || '' });
   160	    const advisorResult = advisorMode === 'python'
   161	      ? probeAdvisor({ prompt: fx.public.prompt || '' }) : undefined;
   162	    scenarioRows.push(scoreScenario({ scenarioId: fx.scenarioId, tier: fx.tier, routerResult, expected: fx.expected, advisorResult }));
   163	  }
   164	}
   165	
   166	function filterScenarios(scenarios, filter) {
   167	  if (!filter) return scenarios;
   168	  const f = String(filter).toLowerCase();
   169	  if (f === 'critical') return scenarios.filter((s) => s.critical);
   170	  const ids = new Set(f.split(',').map((x) => x.trim().toUpperCase()));
   171	  return scenarios.filter((s) => ids.has(s.scenarioId.toUpperCase()));
   172	}
   173	
   174	// Default corpus: the skill's manual_testing_playbook. Each scenario routes to
   175	// the executor for its classKind; browser scenarios are routed out of the text
   176	// executors. Contamination-lint is a drift FINDING in router mode (the playbook
   177	// intentionally carries trigger words) and is skipped entirely in live mode.
   178	function runPlaybook({ skillRoot, skillId, traceMode, advisorMode, executor, playbookDir, scenariosFilter, scenarioRows, lintFindings, warningsOut }) {
   179	  let scenarios;
   180	  let warnings;
   181	  try {
   182	    ({ scenarios, warnings } = loadPlaybookScenarios({ skillRoot, playbookDir }));
   183	  } catch (err) {
   184	    // A skill with no playbook corpus at all scores zero scenarios rather than
   185	    // aborting: the structural/registry connectivity gate is evaluated upstream
   186	    // and independently, so an absent corpus must not preempt its verdict. A
   187	    // legacy underscore playbook root stays fail-closed — only the genuinely
   188	    // empty case is absorbed here; every other load error re-throws.
   189	    if (!err || err.code !== 'MISSING_PLAYBOOK_ROOT') throw err;
   190	    scenarios = [];
   191	    warnings = [];
   192	  }
   193	  if (warningsOut) warningsOut.push(...warnings);
   194	  for (const sc of filterScenarios(scenarios, scenariosFilter)) {
   195	    const observed = dispatchScenario({ scenario: sc, skillRoot, traceMode, executor });
   196	    if (sc.classKind === 'browser') {
   197	      if (observed.routedOut || observed.error) {
   198	        // Router/CI mode, or the browser harness was unavailable.
   199	        scenarioRows.push({
   200	          scenarioId: sc.scenarioId, classKind: 'browser', routedOut: true,
   201	          reason: observed.reason || observed.error || 'browser scenario — routed to browser harness',
   202	        });
   203	      } else {
   204	        // Live mode: browser-executor returned a full scenario row (with a verdict).
   205	        scenarioRows.push(observed);
   206	      }
   207	      continue;
   208	    }
   209	    if (traceMode === 'router' && sc.prompt) {
   210	      const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: { resources: sc.expectedResources } });
   211	      const lint = lintFixture({ publicText: sc.prompt, bannedVocab });
   212	      if (!lint.passed) lintFindings.push({ scenarioId: sc.scenarioId, leaks: lint.hardLeaks.map((h) => h.term) });
   213	    }
   214	    const advisorResult = (advisorMode === 'python' && sc.classKind === 'advisor' && sc.prompt)
   215	      ? probeAdvisor({ prompt: sc.prompt }) : undefined;
   216	    const row = scoreScenario({ scenario: sc, skillId, observed, advisorResult, traceMode });
   217	    // Route-gold lane: evaluated on every row that carries authored gold so
   218	    // the report always shows the counts; the gate flag decides enforcement.
   219	    row.routeGold = evaluateRouteGold({ scenario: sc, observed });
   220	    scenarioRows.push(row);
   221	  }
   222	}
   223	
   224	// ─────────────────────────────────────────────────────────────────────────────
   225	// 4. CORE LOGIC
   226	// ─────────────────────────────────────────────────────────────────────────────
   227	
   228	/**
   229	 * Run the Lane C benchmark: resolve skill, D5 connectivity gate, score scenarios
   230	 * (legacy fixtures or playbook), aggregate, and write report.{json,md}.
   231	 *
   232	 * @param {Object} args - Parsed CLI args.
   233	 * @returns {number} Process exit code (0 success, 2 on missing SKILL.md,
   234	 *   3 when the D5 structural/registry gate blocked the verdict).
   235	 */
   236	function run(args) {
   237	  const skillRoot = resolveSkillRoot(args.skill);
   238	  const skillId = resolveSkillId(skillRoot);
   239	  const outputsDir = path.resolve(args['outputs-dir']);
   240	  fs.mkdirSync(outputsDir, { recursive: true });
   241	  const advisorMode = args['advisor-mode'] || 'off';
   242	  // The internal fallback stays 'router' so direct run() calls (the test suite)
   243	  // are deterministic; the live default is injected by loop-host for operators.
   244	  const traceMode = args['trace-mode'] || 'router';
   245	
   246	  if (!fs.existsSync(path.join(skillRoot, 'SKILL.md'))) {
   247	    process.stderr.write(`run-skill-benchmark: no SKILL.md at ${skillRoot}\n`);
   248	    return 2;
   249	  }
   250	
   251	  let routeGold;
   252	  try {
   253	    routeGold = resolveRouteGold(args, skillRoot);
   254	  } catch (err) {
   255	    process.stderr.write(`run-skill-benchmark: ${err.message}\n`);
   256	    return 2;
   257	  }
   258	
   259	  // Topology digest snapshot: a manifest-bearing skill's leaf-manifest.json
   260	  // must not change while a run is scoring against it, or the scored rows and
   261	  // the committed gold would silently drift apart mid-run. A skill with no
   262	  // manifest digests to null and never reaches the abort check below.
   263	  const topologyDigestBefore = readManifestDigest(skillRoot);
   264	
   265	  // D5 hard gate first.
   266	  const connectivity = scanConnectivity({ skillRoot });
   267	  const hubRegistry = scanHubRegistry({ skillRoot });
   268	
   269	  const scenarioRows = [];
   270	  const lintFindings = [];
   271	  const warnings = [];
   272	  if (args['fixtures-dir']) {
   273	    runLegacyFixtures({ fixturesDir: path.resolve(args['fixtures-dir']), skillRoot, skillId, advisorMode, scenarioRows });
   274	  } else {
   275	    runPlaybook({
   276	      skillRoot, skillId, traceMode, advisorMode, executor: args.executor,
   277	      playbookDir: args['playbook-dir'],
   278	      scenariosFilter: args.scenarios, scenarioRows, lintFindings, warningsOut: warnings,
   279	    });
   280	  }
   281	
   282	  const topologyDigestAfter = readManifestDigest(skillRoot);
   283	  if (topologyDigestBefore !== null && topologyDigestBefore !== topologyDigestAfter) {
   284	    process.stderr.write(
   285	      `run-skill-benchmark: topology_changed_during_run — leaf-manifest.json changed while scoring ${skillId} `
   286	      + `(before=${topologyDigestBefore} after=${topologyDigestAfter}); aborting rather than scoring against a shifted manifest\n`,
   287	    );
   288	    return 4;
   289	  }
   290	
   291	  // aggregate + emit.
   292	  const report = aggregate({ skillId, skillRoot, scenarioRows, connectivity, hubRegistry, traceMode, lintFindings, routeGold });
   293	  if (topologyDigestBefore !== null) report.topologyDigest = topologyDigestBefore;
   294	  if (warnings.length) report.parseWarnings = warnings;
   295	  const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');
   296	  const reportMdPath = reportJsonPath.replace(/\.json$/, '.md');
   297	  fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   298	  fs.writeFileSync(reportMdPath, renderReport(report));
   299	
   300	  process.stdout.write(`skill-benchmark: ${skillId} verdict=${report.verdict} aggregate=${report.aggregateScore} scenarios=${scenarioRows.length}\n`);
   301	  process.stdout.write(`  report.json -> ${reportJsonPath}\n  report.md   -> ${reportMdPath}\n`);
   302	  // The D5 gate exists to make a structurally-broken skill (dead router, broken
   303	  // hub registry) unusable regardless of weighted score. An exit code that stays
   304	  // 0 on that verdict lets a CI caller treat "blocked" the same as "passed" —
   305	  // reports still write either way, but the process signal must disagree. The
   306	  // route-gold gate carries the same contract: an enforced route-contract
   307	  // violation must be a non-zero process signal, not just report text.
   308	  if (report.verdict === 'BLOCKED-BY-STRUCTURE'
   309	      || report.verdict === 'BLOCKED-BY-REGISTRY'
   310	      || report.verdict === 'BLOCKED-BY-ROUTE-GOLD') return 3;
   311	  return 0;
   312	}
   313	
   314	// Opt-in D4-R pass (live + paid). Kept OUT of the synchronous run() so the
   315	// deterministic test suite (which calls run() and reads the report immediately)
   316	// stays sync. Re-reads the report run() wrote, runs the task-outcome ablation on
   317	// the explicitly selected scenarios, attaches each row's d4TaskOutcome, recomputes
   318	// the advisory D4_task_outcome aggregate, and re-writes report.{json,md}. D4-R runs
   319	// only on target-owned scenarios named via --d4-scenarios (or --scenarios); there
   320	// are no cross-target defaults, which would silently borrow another skill's ids.
   321	
   322	/**
   323	 * Opt-in D4-R pass: re-read the written report, run the task-outcome ablation on
   324	 * the chosen scenarios, attach each row's d4TaskOutcome, recompute the advisory
   325	 * D4_task_outcome aggregate, and re-write report.{json,md}.
   326	 *
   327	 * @param {Object} args - Parsed CLI args.
   328	 * @returns {Promise<number>} Process exit code (0 on success).
   329	 */
   330	async function augmentWithD4R(args) {
   331	  const { runD4RAblation } = require('./d4-ablation.cjs');
   332	  const skillRoot = resolveSkillRoot(args.skill);
   333	  const outputsDir = path.resolve(args['outputs-dir']);
   334	  const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');
   335	  const report = JSON.parse(fs.readFileSync(reportJsonPath, 'utf8'));
   336	  const { scenarios } = loadPlaybookScenarios({ skillRoot, playbookDir: args['playbook-dir'] });
   337	  const explicit = args['d4-scenarios'] || args.scenarios;
   338	  const wanted = explicit
   339	    ? String(explicit).split(',').map((s) => s.trim().toUpperCase()).filter(Boolean)
   340	    : [];
   341	  if (!wanted.length) {
   342	    report.advisorySignals = report.advisorySignals || {};
   343	    report.advisorySignals.D4_task_outcome = {
   344	      score: null,
   345	      status: 'not-run-no-target-scenarios',
   346	      note: 'D4-R needs explicit target-owned --d4-scenarios (or --scenarios); no cross-target defaults',
   347	    };
   348	    fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   349	    fs.writeFileSync(reportJsonPath.replace(/\.json$/, '.md'), renderReport(report));
   350	    process.stdout.write('  D4-R: not run — pass explicit --d4-scenarios (target-owned ids)\n');
   351	    return 0;
   352	  }
   353	  const byId = new Map((report.scenarioRows || []).map((r) => [(r.scenarioId || '').toUpperCase(), r]));
   354	  const graderMode = args['grader-mode'] || 'real';
   355	  const model = process.env.SKILL_BENCH_OPENCODE_MODEL;
   356	  const variant = process.env.SKILL_BENCH_OPENCODE_VARIANT;
   357	  let scored = 0;
   358	  for (const sc of scenarios) {
   359	    if (!wanted.includes((sc.scenarioId || '').toUpperCase())) continue;
   360	    process.stdout.write(`  D4-R ablation: ${sc.scenarioId} ...\n`);
   361	    const res = await runD4RAblation({ scenario: sc, skillRoot, model, variant, graderMode });
   362	    const row = byId.get((sc.scenarioId || '').toUpperCase());
   363	    if (row) { row.d4TaskOutcome = res.d4r; if (typeof res.d4r.score === 'number') scored += 1; }
   364	  }
   365	  const vals = (report.scenarioRows || [])
   366	    .map((r) => (r.d4TaskOutcome && typeof r.d4TaskOutcome.score === 'number' ? Math.round(r.d4TaskOutcome.score * 100) : null))
   367	    .filter((v) => typeof v === 'number');
   368	  const d4TaskAvg = vals.length ? Math.round(vals.reduce((a, b) => a + b, 0) / vals.length) : null;
   369	  report.advisorySignals = report.advisorySignals || {};
   370	  report.advisorySignals.D4_task_outcome = d4TaskAvg === null
   371	    ? { score: null, status: 'no D4-R rows scored', note: 'task-outcome usefulness delta; separate from D4 hallucination' }
   372	    : { score: d4TaskAvg, scoredCount: scored, attribution: 'approximate', note: 'task-outcome usefulness delta (skill-on vs off), separate from D4 hallucination' };
   373	  fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   374	  fs.writeFileSync(reportJsonPath.replace(/\.json$/, '.md'), renderReport(report));
   375	  process.stdout.write(`  D4-R: ${scored} scenario(s) scored; advisory D4_task_outcome=${d4TaskAvg == null ? 'null' : d4TaskAvg}\n`);
   376	  return 0;
   377	}
   378	
   379	// ─────────────────────────────────────────────────────────────────────────────
   380	// 5. EXPORTS

