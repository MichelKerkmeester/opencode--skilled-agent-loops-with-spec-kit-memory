    fix(mcp-server): correct misleading causal relation-coverage backfill hint (026/019)
    
    memory_causal_stats advertised an 'autonomous-causal-relation-backfill' and told callers to run memory_health({autoRepair}) to backfill relation coverage, but no such backfill is wired: relation-coverage.ts is a pure reporter, the autoRepair handler only rebuilds FTS + cleans orphans, and lastBackfillAt is always null. Mark backfillJob.implemented=false, set command=null, and rewrite the remediationHint to name the real mechanism ('supports' edges via post-insert enrichment on save (default-on); typed relations via explicit memory_causal_link). backfillJob.name retained for consumer/test stability. New relation-coverage-unit.vitest.ts + honest-contract assertions in causal-stats-output.vitest.ts; build clean. A full autonomous relation-inference backfill (semantic caused/contradicts) is recorded as a future feature. 019 Level-1 packet validates 0/0.
    
    Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

diff --git a/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts b/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts
index 25eba88d3b..440f507c77 100644
--- a/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts
+++ b/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts
@@ -24,7 +24,11 @@ interface RelationCoverageState {
   backfillJob: {
     name: string;
     scope: string;
-    command: string;
+    // Honest signal: the autonomous relation-backfill is NOT wired. No command balances relations —
+    // 'supports' edges grow via post-insert enrichment on save (default-on); typed relations require
+    // explicit memory_causal_link. `implemented` stays false and `command` null until a real job exists.
+    implemented: boolean;
+    command: string | null;
     lastBackfillAt: string | null;
   };
   targets: RelationCoverageTarget[];
@@ -102,7 +106,8 @@ function buildRelationCoverageState(
     backfillJob: {
       name: 'autonomous-causal-relation-backfill',
       scope: 'memory causal graph relation balancing across caused/supports/contradicts/supersedes/produced/cited_by',
-      command: BACKFILL_COMMAND,
+      implemented: false,
+      command: null,
       lastBackfillAt: readLastBackfillAt(db),
     },
     targets,
@@ -110,7 +115,7 @@ function buildRelationCoverageState(
     status,
     remediationHint: status === 'met'
       ? null
-      : `Run ${BACKFILL_COMMAND} to backfill relation coverage; prioritize ${failing.map((entry) => entry.relation).join(', ') || 'unlinked records'}.`,
+      : `Relation balancing is not auto-backfilled: 'supports' edges come from post-insert enrichment on save (default-on); typed relations (caused/contradicts/supersedes/produced/cited_by) require explicit memory_causal_link. Below target: ${failing.map((entry) => entry.relation).join(', ') || 'unlinked records'}.`,
   };
 }
