('/db', injectFs(() => {\n\n  Line 149:       launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n\n  Line 155:       launcher.readMaintenanceMarker(\n\n  Line 164:       launcher.readMaintenanceMarker(\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts:\n  Line 362:       join(paths.dbDir, '.maintenance-active.json'),\n\n  Line 392:     expect(settled.stdout).toMatch(/maintenance-active/);\n\n  Line 426:       join(paths.dbDir, '.maintenance-active.json'),\n","metadata":{"matches":22,"truncated":false},"title":"maintenance-active|maintenanceMarker|shouldAdoptDespiteProbe|readMaintenanceMarker|maintenanceMarkerPath|maintenanceMarkerDir","time":{"start":1781719851781,"end":1781719851827}},"id":"prt_ed6c762fd001veFX6NbNOSTfGz","sessionID":"ses_12939ea57ffe2mRoz7BF8L6z5a","messageID":"msg_ed6c6a084001zI3vY49In3TTRz"}}
