     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ build-report.cjs — render report.md from report.json (anti-drift)        ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * build-report.cjs — render report.md FROM report.json (anti-drift).
     9	 *
    10	 * The converged design requires a dual artifact: a machine report.json and a
    11	 * human report.md, with the markdown rendered from the JSON so they cannot drift.
    12	 * There is no pre-existing Lane B renderer to reuse (Lane B emits JSON only), so
    13	 * this renderer is Lane-C-specific. It is the ONLY writer of report.md — it
    14	 * accepts no score arguments, only the report object.
    15	 */
    16	
    17	// ─────────────────────────────────────────────────────────────────────────────
    18	// 1. IMPORTS/REQUIRES
    19	// ─────────────────────────────────────────────────────────────────────────────
    20	
    21	const fs = require('fs');
