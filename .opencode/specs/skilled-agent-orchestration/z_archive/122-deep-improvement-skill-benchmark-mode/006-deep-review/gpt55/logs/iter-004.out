     1	#!/usr/bin/env node
     2	'use strict';
     3	
     4	/**
     5	 * advisor-probe.cjs — D1-inter signal: does the skill-advisor route a domain
     6	 * prompt to the target skill?
     7	 *
     8	 * Captured OUT-OF-BAND (the advisor never sees that it is being benchmarked):
     9	 * we run the in-repo Python advisor CLI (`skill_advisor.py`) over the PUBLIC
    10	 * prompt and read its ranked recommendations. This is DETERMINISTIC — the Python
    11	 * scorer reads the compiled SQLite skill graph, not an LLM — so it belongs in the
    12	 * Mode A deterministic core, not live mode. (The TS `scoreAdvisorPrompt` is the
    13	 * other entry point; the Python CLI is chosen here because it is process-isolated
    14	 * and needs no cross-language bridge from CJS.)
    15	 *
    16	 * Probing is opt-in (the orchestrator calls it only when --advisor-mode=python)
    17	 * so the pure-router Mode A default stays dependency-free and fast.
    18	 */
    19	
    20	const path = require('path');
    21	const { spawnSync } = require('child_process');
    22	
    23	const SKILLS_DIR = path.resolve(__dirname, '..', '..', '..'); // .opencode/skills
    24	const DEFAULT_ADVISOR_PY = path.join(
    25	  SKILLS_DIR, 'system-skill-advisor', 'mcp_server', 'scripts', 'skill_advisor.py',
    26	);
    27	
    28	/**
    29	 * Run the advisor over a prompt and return its ranked recommendations.
    30	 * @returns {{ ok: boolean, recommendations: Array<{skill:string,confidence:number}>,
    31	 *   topSkill: string|null, error?: string }}
    32	 */
    33	function probeAdvisor({ prompt, advisorPy, timeoutMs }) {
    34	  const py = advisorPy || DEFAULT_ADVISOR_PY;
    35	  const res = spawnSync('python3', [py, String(prompt || '')], {
    36	    encoding: 'utf8',
    37	    timeout: timeoutMs || 60000,
    38	    maxBuffer: 8 * 1024 * 1024,
    39	  });
    40	  if (res.status !== 0 || !res.stdout) {
    41	    return { ok: false, recommendations: [], topSkill: null, error: (res.stderr || `exit ${res.status}`).slice(0, 200) };
    42	  }
    43	  let parsed;
    44	  try {
    45	    parsed = JSON.parse(res.stdout);
    46	  } catch (err) {
    47	    return { ok: false, recommendations: [], topSkill: null, error: `unparseable advisor output: ${err.message}` };
    48	  }
    49	  const recs = (Array.isArray(parsed) ? parsed : []).map((r) => ({
    50	    skill: r.skill, confidence: typeof r.confidence === 'number' ? r.confidence : null,
    51	  }));
    52	  return { ok: true, recommendations: recs, topSkill: recs.length ? recs[0].skill : null };
    53	}
    54	
    55	/**
    56	 * Score the D1-inter dimension for one scenario from an advisor probe result.
    57	 * Rank-weighted: top-1 = 1.0, top-3 = 0.75, top-5 = 0.5, else 0. Negative
    58	 * scenarios invert: the target must NOT appear in the recommendations.
    59	 * @returns {{ score: number|null, rank: number|null, topSkill: string|null, ok: boolean }}
    60	 */
    61	function scoreD1Inter({ advisorResult, expectedSkillId, negative }) {
    62	  if (!advisorResult || !advisorResult.ok) return { score: null, rank: null, topSkill: null, ok: false };
    63	  const recs = advisorResult.recommendations;
    64	  const rankIdx = expectedSkillId ? recs.findIndex((r) => r.skill === expectedSkillId) : -1;
    65	  const rank = rankIdx === -1 ? null : rankIdx + 1;
    66	  if (negative) {
    67	    // should NOT activate: success = target absent from (or low in) the list.
    68	    return { score: rank === null || rank > 5 ? 1 : 0, rank, topSkill: advisorResult.topSkill, ok: true };
    69	  }
    70	  let score = 0;
    71	  if (rank === 1) score = 1;
    72	  else if (rank !== null && rank <= 3) score = 0.75;
    73	  else if (rank !== null && rank <= 5) score = 0.5;
    74	  return { score, rank, topSkill: advisorResult.topSkill, ok: true };
    75	}
    76	
    77	module.exports = { probeAdvisor, scoreD1Inter, DEFAULT_ADVISOR_PY };
    78	
    79	if (require.main === module) {
    80	  const args = require('./_args.cjs').parse(process.argv.slice(2));
    81	  if (!args.prompt) {
    82	    process.stderr.write('usage: advisor-probe.cjs --prompt "<text>" [--advisor-py <path>]\n');
    83	    process.exit(2);
    84	  }
    85	  const out = probeAdvisor({ prompt: args.prompt, advisorPy: args['advisor-py'] });
    86	  process.stdout.write(JSON.stringify(out, null, 2) + '\n');
    87	  process.exit(out.ok ? 0 : 1);
    88	}

