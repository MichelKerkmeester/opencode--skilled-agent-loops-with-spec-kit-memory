            \"evidenceGapDetected\": false,\n            \"trmEnabled\": true,\n            \"applyStateLimits\": false,\n            \"minState\": \"\"\n          }\n        },\n        {\n          \"stage\": \"final-rank\",\n          \"timestamp\": 1784650214342,\n          \"inputCount\": 8,\n          \"outputCount\": 8,\n          \"durationMs\": 0,\n          \"metadata\": {\n            \"confidenceTruncation\": {\n              \"truncated\": false,\n              \"originalCount\": 8,\n              \"truncatedCount\": 8,\n              \"medianGap\": 0,\n              \"cutoffGap\": 0,\n              \"cutoffIndex\": 7,\n              \"thresholdMultiplier\": 2,\n              \"minResultsGuaranteed\": 10,\n              \"featureFlagEnabled\": true\n            }\n          }\n        }\n      ],\n      \"totalDurationMs\": 386,\n      \"finalResultCount\": 8\n    },\n    \"vectorDegradation\": {\n      \"degraded\": false,\n      \"vectorSearchAvailable\": true,\n      \"mode\": \"hybrid\",\n      \"reason\": null,\n      \"degradedVector\": {\n        \"state\": \"healthy\",\n        \"degraded\": false,\n        \"sentinelPersisted\": true,\n        \"detections\": 0,\n        \"quarantines\": 0,\n        \"rebuildsStarted\": 0,\n        \"rebuildsCompleted\": 0,\n        \"rebuildsFailed\": 0,\n        \"lastEventAt\": null,\n        \"lastReason\": null,\n        \"lastShard\": null,\n        \"lastQuarantine\": null,\n        \"activeJobId\": null\n      }\n    },\n    \"searchDecisionEnvelope\": {\n      \"envelopeVersion\": 1,\n      \"requestId\": \"8173591c-cbce-4570-b020-a36dbb9237af\",\n      \"queryPlan\": {\n        \"intent\": \"find_spec\",\n        \"complexity\": \"complex\",\n        \"artifactClass\": \"checklist\",\n        \"authorityNeed\": \"high\",\n        \"selectedChannels\": [\n          \"vector\",\n          \"fts\",\n          \"bm25\",\n          \"graph\",\n          \"degree\"\n        ],\n        \"skippedChannels\": [],\n        \"routingReasons\": [\n          \"complexity:complex\",\n          \"confidence:high\",\n          \"terms:18\",\n          \"artifact:checklist\",\n          \"channels:vector+fts+bm25+graph+degree\"\n        ],\n        \"fallbackPolicy\": {\n          \"mode\": \"none\",\n          \"reason\": \"No fallback applied\"\n        }\n      },\n      \"timestamp\": \"2026-07-21T16:10:13.720Z\",\n      \"latencyMs\": 628,\n      \"trustTree\": {\n        \"decision\": \"degraded\",\n        \"hasContradiction\": false,\n        \"signals\": [\n          {\n            \"source\": \"memory.responsePolicy\",\n            \"state\": \"live\",\n            \"summary\": \"Response policy decision: memory_context_response\",\n            \"citations\": [],\n            \"raw\": {\n              \"state\": \"live\",\n              \"decision\": \"memory_context_response\"\n            }\n          },\n          {\n            \"source\": \"code_graph.readiness\",\n            \"state\": \"absent\",\n            \"summary\": \"Code graph readiness: missing\",\n            \"citations\": [],\n            \"raw\": {\n              \"trustState\": \"absent\",\n              \"canonicalReadiness\": \"missing\"\n            }\n          },\n          {\n            \"source\": \"advisor.trustState\",\n            \"state\": \"absent\",\n            \"summary\": \"No advisor trust-state signal supplied\",\n            \"citations\": []\n          },\n          {\n            \"source\": \"causal\",\n            \"state\": \"absent\",\n            \"summary\": \"No causal relation signal supplied\",\n            \"citations\": []\n          }\n        ],\n        \"causal\": {\n          \"supports\": [],\n          \"supersedes\": [],\n          \"contradicts\": []\n        },\n        \"citations\": [],\n        \"reasons\": [\n          \"decision:degraded\",\n          \"live-signals:1\",\n          \"degraded-signals:0\",\n          \"absent-or-unknown-signals:3\"\n        ]\n      }\n    },\n    \"appliedBoosts\": {\n      \"session\": {\n        \"applied\": \"off\"\n      },\n      \"causal\": {\n        \"applied\": \"enabled\"\n      }\n    },\n    \"recovery\": {\n      \"status\": \"no_results\",\n      \"reason\": \"spec_filter_too_narrow\",\n      \"suggestedQueries\": [\n        \"Review target .opencode/specs/sk-design/017-remediation-program-review:\",\n        \"Review target .opencode/specs/sk-design/017-remediation-program-review: prior decisions, claimed remediation status, key implementation and verification context for a detached deep-review lineage.\"\n      ],\n      \"recommendedAction\": \"retry_broader\"\n    },\n    \"citationPolicy\": \"do_not_cite_results\",\n    \"responsePolicy\": {\n      \"requiredAction\": \"broaden_or_ask\",\n      \"noCanonicalPathClaims\": true,\n      \"citationRequiredForPaths\": true,\n      \"safeResponse\": \"Retrieval quality is weak. Broaden the query or ask the user for disambiguation before citing any path.\"\n    },\n    \"progressiveDisclosure\": {\n      \"summaryLayer\": {\n        \"count\": 0,\n        \"digest\": \"0 results\"\n      },\n      \"results\": [],\n      \"continuation\": null\n    },\n    \"results\": [],\n    \"evidenceDigest\": \"No results found.\",\n    \"followUps\": [\n      \"Try broadening the query or removing specFolder filter\"\n    ],\n    \"delegatedSearch\": {\n      \"summary\": \"No matching memories found\",\n      \"hints\": [\n        \"Try broadening your search query\",\n        \"Use memory_list() to browse available memories\",\n        \"Check if specFolder filter is too restrictive\"\n      ],\n      \"meta\": {\n        \"tool\": \"memory_search\",\n        \"tokenCount\": 3937,\n        \"latencyMs\": 400,\n        \"cacheHit\": false,\n        \"responseProfile\": \"research\"\n      }\n    },\n    \"queryIntentRouting\": {\n      \"queryIntent\": \"semantic\",\n      \"routedBackend\": \"semantic\",\n      \"confidence