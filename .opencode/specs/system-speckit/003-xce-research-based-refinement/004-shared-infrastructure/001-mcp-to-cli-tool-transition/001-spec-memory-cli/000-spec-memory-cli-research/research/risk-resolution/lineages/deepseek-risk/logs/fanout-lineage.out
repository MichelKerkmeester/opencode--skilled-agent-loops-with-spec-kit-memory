> {\n          if (activeSocket !== socket) return;\n          socketDrainWaiting = false;\n          resumeClientInputIfReady();\n          pumpSocketQueue();\n        });\n        return;\n      }\n    }\n    resumeClientInputIfReady();\n  }","lineStart":280,"lineEnd":529,"totalLines":813,"truncated":true}},"title":".opencode/bin/lib/launcher-session-proxy.cjs","time":{"start":1780742073212,"end":1780742073217}},"id":"prt_e9c7fa86d001nGaGc5OsJ3FJXC","sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","messageID":"msg_e9c7f9a9d001n4vk9qJ2mgMrGL"}}
