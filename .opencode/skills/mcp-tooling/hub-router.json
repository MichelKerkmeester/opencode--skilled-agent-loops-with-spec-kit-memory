{
  "skill": "mcp-tooling",
  "version": "1.1.0.0",
  "routerPolicy": {
    "defaultMode": null,
    "ambiguityDelta": 1,
    "tieBreak": [
      "mcp-chrome-devtools",
      "mcp-click-up",
      "mcp-aside-devtools",
      "mcp-figma",
      "mcp-refero",
      "mcp-mobbin"
    ],
    "outcomes": {
      "single": "one dominant tool signal routes to one mode",
      "orderedBundle": "multiple explicitly requested tools route in tie-break order",
      "defer": "unclear or contradictory tool intent asks for disambiguation"
    },
    "defaultResource": [
      "shared/references/smart-routing.md",
      "mode-registry.json"
    ],
    "defaultResourceSemantics": "fallback-only",
    "defaultResourceContract": "A scored route assembles exactly the selected mode's declared resources. defaultResource is consulted ONLY when no mode scores (zero-signal branch), and then only as the defer-time suggestion offered alongside disambiguation - it is never unioned into a scored route's resource set.",
    "discoveryClasses": [
      "hub-identity",
      "provider-neutral-design-research"
    ],
    "discoveryClassesContract": "Classes listed here are hub discovery/defer evidence only. They are intentionally referenced by NO mode's scoring classes: a prompt matching only discovery vocabulary scores zero modes and takes the defer outcome instead of fanning out to every mode."
  },
  "routerSignals": {
    "mcp-chrome-devtools": {
      "weight": 4,
      "classes": [
        "chrome-devtools-aliases",
        "browser-debug"
      ],
      "resources": [
        "mcp-chrome-devtools/SKILL.md"
      ]
    },
    "mcp-click-up": {
      "weight": 4,
      "classes": [
        "clickup-aliases",
        "task-management"
      ],
      "resources": [
        "mcp-click-up/SKILL.md"
      ]
    },
    "mcp-aside-devtools": {
      "weight": 4,
      "classes": [
        "aside-devtools-aliases",
        "agentic-browser"
      ],
      "resources": [
        "mcp-aside-devtools/SKILL.md"
      ]
    },
    "mcp-figma": {
      "weight": 4,
      "classes": [
        "figma-aliases",
        "design-transport"
      ],
      "resources": [
        "mcp-figma/SKILL.md"
      ]
    },
    "mcp-refero": {
      "weight": 4,
      "classes": [
        "refero-aliases",
        "design-reference-research"
      ],
      "resources": [
        "mcp-refero/SKILL.md"
      ]
    },
    "mcp-mobbin": {
      "weight": 4,
      "classes": [
        "mobbin-aliases",
        "app-design-research"
      ],
      "resources": [
        "mcp-mobbin/SKILL.md"
      ]
    }
  },
  "vocabularyClasses": {
    "hub-identity": {
      "note": "Discovery-only (see routerPolicy.discoveryClasses): hub-level vocabulary that identifies THIS hub, not any one mode. Deliberately unreferenced by routerSignals so hub-identity-only prompts defer.",
      "keywords": [
        "mcp-tooling",
        "mcp tool bridge",
        "mode-registry",
        "hub-router"
      ]
    },
    "provider-neutral-design-research": {
      "note": "Discovery-only (see routerPolicy.discoveryClasses): generic design-research phrasing naming neither provider. Reserved for defer between mcp-refero and mcp-mobbin per MT-008/MT-009 scenario contracts; never provider-scoring vocabulary.",
      "keywords": [
        "screen examples"
      ]
    },
    "chrome-devtools-aliases": {
      "keywords": [
