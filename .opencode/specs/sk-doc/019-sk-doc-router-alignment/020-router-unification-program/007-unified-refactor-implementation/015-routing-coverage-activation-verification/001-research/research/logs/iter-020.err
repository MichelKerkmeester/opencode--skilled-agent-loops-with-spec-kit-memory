   128	async function withStdoutSilenced(fn) {
   129	  const forwarded = (...args) => {
   130	    const rendered = args
   131	      .map((value) => (typeof value === 'string' ? value : JSON.stringify(value)))
   132	      .join(' ');
   133	    process.stderr.write(`${rendered}\n`);
   134	  };
   135	
   136	  const original = {
   137	    log: console.log,
   138	    info: console.info,
   139	    debug: console.debug,
   140	    warn: console.warn,
   141	  };
   142	
   143	  console.log = forwarded;
   144	  console.info = forwarded;
   145	  console.debug = forwarded;
   146	  console.warn = forwarded;
   147	
   148	  try {
   149	    return await fn();
   150	  } finally {
   151	    console.log = original.log;
   152	    console.info = original.info;
   153	    console.debug = original.debug;
   154	    console.warn = original.warn;
   155	  }
   156	}
