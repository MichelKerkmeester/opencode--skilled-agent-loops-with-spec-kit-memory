{"type":"tool_use","timestamp":1782931028681,"sessionID":"ses_0e10e5929ffe88XcmihhZxWbsA","part":{"type":"tool","tool":"read","callID":"call_68de9d10f3294bda93fae6ca","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n5: // ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n6: // ║          declared mode disagrees with mode-registry.json's entry for    ║\n7: // ║          the resolved target agent, and flags/blocks repeated/loop-like ║\n8: // ║          orchestrate-to-command-owned-loop-executor dispatches within a ║\n9: // ║          session while allowing exactly one legitimate bounded hand-off.║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: 'use strict';\n12: \n13: // ─────────────────────────────────────────────────────────────────────────────\n14: // 1. IMPORTS\n15: // ─────────────────────────────────────────────────────────────────────────────\n16: \n17: import { mkdirSync, readFileSync, renameSync, unlinkSync, writeFileSync } from 'node:fs';\n18: import { join } from 'node:path';\n19: \n20: // ─────────────────────────────────────────────────────────────────────────────\n21: // 2. CONSTANTS\n22: // ─────────────────────────────────────────────────────────────────────────────\n23: \n24: const REGISTRY_RELATIVE_PATH = '.opencode/skills/deep-loop-workflows/mode-registry.json';\n25: const LOOP_GUARD_STATE_DIR_RELATIVE_PATH = '.opencode/skills/.loop-guard-state';\n26: const REJECT_MODE_ENV = 'MK_DEEP_LOOP_GUARD_REJECT';\n27: const REJECT_LOOP_ENV = 'MK_DEEP_LOOP_GUARD_REJECT_LOOP';\n28: \n29: // Command-owned loop executors: dispatched only by their parent /deep:* command,\n30: // which owns iteration state and convergence. orchestrate may perform exactly one\n31: // bounded hand-off to these -- repeated hand-offs re-implement the loop outside\n32: // its owning command. Generic subagents (context/review/write/debug) and\n33: // ai-council (also reachable via /deep:ai-council for multi-turn planning) are\n34: // intentionally excluded from loop-repeat counting.\n35: const LOOP_EXECUTOR_AGENTS = new Set(['deep-research', 'deep-review', 'deep-improvement', 'prompt-improver']);\n36: \n37: // A dispatch carrying one of these markers originates from the parent command's\n38: // own iteration loop (e.g. the rendered prompt pack for iteration N), not from\n39: // orchestrate re-implementing the loop -- so it must not count toward the\n40: // loop-repeat threshold.\n41: const ITERATION_MARKER_REGEX = /(?:^|\\n)\\s*Iteration:\\s*\\d+\\s*of\\s*\\d+|STATE SUMMARY/i;\n42: \n43: const WARN_AT_COUNT = 2;\n44: const BLOCK_AT_COUNT = 3;\n45: \n46: // ─────────────────────────────────────────────────────────────────────────────\n47: // 3. HELPERS -- registry + mode mismatch\n48: // ─────────────────────────────────────────────────────────────────────────────\n49: \n50: function loadRegistryAgents(registryPath) {\n51:   try {\n52:     const raw = readFileSync(registryPath, 'utf8');\n53:     const data = JSON.parse(raw);\n54:     const map = new Map();\n55:     for (const mode of data.modes || []) {\n56:       if (mode.agent) map.set(mode.agent, mode);\n57:     }\n58:     return map;\n59:   } catch (_) {\n60:     return null;\n61:   }\n62: }\n63: \n64: function declaredModeFromPrompt(promptText) {\n65:   const match = /mode=([a-z0-9-]+)/i.exec(promptText || '');\n66:   return match ? match[1] : null;\n67: }\n68: \n69: function mismatchDetail(subagentType, registryMode, declaredMode) {\n70:   return [\n71:     'mk-deep-loop-guard: Deep Route mode mismatch --',\n72:     `dispatch targets subagent_type=\"${subagentType}\"`,\n73:     `(registry mode=\"${registryMode}\")`,\n74:     `but the prompt declares mode=\"${declaredMode}\"`,\n75:   ].join(' ');\n76: }\n77: \n78: // ─────────────────────────────────────────────────────────────────────────────\n79: // 4. HELPERS -- target identity resolution\n80: // ─────────────────────────────────────────────────────────────────────────────\n81: \n82: /**\n83:  * Resolve the real dispatch target's agent identity.\n84:  *\n85:  * orchestrate's own dispatch convention sets subagent_type=\"general\" for every\n86:  * Task call regardless of target (the specialized agent's definition file is\n87:  * pasted into the prompt body instead), so subagent_type alone cannot identify\n88:  * the target. Parse the prompt's \"Agent: @<name>\" / \"Deep Route: ... target_agent=@<name>\"\n89:  * fields first; fall back to subagent_type only when it is not the generic\n90:  * \"general\" placeholder (covers callers that do set it directly, e.g. this\n91:  * repo's own fan-out lineage prompts).\n92:  *\n93:  * @param {string} subagentType - raw args.subagent_type / args.subagentType value\n94:  * @param {string} promptText - raw args.prompt value\n95:  * @returns {string|null} resolved agent identity, or null if unresolvable\n96:  */\n97: function resolveTargetIdentity(subagentType, promptText) {\n98:   const text = promptText || '';\n99:   const deepRouteMatch = /target_agent=@?([a-z0-9-]+)/i.exec(text);\n100:   if (deepRouteMatch) return deepRouteMatch[1];\n101: \n102:   const agentLineMatch = /(?:^|\\n)\\s*Agent:\\s*@?([a-z0-9-]+)/i.exec(text);\n103:   if (agentLineMatch) return agentLineMatch[1];\n104: \n105:   if (subagentType && subagentType !== 'general') return subagentType;\n106:   return null;\n107: }\n108: \n109: // ─────────────────────────────────────────────────────────────────────────────\n110: // 5. HELPERS -- session-scoped loop-repeat state (atomic file persistence)\n111: // ─────────────────────────────────────────────────────────────────────────────\n112: \n113: function sessionStateKey(sessionID) {\n114:   return Buffer.from(String(sessionID), 'utf8').toString('hex');\n115: }\n116: \n117: function loopStatePath(stateDir, sessionID) {\n118:   return join(stateDir, `${sessionStateKey(sessionID)}.json`);\n119: }\n120: \n121: function readLoopState(stateDir, sessionID) {\n122:   try {\n123:     const raw = readFileSync(loopStatePath(stateDir, sessionID), 'utf8');\n124:     const parsed = JSON.parse(raw);\n125:     return parsed && typeof parsed === 'object' ? parsed : {};\n126:   } catch (_) {\n127:     return {};\n128:   }\n129: }\n130: \n131: function writeLoopStateAtomic(stateDir, sessionID, state) {\n132:   try {\n133:     mkdirSync(stateDir, { recursive: true });\n134:   } catch (_) {\n135:     return; // Fail open: cannot create state dir, skip persistence this call.\n136:   }\n137:   const finalPath = loopStatePath(stateDir, sessionID);\n138:   const tempPath = `${finalPath}.${process.pid}.${Date.now()}.tmp`;\n139:   try {\n140:     writeFileSync(tempPath, `${JSON.stringify(state, null, 2)}\\n`, 'utf8');\n141:     renameSync(tempPath, finalPath);\n142:   } catch (_) {\n143:     try { unlinkSync(tempPath); } catch (_ignored) { /* best-effort cleanup */ }\n144:     // Fail open: a persistence error must never block the dispatch it guards.\n145:   }\n146: }\n147: \n148: /**\n149:  * Record one dispatch to a loop-executor target and return the updated\n150:  * non-command-driven count for that target in this session.\n151:  *\n152:  * @param {string} stateDir - loop-guard state directory\n153:  * @param {string} sessionID - current session id\n154:  * @param {string} targetAgent - resolved loop-executor identity\n155:  * @param {boolean} commandDriven - true when the dispatch carries iteration-state markers\n156:  * @returns {number} updated non-command-driven dispatch count for targetAgent\n157:  */\n158: function recordLoopDispatch(stateDir, sessionID, targetAgent, commandDriven) {\n159:   const state = readLoopState(stateDir, sessionID);\n160:   const dispatches = state.dispatches && typeof state.dispatches === 'object' ? state.dispatches : {};\n161:   const entry = dispatches[targetAgent] && typeof dispatches[targetAgent] === 'object'\n162:     ? dispatches[targetAgent]\n163:     : { count: 0 };\n164: \n165:   if (!commandDriven) entry.count = (entry.count || 0) + 1;\n166:   entry.lastCommandDriven = commandDriven;\n167:   entry.lastTimestamp = new Date().toISOString();\n168:   dispatches[targetAgent] = entry;\n169: \n170:   writeLoopStateAtomic(stateDir, sessionID, {\n171:     sessionId: sessionID,\n172:     dispatches,\n173:   });\n174: \n175:   return entry.count;\n176: }\n177: \n178: function loopRepeatDetail(targetAgent, count) {\n179:   return [\n180:     'mk-deep-loop-guard: loop-like repeated dispatch --',\n181:     `orchestrate has dispatched \"${targetAgent}\" ${count} times`,\n182:     'in this session without a command-driven iteration marker;',\n183:     'command-owned loop executors should be dispatched by their parent /deep:* command,',\n184:     'not repeatedly hand off from orchestrate.',\n185:   ].join(' ');\n186: }\n187: \n188: // ─────────────────────────────────────────────────────────────────────────────\n189: // 6. PLUGIN FACTORY\n190: // ─────────────────────────────────────────────────────────────────────────────\n191: \n192: /**\n193:  * Create the mk-deep-loop-guard OpenCode plugin hooks.\n194:  *\n195:  * Hard limits (by design, not oversight):\n196:  * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n197:  * - Does not catch a schema-valid, route-matched artifact that internally\n198:  *   does semantically wrong-mode work.\n199:  * - Loop-repeat detection is session-scoped and per-target-agent; it cannot\n200:  *   detect a cross-executor meta-loop (e.g. deep-research, deep-review,\n201:  *   deep-research again) -- only repeated hand-offs to the SAME executor.\n202:  * - Fails open on its own errors (missing/unreadable registry or state,\n203:  *   unexpected arg shapes) so a bug here never blocks unrelated, correctly-\n204:  *   routed work.\n205:  *\n206:  * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n207:  * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n208:  */\n209: export default async function MkDeepLoopGuardPlugin(ctx) {\n210:   const projectDir = ctx?.directory || process.cwd();\n211:   const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n212:   const loopStateDir = join(projectDir, LOOP_GUARD_STATE_DIR_RELATIVE_PATH);\n213: \n214:   return {\n215:     async 'tool.execute.before'(input, output) {\n216:       try {\n217:         if (!input || input.tool !== 'task') return;\n218:         const args = output && output.args;\n219:         if (!args || typeof args !== 'object') return;\n220: \n221:         const rawSubagentType = args.subagent_type || args.subagentType;\n222:         const targetAgent = resolveTargetIdentity(rawSubagentType, args.prompt);\n223:         if (!targetAgent) return;\n224: \n225:         // -- Check 1: Deep Route mode mismatch (existing behavior, identity-fixed) --\n226:         const registry = loadRegistryAgents(registryPath);\n227:         if (registry) {\n228:           const entry = registry.get(targetAgent);\n229:           if (entry) {\n230:             const declaredMode = declaredModeFromPrompt(args.prompt);\n231:             if (declaredMode && declaredMode !== entry.workflowMode) {\n232:               const detail = mismatchDetail(targetAgent, entry.workflowMode, declaredMode);\n233:               if (process.env[REJECT_MODE_ENV] === '1') throw new Error(detail);\n234:               console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n235:             }\n236:           }\n237:         }\n238: \n239:         // -- Check 2: loop-like repeated hand-off to a command-owned loop executor --\n240:         if (LOOP_EXECUTOR_AGENTS.has(targetAgent) && input.sessionID) {\n241:           const commandDriven = ITERATION_MARKER_REGEX.test(args.prompt || '');\n242:           const count = recordLoopDispatch(loopStateDir, input.sessionID, targetAgent, commandDriven);\n243: \n244:           if (!commandDriven && count >= WARN_AT_COUNT) {\n245:             const detail = loopRepeatDetail(targetAgent, count);\n246:             if (count >= BLOCK_AT_COUNT && process.env[REJECT_LOOP_ENV] === '1') {\n247:               throw new Error(detail);\n248:             }\n249:             console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n250:           }\n251:         }\n252:       } catch (err) {\n253:         if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n254:         // Fail open on any unexpected internal error -- never block unrelated dispatches.\n255:       }\n256:     },\n257:   };\n258: }\n\n(End of file - total 258 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n// ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n// ║          declared mode disagrees with mode-registry.json's entry for    ║\n// ║          the resolved target agent, and flags/blocks repeated/loop-like ║\n// ║          orchestrate-to-command-owned-loop-executor dispatches within a ║\n// ║          session while allowing exactly one legitimate bounded hand-off.║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nimport { mkdirSync, readFileSync, renameSync, unlinkSync, writeFileSync } from 'node:fs';\nimport { join } from 'node:path';\n\n// ─────────────────────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n// ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n// ║          declared mode disagrees with mode-registry.json's entry for    ║\n// ║          the resolved target agent, and flags/blocks repeated/loop-like ║\n// ║          orchestrate-to-command-owned-loop-executor dispatches within a ║\n// ║          session while allowing exactly one legitimate bounded hand-off.║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nimport { mkdirSync, readFileSync, renameSync, unlinkSync, writeFileSync } from 'node:fs';\nimport { join } from 'node:path';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst REGISTRY_RELATIVE_PATH = '.opencode/skills/deep-loop-workflows/mode-registry.json';\nconst LOOP_GUARD_STATE_DIR_RELATIVE_PATH = '.opencode/skills/.loop-guard-state';\nconst REJECT_MODE_ENV = 'MK_DEEP_LOOP_GUARD_REJECT';\nconst REJECT_LOOP_ENV = 'MK_DEEP_LOOP_GUARD_REJECT_LOOP';\n\n// Command-owned loop executors: dispatched only by their parent /deep:* command,\n// which owns iteration state and convergence. orchestrate may perform exactly one\n// bounded hand-off to these -- repeated hand-offs re-implement the loop outside\n// its owning command. Generic subagents (context/review/write/debug) and\n// ai-council (also reachable via /deep:ai-council for multi-turn planning) are\n// intentionally excluded from loop-repeat counting.\nconst LOOP_EXECUTOR_AGENTS = new Set(['deep-research', 'deep-review', 'deep-improvement', 'prompt-improver']);\n\n// A dispatch carrying one of these markers originates from the parent command's\n// own iteration loop (e.g. the rendered prompt pack for iteration N), not from\n// orchestrate re-implementing the loop -- so it must not count toward the\n// loop-repeat threshold.\nconst ITERATION_MARKER_REGEX = /(?:^|\\n)\\s*Iteration:\\s*\\d+\\s*of\\s*\\d+|STATE SUMMARY/i;\n\nconst WARN_AT_COUNT = 2;\nconst BLOCK_AT_COUNT = 3;\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS -- registry + mode mismatch\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction loadRegistryAgents(registryPath) {\n  try {\n    const raw = readFileSync(registryPath, 'utf8');\n    const data = JSON.parse(raw);\n    const map = new Map();\n    for (const mode of data.modes || []) {\n      if (mode.agent) map.set(mode.agent, mode);\n    }\n    return map;\n  } catch (_) {\n    return null;\n  }\n}\n\nfunction declaredModeFromPrompt(promptText) {\n  const match = /mode=([a-z0-9-]+)/i.exec(promptText || '');\n  return match ? match[1] : null;\n}\n\nfunction mismatchDetail(subagentType, registryMode, declaredMode) {\n  return [\n    'mk-deep-loop-guard: Deep Route mode mismatch --',\n    `dispatch targets subagent_type=\"${subagentType}\"`,\n    `(registry mode=\"${registryMode}\")`,\n    `but the prompt declares mode=\"${declaredMode}\"`,\n  ].join(' ');\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. HELPERS -- target identity resolution\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Resolve the real dispatch target's agent identity.\n *\n * orchestrate's own dispatch convention sets subagent_type=\"general\" for every\n * Task call regardless of target (the specialized agent's definition file is\n * pasted into the prompt body instead), so subagent_type alone cannot identify\n * the target. Parse the prompt's \"Agent: @<name>\" / \"Deep Route: ... target_agent=@<name>\"\n * fields first; fall back to subagent_type only when it is not the generic\n * \"general\" placeholder (covers callers that do set it directly, e.g. this\n * repo's own fan-out lineage prompts).\n *\n * @param {string} subagentType - raw args.subagent_type / args.subagentType value\n * @param {string} promptText - raw args.prompt value\n * @returns {string|null} resolved agent identity, or null if unresolvable\n */\nfunction resolveTargetIdentity(subagentType, promptText) {\n  const text = promptText || '';\n  const deepRouteMatch = /target_agent=@?([a-z0-9-]+)/i.exec(text);\n  if (deepRouteMatch) return deepRouteMatch[1];\n\n  const agentLineMatch = /(?:^|\\n)\\s*Agent:\\s*@?([a-z0-9-]+)/i.exec(text);\n  if (agentLineMatch) return agentLineMatch[1];\n\n  if (subagentType && subagentType !== 'general') return subagentType;\n  return null;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. HELPERS -- session-scoped loop-repeat state (atomic file persistence)\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction sessionStateKey(sessionID) {\n  return Buffer.from(String(sessionID), 'utf8').toString('hex');\n}\n\nfunction loopStatePath(stateDir, sessionID) {\n  return join(stateDir, `${sessionStateKey(sessionID)}.json`);\n}\n\nfunction readLoopState(stateDir, sessionID) {\n  try {\n    const raw = readFileSync(loopStatePath(stateDir, sessionID), 'utf8');\n    const parsed = JSON.parse(raw);\n    return parsed && typeof parsed === 'object' ? parsed : {};\n  } catch (_) {\n    return {};\n  }\n}\n\nfunction writeLoopStateAtomic(stateDir, sessionID, state) {\n  try {\n    mkdirSync(stateDir, { recursive: true });\n  } catch (_) {\n    return; // Fail open: cannot create state dir, skip persistence this call.\n  }\n  const finalPath = loopStatePath(stateDir, sessionID);\n  const tempPath = `${finalPath}.${process.pid}.${Date.now()}.tmp`;\n  try {\n    writeFileSync(tempPath, `${JSON.stringify(state, null, 2)}\\n`, 'utf8');\n    renameSync(tempPath, finalPath);\n  } catch (_) {\n    try { unlinkSync(tempPath); } catch (_ignored) { /* best-effort cleanup */ }\n    // Fail open: a persistence error must never block the dispatch it guards.\n  }\n}\n\n/**\n * Record one dispatch to a loop-executor target and return the updated\n * non-command-driven count for that target in this session.\n *\n * @param {string} stateDir - loop-guard state directory\n * @param {string} sessionID - current session id\n * @param {string} targetAgent - resolved loop-executor identity\n * @param {boolean} commandDriven - true when the dispatch carries iteration-state markers\n * @returns {number} updated non-command-driven dispatch count for targetAgent\n */\nfunction recordLoopDispatch(stateDir, sessionID, targetAgent, commandDriven) {\n  const state = readLoopState(stateDir, sessionID);\n  const dispatches = state.dispatches && typeof state.dispatches === 'object' ? state.dispatches : {};\n  const entry = dispatches[targetAgent] && typeof dispatches[targetAgent] === 'object'\n    ? dispatches[targetAgent]\n    : { count: 0 };\n\n  if (!commandDriven) entry.count = (entry.count || 0) + 1;\n  entry.lastCommandDriven = commandDriven;\n  entry.lastTimestamp = new Date().toISOString();\n  dispatches[targetAgent] = entry;\n\n  writeLoopStateAtomic(stateDir, sessionID, {\n    sessionId: sessionID,\n    dispatches,\n  });\n\n  return entry.count;\n}\n\nfunction loopRepeatDetail(targetAgent, count) {\n  return [\n    'mk-deep-loop-guard: loop-like repeated dispatch --',\n    `orchestrate has dispatched \"${targetAgent}\" ${count} times`,\n    'in this session without a command-driven iteration marker;',\n    'command-owned loop executors should be dispatched by their parent /deep:* command,',\n    'not repeatedly hand off from orchestrate.',\n  ].join(' ');\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. PLUGIN FACTORY\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Create the mk-deep-loop-guard OpenCode plugin hooks.\n *\n * Hard limits (by design, not oversight):\n * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n * - Does not catch a schema-valid, route-matched artifact that internally\n *   does semantically wrong-mode work.\n * - Loop-repeat detection is session-scoped and per-target-agent; it cannot\n *   detect a cross-executor meta-loop (e.g. deep-research, deep-review,\n *   deep-research again) -- only repeated hand-offs to the SAME executor.\n * - Fails open on its own errors (missing/unreadable registry or state,\n *   unexpected arg shapes) so a bug here never blocks unrelated, correctly-\n *   routed work.\n *\n * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n */\nexport default async function MkDeepLoopGuardPlugin(ctx) {\n  const projectDir = ctx?.directory || process.cwd();\n  const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n  const loopStateDir = join(projectDir, LOOP_GUARD_STATE_DIR_RELATIVE_PATH);\n\n  return {\n    async 'tool.execute.before'(input, output) {\n      try {\n        if (!input || input.tool !== 'task') return;\n        const args = output && output.args;\n        if (!args || typeof args !== 'object') return;\n\n        const rawSubagentType = args.subagent_type || args.subagentType;\n        const targetAgent = resolveTargetIdentity(rawSubagentType, args.prompt);\n        if (!targetAgent) return;\n\n        // -- Check 1: Deep Route mode mismatch (existing behavior, identity-fixed) --\n        const registry = loadRegistryAgents(registryPath);\n        if (registry) {\n          const entry = registry.get(targetAgent);\n          if (entry) {\n            const declaredMode = declaredModeFromPrompt(args.prompt);\n            if (declaredMode && declaredMode !== entry.workflowMode) {\n              const detail = mismatchDetail(targetAgent, entry.workflowMode, declaredMode);\n              if (process.env[REJECT_MODE_ENV] === '1') throw new Error(detail);\n              console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n            }\n          }\n        }\n\n        // -- Check 2: loop-like repeated hand-off to a command-owned loop executor --\n        if (LOOP_EXECUTOR_AGENTS.has(targetAgent) && input.sessionID) {\n          const commandDriven = ITERATION_MARKER_REGEX.test(args.prompt || '');\n          const count = recordLoopDispatch(loopStateDir, input.sessionID, targetAgent, commandDriven);\n\n          if (!commandDriven && count >= WARN_AT_COUNT) {\n            const detail = loopRepeatDetail(targetAgent, count);\n            if (count >= BLOCK_AT_COUNT && process.env[REJECT_LOOP_ENV] === '1') {\n              throw new Error(detail);\n            }\n            console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n          }\n        }\n      } catch (err) {\n        if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n        // Fail open on any unexpected internal error -- never block unrelated dispatches.\n      }\n    },\n  };\n}","lineStart":1,"lineEnd":258,"totalLines":258,"truncated":false}},"title":".opencode/plugins/mk-deep-loop-guard.js","time":{"start":1782931028676,"end":1782931028680}},"id":"prt_f1ef87ac1001NPFPyOW5hoReFH","sessionID":"ses_0e10e5929ffe88XcmihhZxWbsA","messageID":"msg_f1ef85664001Jd6nBlJ4S2Fqwa"}}
