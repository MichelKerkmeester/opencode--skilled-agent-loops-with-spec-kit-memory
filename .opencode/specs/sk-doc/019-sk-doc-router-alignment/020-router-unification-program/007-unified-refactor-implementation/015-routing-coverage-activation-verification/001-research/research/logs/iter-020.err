    84	function fakeChild(options = {}) {
    85	  const child = new EventEmitter();
    86	  child.stdout = new EventEmitter();
    87	  child.stdout.setEncoding = () => undefined;
    88	  child.stdinPayload = null;
    89	  child.stdin = {
    90	    end(payload) {
    91	      child.stdinPayload = String(payload ?? '');
    92	      if (!options.manual) {
    93	        const emitResult = () => {
    94	          if (options.stdout !== undefined) {
    95	            child.stdout.emit('data', options.stdout);
    96	          }
    97	          if (options.close !== false) {
    98	            child.emit('close', options.code ?? 0);
    99	          }
   100	        };
   101	        if (options.delayMs) {
   102	          setTimeout(emitResult, options.delayMs);
   103	        } else {
   104	          queueMicrotask(emitResult);
   105	        }
   106	      }
   107	    },
   108	  };
   109	  child.kills = [];
   110	  child.kill = (signal) => {
   111	    child.kills.push(signal);
   112	    return true;
   113	  };
   114	  return child;
   115	}
