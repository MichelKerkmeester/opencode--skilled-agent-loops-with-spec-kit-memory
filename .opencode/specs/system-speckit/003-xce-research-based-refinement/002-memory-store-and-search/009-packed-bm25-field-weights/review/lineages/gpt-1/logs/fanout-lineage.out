{"type":"tool_use","timestamp":1781151899250,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_Jm4YlOSNmglYcijzz4odi9FO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25 Index\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: import { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\n6: import {\n7:   normalizeLexicalQueryTokens,\n8:   sanitizeFTS5Query,\n9:   sanitizeQueryTokens,\n10:   simpleStem,\n11:   STOP_WORDS,\n12:   tokenize,\n13: } from './lexical-normalizer.js';\n14: import type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\n15: import { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n16: \n17: // ───────────────────────────────────────────────────────────────\n18: // 1. INTERFACES\n19: \n20: // ───────────────────────────────────────────────────────────────\n21: interface BM25SearchResult {\n22:   id: string;\n23:   /**\n24:    * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n25:    * Higher = better lexical match. Not directly comparable to vector similarity\n26:    * scores; use min-max normalization or RRF when combining with other methods.\n27:    */\n28:   score: number;\n29: }\n30: \n31: interface BM25Stats {\n32:   documentCount: number;\n33:   termCount: number;\n34:   avgDocLength: number;\n35: }\n36: \n37: interface BM25DocumentSource {\n38:   title?: string | null;\n39:   content_text?: string | null;\n40:   trigger_phrases?: string | string[] | null;\n41:   file_path?: string | null;\n42: }\n43: \n44: /* ───────────────────────────────────────────────────────────────\n45:    1B. CONSTANTS & FEATURE FLAG\n46:    ──────────────────────────────────────────────────────────────── */\n47: \n48: const DEFAULT_K1 = 1.2;\n49: const DEFAULT_B = 0.75;\n50: const BM25_WARMUP_BATCH_SIZE = 250;\n51: const BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n52: const BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\n53: const BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\n54: type Bm25Engine = typeof BM25_ENGINE_VALUES[number];\n55: type InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\n56: type BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n57: \n58: const BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\n59: const BM25_ENGINE_LOGGED = new Set<string>();\n60: \n61: /**\n62:  * Field weight multipliers for weighted BM25 scoring.\n63:  * When indexing a document composed of multiple fields, multiply\n64:  * each field's token scores by the appropriate weight before\n65:  * accumulating the total document score.\n66:  *\n67:  * These weights are shared by the FTS5 path and the packed in-memory\n68:  * fallback so both lexical lanes preserve the same field-priority intent.\n69:  *\n70:  * title:           10.0 — exact title matches are the strongest signal\n71:  * trigger_phrases:  5.0 — curated keywords next most important\n72:  * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n73:  * body:             1.0 — baseline weight for full body / content_text\n74:  */\n75: const BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n76: \n77: const BM25_FIELD_WEIGHTS: Record<string, number> = {\n78:   title: BM25_FTS5_WEIGHTS[0],\n79:   trigger_phrases: BM25_FTS5_WEIGHTS[1],\n80:   content_generic: BM25_FTS5_WEIGHTS[2],\n81:   body: BM25_FTS5_WEIGHTS[3],\n82: };\n83: \n84: type BM25FieldWeights = Record<BM25FieldName, number>;\n85: \n86: interface BM25DocumentFields {\n87:   title?: string | null;\n88:   trigger_phrases?: string | string[] | null;\n89:   content_generic?: string | null;\n90:   body?: string | null;\n91: }\n92: \n93: interface BM25SearchOptions {\n94:   fieldWeights?: Partial<BM25FieldWeights>;\n95: }\n96: \n97: interface LegacyDocumentRecord {\n98:   tokens: string[];\n99:   termFreq: Map<string, number>;\n100: }\n101: \n102: interface PackedTermFrequency {\n103:   total: number;\n104:   fields: Record<BM25FieldName, number>;\n105: }\n106: \n107: interface PackedDocumentRecord {\n108:   numericId: number;\n109:   id: string;\n110:   length: number;\n111:   terms: string[];\n112: }\n113: \n114: interface PackedPostingMutable {\n115:   docIds: number[];\n116:   totalTfs: number[];\n117:   titleTfs: number[];\n118:   triggerTfs: number[];\n119:   pathTfs: number[];\n120:   bodyTfs: number[];\n121: }\n122: \n123: interface PackedPostingList {\n124:   docIds: Uint32Array;\n125:   totalTfs: Uint32Array;\n126:   titleTfs: Uint32Array;\n127:   triggerTfs: Uint32Array;\n128:   pathTfs: Uint32Array;\n129:   bodyTfs: Uint32Array;\n130: }\n131: \n132: /**\n133:  * Check whether the in-memory BM25 index is enabled.\n134:  *\n135:  * @returns `true` when BM25 indexing/search is enabled for the current process.\n136:  * @example\n137:  * ```ts\n138:  * if (isBm25Enabled()) {\n139:  *   getIndex();\n140:  * }\n141:  * ```\n142:  */\n143: function isBm25Enabled(): boolean {\n144:   const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n145:   if (!value) return true; // enabled by default\n146:   if (BM25_DISABLED_VALUES.has(value)) return false;\n147:   return BM25_ENABLED_VALUES.has(value);\n148: }\n149: \n150: // ───────────────────────────────────────────────────────────────\n151: // 2. HELPERS\n152: \n153: // ───────────────────────────────────────────────────────────────\n154: /**\n155:  * Count token frequency occurrences for BM25 scoring.\n156:  *\n157:  * @param tokens - Normalized tokens produced by {@link tokenize}.\n158:  * @returns A frequency map keyed by token text.\n159:  * @example\n160:  * ```ts\n161:  * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n162:  * // 2\n163:  * ```\n164:  */\n165: function getTermFrequencies(tokens: string[]): Map<string, number> {\n166:   const freq = new Map<string, number>();\n167:   for (const token of tokens) {\n168:     freq.set(token, (freq.get(token) || 0) + 1);\n169:   }\n170:   return freq;\n171: }\n172: \n173: function visitBm25Tokens(text: string, visitor: (token: string) => void): void {\n174:   if (!text || typeof text !== 'string') return;\n175: \n176:   let token = '';\n177:   const flush = () => {\n178:     if (token.length >= 2 && !STOP_WORDS.has(token)) {\n179:       visitor(simpleStem(token));\n180:     }\n181:     token = '';\n182:   };\n183: \n184:   for (let i = 0; i < text.length; i += 1) {\n185:     const code = text.charCodeAt(i);\n186:     if (code >= 65 && code <= 90) {\n187:       token += String.fromCharCode(code + 32);\n188:     } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n189:       token += text[i];\n190:     } else if (token.length > 0) {\n191:       flush();\n192:     }\n193:   }\n194: \n195:   if (token.length > 0) {\n196:     flush();\n197:   }\n198: }\n199: \n200: function normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n201:   if (Array.isArray(triggerPhrases)) {\n202:     return triggerPhrases\n203:       .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n204:       .join(' ');\n205:   }\n206: \n207:   if (typeof triggerPhrases !== 'string') {\n208:     return '';\n209:   }\n210: \n211:   const trimmed = triggerPhrases.trim();\n212:   if (!trimmed) {\n213:     return '';\n214:   }\n215: \n216:   try {\n217:     const parsed = JSON.parse(trimmed) as unknown;\n218:     if (Array.isArray(parsed)) {\n219:       return parsed\n220:         .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n221:         .join(' ');\n222:     }\n223:   } catch {\n224:     // Fall back to raw string when the database value is not JSON.\n225:   }\n226: \n227:   return trimmed;\n228: }\n229: \n230: function defaultPackedTermFrequency(): PackedTermFrequency {\n231:   return {\n232:     total: 0,\n233:     fields: {\n234:       title: 0,\n235:       trigger_phrases: 0,\n236:       content_generic: 0,\n237:       body: 0,\n238:     },\n239:   };\n240: }\n241: \n242: function resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n243:   return {\n244:     title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n245:     trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n246:     content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n247:     body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n248:   };\n249: }\n250: \n251: function emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n252:   const key = `${engine}:${reason}`;\n253:   if (BM25_ENGINE_LOGGED.has(key)) {\n254:     return;\n255:   }\n256:   BM25_ENGINE_LOGGED.add(key);\n257:   console.info(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n258: }\n259: \n260: function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n\n(Showing lines 1-260 of 1095. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface BM25SearchResult {\n  id: string;\n  /**\n   * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n   * Higher = better lexical match. Not directly comparable to vector similarity\n   * scores; use min-max normalization or RRF when combining with other methods.\n   */\n  score: number;\n}\n\ninterface BM25Stats {\n  documentCount: number;\n  termCount: number;\n  avgDocLength: number;\n}\n\ninterface BM25DocumentSource {\n  title?: string | null;\n  content_text?: string | null;\n  trigger_phrases?: string | string[] | null;\n  file_path?: string | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1B. CONSTANTS & FEATURE FLAG\n   ──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_K1 = 1.2;\nconst DEFAULT_B = 0.75;\nconst BM25_WARMUP_BATCH_SIZE = 250;\nconst BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\nconst BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\nconst BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\ntype Bm25Engine = typeof BM25_ENGINE_VALUES[number];\ntype InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\ntype BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n\nconst BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\nconst BM25_ENGINE_LOGGED = new Set<string>();\n\n/**\n * Field weight multipliers for weighted BM25 scoring.\n * When indexing a document composed of multiple fields, multiply\n * each field's token scores by the appropriate weight before\n * accumulating the total document score.\n *\n * These weights are shared by the FTS5 path and the packed in-memory\n * fallback so both lexical lanes preserve the same field-priority intent.\n *\n * title:           10.0 — exact title matches are the strongest signal\n * trigger_phrases:  5.0 — curated keywords next most important\n * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n * body:             1.0 — baseline weight for full body / content_text\n */\nconst BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n\nconst BM25_FIELD_WEIGHTS: Record<string, number> = {\n  title: BM25_FTS5_WEIGHTS[0],\n  trigger_phrases: BM25_FTS5_WEIGHTS[1],\n  content_generic: BM25_FTS5_WEIGHTS[2],\n  body: BM25_FTS5_WEIGHTS[3],\n};\n\ntype BM25FieldWeights = Record<BM25FieldName, number>;\n\ninterface BM25DocumentFields {\n  title?: string | null;\n  trigger_phrases?: string | string[] | null;\n  content_generic?: string | null;\n  body?: string | null;\n}\n\ninterface BM25SearchOptions {\n  fieldWeights?: Partial<BM25FieldWeights>;\n}\n\ninterface LegacyDocumentRecord {\n  tokens: string[];\n  termFreq: Map<string, number>;\n}\n\ninterface PackedTermFrequency {\n  total: number;\n  fields: Record<BM25FieldName, number>;\n}\n\ninterface PackedDocumentRecord {\n  numericId: number;\n  id: string;\n  length: number;\n  terms: string[];\n}\n\ninterface PackedPostingMutable {\n  docIds: number[];\n  totalTfs: number[];\n  titleTfs: number[];\n  triggerTfs: number[];\n  pathTfs: number[];\n  bodyTfs: number[];\n}\n\ninterface PackedPostingList {\n  docIds: Uint32Array;\n  totalTfs: Uint32Array;\n  titleTfs: Uint32Array;\n  triggerTfs: Uint32Array;\n  pathTfs: Uint32Array;\n  bodyTfs: Uint32Array;\n}\n\n/**\n * Check whether the in-memory BM25 index is enabled.\n *\n * @returns `true` when BM25 indexing/search is enabled for the current process.\n * @example\n * ```ts\n * if (isBm25Enabled()) {\n *   getIndex();\n * }\n * ```\n */\nfunction isBm25Enabled(): boolean {\n  const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n  if (!value) return true; // enabled by default\n  if (BM25_DISABLED_VALUES.has(value)) return false;\n  return BM25_ENABLED_VALUES.has(value);\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. HELPERS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Count token frequency occurrences for BM25 scoring.\n *\n * @param tokens - Normalized tokens produced by {@link tokenize}.\n * @returns A frequency map keyed by token text.\n * @example\n * ```ts\n * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n * // 2\n * ```\n */\nfunction getTermFrequencies(tokens: string[]): Map<string, number> {\n  const freq = new Map<string, number>();\n  for (const token of tokens) {\n    freq.set(token, (freq.get(token) || 0) + 1);\n  }\n  return freq;\n}\n\nfunction visitBm25Tokens(text: string, visitor: (token: string) => void): void {\n  if (!text || typeof text !== 'string') return;\n\n  let token = '';\n  const flush = () => {\n    if (token.length >= 2 && !STOP_WORDS.has(token)) {\n      visitor(simpleStem(token));\n    }\n    token = '';\n  };\n\n  for (let i = 0; i < text.length; i += 1) {\n    const code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      token += String.fromCharCode(code + 32);\n    } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n      token += text[i];\n    } else if (token.length > 0) {\n      flush();\n    }\n  }\n\n  if (token.length > 0) {\n    flush();\n  }\n}\n\nfunction normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n  if (Array.isArray(triggerPhrases)) {\n    return triggerPhrases\n      .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n      .join(' ');\n  }\n\n  if (typeof triggerPhrases !== 'string') {\n    return '';\n  }\n\n  const trimmed = triggerPhrases.trim();\n  if (!trimmed) {\n    return '';\n  }\n\n  try {\n    const parsed = JSON.parse(trimmed) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed\n        .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n        .join(' ');\n    }\n  } catch {\n    // Fall back to raw string when the database value is not JSON.\n  }\n\n  return trimmed;\n}\n\nfunction defaultPackedTermFrequency(): PackedTermFrequency {\n  return {\n    total: 0,\n    fields: {\n      title: 0,\n      trigger_phrases: 0,\n      content_generic: 0,\n      body: 0,\n    },\n  };\n}\n\nfunction resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n  return {\n    title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n    trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n    content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n    body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n  };\n}\n\nfunction emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n  const key = `${engine}:${reason}`;\n  if (BM25_ENGINE_LOGGED.has(key)) {\n    return;\n  }\n  BM25_ENGINE_LOGGED.add(key);\n  console.info(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n}\n\nfunction resolveInMemoryBm25Engine(): InMemoryBm25Engine {","lineStart":1,"lineEnd":260,"totalLines":1095,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781151899246,"end":1781151899249}},"metadata":{"openai":{"itemId":"fc_0f7bfbafc466ec3e016a2a389b2f80819191c6e6a941c776f6"}},"id":"prt_eb4ed1e48001sx8wdlguL5vd7I","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ecffd9001L60FxfP8wr6e40"}}
{"type":"tool_use","timestamp":1781151899268,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_HBPhOgWICzPwvTJ1spSc54xg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25-Only Baseline Runner\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // Runs the ground truth query set through the BM25/FTS5-only\n6: // Search path (disabling vector, graph, and trigger channels)\n7: // And computes baseline metrics. Records results in eval DB.\n8: //\n9: // The baseline measurement establishes the \"floor\" — what simple\n10: // Keyword search achieves without any semantic, graph, or trigger\n11: // Augmentation.\n12: //\n13: // Design notes:\n14: //   - The search function is injected as a dependency so tests\n15: // Can use mocks without a live DB.\n16: //   - The contingency decision matrix turns the measured MRR@5\n17: // Into an actionable gate: PAUSE / RATIONALIZE / PROCEED.\n18: //   - recordBaselineMetrics() is a pure DB write — no network I/O.\n19: import type Database from 'better-sqlite3';\n20: \n21: import {\n22:   computeMRR,\n23:   computeNDCG,\n24:   computeRecall,\n25:   computeHitRate,\n26:   type EvalResult,\n27:   type GroundTruthEntry,\n28: } from './eval-metrics.js';\n29: import {\n30:   GROUND_TRUTH_QUERIES,\n31:   GROUND_TRUTH_RELEVANCES,\n32:   type GroundTruthQuery,\n33: } from './ground-truth-data.js';\n34: \n35: /* ───────────────────────────────────────────────────────────────\n36:    1. PUBLIC TYPES\n37: ──────────────────────────────────────────────────────────────── */\n38: \n39: /** Configuration options for the BM25 baseline runner. */\n40: export interface BM25BaselineConfig {\n41:   /** Maximum number of queries to run. Defaults to all 110. */\n42:   queryLimit?: number;\n43:   /** Top-K cutoff for NDCG and Recall metrics. MRR always uses k=5 for contingency compatibility. */\n44:   k?: number;\n45:   /** Exclude hard-negative queries from the run. Default: false. */\n46:   skipHardNegatives?: boolean;\n47: }\n48: \n49: /** Metrics produced by a single BM25 baseline run. */\n50: export interface BM25BaselineMetrics {\n51:   mrr5: number;\n52:   /** NDCG at configured K (default 10). Named ndcg10 for backwards compatibility. */\n53:   ndcg10: number;\n54:   /** Recall at configured K (default 20). Named recall20 for backwards compatibility. */\n55:   recall20: number;\n56:   hitRate1: number;\n57: }\n58: \n59: /** Full result returned by runBM25Baseline(). */\n60: export interface BM25BaselineResult {\n61:   metrics: BM25BaselineMetrics;\n62:   queryCount: number;\n63:   timestamp: string;\n64:   contingencyDecision: ContingencyDecision;\n65:   /** Per-query MRR@5 values for bootstrap CI computation. */\n66:   perQueryMRR?: number[];\n67:   /** Bootstrap 95% CI for MRR@5 (computed if perQueryMRR available). */\n68:   bootstrapCI?: BootstrapCIResult;\n69: }\n70: \n71: /** Decision produced by evaluateContingency() or evaluateContingencyRelative(). */\n72: export interface ContingencyDecision {\n73:   /** The MRR@5 value used to derive the decision. */\n74:   bm25MRR: number;\n75:   /** Human-readable threshold band: '>=0.8' | '0.5-0.8' | '<0.5'. */\n76:   threshold: string;\n77:   /** Gate action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED'. */\n78:   action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED';\n79:   /** Plain-language interpretation for humans reading the exit gate report. */\n80:   interpretation: string;\n81:   /** Comparison mode: 'absolute' (the rollout) or 'relative' (the original rollout+). */\n82:   mode?: 'absolute' | 'relative';\n83:   /** Hybrid MRR@5 used as reference (relative mode only). */\n84:   hybridMRR?: number;\n85:   /** BM25/hybrid ratio (relative mode only). */\n86:   ratio?: number;\n87: }\n88: \n89: /**\n90:  * A single search result as returned by the injected BM25 search function.\n91:  * Mirrors the shape used in hybrid-search.ts so callers can reuse the same\n92:  * function reference.\n93:  */\n94: export interface BM25SearchResult {\n95:   /** Memory ID (numeric). */\n96:   id: number;\n97:   /** Retrieval score (raw BM25 / FTS5 rank). */\n98:   score: number;\n99:   /** Source channel identifier. Expected: 'bm25' or 'fts'. */\n100:   source: string;\n101: }\n102: \n103: /**\n104:  * A relevance judgment loaded from eval_ground_truth for a single query.\n105:  * Used to evaluate results returned by the injected search function.\n106:  */\n107: export interface QueryGroundTruth {\n108:   queryId: number;\n109:   memoryId: number;\n110:   relevance: number;\n111: }\n112: \n113: /** Query and graded relevance data for fixture-backed engine comparisons. */\n114: export interface BM25ComparisonQuery {\n115:   id: number;\n116:   query: string;\n117:   relevances: QueryGroundTruth[];\n118: }\n119: \n120: /** Search functions used to compare lexical engines on the same query set. */\n121: export interface BM25EngineComparisonSearches {\n122:   legacy: BM25SearchFn;\n123:   packed: BM25SearchFn;\n124:   fts5?: BM25SearchFn;\n125: }\n126: \n127: /** Metrics and pass/fail signals for a packed-vs-legacy BM25 comparison. */\n128: export interface BM25EngineComparisonResult {\n129:   legacy: BM25BaselineMetrics;\n130:   packed: BM25BaselineMetrics;\n131:   fts5?: BM25BaselineMetrics;\n132:   packedAtLeastLegacy: boolean;\n133:   titleSignalRestored: boolean;\n134: }\n135: \n136: /**\n137:  * Injected BM25-only search function signature.\n138:  *\n139:  * The function receives the query text and a limit and must return results\n140:  * using ONLY the BM25/FTS5 channel (vector, graph, trigger disabled).\n141:  * For production use, wire up the FTS5 path from hybrid-search with all\n142:  * other channels explicitly disabled.\n143:  */\n144: export type BM25SearchFn = (\n145:   query: string,\n146:   limit: number,\n147: ) => BM25SearchResult[] | Promise<BM25SearchResult[]>;\n148: \n149: /* ───────────────────────────────────────────────────────────────\n150:    2. CONTINGENCY DECISION MATRIX\n151: ──────────────────────────────────────────────────────────────── */\n152: \n153: /**\n154:  * Evaluate the BM25 MRR@5 value against the contingency decision matrix.\n155:  *\n156:  * Matrix:\n157:  *   MRR@5 >= 0.80 → PAUSE\n158:  *     BM25 alone is very strong — semantic/graph additions may not\n159:  *     justify the added complexity. Evaluate whether the multi-channel\n160:  *     architecture is warranted before proceeding.\n161:  *\n162:  *   MRR@5 0.50–0.79 → RATIONALIZE\n163:  *     BM25 is moderate — semantic/graph channels must demonstrably\n164:  *     improve over this baseline. Each additional channel needs\n165:  *     positive delta evidence.\n166:  *\n167:  *   MRR@5 < 0.50 → PROCEED\n168:  *     BM25 alone is weak — strong justification for multi-channel\n169:  *     retrieval. Proceed with hybrid search implementation.\n170:  *\n171:  * @param bm25MRR - The measured MRR@5 value (must be in [0, 1]).\n172:  * @returns ContingencyDecision with threshold label, action, and interpretation.\n173:  */\n174: export function evaluateContingency(bm25MRR: number): ContingencyDecision {\n175:   if (bm25MRR >= 0.80) {\n176:     return {\n177:       bm25MRR,\n178:       mode: 'absolute',\n179:       threshold: '>=0.8',\n180:       action: 'PAUSE',\n181:       interpretation:\n182:         'BM25 alone is very strong — semantic/graph additions may not justify complexity. ' +\n183:         'Re-evaluate whether a multi-channel architecture is warranted before proceeding with ' +\n184:         'additional retrieval channels. Consider whether the marginal gain from vector/graph ' +\n185:         'search is worth the operational overhead.',\n186:     };\n187:   }\n188: \n189:   if (bm25MRR >= 0.50) {\n190:     return {\n191:       bm25MRR,\n192:       mode: 'absolute',\n193:       threshold: '0.5-0.8',\n194:       action: 'RATIONALIZE',\n195:       interpretation:\n196:         'BM25 is moderate — semantic/graph channels should demonstrably improve over this baseline. ' +\n197:         'Each additional channel (vector, graph, trigger) must show a statistically meaningful ' +\n198:         'positive delta in MRR@5 before adoption. Track per-channel contribution carefully.',\n199:     };\n200:   }\n201: \n202:   return {\n203:     bm25MRR,\n204:     mode: 'absolute',\n205:     threshold: '<0.5',\n206:     action: 'PROCEED',\n207:     interpretation:\n208:       'BM25 alone is weak — strong justification for multi-channel retrieval. ' +\n209:       'The low keyword-only baseline confirms that semantic and graph augmentation ' +\n210:       'adds meaningful value. Proceed with hybrid search implementation.',\n211:   };\n212: }\n213: \n214: /**\n215:  * Compare lexical engines against a caller-provided fixture query set.\n216:  * The helper reuses the baseline metrics so relevance gates stay aligned\n217:  * with the production BM25-only evaluation report.\n218:  */\n219: export async function runBM25EngineComparison(\n220:   searches: BM25EngineComparisonSearches,\n221:   queries: BM25ComparisonQuery[],\n222:   config: Pick<BM25BaselineConfig, 'k'> = {},\n223: ): Promise<BM25EngineComparisonResult> {\n224:   const k = config.k ?? 20;\n225:   const legacy = await runComparisonMetrics(searches.legacy, queries, k);\n226:   const packed = await runComparisonMetrics(searches.packed, queries, k);\n227:   const fts5 = searches.fts5 ? await runComparisonMetrics(searches.fts5, queries, k) : undefined;\n228: \n229:   return {\n230:     legacy,\n231:     packed,\n232:     fts5,\n233:     packedAtLeastLegacy:\n234:       packed.mrr5 >= legacy.mrr5 &&\n235:       packed.ndcg10 >= legacy.ndcg10 &&\n236:       packed.recall20 >= legacy.recall20,\n237:     titleSignalRestored: packed.hitRate1 >= legacy.hitRate1,\n238:   };\n239: }\n240: \n241: async function runComparisonMetrics(\n242:   searchFn: BM25SearchFn,\n243:   queries: BM25ComparisonQuery[],\n244:   k: number,\n245: ): Promise<BM25BaselineMetrics> {\n246:   const fetchLimit = Math.max(20, k, 10);\n247:   let totalMRR = 0;\n248:   let totalNDCG = 0;\n249:   let totalRecall = 0;\n250:   let totalHitRate = 0;\n251: \n252:   for (const q of queries) {\n253:     const rawResults = await Promise.resolve(searchFn(q.query, fetchLimit));\n254:     const evalResults: EvalResult[] = rawResults.map((r, idx) => ({\n255:       memoryId: r.id,\n256:       score: r.score,\n257:       rank: idx + 1,\n258:     }));\n259: \n260:     const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({\n\n(Showing lines 1-260 of 693. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25-Only Baseline Runner\n// ───────────────────────────────────────────────────────────────\n//\n// Runs the ground truth query set through the BM25/FTS5-only\n// Search path (disabling vector, graph, and trigger channels)\n// And computes baseline metrics. Records results in eval DB.\n//\n// The baseline measurement establishes the \"floor\" — what simple\n// Keyword search achieves without any semantic, graph, or trigger\n// Augmentation.\n//\n// Design notes:\n//   - The search function is injected as a dependency so tests\n// Can use mocks without a live DB.\n//   - The contingency decision matrix turns the measured MRR@5\n// Into an actionable gate: PAUSE / RATIONALIZE / PROCEED.\n//   - recordBaselineMetrics() is a pure DB write — no network I/O.\nimport type Database from 'better-sqlite3';\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25-Only Baseline Runner\n// ───────────────────────────────────────────────────────────────\n//\n// Runs the ground truth query set through the BM25/FTS5-only\n// Search path (disabling vector, graph, and trigger channels)\n// And computes baseline metrics. Records results in eval DB.\n//\n// The baseline measurement establishes the \"floor\" — what simple\n// Keyword search achieves without any semantic, graph, or trigger\n// Augmentation.\n//\n// Design notes:\n//   - The search function is injected as a dependency so tests\n// Can use mocks without a live DB.\n//   - The contingency decision matrix turns the measured MRR@5\n// Into an actionable gate: PAUSE / RATIONALIZE / PROCEED.\n//   - recordBaselineMetrics() is a pure DB write — no network I/O.\nimport type Database from 'better-sqlite3';\n\nimport {\n  computeMRR,\n  computeNDCG,\n  computeRecall,\n  computeHitRate,\n  type EvalResult,\n  type GroundTruthEntry,\n} from './eval-metrics.js';\nimport {\n  GROUND_TRUTH_QUERIES,\n  GROUND_TRUTH_RELEVANCES,\n  type GroundTruthQuery,\n} from './ground-truth-data.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. PUBLIC TYPES\n──────────────────────────────────────────────────────────────── */\n\n/** Configuration options for the BM25 baseline runner. */\nexport interface BM25BaselineConfig {\n  /** Maximum number of queries to run. Defaults to all 110. */\n  queryLimit?: number;\n  /** Top-K cutoff for NDCG and Recall metrics. MRR always uses k=5 for contingency compatibility. */\n  k?: number;\n  /** Exclude hard-negative queries from the run. Default: false. */\n  skipHardNegatives?: boolean;\n}\n\n/** Metrics produced by a single BM25 baseline run. */\nexport interface BM25BaselineMetrics {\n  mrr5: number;\n  /** NDCG at configured K (default 10). Named ndcg10 for backwards compatibility. */\n  ndcg10: number;\n  /** Recall at configured K (default 20). Named recall20 for backwards compatibility. */\n  recall20: number;\n  hitRate1: number;\n}\n\n/** Full result returned by runBM25Baseline(). */\nexport interface BM25BaselineResult {\n  metrics: BM25BaselineMetrics;\n  queryCount: number;\n  timestamp: string;\n  contingencyDecision: ContingencyDecision;\n  /** Per-query MRR@5 values for bootstrap CI computation. */\n  perQueryMRR?: number[];\n  /** Bootstrap 95% CI for MRR@5 (computed if perQueryMRR available). */\n  bootstrapCI?: BootstrapCIResult;\n}\n\n/** Decision produced by evaluateContingency() or evaluateContingencyRelative(). */\nexport interface ContingencyDecision {\n  /** The MRR@5 value used to derive the decision. */\n  bm25MRR: number;\n  /** Human-readable threshold band: '>=0.8' | '0.5-0.8' | '<0.5'. */\n  threshold: string;\n  /** Gate action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED'. */\n  action: 'PAUSE' | 'RATIONALIZE' | 'PROCEED';\n  /** Plain-language interpretation for humans reading the exit gate report. */\n  interpretation: string;\n  /** Comparison mode: 'absolute' (the rollout) or 'relative' (the original rollout+). */\n  mode?: 'absolute' | 'relative';\n  /** Hybrid MRR@5 used as reference (relative mode only). */\n  hybridMRR?: number;\n  /** BM25/hybrid ratio (relative mode only). */\n  ratio?: number;\n}\n\n/**\n * A single search result as returned by the injected BM25 search function.\n * Mirrors the shape used in hybrid-search.ts so callers can reuse the same\n * function reference.\n */\nexport interface BM25SearchResult {\n  /** Memory ID (numeric). */\n  id: number;\n  /** Retrieval score (raw BM25 / FTS5 rank). */\n  score: number;\n  /** Source channel identifier. Expected: 'bm25' or 'fts'. */\n  source: string;\n}\n\n/**\n * A relevance judgment loaded from eval_ground_truth for a single query.\n * Used to evaluate results returned by the injected search function.\n */\nexport interface QueryGroundTruth {\n  queryId: number;\n  memoryId: number;\n  relevance: number;\n}\n\n/** Query and graded relevance data for fixture-backed engine comparisons. */\nexport interface BM25ComparisonQuery {\n  id: number;\n  query: string;\n  relevances: QueryGroundTruth[];\n}\n\n/** Search functions used to compare lexical engines on the same query set. */\nexport interface BM25EngineComparisonSearches {\n  legacy: BM25SearchFn;\n  packed: BM25SearchFn;\n  fts5?: BM25SearchFn;\n}\n\n/** Metrics and pass/fail signals for a packed-vs-legacy BM25 comparison. */\nexport interface BM25EngineComparisonResult {\n  legacy: BM25BaselineMetrics;\n  packed: BM25BaselineMetrics;\n  fts5?: BM25BaselineMetrics;\n  packedAtLeastLegacy: boolean;\n  titleSignalRestored: boolean;\n}\n\n/**\n * Injected BM25-only search function signature.\n *\n * The function receives the query text and a limit and must return results\n * using ONLY the BM25/FTS5 channel (vector, graph, trigger disabled).\n * For production use, wire up the FTS5 path from hybrid-search with all\n * other channels explicitly disabled.\n */\nexport type BM25SearchFn = (\n  query: string,\n  limit: number,\n) => BM25SearchResult[] | Promise<BM25SearchResult[]>;\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONTINGENCY DECISION MATRIX\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Evaluate the BM25 MRR@5 value against the contingency decision matrix.\n *\n * Matrix:\n *   MRR@5 >= 0.80 → PAUSE\n *     BM25 alone is very strong — semantic/graph additions may not\n *     justify the added complexity. Evaluate whether the multi-channel\n *     architecture is warranted before proceeding.\n *\n *   MRR@5 0.50–0.79 → RATIONALIZE\n *     BM25 is moderate — semantic/graph channels must demonstrably\n *     improve over this baseline. Each additional channel needs\n *     positive delta evidence.\n *\n *   MRR@5 < 0.50 → PROCEED\n *     BM25 alone is weak — strong justification for multi-channel\n *     retrieval. Proceed with hybrid search implementation.\n *\n * @param bm25MRR - The measured MRR@5 value (must be in [0, 1]).\n * @returns ContingencyDecision with threshold label, action, and interpretation.\n */\nexport function evaluateContingency(bm25MRR: number): ContingencyDecision {\n  if (bm25MRR >= 0.80) {\n    return {\n      bm25MRR,\n      mode: 'absolute',\n      threshold: '>=0.8',\n      action: 'PAUSE',\n      interpretation:\n        'BM25 alone is very strong — semantic/graph additions may not justify complexity. ' +\n        'Re-evaluate whether a multi-channel architecture is warranted before proceeding with ' +\n        'additional retrieval channels. Consider whether the marginal gain from vector/graph ' +\n        'search is worth the operational overhead.',\n    };\n  }\n\n  if (bm25MRR >= 0.50) {\n    return {\n      bm25MRR,\n      mode: 'absolute',\n      threshold: '0.5-0.8',\n      action: 'RATIONALIZE',\n      interpretation:\n        'BM25 is moderate — semantic/graph channels should demonstrably improve over this baseline. ' +\n        'Each additional channel (vector, graph, trigger) must show a statistically meaningful ' +\n        'positive delta in MRR@5 before adoption. Track per-channel contribution carefully.',\n    };\n  }\n\n  return {\n    bm25MRR,\n    mode: 'absolute',\n    threshold: '<0.5',\n    action: 'PROCEED',\n    interpretation:\n      'BM25 alone is weak — strong justification for multi-channel retrieval. ' +\n      'The low keyword-only baseline confirms that semantic and graph augmentation ' +\n      'adds meaningful value. Proceed with hybrid search implementation.',\n  };\n}\n\n/**\n * Compare lexical engines against a caller-provided fixture query set.\n * The helper reuses the baseline metrics so relevance gates stay aligned\n * with the production BM25-only evaluation report.\n */\nexport async function runBM25EngineComparison(\n  searches: BM25EngineComparisonSearches,\n  queries: BM25ComparisonQuery[],\n  config: Pick<BM25BaselineConfig, 'k'> = {},\n): Promise<BM25EngineComparisonResult> {\n  const k = config.k ?? 20;\n  const legacy = await runComparisonMetrics(searches.legacy, queries, k);\n  const packed = await runComparisonMetrics(searches.packed, queries, k);\n  const fts5 = searches.fts5 ? await runComparisonMetrics(searches.fts5, queries, k) : undefined;\n\n  return {\n    legacy,\n    packed,\n    fts5,\n    packedAtLeastLegacy:\n      packed.mrr5 >= legacy.mrr5 &&\n      packed.ndcg10 >= legacy.ndcg10 &&\n      packed.recall20 >= legacy.recall20,\n    titleSignalRestored: packed.hitRate1 >= legacy.hitRate1,\n  };\n}\n\nasync function runComparisonMetrics(\n  searchFn: BM25SearchFn,\n  queries: BM25ComparisonQuery[],\n  k: number,\n): Promise<BM25BaselineMetrics> {\n  const fetchLimit = Math.max(20, k, 10);\n  let totalMRR = 0;\n  let totalNDCG = 0;\n  let totalRecall = 0;\n  let totalHitRate = 0;\n\n  for (const q of queries) {\n    const rawResults = await Promise.resolve(searchFn(q.query, fetchLimit));\n    const evalResults: EvalResult[] = rawResults.map((r, idx) => ({\n      memoryId: r.id,\n      score: r.score,\n      rank: idx + 1,\n    }));\n\n    const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({","lineStart":1,"lineEnd":260,"totalLines":693,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","time":{"start":1781151899264,"end":1781151899267}},"metadata":{"openai":{"itemId":"fc_0f7bfbafc466ec3e016a2a389b2f9081919c918b5ce8e07f2b"}},"id":"prt_eb4ed1e78001jHFMw6hIXhmPPS","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ecffd9001L60FxfP8wr6e40"}}
{"type":"tool_use","timestamp":1781151899292,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_4ctFwrIs7YVKmr9ZOP7altGZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: BM25 Packed Engine Fixtures\n3: // ───────────────────────────────────────────────────────────────\n4: import type { BM25ComparisonQuery } from '../bm25-baseline.js';\n5: \n6: interface BM25PackedFixtureDocument {\n7:   id: number;\n8:   title: string;\n9:   content_text: string;\n10:   trigger_phrases: string[];\n11:   file_path: string;\n12: }\n13: \n14: interface CorpusFixtureOptions {\n15:   documentCount?: number;\n16:   targetIndexedBytes?: number;\n17: }\n18: \n19: const FIXTURE_FILLER = [\n20:   'the and of to in on at by from is it as was are be has had have been',\n21:   'this that these those not no do does did so if then than too very',\n22: ].join(' ');\n23: \n24: const GOLDEN_DOCUMENTS: BM25PackedFixtureDocument[] = [\n25:   {\n26:     id: 101,\n27:     title: 'Auth Guard Session Renewal',\n28:     content_text: 'Policy for renewing authenticated sessions and preserving access control context.',\n29:     trigger_phrases: ['auth guard', 'session renewal'],\n30:     file_path: 'specs/auth/session-renewal.md',\n31:   },\n32:   {\n33:     id: 102,\n34:     title: 'Cache Eviction Strategy',\n35:     content_text: 'Cache lifecycle and invalidation notes for retrieval pressure management.',\n36:     trigger_phrases: ['cache eviction', 'stale cache'],\n37:     file_path: 'specs/cache/eviction.md',\n38:   },\n39:   {\n40:     id: 103,\n41:     title: 'Trigger Phrase Backfill',\n42:     content_text: 'Backfill process for curated phrases and lexical discovery coverage.',\n43:     trigger_phrases: ['trigger phrase', 'phrase backfill'],\n44:     file_path: 'specs/search/trigger-backfill.md',\n45:   },\n46:   {\n47:     id: 104,\n48:     title: 'Vector Retention Policy',\n49:     content_text: 'Retention and retry behavior for vector embeddings and missing shard coverage.',\n50:     trigger_phrases: ['vector retention', 'embedding retry'],\n51:     file_path: 'specs/vector/retention.md',\n52:   },\n53:   {\n54:     id: 105,\n55:     title: 'Memory Search Ranking',\n56:     content_text: 'Ranking calibration for lexical search and semantic fusion channels.',\n57:     trigger_phrases: ['memory search', 'ranking calibration'],\n58:     file_path: 'specs/search/ranking.md',\n59:   },\n60:   {\n61:     id: 106,\n62:     title: 'Generic Operations Notes',\n63:     content_text: 'Auth guard appears repeatedly in a generic operational body auth guard auth guard auth guard.',\n64:     trigger_phrases: ['operations'],\n65:     file_path: 'specs/ops/generic.md',\n66:   },\n67: ];\n68: \n69: const GOLDEN_QUERIES: BM25ComparisonQuery[] = [\n70:   {\n71:     id: 1,\n72:     query: 'auth guard',\n73:     relevances: [{ queryId: 1, memoryId: 101, relevance: 3 }],\n74:   },\n75:   {\n76:     id: 2,\n77:     query: 'cache eviction',\n78:     relevances: [{ queryId: 2, memoryId: 102, relevance: 3 }],\n79:   },\n80:   {\n81:     id: 3,\n82:     query: 'trigger phrase backfill',\n83:     relevances: [{ queryId: 3, memoryId: 103, relevance: 3 }],\n84:   },\n85:   {\n86:     id: 4,\n87:     query: 'vector retention',\n88:     relevances: [{ queryId: 4, memoryId: 104, relevance: 3 }],\n89:   },\n90:   {\n91:     id: 5,\n92:     query: 'memory search ranking',\n93:     relevances: [{ queryId: 5, memoryId: 105, relevance: 3 }],\n94:   },\n95: ];\n96: \n97: function makeCorpusFiller(targetBytes: number): string {\n98:   const chunk = `${FIXTURE_FILLER} `;\n99:   return chunk.repeat(Math.max(1, Math.ceil(targetBytes / chunk.length))).slice(0, targetBytes);\n100: }\n101: \n102: function createCorpusSizedDocuments(options: CorpusFixtureOptions = {}): BM25PackedFixtureDocument[] {\n103:   const documentCount = options.documentCount ?? 10_245;\n104:   const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n105:   const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n106:   const sharedBody = makeCorpusFiller(bytesPerDocument);\n107:   const docs: BM25PackedFixtureDocument[] = [];\n108: \n109:   for (let i = 0; i < documentCount; i += 1) {\n110:     docs.push({\n111:       id: 10_000 + i,\n112:       title: `Corpus Fixture ${i}`,\n113:       content_text: sharedBody,\n114:       trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n115:       file_path: `fixtures/corpus/${i}.md`,\n116:     });\n117:   }\n118: \n119:   return docs;\n120: }\n121: \n122: function* iterateCorpusSizedDocuments(options: CorpusFixtureOptions = {}): Generator<BM25PackedFixtureDocument> {\n123:   const documentCount = options.documentCount ?? 10_245;\n124:   const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n125:   const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n126:   const sharedBody = makeCorpusFiller(bytesPerDocument);\n127: \n128:   for (let i = 0; i < documentCount; i += 1) {\n129:     yield {\n130:       id: 10_000 + i,\n131:       title: `Corpus Fixture ${i}`,\n132:       content_text: sharedBody,\n133:       trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n134:       file_path: `fixtures/corpus/${i}.md`,\n135:     };\n136:   }\n137: }\n138: \n139: function createPackedEvalDocuments(): BM25PackedFixtureDocument[] {\n140:   return GOLDEN_DOCUMENTS.map((doc) => ({ ...doc, trigger_phrases: [...doc.trigger_phrases] }));\n141: }\n142: \n143: function createPackedEvalQueries(): BM25ComparisonQuery[] {\n144:   return GOLDEN_QUERIES.map((query) => ({\n145:     ...query,\n146:     relevances: query.relevances.map((relevance) => ({ ...relevance })),\n147:   }));\n148: }\n149: \n150: export {\n151:   createCorpusSizedDocuments,\n152:   iterateCorpusSizedDocuments,\n153:   createPackedEvalDocuments,\n154:   createPackedEvalQueries,\n155: };\n156: \n157: export type {\n158:   BM25PackedFixtureDocument,\n159:   CorpusFixtureOptions,\n160: };\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: BM25 Packed Engine Fixtures\n// ───────────────────────────────────────────────────────────────\nimport type { BM25ComparisonQuery } from '../bm25-baseline.js';\n\ninterface BM25PackedFixtureDocument {\n  id: number;\n  title: string;\n  content_text: string;\n  trigger_phrases: string[];\n  file_path: string;\n}\n\ninterface CorpusFixtureOptions {\n  documentCount?: number;\n  targetIndexedBytes?: number;\n}\n\nconst FIXTURE_FILLER = [\n  'the and of to in on at by from is it as was are be has had have been',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: BM25 Packed Engine Fixtures\n// ───────────────────────────────────────────────────────────────\nimport type { BM25ComparisonQuery } from '../bm25-baseline.js';\n\ninterface BM25PackedFixtureDocument {\n  id: number;\n  title: string;\n  content_text: string;\n  trigger_phrases: string[];\n  file_path: string;\n}\n\ninterface CorpusFixtureOptions {\n  documentCount?: number;\n  targetIndexedBytes?: number;\n}\n\nconst FIXTURE_FILLER = [\n  'the and of to in on at by from is it as was are be has had have been',\n  'this that these those not no do does did so if then than too very',\n].join(' ');\n\nconst GOLDEN_DOCUMENTS: BM25PackedFixtureDocument[] = [\n  {\n    id: 101,\n    title: 'Auth Guard Session Renewal',\n    content_text: 'Policy for renewing authenticated sessions and preserving access control context.',\n    trigger_phrases: ['auth guard', 'session renewal'],\n    file_path: 'specs/auth/session-renewal.md',\n  },\n  {\n    id: 102,\n    title: 'Cache Eviction Strategy',\n    content_text: 'Cache lifecycle and invalidation notes for retrieval pressure management.',\n    trigger_phrases: ['cache eviction', 'stale cache'],\n    file_path: 'specs/cache/eviction.md',\n  },\n  {\n    id: 103,\n    title: 'Trigger Phrase Backfill',\n    content_text: 'Backfill process for curated phrases and lexical discovery coverage.',\n    trigger_phrases: ['trigger phrase', 'phrase backfill'],\n    file_path: 'specs/search/trigger-backfill.md',\n  },\n  {\n    id: 104,\n    title: 'Vector Retention Policy',\n    content_text: 'Retention and retry behavior for vector embeddings and missing shard coverage.',\n    trigger_phrases: ['vector retention', 'embedding retry'],\n    file_path: 'specs/vector/retention.md',\n  },\n  {\n    id: 105,\n    title: 'Memory Search Ranking',\n    content_text: 'Ranking calibration for lexical search and semantic fusion channels.',\n    trigger_phrases: ['memory search', 'ranking calibration'],\n    file_path: 'specs/search/ranking.md',\n  },\n  {\n    id: 106,\n    title: 'Generic Operations Notes',\n    content_text: 'Auth guard appears repeatedly in a generic operational body auth guard auth guard auth guard.',\n    trigger_phrases: ['operations'],\n    file_path: 'specs/ops/generic.md',\n  },\n];\n\nconst GOLDEN_QUERIES: BM25ComparisonQuery[] = [\n  {\n    id: 1,\n    query: 'auth guard',\n    relevances: [{ queryId: 1, memoryId: 101, relevance: 3 }],\n  },\n  {\n    id: 2,\n    query: 'cache eviction',\n    relevances: [{ queryId: 2, memoryId: 102, relevance: 3 }],\n  },\n  {\n    id: 3,\n    query: 'trigger phrase backfill',\n    relevances: [{ queryId: 3, memoryId: 103, relevance: 3 }],\n  },\n  {\n    id: 4,\n    query: 'vector retention',\n    relevances: [{ queryId: 4, memoryId: 104, relevance: 3 }],\n  },\n  {\n    id: 5,\n    query: 'memory search ranking',\n    relevances: [{ queryId: 5, memoryId: 105, relevance: 3 }],\n  },\n];\n\nfunction makeCorpusFiller(targetBytes: number): string {\n  const chunk = `${FIXTURE_FILLER} `;\n  return chunk.repeat(Math.max(1, Math.ceil(targetBytes / chunk.length))).slice(0, targetBytes);\n}\n\nfunction createCorpusSizedDocuments(options: CorpusFixtureOptions = {}): BM25PackedFixtureDocument[] {\n  const documentCount = options.documentCount ?? 10_245;\n  const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n  const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n  const sharedBody = makeCorpusFiller(bytesPerDocument);\n  const docs: BM25PackedFixtureDocument[] = [];\n\n  for (let i = 0; i < documentCount; i += 1) {\n    docs.push({\n      id: 10_000 + i,\n      title: `Corpus Fixture ${i}`,\n      content_text: sharedBody,\n      trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n      file_path: `fixtures/corpus/${i}.md`,\n    });\n  }\n\n  return docs;\n}\n\nfunction* iterateCorpusSizedDocuments(options: CorpusFixtureOptions = {}): Generator<BM25PackedFixtureDocument> {\n  const documentCount = options.documentCount ?? 10_245;\n  const targetIndexedBytes = options.targetIndexedBytes ?? 69_200_000;\n  const bytesPerDocument = Math.max(128, Math.floor(targetIndexedBytes / documentCount));\n  const sharedBody = makeCorpusFiller(bytesPerDocument);\n\n  for (let i = 0; i < documentCount; i += 1) {\n    yield {\n      id: 10_000 + i,\n      title: `Corpus Fixture ${i}`,\n      content_text: sharedBody,\n      trigger_phrases: [`fixture-${i % 97}`, 'packed bm25'],\n      file_path: `fixtures/corpus/${i}.md`,\n    };\n  }\n}\n\nfunction createPackedEvalDocuments(): BM25PackedFixtureDocument[] {\n  return GOLDEN_DOCUMENTS.map((doc) => ({ ...doc, trigger_phrases: [...doc.trigger_phrases] }));\n}\n\nfunction createPackedEvalQueries(): BM25ComparisonQuery[] {\n  return GOLDEN_QUERIES.map((query) => ({\n    ...query,\n    relevances: query.relevances.map((relevance) => ({ ...relevance })),\n  }));\n}\n\nexport {\n  createCorpusSizedDocuments,\n  iterateCorpusSizedDocuments,\n  createPackedEvalDocuments,\n  createPackedEvalQueries,\n};\n\nexport type {\n  BM25PackedFixtureDocument,\n  CorpusFixtureOptions,\n};","lineStart":1,"lineEnd":160,"totalLines":160,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/eval/fixtures/bm25-packed-fixture.ts","time":{"start":1781151899289,"end":1781151899291}},"metadata":{"openai":{"itemId":"fc_0f7bfbafc466ec3e016a2a389b2f988191a8aac0b2b83ea30f"}},"id":"prt_eb4ed1e82001FMgrOQ3jDrXBJU","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ecffd9001L60FxfP8wr6e40"}}
{"type":"tool_use","timestamp":1781151899305,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_AucqEv7VaBwUTiwxRhmSlwBv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: PACKED IN-MEMORY BM25\n3: // ───────────────────────────────────────────────────────────────\n4: import { performance } from 'node:perf_hooks';\n5: import Database from 'better-sqlite3';\n6: import { afterEach, describe, expect, it, vi } from 'vitest';\n7: \n8: import {\n9:   BM25Index,\n10:   BM25_FIELD_WEIGHTS,\n11:   buildBm25DocumentFields,\n12:   shouldWarmInMemoryBm25,\n13:   type BM25DocumentFields,\n14:   type BM25SearchResult,\n15: } from '../lib/search/bm25-index';\n16: import { fts5Bm25Search, isFts5Available } from '../lib/search/sqlite-fts';\n17: import { runBM25EngineComparison, type BM25SearchResult as BaselineResult } from '../lib/eval/bm25-baseline';\n18: import {\n19:   createPackedEvalDocuments,\n20:   createPackedEvalQueries,\n21:   iterateCorpusSizedDocuments,\n22:   type BM25PackedFixtureDocument,\n23: } from '../lib/eval/fixtures/bm25-packed-fixture';\n24: \n25: const ORIGINAL_BM25_ENGINE = process.env.SPECKIT_BM25_ENGINE;\n26: const ORIGINAL_ENABLE_BM25 = process.env.ENABLE_BM25;\n27: const RSS_BUDGET_BYTES = 150 * 1024 * 1024;\n28: const WARMUP_BUDGET_MS = 10_000;\n29: \n30: function toFields(doc: BM25PackedFixtureDocument): BM25DocumentFields {\n31:   return buildBm25DocumentFields({\n32:     title: doc.title,\n33:     content_text: doc.content_text,\n34:     trigger_phrases: doc.trigger_phrases,\n35:     file_path: doc.file_path,\n36:   });\n37: }\n38: \n39: function addFixtureDocuments(index: BM25Index, docs: BM25PackedFixtureDocument[]): void {\n40:   for (const doc of docs) {\n41:     index.addDocumentFields(String(doc.id), toFields(doc));\n42:   }\n43:   index.finalizePackedPostings();\n44: }\n45: \n46: function toBaselineResults(results: BM25SearchResult[], source: string): BaselineResult[] {\n47:   return results.map((result) => ({\n48:     id: Number(result.id),\n49:     score: result.score,\n50:     source,\n51:   }));\n52: }\n53: \n54: function createFtsDatabase(docs: BM25PackedFixtureDocument[]): Database.Database {\n55:   const db = new Database(':memory:');\n56:   db.exec(`\n57:     CREATE TABLE memory_index (\n58:       id INTEGER PRIMARY KEY,\n59:       title TEXT,\n60:       content_text TEXT,\n61:       trigger_phrases TEXT,\n62:       file_path TEXT,\n63:       importance_tier TEXT\n64:     );\n65:     CREATE VIRTUAL TABLE memory_fts USING fts5(\n66:       title,\n67:       trigger_phrases,\n68:       file_path,\n69:       content_text,\n70:       content='memory_index',\n71:       content_rowid='id'\n72:     );\n73:   `);\n74: \n75:   const insertMemory = db.prepare(`\n76:     INSERT INTO memory_index (id, title, content_text, trigger_phrases, file_path, importance_tier)\n77:     VALUES (?, ?, ?, ?, ?, 'normal')\n78:   `);\n79:   const insertFts = db.prepare(`\n80:     INSERT INTO memory_fts (rowid, title, trigger_phrases, file_path, content_text)\n81:     VALUES (?, ?, ?, ?, ?)\n82:   `);\n83: \n84:   const insertAll = db.transaction(() => {\n85:     for (const doc of docs) {\n86:       const triggers = doc.trigger_phrases.join(' ');\n87:       insertMemory.run(doc.id, doc.title, doc.content_text, triggers, doc.file_path);\n88:       insertFts.run(doc.id, doc.title, triggers, doc.file_path, doc.content_text);\n89:     }\n90:   });\n91:   insertAll();\n92:   return db;\n93: }\n94: \n95: afterEach(() => {\n96:   if (ORIGINAL_BM25_ENGINE === undefined) {\n97:     delete process.env.SPECKIT_BM25_ENGINE;\n98:   } else {\n99:     process.env.SPECKIT_BM25_ENGINE = ORIGINAL_BM25_ENGINE;\n100:   }\n101: \n102:   if (ORIGINAL_ENABLE_BM25 === undefined) {\n103:     delete process.env.ENABLE_BM25;\n104:   } else {\n105:     process.env.ENABLE_BM25 = ORIGINAL_ENABLE_BM25;\n106:   }\n107:   vi.restoreAllMocks();\n108: });\n109: \n110: describe('packed in-memory BM25 engine', () => {\n111:   it('warms the corpus fixture within RSS and latency budgets', () => {\n112:     process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n113:     const index = new BM25Index(undefined, undefined, 'packed-inmemory');\n114:     const beforeRss = process.memoryUsage().rss;\n115:     const start = performance.now();\n116: \n117:     for (const doc of iterateCorpusSizedDocuments()) {\n118:       index.addDocumentFields(String(doc.id), toFields(doc));\n119:     }\n120:     index.finalizePackedPostings();\n121: \n122:     const warmupMs = performance.now() - start;\n123:     const rssSpike = Math.max(0, process.memoryUsage().rss - beforeRss);\n124: \n125:     expect(index.getStats().documentCount).toBe(10_245);\n126:     expect(index.getStats().termCount).toBeGreaterThan(100);\n127:     expect(rssSpike).toBeLessThanOrEqual(RSS_BUDGET_BYTES);\n128:     expect(warmupMs).toBeLessThanOrEqual(WARMUP_BUDGET_MS);\n129:   });\n130: \n131:   it('restores field weighting and keeps weights query-time tunable', () => {\n132:     const docs = createPackedEvalDocuments();\n133:     const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n134:     const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n135: \n136:     addFixtureDocuments(packed, docs);\n137:     for (const doc of docs) {\n138:       legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n139:     }\n140: \n141:     const legacyTop = legacy.search('auth guard', 1)[0]?.id;\n142:     const packedTop = packed.search('auth guard', 1)[0]?.id;\n143:     const flatPackedTop = packed.search('auth guard', 1, {\n144:       fieldWeights: { title: 1, trigger_phrases: 1, content_generic: 1, body: 1 },\n145:     })[0]?.id;\n146: \n147:     expect(BM25_FIELD_WEIGHTS.title).toBeGreaterThan(BM25_FIELD_WEIGHTS.trigger_phrases);\n148:     expect(BM25_FIELD_WEIGHTS.trigger_phrases).toBeGreaterThan(BM25_FIELD_WEIGHTS.content_generic);\n149:     expect(BM25_FIELD_WEIGHTS.content_generic).toBeGreaterThan(BM25_FIELD_WEIGHTS.body);\n150:     expect(legacyTop).not.toBe('101');\n151:     expect(packedTop).toBe('101');\n152:     expect(flatPackedTop).not.toBe('101');\n153:   });\n154: \n155:   it('keeps legacy, packed, and auto selection explicit and logged', () => {\n156:     const infoSpy = vi.spyOn(console, 'info').mockImplementation(() => {});\n157: \n158:     process.env.ENABLE_BM25 = 'true';\n159:     process.env.SPECKIT_BM25_ENGINE = 'legacy-inmemory';\n160:     const legacy = new BM25Index();\n161:     expect((legacy as unknown as { engine: string }).engine).toBe('legacy-inmemory');\n162:     expect(shouldWarmInMemoryBm25(null)).toBe(true);\n163: \n164:     process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n165:     const packed = new BM25Index();\n166:     expect((packed as unknown as { engine: string }).engine).toBe('packed-inmemory');\n167:     expect(shouldWarmInMemoryBm25(null)).toBe(true);\n168: \n169:     delete process.env.SPECKIT_BM25_ENGINE;\n170:     const auto = new BM25Index();\n171:     expect((auto as unknown as { engine: string }).engine).toBe('packed-inmemory');\n172: \n173:     expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('legacy-inmemory'))).toBe(true);\n174:     expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('packed-inmemory'))).toBe(true);\n175:     expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('auto mode fallback'))).toBe(true);\n176:   });\n177: \n178:   it('passes packed-vs-legacy baseline comparison and matches FTS5 title intent', async () => {\n179:     const docs = createPackedEvalDocuments();\n180:     const queries = createPackedEvalQueries();\n181:     const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n182:     const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n183:     const ftsDb = createFtsDatabase(docs);\n184: \n185:     try {\n186:       addFixtureDocuments(packed, docs);\n187:       for (const doc of docs) {\n188:         legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n189:       }\n190: \n191:       expect(isFts5Available(ftsDb)).toBe(true);\n192:       const comparison = await runBM25EngineComparison({\n193:         legacy: (query, limit) => toBaselineResults(legacy.search(query, limit), 'bm25'),\n194:         packed: (query, limit) => toBaselineResults(packed.search(query, limit), 'bm25'),\n195:         fts5: (query, limit) => fts5Bm25Search(ftsDb, query, { limit }).map((row) => ({\n196:           id: Number(row.id),\n197:           score: row.fts_score,\n198:           source: 'fts',\n199:         })),\n200:       }, queries);\n201: \n202:       expect(comparison.packedAtLeastLegacy).toBe(true);\n203:       expect(comparison.titleSignalRestored).toBe(true);\n204:       expect(comparison.packed.mrr5).toBeGreaterThanOrEqual(comparison.legacy.mrr5);\n205:       expect(comparison.fts5?.hitRate1).toBe(1);\n206:     } finally {\n207:       ftsDb.close();\n208:     }\n209:   });\n210: });\n\n(End of file - total 210 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: PACKED IN-MEMORY BM25\n// ───────────────────────────────────────────────────────────────\nimport { performance } from 'node:perf_hooks';\nimport Database from 'better-sqlite3';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport {\n  BM25Index,\n  BM25_FIELD_WEIGHTS,\n  buildBm25DocumentFields,\n  shouldWarmInMemoryBm25,\n  type BM25DocumentFields,\n  type BM25SearchResult,\n} from '../lib/search/bm25-index';\nimport { fts5Bm25Search, isFts5Available } from '../lib/search/sqlite-fts';\nimport { runBM25EngineComparison, type BM25SearchResult as BaselineResult } from '../lib/eval/bm25-baseline';\nimport {\n  createPackedEvalDocuments,\n  createPackedEvalQueries,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: PACKED IN-MEMORY BM25\n// ───────────────────────────────────────────────────────────────\nimport { performance } from 'node:perf_hooks';\nimport Database from 'better-sqlite3';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport {\n  BM25Index,\n  BM25_FIELD_WEIGHTS,\n  buildBm25DocumentFields,\n  shouldWarmInMemoryBm25,\n  type BM25DocumentFields,\n  type BM25SearchResult,\n} from '../lib/search/bm25-index';\nimport { fts5Bm25Search, isFts5Available } from '../lib/search/sqlite-fts';\nimport { runBM25EngineComparison, type BM25SearchResult as BaselineResult } from '../lib/eval/bm25-baseline';\nimport {\n  createPackedEvalDocuments,\n  createPackedEvalQueries,\n  iterateCorpusSizedDocuments,\n  type BM25PackedFixtureDocument,\n} from '../lib/eval/fixtures/bm25-packed-fixture';\n\nconst ORIGINAL_BM25_ENGINE = process.env.SPECKIT_BM25_ENGINE;\nconst ORIGINAL_ENABLE_BM25 = process.env.ENABLE_BM25;\nconst RSS_BUDGET_BYTES = 150 * 1024 * 1024;\nconst WARMUP_BUDGET_MS = 10_000;\n\nfunction toFields(doc: BM25PackedFixtureDocument): BM25DocumentFields {\n  return buildBm25DocumentFields({\n    title: doc.title,\n    content_text: doc.content_text,\n    trigger_phrases: doc.trigger_phrases,\n    file_path: doc.file_path,\n  });\n}\n\nfunction addFixtureDocuments(index: BM25Index, docs: BM25PackedFixtureDocument[]): void {\n  for (const doc of docs) {\n    index.addDocumentFields(String(doc.id), toFields(doc));\n  }\n  index.finalizePackedPostings();\n}\n\nfunction toBaselineResults(results: BM25SearchResult[], source: string): BaselineResult[] {\n  return results.map((result) => ({\n    id: Number(result.id),\n    score: result.score,\n    source,\n  }));\n}\n\nfunction createFtsDatabase(docs: BM25PackedFixtureDocument[]): Database.Database {\n  const db = new Database(':memory:');\n  db.exec(`\n    CREATE TABLE memory_index (\n      id INTEGER PRIMARY KEY,\n      title TEXT,\n      content_text TEXT,\n      trigger_phrases TEXT,\n      file_path TEXT,\n      importance_tier TEXT\n    );\n    CREATE VIRTUAL TABLE memory_fts USING fts5(\n      title,\n      trigger_phrases,\n      file_path,\n      content_text,\n      content='memory_index',\n      content_rowid='id'\n    );\n  `);\n\n  const insertMemory = db.prepare(`\n    INSERT INTO memory_index (id, title, content_text, trigger_phrases, file_path, importance_tier)\n    VALUES (?, ?, ?, ?, ?, 'normal')\n  `);\n  const insertFts = db.prepare(`\n    INSERT INTO memory_fts (rowid, title, trigger_phrases, file_path, content_text)\n    VALUES (?, ?, ?, ?, ?)\n  `);\n\n  const insertAll = db.transaction(() => {\n    for (const doc of docs) {\n      const triggers = doc.trigger_phrases.join(' ');\n      insertMemory.run(doc.id, doc.title, doc.content_text, triggers, doc.file_path);\n      insertFts.run(doc.id, doc.title, triggers, doc.file_path, doc.content_text);\n    }\n  });\n  insertAll();\n  return db;\n}\n\nafterEach(() => {\n  if (ORIGINAL_BM25_ENGINE === undefined) {\n    delete process.env.SPECKIT_BM25_ENGINE;\n  } else {\n    process.env.SPECKIT_BM25_ENGINE = ORIGINAL_BM25_ENGINE;\n  }\n\n  if (ORIGINAL_ENABLE_BM25 === undefined) {\n    delete process.env.ENABLE_BM25;\n  } else {\n    process.env.ENABLE_BM25 = ORIGINAL_ENABLE_BM25;\n  }\n  vi.restoreAllMocks();\n});\n\ndescribe('packed in-memory BM25 engine', () => {\n  it('warms the corpus fixture within RSS and latency budgets', () => {\n    process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n    const index = new BM25Index(undefined, undefined, 'packed-inmemory');\n    const beforeRss = process.memoryUsage().rss;\n    const start = performance.now();\n\n    for (const doc of iterateCorpusSizedDocuments()) {\n      index.addDocumentFields(String(doc.id), toFields(doc));\n    }\n    index.finalizePackedPostings();\n\n    const warmupMs = performance.now() - start;\n    const rssSpike = Math.max(0, process.memoryUsage().rss - beforeRss);\n\n    expect(index.getStats().documentCount).toBe(10_245);\n    expect(index.getStats().termCount).toBeGreaterThan(100);\n    expect(rssSpike).toBeLessThanOrEqual(RSS_BUDGET_BYTES);\n    expect(warmupMs).toBeLessThanOrEqual(WARMUP_BUDGET_MS);\n  });\n\n  it('restores field weighting and keeps weights query-time tunable', () => {\n    const docs = createPackedEvalDocuments();\n    const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n    const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n\n    addFixtureDocuments(packed, docs);\n    for (const doc of docs) {\n      legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n    }\n\n    const legacyTop = legacy.search('auth guard', 1)[0]?.id;\n    const packedTop = packed.search('auth guard', 1)[0]?.id;\n    const flatPackedTop = packed.search('auth guard', 1, {\n      fieldWeights: { title: 1, trigger_phrases: 1, content_generic: 1, body: 1 },\n    })[0]?.id;\n\n    expect(BM25_FIELD_WEIGHTS.title).toBeGreaterThan(BM25_FIELD_WEIGHTS.trigger_phrases);\n    expect(BM25_FIELD_WEIGHTS.trigger_phrases).toBeGreaterThan(BM25_FIELD_WEIGHTS.content_generic);\n    expect(BM25_FIELD_WEIGHTS.content_generic).toBeGreaterThan(BM25_FIELD_WEIGHTS.body);\n    expect(legacyTop).not.toBe('101');\n    expect(packedTop).toBe('101');\n    expect(flatPackedTop).not.toBe('101');\n  });\n\n  it('keeps legacy, packed, and auto selection explicit and logged', () => {\n    const infoSpy = vi.spyOn(console, 'info').mockImplementation(() => {});\n\n    process.env.ENABLE_BM25 = 'true';\n    process.env.SPECKIT_BM25_ENGINE = 'legacy-inmemory';\n    const legacy = new BM25Index();\n    expect((legacy as unknown as { engine: string }).engine).toBe('legacy-inmemory');\n    expect(shouldWarmInMemoryBm25(null)).toBe(true);\n\n    process.env.SPECKIT_BM25_ENGINE = 'packed-inmemory';\n    const packed = new BM25Index();\n    expect((packed as unknown as { engine: string }).engine).toBe('packed-inmemory');\n    expect(shouldWarmInMemoryBm25(null)).toBe(true);\n\n    delete process.env.SPECKIT_BM25_ENGINE;\n    const auto = new BM25Index();\n    expect((auto as unknown as { engine: string }).engine).toBe('packed-inmemory');\n\n    expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('legacy-inmemory'))).toBe(true);\n    expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('packed-inmemory'))).toBe(true);\n    expect(infoSpy.mock.calls.some((call) => String(call[0]).includes('auto mode fallback'))).toBe(true);\n  });\n\n  it('passes packed-vs-legacy baseline comparison and matches FTS5 title intent', async () => {\n    const docs = createPackedEvalDocuments();\n    const queries = createPackedEvalQueries();\n    const legacy = new BM25Index(undefined, undefined, 'legacy-inmemory');\n    const packed = new BM25Index(undefined, undefined, 'packed-inmemory');\n    const ftsDb = createFtsDatabase(docs);\n\n    try {\n      addFixtureDocuments(packed, docs);\n      for (const doc of docs) {\n        legacy.addDocument(String(doc.id), [doc.title, doc.content_text, doc.trigger_phrases.join(' '), doc.file_path].join(' '));\n      }\n\n      expect(isFts5Available(ftsDb)).toBe(true);\n      const comparison = await runBM25EngineComparison({\n        legacy: (query, limit) => toBaselineResults(legacy.search(query, limit), 'bm25'),\n        packed: (query, limit) => toBaselineResults(packed.search(query, limit), 'bm25'),\n        fts5: (query, limit) => fts5Bm25Search(ftsDb, query, { limit }).map((row) => ({\n          id: Number(row.id),\n          score: row.fts_score,\n          source: 'fts',\n        })),\n      }, queries);\n\n      expect(comparison.packedAtLeastLegacy).toBe(true);\n      expect(comparison.titleSignalRestored).toBe(true);\n      expect(comparison.packed.mrr5).toBeGreaterThanOrEqual(comparison.legacy.mrr5);\n      expect(comparison.fts5?.hitRate1).toBe(1);\n    } finally {\n      ftsDb.close();\n    }\n  });\n});","lineStart":1,"lineEnd":210,"totalLines":210,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/bm25-packed-inmemory.vitest.ts","time":{"start":1781151899303,"end":1781151899305}},"metadata":{"openai":{"itemId":"fc_0f7bfbafc466ec3e016a2a389b2fa08191b456336534f8dcb6"}},"id":"prt_eb4ed1ea1001j8FPTMMPx5YjsI","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ecffd9001L60FxfP8wr6e40"}}
{"type":"step_finish","timestamp":1781151899595,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"id":"prt_eb4ed1fc9001zbac7lMcQoAjAv","reason":"tool-calls","snapshot":"d099332a90a08a3dac28e7f95b5ef70267b29ccb","messageID":"msg_eb4ecffd9001L60FxfP8wr6e40","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","type":"step-finish","tokens":{"total":79588,"input":9676,"output":256,"reasoning":24,"cache":{"write":0,"read":69632}},"cost":0}}
