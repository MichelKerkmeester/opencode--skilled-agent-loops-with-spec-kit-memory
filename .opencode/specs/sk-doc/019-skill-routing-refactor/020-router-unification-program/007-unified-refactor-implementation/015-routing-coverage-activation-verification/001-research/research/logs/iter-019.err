   191	def detect_document_type(file_path: str, content: str, rules: Dict[str, Any]) -> str:
   192	    """Detect document type from file path or content."""
   193	    path_lower = str(file_path).lower()
   194	    assert_supported_root_path(path_lower)
   195	    portable_path = PurePosixPath(path_lower.replace('\\', '/'))
   196	
   197	    if any(f'/{name}/' in path_lower or f'\\{name}\\' in path_lower for name in PLAYBOOK_DIR_NAMES):
   198	        # A per-feature playbook leaf sits one level below the category root
   199	        # (manual-testing-playbook/<category>/<feature>.md). Classify by that structural
   200	        # position rather than an ordinal folder-name prefix, so category folders can be
   201	        # named by meaning alone. The root index file (whose parent IS the
   202	        # manual_testing_playbook dir) is intentionally excluded.
   203	        if portable_path.parent.parent.name in PLAYBOOK_DIR_NAMES:
   204	            return 'playbook_feature'
   205	    # Per-feature catalog leaves sit one level below the catalog root
   206	    # (feature-catalog/<category>/<feature>.md). These carry the Validation And Tests
   207	    # table whose Type taxonomy and placeholder rows the generic readme path misses.
   208	    # Classify by structural position rather than an ordinal folder-name prefix; the
   209	    # root index file (whose parent IS the feature_catalog dir) stays excluded.
   210	    if any(f'/{name}/' in path_lower or f'\\{name}\\' in path_lower for name in CATALOG_DIR_NAMES):
   211	        if portable_path.parent.parent.name in CATALOG_DIR_NAMES:
   212	            return 'feature_catalog'
   213	    if '/command/' in path_lower or '\\command\\' in path_lower or '/commands/' in path_lower or '\\commands\\' in path_lower:
   214	        return 'command'
   215	    if '/install-guides/' in path_lower or '\\install_guides\\' in path_lower:
   216	        return 'install_guide'
   217	    if 'install_guide' in Path(path_lower).stem or 'install-guide' in Path(path_lower).stem:
   218	        return 'install_guide'
   219	    # Changelog files: under .opencode/changelog/, .opencode/skills/*/changelog/,
   220	    # or spec-folder nested changelog/ subdirectories. Files match v{VERSION}.md or changelog-*.md
   221	    if '/changelog/' in path_lower or '\\changelog\\' in path_lower:
   222	        return 'changelog'
   223	    if path_lower.endswith('readme.md'):
   224	        return 'readme'
   225	    if path_lower.endswith('skill.md'):
   226	        return 'skill'
   227	    if '/specs/' in path_lower or '\\specs\\' in path_lower:
   228	        return 'spec'
   229	    if '/agents/' in path_lower or '\\agents\\' in path_lower or '/agent/' in path_lower or '\\agent\\' in path_lower:
   230	        return 'agent'
   231	    if '/references/' in path_lower or '\\references\\' in path_lower:
   232	        return 'reference'
   233	    if '/assets/' in path_lower or '\\assets\\' in path_lower:
   234	        return 'asset'
   235	
   236	    # Default to readme for general markdown
   237	    return 'readme'
   238	
