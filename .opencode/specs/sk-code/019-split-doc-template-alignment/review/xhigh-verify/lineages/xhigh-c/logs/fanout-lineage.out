ion-${String(n).padStart(3,'0')}.md`), 'utf8').trimEnd();\n  if (!/Review verdict: (PASS|CONDITIONAL|FAIL)$/.test(narrative)) throw new Error(`iteration ${n} final verdict mismatch`);\n  const deltaRecords = fs.readFileSync(path.join(root, `deltas/iter-${String(n).padStart(3,'0')}.jsonl`), 'utf8').trim().split(/\\r?\\n/).map(JSON.parse);\n  if (!deltaRecords.some(r => r.type === 'iteration' && r.iteration === n)) throw new Error(`iteration ${n} delta mismatch`);\n  const check = spawnSync(process.execPath, ['.opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs', '--loop-type', 'review', '--artifact-dir', root, '--iteration', String(n), '--json'], { encoding: 'utf8' });\n  if (check.status !== 0) throw new Error(`verify-iteration ${n} failed: ${check.stdout}${check.stderr}`);\n}\nconst report = fs.readFileSync(path.join(root, 'review-report.md'), 'utf8');\nconst sections = ['Executive Summary','Planning Trigger','Active Finding Registry','Remediation Workstreams','Spec Seed','Plan Seed','Traceability Status','Deferred Items','Dimension Expansion Map','Search Ledger','Audit Appendix'];\nconst absentSections = sections.filter(section => !report.includes(`## ${section}`));\nif (absentSections.length) throw new Error(`report sections missing: ${absentSections.join(', ')}`);\nif (report.includes('## Resource Map Coverage Gate')) throw new Error('unexpected resource-map coverage gate section');\nif (fs.existsSync(path.join(root, '.deep-review.lock'))) throw new Error('lock file still present');\nif (records.some(r => r.event === 'paused' || r.event === 'stuck_recovery')) throw new Error('unnormalized event found');\nprocess.stdout.write(JSON.stringify({\n  ok: true,\n  sessionId: config.sessionId,\n  iterations: iterations.length,\n  stopReason: synthesis.stopReason,\n  verdict: synthesis.verdict,\n  findings: registry.findingsBySeverity,\n  dimensions: registry.dimensionCoverage,\n  searchDebt: registry.searchDebt.length,\n  artifactsChecked: required.length,\n  reportSections: sections.length,\n  jsonlRecords: records.length,\n  lockReleased: true,\n}) + '\\n');\nEOF","time":{"start":1783918772258,"end":1783918772260}},"metadata":{"openai":{"itemId":"fc_07c9be4b22b584e1016a54709d5df08191908a6320bcc02b74"}},"id":"prt_f59d7e6b3001nDrlWmKwjEW3UA","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59d7cc7b001pHhKZR1iKS1o99"}}
