in google-chrome google-chrome-stable chromium chromium-browser microsoft-edge; do\n36:     if command -v \"$c\" >/dev/null 2>&1; then\n37:       command -v \"$c\"\n38:       return 0\n39:     fi\n40:   done\n41: \n42:   return 1\n43: }\n44: \n45: log \"== mcp-chrome-devtools doctor (read-only) ==\"\n46: \n47: # Platform and runtime\n48: case \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\n49: if command -v node >/dev/null 2>&1; then\n50:   nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null || echo none) (<18)\"\n51: else warn \"Node not found\"; fi\n52: command -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n53: \n54: # Primary CLI\n55: log \"-- bdg CLI --\"\n56: if command -v bdg >/dev/null 2>&1; then\n57:   if version=\"$(bdg --version 2>/dev/null)\"; then\n58:     ok \"bdg: $(command -v bdg) ($version)\"\n59:   else\n60:     ok \"bdg: $(command -v bdg) (version unavailable)\"\n61:   fi\n62: elif command -v npx >/dev/null 2>&1; then\n63:   if npx --no-install browser-debugger-cli@alpha --version >/dev/null 2>&1; then\n64:     ok \"browser-debugger-cli@alpha: resolvable via npx --no-install\"\n65:   else\n66:     warn \"bdg not on PATH and browser-debugger-cli@alpha not resolvable via npx --no-install\"\n67:   fi\n68: else\n69:   warn \"bdg not on PATH and npx not found\"\n70: fi\n71: \n72: # Browser runtime\n73: log \"-- Chrome/Chromium browser --\"\n74: if p=\"$(chrome_path)\"; then\n75:   ok \"Chrome/Chromium/Edge: $p\"\n76: else\n77:   warn \"Chrome/Chromium/Edge not found at common paths or PATH\"\n78: fi\n79: \n80: # Optional MCP via Code Mode\n81: log \"-- Optional Chrome DevTools MCP via Code Mode --\"\n82: UTCP=\"$HERE/../../../../.utcp_config.json\"\n83: if [ -f \"$UTCP\" ]; then\n84:   if grep -q '\"name\"[[:space:]]*:[[:space:]]*\"chrome_devtools' \"$UTCP\" 2>/dev/null; then\n85:     ok \"Code Mode chrome_devtools manual registered in .utcp_config.json\"\n86:   else\n87:     info \"No chrome_devtools manual in .utcp_config.json\"\n88:   fi\n89: else\n90:   info \".utcp_config.json not found at expected repo root, optional MCP is opt-in\"\n91: fi\n92: \n93: log \"\"\n94: log \"Doctor is read-only. For setup, see install.sh and INSTALL_GUIDE.md.\"\n95: \n96: exit 0\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# WHY: read-only diagnostics for Chrome DevTools tooling. It changes nothing,\n# installs nothing, and never prints secrets.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n\n_c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\nlog()  { printf '%s\\n' \"$*\"; }\ninfo() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\nok()   { printf '%sâś“ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\nwarn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\nerr()  { printf '%sâś— %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n\nnode_major() {\n  command -v node >/dev/null 2>&1 || { printf ''; return 0; }\n  node -p 'process.versions.node.split(\".\")[0]' 2>/dev/null || printf ''\n}\n\nchrome_path() {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-chrome-devtools/scripts/doctor.sh","text":"#!/usr/bin/env bash\n# WHY: read-only diagnostics for Chrome DevTools tooling. It changes nothing,\n# installs nothing, and never prints secrets.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n\n_c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\nlog()  { printf '%s\\n' \"$*\"; }\ninfo() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\nok()   { printf '%sâś“ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\nwarn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\nerr()  { printf '%sâś— %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n\nnode_major() {\n  command -v node >/dev/null 2>&1 || { printf ''; return 0; }\n  node -p 'process.versions.node.split(\".\")[0]' 2>/dev/null || printf ''\n}\n\nchrome_path() {\n  if [ -n \"${CHROME_PATH:-}\" ] && [ -x \"$CHROME_PATH\" ]; then\n    printf '%s' \"$CHROME_PATH\"\n    return 0\n  fi\n\n  for p in \\\n    \"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\" \\\n    \"/Applications/Google Chrome Canary.app/Contents/MacOS/Google Chrome Canary\" \\\n    \"/Applications/Chromium.app/Contents/MacOS/Chromium\" \\\n    \"/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge\"\n  do\n    [ -x \"$p\" ] && { printf '%s' \"$p\"; return 0; }\n  done\n\n  for c in google-chrome google-chrome-stable chromium chromium-browser microsoft-edge; do\n    if command -v \"$c\" >/dev/null 2>&1; then\n      command -v \"$c\"\n      return 0\n    fi\n  done\n\n  return 1\n}\n\nlog \"== mcp-chrome-devtools doctor (read-only) ==\"\n\n# Platform and runtime\ncase \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\nif command -v node >/dev/null 2>&1; then\n  nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null || echo none) (<18)\"\nelse warn \"Node not found\"; fi\ncommand -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n\n# Primary CLI\nlog \"-- bdg CLI --\"\nif command -v bdg >/dev/null 2>&1; then\n  if version=\"$(bdg --version 2>/dev/null)\"; then\n    ok \"bdg: $(command -v bdg) ($version)\"\n  else\n    ok \"bdg: $(command -v bdg) (version unavailable)\"\n  fi\nelif command -v npx >/dev/null 2>&1; then\n  if npx --no-install browser-debugger-cli@alpha --version >/dev/null 2>&1; then\n    ok \"browser-debugger-cli@alpha: resolvable via npx --no-install\"\n  else\n    warn \"bdg not on PATH and browser-debugger-cli@alpha not resolvable via npx --no-install\"\n  fi\nelse\n  warn \"bdg not on PATH and npx not found\"\nfi\n\n# Browser runtime\nlog \"-- Chrome/Chromium browser --\"\nif p=\"$(chrome_path)\"; then\n  ok \"Chrome/Chromium/Edge: $p\"\nelse\n  warn \"Chrome/Chromium/Edge not found at common paths or PATH\"\nfi\n\n# Optional MCP via Code Mode\nlog \"-- Optional Chrome DevTools MCP via Code Mode --\"\nUTCP=\"$HERE/../../../../.utcp_config.json\"\nif [ -f \"$UTCP\" ]; then\n  if grep -q '\"name\"[[:space:]]*:[[:space:]]*\"chrome_devtools' \"$UTCP\" 2>/dev/null; then\n    ok \"Code Mode chrome_devtools manual registered in .utcp_config.json\"\n  else\n    info \"No chrome_devtools manual in .utcp_config.json\"\n  fi\nelse\n  info \".utcp_config.json not found at expected repo root, optional MCP is opt-in\"\nfi\n\nlog \"\"\nlog \"Doctor is read-only. For setup, see install.sh and INSTALL_GUIDE.md.\"\n\nexit 0","lineStart":1,"lineEnd":96,"totalLines":96,"truncated":false}},"title":".opencode/skills/mcp-chrome-devtools/scripts/doctor.sh","time":{"start":1781544815502,"end":1781544815518}},"metadata":{"openai":{"itemId":"fc_0293ae9edfd8a8df016a30376d739c8191a142785a7fb358e6"}},"id":"prt_ecc588b6f001W3xHPOxXb3wQSi","sessionID":"ses_133a82fbbffevAjtqNLJ4lglcd","messageID":"msg_ecc5844da001LfvSst96dr5Uq0"}}
