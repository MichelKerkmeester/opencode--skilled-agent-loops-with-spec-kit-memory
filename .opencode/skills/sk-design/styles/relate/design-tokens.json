{
  "color": {
    "snow-canvas": {
      "$value": "#fcfcfc",
      "$type": "color",
      "$description": "Snow Canvas — Page background, card surfaces, nav surface — the dominant neutral that makes blue accents feel switched on"
    },
    "lavender-wash": {
      "$value": "#f0f4fe",
      "$type": "color",
      "$description": "Lavender Wash — Subtle accent surface behind hero and feature blocks — gives cool-tinted depth without darkening the page"
    },
    "midnight-ink": {
      "$value": "#020520",
      "$type": "color",
      "$description": "Midnight Ink — Hero and section headings — near-black with a violet cast, reads warmer than pure black against white"
    },
    "graphite-body": {
      "$value": "#14141e",
      "$type": "color",
      "$description": "Graphite Body — Body text, secondary headings, product UI labels — workhorse dark neutral with cool undertone"
    },
    "slate-caption": {
      "$value": "#374151",
      "$type": "color",
      "$description": "Slate Caption — Muted body text, nav labels, list items — medium-dark gray for subordinate copy"
    },
    "ash-helper": {
      "$value": "#6b7280",
      "$type": "color",
      "$description": "Ash Helper — Helper text, metadata, timestamps — lighter gray for tertiary information"
    },
    "stone-divider": {
      "$value": "#e2e8f0",
      "$type": "color",
      "$description": "Stone Divider — Hairline borders, card edges, divider lines — barely-there separation between surfaces"
    },
    "fog-surface": {
      "$value": "#f1f5f9",
      "$type": "color",
      "$description": "Fog Surface — Input backgrounds, disabled states, subtle grouping surfaces — one shade darker than canvas"
    },
    "royal-signal": {
      "$value": "#145aff",
      "$type": "color",
      "$description": "Royal Signal — Primary brand accent — headlines, links, hero word highlight, pipeline-active dots, logo mark. Single saturated hue carries the entire brand identity"
    },
    "cobalt-glow": {
      "$value": "#3b82f6",
      "$type": "color",
      "$description": "Cobalt Glow — Blue wash for highlight backgrounds, decorative bands, and soft emphasis behind content"
    },
    "mint-win": {
      "$value": "#16ca2e",
      "$type": "color",
      "$description": "Mint Win — Green text accent for links, tags, and emphasized short phrases. Use as a supporting accent, not as a status color"
    },
    "coral-lost": {
      "$value": "#f26052",
      "$type": "color",
      "$description": "Coral Lost — Red text accent for links, tags, and emphasized short phrases. Use as a supporting accent, not as a status color"
    },
    "amber-pending": {
      "$value": "#ffa64d",
      "$type": "color",
      "$description": "Amber Pending — Orange text accent for links, tags, and emphasized short phrases. Use as a supporting accent, not as a status color"
    },
    "azure-focus": {
      "$value": "#0099ff",
      "$type": "color",
      "$description": "Azure Focus — Input focus ring glow — pure blue that distinguishes active form state from ambient blue brand color"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary typeface for headings, body, nav, buttons — the only text family on the page. Weights split: 600 for hero/section headlines, 500 for subheadings and nav, 400 for body copy. Display sizes (56–80px) use aggressive negative tracking (-0.027 to -0.037em) that compresses letterforms into a tight confident block."
    },
    "pretendard": {
      "$value": "Pretendard",
      "$type": "fontFamily",
      "$description": "Secondary typeface used for Korean-language rendering and specific UI labels with positive tracking (+0.019 to +0.030em) — appears in localized product UI strings"
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Monospace accent for code-adjacent text, numerical callouts, and technical labels — negative tracking makes it feel geometric"
    },
