style-library.mjs\n49: .opencode/skills/sk-design/styles/lib/paths.mjs\n50: .opencode/skills/sk-design/styles/library/manifests/retrieval-manifest.json\n51: .opencode/skills/sk-design/styles/scripts/README.md\n52: .opencode/skills/sk-design/styles/scripts/extract-refero.mjs\n53: .opencode/skills/sk-design/styles/tests/database/adapter.test.mjs\n54: .opencode/skills/sk-design/styles/tests/database/fixtures.mjs\n55: .opencode/skills/sk-design/styles/tests/database/fixtures.test.mjs\n56: .opencode/skills/sk-design/styles/tests/database/index.mjs\n57: .opencode/skills/sk-design/styles/tests/database/indexer.test.mjs\n58: .opencode/skills/sk-design/styles/tests/database/judgments.test.mjs\n59: .opencode/skills/sk-design/styles/tests/database/manifest.test.mjs\n60: .opencode/skills/sk-design/styles/tests/database/operator.test.mjs\n61: .opencode/skills/sk-design/styles/tests/database/oracle.test.mjs\n62: .opencode/skills/sk-design/styles/tests/database/retrieval.test.mjs\n63: .opencode/skills/sk-design/styles/tests/database/schema.test.mjs\n64: .opencode/skills/sk-design/styles/tests/database/telemetry.test.mjs\n65: .opencode/skills/sk-design/styles/tests/engine/check-stable.test.mjs\n66: .opencode/skills/sk-design/styles/tests/engine/eligibility-first.test.mjs\n67: .opencode/skills/sk-design/styles/tests/engine/fallback.test.mjs\n68: .opencode/skills/sk-design/styles/tests/engine/fixtures.mjs\n69: .opencode/skills/sk-design/styles/tests/engine/hydrate-guard.test.mjs\n70: .opencode/skills/sk-design/styles/tests/engine/index.mjs\n71: .opencode/skills/sk-design/styles/tests/engine/invalidation.test.mjs\n72: .opencode/skills/sk-design/styles/tests/engine/proof.test.mjs\n73: .opencode/skills/sk-design/styles/tests/oracle/differential-oracle.mjs\n74: .opencode/skills/sk-design/styles/tests/oracle/golden/degraded-disable-fts.canonical.json\n75: .opencode/skills/sk-design/styles/tests/oracle/golden/exact-reuse.canonical.json\n76: .opencode/skills/sk-design/styles/tests/oracle/go