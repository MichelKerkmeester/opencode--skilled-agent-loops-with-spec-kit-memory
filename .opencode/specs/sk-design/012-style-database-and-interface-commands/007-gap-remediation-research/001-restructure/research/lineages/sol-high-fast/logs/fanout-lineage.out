 ]\n        },\n        {\n          \"memory_id\": 2653,\n          \"spec_folder\": \"system-code-graph/z_archive/002-structural-indexer\",\n          \"title\": \"Phase 008: Structural Indexer (tree-sitter) [system-code-graph/z_archive/002-structural-indexer/spec]\",\n          \"matched_phrases\": [\n            \"tree\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 2701,\n          \"spec_folder\": \"system-code-graph/z_archive/012-query-routing-integration\",\n          \"title\": \"Feature Specification: Query-Routing [system-code-graph/z_archive/012-query-routing-integration/spec]\",\n          \"matched_phrases\": [\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 2696,\n          \"spec_folder\": \"system-code-graph/z_archive/011-code-graph-auto-trigger\",\n          \"title\": \"Phase 019: Code Graph Auto-Trigger [system-code-graph/z_archive/011-code-graph-auto-trigger/spec]\",\n          \"matched_phrases\": [\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 2686,\n          \"spec_folder\": \"system-code-graph/z_archive/009-cross-runtime-ux\",\n          \"title\": \"Spec: Cross-Runtime UX & Documentation [024/016] [system-code-graph/z_archive/009-cross-runtime-ux/spec]\",\n          \"matched_phrases\": [\n            \"spec\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-07-21T07:27:58.887Z\",\n      \"latencyMs\": 1929\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1784618876617,"end":1784618879632}},"metadata":{"openai":{"itemId":"fc_0f2ae68b33ca2150016a5f1f7ab88881918a093cdfb5245cec"}},"id":"prt_f8392f792001Wesmj48u9B4T3Q","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f8392d95b001wL5zEQx6o550iu"}}
