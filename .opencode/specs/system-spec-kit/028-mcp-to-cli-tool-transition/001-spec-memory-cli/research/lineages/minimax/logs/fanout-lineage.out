aited<typeof import('./core/index.js')>;\n25: type StartupChecksModule = Awaited<typeof import('./startup-checks.js')>;\n26: type CausalEdgesModule = Awaited<typeof import('./lib/storage/causal-edges.js')>;\n27: type HistoryModule = Awaited<typeof import('./lib/storage/history.js')>;\n28: type SchemaDowngradeModule = Awaited<typeof import('./lib/storage/schema-downgrade.js')>;\n29: \n30: let _vector_index: VectorIndexModule | null = null;\n31: let _checkpoints: CheckpointsModule | null = null;\n32: let _access_tracker: AccessTrackerModule | null = null;\n33: let _mutation_ledger: MutationLedgerModule | null = null;\n34: let _trigger_matcher: TriggerMatcherModule | null = null;\n35: let _core_index: CoreIndexModule | null = null;\n36: let _startup_checks: StartupChecksModule | null = null;\n37: let _causal_edges: CausalEdgesModule | null = null;\n38: let _history: HistoryModule | null = null;\n39: let _schema_downgrade: SchemaDowngradeModule | null = null;\n40: \n41: async function getVectorIndex() {\n42:   return _vector_index ??= await import('./lib/search/vector-index.js');\n43: }\n44: \n45: async function getCheckpointsLib() {\n46:   return _checkpoints ??= await import('./lib/storage/checkpoints.js');\n47: }\n48: \n49: async function getAccessTracker() {\n50:   return _access_tracker ??= await import('./lib/storage/access-tracker.js');\n51: }\n52: \n53: async function getMutationLedger() {\n54:   return _mutation_ledger ??= await import('./lib/storage/mutation-ledger.js');\n55: }\n56: \n57: async function getTriggerMatcher() {\n58:   return _trigger_matcher ??= await import('./lib/parsing/trigger-matcher.js');\n59: }\n60: \n61: async function getCoreIndex() {\n62:   return _core_index ??= await import('./core/index.js');\n63: }\n64: \n65: async function getStartupChecks() {\n66:   return _startup_checks ??= await import('./startup-checks.js');\n67: }\n68: \n69: async function getCausalEdges() {\n70:   return _causal_edges ??= await import('./lib/storage/causal-edges.js');\n71: }\n72: \n73: async function getHistory() {\n74:   return _history ??= await import('./lib/storage/history.js');\n75: }\n76: \n77: async function getSchemaDowngrade() {\n78:   return _schema_downgrade ??= await import('./lib/storage/schema-downgrade.js');\n79: }\n80: \n81: async function getDatabasePath(): Promise<string> {\n82:   return (await getCoreIndex()).DATABASE_PATH;\n83: }\n84: \n85: /* ───────────────────────────────────────────────────────────────\n86:    1. ARGUMENT PARSING\n87: ──────────────────────────────────────────────────────────────── */\n88: \n89: const args = process.argv.slice(2);\n90: const command = args[0];\n91: \n92: function getFlag(name: string): boolean {\n93:   return args.includes(`--${name}`);\n94: }\n95: \n96: function getOption(name: string): string | undefined {\n97:   const idx = args.indexOf(`--${name}`);\n98:   if (idx === -1 || idx + 1 >= args.length) return undefined;\n99:   return args[idx + 1];\n100: }\n101: \n102: function printUsage(): void {\n103:   console.log(`\n104: spec-kit-cli — Bulk database operations for Spec Kit Memory\n105: \n106: Usage:\n107:   spec-kit-cli <command> [options]\n108: \n109: Commands:\n110:   stats                          Show memory database statistics\n111:   bulk-delete --tier <tier>      Delete memories by importance tier\n112:     [--folder <spec-folder>]       Optional: scope to a spec folder\n113:     [--older-than <days>]          Optional: only delete older than N days\n114:     [--dry-run]                    Preview without deleting\n115:     [--skip-checkpoint]            Optional: skip pre-delete checkpoint (blocked for constitutional/critical)\n116:   reindex [--force] [--eager-warmup]\n117:                                  Re-index memory files (lazy model load by default)\n118:   schema-downgrade --to 15 --confirm\n119:                                  Downgrade schema from v16 to v15 (targeted, destructive)\n120: \n\n(Showing lines 1-120 of 597. Use offset=121 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ────────────────────────────────────────────────────────────────\n// MODULE: Cli\n// ────────────────────────────────────────────────────────────────\n// Standalone CLI for bulk database operations, runnable from any\n// Directory. Resolves its own modules via __dirname so\n// Better-sqlite3 and sqlite-vec load correctly regardless of cwd.\n//\n// Usage:\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js stats\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js bulk-delete --tier deprecated\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js reindex [--force] [--eager-warmup]\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js schema-downgrade --to 15 --confirm\nimport { createRequire } from 'node:module';\n\nconst require = createRequire(import.meta.url);\nconst { version: CLI_VERSION } = require('../package.json') as { version: string };\n\ntype VectorIndexModule = Awaited<typeof import('./lib/search/vector-index.js')>;\ntype CheckpointsModule = Awaited<typeof import('./lib/storage/checkpoints.js')>;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/cli.ts","text":"#!/usr/bin/env node\n// ────────────────────────────────────────────────────────────────\n// MODULE: Cli\n// ────────────────────────────────────────────────────────────────\n// Standalone CLI for bulk database operations, runnable from any\n// Directory. Resolves its own modules via __dirname so\n// Better-sqlite3 and sqlite-vec load correctly regardless of cwd.\n//\n// Usage:\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js stats\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js bulk-delete --tier deprecated\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js reindex [--force] [--eager-warmup]\n//   Node .opencode/skills/system-spec-kit/mcp_server/dist/cli.js schema-downgrade --to 15 --confirm\nimport { createRequire } from 'node:module';\n\nconst require = createRequire(import.meta.url);\nconst { version: CLI_VERSION } = require('../package.json') as { version: string };\n\ntype VectorIndexModule = Awaited<typeof import('./lib/search/vector-index.js')>;\ntype CheckpointsModule = Awaited<typeof import('./lib/storage/checkpoints.js')>;\ntype AccessTrackerModule = Awaited<typeof import('./lib/storage/access-tracker.js')>;\ntype MutationLedgerModule = Awaited<typeof import('./lib/storage/mutation-ledger.js')>;\ntype TriggerMatcherModule = Awaited<typeof import('./lib/parsing/trigger-matcher.js')>;\ntype CoreIndexModule = Awaited<typeof import('./core/index.js')>;\ntype StartupChecksModule = Awaited<typeof import('./startup-checks.js')>;\ntype CausalEdgesModule = Awaited<typeof import('./lib/storage/causal-edges.js')>;\ntype HistoryModule = Awaited<typeof import('./lib/storage/history.js')>;\ntype SchemaDowngradeModule = Awaited<typeof import('./lib/storage/schema-downgrade.js')>;\n\nlet _vector_index: VectorIndexModule | null = null;\nlet _checkpoints: CheckpointsModule | null = null;\nlet _access_tracker: AccessTrackerModule | null = null;\nlet _mutation_ledger: MutationLedgerModule | null = null;\nlet _trigger_matcher: TriggerMatcherModule | null = null;\nlet _core_index: CoreIndexModule | null = null;\nlet _startup_checks: StartupChecksModule | null = null;\nlet _causal_edges: CausalEdgesModule | null = null;\nlet _history: HistoryModule | null = null;\nlet _schema_downgrade: SchemaDowngradeModule | null = null;\n\nasync function getVectorIndex() {\n  return _vector_index ??= await import('./lib/search/vector-index.js');\n}\n\nasync function getCheckpointsLib() {\n  return _checkpoints ??= await import('./lib/storage/checkpoints.js');\n}\n\nasync function getAccessTracker() {\n  return _access_tracker ??= await import('./lib/storage/access-tracker.js');\n}\n\nasync function getMutationLedger() {\n  return _mutation_ledger ??= await import('./lib/storage/mutation-ledger.js');\n}\n\nasync function getTriggerMatcher() {\n  return _trigger_matcher ??= await import('./lib/parsing/trigger-matcher.js');\n}\n\nasync function getCoreIndex() {\n  return _core_index ??= await import('./core/index.js');\n}\n\nasync function getStartupChecks() {\n  return _startup_checks ??= await import('./startup-checks.js');\n}\n\nasync function getCausalEdges() {\n  return _causal_edges ??= await import('./lib/storage/causal-edges.js');\n}\n\nasync function getHistory() {\n  return _history ??= await import('./lib/storage/history.js');\n}\n\nasync function getSchemaDowngrade() {\n  return _schema_downgrade ??= await import('./lib/storage/schema-downgrade.js');\n}\n\nasync function getDatabasePath(): Promise<string> {\n  return (await getCoreIndex()).DATABASE_PATH;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. ARGUMENT PARSING\n──────────────────────────────────────────────────────────────── */\n\nconst args = process.argv.slice(2);\nconst command = args[0];\n\nfunction getFlag(name: string): boolean {\n  return args.includes(`--${name}`);\n}\n\nfunction getOption(name: string): string | undefined {\n  const idx = args.indexOf(`--${name}`);\n  if (idx === -1 || idx + 1 >= args.length) return undefined;\n  return args[idx + 1];\n}\n\nfunction printUsage(): void {\n  console.log(`\nspec-kit-cli — Bulk database operations for Spec Kit Memory\n\nUsage:\n  spec-kit-cli <command> [options]\n\nCommands:\n  stats                          Show memory database statistics\n  bulk-delete --tier <tier>      Delete memories by importance tier\n    [--folder <spec-folder>]       Optional: scope to a spec folder\n    [--older-than <days>]          Optional: only delete older than N days\n    [--dry-run]                    Preview without deleting\n    [--skip-checkpoint]            Optional: skip pre-delete checkpoint (blocked for constitutional/critical)\n  reindex [--force] [--eager-warmup]\n                                 Re-index memory files (lazy model load by default)\n  schema-downgrade --to 15 --confirm\n                                 Downgrade schema from v16 to v15 (targeted, destructive)\n","lineStart":1,"lineEnd":120,"totalLines":597,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/cli.ts","time":{"start":1780736167121,"end":1780736167128}},"id":"prt_e9c258cb8001kfe2ggM0b2IKd9","sessionID":"ses_163de1863ffeLd3K58IkmWaFwL","messageID":"msg_e9c256fa9001rJVjLgI3Xc2QfV"}}
