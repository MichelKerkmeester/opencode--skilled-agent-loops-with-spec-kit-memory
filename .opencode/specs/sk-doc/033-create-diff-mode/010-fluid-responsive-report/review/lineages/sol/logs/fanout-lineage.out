{"type":"tool_use","timestamp":1784210626304,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_iFx6rhZmMrDfFvl8oZc6X633","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/scripts/create_diff.py","offset":1160,"limit":315},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/scripts/create_diff.py</path>\n<type>file</type>\n<content>\n1160:     blob = snap_dir / f\"{ts}-{digest[:12]}{path.suffix}\"\n1161:     _atomic_copy(path, blob)\n1162:     entry = {\n1163:         \"captured_at\": _now_iso(),\n1164:         \"source_path\": str(path.resolve()),\n1165:         \"source_name\": path.name,\n1166:         \"sha256\": digest,\n1167:         \"size\": path.stat().st_size,\n1168:         \"blob\": blob.name,\n1169:     }\n1170:     manifest = snap_dir / \"manifest.json\"\n1171:     data = _load_manifest(manifest)\n1172:     data[\"source_path\"] = str(path.resolve())\n1173:     data.setdefault(\"snapshots\", []).append(entry)\n1174:     _write_json(manifest, data)\n1175:     return entry\n1176: \n1177: \n1178: def _load_manifest(manifest: Path) -> dict:\n1179:     if manifest.exists():\n1180:         try:\n1181:             return json.loads(manifest.read_text(encoding=\"utf-8\"))\n1182:         except json.JSONDecodeError:\n1183:             return {}\n1184:     return {}\n1185: \n1186: \n1187: def _write_json(path: Path, data: dict) -> None:\n1188:     path.parent.mkdir(parents=True, exist_ok=True)\n1189:     fd, tmp = tempfile.mkstemp(dir=str(path.parent))\n1190:     with os.fdopen(fd, \"w\", encoding=\"utf-8\") as fh:\n1191:         json.dump(data, fh, indent=2, sort_keys=True)\n1192:         fh.write(\"\\n\")\n1193:     os.replace(tmp, path)\n1194: \n1195: \n1196: def latest_snapshot(path: Path, state: Path) -> Optional[dict]:\n1197:     \"\"\"Return the most recent snapshot manifest entry for a file, if any.\n1198: \n1199:     Args:\n1200:         path: File whose baseline history is queried.\n1201:         state: State directory root holding the snapshot store.\n1202: \n1203:     Returns:\n1204:         The newest manifest entry, or None when no snapshot exists.\n1205:     \"\"\"\n1206:     manifest = _snap_dir(state, path) / \"manifest.json\"\n1207:     data = _load_manifest(manifest)\n1208:     snaps = data.get(\"snapshots\") or []\n1209:     return snaps[-1] if snaps else None\n1210: \n1211: \n1212: # --------------------------------------------------------------------------- #\n1213: # Commands\n1214: # --------------------------------------------------------------------------- #\n1215: \n1216: def _write_report(html_str: str, out: Optional[str], default_stem: str) -> Path:\n1217:     target = Path(out) if out else Path.cwd() / f\"{default_stem}.diff.html\"\n1218:     target.parent.mkdir(parents=True, exist_ok=True)\n1219:     target.write_text(html_str, encoding=\"utf-8\")\n1220:     return target\n1221: \n1222: \n1223: def _summary_dict(diff: DiffResult, report: Optional[Path], fmt: str, tier: str) -> dict:\n1224:     return {\n1225:         \"format\": fmt, \"fidelity_tier\": tier,\n1226:         \"added\": diff.added, \"removed\": diff.removed, \"changed\": diff.changed,\n1227:         \"unchanged\": diff.unchanged, \"possible_moves\": diff.moves,\n1228:         \"total_changes\": diff.total_changes,\n1229:         \"identical\": diff.total_changes == 0,\n1230:         \"report\": str(report) if report else None,\n1231:     }\n1232: \n1233: \n1234: # ───────────────────────────────────────────────────────────────\n1235: # 7. COMMAND-LINE INTERFACE\n1236: # ───────────────────────────────────────────────────────────────\n1237: \n1238: def cmd_capabilities(args: argparse.Namespace) -> int:\n1239:     \"\"\"Print the supported-format matrix and fidelity tiers.\n1240: \n1241:     Args:\n1242:         args: Parsed CLI arguments (honors --json).\n1243: \n1244:     Returns:\n1245:         Process exit code.\n1246:     \"\"\"\n1247:     pdf_kind, _ = _pdf_extractor()\n1248:     rows = [\n1249:         (\"text\", TIER_FULL, True, \"Plain text, logs, CSV.\"),\n1250:         (\"markdown\", TIER_FULL, True, \"Exact text + heading/section awareness.\"),\n1251:         (\"html\", TIER_TEXT, True, \"Visible text; styling/attributes not compared.\"),\n1252:         (\"docx\", TIER_TEXT, True, \"Paragraph/table text; formatting/tracked-changes not compared.\"),\n1253:         (\"pdf\", TIER_CONDITIONAL, pdf_kind is not None,\n1254:          f\"Text layer only; extractor: {pdf_kind or 'NONE — install pdftotext or pypdf'}.\"),\n1255:     ]\n1256:     if getattr(args, \"json\", False):\n1257:         payload = [{\"format\": f, \"tier\": t, \"available\": bool(a), \"notes\": n}\n1258:                    for f, t, a, n in rows]\n1259:         print(json.dumps({\"formats\": payload, \"pdf_extractor\": pdf_kind}, indent=2))\n1260:         return EXIT_OK\n1261:     print(f\"{GENERATOR} — format capabilities\\n\")\n1262:     print(f\"{'FORMAT':10} {'TIER':12} {'AVAILABLE':10} NOTES\")\n1263:     for f, t, a, n in rows:\n1264:         print(f\"{f:10} {t:12} {'yes' if a else 'NO':10} {n}\")\n1265:     print(\"\\nTiers: \" + \"; \".join(f\"{k}={v}\" for k, v in TIER_LABEL.items()))\n1266:     return EXIT_OK\n1267: \n1268: \n1269: def cmd_snapshot(args: argparse.Namespace) -> int:\n1270:     \"\"\"Capture a baseline snapshot of a file before it is edited.\n1271: \n1272:     Args:\n1273:         args: Parsed CLI arguments (file, --state-dir).\n1274: \n1275:     Returns:\n1276:         Process exit code.\n1277:     \"\"\"\n1278:     path = Path(args.file)\n1279:     state = _state_dir(args.state_dir)\n1280:     try:\n1281:         entry = capture_snapshot(path, state)\n1282:     except CapabilityError as exc:\n1283:         print(f\"error: {exc}\", file=sys.stderr)\n1284:         return EXIT_IO\n1285:     print(f\"Captured baseline for {path.name}\")\n1286:     print(f\"  sha256 {entry['sha256'][:16]}…  size {entry['size']}  at {entry['captured_at']}\")\n1287:     print(f\"  stored under {_snap_dir(state, path)}\")\n1288:     return EXIT_OK\n1289: \n1290: \n1291: def _compare_and_report(ext_a: Extraction, ext_b: Extraction, *, label_before: str,\n1292:                         label_after: str, view: str, out: Optional[str],\n1293:                         default_stem: str, as_json: bool, title: str) -> int:\n1294:     a_norm = normalize(ext_a.text)\n1295:     b_norm = normalize(ext_b.text)\n1296:     # Markdown documents get heading-aware sectioning: the diff is divided by the\n1297:     # document's own outline, so long reports stay scannable by structure.\n1298:     section_re = _MD_HEADING_RE if ext_b.fmt == \"markdown\" else None\n1299:     diff = diff_lines(a_norm, b_norm, section_re=section_re)\n1300:     report_html = render_report(diff, label_before=label_before, label_after=label_after,\n1301:                                 extraction_before=ext_a, extraction_after=ext_b,\n1302:                                 view=view, title=title)\n1303:     report_path = _write_report(report_html, out, default_stem)\n1304:     summary = _summary_dict(diff, report_path, ext_b.fmt, ext_b.tier)\n1305:     if as_json:\n1306:         print(json.dumps(summary, indent=2))\n1307:         return EXIT_OK\n1308:     print(f\"Compared {label_before} → {label_after} ({ext_b.fmt}, tier {ext_b.tier})\")\n1309:     print(f\"  +{diff.added}  −{diff.removed}  ~{diff.changed}  \"\n1310:           f\"moves≈{diff.moves}  unchanged {diff.unchanged}\")\n1311:     for w in dict.fromkeys(ext_a.warnings + ext_b.warnings):\n1312:         print(f\"  fidelity: {w}\")\n1313:     if diff.total_changes == 0:\n1314:         print(\"  identical after normalization.\")\n1315:     print(f\"  report: {report_path}\")\n1316:     return EXIT_OK\n1317: \n1318: \n1319: def cmd_compare(args: argparse.Namespace) -> int:\n1320:     \"\"\"Compare a file against its most recent stored baseline snapshot.\n1321: \n1322:     Args:\n1323:         args: Parsed CLI arguments (file, --report, --view, --state-dir, --json).\n1324: \n1325:     Returns:\n1326:         Process exit code.\n1327:     \"\"\"\n1328:     path = Path(args.file)\n1329:     state = _state_dir(args.state_dir)\n1330:     snap = latest_snapshot(path, state)\n1331:     if not snap:\n1332:         print(f\"error: no baseline snapshot for {path.name}. Run \"\n1333:               f\"`snapshot {path}` before the edit, or use `compare-pair`.\",\n1334:               file=sys.stderr)\n1335:         return EXIT_NO_BASELINE\n1336:     blob = _snap_dir(state, path) / snap[\"blob\"]\n1337:     try:\n1338:         ext_before = extract(blob, fmt=detect_format(path))\n1339:         ext_after = extract(path)\n1340:     except CapabilityError as exc:\n1341:         print(f\"error: {exc}\", file=sys.stderr)\n1342:         return EXIT_UNSUPPORTED\n1343:     return _compare_and_report(\n1344:         ext_before, ext_after,\n1345:         label_before=f\"baseline @ {snap['captured_at']}\", label_after=path.name,\n1346:         view=args.view, out=args.report, default_stem=path.stem,\n1347:         as_json=args.json, title=f\"Diff — {path.name}\")\n1348: \n1349: \n1350: def cmd_compare_pair(args: argparse.Namespace) -> int:\n1351:     \"\"\"Compare two explicit files with no stored state.\n1352: \n1353:     Args:\n1354:         args: Parsed CLI arguments (--before, --after, --report, --view,\n1355:             --label-before, --label-after, --json).\n1356: \n1357:     Returns:\n1358:         Process exit code.\n1359:     \"\"\"\n1360:     a = Path(args.before)\n1361:     b = Path(args.after)\n1362:     try:\n1363:         ext_a = extract(a)\n1364:         ext_b = extract(b)\n1365:     except CapabilityError as exc:\n1366:         print(f\"error: {exc}\", file=sys.stderr)\n1367:         return EXIT_UNSUPPORTED\n1368:     label_before = args.label_before or a.name\n1369:     label_after = args.label_after or b.name\n1370:     return _compare_and_report(\n1371:         ext_a, ext_b, label_before=label_before, label_after=label_after,\n1372:         view=args.view, out=args.report, default_stem=b.stem,\n1373:         as_json=args.json, title=f\"Diff — {label_before} → {label_after}\")\n1374: \n1375: \n1376: def cmd_status(args: argparse.Namespace) -> int:\n1377:     \"\"\"List stored snapshots, optionally filtered to one source file.\n1378: \n1379:     Args:\n1380:         args: Parsed CLI arguments (file, --state-dir, --json).\n1381: \n1382:     Returns:\n1383:         Process exit code.\n1384:     \"\"\"\n1385:     state = _state_dir(args.state_dir)\n1386:     root = state / \"snapshots\"\n1387:     if not root.exists():\n1388:         print(\"No snapshots stored.\")\n1389:         return EXIT_OK\n1390:     entries = []\n1391:     for sub in sorted(root.iterdir()):\n1392:         manifest = sub / \"manifest.json\"\n1393:         data = _load_manifest(manifest)\n1394:         snaps = data.get(\"snapshots\") or []\n1395:         if args.file and data.get(\"source_path\") != str(Path(args.file).resolve()):\n1396:             continue\n1397:         entries.append((data.get(\"source_path\", str(sub)), snaps))\n1398:     if args.json:\n1399:         print(json.dumps([{\"source_path\": p, \"count\": len(s),\n1400:                            \"latest\": s[-1][\"captured_at\"] if s else None}\n1401:                           for p, s in entries], indent=2))\n1402:         return EXIT_OK\n1403:     if not entries:\n1404:         print(\"No matching snapshots.\")\n1405:         return EXIT_OK\n1406:     for src, snaps in entries:\n1407:         print(f\"{src}  —  {len(snaps)} snapshot(s)\")\n1408:         for s in snaps[-5:]:\n1409:             print(f\"    {s['captured_at']}  {s['sha256'][:12]}  {s['size']} bytes\")\n1410:     return EXIT_OK\n1411: \n1412: \n1413: def cmd_cleanup(args: argparse.Namespace) -> int:\n1414:     \"\"\"Remove stored snapshots, optionally by file or age, with a dry-run mode.\n1415: \n1416:     Args:\n1417:         args: Parsed CLI arguments (--file, --older-than, --state-dir, --dry-run).\n1418: \n1419:     Returns:\n1420:         Process exit code.\n1421:     \"\"\"\n1422:     state = _state_dir(args.state_dir)\n1423:     root = state / \"snapshots\"\n1424:     if not root.exists():\n1425:         print(\"Nothing to clean.\")\n1426:         return EXIT_OK\n1427:     cutoff = None\n1428:     if args.older_than is not None:\n1429:         cutoff = _dt.datetime.now(_dt.timezone.utc) - _dt.timedelta(days=args.older_than)\n1430:     removed = 0\n1431:     for sub in sorted(root.iterdir()):\n1432:         manifest = sub / \"manifest.json\"\n1433:         data = _load_manifest(manifest)\n1434:         if args.file and data.get(\"source_path\") != str(Path(args.file).resolve()):\n1435:             continue\n1436:         kept = []\n1437:         for s in data.get(\"snapshots\") or []:\n1438:             drop = True\n1439:             if cutoff is not None:\n1440:                 captured = _dt.datetime.fromisoformat(s[\"captured_at\"])\n1441:                 drop = captured < cutoff\n1442:             if drop:\n1443:                 removed += 1\n1444:                 blob = sub / s[\"blob\"]\n1445:                 print(f\"{'[dry-run] would remove' if args.dry_run else 'removed'} \"\n1446:                       f\"{blob}\")\n1447:                 if not args.dry_run and blob.exists():\n1448:                     blob.unlink()\n1449:             else:\n1450:                 kept.append(s)\n1451:         if not args.dry_run:\n1452:             data[\"snapshots\"] = kept\n1453:             _write_json(manifest, data)\n1454:     print(f\"{'Would remove' if args.dry_run else 'Removed'} {removed} snapshot(s).\")\n1455:     return EXIT_OK\n1456: \n1457: \n1458: # --------------------------------------------------------------------------- #\n1459: # Argument parsing\n1460: # --------------------------------------------------------------------------- #\n1461: \n1462: def build_parser() -> argparse.ArgumentParser:\n1463:     \"\"\"Build the argparse parser with every subcommand and its options.\n1464: \n1465:     Returns:\n1466:         The configured ArgumentParser (each subcommand sets its handler via\n1467:         set_defaults(func=...)).\n1468:     \"\"\"\n1469:     p = argparse.ArgumentParser(prog=\"create_diff.py\", description=__doc__.splitlines()[0])\n1470:     sub = p.add_subparsers(dest=\"command\", required=True)\n1471: \n1472:     sp = sub.add_parser(\"capabilities\", help=\"list supported formats and fidelity tiers\")\n1473:     sp.add_argument(\"--json\", action=\"store_true\")\n1474:     sp.set_defaults(func=cmd_capabilities)\n\n(Showing lines 1160-1474 of 1535. Use offset=1475 to continue.)\n</content>","metadata":{"preview":"    blob = snap_dir / f\"{ts}-{digest[:12]}{path.suffix}\"\n    _atomic_copy(path, blob)\n    entry = {\n        \"captured_at\": _now_iso(),\n        \"source_path\": str(path.resolve()),\n        \"source_name\": path.name,\n        \"sha256\": digest,\n        \"size\": path.stat().st_size,\n        \"blob\": blob.name,\n    }\n    manifest = snap_dir / \"manifest.json\"\n    data = _load_manifest(manifest)\n    data[\"source_path\"] = str(path.resolve())\n    data.setdefault(\"snapshots\", []).append(entry)\n    _write_json(manifest, data)\n    return entry\n\n\ndef _load_manifest(manifest: Path) -> dict:\n    if manifest.exists():","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/scripts/create_diff.py","text":"    blob = snap_dir / f\"{ts}-{digest[:12]}{path.suffix}\"\n    _atomic_copy(path, blob)\n    entry = {\n        \"captured_at\": _now_iso(),\n        \"source_path\": str(path.resolve()),\n        \"source_name\": path.name,\n        \"sha256\": digest,\n        \"size\": path.stat().st_size,\n        \"blob\": blob.name,\n    }\n    manifest = snap_dir / \"manifest.json\"\n    data = _load_manifest(manifest)\n    data[\"source_path\"] = str(path.resolve())\n    data.setdefault(\"snapshots\", []).append(entry)\n    _write_json(manifest, data)\n    return entry\n\n\ndef _load_manifest(manifest: Path) -> dict:\n    if manifest.exists():\n        try:\n            return json.loads(manifest.read_text(encoding=\"utf-8\"))\n        except json.JSONDecodeError:\n            return {}\n    return {}\n\n\ndef _write_json(path: Path, data: dict) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    fd, tmp = tempfile.mkstemp(dir=str(path.parent))\n    with os.fdopen(fd, \"w\", encoding=\"utf-8\") as fh:\n        json.dump(data, fh, indent=2, sort_keys=True)\n        fh.write(\"\\n\")\n    os.replace(tmp, path)\n\n\ndef latest_snapshot(path: Path, state: Path) -> Optional[dict]:\n    \"\"\"Return the most recent snapshot manifest entry for a file, if any.\n\n    Args:\n        path: File whose baseline history is queried.\n        state: State directory root holding the snapshot store.\n\n    Returns:\n        The newest manifest entry, or None when no snapshot exists.\n    \"\"\"\n    manifest = _snap_dir(state, path) / \"manifest.json\"\n    data = _load_manifest(manifest)\n    snaps = data.get(\"snapshots\") or []\n    return snaps[-1] if snaps else None\n\n\n# --------------------------------------------------------------------------- #\n# Commands\n# --------------------------------------------------------------------------- #\n\ndef _write_report(html_str: str, out: Optional[str], default_stem: str) -> Path:\n    target = Path(out) if out else Path.cwd() / f\"{default_stem}.diff.html\"\n    target.parent.mkdir(parents=True, exist_ok=True)\n    target.write_text(html_str, encoding=\"utf-8\")\n    return target\n\n\ndef _summary_dict(diff: DiffResult, report: Optional[Path], fmt: str, tier: str) -> dict:\n    return {\n        \"format\": fmt, \"fidelity_tier\": tier,\n        \"added\": diff.added, \"removed\": diff.removed, \"changed\": diff.changed,\n        \"unchanged\": diff.unchanged, \"possible_moves\": diff.moves,\n        \"total_changes\": diff.total_changes,\n        \"identical\": diff.total_changes == 0,\n        \"report\": str(report) if report else None,\n    }\n\n\n# ───────────────────────────────────────────────────────────────\n# 7. COMMAND-LINE INTERFACE\n# ───────────────────────────────────────────────────────────────\n\ndef cmd_capabilities(args: argparse.Namespace) -> int:\n    \"\"\"Print the supported-format matrix and fidelity tiers.\n\n    Args:\n        args: Parsed CLI arguments (honors --json).\n\n    Returns:\n        Process exit code.\n    \"\"\"\n    pdf_kind, _ = _pdf_extractor()\n    rows = [\n        (\"text\", TIER_FULL, True, \"Plain text, logs, CSV.\"),\n        (\"markdown\", TIER_FULL, True, \"Exact text + heading/section awareness.\"),\n        (\"html\", TIER_TEXT, True, \"Visible text; styling/attributes not compared.\"),\n        (\"docx\", TIER_TEXT, True, \"Paragraph/table text; formatting/tracked-changes not compared.\"),\n        (\"pdf\", TIER_CONDITIONAL, pdf_kind is not None,\n         f\"Text layer only; extractor: {pdf_kind or 'NONE — install pdftotext or pypdf'}.\"),\n    ]\n    if getattr(args, \"json\", False):\n        payload = [{\"format\": f, \"tier\": t, \"available\": bool(a), \"notes\": n}\n                   for f, t, a, n in rows]\n        print(json.dumps({\"formats\": payload, \"pdf_extractor\": pdf_kind}, indent=2))\n        return EXIT_OK\n    print(f\"{GENERATOR} — format capabilities\\n\")\n    print(f\"{'FORMAT':10} {'TIER':12} {'AVAILABLE':10} NOTES\")\n    for f, t, a, n in rows:\n        print(f\"{f:10} {t:12} {'yes' if a else 'NO':10} {n}\")\n    print(\"\\nTiers: \" + \"; \".join(f\"{k}={v}\" for k, v in TIER_LABEL.items()))\n    return EXIT_OK\n\n\ndef cmd_snapshot(args: argparse.Namespace) -> int:\n    \"\"\"Capture a baseline snapshot of a file before it is edited.\n\n    Args:\n        args: Parsed CLI arguments (file, --state-dir).\n\n    Returns:\n        Process exit code.\n    \"\"\"\n    path = Path(args.file)\n    state = _state_dir(args.state_dir)\n    try:\n        entry = capture_snapshot(path, state)\n    except CapabilityError as exc:\n        print(f\"error: {exc}\", file=sys.stderr)\n        return EXIT_IO\n    print(f\"Captured baseline for {path.name}\")\n    print(f\"  sha256 {entry['sha256'][:16]}…  size {entry['size']}  at {entry['captured_at']}\")\n    print(f\"  stored under {_snap_dir(state, path)}\")\n    return EXIT_OK\n\n\ndef _compare_and_report(ext_a: Extraction, ext_b: Extraction, *, label_before: str,\n                        label_after: str, view: str, out: Optional[str],\n                        default_stem: str, as_json: bool, title: str) -> int:\n    a_norm = normalize(ext_a.text)\n    b_norm = normalize(ext_b.text)\n    # Markdown documents get heading-aware sectioning: the diff is divided by the\n    # document's own outline, so long reports stay scannable by structure.\n    section_re = _MD_HEADING_RE if ext_b.fmt == \"markdown\" else None\n    diff = diff_lines(a_norm, b_norm, section_re=section_re)\n    report_html = render_report(diff, label_before=label_before, label_after=label_after,\n                                extraction_before=ext_a, extraction_after=ext_b,\n                                view=view, title=title)\n    report_path = _write_report(report_html, out, default_stem)\n    summary = _summary_dict(diff, report_path, ext_b.fmt, ext_b.tier)\n    if as_json:\n        print(json.dumps(summary, indent=2))\n        return EXIT_OK\n    print(f\"Compared {label_before} → {label_after} ({ext_b.fmt}, tier {ext_b.tier})\")\n    print(f\"  +{diff.added}  −{diff.removed}  ~{diff.changed}  \"\n          f\"moves≈{diff.moves}  unchanged {diff.unchanged}\")\n    for w in dict.fromkeys(ext_a.warnings + ext_b.warnings):\n        print(f\"  fidelity: {w}\")\n    if diff.total_changes == 0:\n        print(\"  identical after normalization.\")\n    print(f\"  report: {report_path}\")\n    return EXIT_OK\n\n\ndef cmd_compare(args: argparse.Namespace) -> int:\n    \"\"\"Compare a file against its most recent stored baseline snapshot.\n\n    Args:\n        args: Parsed CLI arguments (file, --report, --view, --state-dir, --json).\n\n    Returns:\n        Process exit code.\n    \"\"\"\n    path = Path(args.file)\n    state = _state_dir(args.state_dir)\n    snap = latest_snapshot(path, state)\n    if not snap:\n        print(f\"error: no baseline snapshot for {path.name}. Run \"\n              f\"`snapshot {path}` before the edit, or use `compare-pair`.\",\n              file=sys.stderr)\n        return EXIT_NO_BASELINE\n    blob = _snap_dir(state, path) / snap[\"blob\"]\n    try:\n        ext_before = extract(blob, fmt=detect_format(path))\n        ext_after = extract(path)\n    except CapabilityError as exc:\n        print(f\"error: {exc}\", file=sys.stderr)\n        return EXIT_UNSUPPORTED\n    return _compare_and_report(\n        ext_before, ext_after,\n        label_before=f\"baseline @ {snap['captured_at']}\", label_after=path.name,\n        view=args.view, out=args.report, default_stem=path.stem,\n        as_json=args.json, title=f\"Diff — {path.name}\")\n\n\ndef cmd_compare_pair(args: argparse.Namespace) -> int:\n    \"\"\"Compare two explicit files with no stored state.\n\n    Args:\n        args: Parsed CLI arguments (--before, --after, --report, --view,\n            --label-before, --label-after, --json).\n\n    Returns:\n        Process exit code.\n    \"\"\"\n    a = Path(args.before)\n    b = Path(args.after)\n    try:\n        ext_a = extract(a)\n        ext_b = extract(b)\n    except CapabilityError as exc:\n        print(f\"error: {exc}\", file=sys.stderr)\n        return EXIT_UNSUPPORTED\n    label_before = args.label_before or a.name\n    label_after = args.label_after or b.name\n    return _compare_and_report(\n        ext_a, ext_b, label_before=label_before, label_after=label_after,\n        view=args.view, out=args.report, default_stem=b.stem,\n        as_json=args.json, title=f\"Diff — {label_before} → {label_after}\")\n\n\ndef cmd_status(args: argparse.Namespace) -> int:\n    \"\"\"List stored snapshots, optionally filtered to one source file.\n\n    Args:\n        args: Parsed CLI arguments (file, --state-dir, --json).\n\n    Returns:\n        Process exit code.\n    \"\"\"\n    state = _state_dir(args.state_dir)\n    root = state / \"snapshots\"\n    if not root.exists():\n        print(\"No snapshots stored.\")\n        return EXIT_OK\n    entries = []\n    for sub in sorted(root.iterdir()):\n        manifest = sub / \"manifest.json\"\n        data = _load_manifest(manifest)\n        snaps = data.get(\"snapshots\") or []\n        if args.file and data.get(\"source_path\") != str(Path(args.file).resolve()):\n            continue\n        entries.append((data.get(\"source_path\", str(sub)), snaps))\n    if args.json:\n        print(json.dumps([{\"source_path\": p, \"count\": len(s),\n                           \"latest\": s[-1][\"captured_at\"] if s else None}\n                          for p, s in entries], indent=2))\n        return EXIT_OK\n    if not entries:\n        print(\"No matching snapshots.\")\n        return EXIT_OK\n    for src, snaps in entries:\n        print(f\"{src}  —  {len(snaps)} snapshot(s)\")\n        for s in snaps[-5:]:\n            print(f\"    {s['captured_at']}  {s['sha256'][:12]}  {s['size']} bytes\")\n    return EXIT_OK\n\n\ndef cmd_cleanup(args: argparse.Namespace) -> int:\n    \"\"\"Remove stored snapshots, optionally by file or age, with a dry-run mode.\n\n    Args:\n        args: Parsed CLI arguments (--file, --older-than, --state-dir, --dry-run).\n\n    Returns:\n        Process exit code.\n    \"\"\"\n    state = _state_dir(args.state_dir)\n    root = state / \"snapshots\"\n    if not root.exists():\n        print(\"Nothing to clean.\")\n        return EXIT_OK\n    cutoff = None\n    if args.older_than is not None:\n        cutoff = _dt.datetime.now(_dt.timezone.utc) - _dt.timedelta(days=args.older_than)\n    removed = 0\n    for sub in sorted(root.iterdir()):\n        manifest = sub / \"manifest.json\"\n        data = _load_manifest(manifest)\n        if args.file and data.get(\"source_path\") != str(Path(args.file).resolve()):\n            continue\n        kept = []\n        for s in data.get(\"snapshots\") or []:\n            drop = True\n            if cutoff is not None:\n                captured = _dt.datetime.fromisoformat(s[\"captured_at\"])\n                drop = captured < cutoff\n            if drop:\n                removed += 1\n                blob = sub / s[\"blob\"]\n                print(f\"{'[dry-run] would remove' if args.dry_run else 'removed'} \"\n                      f\"{blob}\")\n                if not args.dry_run and blob.exists():\n                    blob.unlink()\n            else:\n                kept.append(s)\n        if not args.dry_run:\n            data[\"snapshots\"] = kept\n            _write_json(manifest, data)\n    print(f\"{'Would remove' if args.dry_run else 'Removed'} {removed} snapshot(s).\")\n    return EXIT_OK\n\n\n# --------------------------------------------------------------------------- #\n# Argument parsing\n# --------------------------------------------------------------------------- #\n\ndef build_parser() -> argparse.ArgumentParser:\n    \"\"\"Build the argparse parser with every subcommand and its options.\n\n    Returns:\n        The configured ArgumentParser (each subcommand sets its handler via\n        set_defaults(func=...)).\n    \"\"\"\n    p = argparse.ArgumentParser(prog=\"create_diff.py\", description=__doc__.splitlines()[0])\n    sub = p.add_subparsers(dest=\"command\", required=True)\n\n    sp = sub.add_parser(\"capabilities\", help=\"list supported formats and fidelity tiers\")\n    sp.add_argument(\"--json\", action=\"store_true\")\n    sp.set_defaults(func=cmd_capabilities)","lineStart":1160,"lineEnd":1474,"totalLines":1535,"truncated":true}},"title":".opencode/skills/sk-doc/create-diff/scripts/create_diff.py","time":{"start":1784210626288,"end":1784210626302}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a248191977ff89d108d963d"}},"id":"prt_f6b3d96b9001QpmpEj8AQMzXVo","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626311,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_J95Nsq6LffgDmoyxNof0X1ec","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/scripts/test_create_diff.py","offset":170,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/scripts/test_create_diff.py</path>\n<type>file</type>\n<content>\n170: \n171:     def test_empty_to_empty_is_no_change(self):\n172:         d = _diff(\"\", \"\")\n173:         self.assertEqual(d.total_changes, 0)\n174:         self.assertEqual(d.rows, [])\n175: \n176:     def test_trailing_newline_only_is_insignificant(self):\n177:         self.assertEqual(_diff(\"x\", \"x\\n\").total_changes, 0)\n178: \n179:     def test_interior_blank_line_preserved(self):\n180:         d = _diff(\"a\", \"a\\n\\n\")\n181:         self.assertEqual(d.added, 1)\n182: \n183: \n184: class SafetyValidatorAllowlist(unittest.TestCase):\n185:     \"\"\"One hazard per case: the clean baseline passes; each disallowed construct is\n186:     rejected. The gate is an allowlist for the renderer's exact dialect.\"\"\"\n187: \n188:     def test_clean_baseline_passes(self):\n189:         self.assertEqual(_validate_html(_doc()), [])\n190: \n191:     def _assert_flags(self, html: str, needle: str):\n192:         problems = _validate_html(html)\n193:         joined = \" | \".join(problems).lower()\n194:         self.assertIn(needle.lower(), joined, f\"expected {needle!r} in {problems!r}\")\n195: \n196:     def test_meta_refresh_rejected(self):\n197:         self._assert_flags(_doc(head='<meta http-equiv=\"refresh\" content=\"0;url=x\">'),\n198:                            \"http-equiv 'refresh'\")\n199: \n200:     def test_unknown_http_equiv_rejected(self):\n201:         self._assert_flags(_doc(head='<meta http-equiv=\"x-ua-compatible\" content=\"IE=edge\">'),\n202:                            \"http-equiv 'x-ua-compatible'\")\n203: \n204:     def test_duplicate_attribute_rejected(self):\n205:         html = ('<!doctype html><html lang=\"en\"><head>'\n206:                 f'<meta http-equiv=\"Content-Security-Policy\" content=\"{_CANON_CSP}\" '\n207:                 'content=\"default-src *\"><title>t</title></head><body></body></html>')\n208:         self._assert_flags(html, \"duplicate attribute 'content'\")\n209: \n210:     def test_non_ascii_csp_whitespace_rejected(self):\n211:         # A U+00A0 no-break space smuggled into the CSP tokenizes as one directive\n212:         # for a naive ASCII split but differently in the browser; reject it outright.\n213:         smuggled = _CANON_CSP.replace(\"img-src data:\", \"img-src\\u00a0data:\")\n214:         self._assert_flags(_doc(csp=smuggled), \"non-ascii or control\")\n215: \n216:     def test_csp_after_body_rejected(self):\n217:         html = ('<!doctype html><html lang=\"en\"><head><title>t</title></head><body>'\n218:                 f'<meta http-equiv=\"Content-Security-Policy\" content=\"{_CANON_CSP}\">'\n219:                 '<p>x</p></body></html>')\n220:         self._assert_flags(html, \"before <body>\")\n221: \n222:     def test_missing_csp_rejected(self):\n223:         self._assert_flags(_doc(csp=None), \"missing content-security-policy\")\n224: \n225:     def test_multiple_csp_rejected(self):\n226:         self._assert_flags(_doc(head=f'<meta http-equiv=\"Content-Security-Policy\" content=\"{_CANON_CSP}\">'),\n227:                            \"multiple content-security-policy\")\n228: \n229:     def test_weakened_csp_rejected(self):\n230:         weak = _CANON_CSP.replace(\"default-src 'none'\", \"default-src *\")\n231:         self._assert_flags(_doc(csp=weak), \"does not match the required policy\")\n232: \n233:     def test_disallowed_element_script(self):\n234:         self._assert_flags(_doc(body=\"<script>alert(1)</script>\"), \"disallowed element <script>\")\n235: \n236:     def test_disallowed_element_iframe(self):\n237:         self._assert_flags(_doc(body='<iframe srcdoc=\"&lt;b&gt;\"></iframe>'),\n238:                            \"disallowed element <iframe>\")\n239: \n240:     def test_disallowed_attr_event_handler(self):\n241:         self._assert_flags(_doc(body='<p onclick=\"x()\">x</p>'), \"disallowed attribute 'onclick'\")\n242: \n243:     def test_disallowed_attr_style(self):\n244:         self._assert_flags(_doc(body='<p style=\"color:red\">x</p>'), \"disallowed attribute 'style'\")\n245: \n246:     def test_disallowed_attr_srcdoc(self):\n247:         # srcdoc is rejected as a disallowed attribute even before the tag check,\n248:         # so a separately-parsed inline document can never enter.\n249:         self._assert_flags(_doc(body='<div srcdoc=\"x\">y</div>'), \"disallowed attribute 'srcdoc'\")\n250: \n251:     def test_external_href_rejected(self):\n252:         self._assert_flags(_doc(body='<a href=\"https://evil.example\">x</a>'), \"external reference\")\n253: \n254:     def test_data_uri_href_rejected(self):\n255:         self._assert_flags(_doc(body='<a href=\"data:text/html,x\">x</a>'), \"external reference\")\n256: \n257:     def test_javascript_href_rejected(self):\n258:         self._assert_flags(_doc(body='<a href=\"javascript:alert(1)\">x</a>'), \"external reference\")\n259: \n260:     def test_css_import_rejected(self):\n261:         self._assert_flags(_doc(head='<style>@import url(x)</style>'), \"@import\")\n262: \n263:     def test_css_url_rejected(self):\n264:         self._assert_flags(_doc(head='<style>.a{background:url(x)}</style>'), \"url()\")\n265: \n266:     def test_escaped_hostile_text_is_inert(self):\n267:         with tempfile.TemporaryDirectory() as d:\n268:             html = _report(Path(d), \"a\\n<img src=x onerror=alert(9)>\",\n269:                            \"b\\n<script>alert(1)</script>\", view=\"unified\")\n270:             p = _write(Path(d), \"r.html\", html)\n271:             self.assertEqual(vr.validate(p), [])           # no live hazard\n272:             self.assertNotIn(\"<script>alert\", html)         # source stayed escaped\n273:             self.assertIn(\"&lt;script&gt;\", html)\n274: \n275: \n276: class ReportConformance(unittest.TestCase):\n277:     def test_four_canonical_reports_pass_allowlist(self):\n278:         fixtures = [(\"one\\ntwo\\nthree\", \"one\\nTWO\\nthree\"),\n279:                     (\"alpha\\nbeta\", \"alpha\\nbeta\\ngamma\")]\n280:         with tempfile.TemporaryDirectory() as d:\n281:             count = 0\n282:             for a, b in fixtures:\n283:                 for view in (\"unified\", \"side-by-side\"):\n284:                     html = _report(Path(d), a, b, view=view)\n285:                     p = _write(Path(d), f\"r{count}.html\", html)\n286:                     self.assertEqual(vr.validate(p), [],\n287:                                      f\"canonical report {count} (view={view}) must pass\")\n288:                     count += 1\n289:             self.assertEqual(count, 4)\n290: \n291: \n292: class ReportInvariants(unittest.TestCase):\n293:     def test_zero_js_and_exact_csp(self):\n294:         with tempfile.TemporaryDirectory() as d:\n295:             html = _report(Path(d), \"a\", \"b\")\n296:         self.assertNotIn(\"<script\", html)\n297:         self.assertIn(_CANON_CSP, html)\n298: \n299:     def test_byte_reproducible(self):\n300:         os.environ[\"SOURCE_DATE_EPOCH\"] = \"1700000000\"\n301:         try:\n302:             with tempfile.TemporaryDirectory() as d:\n303:                 first = _report(Path(d), \"a\\nb\\nc\", \"a\\nB\\nc\")\n304:                 second = _report(Path(d), \"a\\nb\\nc\", \"a\\nB\\nc\")\n305:             self.assertEqual(first, second)\n306:         finally:\n307:             os.environ.pop(\"SOURCE_DATE_EPOCH\", None)\n308: \n309:     def test_side_by_side_pairs_change_into_six_cells(self):\n310:         with tempfile.TemporaryDirectory() as d:\n311:             html = _report(Path(d), \"keep\\nold\\nkeep\", \"keep\\nnew\\nkeep\", view=\"side-by-side\")\n312:         rows = re.findall(r'<tr class=\"change\">(.*?)</tr>', html)\n313:         self.assertEqual(len(rows), 1)\n314:         self.assertEqual(len(re.findall(r\"<td\", rows[0])), 6)\n315: \n316:     def test_side_by_side_scroll_is_scoped_and_keyboard_operable(self):\n317:         with tempfile.TemporaryDirectory() as d:\n318:             html = _report(Path(d), \"a\", \"b\", view=\"side-by-side\")\n319:         self.assertIn('.sxs{min-width:', html)                       # actually overflows → scrolls\n320:         self.assertIn('role=\"region\"', html)\n321:         self.assertIn('aria-label=\"Side-by-side differences\"', html)\n322:         self.assertIn('tabindex=\"0\"', html)\n323:         self.assertIn('.diff-scroll:focus-visible', html)\n324: \n325:     def test_fluid_type_layer_is_container_keyed(self):\n326:         # Type and section rhythm flex to the content column (not the viewport), so\n327:         # the report stays readable across the range of IDE preview-pane widths.\n328:         with tempfile.TemporaryDirectory() as d:\n329:             html = _report(Path(d), \"a\", \"b\")\n330:         self.assertIn(\"container-type:inline-size\", html)\n331:         self.assertIn(\"@container report\", html)\n332:         self.assertIn(\"cqi\", html)\n333: \n334:     def test_page_gutter_has_two_rem_minimum(self):\n335:         # The report content must never sit flush against the pane edge; a >=2rem\n336:         # page gutter keeps the diff readable in a narrow docked IDE preview.\n337:         with tempfile.TemporaryDirectory() as d:\n338:             html = _report(Path(d), \"a\", \"b\")\n339:         self.assertRegex(html, r\"main\\{[^}]*padding:2rem\\}\")\n340: \n341:     def test_markdown_headings_divide_sections(self):\n342:         # Markdown diffs are navigable by document structure: headings hidden in\n343:         # collapsed runs surface as visible section bands, and hunk headers name\n344:         # the section they fall in — line numbers alone can't say WHERE you are.\n345:         body = \"\\n\".join(f\"filler {i}\" for i in range(12))\n346:         a = f\"# Title\\nintro\\n\\n## Alpha\\n{body}\\n\\n## Beta\\nold line\\n\"\n347:         b = f\"# Title\\nintro\\n\\n## Alpha\\n{body}\\n\\n## Beta\\nnew line\\n\"\n348:         with tempfile.TemporaryDirectory() as d:\n349:             fa = _write(Path(d), \"a.md\", a)\n\n(Showing lines 170-349 of 416. Use offset=350 to continue.)\n</content>","metadata":{"preview":"\n    def test_empty_to_empty_is_no_change(self):\n        d = _diff(\"\", \"\")\n        self.assertEqual(d.total_changes, 0)\n        self.assertEqual(d.rows, [])\n\n    def test_trailing_newline_only_is_insignificant(self):\n        self.assertEqual(_diff(\"x\", \"x\\n\").total_changes, 0)\n\n    def test_interior_blank_line_preserved(self):\n        d = _diff(\"a\", \"a\\n\\n\")\n        self.assertEqual(d.added, 1)\n\n\nclass SafetyValidatorAllowlist(unittest.TestCase):\n    \"\"\"One hazard per case: the clean baseline passes; each disallowed construct is\n    rejected. The gate is an allowlist for the renderer's exact dialect.\"\"\"\n\n    def test_clean_baseline_passes(self):\n        self.assertEqual(_validate_html(_doc()), [])","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/scripts/test_create_diff.py","text":"\n    def test_empty_to_empty_is_no_change(self):\n        d = _diff(\"\", \"\")\n        self.assertEqual(d.total_changes, 0)\n        self.assertEqual(d.rows, [])\n\n    def test_trailing_newline_only_is_insignificant(self):\n        self.assertEqual(_diff(\"x\", \"x\\n\").total_changes, 0)\n\n    def test_interior_blank_line_preserved(self):\n        d = _diff(\"a\", \"a\\n\\n\")\n        self.assertEqual(d.added, 1)\n\n\nclass SafetyValidatorAllowlist(unittest.TestCase):\n    \"\"\"One hazard per case: the clean baseline passes; each disallowed construct is\n    rejected. The gate is an allowlist for the renderer's exact dialect.\"\"\"\n\n    def test_clean_baseline_passes(self):\n        self.assertEqual(_validate_html(_doc()), [])\n\n    def _assert_flags(self, html: str, needle: str):\n        problems = _validate_html(html)\n        joined = \" | \".join(problems).lower()\n        self.assertIn(needle.lower(), joined, f\"expected {needle!r} in {problems!r}\")\n\n    def test_meta_refresh_rejected(self):\n        self._assert_flags(_doc(head='<meta http-equiv=\"refresh\" content=\"0;url=x\">'),\n                           \"http-equiv 'refresh'\")\n\n    def test_unknown_http_equiv_rejected(self):\n        self._assert_flags(_doc(head='<meta http-equiv=\"x-ua-compatible\" content=\"IE=edge\">'),\n                           \"http-equiv 'x-ua-compatible'\")\n\n    def test_duplicate_attribute_rejected(self):\n        html = ('<!doctype html><html lang=\"en\"><head>'\n                f'<meta http-equiv=\"Content-Security-Policy\" content=\"{_CANON_CSP}\" '\n                'content=\"default-src *\"><title>t</title></head><body></body></html>')\n        self._assert_flags(html, \"duplicate attribute 'content'\")\n\n    def test_non_ascii_csp_whitespace_rejected(self):\n        # A U+00A0 no-break space smuggled into the CSP tokenizes as one directive\n        # for a naive ASCII split but differently in the browser; reject it outright.\n        smuggled = _CANON_CSP.replace(\"img-src data:\", \"img-src\\u00a0data:\")\n        self._assert_flags(_doc(csp=smuggled), \"non-ascii or control\")\n\n    def test_csp_after_body_rejected(self):\n        html = ('<!doctype html><html lang=\"en\"><head><title>t</title></head><body>'\n                f'<meta http-equiv=\"Content-Security-Policy\" content=\"{_CANON_CSP}\">'\n                '<p>x</p></body></html>')\n        self._assert_flags(html, \"before <body>\")\n\n    def test_missing_csp_rejected(self):\n        self._assert_flags(_doc(csp=None), \"missing content-security-policy\")\n\n    def test_multiple_csp_rejected(self):\n        self._assert_flags(_doc(head=f'<meta http-equiv=\"Content-Security-Policy\" content=\"{_CANON_CSP}\">'),\n                           \"multiple content-security-policy\")\n\n    def test_weakened_csp_rejected(self):\n        weak = _CANON_CSP.replace(\"default-src 'none'\", \"default-src *\")\n        self._assert_flags(_doc(csp=weak), \"does not match the required policy\")\n\n    def test_disallowed_element_script(self):\n        self._assert_flags(_doc(body=\"<script>alert(1)</script>\"), \"disallowed element <script>\")\n\n    def test_disallowed_element_iframe(self):\n        self._assert_flags(_doc(body='<iframe srcdoc=\"&lt;b&gt;\"></iframe>'),\n                           \"disallowed element <iframe>\")\n\n    def test_disallowed_attr_event_handler(self):\n        self._assert_flags(_doc(body='<p onclick=\"x()\">x</p>'), \"disallowed attribute 'onclick'\")\n\n    def test_disallowed_attr_style(self):\n        self._assert_flags(_doc(body='<p style=\"color:red\">x</p>'), \"disallowed attribute 'style'\")\n\n    def test_disallowed_attr_srcdoc(self):\n        # srcdoc is rejected as a disallowed attribute even before the tag check,\n        # so a separately-parsed inline document can never enter.\n        self._assert_flags(_doc(body='<div srcdoc=\"x\">y</div>'), \"disallowed attribute 'srcdoc'\")\n\n    def test_external_href_rejected(self):\n        self._assert_flags(_doc(body='<a href=\"https://evil.example\">x</a>'), \"external reference\")\n\n    def test_data_uri_href_rejected(self):\n        self._assert_flags(_doc(body='<a href=\"data:text/html,x\">x</a>'), \"external reference\")\n\n    def test_javascript_href_rejected(self):\n        self._assert_flags(_doc(body='<a href=\"javascript:alert(1)\">x</a>'), \"external reference\")\n\n    def test_css_import_rejected(self):\n        self._assert_flags(_doc(head='<style>@import url(x)</style>'), \"@import\")\n\n    def test_css_url_rejected(self):\n        self._assert_flags(_doc(head='<style>.a{background:url(x)}</style>'), \"url()\")\n\n    def test_escaped_hostile_text_is_inert(self):\n        with tempfile.TemporaryDirectory() as d:\n            html = _report(Path(d), \"a\\n<img src=x onerror=alert(9)>\",\n                           \"b\\n<script>alert(1)</script>\", view=\"unified\")\n            p = _write(Path(d), \"r.html\", html)\n            self.assertEqual(vr.validate(p), [])           # no live hazard\n            self.assertNotIn(\"<script>alert\", html)         # source stayed escaped\n            self.assertIn(\"&lt;script&gt;\", html)\n\n\nclass ReportConformance(unittest.TestCase):\n    def test_four_canonical_reports_pass_allowlist(self):\n        fixtures = [(\"one\\ntwo\\nthree\", \"one\\nTWO\\nthree\"),\n                    (\"alpha\\nbeta\", \"alpha\\nbeta\\ngamma\")]\n        with tempfile.TemporaryDirectory() as d:\n            count = 0\n            for a, b in fixtures:\n                for view in (\"unified\", \"side-by-side\"):\n                    html = _report(Path(d), a, b, view=view)\n                    p = _write(Path(d), f\"r{count}.html\", html)\n                    self.assertEqual(vr.validate(p), [],\n                                     f\"canonical report {count} (view={view}) must pass\")\n                    count += 1\n            self.assertEqual(count, 4)\n\n\nclass ReportInvariants(unittest.TestCase):\n    def test_zero_js_and_exact_csp(self):\n        with tempfile.TemporaryDirectory() as d:\n            html = _report(Path(d), \"a\", \"b\")\n        self.assertNotIn(\"<script\", html)\n        self.assertIn(_CANON_CSP, html)\n\n    def test_byte_reproducible(self):\n        os.environ[\"SOURCE_DATE_EPOCH\"] = \"1700000000\"\n        try:\n            with tempfile.TemporaryDirectory() as d:\n                first = _report(Path(d), \"a\\nb\\nc\", \"a\\nB\\nc\")\n                second = _report(Path(d), \"a\\nb\\nc\", \"a\\nB\\nc\")\n            self.assertEqual(first, second)\n        finally:\n            os.environ.pop(\"SOURCE_DATE_EPOCH\", None)\n\n    def test_side_by_side_pairs_change_into_six_cells(self):\n        with tempfile.TemporaryDirectory() as d:\n            html = _report(Path(d), \"keep\\nold\\nkeep\", \"keep\\nnew\\nkeep\", view=\"side-by-side\")\n        rows = re.findall(r'<tr class=\"change\">(.*?)</tr>', html)\n        self.assertEqual(len(rows), 1)\n        self.assertEqual(len(re.findall(r\"<td\", rows[0])), 6)\n\n    def test_side_by_side_scroll_is_scoped_and_keyboard_operable(self):\n        with tempfile.TemporaryDirectory() as d:\n            html = _report(Path(d), \"a\", \"b\", view=\"side-by-side\")\n        self.assertIn('.sxs{min-width:', html)                       # actually overflows → scrolls\n        self.assertIn('role=\"region\"', html)\n        self.assertIn('aria-label=\"Side-by-side differences\"', html)\n        self.assertIn('tabindex=\"0\"', html)\n        self.assertIn('.diff-scroll:focus-visible', html)\n\n    def test_fluid_type_layer_is_container_keyed(self):\n        # Type and section rhythm flex to the content column (not the viewport), so\n        # the report stays readable across the range of IDE preview-pane widths.\n        with tempfile.TemporaryDirectory() as d:\n            html = _report(Path(d), \"a\", \"b\")\n        self.assertIn(\"container-type:inline-size\", html)\n        self.assertIn(\"@container report\", html)\n        self.assertIn(\"cqi\", html)\n\n    def test_page_gutter_has_two_rem_minimum(self):\n        # The report content must never sit flush against the pane edge; a >=2rem\n        # page gutter keeps the diff readable in a narrow docked IDE preview.\n        with tempfile.TemporaryDirectory() as d:\n            html = _report(Path(d), \"a\", \"b\")\n        self.assertRegex(html, r\"main\\{[^}]*padding:2rem\\}\")\n\n    def test_markdown_headings_divide_sections(self):\n        # Markdown diffs are navigable by document structure: headings hidden in\n        # collapsed runs surface as visible section bands, and hunk headers name\n        # the section they fall in — line numbers alone can't say WHERE you are.\n        body = \"\\n\".join(f\"filler {i}\" for i in range(12))\n        a = f\"# Title\\nintro\\n\\n## Alpha\\n{body}\\n\\n## Beta\\nold line\\n\"\n        b = f\"# Title\\nintro\\n\\n## Alpha\\n{body}\\n\\n## Beta\\nnew line\\n\"\n        with tempfile.TemporaryDirectory() as d:\n            fa = _write(Path(d), \"a.md\", a)","lineStart":170,"lineEnd":349,"totalLines":416,"truncated":true}},"title":".opencode/skills/sk-doc/create-diff/scripts/test_create_diff.py","time":{"start":1784210626293,"end":1784210626310}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a2c81919f09dc68276187d1"}},"id":"prt_f6b3d96f1001Zg8UKB2Bu6IHn4","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626381,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_w72Aq8351ZTaJatQes5mBIFV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/diff.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/diff.md</path>\n<type>file</type>\n<content>\n1: ---\n2: description: Create a self-contained before/after document diff report via the create-diff engine. Modes :auto, :confirm.\n3: argument-hint: \"<target-document | --before old --after new> [--report out.html] [--view unified|side-by-side] [:auto|:confirm] (:auto supports PRE-BOUND SETUP ANSWERS: prompt-body block for non-interactive setup)\"\n4: allowed-tools: Read, Write, Edit, Bash, Glob, Grep\n5: ---\n6: \n7: # /create:diff Router\n8: \n9: This command is a thin router. It separates execution routing from user-facing presentation.\n10: \n11: ## 1. ROUTER CONTRACT\n12: \n13: Route /create:diff to its presentation contract and workflow YAML for producing a local, Git-free before/after document diff as a self-contained HTML report via the create-diff engine.\n14: \n15: - Do not dispatch workflow behavior from this router.\n16: - Do not edit workflow YAML while executing this command.\n17: \n18: ## 2. OWNED ASSETS\n19: \n20: | Asset | Path | Purpose |\n21: | --- | --- | --- |\n22: | Presentation contract | `.opencode/commands/create/assets/create_diff_presentation.txt` | Startup questions, setup dashboard, and completion display |\n23: | Auto workflow | `.opencode/commands/create/assets/create_diff_auto.yaml` | Autonomous workflow execution |\n24: | Confirm workflow | `.opencode/commands/create/assets/create_diff_confirm.yaml` | Interactive checkpointed workflow execution |\n25: \n26: ## 3. MODE ROUTING\n27: \n28: - If any referenced asset is missing, stop and report the missing path.\n29: - The YAML owns workflow behavior; the presentation Markdown owns user-visible wording and layout.\n30: \n31: ## 4. EXECUTION TARGETS\n32: \n33: 1. Read `.opencode/commands/create/assets/create_diff_presentation.txt`.\n34: 2. Run the presentation contract's Phase 0 verification and setup resolution.\n35: 3. Resolve execution mode from `$ARGUMENTS` or the setup answer: `:auto` or `:confirm`.\n36: 4. Load exactly one workflow YAML:\n37:    - `:auto` -> `.opencode/commands/create/assets/create_diff_auto.yaml`\n38:    - `:confirm` or omitted mode -> `.opencode/commands/create/assets/create_diff_confirm.yaml`\n39: 5. Execute the selected YAML step by step.\n40: 6. Use the presentation contract, not this router, for user prompts, setup/status dashboards, and final result display.\n41: \n42: ## 5. PRESENTATION BOUNDARY\n43: \n44: The following content lives only in `.opencode/commands/create/assets/create_diff_presentation.txt`:\n45: \n46: - Startup questions, Phase 0 verification, setup dashboard, confirmation prompts, status display, completion display, and next-step text.\n47: \n48: The router must not invent visible wording for those surfaces; it only selects the workflow YAML and execution mode.\n49: \n50: ## 6. WORKFLOW SUMMARY\n51: \n52: The bound workflow YAML (`create_diff_auto.yaml` for `:auto`, `create_diff_confirm.yaml` for `:confirm` or an omitted mode) runs the create-diff workflow step by step after Phase 0 verification and setup resolution, wrapping the `create_diff.py` engine to capture a baseline (or accept an explicit before/after pair), compare the versions, render a single self-contained HTML report, and validate it with `validate_report.py`. `:auto` executes autonomously; `:confirm` runs the same steps as an interactive checkpointed workflow. All user-facing prompts, setup/status dashboards, and result display come from the presentation contract, not this router.\n53: \n54: User request: $ARGUMENTS\n\n(End of file - total 54 lines)\n</content>","metadata":{"preview":"---\ndescription: Create a self-contained before/after document diff report via the create-diff engine. Modes :auto, :confirm.\nargument-hint: \"<target-document | --before old --after new> [--report out.html] [--view unified|side-by-side] [:auto|:confirm] (:auto supports PRE-BOUND SETUP ANSWERS: prompt-body block for non-interactive setup)\"\nallowed-tools: Read, Write, Edit, Bash, Glob, Grep\n---\n\n# /create:diff Router\n\nThis command is a thin router. It separates execution routing from user-facing presentation.\n\n## 1. ROUTER CONTRACT\n\nRoute /create:diff to its presentation contract and workflow YAML for producing a local, Git-free before/after document diff as a self-contained HTML report via the create-diff engine.\n\n- Do not dispatch workflow behavior from this router.\n- Do not edit workflow YAML while executing this command.\n\n## 2. OWNED ASSETS\n\n| Asset | Path | Purpose |","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/diff.md","text":"---\ndescription: Create a self-contained before/after document diff report via the create-diff engine. Modes :auto, :confirm.\nargument-hint: \"<target-document | --before old --after new> [--report out.html] [--view unified|side-by-side] [:auto|:confirm] (:auto supports PRE-BOUND SETUP ANSWERS: prompt-body block for non-interactive setup)\"\nallowed-tools: Read, Write, Edit, Bash, Glob, Grep\n---\n\n# /create:diff Router\n\nThis command is a thin router. It separates execution routing from user-facing presentation.\n\n## 1. ROUTER CONTRACT\n\nRoute /create:diff to its presentation contract and workflow YAML for producing a local, Git-free before/after document diff as a self-contained HTML report via the create-diff engine.\n\n- Do not dispatch workflow behavior from this router.\n- Do not edit workflow YAML while executing this command.\n\n## 2. OWNED ASSETS\n\n| Asset | Path | Purpose |\n| --- | --- | --- |\n| Presentation contract | `.opencode/commands/create/assets/create_diff_presentation.txt` | Startup questions, setup dashboard, and completion display |\n| Auto workflow | `.opencode/commands/create/assets/create_diff_auto.yaml` | Autonomous workflow execution |\n| Confirm workflow | `.opencode/commands/create/assets/create_diff_confirm.yaml` | Interactive checkpointed workflow execution |\n\n## 3. MODE ROUTING\n\n- If any referenced asset is missing, stop and report the missing path.\n- The YAML owns workflow behavior; the presentation Markdown owns user-visible wording and layout.\n\n## 4. EXECUTION TARGETS\n\n1. Read `.opencode/commands/create/assets/create_diff_presentation.txt`.\n2. Run the presentation contract's Phase 0 verification and setup resolution.\n3. Resolve execution mode from `$ARGUMENTS` or the setup answer: `:auto` or `:confirm`.\n4. Load exactly one workflow YAML:\n   - `:auto` -> `.opencode/commands/create/assets/create_diff_auto.yaml`\n   - `:confirm` or omitted mode -> `.opencode/commands/create/assets/create_diff_confirm.yaml`\n5. Execute the selected YAML step by step.\n6. Use the presentation contract, not this router, for user prompts, setup/status dashboards, and final result display.\n\n## 5. PRESENTATION BOUNDARY\n\nThe following content lives only in `.opencode/commands/create/assets/create_diff_presentation.txt`:\n\n- Startup questions, Phase 0 verification, setup dashboard, confirmation prompts, status display, completion display, and next-step text.\n\nThe router must not invent visible wording for those surfaces; it only selects the workflow YAML and execution mode.\n\n## 6. WORKFLOW SUMMARY\n\nThe bound workflow YAML (`create_diff_auto.yaml` for `:auto`, `create_diff_confirm.yaml` for `:confirm` or an omitted mode) runs the create-diff workflow step by step after Phase 0 verification and setup resolution, wrapping the `create_diff.py` engine to capture a baseline (or accept an explicit before/after pair), compare the versions, render a single self-contained HTML report, and validate it with `validate_report.py`. `:auto` executes autonomously; `:confirm` runs the same steps as an interactive checkpointed workflow. All user-facing prompts, setup/status dashboards, and result display come from the presentation contract, not this router.\n\nUser request: $ARGUMENTS","lineStart":1,"lineEnd":54,"totalLines":54,"truncated":false}},"title":".opencode/commands/create/diff.md","time":{"start":1784210626345,"end":1784210626355}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a6881919f0a586125bc1203"}},"id":"prt_f6b3d9727001sNCoSEqnH76RjY","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626381,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_fYe5miwOG9IBZleCwxn1TZBX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/SKILL.md","limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/SKILL.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: create-diff\n3: description: Local, Git-free before/after review of an edited document (text, Markdown, HTML, DOCX, text PDF) as a self-contained HTML report.\n4: allowed-tools: [Read, Write, Edit, Bash, Grep, Glob]\n5: version: 1.1.0.0\n6: ---\n7: <!-- Keywords: create-diff, document diff, before after review, before/after document, local html diff report, document snapshot, ai edit review, docx diff, pdf diff, markdown diff -->\n8: \n9: # Create Diff\n10: \n11: `create-diff` is the `sk-doc` workflow packet for reviewing what changed in a locally edited document — outside Git and without a hosted service. It captures a baseline before an edit, then compares the before and after versions and renders a single self-contained, accessible HTML report. The comparison engine ships with this packet as `scripts/create_diff.py`; everything runs on the machine with no network, no upload, and no telemetry, and source files are never modified.\n12: \n13: Supported formats and fidelity tiers: plain text and Markdown (full text fidelity), HTML and DOCX (visible/structural text), and text-layer PDF (conditional on a local extractor). Each report states its fidelity tier so a comparison is never trusted beyond what the extractor can actually see.\n14: \n15: This packet owns diff authoring and its two scripts. It uses shared sk-doc standards from `../shared/` for surrounding-document quality. It must not add packet-local advisor metadata such as `graph-metadata.json` or `description.json`.\n16: \n17: ---\n18: \n19: ## 1. WHEN TO USE\n20: \n21: ### Activation Triggers\n22: \n23: Use this packet when the request asks to:\n24: \n25: - Review what an AI (or anyone) changed in a locally edited document.\n26: - Produce a before/after report for a Markdown, text, HTML, DOCX, or PDF file that is not in Git.\n27: - Capture a baseline of a document before editing it, so the change can be reviewed afterward.\n28: - Compare two explicit versions of a document (an old file and a new file).\n29: \n30: Keyword triggers: `create diff report`, `document before/after review`, `before/after document diff`, `document change report`, `review document edits`, `docx diff`, `pdf diff`.\n31: \n32: ### When NOT to Use\n33: \n34: Route elsewhere when:\n35: \n36: - The files are code or already tracked in Git — use `git`/`sk-git` for source diffs.\n37: - The comparison is visual or design-oriented (layout, pixels, screenshots) — use `sk-design`.\n38: - The task is auditing, scoring, or validating a single existing document rather than comparing two states — use `create-quality-control`.\n39: - The deliverable is a README, skill, command, agent, changelog, or flowchart — use the matching `create-*` packet.\n40: \n41: If the target document or output path is unknown and acting would be a guess, ask before writing.\n42: \n43: ---\n44: \n45: ## 2. SMART ROUTING\n46: \n47: This packet ships a flat `references/` route-map and worked-example fixtures under `assets/`; there are no `references/<key>/` or `assets/<key>/` subdirectories to infer. Routing is intent-based:\n48: \n49: - If the request clearly asks for a before/after document review, route here and pick the workflow shape in section 3 (automatic baseline vs. explicit pair).\n50: - If the target document, baseline state, or output path is unclear, use `UNKNOWN_FALLBACK`: confirm the document, whether a baseline exists, and the report path before acting.\n51: - If a referenced resource is missing, do not invent a path — use the nearest guidance in `references/README.md` and report the gap.\n52: - Do not hijack routing from functional siblings when the intent is not clearly a document before/after review.\n53: \n54: ### Smart Router Pseudocode\n55: \n56: ```python\n57: from pathlib import Path\n58: \n59: SKILL_ROOT = Path(__file__).resolve().parent\n60: RESOURCE_BASES = (SKILL_ROOT / \"references\", SKILL_ROOT / \"assets\")\n61: DEFAULT_RESOURCE = \"references/README.md\"\n62: \n63: # Two workflow shapes for one intent: automatic (snapshot-backed) or explicit pair.\n64: INTENT_MODEL = {\n65:     \"auto_capture_compare\": {\"weight\": 4, \"keywords\": [\"review edits\", \"before/after\", \"before after review\", \"document change report\", \"what changed\"]},\n66:     \"explicit_pair\": {\"weight\": 4, \"keywords\": [\"compare two files\", \"old and new\", \"before and after files\", \"explicit pair\"]},\n67: }\n68: UNKNOWN_FALLBACK_CHECKLIST = [\n69:     \"Confirm the target document (and its format)\",\n70:     \"Confirm whether a baseline snapshot already exists\",\n71:     \"Confirm the output report path\",\n72: ]\n73: \n74: def discover_markdown_resources() -> set[str]:\n75:     docs = []\n76:     for base in RESOURCE_BASES:\n77:         if base.exists():\n78:             docs.extend(path for path in base.rglob(\"*.md\") if path.is_file())\n79:     return {doc.relative_to(SKILL_ROOT).as_posix() for doc in docs}\n80: \n81: def _guard_in_skill(relative_path: str) -> str:\n82:     resolved = (SKILL_ROOT / relative_path).resolve()\n83:     resolved.relative_to(SKILL_ROOT)\n84:     if resolved.suffix.lower() != \".md\":\n85:         raise ValueError(f\"Only markdown resources are routable: {relative_path}\")\n86:     return resolved.relative_to(SKILL_ROOT).as_posix()\n87: \n88: def load_if_available(relative_path, inventory, loaded, seen) -> None:\n89:     guarded = _guard_in_skill(relative_path)\n90:     if guarded in inventory and guarded not in seen:\n91:         load(guarded)\n92:         loaded.append(guarded)\n93:         seen.add(guarded)\n94: \n95: def score_intents(request) -> dict:\n96:     text = request.text.lower()\n97:     scores = {intent: 0 for intent in INTENT_MODEL}\n98:     for intent, cfg in INTENT_MODEL.items():\n99:         for kw in cfg[\"keywords\"]:\n100:             if kw in text:\n101:                 scores[intent] += cfg[\"weight\"]\n102:     return scores\n103: \n104: def route_diff_request(request):\n105:     inventory = discover_markdown_resources()\n106:     loaded, seen = [], set()\n107:     scores = score_intents(request)\n108: \n109:     if max(scores.values() or [0]) < 4:                      # Tier 1: target/baseline/output unclear\n110:         load_if_available(DEFAULT_RESOURCE, inventory, loaded, seen)\n111:         return {\n112:             \"load_level\": \"UNKNOWN_FALLBACK\",\n113:             \"needs_disambiguation\": True,\n114:             \"disambiguation_checklist\": UNKNOWN_FALLBACK_CHECKLIST,\n115:             \"resources\": loaded,\n116:         }\n117: \n118:     shape = max(scores, key=scores.get)                       # Tier 2: workflow shape resolved\n119:     for path in sorted(inventory):\n120:         load_if_available(path, inventory, loaded, seen)\n121:     return {\"shape\": shape, \"resources\": loaded}\n122: ```\n123: \n124: ---\n125: \n126: ## 3. HOW IT WORKS\n127: \n128: All comparison, extraction, snapshotting, and rendering are done by `scripts/create_diff.py`. Run it from this packet directory (or give an absolute path to it). The invariant is: **capture the baseline before the edit** — a diff needs a real before-state.\n129: \n130: ### Automatic flow (snapshot-backed)\n131: \n132: ```bash\n133: # 0. (optional) confirm what is supported and at what fidelity\n134: python3 scripts/create_diff.py capabilities\n135: \n136: # 1. BEFORE the edit — capture a baseline (copies the file into a local .create-diff/ store;\n137: #    never touches the source)\n138: python3 scripts/create_diff.py snapshot path/to/doc.md\n139: \n140: # 2. ... let the edit happen (AI or human) ...\n141: \n142: # 3. AFTER the edit — compare the current file against its latest baseline and render the report\n143: python3 scripts/create_diff.py compare path/to/doc.md --report review.html\n144: ```\n145: \n146: ### Explicit-pair flow (fallback — no stored state needed)\n147: \n148: Use this when there is no baseline, when comparing two arbitrary versions, or when the automatic store is unavailable:\n149: \n150: ```bash\n151: python3 scripts/create_diff.py compare-pair --before old.md --after new.md --report review.html\n152: ```\n153: \n154: ### Report and verification\n155: \n156: - The report is a single self-contained HTML file (inlined CSS, no scripts, no network). Views: `--view unified` (default) or `--view side-by-side`.\n157: - Always verify a generated report is safe and self-contained before handing it off:\n158: \n159: ```bash\n160: python3 scripts/validate_report.py review.html\n161: ```\n162: \n163: ### Lifecycle helpers\n164: \n165: ```bash\n166: python3 scripts/create_diff.py status [path/to/doc.md]      # list stored baselines\n167: python3 scripts/create_diff.py cleanup --older-than 14      # prune old baselines (add --dry-run to preview)\n168: ```\n169: \n170: ### Machine-readable output and exit codes\n171: \n172: Add `--json` to `compare`, `compare-pair`, `capabilities`, or `status` for a structured summary. Exit codes: `0` success · `2` usage error · `3` unsupported/limited format with no fallback · `4` missing baseline snapshot · `5` I/O or extraction failure. Map these to actionable messages rather than swallowing them.\n173: \n174: ---\n175: \n176: ## 4. CAPABILITY & FIDELITY TIERS\n177: \n178: State the tier to the user; never present a low-fidelity comparison as complete.\n179: \n180: | Format | Tier | What is compared | Not compared |\n181: | --- | --- | --- | --- |\n182: | text | full | exact text | — |\n183: | markdown | full | exact text + heading/section awareness | rendered-HTML differences |\n184: | html | text | visible text | CSS, attributes, inline styles, scripts, layout |\n185: | docx | text | paragraph and table text | formatting, styles, images, comments, tracked changes |\n186: | pdf | text* | text layer only | layout, images; scanned/image-only PDFs (no OCR) |\n187: \n188: `text*` (PDF) requires a local extractor — poppler's `pdftotext` or the `pypdf`/`pdfplumber` package. Run `capabilities` to see what is available; when none is, the engine says so and offers the explicit-pair fallback with pre-extracted text. Full detail: `references/capabilities-and-fidelity.md`.\n189: \n190: ---\n191: \n192: ## 5. RULES\n193: \n194: ### ✅ ALWAYS\n195: \n196: - Capture the baseline **before** the edit; that ordering is an invariant.\n197: - Keep everything local — no network, upload, or telemetry.\n198: - State the format fidelity tier and any warnings honestly.\n199: - Read a file before editing it; never modify the source document during comparison.\n200: - Run `scripts/validate_report.py` on a generated report before handing it off, and report the result.\n201: - Offer the explicit-pair fallback when no valid baseline exists.\n202: \n203: ### ⛔ NEVER\n204: \n205: - Never mutate, overwrite, or \"fix up\" the source document — capture and comparison are read-only against it.\n206: - Never present a `text`/`text*`-tier comparison as if it captured formatting, layout, or tracked changes.\n207: - Never claim a diff was produced when the format was unsupported and no fallback ran.\n208: - Never add packet-local `graph-metadata.json` or `description.json`.\n209: - Never send document content off-machine or fetch a remote resource into the report.\n210: \n211: ### ⚠️ ESCALATE\n212: \n213: - When a PDF has no text layer (appears scanned) — the comparison would be empty; OCR is out of scope.\n214: - When the document format is unsupported and no explicit pre-extracted pair can be provided.\n215: - When the target document or output path is unknown and acting would be a guess.\n216: \n217: ---\n218: \n219: ## 6. VERIFICATION\n220: \n221: Before delivery:\n222: \n223: 1. Confirm the source file is byte-for-byte unchanged (compare should never write to it).\n224: 2. Run `python3 scripts/validate_report.py <report>` → expect `PASS` (asserts doctype, `lang`, a Content-Security-Policy meta tag, zero `<script>`, no inline event handlers, no remote resource references).\n225: 3. Report the change summary (`+added −removed ~changed`, possible moves, fidelity tier) and the report path.\n226: \n227: If the validator fails, fix the renderer or report the failure explicitly — do not claim a clean, self-contained report.\n228: \n229: ---\n230: \n231: ## 7. SUCCESS CRITERIA\n232: \n233: The task is successful when:\n234: \n235: - The correct workflow shape is used (automatic baseline when one exists; explicit pair otherwise), and code/Git/design/audit requests are deferred to their owners.\n236: - The baseline was captured before the edit, or the explicit-pair fallback was used, and the source file is unchanged.\n237: - A single self-contained, accessible HTML report is produced and passes `validate_report.py`.\n238: - The fidelity tier and any warnings are stated; a limited-fidelity result is never presented as complete.\n239: - All processing stayed local, and no packet-local advisor metadata was created.\n240: \n241: ---\n242: \n243: ## 8. INTEGRATION POINTS\n244: \n245: - **sk-doc parent hub** — this packet is registered in `../mode-registry.json` and `../hub-router.json`; the single advisor identity and workflow registry live at the hub root, not here.\n246: - **Shared backbone** — `../shared/` provides sk-doc quality standards and the document validator for surrounding markdown when that is in scope.\n247: - **Canon gates** — `parent-skill-check.cjs`, `create-skill/scripts/package_skill.py --check`, and `scripts/check-frontmatter-versions.sh` validate this packet's registration and shape.\n248: - **`/create:diff` command** — the mode is invocable as `/create:diff` (`:auto`/`:confirm`) via a full sibling-pattern router plus presentation and auto/confirm YAML assets under `.opencode/commands/create/`, alongside advisor-alias routing and direct script invocation.\n249: - **Sibling boundaries** — hands off to `sk-git` (code/Git diffs), `sk-design` (visual comparison), and `create-quality-control` (single-document audit).\n250: \n251: ---\n252: \n253: ## 9. RELATED RESOURCES\n254: \n255: - `references/README.md` — reference route-map (capabilities/fidelity, workflow, CLI reference, accessibility contract, worked example).\n256: - `feature-catalog/feature-catalog.md` — canonical inventory of this mode's capabilities.\n257: - `manual-testing-playbook/manual-testing-playbook.md` — operator-facing manual validation scenarios.\n258: - `assets/fixtures/` — a runnable before/after worked example.\n259: - `../shared/` — shared sk-doc quality standards and document validator.\n260: - Engine and mode design: `.opencode/specs/sk-doc/033-create-diff-mode/` (parent spec, phase `006-opencode-skill-and-accessibility`, research synthesis in `001-research-and-requirements/research/research.md`).\n261: \n262: ---\n263: \n264: ## 10. REFERENCES\n265: \n266: - `scripts/create_diff.py` — the comparison engine (extraction, diff, snapshots, report).\n267: - `scripts/validate_report.py` — report safety/self-containment validator.\n268: - `references/cli-reference.md` — full command, flag, and exit-code reference.\n269: - `references/capabilities-and-fidelity.md` — format support matrix and fidelity tiers.\n270: - `references/workflow.md` — baseline-capture, explicit-pair, and snapshot lifecycle.\n271: - `references/accessibility-contract.md` — the report's accessibility guarantees.\n272: - `references/worked-example.md` — an end-to-end walkthrough using the shipped fixtures.\n\n(End of file - total 272 lines)\n</content>","metadata":{"preview":"---\nname: create-diff\ndescription: Local, Git-free before/after review of an edited document (text, Markdown, HTML, DOCX, text PDF) as a self-contained HTML report.\nallowed-tools: [Read, Write, Edit, Bash, Grep, Glob]\nversion: 1.1.0.0\n---\n<!-- Keywords: create-diff, document diff, before after review, before/after document, local html diff report, document snapshot, ai edit review, docx diff, pdf diff, markdown diff -->\n\n# Create Diff\n\n`create-diff` is the `sk-doc` workflow packet for reviewing what changed in a locally edited document — outside Git and without a hosted service. It captures a baseline before an edit, then compares the before and after versions and renders a single self-contained, accessible HTML report. The comparison engine ships with this packet as `scripts/create_diff.py`; everything runs on the machine with no network, no upload, and no telemetry, and source files are never modified.\n\nSupported formats and fidelity tiers: plain text and Markdown (full text fidelity), HTML and DOCX (visible/structural text), and text-layer PDF (conditional on a local extractor). Each report states its fidelity tier so a comparison is never trusted beyond what the extractor can actually see.\n\nThis packet owns diff authoring and its two scripts. It uses shared sk-doc standards from `../shared/` for surrounding-document quality. It must not add packet-local advisor metadata such as `graph-metadata.json` or `description.json`.\n\n---\n\n## 1. WHEN TO USE\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/SKILL.md","text":"---\nname: create-diff\ndescription: Local, Git-free before/after review of an edited document (text, Markdown, HTML, DOCX, text PDF) as a self-contained HTML report.\nallowed-tools: [Read, Write, Edit, Bash, Grep, Glob]\nversion: 1.1.0.0\n---\n<!-- Keywords: create-diff, document diff, before after review, before/after document, local html diff report, document snapshot, ai edit review, docx diff, pdf diff, markdown diff -->\n\n# Create Diff\n\n`create-diff` is the `sk-doc` workflow packet for reviewing what changed in a locally edited document — outside Git and without a hosted service. It captures a baseline before an edit, then compares the before and after versions and renders a single self-contained, accessible HTML report. The comparison engine ships with this packet as `scripts/create_diff.py`; everything runs on the machine with no network, no upload, and no telemetry, and source files are never modified.\n\nSupported formats and fidelity tiers: plain text and Markdown (full text fidelity), HTML and DOCX (visible/structural text), and text-layer PDF (conditional on a local extractor). Each report states its fidelity tier so a comparison is never trusted beyond what the extractor can actually see.\n\nThis packet owns diff authoring and its two scripts. It uses shared sk-doc standards from `../shared/` for surrounding-document quality. It must not add packet-local advisor metadata such as `graph-metadata.json` or `description.json`.\n\n---\n\n## 1. WHEN TO USE\n\n### Activation Triggers\n\nUse this packet when the request asks to:\n\n- Review what an AI (or anyone) changed in a locally edited document.\n- Produce a before/after report for a Markdown, text, HTML, DOCX, or PDF file that is not in Git.\n- Capture a baseline of a document before editing it, so the change can be reviewed afterward.\n- Compare two explicit versions of a document (an old file and a new file).\n\nKeyword triggers: `create diff report`, `document before/after review`, `before/after document diff`, `document change report`, `review document edits`, `docx diff`, `pdf diff`.\n\n### When NOT to Use\n\nRoute elsewhere when:\n\n- The files are code or already tracked in Git — use `git`/`sk-git` for source diffs.\n- The comparison is visual or design-oriented (layout, pixels, screenshots) — use `sk-design`.\n- The task is auditing, scoring, or validating a single existing document rather than comparing two states — use `create-quality-control`.\n- The deliverable is a README, skill, command, agent, changelog, or flowchart — use the matching `create-*` packet.\n\nIf the target document or output path is unknown and acting would be a guess, ask before writing.\n\n---\n\n## 2. SMART ROUTING\n\nThis packet ships a flat `references/` route-map and worked-example fixtures under `assets/`; there are no `references/<key>/` or `assets/<key>/` subdirectories to infer. Routing is intent-based:\n\n- If the request clearly asks for a before/after document review, route here and pick the workflow shape in section 3 (automatic baseline vs. explicit pair).\n- If the target document, baseline state, or output path is unclear, use `UNKNOWN_FALLBACK`: confirm the document, whether a baseline exists, and the report path before acting.\n- If a referenced resource is missing, do not invent a path — use the nearest guidance in `references/README.md` and report the gap.\n- Do not hijack routing from functional siblings when the intent is not clearly a document before/after review.\n\n### Smart Router Pseudocode\n\n```python\nfrom pathlib import Path\n\nSKILL_ROOT = Path(__file__).resolve().parent\nRESOURCE_BASES = (SKILL_ROOT / \"references\", SKILL_ROOT / \"assets\")\nDEFAULT_RESOURCE = \"references/README.md\"\n\n# Two workflow shapes for one intent: automatic (snapshot-backed) or explicit pair.\nINTENT_MODEL = {\n    \"auto_capture_compare\": {\"weight\": 4, \"keywords\": [\"review edits\", \"before/after\", \"before after review\", \"document change report\", \"what changed\"]},\n    \"explicit_pair\": {\"weight\": 4, \"keywords\": [\"compare two files\", \"old and new\", \"before and after files\", \"explicit pair\"]},\n}\nUNKNOWN_FALLBACK_CHECKLIST = [\n    \"Confirm the target document (and its format)\",\n    \"Confirm whether a baseline snapshot already exists\",\n    \"Confirm the output report path\",\n]\n\ndef discover_markdown_resources() -> set[str]:\n    docs = []\n    for base in RESOURCE_BASES:\n        if base.exists():\n            docs.extend(path for path in base.rglob(\"*.md\") if path.is_file())\n    return {doc.relative_to(SKILL_ROOT).as_posix() for doc in docs}\n\ndef _guard_in_skill(relative_path: str) -> str:\n    resolved = (SKILL_ROOT / relative_path).resolve()\n    resolved.relative_to(SKILL_ROOT)\n    if resolved.suffix.lower() != \".md\":\n        raise ValueError(f\"Only markdown resources are routable: {relative_path}\")\n    return resolved.relative_to(SKILL_ROOT).as_posix()\n\ndef load_if_available(relative_path, inventory, loaded, seen) -> None:\n    guarded = _guard_in_skill(relative_path)\n    if guarded in inventory and guarded not in seen:\n        load(guarded)\n        loaded.append(guarded)\n        seen.add(guarded)\n\ndef score_intents(request) -> dict:\n    text = request.text.lower()\n    scores = {intent: 0 for intent in INTENT_MODEL}\n    for intent, cfg in INTENT_MODEL.items():\n        for kw in cfg[\"keywords\"]:\n            if kw in text:\n                scores[intent] += cfg[\"weight\"]\n    return scores\n\ndef route_diff_request(request):\n    inventory = discover_markdown_resources()\n    loaded, seen = [], set()\n    scores = score_intents(request)\n\n    if max(scores.values() or [0]) < 4:                      # Tier 1: target/baseline/output unclear\n        load_if_available(DEFAULT_RESOURCE, inventory, loaded, seen)\n        return {\n            \"load_level\": \"UNKNOWN_FALLBACK\",\n            \"needs_disambiguation\": True,\n            \"disambiguation_checklist\": UNKNOWN_FALLBACK_CHECKLIST,\n            \"resources\": loaded,\n        }\n\n    shape = max(scores, key=scores.get)                       # Tier 2: workflow shape resolved\n    for path in sorted(inventory):\n        load_if_available(path, inventory, loaded, seen)\n    return {\"shape\": shape, \"resources\": loaded}\n```\n\n---\n\n## 3. HOW IT WORKS\n\nAll comparison, extraction, snapshotting, and rendering are done by `scripts/create_diff.py`. Run it from this packet directory (or give an absolute path to it). The invariant is: **capture the baseline before the edit** — a diff needs a real before-state.\n\n### Automatic flow (snapshot-backed)\n\n```bash\n# 0. (optional) confirm what is supported and at what fidelity\npython3 scripts/create_diff.py capabilities\n\n# 1. BEFORE the edit — capture a baseline (copies the file into a local .create-diff/ store;\n#    never touches the source)\npython3 scripts/create_diff.py snapshot path/to/doc.md\n\n# 2. ... let the edit happen (AI or human) ...\n\n# 3. AFTER the edit — compare the current file against its latest baseline and render the report\npython3 scripts/create_diff.py compare path/to/doc.md --report review.html\n```\n\n### Explicit-pair flow (fallback — no stored state needed)\n\nUse this when there is no baseline, when comparing two arbitrary versions, or when the automatic store is unavailable:\n\n```bash\npython3 scripts/create_diff.py compare-pair --before old.md --after new.md --report review.html\n```\n\n### Report and verification\n\n- The report is a single self-contained HTML file (inlined CSS, no scripts, no network). Views: `--view unified` (default) or `--view side-by-side`.\n- Always verify a generated report is safe and self-contained before handing it off:\n\n```bash\npython3 scripts/validate_report.py review.html\n```\n\n### Lifecycle helpers\n\n```bash\npython3 scripts/create_diff.py status [path/to/doc.md]      # list stored baselines\npython3 scripts/create_diff.py cleanup --older-than 14      # prune old baselines (add --dry-run to preview)\n```\n\n### Machine-readable output and exit codes\n\nAdd `--json` to `compare`, `compare-pair`, `capabilities`, or `status` for a structured summary. Exit codes: `0` success · `2` usage error · `3` unsupported/limited format with no fallback · `4` missing baseline snapshot · `5` I/O or extraction failure. Map these to actionable messages rather than swallowing them.\n\n---\n\n## 4. CAPABILITY & FIDELITY TIERS\n\nState the tier to the user; never present a low-fidelity comparison as complete.\n\n| Format | Tier | What is compared | Not compared |\n| --- | --- | --- | --- |\n| text | full | exact text | — |\n| markdown | full | exact text + heading/section awareness | rendered-HTML differences |\n| html | text | visible text | CSS, attributes, inline styles, scripts, layout |\n| docx | text | paragraph and table text | formatting, styles, images, comments, tracked changes |\n| pdf | text* | text layer only | layout, images; scanned/image-only PDFs (no OCR) |\n\n`text*` (PDF) requires a local extractor — poppler's `pdftotext` or the `pypdf`/`pdfplumber` package. Run `capabilities` to see what is available; when none is, the engine says so and offers the explicit-pair fallback with pre-extracted text. Full detail: `references/capabilities-and-fidelity.md`.\n\n---\n\n## 5. RULES\n\n### ✅ ALWAYS\n\n- Capture the baseline **before** the edit; that ordering is an invariant.\n- Keep everything local — no network, upload, or telemetry.\n- State the format fidelity tier and any warnings honestly.\n- Read a file before editing it; never modify the source document during comparison.\n- Run `scripts/validate_report.py` on a generated report before handing it off, and report the result.\n- Offer the explicit-pair fallback when no valid baseline exists.\n\n### ⛔ NEVER\n\n- Never mutate, overwrite, or \"fix up\" the source document — capture and comparison are read-only against it.\n- Never present a `text`/`text*`-tier comparison as if it captured formatting, layout, or tracked changes.\n- Never claim a diff was produced when the format was unsupported and no fallback ran.\n- Never add packet-local `graph-metadata.json` or `description.json`.\n- Never send document content off-machine or fetch a remote resource into the report.\n\n### ⚠️ ESCALATE\n\n- When a PDF has no text layer (appears scanned) — the comparison would be empty; OCR is out of scope.\n- When the document format is unsupported and no explicit pre-extracted pair can be provided.\n- When the target document or output path is unknown and acting would be a guess.\n\n---\n\n## 6. VERIFICATION\n\nBefore delivery:\n\n1. Confirm the source file is byte-for-byte unchanged (compare should never write to it).\n2. Run `python3 scripts/validate_report.py <report>` → expect `PASS` (asserts doctype, `lang`, a Content-Security-Policy meta tag, zero `<script>`, no inline event handlers, no remote resource references).\n3. Report the change summary (`+added −removed ~changed`, possible moves, fidelity tier) and the report path.\n\nIf the validator fails, fix the renderer or report the failure explicitly — do not claim a clean, self-contained report.\n\n---\n\n## 7. SUCCESS CRITERIA\n\nThe task is successful when:\n\n- The correct workflow shape is used (automatic baseline when one exists; explicit pair otherwise), and code/Git/design/audit requests are deferred to their owners.\n- The baseline was captured before the edit, or the explicit-pair fallback was used, and the source file is unchanged.\n- A single self-contained, accessible HTML report is produced and passes `validate_report.py`.\n- The fidelity tier and any warnings are stated; a limited-fidelity result is never presented as complete.\n- All processing stayed local, and no packet-local advisor metadata was created.\n\n---\n\n## 8. INTEGRATION POINTS\n\n- **sk-doc parent hub** — this packet is registered in `../mode-registry.json` and `../hub-router.json`; the single advisor identity and workflow registry live at the hub root, not here.\n- **Shared backbone** — `../shared/` provides sk-doc quality standards and the document validator for surrounding markdown when that is in scope.\n- **Canon gates** — `parent-skill-check.cjs`, `create-skill/scripts/package_skill.py --check`, and `scripts/check-frontmatter-versions.sh` validate this packet's registration and shape.\n- **`/create:diff` command** — the mode is invocable as `/create:diff` (`:auto`/`:confirm`) via a full sibling-pattern router plus presentation and auto/confirm YAML assets under `.opencode/commands/create/`, alongside advisor-alias routing and direct script invocation.\n- **Sibling boundaries** — hands off to `sk-git` (code/Git diffs), `sk-design` (visual comparison), and `create-quality-control` (single-document audit).\n\n---\n\n## 9. RELATED RESOURCES\n\n- `references/README.md` — reference route-map (capabilities/fidelity, workflow, CLI reference, accessibility contract, worked example).\n- `feature-catalog/feature-catalog.md` — canonical inventory of this mode's capabilities.\n- `manual-testing-playbook/manual-testing-playbook.md` — operator-facing manual validation scenarios.\n- `assets/fixtures/` — a runnable before/after worked example.\n- `../shared/` — shared sk-doc quality standards and document validator.\n- Engine and mode design: `.opencode/specs/sk-doc/033-create-diff-mode/` (parent spec, phase `006-opencode-skill-and-accessibility`, research synthesis in `001-research-and-requirements/research/research.md`).\n\n---\n\n## 10. REFERENCES\n\n- `scripts/create_diff.py` — the comparison engine (extraction, diff, snapshots, report).\n- `scripts/validate_report.py` — report safety/self-containment validator.\n- `references/cli-reference.md` — full command, flag, and exit-code reference.\n- `references/capabilities-and-fidelity.md` — format support matrix and fidelity tiers.\n- `references/workflow.md` — baseline-capture, explicit-pair, and snapshot lifecycle.\n- `references/accessibility-contract.md` — the report's accessibility guarantees.\n- `references/worked-example.md` — an end-to-end walkthrough using the shipped fixtures.","lineStart":1,"lineEnd":272,"totalLines":272,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/SKILL.md","time":{"start":1784210626342,"end":1784210626358}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a60819186408311794912a2"}},"id":"prt_f6b3d9724001eFdthFaJFeW7Ft","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626381,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_xfYp46epoIlvUGnYaTB4dFNp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/README.md","limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/README.md</path>\n<type>file</type>\n<content>\n1: # create-diff\n2: \n3: Local, Git-free before/after review of an edited document — text, Markdown, HTML, DOCX, or text PDF — rendered as a single self-contained, accessible HTML report.\n4: \n5: ## 1. OVERVIEW\n6: \n7: This workflow packet reviews what changed in a locally edited document without Git and without a hosted service. It captures a baseline before an edit, then compares the before and after versions and produces one self-contained HTML report (inlined CSS, zero JavaScript, no network). The comparison engine ships here as `scripts/create_diff.py`; everything runs on the machine and the source file is never modified.\n8: \n9: ## 2. WHEN TO USE\n10: \n11: Use this packet when you need to:\n12: \n13: - Review what an AI (or anyone) changed in a locally edited document.\n14: - Produce a before/after report for a Markdown, text, HTML, DOCX, or PDF file outside Git.\n15: - Capture a baseline of a document before editing it.\n16: - Compare two explicit versions of a document (old file vs. new file).\n17: \n18: Do not use it for code or Git-tracked files (use `git`/`sk-git`), for visual/design comparison (use `sk-design`), or for auditing a single existing document (use `create-quality-control`).\n19: \n20: ## 3. WHAT'S INSIDE\n21: \n22: - `SKILL.md`\n23:   The authoritative packet contract: activation triggers, routing, the diff workflow, capability tiers, rules, and success criteria.\n24: \n25: - `scripts/create_diff.py`\n26:   The comparison engine: format extraction (text, Markdown, HTML, DOCX, text PDF), deterministic line + inline word diff, content-addressed baseline snapshots, and the self-contained HTML report renderer. Python 3 standard library only (PDF optionally uses `pdftotext`/`pypdf`/`pdfplumber` when present).\n27: \n28: - `scripts/validate_report.py`\n29:   Asserts a generated report is safe and self-contained: correct doctype, `lang`, a Content-Security-Policy meta tag, zero `<script>`, no inline event handlers, and no remote resource references.\n30: \n31: - `references/`\n32:   Overflow guidance behind a route-map: `README.md` (reference map), `capabilities-and-fidelity.md` (format matrix + tiers), `workflow.md` (baseline/explicit-pair/lifecycle), `cli-reference.md` (commands, flags, exit codes), `accessibility-contract.md` (report guarantees), and `worked-example.md` (end-to-end walkthrough).\n33: \n34: - `assets/fixtures/`\n35:   A runnable before/after worked example (`onboarding-before.md`, `onboarding-after.md`) plus a short `README.md`.\n36: \n37: - `feature-catalog/`\n38:   Canonical inventory of what this mode does today: a root `feature-catalog.md` plus per-feature reference files grouped by capability area.\n39: \n40: - `manual-testing-playbook/`\n41:   Operator-facing manual validation package: a root `manual-testing-playbook.md` plus per-scenario files with deterministic prompts, commands, expected signals, and pass/fail criteria.\n42: \n43: - `changelog/`\n44:   Versioned packet changelog entries.\n45: \n46: For shared markdown standards and the document-level validator, this packet reuses `../shared` rather than duplicating them.\n47: \n48: ## 4. QUICK START\n49: \n50: `SKILL.md` holds the authoritative workflow — read it first. In brief, from this packet directory:\n51: \n52: ```bash\n53: # BEFORE the edit: capture a baseline (never touches the source)\n54: python3 scripts/create_diff.py snapshot path/to/doc.md\n55: \n56: # AFTER the edit: compare against the baseline and render the report\n57: python3 scripts/create_diff.py compare path/to/doc.md --report review.html\n58: \n59: # Or compare two explicit files (no stored state needed)\n60: python3 scripts/create_diff.py compare-pair --before old.md --after new.md --report review.html\n61: \n62: # Verify the report is safe/self-contained before handoff\n63: python3 scripts/validate_report.py review.html\n64: ```\n65: \n66: Run `python3 scripts/create_diff.py capabilities` to see supported formats and fidelity tiers. Try it against the shipped fixtures — see `assets/fixtures/README.md`.\n67: \n68: ## 5. HUB RELATIONSHIP\n69: \n70: `create-diff` is a nested workflow packet of the `sk-doc` parent hub. The shared backbone lives at `../shared`. The single advisor identity and workflow registry live at the hub root (`../mode-registry.json`, `../hub-router.json`), not inside this packet. This packet must not add packet-local advisor metadata such as `graph-metadata.json`.\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"# create-diff\n\nLocal, Git-free before/after review of an edited document — text, Markdown, HTML, DOCX, or text PDF — rendered as a single self-contained, accessible HTML report.\n\n## 1. OVERVIEW\n\nThis workflow packet reviews what changed in a locally edited document without Git and without a hosted service. It captures a baseline before an edit, then compares the before and after versions and produces one self-contained HTML report (inlined CSS, zero JavaScript, no network). The comparison engine ships here as `scripts/create_diff.py`; everything runs on the machine and the source file is never modified.\n\n## 2. WHEN TO USE\n\nUse this packet when you need to:\n\n- Review what an AI (or anyone) changed in a locally edited document.\n- Produce a before/after report for a Markdown, text, HTML, DOCX, or PDF file outside Git.\n- Capture a baseline of a document before editing it.\n- Compare two explicit versions of a document (old file vs. new file).\n\nDo not use it for code or Git-tracked files (use `git`/`sk-git`), for visual/design comparison (use `sk-design`), or for auditing a single existing document (use `create-quality-control`).\n\n## 3. WHAT'S INSIDE","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/README.md","text":"# create-diff\n\nLocal, Git-free before/after review of an edited document — text, Markdown, HTML, DOCX, or text PDF — rendered as a single self-contained, accessible HTML report.\n\n## 1. OVERVIEW\n\nThis workflow packet reviews what changed in a locally edited document without Git and without a hosted service. It captures a baseline before an edit, then compares the before and after versions and produces one self-contained HTML report (inlined CSS, zero JavaScript, no network). The comparison engine ships here as `scripts/create_diff.py`; everything runs on the machine and the source file is never modified.\n\n## 2. WHEN TO USE\n\nUse this packet when you need to:\n\n- Review what an AI (or anyone) changed in a locally edited document.\n- Produce a before/after report for a Markdown, text, HTML, DOCX, or PDF file outside Git.\n- Capture a baseline of a document before editing it.\n- Compare two explicit versions of a document (old file vs. new file).\n\nDo not use it for code or Git-tracked files (use `git`/`sk-git`), for visual/design comparison (use `sk-design`), or for auditing a single existing document (use `create-quality-control`).\n\n## 3. WHAT'S INSIDE\n\n- `SKILL.md`\n  The authoritative packet contract: activation triggers, routing, the diff workflow, capability tiers, rules, and success criteria.\n\n- `scripts/create_diff.py`\n  The comparison engine: format extraction (text, Markdown, HTML, DOCX, text PDF), deterministic line + inline word diff, content-addressed baseline snapshots, and the self-contained HTML report renderer. Python 3 standard library only (PDF optionally uses `pdftotext`/`pypdf`/`pdfplumber` when present).\n\n- `scripts/validate_report.py`\n  Asserts a generated report is safe and self-contained: correct doctype, `lang`, a Content-Security-Policy meta tag, zero `<script>`, no inline event handlers, and no remote resource references.\n\n- `references/`\n  Overflow guidance behind a route-map: `README.md` (reference map), `capabilities-and-fidelity.md` (format matrix + tiers), `workflow.md` (baseline/explicit-pair/lifecycle), `cli-reference.md` (commands, flags, exit codes), `accessibility-contract.md` (report guarantees), and `worked-example.md` (end-to-end walkthrough).\n\n- `assets/fixtures/`\n  A runnable before/after worked example (`onboarding-before.md`, `onboarding-after.md`) plus a short `README.md`.\n\n- `feature-catalog/`\n  Canonical inventory of what this mode does today: a root `feature-catalog.md` plus per-feature reference files grouped by capability area.\n\n- `manual-testing-playbook/`\n  Operator-facing manual validation package: a root `manual-testing-playbook.md` plus per-scenario files with deterministic prompts, commands, expected signals, and pass/fail criteria.\n\n- `changelog/`\n  Versioned packet changelog entries.\n\nFor shared markdown standards and the document-level validator, this packet reuses `../shared` rather than duplicating them.\n\n## 4. QUICK START\n\n`SKILL.md` holds the authoritative workflow — read it first. In brief, from this packet directory:\n\n```bash\n# BEFORE the edit: capture a baseline (never touches the source)\npython3 scripts/create_diff.py snapshot path/to/doc.md\n\n# AFTER the edit: compare against the baseline and render the report\npython3 scripts/create_diff.py compare path/to/doc.md --report review.html\n\n# Or compare two explicit files (no stored state needed)\npython3 scripts/create_diff.py compare-pair --before old.md --after new.md --report review.html\n\n# Verify the report is safe/self-contained before handoff\npython3 scripts/validate_report.py review.html\n```\n\nRun `python3 scripts/create_diff.py capabilities` to see supported formats and fidelity tiers. Try it against the shipped fixtures — see `assets/fixtures/README.md`.\n\n## 5. HUB RELATIONSHIP\n\n`create-diff` is a nested workflow packet of the `sk-doc` parent hub. The shared backbone lives at `../shared`. The single advisor identity and workflow registry live at the hub root (`../mode-registry.json`, `../hub-router.json`), not inside this packet. This packet must not add packet-local advisor metadata such as `graph-metadata.json`.","lineStart":1,"lineEnd":70,"totalLines":70,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/README.md","time":{"start":1784210626349,"end":1784210626359}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a788191ade0abdc1f2a5efa"}},"id":"prt_f6b3d972c001bbN69AykTujZj6","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626382,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_l2HzadCM34W5ZIB12bECMUhX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_diff_auto.yaml","limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_diff_auto.yaml</path>\n<type>file</type>\n<content>\n1: # -----------------------------------------------------------------\n2: # OPENCODE CREATE: DOCUMENT DIFF WORKFLOW (AUTO MODE)\n3: # -----------------------------------------------------------------\n4: # Mode: autonomous (no user approval gates)\n5: # Note: This workflow executes all steps sequentially with\n6: #       continuous self-validation. Pauses only if confidence < 40%\n7: #       or a required input is missing/unsafe.\n8: # -----------------------------------------------------------------\n9: role: Expert Document Diff Author using sk-doc create-diff packet\n10: purpose: Produce a validated, self-contained before/after document diff HTML report with a 5-step workflow\n11: action: Wrap the create-diff engine from input verification through comparison, report validation, and delivery\n12: \n13: # -----------------------------------------------------------------\n14: # PREREQUISITE: CREATE-DIFF PACKET VERIFICATION\n15: # -----------------------------------------------------------------\n16: # This workflow REQUIRES the create-diff packet for:\n17: #   - Local, Git-free before/after document comparison\n18: #   - Baseline snapshot capture and self-contained HTML rendering\n19: #   - Report safety/self-containment validation\n20: #\n21: # PHASE 0 in the presentation contract verifies the packet resources\n22: # BEFORE this YAML workflow loads. If you're executing this workflow,\n23: # create-diff verification has already passed.\n24: #\n25: # NEVER re-implement diffing, extraction, snapshotting, or rendering;\n26: # always call the engine. Run it from the workspace root so the report\n27: # and the local `.create-diff` snapshot store resolve against the root.\n28: #\n29: # To invoke correctly: /create:diff <target-document | --before old --after new> [--report out.html]\n30: # -----------------------------------------------------------------\n31: \n32: operating_mode:\n33:   workflow: sequential_5_step\n34:   workflow_compliance: MANDATORY\n35:   workflow_execution: autonomous\n36:   approvals: none\n37:   tracking: progressive_task_checklists\n38:   validation: continuous_self_validation\n39:   output_configuration: self_contained_html_report\n40:   description: |\n41:     Executes the 5-step document diff workflow without step-by-step approval.\n42:     Pauses only if confidence drops below threshold, a required input is missing or unsafe, or validation fails.\n43: \n44: development_philosophy:\n45:   principle: \"Capture the real before-state, then let the engine report the change\"\n46:   approach: \"Verify inputs -> Check capability -> Compare via engine -> Validate report -> Deliver\"\n47:   mandate: \"Never mutate the source document; never present a limited-fidelity comparison as complete\"\n48: \n49: report_path_resolution:\n50:   default: \"<document-stem>.diff.html in the current directory\"\n51:   required_extension: .html\n52: \n53: # -----------------------------------------------------------------\n54: # CONFIDENCE & CLARIFICATION FRAMEWORK\n55: # -----------------------------------------------------------------\n56: confidence_framework:\n57:   thresholds:\n58:     high: { range: \"80-100%\", action: \"Proceed with citable source\" }\n59:     medium: { range: \"40-79%\", action: \"Proceed with caution, document assumptions\" }\n60:     low: { range: \"0-39%\", action: \"STOP - Ask clarification with A/B/C options\" }\n61: \n62:   scoring_weights:\n63:     document_path_clarity: 0.30\n64:     review_mode_clarity: 0.30\n65:     format_supported: 0.20\n66:     report_path_clarity: 0.20\n67: \n68:   clarification_format: |\n69:     \"I need clarity (confidence: [NN%]). Which approach:\n70:     - A) [option with brief rationale]\n71:     - B) [option with brief rationale]\n72:     - C) [option with brief rationale]\"\n73: \n74:   escalation:\n75:     timebox_minutes: 10\n76:     failed_attempts_threshold: 2\n77:     action: \"Present options to user with current findings\"\n78: \n79: # -----------------------------------------------------------------\n80: # REQUEST ANALYSIS FRAMEWORK\n81: # -----------------------------------------------------------------\n82: request_analysis_framework:\n83:   code_search_note: \"Use Glob/Grep to locate the target document and any prior report. Read files before comparing. Do not use memory search for arbitrary code or docs.\"\n84:   solution_flow:\n85:   - \"Parse carefully: Is this a document before/after review, and in which mode (automatic baseline vs explicit pair)?\"\n86:   - \"Gather Context: Confirm the document path(s) exist and are readable\"\n87:   - \"Identify Approach: SIMPLEST engine invocation that answers the change question\"\n88:   - \"Validate Choice: Confirm the format is supported at a stated fidelity tier\"\n89:   - \"Clarify If Needed: If <80% confidence or a path is unknown, ask\"\n90:   - \"Scope Check: Producing ONLY the requested HTML report, leaving the source unchanged?\"\n91:   - \"Execute: Compare via engine, validate the report, and report the change summary\"\n92: \n93:   pre_change_validation:\n94:     items:\n95:     - \"Document path (automatic) or --before/--after pair (explicit) provided and existing?\"\n96:     - \"Review mode determined (automatic baseline vs explicit pair)?\"\n97:     - \"Report output path resolved (explicit or engine default)?\"\n98:     - \"Format supported, or explicit-pair fallback available for an unsupported format?\"\n99:     - \"Confidence >=80%? (if not: ask)\"\n100:     stop_conditions: [ \"Any item unchecked\", \"Unknown document or report path that would be a guess\" ]\n101:     stop_action: \"STOP and address before proceeding\"\n102: \n103: # -----------------------------------------------------------------\n104: # USER INPUTS (From gate outputs)\n105: # -----------------------------------------------------------------\n106: user_inputs:\n107:   review_mode: |\n108:     [REVIEW_MODE]\n109:     Either 'automatic' (snapshot the current file, then compare after an edit) or\n110:     'explicit-pair' (compare a known --before file against a --after file).\n111:     FROM UNIFIED SETUP PHASE (Q1 or derived from arguments).\n112: \n113:   target_document: |\n114:     [TARGET_DOCUMENT]\n115:     Workspace-relative path of the document under review. Required when review_mode=automatic.\n116:     FROM UNIFIED SETUP PHASE (Q0 or command argument).\n117: \n118:   before_file: |\n119:     [BEFORE_FILE]\n120:     Old version path. Required when review_mode=explicit-pair.\n121:     FROM UNIFIED SETUP PHASE (--before or marker).\n122: \n123:   after_file: |\n124:     [AFTER_FILE]\n125:     New version path. Required when review_mode=explicit-pair.\n126:     FROM UNIFIED SETUP PHASE (--after or marker).\n127: \n128:   report_path: |\n129:     [REPORT_PATH]\n130:     Output HTML path. Defaults to <document-stem>.diff.html when omitted.\n131:     FROM UNIFIED SETUP PHASE (Q2, --report, or engine default).\n132: \n133:   view: |\n134:     [VIEW]\n135:     Report layout: 'unified' (default) or 'side-by-side'.\n136:     FROM UNIFIED SETUP PHASE (Q3 or --view).\n137: \n138: # -----------------------------------------------------------------\n139: # FIELD HANDLING\n140: # -----------------------------------------------------------------\n141: field_handling:\n142:   review_mode:\n143:     validation: \"must be one of: automatic, explicit-pair\"\n144:     default: \"derive_from_arguments\"\n145:     note: \"--before/--after implies explicit-pair; a single document target implies automatic\"\n146: \n147:   report_path:\n148:     validation: \"workspace-relative path ending in .html, or omitted for the engine default\"\n149:     required: false\n150: \n151:   view:\n152:     validation: \"must be one of: unified, side-by-side\"\n153:     default: \"unified\"\n154: \n155:   defaults:\n156:     output_format: \"single self-contained HTML report (inlined CSS, no scripts, no network)\"\n157:     engine_command: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py\"\n158:     validator_command: \"python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report_path]\"\n159: \n160: input_contract:\n161:   required:\n162:     - create_diff_verified\n163:     - review_mode\n164:   conditional:\n165:     - target_document   # required when review_mode=automatic\n166:     - before_file       # required when review_mode=explicit-pair\n167:     - after_file        # required when review_mode=explicit-pair\n168:   optional:\n169:     - report_path\n170:     - view\n171: \n172: # -----------------------------------------------------------------\n173: # DOCUMENTATION LEVEL\n174: # -----------------------------------------------------------------\n175: documentation_level:\n176:   default: \"No separate spec packet for ordinary document diff review\"\n177:   required_files:\n178:   - report_path\n179:   note: \"The command output is a single self-contained HTML report unless the user explicitly asks for surrounding documentation.\"\n180: \n181: # -----------------------------------------------------------------\n182: # CREATE-DIFF RESOURCES\n183: # -----------------------------------------------------------------\n184: diff_resources:\n185:   skill_contract: .opencode/skills/sk-doc/create-diff/SKILL.md\n186: \n187: diff_scripts:\n188:   create_diff_engine: .opencode/skills/sk-doc/create-diff/scripts/create_diff.py\n189:   validate_report: .opencode/skills/sk-doc/create-diff/scripts/validate_report.py\n190: \n191: diff_references:\n192:   route_map: .opencode/skills/sk-doc/create-diff/references/README.md\n193:   cli_reference: .opencode/skills/sk-doc/create-diff/references/cli-reference.md\n194:   capabilities_and_fidelity: .opencode/skills/sk-doc/create-diff/references/capabilities-and-fidelity.md\n195:   workflow: .opencode/skills/sk-doc/create-diff/references/workflow.md\n196:   accessibility_contract: .opencode/skills/sk-doc/create-diff/references/accessibility-contract.md\n197:   worked_example: .opencode/skills/sk-doc/create-diff/references/worked-example.md\n198: \n199: # -----------------------------------------------------------------\n200: # ENGINE COMMAND REFERENCE (authoritative flags from cli-reference.md)\n201: # -----------------------------------------------------------------\n202: engine_commands:\n203:   capabilities: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py capabilities [--json]\"\n204:   snapshot: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py snapshot <file> [--state-dir DIR]\"\n205:   compare: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare <file> [--report OUT] [--view unified|side-by-side] [--state-dir DIR] [--json]\"\n206:   compare_pair: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare-pair --before A --after B [--report OUT] [--view unified|side-by-side] [--label-before L] [--label-after L] [--json]\"\n207:   status: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py status [<file>] [--state-dir DIR] [--json]\"\n208:   validate: \"python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py <report.html> [more.html ...]\"\n209: \n210: # -----------------------------------------------------------------\n211: # WORKFLOW ENFORCEMENT (CRITICAL)\n212: # -----------------------------------------------------------------\n213: workflow_enforcement:\n214:   mode: strict\n215:   step_order: sequential_mandatory\n216:   skip_allowed: false\n217: \n218:   phase_gate:\n219:     location: \"Between Step 1 and Step 3 (comparison)\"\n220:     purpose: \"Verify inputs and format capability before invoking the engine\"\n221:     requirements:\n222:     - \"Document path(s) confirmed to exist\"\n223:     - \"Review mode resolved\"\n224:     - \"Format supported or explicit-pair fallback selected\"\n225:     action_if_failed: \"STOP and return to the incomplete step\"\n226: \n227:   critical_steps:\n228:     step_1_input_verification:\n229:       enforcement: \"MUST confirm document path(s), review mode, report path, and view; never guess an unknown path\"\n230:       verification: \"Self-validate inputs before proceeding\"\n231:     step_3_comparison:\n232:       enforcement: \"MUST call the engine (snapshot+compare or compare-pair); NEVER re-implement diffing\"\n233:       verification: \"Engine exit code captured and mapped to an actionable message\"\n234:     step_4_report_validation:\n235:       enforcement: \"MUST run validate_report.py on the generated report\"\n236:       verification: \"Validator exits 0, or the failure is fixed/reported before delivery\"\n237: \n238: gate_logic:\n239:   hard:\n240:     H0_diff_verified:\n241:       description: \"create-diff packet resource verification must have passed in Phase 0\"\n242:       fail_action: \"STOP and return to the command setup phase\"\n243:     H1_required_fields:\n244:       description: \"Required setup fields for the resolved review mode must be present before comparison\"\n245:       fail_action: \"STOP and collect missing inputs\"\n246:     H2_source_immutable:\n247:       description: \"The source document must never be modified by capture or comparison\"\n248:       fail_action: \"STOP if any engine step would write to the source; comparison is read-only against it\"\n249:     H3_report_validation:\n250:       description: \"Generated report must pass validate_report.py before delivery\"\n251:       fail_action: \"Fix the renderer output or report the failure; do not claim a clean self-contained report\"\n252:   soft:\n253:     S1_low_fidelity:\n254:       description: \"Warn when the format resolves to a text-only tier (html, docx, pdf text layer)\"\n255:       fail_action: \"State the fidelity tier; never present it as capturing formatting/layout/tracked changes\"\n256:     S2_existing_report:\n257:       description: \"Warn when the report path already exists\"\n258:       fail_action: \"Proceed only after explicit overwrite intent\"\n259: \n260: # -----------------------------------------------------------------\n261: # CONTEXT LOADING\n262: # -----------------------------------------------------------------\n263: context_loading:\n264:   trigger: \"During UNIFIED SETUP PHASE, non-interactive resolution before Step 1\"\n265:   applies_when: \"an existing baseline may be present for the target document, OR a prior report exists at the report path, OR the request names specific before/after files\"\n266:   auto_resolution:\n267:     default: \"If review_mode=automatic, run `status <file>` to detect an existing baseline; if one exists, compare against it, else snapshot first. If review_mode=explicit-pair, load only the named --before/--after files. Otherwise skip discovery.\"\n268:     override: \"Honor an explicit --state-dir when supplied as a command argument or pre-bound marker\"\n269:   tool_integration:\n270:     primary: \"Glob/Grep to locate the target document, before/after files, and any prior report; Read matches before reuse\"\n271:     engine_state_probe: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py status [<file>] --json\"\n272:   output: baseline_state\n273: \n274: # -----------------------------------------------------------------\n275: # WORKFLOW (5 STEPS - AUTONOMOUS)\n276: # -----------------------------------------------------------------\n277: workflow_overview:\n278:   steps:\n279:     - id: step_1_input_verification\n280:       purpose: \"Confirm document path(s), review mode, report path, and view; refuse to guess unknown paths\"\n281:     - id: step_2_capability_check\n282:       purpose: \"Optionally confirm format support and fidelity tier before comparing\"\n283:     - id: step_3_comparison\n284:       purpose: \"Run the engine: automatic snapshot+compare, or explicit compare-pair\"\n285:     - id: step_4_report_validation\n286:       purpose: \"Validate the generated report is safe and self-contained\"\n287:     - id: step_5_delivery\n288:       purpose: \"Emit final status with report path, change summary, fidelity tier, and validator result\"\n289: \n290: workflow:\n291:   # ==============================================================\n292:   # STEP 1: INPUT VERIFICATION\n293:   # ==============================================================\n294:   step_1_input_verification:\n295:     purpose: Confirm inputs from the UNIFIED SETUP PHASE and validate paths (DO NOT GUESS)\n296:     activities:\n297:     - Confirm review_mode from UNIFIED SETUP PHASE (Q1 or derived from arguments)\n298:     - \"IF review_mode=automatic: confirm target_document exists and is readable\"\n299:     - \"IF review_mode=explicit-pair: confirm before_file and after_file exist and are readable\"\n300:     - Resolve report_path (explicit .html path or the engine default <document-stem>.diff.html)\n301:     - Resolve view (unified default or side-by-side)\n302:     - Probe baseline_state via `status` when review_mode=automatic\n303:     validation:\n304:       path_existence: \"each named document path must exist on disk\"\n305:       report_format: \"report_path, when explicit, ends in .html\"\n306:       refuse_guess: \"STOP if any required path is unknown; ask rather than assume\"\n307:     outputs:\n308:     - inputs_confirmed\n309:     - review_mode_resolved\n310:     - baseline_state\n311:     - report_path_resolved\n312: \n313:   # ==============================================================\n314:   # PHASE GATE: INPUTS -> COMPARISON\n315:   # ==============================================================\n316:   # ==============================================================\n317:   # STEP 2: CAPABILITY CHECK\n318:   # ==============================================================\n319:   step_2_capability_check:\n320:     purpose: Confirm format support and fidelity tier when uncertain\n321:     condition: \"run when the input format is uncertain (e.g. DOCX or PDF) or before a first comparison\"\n322:     activities:\n323:     - \"Run: python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py capabilities [--json]\"\n324:     - \"Determine the fidelity tier for the input format (full / text / text*)\"\n325:     - \"IF the format is a text-layer PDF and no extractor is available (exit 3): do not claim a diff; offer the explicit-pair fallback with pre-extracted text\"\n326:     - \"Record the fidelity tier to state honestly at delivery\"\n327:     outputs:\n328:     - capability_confirmed\n329:     - fidelity_tier\n330: \n331:   phase_gate_inputs_to_comparison:\n332:     trigger: \"After Step 1 and Step 2 complete\"\n333:     enforcement: HARD_BLOCK\n334:     verification: |\n335:       BEFORE invoking the engine (Step 3):\n336: \n337:       VERIFY all input artifacts exist:\n338:       - [ ] Review mode resolved\n339:       - [ ] Document path (automatic) or --before/--after pair (explicit) confirmed to exist\n340:       - [ ] Report path resolved\n341:       - [ ] Format supported, or explicit-pair fallback selected for an unsupported format\n342: \n343:       IF any artifact missing:\n344:       - STOP -> Return to Step 1/Step 2 -> Complete it -> Return here\n345: \n346:       WHEN all artifacts verified:\n347:       - SET PHASE GATE STATUS: PASSED -> Proceed to Step 3\n348:     action_if_failed: \"Return to incomplete step\"\n349: \n350:   # ==============================================================\n351:   # STEP 3: COMPARISON (ENGINE-DRIVEN)\n352:   # ==============================================================\n353:   step_3_comparison:\n354:     purpose: Invoke the create-diff engine to compare versions and render the report\n355:     enforcement: MANDATORY\n356:     activities:\n357:     - \"NEVER re-implement diffing, extraction, or rendering; always call the engine\"\n358:     branch_automatic_baseline:\n359:       when: \"review_mode=automatic\"\n360:       steps:\n361:       - \"IF a baseline already exists (from baseline_state): skip snapshot\"\n362:       - \"ELSE capture a baseline BEFORE the edit: python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py snapshot <target_document> [--state-dir DIR]\"\n363:       - \"... allow the edit to happen (AI or human) between snapshot and compare ...\"\n364:       - \"AFTER the edit, compare and render: python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare <target_document> --report <report_path> [--view side-by-side] [--state-dir DIR] --json\"\n365:       invariant: \"The baseline must be captured before the edit; a compare with no baseline exits 4\"\n366:     branch_explicit_pair:\n367:       when: \"review_mode=explicit-pair\"\n368:       steps:\n369:       - \"Compare two explicit files (no stored state): python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare-pair --before <before_file> --after <after_file> --report <report_path> [--view side-by-side] [--label-before L] [--label-after L] --json\"\n370:     exit_code_handling:\n371:       \"0\": \"Success - capture the JSON change summary and continue to Step 4\"\n372:       \"2\": \"Usage error (bad arguments) - fix the invocation and re-run\"\n373:       \"3\": \"Unsupported/limited format with no fallback (e.g. PDF with no extractor) - STOP with an actionable message; offer explicit-pair with pre-extracted text\"\n374:       \"4\": \"Missing baseline snapshot for compare - capture a snapshot first, or switch to compare-pair\"\n375:       \"5\": \"I/O or extraction failure - STOP and report the failing path/cause\"\n376:     outputs:\n377:     - comparison_complete\n378:     - change_summary   # added / removed / changed / possible_moves / total_changes / identical\n379:     - report_written\n380:     validation: engine_exit_zero\n381: \n382:   # ==============================================================\n383:   # STEP 4: REPORT VALIDATION\n384:   # ==============================================================\n385:   step_4_report_validation:\n386:     purpose: Validate the generated report is safe and self-contained\n387:     enforcement: HARD_BLOCK\n388:     activities:\n389:     - \"Run: python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py <report_path>\"\n390:     - \"Expect exit 0 (asserts doctype, <html lang>, a Content-Security-Policy meta tag, zero <script> tags, no inline event handlers, no remote href/src)\"\n391:     - \"IF the validator exits 1: STOP - do not claim a clean self-contained report; report the specific failure\"\n392:     - \"Confirm the source document is byte-for-byte unchanged (comparison is read-only against it)\"\n393:     validation_command: |\n394:       python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report_path]\n395:     quality_gates:\n396:       validator_exit: \"must be 0 before clean delivery\"\n397:       source_immutable: \"source document unchanged by capture or comparison\"\n398:       enforcement: HARD_BLOCK\n399:     fix_workflow: |\n400:       IF validation fails:\n401:       1. Review the exact validator output.\n402:       2. Fix the renderer output or re-run the comparison.\n403:       3. Re-run the validator command.\n404:       4. Repeat until passing, or report the failure explicitly.\n405:     outputs:\n406:     - report_validation_result: pass_or_fail\n407:     - validation_errors: list_if_failed\n408:     validation: report_safe\n409: \n410:   # ==============================================================\n411:   # STEP 5: DELIVERY\n412:   # ==============================================================\n413:   step_5_delivery:\n414:     purpose: Emit completion status with report path and evidence\n415:     condition: \"report_path is not null and report validation passed\"\n416:     activities:\n417:     - Ensure the output remains a single self-contained HTML report\n418:     - Record review mode, report path, change summary, fidelity tier, and validator result in the delivery summary\n419:     - State the fidelity tier honestly; never present a text-tier comparison as capturing formatting or layout\n420:     - Do not create packet-local advisor metadata or extra output files\n421:     outputs:\n422:     - delivery_summary: \"report path, change summary, fidelity tier, and validation evidence\"\n423:     validation: delivery_ready\n424: \n425:     validation_evidence:\n426:       validator: .opencode/skills/sk-doc/create-diff/scripts/validate_report.py\n427:       invocation: |\n428:         python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report_path]\n429:       critical_note: \"Run the report validator directly before delivery. Do not claim a clean, self-contained report if the command fails or exits non-zero.\"\n430:       when: \"Immediately after the report is written\"\n431: \n432:     anchor_requirements:\n433:       enforcement: NOT_APPLICABLE\n434:       rationale: \"The command creates a single HTML report, not a memory packet.\"\n435: \n436:     importance_tier:\n437:       assign: normal\n438:       rationale: \"Document diff review is artifact-scoped unless the user requests durable project memory.\"\n439:       promotion_note: \"Promote only if the report becomes authoritative project documentation.\"\n440: \n441: # -----------------------------------------------------------------\n442: # CIRCUIT BREAKER\n443: # -----------------------------------------------------------------\n444: circuit_breaker:\n445:   consecutive_failure_threshold: 3\n446:   states:\n447:     closed: \"Normal operation\"\n448:     open: \"3+ failures - pause and report to user\"\n449:     half_open: \"Test with single retry before resuming\"\n450:   on_open:\n451:     action: \"Report failures to user with summary\"\n452:     suggest: \"Review inputs and try again, or escalate\"\n453: \n454: # -----------------------------------------------------------------\n455: # ERROR RECOVERY (maps engine exit codes to actionable messages)\n456: # -----------------------------------------------------------------\n457: error_recovery:\n458:   unknown_document_path:\n459:     action: \"Show valid format (workspace-relative path), prompt for the correct document; never guess\"\n460:     example: \"Expected: docs/notes/proposal.md\"\n461:   usage_error:\n462:     exit_code: 2\n463:     action: \"Correct the arguments per references/cli-reference.md and re-run\"\n464:   unsupported_or_limited_format:\n465:     exit_code: 3\n466:     action: \"Explain the format is unsupported/limited with no fallback (e.g. a PDF with no text extractor); offer compare-pair with pre-extracted text\"\n467:   missing_baseline:\n468:     exit_code: 4\n469:     action: \"No baseline snapshot exists for compare; capture one with `snapshot <file>` first, or use compare-pair --before/--after\"\n470:   io_or_extraction_failure:\n471:     exit_code: 5\n472:     action: \"Report the failing path or extraction cause; do not claim a diff was produced\"\n473:   report_validation_failure:\n474:     validator_exit: 1\n475:     action: \"Report is not safe/self-contained; fix the renderer output or report the failure. Never claim a clean report\"\n476:   scanned_pdf:\n477:     action: \"A PDF with no text layer would yield an empty comparison; OCR is out of scope - escalate\"\n478: \n479: # -----------------------------------------------------------------\n480: # AUTONOMOUS EXECUTION\n481: # -----------------------------------------------------------------\n482: autonomous_execution:\n483:   validation_approach: \"Continuous self-validation at each step\"\n484:   error_handling: \"Auto-recover if possible, halt on critical failures and unmapped exit codes\"\n485:   progress_reporting: \"Brief status updates between steps\"\n486: \n487: # -----------------------------------------------------------------\n488: # QUALITY STANDARDS\n489: # -----------------------------------------------------------------\n490: quality_standards:\n491:   report_validation: MANDATORY\n492:   validation_enforcement: HARD_BLOCK\n493:   validation_pipeline:\n494:     stage_1: \"Engine comparison exits 0\"\n495:     stage_2: \"Report safety/self-containment validator exits 0\"\n496:     stage_3: \"Source document confirmed unchanged\"\n497:     stage_4: \"Fidelity tier stated honestly\"\n498:   template_adherence: required\n499:   core_standards_reference: \".opencode/skills/sk-doc/create-diff/SKILL.md\"\n500: \n501: # -----------------------------------------------------------------\n502: # COMPLETION REPORT TEMPLATE\n503: # -----------------------------------------------------------------\n504: completion_report:\n505:   template: |\n506:     Document Diff Complete\n507: \n508:     Review Mode: [automatic-baseline | explicit-pair]\n509:     Report: [report-path]\n510: \n511:     Compared:\n512:     - Automatic: [target-document] (baseline -> current)\n513:     - Explicit pair: before=[before-file] after=[after-file]\n514: \n515:     Changes:\n516:     - Added:   [+N]\n517:     - Removed: [-N]\n518:     - Changed: [~N]\n519:     - Possible moves: [N]\n520:     - Fidelity tier: [full | text | text*]\n521: \n522:     Validation:\n523:     - Command: python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report-path]\n524:     - Result: PASS\n525: \n526:     Output:\n527:     - Single self-contained HTML report (no scripts, no network)\n528:     - Source document unchanged\n529: \n530:     STATUS=OK PATH=[report-path]\n531: \n532: # -----------------------------------------------------------------\n533: # TERMINATION\n534: # -----------------------------------------------------------------\n535: termination:\n536:   after_step: step_5_delivery\n537:   message: \"Document diff workflow complete.\"\n538:   next_steps:\n539:     - condition: \"Further edits are planned\"\n540:       action: \"Capture a fresh baseline before the next edit, then compare again\"\n541:     - condition: \"The report should be shared\"\n542:       action: \"The HTML report is self-contained and safe to open or send as-is\"\n543:     - condition: \"A limited-fidelity tier was used\"\n544:       action: \"Note what was not compared (formatting, layout, tracked changes) to the reader\"\n545: \n546: # -----------------------------------------------------------------\n547: # RULES\n548: # -----------------------------------------------------------------\n549: rules:\n550:   ALWAYS:\n551:     - \"Call the create-diff engine for all comparison, extraction, snapshotting, and rendering\"\n552:     - \"Capture the baseline before the edit in automatic mode\"\n553:     - \"Run validate_report.py before claiming delivery\"\n554:     - \"State the fidelity tier and any warnings honestly\"\n555:     - \"Keep everything local - no network, upload, or telemetry\"\n556:     - \"Read a file before editing; never modify the source document during comparison\"\n557:     - \"Map engine exit codes (2/3/4/5) to actionable messages\"\n558:     - \"Report the exact validation command and result\"\n559:   NEVER:\n560:     - \"Re-implement diffing, extraction, snapshotting, or rendering\"\n561:     - \"Guess an unknown document, baseline state, or report path\"\n562:     - \"Mutate, overwrite, or fix up the source document\"\n563:     - \"Present a text-tier comparison as if it captured formatting, layout, or tracked changes\"\n564:     - \"Claim a diff was produced when the format was unsupported and no fallback ran\"\n565:     - \"Claim a clean report when validate_report.py fails\"\n566:     - \"Create packet-local advisor metadata\"\n\n(End of file - total 566 lines)\n</content>","metadata":{"preview":"# -----------------------------------------------------------------\n# OPENCODE CREATE: DOCUMENT DIFF WORKFLOW (AUTO MODE)\n# -----------------------------------------------------------------\n# Mode: autonomous (no user approval gates)\n# Note: This workflow executes all steps sequentially with\n#       continuous self-validation. Pauses only if confidence < 40%\n#       or a required input is missing/unsafe.\n# -----------------------------------------------------------------\nrole: Expert Document Diff Author using sk-doc create-diff packet\npurpose: Produce a validated, self-contained before/after document diff HTML report with a 5-step workflow\naction: Wrap the create-diff engine from input verification through comparison, report validation, and delivery\n\n# -----------------------------------------------------------------\n# PREREQUISITE: CREATE-DIFF PACKET VERIFICATION\n# -----------------------------------------------------------------\n# This workflow REQUIRES the create-diff packet for:\n#   - Local, Git-free before/after document comparison\n#   - Baseline snapshot capture and self-contained HTML rendering\n#   - Report safety/self-containment validation\n#","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_diff_auto.yaml","text":"# -----------------------------------------------------------------\n# OPENCODE CREATE: DOCUMENT DIFF WORKFLOW (AUTO MODE)\n# -----------------------------------------------------------------\n# Mode: autonomous (no user approval gates)\n# Note: This workflow executes all steps sequentially with\n#       continuous self-validation. Pauses only if confidence < 40%\n#       or a required input is missing/unsafe.\n# -----------------------------------------------------------------\nrole: Expert Document Diff Author using sk-doc create-diff packet\npurpose: Produce a validated, self-contained before/after document diff HTML report with a 5-step workflow\naction: Wrap the create-diff engine from input verification through comparison, report validation, and delivery\n\n# -----------------------------------------------------------------\n# PREREQUISITE: CREATE-DIFF PACKET VERIFICATION\n# -----------------------------------------------------------------\n# This workflow REQUIRES the create-diff packet for:\n#   - Local, Git-free before/after document comparison\n#   - Baseline snapshot capture and self-contained HTML rendering\n#   - Report safety/self-containment validation\n#\n# PHASE 0 in the presentation contract verifies the packet resources\n# BEFORE this YAML workflow loads. If you're executing this workflow,\n# create-diff verification has already passed.\n#\n# NEVER re-implement diffing, extraction, snapshotting, or rendering;\n# always call the engine. Run it from the workspace root so the report\n# and the local `.create-diff` snapshot store resolve against the root.\n#\n# To invoke correctly: /create:diff <target-document | --before old --after new> [--report out.html]\n# -----------------------------------------------------------------\n\noperating_mode:\n  workflow: sequential_5_step\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_task_checklists\n  validation: continuous_self_validation\n  output_configuration: self_contained_html_report\n  description: |\n    Executes the 5-step document diff workflow without step-by-step approval.\n    Pauses only if confidence drops below threshold, a required input is missing or unsafe, or validation fails.\n\ndevelopment_philosophy:\n  principle: \"Capture the real before-state, then let the engine report the change\"\n  approach: \"Verify inputs -> Check capability -> Compare via engine -> Validate report -> Deliver\"\n  mandate: \"Never mutate the source document; never present a limited-fidelity comparison as complete\"\n\nreport_path_resolution:\n  default: \"<document-stem>.diff.html in the current directory\"\n  required_extension: .html\n\n# -----------------------------------------------------------------\n# CONFIDENCE & CLARIFICATION FRAMEWORK\n# -----------------------------------------------------------------\nconfidence_framework:\n  thresholds:\n    high: { range: \"80-100%\", action: \"Proceed with citable source\" }\n    medium: { range: \"40-79%\", action: \"Proceed with caution, document assumptions\" }\n    low: { range: \"0-39%\", action: \"STOP - Ask clarification with A/B/C options\" }\n\n  scoring_weights:\n    document_path_clarity: 0.30\n    review_mode_clarity: 0.30\n    format_supported: 0.20\n    report_path_clarity: 0.20\n\n  clarification_format: |\n    \"I need clarity (confidence: [NN%]). Which approach:\n    - A) [option with brief rationale]\n    - B) [option with brief rationale]\n    - C) [option with brief rationale]\"\n\n  escalation:\n    timebox_minutes: 10\n    failed_attempts_threshold: 2\n    action: \"Present options to user with current findings\"\n\n# -----------------------------------------------------------------\n# REQUEST ANALYSIS FRAMEWORK\n# -----------------------------------------------------------------\nrequest_analysis_framework:\n  code_search_note: \"Use Glob/Grep to locate the target document and any prior report. Read files before comparing. Do not use memory search for arbitrary code or docs.\"\n  solution_flow:\n  - \"Parse carefully: Is this a document before/after review, and in which mode (automatic baseline vs explicit pair)?\"\n  - \"Gather Context: Confirm the document path(s) exist and are readable\"\n  - \"Identify Approach: SIMPLEST engine invocation that answers the change question\"\n  - \"Validate Choice: Confirm the format is supported at a stated fidelity tier\"\n  - \"Clarify If Needed: If <80% confidence or a path is unknown, ask\"\n  - \"Scope Check: Producing ONLY the requested HTML report, leaving the source unchanged?\"\n  - \"Execute: Compare via engine, validate the report, and report the change summary\"\n\n  pre_change_validation:\n    items:\n    - \"Document path (automatic) or --before/--after pair (explicit) provided and existing?\"\n    - \"Review mode determined (automatic baseline vs explicit pair)?\"\n    - \"Report output path resolved (explicit or engine default)?\"\n    - \"Format supported, or explicit-pair fallback available for an unsupported format?\"\n    - \"Confidence >=80%? (if not: ask)\"\n    stop_conditions: [ \"Any item unchecked\", \"Unknown document or report path that would be a guess\" ]\n    stop_action: \"STOP and address before proceeding\"\n\n# -----------------------------------------------------------------\n# USER INPUTS (From gate outputs)\n# -----------------------------------------------------------------\nuser_inputs:\n  review_mode: |\n    [REVIEW_MODE]\n    Either 'automatic' (snapshot the current file, then compare after an edit) or\n    'explicit-pair' (compare a known --before file against a --after file).\n    FROM UNIFIED SETUP PHASE (Q1 or derived from arguments).\n\n  target_document: |\n    [TARGET_DOCUMENT]\n    Workspace-relative path of the document under review. Required when review_mode=automatic.\n    FROM UNIFIED SETUP PHASE (Q0 or command argument).\n\n  before_file: |\n    [BEFORE_FILE]\n    Old version path. Required when review_mode=explicit-pair.\n    FROM UNIFIED SETUP PHASE (--before or marker).\n\n  after_file: |\n    [AFTER_FILE]\n    New version path. Required when review_mode=explicit-pair.\n    FROM UNIFIED SETUP PHASE (--after or marker).\n\n  report_path: |\n    [REPORT_PATH]\n    Output HTML path. Defaults to <document-stem>.diff.html when omitted.\n    FROM UNIFIED SETUP PHASE (Q2, --report, or engine default).\n\n  view: |\n    [VIEW]\n    Report layout: 'unified' (default) or 'side-by-side'.\n    FROM UNIFIED SETUP PHASE (Q3 or --view).\n\n# -----------------------------------------------------------------\n# FIELD HANDLING\n# -----------------------------------------------------------------\nfield_handling:\n  review_mode:\n    validation: \"must be one of: automatic, explicit-pair\"\n    default: \"derive_from_arguments\"\n    note: \"--before/--after implies explicit-pair; a single document target implies automatic\"\n\n  report_path:\n    validation: \"workspace-relative path ending in .html, or omitted for the engine default\"\n    required: false\n\n  view:\n    validation: \"must be one of: unified, side-by-side\"\n    default: \"unified\"\n\n  defaults:\n    output_format: \"single self-contained HTML report (inlined CSS, no scripts, no network)\"\n    engine_command: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py\"\n    validator_command: \"python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report_path]\"\n\ninput_contract:\n  required:\n    - create_diff_verified\n    - review_mode\n  conditional:\n    - target_document   # required when review_mode=automatic\n    - before_file       # required when review_mode=explicit-pair\n    - after_file        # required when review_mode=explicit-pair\n  optional:\n    - report_path\n    - view\n\n# -----------------------------------------------------------------\n# DOCUMENTATION LEVEL\n# -----------------------------------------------------------------\ndocumentation_level:\n  default: \"No separate spec packet for ordinary document diff review\"\n  required_files:\n  - report_path\n  note: \"The command output is a single self-contained HTML report unless the user explicitly asks for surrounding documentation.\"\n\n# -----------------------------------------------------------------\n# CREATE-DIFF RESOURCES\n# -----------------------------------------------------------------\ndiff_resources:\n  skill_contract: .opencode/skills/sk-doc/create-diff/SKILL.md\n\ndiff_scripts:\n  create_diff_engine: .opencode/skills/sk-doc/create-diff/scripts/create_diff.py\n  validate_report: .opencode/skills/sk-doc/create-diff/scripts/validate_report.py\n\ndiff_references:\n  route_map: .opencode/skills/sk-doc/create-diff/references/README.md\n  cli_reference: .opencode/skills/sk-doc/create-diff/references/cli-reference.md\n  capabilities_and_fidelity: .opencode/skills/sk-doc/create-diff/references/capabilities-and-fidelity.md\n  workflow: .opencode/skills/sk-doc/create-diff/references/workflow.md\n  accessibility_contract: .opencode/skills/sk-doc/create-diff/references/accessibility-contract.md\n  worked_example: .opencode/skills/sk-doc/create-diff/references/worked-example.md\n\n# -----------------------------------------------------------------\n# ENGINE COMMAND REFERENCE (authoritative flags from cli-reference.md)\n# -----------------------------------------------------------------\nengine_commands:\n  capabilities: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py capabilities [--json]\"\n  snapshot: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py snapshot <file> [--state-dir DIR]\"\n  compare: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare <file> [--report OUT] [--view unified|side-by-side] [--state-dir DIR] [--json]\"\n  compare_pair: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare-pair --before A --after B [--report OUT] [--view unified|side-by-side] [--label-before L] [--label-after L] [--json]\"\n  status: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py status [<file>] [--state-dir DIR] [--json]\"\n  validate: \"python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py <report.html> [more.html ...]\"\n\n# -----------------------------------------------------------------\n# WORKFLOW ENFORCEMENT (CRITICAL)\n# -----------------------------------------------------------------\nworkflow_enforcement:\n  mode: strict\n  step_order: sequential_mandatory\n  skip_allowed: false\n\n  phase_gate:\n    location: \"Between Step 1 and Step 3 (comparison)\"\n    purpose: \"Verify inputs and format capability before invoking the engine\"\n    requirements:\n    - \"Document path(s) confirmed to exist\"\n    - \"Review mode resolved\"\n    - \"Format supported or explicit-pair fallback selected\"\n    action_if_failed: \"STOP and return to the incomplete step\"\n\n  critical_steps:\n    step_1_input_verification:\n      enforcement: \"MUST confirm document path(s), review mode, report path, and view; never guess an unknown path\"\n      verification: \"Self-validate inputs before proceeding\"\n    step_3_comparison:\n      enforcement: \"MUST call the engine (snapshot+compare or compare-pair); NEVER re-implement diffing\"\n      verification: \"Engine exit code captured and mapped to an actionable message\"\n    step_4_report_validation:\n      enforcement: \"MUST run validate_report.py on the generated report\"\n      verification: \"Validator exits 0, or the failure is fixed/reported before delivery\"\n\ngate_logic:\n  hard:\n    H0_diff_verified:\n      description: \"create-diff packet resource verification must have passed in Phase 0\"\n      fail_action: \"STOP and return to the command setup phase\"\n    H1_required_fields:\n      description: \"Required setup fields for the resolved review mode must be present before comparison\"\n      fail_action: \"STOP and collect missing inputs\"\n    H2_source_immutable:\n      description: \"The source document must never be modified by capture or comparison\"\n      fail_action: \"STOP if any engine step would write to the source; comparison is read-only against it\"\n    H3_report_validation:\n      description: \"Generated report must pass validate_report.py before delivery\"\n      fail_action: \"Fix the renderer output or report the failure; do not claim a clean self-contained report\"\n  soft:\n    S1_low_fidelity:\n      description: \"Warn when the format resolves to a text-only tier (html, docx, pdf text layer)\"\n      fail_action: \"State the fidelity tier; never present it as capturing formatting/layout/tracked changes\"\n    S2_existing_report:\n      description: \"Warn when the report path already exists\"\n      fail_action: \"Proceed only after explicit overwrite intent\"\n\n# -----------------------------------------------------------------\n# CONTEXT LOADING\n# -----------------------------------------------------------------\ncontext_loading:\n  trigger: \"During UNIFIED SETUP PHASE, non-interactive resolution before Step 1\"\n  applies_when: \"an existing baseline may be present for the target document, OR a prior report exists at the report path, OR the request names specific before/after files\"\n  auto_resolution:\n    default: \"If review_mode=automatic, run `status <file>` to detect an existing baseline; if one exists, compare against it, else snapshot first. If review_mode=explicit-pair, load only the named --before/--after files. Otherwise skip discovery.\"\n    override: \"Honor an explicit --state-dir when supplied as a command argument or pre-bound marker\"\n  tool_integration:\n    primary: \"Glob/Grep to locate the target document, before/after files, and any prior report; Read matches before reuse\"\n    engine_state_probe: \"python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py status [<file>] --json\"\n  output: baseline_state\n\n# -----------------------------------------------------------------\n# WORKFLOW (5 STEPS - AUTONOMOUS)\n# -----------------------------------------------------------------\nworkflow_overview:\n  steps:\n    - id: step_1_input_verification\n      purpose: \"Confirm document path(s), review mode, report path, and view; refuse to guess unknown paths\"\n    - id: step_2_capability_check\n      purpose: \"Optionally confirm format support and fidelity tier before comparing\"\n    - id: step_3_comparison\n      purpose: \"Run the engine: automatic snapshot+compare, or explicit compare-pair\"\n    - id: step_4_report_validation\n      purpose: \"Validate the generated report is safe and self-contained\"\n    - id: step_5_delivery\n      purpose: \"Emit final status with report path, change summary, fidelity tier, and validator result\"\n\nworkflow:\n  # ==============================================================\n  # STEP 1: INPUT VERIFICATION\n  # ==============================================================\n  step_1_input_verification:\n    purpose: Confirm inputs from the UNIFIED SETUP PHASE and validate paths (DO NOT GUESS)\n    activities:\n    - Confirm review_mode from UNIFIED SETUP PHASE (Q1 or derived from arguments)\n    - \"IF review_mode=automatic: confirm target_document exists and is readable\"\n    - \"IF review_mode=explicit-pair: confirm before_file and after_file exist and are readable\"\n    - Resolve report_path (explicit .html path or the engine default <document-stem>.diff.html)\n    - Resolve view (unified default or side-by-side)\n    - Probe baseline_state via `status` when review_mode=automatic\n    validation:\n      path_existence: \"each named document path must exist on disk\"\n      report_format: \"report_path, when explicit, ends in .html\"\n      refuse_guess: \"STOP if any required path is unknown; ask rather than assume\"\n    outputs:\n    - inputs_confirmed\n    - review_mode_resolved\n    - baseline_state\n    - report_path_resolved\n\n  # ==============================================================\n  # PHASE GATE: INPUTS -> COMPARISON\n  # ==============================================================\n  # ==============================================================\n  # STEP 2: CAPABILITY CHECK\n  # ==============================================================\n  step_2_capability_check:\n    purpose: Confirm format support and fidelity tier when uncertain\n    condition: \"run when the input format is uncertain (e.g. DOCX or PDF) or before a first comparison\"\n    activities:\n    - \"Run: python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py capabilities [--json]\"\n    - \"Determine the fidelity tier for the input format (full / text / text*)\"\n    - \"IF the format is a text-layer PDF and no extractor is available (exit 3): do not claim a diff; offer the explicit-pair fallback with pre-extracted text\"\n    - \"Record the fidelity tier to state honestly at delivery\"\n    outputs:\n    - capability_confirmed\n    - fidelity_tier\n\n  phase_gate_inputs_to_comparison:\n    trigger: \"After Step 1 and Step 2 complete\"\n    enforcement: HARD_BLOCK\n    verification: |\n      BEFORE invoking the engine (Step 3):\n\n      VERIFY all input artifacts exist:\n      - [ ] Review mode resolved\n      - [ ] Document path (automatic) or --before/--after pair (explicit) confirmed to exist\n      - [ ] Report path resolved\n      - [ ] Format supported, or explicit-pair fallback selected for an unsupported format\n\n      IF any artifact missing:\n      - STOP -> Return to Step 1/Step 2 -> Complete it -> Return here\n\n      WHEN all artifacts verified:\n      - SET PHASE GATE STATUS: PASSED -> Proceed to Step 3\n    action_if_failed: \"Return to incomplete step\"\n\n  # ==============================================================\n  # STEP 3: COMPARISON (ENGINE-DRIVEN)\n  # ==============================================================\n  step_3_comparison:\n    purpose: Invoke the create-diff engine to compare versions and render the report\n    enforcement: MANDATORY\n    activities:\n    - \"NEVER re-implement diffing, extraction, or rendering; always call the engine\"\n    branch_automatic_baseline:\n      when: \"review_mode=automatic\"\n      steps:\n      - \"IF a baseline already exists (from baseline_state): skip snapshot\"\n      - \"ELSE capture a baseline BEFORE the edit: python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py snapshot <target_document> [--state-dir DIR]\"\n      - \"... allow the edit to happen (AI or human) between snapshot and compare ...\"\n      - \"AFTER the edit, compare and render: python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare <target_document> --report <report_path> [--view side-by-side] [--state-dir DIR] --json\"\n      invariant: \"The baseline must be captured before the edit; a compare with no baseline exits 4\"\n    branch_explicit_pair:\n      when: \"review_mode=explicit-pair\"\n      steps:\n      - \"Compare two explicit files (no stored state): python3 .opencode/skills/sk-doc/create-diff/scripts/create_diff.py compare-pair --before <before_file> --after <after_file> --report <report_path> [--view side-by-side] [--label-before L] [--label-after L] --json\"\n    exit_code_handling:\n      \"0\": \"Success - capture the JSON change summary and continue to Step 4\"\n      \"2\": \"Usage error (bad arguments) - fix the invocation and re-run\"\n      \"3\": \"Unsupported/limited format with no fallback (e.g. PDF with no extractor) - STOP with an actionable message; offer explicit-pair with pre-extracted text\"\n      \"4\": \"Missing baseline snapshot for compare - capture a snapshot first, or switch to compare-pair\"\n      \"5\": \"I/O or extraction failure - STOP and report the failing path/cause\"\n    outputs:\n    - comparison_complete\n    - change_summary   # added / removed / changed / possible_moves / total_changes / identical\n    - report_written\n    validation: engine_exit_zero\n\n  # ==============================================================\n  # STEP 4: REPORT VALIDATION\n  # ==============================================================\n  step_4_report_validation:\n    purpose: Validate the generated report is safe and self-contained\n    enforcement: HARD_BLOCK\n    activities:\n    - \"Run: python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py <report_path>\"\n    - \"Expect exit 0 (asserts doctype, <html lang>, a Content-Security-Policy meta tag, zero <script> tags, no inline event handlers, no remote href/src)\"\n    - \"IF the validator exits 1: STOP - do not claim a clean self-contained report; report the specific failure\"\n    - \"Confirm the source document is byte-for-byte unchanged (comparison is read-only against it)\"\n    validation_command: |\n      python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report_path]\n    quality_gates:\n      validator_exit: \"must be 0 before clean delivery\"\n      source_immutable: \"source document unchanged by capture or comparison\"\n      enforcement: HARD_BLOCK\n    fix_workflow: |\n      IF validation fails:\n      1. Review the exact validator output.\n      2. Fix the renderer output or re-run the comparison.\n      3. Re-run the validator command.\n      4. Repeat until passing, or report the failure explicitly.\n    outputs:\n    - report_validation_result: pass_or_fail\n    - validation_errors: list_if_failed\n    validation: report_safe\n\n  # ==============================================================\n  # STEP 5: DELIVERY\n  # ==============================================================\n  step_5_delivery:\n    purpose: Emit completion status with report path and evidence\n    condition: \"report_path is not null and report validation passed\"\n    activities:\n    - Ensure the output remains a single self-contained HTML report\n    - Record review mode, report path, change summary, fidelity tier, and validator result in the delivery summary\n    - State the fidelity tier honestly; never present a text-tier comparison as capturing formatting or layout\n    - Do not create packet-local advisor metadata or extra output files\n    outputs:\n    - delivery_summary: \"report path, change summary, fidelity tier, and validation evidence\"\n    validation: delivery_ready\n\n    validation_evidence:\n      validator: .opencode/skills/sk-doc/create-diff/scripts/validate_report.py\n      invocation: |\n        python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report_path]\n      critical_note: \"Run the report validator directly before delivery. Do not claim a clean, self-contained report if the command fails or exits non-zero.\"\n      when: \"Immediately after the report is written\"\n\n    anchor_requirements:\n      enforcement: NOT_APPLICABLE\n      rationale: \"The command creates a single HTML report, not a memory packet.\"\n\n    importance_tier:\n      assign: normal\n      rationale: \"Document diff review is artifact-scoped unless the user requests durable project memory.\"\n      promotion_note: \"Promote only if the report becomes authoritative project documentation.\"\n\n# -----------------------------------------------------------------\n# CIRCUIT BREAKER\n# -----------------------------------------------------------------\ncircuit_breaker:\n  consecutive_failure_threshold: 3\n  states:\n    closed: \"Normal operation\"\n    open: \"3+ failures - pause and report to user\"\n    half_open: \"Test with single retry before resuming\"\n  on_open:\n    action: \"Report failures to user with summary\"\n    suggest: \"Review inputs and try again, or escalate\"\n\n# -----------------------------------------------------------------\n# ERROR RECOVERY (maps engine exit codes to actionable messages)\n# -----------------------------------------------------------------\nerror_recovery:\n  unknown_document_path:\n    action: \"Show valid format (workspace-relative path), prompt for the correct document; never guess\"\n    example: \"Expected: docs/notes/proposal.md\"\n  usage_error:\n    exit_code: 2\n    action: \"Correct the arguments per references/cli-reference.md and re-run\"\n  unsupported_or_limited_format:\n    exit_code: 3\n    action: \"Explain the format is unsupported/limited with no fallback (e.g. a PDF with no text extractor); offer compare-pair with pre-extracted text\"\n  missing_baseline:\n    exit_code: 4\n    action: \"No baseline snapshot exists for compare; capture one with `snapshot <file>` first, or use compare-pair --before/--after\"\n  io_or_extraction_failure:\n    exit_code: 5\n    action: \"Report the failing path or extraction cause; do not claim a diff was produced\"\n  report_validation_failure:\n    validator_exit: 1\n    action: \"Report is not safe/self-contained; fix the renderer output or report the failure. Never claim a clean report\"\n  scanned_pdf:\n    action: \"A PDF with no text layer would yield an empty comparison; OCR is out of scope - escalate\"\n\n# -----------------------------------------------------------------\n# AUTONOMOUS EXECUTION\n# -----------------------------------------------------------------\nautonomous_execution:\n  validation_approach: \"Continuous self-validation at each step\"\n  error_handling: \"Auto-recover if possible, halt on critical failures and unmapped exit codes\"\n  progress_reporting: \"Brief status updates between steps\"\n\n# -----------------------------------------------------------------\n# QUALITY STANDARDS\n# -----------------------------------------------------------------\nquality_standards:\n  report_validation: MANDATORY\n  validation_enforcement: HARD_BLOCK\n  validation_pipeline:\n    stage_1: \"Engine comparison exits 0\"\n    stage_2: \"Report safety/self-containment validator exits 0\"\n    stage_3: \"Source document confirmed unchanged\"\n    stage_4: \"Fidelity tier stated honestly\"\n  template_adherence: required\n  core_standards_reference: \".opencode/skills/sk-doc/create-diff/SKILL.md\"\n\n# -----------------------------------------------------------------\n# COMPLETION REPORT TEMPLATE\n# -----------------------------------------------------------------\ncompletion_report:\n  template: |\n    Document Diff Complete\n\n    Review Mode: [automatic-baseline | explicit-pair]\n    Report: [report-path]\n\n    Compared:\n    - Automatic: [target-document] (baseline -> current)\n    - Explicit pair: before=[before-file] after=[after-file]\n\n    Changes:\n    - Added:   [+N]\n    - Removed: [-N]\n    - Changed: [~N]\n    - Possible moves: [N]\n    - Fidelity tier: [full | text | text*]\n\n    Validation:\n    - Command: python3 .opencode/skills/sk-doc/create-diff/scripts/validate_report.py [report-path]\n    - Result: PASS\n\n    Output:\n    - Single self-contained HTML report (no scripts, no network)\n    - Source document unchanged\n\n    STATUS=OK PATH=[report-path]\n\n# -----------------------------------------------------------------\n# TERMINATION\n# -----------------------------------------------------------------\ntermination:\n  after_step: step_5_delivery\n  message: \"Document diff workflow complete.\"\n  next_steps:\n    - condition: \"Further edits are planned\"\n      action: \"Capture a fresh baseline before the next edit, then compare again\"\n    - condition: \"The report should be shared\"\n      action: \"The HTML report is self-contained and safe to open or send as-is\"\n    - condition: \"A limited-fidelity tier was used\"\n      action: \"Note what was not compared (formatting, layout, tracked changes) to the reader\"\n\n# -----------------------------------------------------------------\n# RULES\n# -----------------------------------------------------------------\nrules:\n  ALWAYS:\n    - \"Call the create-diff engine for all comparison, extraction, snapshotting, and rendering\"\n    - \"Capture the baseline before the edit in automatic mode\"\n    - \"Run validate_report.py before claiming delivery\"\n    - \"State the fidelity tier and any warnings honestly\"\n    - \"Keep everything local - no network, upload, or telemetry\"\n    - \"Read a file before editing; never modify the source document during comparison\"\n    - \"Map engine exit codes (2/3/4/5) to actionable messages\"\n    - \"Report the exact validation command and result\"\n  NEVER:\n    - \"Re-implement diffing, extraction, snapshotting, or rendering\"\n    - \"Guess an unknown document, baseline state, or report path\"\n    - \"Mutate, overwrite, or fix up the source document\"\n    - \"Present a text-tier comparison as if it captured formatting, layout, or tracked changes\"\n    - \"Claim a diff was produced when the format was unsupported and no fallback ran\"\n    - \"Claim a clean report when validate_report.py fails\"\n    - \"Create packet-local advisor metadata\"","lineStart":1,"lineEnd":566,"totalLines":566,"truncated":false}},"title":".opencode/commands/create/assets/create_diff_auto.yaml","time":{"start":1784210626347,"end":1784210626374}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a70819189b944c70d9cc8e4"}},"id":"prt_f6b3d972a001BSyItHgBlWkDuv","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626382,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_qjNizq8u7F3TB37f9PucpM4N","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/feature-catalog/snapshot-lifecycle/snapshot-state-management.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/feature-catalog/snapshot-lifecycle/snapshot-state-management.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Snapshot state management\"\n3: description: \"Lists and prunes stored baselines so the local snapshot store stays bounded and safe to delete.\"\n4: trigger_phrases:\n5:   - \"Snapshot state management\"\n6:   - \"list stored baselines\"\n7:   - \"cleanup old snapshots\"\n8:   - \"status and cleanup\"\n9: version: 1.0.0.0\n10: ---\n11: \n12: # Snapshot state management (status / cleanup)\n13: \n14: <!-- sk-doc-template: skill_asset_feature-catalog -->\n15: \n16: ## 1. OVERVIEW\n17: \n18: Lists and prunes stored baselines so local snapshot state stays bounded.\n19: \n20: This is the housekeeping half of the snapshot lifecycle. A caller uses `status` to see which baselines exist and `cleanup` to remove ones they no longer need, keeping the local `.create-diff/` store from growing without limit. The store is plain files and is always safe to delete wholesale, so the main risk this feature guards against is not data loss but accidental over-deletion — handled by the `--dry-run` preview before anything is actually removed.\n21: \n22: ---\n23: \n24: ## 2. HOW IT WORKS\n25: \n26: `status [<file>]` lists stored baselines: with no argument it reports every snapshot in the store, and with a file it scopes to that source. `--json` emits the same listing in machine-readable form, and `--state-dir` points at a non-default store.\n27: \n28: `cleanup` prunes baselines by age or wholesale: `--older-than DAYS` keeps recent snapshots and removes older ones, `--file F` scopes the prune to a single source, and running it without an age filter clears the matching snapshots entirely. `--dry-run` prints exactly what would be removed without deleting anything, so a caller can preview a prune first. Because the whole store under `.create-diff/` is disposable, deleting it by hand is an equally valid reset.\n29: \n30: ---\n31: \n32: ## 3. SOURCE FILES\n33: \n34: ### Implementation\n35: \n36: | File | Layer | Role |\n37: |---|---|---|\n38: | `scripts/create_diff.py` | Script | `status` lists snapshots (all or per-file); `cleanup` prunes by `--older-than DAYS` or wholesale with a `--dry-run` preview; state lives under `.create-diff/` and is safe to delete |\n39: | `references/workflow.md` | Shared | The snapshot storage layout and the cleanup lifecycle |\n40: \n41: ### Validation And Tests\n42: \n43: | File | Type | Role |\n44: |---|---|---|\n45: | `manual-testing-playbook/manual-testing-playbook.md` | Manual playbook | SNAP-003 verifies listing, the `--dry-run` preview, and actual pruning |\n46: \n47: ---\n48: \n49: ## 4. SOURCE METADATA\n50: \n51: - Group: SNAPSHOT LIFECYCLE\n52: - Canonical catalog source: `feature-catalog.md`\n53: - Feature file path: `snapshot-lifecycle/snapshot-state-management.md`\n54: \n55: Related references:\n56: - [baseline-snapshot-and-compare.md](baseline-snapshot-and-compare.md) — creates the baselines this feature lists and prunes\n57: - [explicit-pair-comparison.md](explicit-pair-comparison.md) — the stateless flow that writes no snapshot state to manage\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Snapshot state management\"\ndescription: \"Lists and prunes stored baselines so the local snapshot store stays bounded and safe to delete.\"\ntrigger_phrases:\n  - \"Snapshot state management\"\n  - \"list stored baselines\"\n  - \"cleanup old snapshots\"\n  - \"status and cleanup\"\nversion: 1.0.0.0\n---\n\n# Snapshot state management (status / cleanup)\n\n<!-- sk-doc-template: skill_asset_feature-catalog -->\n\n## 1. OVERVIEW\n\nLists and prunes stored baselines so local snapshot state stays bounded.\n\nThis is the housekeeping half of the snapshot lifecycle. A caller uses `status` to see which baselines exist and `cleanup` to remove ones they no longer need, keeping the local `.create-diff/` store from growing without limit. The store is plain files and is always safe to delete wholesale, so the main risk this feature guards against is not data loss but accidental over-deletion — handled by the `--dry-run` preview before anything is actually removed.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/feature-catalog/snapshot-lifecycle/snapshot-state-management.md","text":"---\ntitle: \"Snapshot state management\"\ndescription: \"Lists and prunes stored baselines so the local snapshot store stays bounded and safe to delete.\"\ntrigger_phrases:\n  - \"Snapshot state management\"\n  - \"list stored baselines\"\n  - \"cleanup old snapshots\"\n  - \"status and cleanup\"\nversion: 1.0.0.0\n---\n\n# Snapshot state management (status / cleanup)\n\n<!-- sk-doc-template: skill_asset_feature-catalog -->\n\n## 1. OVERVIEW\n\nLists and prunes stored baselines so local snapshot state stays bounded.\n\nThis is the housekeeping half of the snapshot lifecycle. A caller uses `status` to see which baselines exist and `cleanup` to remove ones they no longer need, keeping the local `.create-diff/` store from growing without limit. The store is plain files and is always safe to delete wholesale, so the main risk this feature guards against is not data loss but accidental over-deletion — handled by the `--dry-run` preview before anything is actually removed.\n\n---\n\n## 2. HOW IT WORKS\n\n`status [<file>]` lists stored baselines: with no argument it reports every snapshot in the store, and with a file it scopes to that source. `--json` emits the same listing in machine-readable form, and `--state-dir` points at a non-default store.\n\n`cleanup` prunes baselines by age or wholesale: `--older-than DAYS` keeps recent snapshots and removes older ones, `--file F` scopes the prune to a single source, and running it without an age filter clears the matching snapshots entirely. `--dry-run` prints exactly what would be removed without deleting anything, so a caller can preview a prune first. Because the whole store under `.create-diff/` is disposable, deleting it by hand is an equally valid reset.\n\n---\n\n## 3. SOURCE FILES\n\n### Implementation\n\n| File | Layer | Role |\n|---|---|---|\n| `scripts/create_diff.py` | Script | `status` lists snapshots (all or per-file); `cleanup` prunes by `--older-than DAYS` or wholesale with a `--dry-run` preview; state lives under `.create-diff/` and is safe to delete |\n| `references/workflow.md` | Shared | The snapshot storage layout and the cleanup lifecycle |\n\n### Validation And Tests\n\n| File | Type | Role |\n|---|---|---|\n| `manual-testing-playbook/manual-testing-playbook.md` | Manual playbook | SNAP-003 verifies listing, the `--dry-run` preview, and actual pruning |\n\n---\n\n## 4. SOURCE METADATA\n\n- Group: SNAPSHOT LIFECYCLE\n- Canonical catalog source: `feature-catalog.md`\n- Feature file path: `snapshot-lifecycle/snapshot-state-management.md`\n\nRelated references:\n- [baseline-snapshot-and-compare.md](baseline-snapshot-and-compare.md) — creates the baselines this feature lists and prunes\n- [explicit-pair-comparison.md](explicit-pair-comparison.md) — the stateless flow that writes no snapshot state to manage","lineStart":1,"lineEnd":57,"totalLines":57,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/feature-catalog/snapshot-lifecycle/snapshot-state-management.md","time":{"start":1784210626325,"end":1784210626376}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a3881919bd21cc48a215db1"}},"id":"prt_f6b3d96f7001SrRQ9CKky7KIHb","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626382,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_yWFuMH5nvspGsYDLyvY69mg6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/feature-catalog/comparison-engine/self-contained-report.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/feature-catalog/comparison-engine/self-contained-report.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Self-contained report\"\n3: description: \"Renders the diff as one self-contained, zero-JavaScript, CSP-locked, accessible HTML file in unified or side-by-side view.\"\n4: trigger_phrases:\n5:   - \"Self-contained report\"\n6:   - \"single-file HTML diff report\"\n7:   - \"zero-JavaScript diff report\"\n8:   - \"self-contained report renderer\"\n9: version: 1.0.0.0\n10: ---\n11: \n12: # Self-contained report\n13: \n14: <!-- sk-doc-template: skill_asset_feature-catalog -->\n15: \n16: ## 1. OVERVIEW\n17: \n18: Renders the diff as a single self-contained HTML file — inlined CSS, zero JavaScript, a restrictive Content-Security-Policy, escaped source content, and accessibility affordances — in unified or side-by-side views.\n19: \n20: The report is the only artifact a human actually opens, so it is built to be trustworthy offline: it loads from a `file://` path with no network access and cannot execute any script. Callers choose the layout with `--view unified` or `--view side-by-side`. The main safety concern the renderer defends against is hostile document content, which it neutralizes by escaping every source character before it reaches the page, and the main reproducibility concern is byte-stable output, which it guarantees under `SOURCE_DATE_EPOCH`.\n21: \n22: ---\n23: \n24: ## 2. HOW IT WORKS\n25: \n26: ### Core behavior\n27: \n28: The renderer emits one HTML document with all CSS inlined and no JavaScript whatsoever. A restrictive Content-Security-Policy meta tag (`default-src 'none'; style-src 'unsafe-inline'; img-src data:; base-uri 'none'; form-action 'none'`) locks the page down so that even if markup leaked in, nothing could load or run. Every character of source content is HTML-escaped, so a `<script>` in a document body renders as literal text rather than live markup. Two layouts are available — unified and side-by-side — selected by the `--view` flag.\n29: \n30: ### Accessibility and reproducibility\n31: \n32: The report is built to an accessibility contract: a skip link, semantic landmarks, the summary and diff rendered as tables with `th` scope, `+`/`−` text markers carrying `aria-label` alongside the colour cue, dark and light theming via `prefers-color-scheme`, and relative units throughout. Output is byte-reproducible under `SOURCE_DATE_EPOCH`, so re-rendering the same diff produces an identical file — which is what lets `validate_report.py` and human reviewers trust it.\n33: \n34: ---\n35: \n36: ## 3. SOURCE FILES\n37: \n38: ### Implementation\n39: \n40: | File | Layer | Role |\n41: |---|---|---|\n42: | `scripts/create_diff.py` | Script | HTML report renderer: inlined CSS, zero JS, restrictive CSP meta tag, HTML-escaping of all source content, unified/side-by-side views, and `SOURCE_DATE_EPOCH` reproducibility |\n43: | `references/accessibility-contract.md` | Shared | The self-containment and accessibility guarantees the report must satisfy and what the validator enforces |\n44: \n45: ### Validation And Tests\n46: \n47: | File | Type | Role |\n48: |---|---|---|\n49: | `scripts/validate_report.py` | Automated test | Asserts doctype, `<html lang>`, and a CSP meta tag, and that real markup contains no `<script>`, inline handlers, or remote references |\n50: | `manual-testing-playbook/manual-testing-playbook.md` | Manual playbook | SAFE-001 (self-contained zero-JS) and SAFE-002 (hostile content escaped) validate the rendered report |\n51: \n52: ---\n53: \n54: ## 4. SOURCE METADATA\n55: \n56: - Group: COMPARISON ENGINE\n57: - Canonical catalog source: `feature-catalog.md`\n58: - Feature file path: `comparison-engine/self-contained-report.md`\n59: \n60: Related references:\n61: - [multi-format-extraction.md](multi-format-extraction.md) — supplies the extracted text that becomes report content\n62: - [deterministic-diffing.md](deterministic-diffing.md) — supplies the diff opcodes this report renders\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Self-contained report\"\ndescription: \"Renders the diff as one self-contained, zero-JavaScript, CSP-locked, accessible HTML file in unified or side-by-side view.\"\ntrigger_phrases:\n  - \"Self-contained report\"\n  - \"single-file HTML diff report\"\n  - \"zero-JavaScript diff report\"\n  - \"self-contained report renderer\"\nversion: 1.0.0.0\n---\n\n# Self-contained report\n\n<!-- sk-doc-template: skill_asset_feature-catalog -->\n\n## 1. OVERVIEW\n\nRenders the diff as a single self-contained HTML file — inlined CSS, zero JavaScript, a restrictive Content-Security-Policy, escaped source content, and accessibility affordances — in unified or side-by-side views.\n\nThe report is the only artifact a human actually opens, so it is built to be trustworthy offline: it loads from a `file://` path with no network access and cannot execute any script. Callers choose the layout with `--view unified` or `--view side-by-side`. The main safety concern the renderer defends against is hostile document content, which it neutralizes by escaping every source character before it reaches the page, and the main reproducibility concern is byte-stable output, which it guarantees under `SOURCE_DATE_EPOCH`.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/feature-catalog/comparison-engine/self-contained-report.md","text":"---\ntitle: \"Self-contained report\"\ndescription: \"Renders the diff as one self-contained, zero-JavaScript, CSP-locked, accessible HTML file in unified or side-by-side view.\"\ntrigger_phrases:\n  - \"Self-contained report\"\n  - \"single-file HTML diff report\"\n  - \"zero-JavaScript diff report\"\n  - \"self-contained report renderer\"\nversion: 1.0.0.0\n---\n\n# Self-contained report\n\n<!-- sk-doc-template: skill_asset_feature-catalog -->\n\n## 1. OVERVIEW\n\nRenders the diff as a single self-contained HTML file — inlined CSS, zero JavaScript, a restrictive Content-Security-Policy, escaped source content, and accessibility affordances — in unified or side-by-side views.\n\nThe report is the only artifact a human actually opens, so it is built to be trustworthy offline: it loads from a `file://` path with no network access and cannot execute any script. Callers choose the layout with `--view unified` or `--view side-by-side`. The main safety concern the renderer defends against is hostile document content, which it neutralizes by escaping every source character before it reaches the page, and the main reproducibility concern is byte-stable output, which it guarantees under `SOURCE_DATE_EPOCH`.\n\n---\n\n## 2. HOW IT WORKS\n\n### Core behavior\n\nThe renderer emits one HTML document with all CSS inlined and no JavaScript whatsoever. A restrictive Content-Security-Policy meta tag (`default-src 'none'; style-src 'unsafe-inline'; img-src data:; base-uri 'none'; form-action 'none'`) locks the page down so that even if markup leaked in, nothing could load or run. Every character of source content is HTML-escaped, so a `<script>` in a document body renders as literal text rather than live markup. Two layouts are available — unified and side-by-side — selected by the `--view` flag.\n\n### Accessibility and reproducibility\n\nThe report is built to an accessibility contract: a skip link, semantic landmarks, the summary and diff rendered as tables with `th` scope, `+`/`−` text markers carrying `aria-label` alongside the colour cue, dark and light theming via `prefers-color-scheme`, and relative units throughout. Output is byte-reproducible under `SOURCE_DATE_EPOCH`, so re-rendering the same diff produces an identical file — which is what lets `validate_report.py` and human reviewers trust it.\n\n---\n\n## 3. SOURCE FILES\n\n### Implementation\n\n| File | Layer | Role |\n|---|---|---|\n| `scripts/create_diff.py` | Script | HTML report renderer: inlined CSS, zero JS, restrictive CSP meta tag, HTML-escaping of all source content, unified/side-by-side views, and `SOURCE_DATE_EPOCH` reproducibility |\n| `references/accessibility-contract.md` | Shared | The self-containment and accessibility guarantees the report must satisfy and what the validator enforces |\n\n### Validation And Tests\n\n| File | Type | Role |\n|---|---|---|\n| `scripts/validate_report.py` | Automated test | Asserts doctype, `<html lang>`, and a CSP meta tag, and that real markup contains no `<script>`, inline handlers, or remote references |\n| `manual-testing-playbook/manual-testing-playbook.md` | Manual playbook | SAFE-001 (self-contained zero-JS) and SAFE-002 (hostile content escaped) validate the rendered report |\n\n---\n\n## 4. SOURCE METADATA\n\n- Group: COMPARISON ENGINE\n- Canonical catalog source: `feature-catalog.md`\n- Feature file path: `comparison-engine/self-contained-report.md`\n\nRelated references:\n- [multi-format-extraction.md](multi-format-extraction.md) — supplies the extracted text that becomes report content\n- [deterministic-diffing.md](deterministic-diffing.md) — supplies the diff opcodes this report renders","lineStart":1,"lineEnd":62,"totalLines":62,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/feature-catalog/comparison-engine/self-contained-report.md","time":{"start":1784210626333,"end":1784210626378}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a488191bfced3e99b081cf8"}},"id":"prt_f6b3d9716001eMxMO2dMdeJDcV","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626382,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_2rHs07itVOXi1qbH8FYYzQyA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/manual-testing-playbook/snapshot/snapshot-status-and-cleanup.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/manual-testing-playbook/snapshot/snapshot-status-and-cleanup.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"SNAP-003 -- Snapshot status and cleanup\"\n3: description: \"This scenario validates snapshot status and cleanup for `SNAP-003`. It focuses on listing stored baselines and pruning them safely with a dry-run preview before deletion.\"\n4: stage: routing\n5: version: 1.0.0.0\n6: ---\n7: \n8: # SNAP-003 -- Snapshot status and cleanup\n9: \n10: This document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `SNAP-003`.\n11: \n12: ---\n13: \n14: ## 1. OVERVIEW\n15: \n16: This scenario validates snapshot status and cleanup for `SNAP-003`. It focuses on listing stored baselines and pruning them safely with a dry-run preview before deletion.\n17: \n18: ### Why This Matters\n19: \n20: The snapshot store accumulates baselines over time, and users need to see what is stored and reclaim space without accidentally deleting a baseline they still need. The safe contract is an accurate `status` listing plus a `cleanup` that previews exactly what it will remove under `--dry-run` before any destructive run. This scenario proves the listing is truthful and that the dry-run preview deletes nothing, so cleanup is always previewable and never a surprise.\n21: \n22: ---\n23: \n24: ## 2. SCENARIO CONTRACT\n25: \n26: Operators run the exact prompt and command sequence for `SNAP-003` and confirm the expected signals without contradictory evidence.\n27: \n28: - Objective: list stored baselines and prune them safely, with a dry-run preview that deletes nothing before the real cleanup\n29: - Real user request: `List my saved baselines and clean up the old ones.`\n30: - Prompt: `List my saved baselines and clean up the old ones.`\n31: - Expected execution process: the operator seeds at least one snapshot, runs `status` to list stored baselines, runs `cleanup --older-than N --dry-run` to preview removals without deleting, then runs `cleanup --older-than N` to actually remove the qualifying baselines.\n32: - Expected signals: an accurate `status` listing, a `--dry-run` preview that reports what would be removed while leaving the store unchanged, and a real `cleanup` run that removes exactly the previewed baselines.\n33: - Desired user-visible outcome: an accurate snapshot listing and a safe, previewable cleanup.\n34: - Pass/fail: PASS if `status` lists the seeded baselines, the `--dry-run` preview leaves the store byte-unchanged, and the real `cleanup` removes exactly the previewed entries; FAIL if the listing is wrong, the dry-run deletes anything, or the real cleanup removes more or fewer entries than previewed.\n35: \n36: ---\n37: \n38: ## 3. TEST EXECUTION\n39: \n40: ### Prompt\n41: \n42: - Prompt: `List my saved baselines and clean up the old ones.`\n43: \n44: ### Commands\n45: \n46: 1. `python3 scripts/create_diff.py snapshot /tmp/doc.md --state-dir /tmp/cd-store`\n47: 2. `python3 scripts/create_diff.py status --state-dir /tmp/cd-store`\n48: 3. `python3 scripts/create_diff.py cleanup --older-than N --dry-run --state-dir /tmp/cd-store`\n49: 4. `python3 scripts/create_diff.py cleanup --older-than N --state-dir /tmp/cd-store`\n50: \n51: ### Expected\n52: \n53: Step 1 seeds at least one baseline under `/tmp/cd-store` and exits `0`. Step 2 prints a listing that includes the seeded baseline and exits `0`. Step 3, with `N` chosen so the seeded baseline qualifies (for example `0` to target all), prints a preview of what would be removed, deletes nothing, and exits `0` — the store is byte-unchanged after step 3. Step 4 removes exactly the baselines previewed in step 3 and exits `0`; a follow-up `status` would show them gone.\n54: \n55: ### Evidence\n56: \n57: Capture the step 2 `status` listing, the step 3 dry-run preview text, a listing of `/tmp/cd-store` immediately after step 3 proving nothing was deleted, the step 4 output, and a final `status` (or store listing) confirming the previewed baselines were removed. Record the value of `N` used.\n58: \n59: ### Pass / Fail\n60: \n61: - **Pass**: step 2 lists the seeded baseline, step 3 previews removals but leaves the store unchanged, and step 4 removes exactly the previewed entries.\n62: - **Fail**: the step 2 listing is inaccurate, step 3 deletes anything, or step 4 removes more or fewer baselines than step 3 previewed.\n63: \n64: ### Failure Triage\n65: \n66: 1. If step 3's preview is empty, the seeded baseline does not yet qualify for the chosen `N`; lower `--older-than` (for example to `0`) or check the snapshot dates shown by `status`.\n67: 2. Compare a listing of `/tmp/cd-store` taken before and immediately after step 3; any difference means the dry-run is not honoring its no-delete contract and is an immediate FAIL.\n68: 3. Confirm the same `--state-dir` is passed to every command so `status`, the dry-run, and the real cleanup all operate on the same store.\n69: \n70: ---\n71: \n72: ## 4. SOURCE FILES\n73: \n74: ### Playbook Sources\n75: \n76: | File | Role |\n77: |---|---|\n78: | `manual-testing-playbook.md` | Root directory page and scenario summary |\n79: | `../../feature-catalog/snapshot-lifecycle/snapshot-state-management.md` | Feature-catalog source describing the implementation contract |\n80: \n81: ### Implementation And Test Anchors\n82: \n83: | File | Role |\n84: |---|---|\n85: | `scripts/create_diff.py` | Primary implementation anchor |\n86: | `scripts/validate_report.py` | Validation anchor |\n87: \n88: ---\n89: \n90: ## 5. SOURCE METADATA\n91: \n92: - Group: SNAPSHOT\n93: - Playbook ID: SNAP-003\n94: - Canonical root source: `manual-testing-playbook.md`\n95: - Feature file path: `snapshot/snapshot-status-and-cleanup.md`\n\n(End of file - total 95 lines)\n</content>","metadata":{"preview":"---\ntitle: \"SNAP-003 -- Snapshot status and cleanup\"\ndescription: \"This scenario validates snapshot status and cleanup for `SNAP-003`. It focuses on listing stored baselines and pruning them safely with a dry-run preview before deletion.\"\nstage: routing\nversion: 1.0.0.0\n---\n\n# SNAP-003 -- Snapshot status and cleanup\n\nThis document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `SNAP-003`.\n\n---\n\n## 1. OVERVIEW\n\nThis scenario validates snapshot status and cleanup for `SNAP-003`. It focuses on listing stored baselines and pruning them safely with a dry-run preview before deletion.\n\n### Why This Matters\n\nThe snapshot store accumulates baselines over time, and users need to see what is stored and reclaim space without accidentally deleting a baseline they still need. The safe contract is an accurate `status` listing plus a `cleanup` that previews exactly what it will remove under `--dry-run` before any destructive run. This scenario proves the listing is truthful and that the dry-run preview deletes nothing, so cleanup is always previewable and never a surprise.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/manual-testing-playbook/snapshot/snapshot-status-and-cleanup.md","text":"---\ntitle: \"SNAP-003 -- Snapshot status and cleanup\"\ndescription: \"This scenario validates snapshot status and cleanup for `SNAP-003`. It focuses on listing stored baselines and pruning them safely with a dry-run preview before deletion.\"\nstage: routing\nversion: 1.0.0.0\n---\n\n# SNAP-003 -- Snapshot status and cleanup\n\nThis document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `SNAP-003`.\n\n---\n\n## 1. OVERVIEW\n\nThis scenario validates snapshot status and cleanup for `SNAP-003`. It focuses on listing stored baselines and pruning them safely with a dry-run preview before deletion.\n\n### Why This Matters\n\nThe snapshot store accumulates baselines over time, and users need to see what is stored and reclaim space without accidentally deleting a baseline they still need. The safe contract is an accurate `status` listing plus a `cleanup` that previews exactly what it will remove under `--dry-run` before any destructive run. This scenario proves the listing is truthful and that the dry-run preview deletes nothing, so cleanup is always previewable and never a surprise.\n\n---\n\n## 2. SCENARIO CONTRACT\n\nOperators run the exact prompt and command sequence for `SNAP-003` and confirm the expected signals without contradictory evidence.\n\n- Objective: list stored baselines and prune them safely, with a dry-run preview that deletes nothing before the real cleanup\n- Real user request: `List my saved baselines and clean up the old ones.`\n- Prompt: `List my saved baselines and clean up the old ones.`\n- Expected execution process: the operator seeds at least one snapshot, runs `status` to list stored baselines, runs `cleanup --older-than N --dry-run` to preview removals without deleting, then runs `cleanup --older-than N` to actually remove the qualifying baselines.\n- Expected signals: an accurate `status` listing, a `--dry-run` preview that reports what would be removed while leaving the store unchanged, and a real `cleanup` run that removes exactly the previewed baselines.\n- Desired user-visible outcome: an accurate snapshot listing and a safe, previewable cleanup.\n- Pass/fail: PASS if `status` lists the seeded baselines, the `--dry-run` preview leaves the store byte-unchanged, and the real `cleanup` removes exactly the previewed entries; FAIL if the listing is wrong, the dry-run deletes anything, or the real cleanup removes more or fewer entries than previewed.\n\n---\n\n## 3. TEST EXECUTION\n\n### Prompt\n\n- Prompt: `List my saved baselines and clean up the old ones.`\n\n### Commands\n\n1. `python3 scripts/create_diff.py snapshot /tmp/doc.md --state-dir /tmp/cd-store`\n2. `python3 scripts/create_diff.py status --state-dir /tmp/cd-store`\n3. `python3 scripts/create_diff.py cleanup --older-than N --dry-run --state-dir /tmp/cd-store`\n4. `python3 scripts/create_diff.py cleanup --older-than N --state-dir /tmp/cd-store`\n\n### Expected\n\nStep 1 seeds at least one baseline under `/tmp/cd-store` and exits `0`. Step 2 prints a listing that includes the seeded baseline and exits `0`. Step 3, with `N` chosen so the seeded baseline qualifies (for example `0` to target all), prints a preview of what would be removed, deletes nothing, and exits `0` — the store is byte-unchanged after step 3. Step 4 removes exactly the baselines previewed in step 3 and exits `0`; a follow-up `status` would show them gone.\n\n### Evidence\n\nCapture the step 2 `status` listing, the step 3 dry-run preview text, a listing of `/tmp/cd-store` immediately after step 3 proving nothing was deleted, the step 4 output, and a final `status` (or store listing) confirming the previewed baselines were removed. Record the value of `N` used.\n\n### Pass / Fail\n\n- **Pass**: step 2 lists the seeded baseline, step 3 previews removals but leaves the store unchanged, and step 4 removes exactly the previewed entries.\n- **Fail**: the step 2 listing is inaccurate, step 3 deletes anything, or step 4 removes more or fewer baselines than step 3 previewed.\n\n### Failure Triage\n\n1. If step 3's preview is empty, the seeded baseline does not yet qualify for the chosen `N`; lower `--older-than` (for example to `0`) or check the snapshot dates shown by `status`.\n2. Compare a listing of `/tmp/cd-store` taken before and immediately after step 3; any difference means the dry-run is not honoring its no-delete contract and is an immediate FAIL.\n3. Confirm the same `--state-dir` is passed to every command so `status`, the dry-run, and the real cleanup all operate on the same store.\n\n---\n\n## 4. SOURCE FILES\n\n### Playbook Sources\n\n| File | Role |\n|---|---|\n| `manual-testing-playbook.md` | Root directory page and scenario summary |\n| `../../feature-catalog/snapshot-lifecycle/snapshot-state-management.md` | Feature-catalog source describing the implementation contract |\n\n### Implementation And Test Anchors\n\n| File | Role |\n|---|---|\n| `scripts/create_diff.py` | Primary implementation anchor |\n| `scripts/validate_report.py` | Validation anchor |\n\n---\n\n## 5. SOURCE METADATA\n\n- Group: SNAPSHOT\n- Playbook ID: SNAP-003\n- Canonical root source: `manual-testing-playbook.md`\n- Feature file path: `snapshot/snapshot-status-and-cleanup.md`","lineStart":1,"lineEnd":95,"totalLines":95,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/manual-testing-playbook/snapshot/snapshot-status-and-cleanup.md","time":{"start":1784210626336,"end":1784210626379}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a508191a04d095a06407783"}},"id":"prt_f6b3d971e001dQZwxsAxYpGCfB","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626382,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_jlYL4scnNr4udJKYTAxL1Twc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/manual-testing-playbook/safety/hostile-content-escaped.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/manual-testing-playbook/safety/hostile-content-escaped.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"SAFE-002 -- Hostile content is escaped\"\n3: description: \"This scenario validates hostile-content escaping for `SAFE-002`. It focuses on confirming document content containing markup is escaped as inert text and never becomes live markup or fails the validator.\"\n4: stage: routing\n5: version: 1.0.0.0\n6: ---\n7: \n8: # SAFE-002 -- Hostile content is escaped\n9: \n10: This document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `SAFE-002`.\n11: \n12: ---\n13: \n14: ## 1. OVERVIEW\n15: \n16: This scenario validates hostile-content escaping for `SAFE-002`. It focuses on confirming document content containing markup (for example `<script>`, `onerror=`) is escaped as inert text and never becomes live markup or fails the validator.\n17: \n18: ### Why This Matters\n19: \n20: The documents users compare are untrusted input, and any of them may contain markup that looks like an attack — a `<script>` tag, an `onerror=` handler, an `<img src=x>`. If the report renders that content as live markup instead of escaped text, opening the report could execute attacker-controlled code. This scenario feeds deliberately hostile content through the engine and proves the tokens are escaped to inert characters (`&lt;script&gt;`) while the report still validates safe, so untrusted input can never turn the report into an exploit.\n21: \n22: ---\n23: \n24: ## 2. SCENARIO CONTRACT\n25: \n26: Operators run the exact prompt and command sequence for `SAFE-002` and confirm the expected signals without contradictory evidence.\n27: \n28: - Objective: confirm document content containing markup is escaped as inert text, never becomes live markup, and does not fail the validator\n29: - Real user request: `One of these files has a fake script tag in the text — make sure the report is still safe.`\n30: - Prompt: `One of these files has a fake script tag in the text — make sure the report is still safe.`\n31: - Expected execution process: the operator prepares two small files whose content includes hostile tokens such as `<script>alert(1)</script>` and `<img src=x onerror=...>`, compares them with `compare-pair`, then runs `validate_report.py`; the engine escapes the tokens and the validator ignores escaped content while still passing.\n32: - Expected signals: the hostile tokens appear escaped in the report (`&lt;script&gt;`), no live `<script>` element exists in the markup, and the validator returns `PASS`.\n33: - Desired user-visible outcome: the hostile text is shown as literal characters, never executed, and the report still validates safe.\n34: - Pass/fail: PASS if the hostile tokens are escaped in the report body, no live script element is present, and the validator returns `PASS`; FAIL if any token renders as live markup, or the validator returns `FAIL`.\n35: \n36: ---\n37: \n38: ## 3. TEST EXECUTION\n39: \n40: ### Prompt\n41: \n42: - Prompt: `One of these files has a fake script tag in the text — make sure the report is still safe.`\n43: \n44: ### Commands\n45: \n46: 1. `python3 scripts/create_diff.py compare-pair --before /tmp/hostile_before.md --after /tmp/hostile_after.md --report /tmp/hostile.html`\n47: 2. `python3 scripts/validate_report.py /tmp/hostile.html`\n48: \n49: ### Expected\n50: \n51: Before step 1, create `/tmp/hostile_before.md` and `/tmp/hostile_after.md` whose text includes hostile tokens such as `<script>alert(1)</script>` and `<img src=x onerror=alert(1)>`. Step 1 compares them, writes `/tmp/hostile.html`, and exits `0`; the report shows those tokens escaped as `&lt;script&gt;...` literal text, with no live `<script>` element in the markup. Step 2 checks the report and returns `PASS` (exit `0`) because escaped content is ignored by the validator.\n52: \n53: ### Evidence\n54: \n55: Capture the step 1 exit code and report path, a snippet of `/tmp/hostile.html` showing the hostile tokens rendered as escaped entities (`&lt;script&gt;`), confirmation that no live `<script>` element or inline handler exists in the page structure, and the step 2 validator `PASS` verdict.\n56: \n57: ### Pass / Fail\n58: \n59: - **Pass**: the hostile tokens appear escaped (`&lt;script&gt;`, `&lt;img ... onerror=...&gt;`) in the report body, no live script element or inline handler is present in the markup, and step 2 returns `PASS`.\n60: - **Fail**: any hostile token renders as a live element or handler in the markup, or step 2 returns `FAIL`.\n61: \n62: ### Failure Triage\n63: \n64: 1. Search `/tmp/hostile.html` for the raw string `<script`; every occurrence inside the diff content must be the escaped form `&lt;script`, not a live tag.\n65: 2. Distinguish the report's own structural markup (expected) from the compared content (must be escaped); the validator ignores escaped content, so a `FAIL` points at a real un-escaped element.\n66: 3. Confirm the input files actually contain the hostile tokens as text before re-running; an input that never carried the tokens cannot exercise the escaping path.\n67: \n68: ---\n69: \n70: ## 4. SOURCE FILES\n71: \n72: ### Playbook Sources\n73: \n74: | File | Role |\n75: |---|---|\n76: | `manual-testing-playbook.md` | Root directory page and scenario summary |\n77: | `../../feature-catalog/comparison-engine/self-contained-report.md` | Feature-catalog source describing the implementation contract |\n78: \n79: ### Implementation And Test Anchors\n80: \n81: | File | Role |\n82: |---|---|\n83: | `scripts/create_diff.py` | Primary implementation anchor |\n84: | `scripts/validate_report.py` | Validation anchor |\n85: \n86: ---\n87: \n88: ## 5. SOURCE METADATA\n89: \n90: - Group: SAFETY\n91: - Playbook ID: SAFE-002\n92: - Canonical root source: `manual-testing-playbook.md`\n93: - Feature file path: `safety/hostile-content-escaped.md`\n\n(End of file - total 93 lines)\n</content>","metadata":{"preview":"---\ntitle: \"SAFE-002 -- Hostile content is escaped\"\ndescription: \"This scenario validates hostile-content escaping for `SAFE-002`. It focuses on confirming document content containing markup is escaped as inert text and never becomes live markup or fails the validator.\"\nstage: routing\nversion: 1.0.0.0\n---\n\n# SAFE-002 -- Hostile content is escaped\n\nThis document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `SAFE-002`.\n\n---\n\n## 1. OVERVIEW\n\nThis scenario validates hostile-content escaping for `SAFE-002`. It focuses on confirming document content containing markup (for example `<script>`, `onerror=`) is escaped as inert text and never becomes live markup or fails the validator.\n\n### Why This Matters\n\nThe documents users compare are untrusted input, and any of them may contain markup that looks like an attack — a `<script>` tag, an `onerror=` handler, an `<img src=x>`. If the report renders that content as live markup instead of escaped text, opening the report could execute attacker-controlled code. This scenario feeds deliberately hostile content through the engine and proves the tokens are escaped to inert characters (`&lt;script&gt;`) while the report still validates safe, so untrusted input can never turn the report into an exploit.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/manual-testing-playbook/safety/hostile-content-escaped.md","text":"---\ntitle: \"SAFE-002 -- Hostile content is escaped\"\ndescription: \"This scenario validates hostile-content escaping for `SAFE-002`. It focuses on confirming document content containing markup is escaped as inert text and never becomes live markup or fails the validator.\"\nstage: routing\nversion: 1.0.0.0\n---\n\n# SAFE-002 -- Hostile content is escaped\n\nThis document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `SAFE-002`.\n\n---\n\n## 1. OVERVIEW\n\nThis scenario validates hostile-content escaping for `SAFE-002`. It focuses on confirming document content containing markup (for example `<script>`, `onerror=`) is escaped as inert text and never becomes live markup or fails the validator.\n\n### Why This Matters\n\nThe documents users compare are untrusted input, and any of them may contain markup that looks like an attack — a `<script>` tag, an `onerror=` handler, an `<img src=x>`. If the report renders that content as live markup instead of escaped text, opening the report could execute attacker-controlled code. This scenario feeds deliberately hostile content through the engine and proves the tokens are escaped to inert characters (`&lt;script&gt;`) while the report still validates safe, so untrusted input can never turn the report into an exploit.\n\n---\n\n## 2. SCENARIO CONTRACT\n\nOperators run the exact prompt and command sequence for `SAFE-002` and confirm the expected signals without contradictory evidence.\n\n- Objective: confirm document content containing markup is escaped as inert text, never becomes live markup, and does not fail the validator\n- Real user request: `One of these files has a fake script tag in the text — make sure the report is still safe.`\n- Prompt: `One of these files has a fake script tag in the text — make sure the report is still safe.`\n- Expected execution process: the operator prepares two small files whose content includes hostile tokens such as `<script>alert(1)</script>` and `<img src=x onerror=...>`, compares them with `compare-pair`, then runs `validate_report.py`; the engine escapes the tokens and the validator ignores escaped content while still passing.\n- Expected signals: the hostile tokens appear escaped in the report (`&lt;script&gt;`), no live `<script>` element exists in the markup, and the validator returns `PASS`.\n- Desired user-visible outcome: the hostile text is shown as literal characters, never executed, and the report still validates safe.\n- Pass/fail: PASS if the hostile tokens are escaped in the report body, no live script element is present, and the validator returns `PASS`; FAIL if any token renders as live markup, or the validator returns `FAIL`.\n\n---\n\n## 3. TEST EXECUTION\n\n### Prompt\n\n- Prompt: `One of these files has a fake script tag in the text — make sure the report is still safe.`\n\n### Commands\n\n1. `python3 scripts/create_diff.py compare-pair --before /tmp/hostile_before.md --after /tmp/hostile_after.md --report /tmp/hostile.html`\n2. `python3 scripts/validate_report.py /tmp/hostile.html`\n\n### Expected\n\nBefore step 1, create `/tmp/hostile_before.md` and `/tmp/hostile_after.md` whose text includes hostile tokens such as `<script>alert(1)</script>` and `<img src=x onerror=alert(1)>`. Step 1 compares them, writes `/tmp/hostile.html`, and exits `0`; the report shows those tokens escaped as `&lt;script&gt;...` literal text, with no live `<script>` element in the markup. Step 2 checks the report and returns `PASS` (exit `0`) because escaped content is ignored by the validator.\n\n### Evidence\n\nCapture the step 1 exit code and report path, a snippet of `/tmp/hostile.html` showing the hostile tokens rendered as escaped entities (`&lt;script&gt;`), confirmation that no live `<script>` element or inline handler exists in the page structure, and the step 2 validator `PASS` verdict.\n\n### Pass / Fail\n\n- **Pass**: the hostile tokens appear escaped (`&lt;script&gt;`, `&lt;img ... onerror=...&gt;`) in the report body, no live script element or inline handler is present in the markup, and step 2 returns `PASS`.\n- **Fail**: any hostile token renders as a live element or handler in the markup, or step 2 returns `FAIL`.\n\n### Failure Triage\n\n1. Search `/tmp/hostile.html` for the raw string `<script`; every occurrence inside the diff content must be the escaped form `&lt;script`, not a live tag.\n2. Distinguish the report's own structural markup (expected) from the compared content (must be escaped); the validator ignores escaped content, so a `FAIL` points at a real un-escaped element.\n3. Confirm the input files actually contain the hostile tokens as text before re-running; an input that never carried the tokens cannot exercise the escaping path.\n\n---\n\n## 4. SOURCE FILES\n\n### Playbook Sources\n\n| File | Role |\n|---|---|\n| `manual-testing-playbook.md` | Root directory page and scenario summary |\n| `../../feature-catalog/comparison-engine/self-contained-report.md` | Feature-catalog source describing the implementation contract |\n\n### Implementation And Test Anchors\n\n| File | Role |\n|---|---|\n| `scripts/create_diff.py` | Primary implementation anchor |\n| `scripts/validate_report.py` | Validation anchor |\n\n---\n\n## 5. SOURCE METADATA\n\n- Group: SAFETY\n- Playbook ID: SAFE-002\n- Canonical root source: `manual-testing-playbook.md`\n- Feature file path: `safety/hostile-content-escaped.md`","lineStart":1,"lineEnd":93,"totalLines":93,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/manual-testing-playbook/safety/hostile-content-escaped.md","time":{"start":1784210626339,"end":1784210626380}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a588191af772793f4dc651a"}},"id":"prt_f6b3d9721001VJGh2Y74H1jeQm","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
{"type":"tool_use","timestamp":1784210626391,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_EUHRfMYtu5oVpDDbi81oR6uP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/references/workflow.md","limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/references/workflow.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Baseline, Comparison, and Lifecycle Workflow\n3: description: The capture-before-edit invariant, the automatic snapshot flow, the explicit-pair fallback, snapshot storage, and cleanup lifecycle for create-diff.\n4: trigger_phrases:\n5:   - \"create-diff workflow\"\n6:   - \"capture baseline before edit\"\n7:   - \"explicit before after pair\"\n8:   - \"snapshot cleanup lifecycle\"\n9: importance_tier: normal\n10: contextType: implementation\n11: version: 1.0.0.0\n12: ---\n13: \n14: # Workflow: baseline, comparison, and lifecycle\n15: \n16: The core invariant: **capture the baseline before the edit.** A before/after review needs a real before-state, and once a file is overwritten the original is gone. `create-diff` never mutates the source — capture copies it into a local store.\n17: \n18: ## Automatic flow (snapshot-backed)\n19: \n20: Best when you control the moment before an edit (e.g. an AI is about to modify a document).\n21: \n22: ```bash\n23: # 1. BEFORE the edit\n24: python3 ../scripts/create_diff.py snapshot path/to/doc.md\n25: \n26: # 2. ... the edit happens ...\n27: \n28: # 3. AFTER the edit\n29: python3 ../scripts/create_diff.py compare path/to/doc.md --report review.html\n30: ```\n31: \n32: `compare` uses the file's **latest** snapshot as the \"before\" and the current file as the \"after\". If no snapshot exists it exits `4` and tells you to snapshot first or use the explicit pair.\n33: \n34: ## Explicit-pair flow (fallback)\n35: \n36: Best when there is no baseline, when comparing two arbitrary versions, or when the automatic store is unavailable or unwanted.\n37: \n38: ```bash\n39: python3 ../scripts/create_diff.py compare-pair \\\n40:   --before old.md --after new.md \\\n41:   --label-before \"v1\" --label-after \"v2\" \\\n42:   --report review.html\n43: ```\n44: \n45: No stored state is read or written. `--label-before`/`--label-after` set the names shown in the report (default: the file names).\n46: \n47: ## Where snapshots live\n48: \n49: Baselines are stored under a `.create-diff/` directory in the current working directory (override with `--state-dir DIR`). Each source path gets its own subdirectory keyed by a hash of its absolute path, containing the copied blobs plus a `manifest.json` recording capture time, size, and SHA-256. Writes are atomic (temp file + rename); the source is only ever read.\n50: \n51: Add `.create-diff/` to `.gitignore` if you run this inside a repository — it is local scratch state, not a deliverable.\n52: \n53: ## Lifecycle\n54: \n55: ```bash\n56: # What baselines exist (all, or for one file)\n57: python3 ../scripts/create_diff.py status\n58: python3 ../scripts/create_diff.py status path/to/doc.md\n59: \n60: # Prune old baselines (preview first)\n61: python3 ../scripts/create_diff.py cleanup --older-than 14 --dry-run\n62: python3 ../scripts/create_diff.py cleanup --older-than 14\n63: ```\n64: \n65: `cleanup` with no `--older-than` removes all matching snapshots; scope it with `--file` and preview with `--dry-run`.\n66: \n67: ## After generating a report\n68: \n69: Always validate the report before handing it off:\n70: \n71: ```bash\n72: python3 ../scripts/validate_report.py review.html\n73: ```\n74: \n75: Then report the change summary and the report path. If the source file changed during the run, something is wrong — comparison must be read-only against the source.\n\n(End of file - total 75 lines)\n</content>","metadata":{"preview":"---\ntitle: Baseline, Comparison, and Lifecycle Workflow\ndescription: The capture-before-edit invariant, the automatic snapshot flow, the explicit-pair fallback, snapshot storage, and cleanup lifecycle for create-diff.\ntrigger_phrases:\n  - \"create-diff workflow\"\n  - \"capture baseline before edit\"\n  - \"explicit before after pair\"\n  - \"snapshot cleanup lifecycle\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.0.0.0\n---\n\n# Workflow: baseline, comparison, and lifecycle\n\nThe core invariant: **capture the baseline before the edit.** A before/after review needs a real before-state, and once a file is overwritten the original is gone. `create-diff` never mutates the source — capture copies it into a local store.\n\n## Automatic flow (snapshot-backed)\n\nBest when you control the moment before an edit (e.g. an AI is about to modify a document).","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-diff/references/workflow.md","text":"---\ntitle: Baseline, Comparison, and Lifecycle Workflow\ndescription: The capture-before-edit invariant, the automatic snapshot flow, the explicit-pair fallback, snapshot storage, and cleanup lifecycle for create-diff.\ntrigger_phrases:\n  - \"create-diff workflow\"\n  - \"capture baseline before edit\"\n  - \"explicit before after pair\"\n  - \"snapshot cleanup lifecycle\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.0.0.0\n---\n\n# Workflow: baseline, comparison, and lifecycle\n\nThe core invariant: **capture the baseline before the edit.** A before/after review needs a real before-state, and once a file is overwritten the original is gone. `create-diff` never mutates the source — capture copies it into a local store.\n\n## Automatic flow (snapshot-backed)\n\nBest when you control the moment before an edit (e.g. an AI is about to modify a document).\n\n```bash\n# 1. BEFORE the edit\npython3 ../scripts/create_diff.py snapshot path/to/doc.md\n\n# 2. ... the edit happens ...\n\n# 3. AFTER the edit\npython3 ../scripts/create_diff.py compare path/to/doc.md --report review.html\n```\n\n`compare` uses the file's **latest** snapshot as the \"before\" and the current file as the \"after\". If no snapshot exists it exits `4` and tells you to snapshot first or use the explicit pair.\n\n## Explicit-pair flow (fallback)\n\nBest when there is no baseline, when comparing two arbitrary versions, or when the automatic store is unavailable or unwanted.\n\n```bash\npython3 ../scripts/create_diff.py compare-pair \\\n  --before old.md --after new.md \\\n  --label-before \"v1\" --label-after \"v2\" \\\n  --report review.html\n```\n\nNo stored state is read or written. `--label-before`/`--label-after` set the names shown in the report (default: the file names).\n\n## Where snapshots live\n\nBaselines are stored under a `.create-diff/` directory in the current working directory (override with `--state-dir DIR`). Each source path gets its own subdirectory keyed by a hash of its absolute path, containing the copied blobs plus a `manifest.json` recording capture time, size, and SHA-256. Writes are atomic (temp file + rename); the source is only ever read.\n\nAdd `.create-diff/` to `.gitignore` if you run this inside a repository — it is local scratch state, not a deliverable.\n\n## Lifecycle\n\n```bash\n# What baselines exist (all, or for one file)\npython3 ../scripts/create_diff.py status\npython3 ../scripts/create_diff.py status path/to/doc.md\n\n# Prune old baselines (preview first)\npython3 ../scripts/create_diff.py cleanup --older-than 14 --dry-run\npython3 ../scripts/create_diff.py cleanup --older-than 14\n```\n\n`cleanup` with no `--older-than` removes all matching snapshots; scope it with `--file` and preview with `--dry-run`.\n\n## After generating a report\n\nAlways validate the report before handing it off:\n\n```bash\npython3 ../scripts/validate_report.py review.html\n```\n\nThen report the change summary and the report path. If the source file changed during the run, something is wrong — comparison must be read-only against the source.","lineStart":1,"lineEnd":75,"totalLines":75,"truncated":false}},"title":".opencode/skills/sk-doc/create-diff/references/workflow.md","time":{"start":1784210626372,"end":1784210626389}},"metadata":{"openai":{"itemId":"fc_0c0eb740cb1ea7b5016a58e4c21a7c81918de0db83692ffc0e"}},"id":"prt_f6b3d972e0010v1MFuaciB9FW4","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3d57e1001EFJ5zgaUOzBKXJ"}}
