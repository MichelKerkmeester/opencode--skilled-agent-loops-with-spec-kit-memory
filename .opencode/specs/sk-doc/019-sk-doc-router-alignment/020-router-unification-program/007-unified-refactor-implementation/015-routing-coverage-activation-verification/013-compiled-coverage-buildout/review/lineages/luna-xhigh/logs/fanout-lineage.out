gpt-5.6-luna-fast session.id=ses_0ae5fae5bffespQwB5PBFyzL1b small=false agent=build mode=primary\n\n  Line 1225801: timestamp=2026-07-11T14:42:10.743Z level=ERROR run=60df0840 message=\"stream error\" providerID=openai modelID=gpt-5.6-luna-fast session.id=ses_0ae5fae5bffespQwB5PBFyzL1b small=false agent=build mode=primary error.error=\"AI_APICallError: Model not found gpt-5.6-luna\"\n\n  Line 1225802: timestamp=2026-07-11T14:42:12.241Z level=INFO run=47b400cb message=stream providerID=openai modelID=gpt-5.6-luna-fast session.id=ses_0ae5fa46effe9m1F1Pc77GmOuT small=false agent=build mode=primary\n\n  Line 1225804: timestamp=2026-07-11T14:42:13.488Z level=ERROR run=47b400cb message=\"stream error\" providerID=openai modelID=gpt-5.6-luna-fast session.id=ses_0ae5fa46effe9m1F1Pc77GmOuT small=false agent=build mode=primary error.error=\"AI_APICallError: Model not found gpt-5.6-luna\"\n\n  Line 1225805: timestamp=2026-07-11T14:42:14.222Z level=INFO run=9e5bde16 message=stream providerID=openai modelID=gpt-5.6-luna-fast session.id=ses_0ae5f9ac2ffekd3g74HKsjZ0DK small=false agent=build mode=primary\n\n  Line 1225807: timestamp=2026-07-11T14:42:15.609Z level=ERROR run=9e5bde16 message=\"stream error\" providerID=openai modelID=gpt-5.6-luna-fast session.id=ses_0ae5f9ac2ffekd3g74HKsjZ0DK small=false agent=build mode=primary error.error=\"AI_APICallError: Model not found gpt-5.6-luna\"\n\n  Line 1225808: timestamp=2026-07-11T14:42:16.825Z level=INFO run=a5b67cbb message=stream providerID=openai modelID=gpt-5.6-luna-fast session.id=ses_0ae5f8eb2ffeElNdrMmumnQC3U small=false agent=build mode=primary\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"modelID=gpt-5\\.6-luna-fast","time":{"start":1784692420373,"end":1784692420426}},"metadata":{"openai":{"itemId":"fc_0ebaa4730d321913016a603ec3b8388191a05e662baafe874a"}},"id":"prt_f87f52c67001kqleleOBJfvmsf","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f4eec4001h0XG7p0c0Dc2xW"}}
