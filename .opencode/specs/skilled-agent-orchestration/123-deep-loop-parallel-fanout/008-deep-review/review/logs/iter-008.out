   180	        specFolder: nsB.specFolder,
   181	        loopType: nsB.loopType,
   182	        sessionId: nsB.sessionId,
   183	        id: 'node-b',
   184	        kind: 'CLAIM',
   185	        name: 'lineage B finding',
   186	      });
   187	
   188	      // Each session sees only its own nodes — this is the per-lineage isolation guarantee
   189	      const nodesA = db.getNodes({ specFolder: nsA.specFolder, loopType: nsA.loopType, sessionId: nsA.sessionId });
