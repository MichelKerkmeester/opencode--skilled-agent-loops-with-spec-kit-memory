{
  // Full-skill surface classification for deep-agent-improvement.
  // All targets are now evaluated exclusively via dynamic mode
  // (generate-profile.cjs + 5-dimension scoring). No static profiles
  // are shipped; the targets array is intentionally empty. Promotion
  // requires explicit per-target approval under dynamic mode.
  "version": 3,
  "defaultMode": "proposal-first",

  // Dynamic profile generation is the canonical (and only) evaluation path.
  // Agents are evaluated against their own derived structure and rules.
  // Dynamic profiles are not automatically promotion-eligible.
  "dynamicProfileEnabled": true,

  // Path to the script that generates a dynamic target profile on the fly.
  "dynamicProfileScript": ".opencode/skills/deep-agent-improvement/scripts/generate-profile.cjs",

  // Path to the integration-surface scanner that checks mirror parity,
  // command coverage, permission alignment, and resource references
  // for a given target agent across all runtime directories.
  "integrationScanScript": ".opencode/skills/deep-agent-improvement/scripts/scan-integration.cjs",

  // profileCatalog remains referenced for path consistency with config, but
  // the directory is intentionally empty (contains only .gitkeep).
  "profileCatalog": ".opencode/skills/deep-agent-improvement/assets/agent-improvement/target-profiles",
  "targets": [],

  // `fixed` declares files deep-agent-improvement MUST NEVER mutate. These paths
  // belong to LIVE spec-kit surfaces (commands + templates) outside this
  // skill; they are protections, not static profiles for the handover agent.
  "fixed": [
    ".opencode/commands/speckit/handover.md",
    ".agents/commands/speckit/handover.toml",
    ".gemini/commands/speckit/handover.toml",
    ".opencode/skills/system-spec-kit/templates/handover.md"
  ],

  // `forbidden` declares files deep-agent-improvement MUST NEVER write to even
  // when a candidate superficially matches. Same rationale as `fixed`.
  "forbidden": [
    ".opencode/commands/speckit/handover.md",
    ".agents/commands/speckit/handover.toml",
    ".gemini/commands/speckit/handover.toml",
    ".opencode/skills/system-spec-kit/templates/handover.md"
  ],
  "packaging": {
    "mirrorSyncMode": "downstream-only",
    "forbidMirrorEvidenceAsBenchmarkTruth": true
  }
}
