{"type":"tool_use","timestamp":1780727822619,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_KYPZjtlKMOeGKsxNS5BErFzL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py","offset":1,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py</path>\n<type>file</type>\n<content>\n1: import uuid\n2: from datetime import datetime\n3: \n4: from pgvector.sqlalchemy import Vector\n5: from sqlalchemy import DateTime, Float, ForeignKey, Index, Integer, Text, func, text\n6: from sqlalchemy.dialects.postgresql import JSONB, TSVECTOR, UUID as PG_UUID\n7: from sqlalchemy.orm import Mapped, mapped_column\n8: \n9: from common.constants import VECTOR_DIM\n10: from common.models.base import Base\n11: \n12: \n13: class Memory(Base):\n14:     __tablename__ = \"memories\"\n15: \n16:     id: Mapped[uuid.UUID] = mapped_column(\n17:         primary_key=True, server_default=text(\"gen_random_uuid()\")\n18:     )\n19:     tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n20:     fleet_id: Mapped[str | None] = mapped_column(Text)\n21:     agent_id: Mapped[str] = mapped_column(Text, nullable=False)\n22:     memory_type: Mapped[str] = mapped_column(Text, nullable=False)\n23:     content: Mapped[str] = mapped_column(Text, nullable=False)\n24:     embedding = mapped_column(Vector(VECTOR_DIM))\n25:     weight: Mapped[float] = mapped_column(Float, server_default=text(\"0.5\"))\n26:     source_uri: Mapped[str | None] = mapped_column(Text)\n27:     run_id: Mapped[str | None] = mapped_column(Text)\n28:     metadata_: Mapped[dict | None] = mapped_column(\"metadata\", JSONB)\n29:     created_at: Mapped[datetime] = mapped_column(\n30:         DateTime(timezone=True), server_default=text(\"now()\")\n31:     )\n32:     title: Mapped[str | None] = mapped_column(Text)\n33:     content_hash: Mapped[str | None] = mapped_column(Text)\n34:     # Per-attempt idempotency token (CAURA-602). Server-derived from\n35:     # ``X-Bulk-Attempt-Id + \":\" + index`` on the bulk path; NULL for\n36:     # single-write and pre-rollout rows. The partial unique index\n37:     # ``ix_memories_attempt_unique`` (migration 007) enforces uniqueness\n38:     # only when this is non-NULL, so legacy paths are unaffected.\n39:     client_request_id: Mapped[str | None] = mapped_column(Text)\n40:     expires_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n41:     deleted_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n42:     search_vector = mapped_column(TSVECTOR)\n43: \n44:     # RDF triple representation\n45:     subject_entity_id: Mapped[uuid.UUID | None] = mapped_column(\n46:         PG_UUID(as_uuid=True),\n47:         ForeignKey(\"entities.id\", ondelete=\"SET NULL\"),\n48:     )\n49:     predicate: Mapped[str | None] = mapped_column(Text)\n50:     object_value: Mapped[str | None] = mapped_column(Text)\n51: \n52:     # Temporal validity windows\n53:     ts_valid_start: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n54:     ts_valid_end: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n55: \n56:     # Status lifecycle\n57:     status: Mapped[str] = mapped_column(\n58:         Text, server_default=text(\"'active'\"), nullable=False\n59:     )\n60: \n61:     # Visibility scope\n62:     visibility: Mapped[str] = mapped_column(\n63:         Text,\n64:         server_default=text(\"'scope_team'\"),\n65:         nullable=False,\n66:     )\n67: \n68:     # Recall tracking (incremented on agent-facing retrievals only)\n69:     recall_count: Mapped[int] = mapped_column(\n70:         Integer, server_default=text(\"0\"), nullable=False\n71:     )\n72:     last_recalled_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n73: \n74:     # Crystallizer dedup tracking\n75:     last_dedup_checked_at: Mapped[datetime | None] = mapped_column(\n76:         DateTime(timezone=True)\n77:     )\n78: \n79:     # Contradiction tracking\n80:     supersedes_id: Mapped[uuid.UUID | None] = mapped_column(\n81:         PG_UUID(as_uuid=True),\n82:         ForeignKey(\"memories.id\", ondelete=\"SET NULL\"),\n83:     )\n84: \n85:     __table_args__ = (\n86:         Index(\"ix_memories_tenant_type\", \"tenant_id\", \"memory_type\"),\n87:         Index(\"ix_memories_tenant_agent\", \"tenant_id\", \"agent_id\"),\n88:         Index(\"ix_memories_content_hash\", \"tenant_id\", \"content_hash\"),\n89:         # Backs per-attempt bulk-write idempotency (CAURA-602). Created\n90:         # ``CONCURRENTLY`` in migration 007 with the same predicates;\n91:         # declared here so SQLAlchemy reflection / Alembic autogen\n92:         # round-trips match the live schema. ``COALESCE(fleet_id, '')``\n93:         # makes fleetless rows participate in the unique constraint —\n94:         # PostgreSQL treats NULLs as distinct by default, so without\n95:         # this two retries with ``fleet_id IS NULL`` would both insert.\n96:         Index(\n97:             \"ix_memories_attempt_unique\",\n98:             \"tenant_id\",\n99:             func.coalesce(text(\"fleet_id\"), \"\"),\n100:             \"client_request_id\",\n101:             unique=True,\n102:             postgresql_where=text(\n103:                 \"deleted_at IS NULL AND client_request_id IS NOT NULL\"\n104:             ),\n105:         ),\n106:         Index(\"ix_memories_valid_range\", \"ts_valid_start\", \"ts_valid_end\"),\n107:         Index(\"ix_memories_subject_entity\", \"subject_entity_id\"),\n108:         Index(\"ix_memories_recall_count\", \"recall_count\"),\n109:         Index(\"ix_memories_tenant_fleet\", \"tenant_id\", \"fleet_id\"),\n110:         # Backs the cursor-paginated list path (``list_by_filters`` +\n111:         # the ``memclaw_list`` MCP tool) which orders by\n112:         # ``(created_at DESC, id DESC)`` under ``tenant_id = ?`` and\n113:         # ``deleted_at IS NULL``. Partial WHERE keeps the index small\n114:         # since soft-deleted rows are never read on the hot path.\n115:         # Bare-column references (``created_at.desc()`` not\n116:         # ``text(\"created_at DESC\")``) so Alembic autogen can reflect\n117:         # and compare the index — matches ``analysis_report.py:38``.\n118:         Index(\n119:             \"ix_memories_tenant_created_active\",\n120:             \"tenant_id\",\n121:             created_at.desc(),\n122:             id.desc(),\n123:             postgresql_where=text(\"deleted_at IS NULL\"),\n124:         ),\n125:         # Backs the CAURA-656 purge-fanout discovery query\n126:         # (``list_tenants_with_purgeable_memories``). Every other\n127:         # partial index on this table is keyed on\n128:         # ``deleted_at IS NULL`` (active path); without this\n129:         # complement the soft-deleted-side discovery falls back to a\n130:         # full scan.\n131:         Index(\n132:             \"ix_memories_purgeable\",\n133:             \"tenant_id\",\n134:             postgresql_where=text(\"deleted_at IS NOT NULL\"),\n135:         ),\n136:     )\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"import uuid\nfrom datetime import datetime\n\nfrom pgvector.sqlalchemy import Vector\nfrom sqlalchemy import DateTime, Float, ForeignKey, Index, Integer, Text, func, text\nfrom sqlalchemy.dialects.postgresql import JSONB, TSVECTOR, UUID as PG_UUID\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.constants import VECTOR_DIM\nfrom common.models.base import Base\n\n\nclass Memory(Base):\n    __tablename__ = \"memories\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py","text":"import uuid\nfrom datetime import datetime\n\nfrom pgvector.sqlalchemy import Vector\nfrom sqlalchemy import DateTime, Float, ForeignKey, Index, Integer, Text, func, text\nfrom sqlalchemy.dialects.postgresql import JSONB, TSVECTOR, UUID as PG_UUID\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.constants import VECTOR_DIM\nfrom common.models.base import Base\n\n\nclass Memory(Base):\n    __tablename__ = \"memories\"\n\n    id: Mapped[uuid.UUID] = mapped_column(\n        primary_key=True, server_default=text(\"gen_random_uuid()\")\n    )\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False, index=True)\n    fleet_id: Mapped[str | None] = mapped_column(Text)\n    agent_id: Mapped[str] = mapped_column(Text, nullable=False)\n    memory_type: Mapped[str] = mapped_column(Text, nullable=False)\n    content: Mapped[str] = mapped_column(Text, nullable=False)\n    embedding = mapped_column(Vector(VECTOR_DIM))\n    weight: Mapped[float] = mapped_column(Float, server_default=text(\"0.5\"))\n    source_uri: Mapped[str | None] = mapped_column(Text)\n    run_id: Mapped[str | None] = mapped_column(Text)\n    metadata_: Mapped[dict | None] = mapped_column(\"metadata\", JSONB)\n    created_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), server_default=text(\"now()\")\n    )\n    title: Mapped[str | None] = mapped_column(Text)\n    content_hash: Mapped[str | None] = mapped_column(Text)\n    # Per-attempt idempotency token (CAURA-602). Server-derived from\n    # ``X-Bulk-Attempt-Id + \":\" + index`` on the bulk path; NULL for\n    # single-write and pre-rollout rows. The partial unique index\n    # ``ix_memories_attempt_unique`` (migration 007) enforces uniqueness\n    # only when this is non-NULL, so legacy paths are unaffected.\n    client_request_id: Mapped[str | None] = mapped_column(Text)\n    expires_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    deleted_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    search_vector = mapped_column(TSVECTOR)\n\n    # RDF triple representation\n    subject_entity_id: Mapped[uuid.UUID | None] = mapped_column(\n        PG_UUID(as_uuid=True),\n        ForeignKey(\"entities.id\", ondelete=\"SET NULL\"),\n    )\n    predicate: Mapped[str | None] = mapped_column(Text)\n    object_value: Mapped[str | None] = mapped_column(Text)\n\n    # Temporal validity windows\n    ts_valid_start: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n    ts_valid_end: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n\n    # Status lifecycle\n    status: Mapped[str] = mapped_column(\n        Text, server_default=text(\"'active'\"), nullable=False\n    )\n\n    # Visibility scope\n    visibility: Mapped[str] = mapped_column(\n        Text,\n        server_default=text(\"'scope_team'\"),\n        nullable=False,\n    )\n\n    # Recall tracking (incremented on agent-facing retrievals only)\n    recall_count: Mapped[int] = mapped_column(\n        Integer, server_default=text(\"0\"), nullable=False\n    )\n    last_recalled_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True))\n\n    # Crystallizer dedup tracking\n    last_dedup_checked_at: Mapped[datetime | None] = mapped_column(\n        DateTime(timezone=True)\n    )\n\n    # Contradiction tracking\n    supersedes_id: Mapped[uuid.UUID | None] = mapped_column(\n        PG_UUID(as_uuid=True),\n        ForeignKey(\"memories.id\", ondelete=\"SET NULL\"),\n    )\n\n    __table_args__ = (\n        Index(\"ix_memories_tenant_type\", \"tenant_id\", \"memory_type\"),\n        Index(\"ix_memories_tenant_agent\", \"tenant_id\", \"agent_id\"),\n        Index(\"ix_memories_content_hash\", \"tenant_id\", \"content_hash\"),\n        # Backs per-attempt bulk-write idempotency (CAURA-602). Created\n        # ``CONCURRENTLY`` in migration 007 with the same predicates;\n        # declared here so SQLAlchemy reflection / Alembic autogen\n        # round-trips match the live schema. ``COALESCE(fleet_id, '')``\n        # makes fleetless rows participate in the unique constraint —\n        # PostgreSQL treats NULLs as distinct by default, so without\n        # this two retries with ``fleet_id IS NULL`` would both insert.\n        Index(\n            \"ix_memories_attempt_unique\",\n            \"tenant_id\",\n            func.coalesce(text(\"fleet_id\"), \"\"),\n            \"client_request_id\",\n            unique=True,\n            postgresql_where=text(\n                \"deleted_at IS NULL AND client_request_id IS NOT NULL\"\n            ),\n        ),\n        Index(\"ix_memories_valid_range\", \"ts_valid_start\", \"ts_valid_end\"),\n        Index(\"ix_memories_subject_entity\", \"subject_entity_id\"),\n        Index(\"ix_memories_recall_count\", \"recall_count\"),\n        Index(\"ix_memories_tenant_fleet\", \"tenant_id\", \"fleet_id\"),\n        # Backs the cursor-paginated list path (``list_by_filters`` +\n        # the ``memclaw_list`` MCP tool) which orders by\n        # ``(created_at DESC, id DESC)`` under ``tenant_id = ?`` and\n        # ``deleted_at IS NULL``. Partial WHERE keeps the index small\n        # since soft-deleted rows are never read on the hot path.\n        # Bare-column references (``created_at.desc()`` not\n        # ``text(\"created_at DESC\")``) so Alembic autogen can reflect\n        # and compare the index — matches ``analysis_report.py:38``.\n        Index(\n            \"ix_memories_tenant_created_active\",\n            \"tenant_id\",\n            created_at.desc(),\n            id.desc(),\n            postgresql_where=text(\"deleted_at IS NULL\"),\n        ),\n        # Backs the CAURA-656 purge-fanout discovery query\n        # (``list_tenants_with_purgeable_memories``). Every other\n        # partial index on this table is keyed on\n        # ``deleted_at IS NULL`` (active path); without this\n        # complement the soft-deleted-side discovery falls back to a\n        # full scan.\n        Index(\n            \"ix_memories_purgeable\",\n            \"tenant_id\",\n            postgresql_where=text(\"deleted_at IS NOT NULL\"),\n        ),\n    )","lineStart":1,"lineEnd":136,"totalLines":136,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py","time":{"start":1780727822610,"end":1780727822617}},"metadata":{"openai":{"itemId":"fc_0326cbe870de78b7016a23c00e3e908191b108b11c7dd9c2e1"}},"id":"prt_e9ba637c6001gu36Di4d517S6O","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba62309001EhyPASXI32N7ey"}}
{"type":"step_finish","timestamp":1780727822913,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba63a3f001mwgmSBvCR59M2m","reason":"tool-calls","snapshot":"26e9db12cffad3970a26e352c1512eed80ddcdad","messageID":"msg_e9ba62309001EhyPASXI32N7ey","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","type":"step-finish","tokens":{"total":149278,"input":120499,"output":76,"reasoning":31,"cache":{"write":0,"read":28672}},"cost":0}}
{"type":"step_start","timestamp":1780727825147,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba642f8001tqZC4ksWlx4RuJ","messageID":"msg_e9ba63b4a001QV4xZz5RFvBCte","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","snapshot":"09e7841ced89204d0126537a3c24917595f73370","type":"step-start"}}
{"type":"text","timestamp":1780727911098,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba6a7e4001N1VhvpAi4aHYoG","messageID":"msg_e9ba63b4a001QV4xZz5RFvBCte","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","type":"text","text":"## Mechanism\nMemClaw’s `/search` request enters `core-api` as `SearchRequest`, which requires `tenant_id`, a non-empty `query`, optional `fleet_ids`, agent/type/status/time filters, and `top_k` capped at 1-20 (`core-api/src/core_api/schemas.py:303`, `core-api/src/core_api/schemas.py:314`). The REST route enforces readable tenant scope, applies a per-tenant search slot, derives an effective caller agent, and for low-trust agents forces fleet scoping before calling `search_memories` (`core-api/src/core_api/routes/memories.py:1408`, `core-api/src/core_api/routes/memories.py:1412`, `core-api/src/core_api/routes/memories.py:1425`, `core-api/src/core_api/routes/memories.py:1438`, `core-api/src/core_api/routes/memories.py:1456`).\n\nThe active path is a decomposed pipeline: resolve profile, extract temporal hint, classify query, embed plus entity boost, scored storage search, post-filter, serialize, optionally inject STM, then track recalls (`core-api/src/core_api/services/memory_service.py:2984`, `core-api/src/core_api/pipeline/compositions/search.py:17`, `core-api/src/core_api/pipeline/compositions/search.py:20`). Search profile resolution sets effective `top_k`, `min_similarity`, adaptive FTS weight, freshness, graph hops, and similarity blend (`core-api/src/core_api/pipeline/steps/search/resolve_search_profile.py:33`).\n\nCandidate generation has two modes. First, `ClassifyQuery` tokenizes the query and searches the entity FTS index; if entity matches are specific enough, it graph-expands entities, loads linked memories, skips embedding and scored search, and ranks by graph-hop boost (`core-api/src/core_api/pipeline/steps/search/classify_query.py:1`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:75`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:99`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:124`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:125`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:378`). It explicitly rejects over-broad entity matches above a cap and falls through to hybrid search (`core-api/src/core_api/pipeline/steps/search/classify_query.py:82`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:90`, `core-api/src/core_api/constants.py:450`). Otherwise it routes to keyword or semantic search based on adaptive FTS weight (`core-api/src/core_api/pipeline/steps/search/classify_query.py:186`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:187`).\n\nHybrid candidate generation runs query embedding and entity/graph boost concurrently (`core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:1`, `core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:154`). Query embeddings use `get_query_embedding`, which supports instruction-aware asymmetric query/document embedding but falls back to symmetric `embed` for local/symmetric providers (`common/embedding/_service.py:257`, `common/embedding/_service.py:264`, `common/embedding/_service.py:290`, `common/embedding/_service.py:296`). The query embedding cache key includes model, vector dimension, instruction, tenant, and normalized query, with an in-process stampede guard for concurrent cold misses (`core-api/src/core_api/services/memory_service.py:2615`, `core-api/src/core_api/services/memory_service.py:2652`, `core-api/src/core_api/services/memory_service.py:2672`). Entity boost uses entity FTS, optional graph expansion, linked-memory collection, hop-based boosts, and a cap on boosted memories (`core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:60`, `core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:73`, `core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:92`, `core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:109`, `core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:113`). If entity boost times out after embedding succeeds, it degrades to vector-only search instead of failing the query (`core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:168`, `core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:195`).\n\nScoring is not RRF or cross-encoder reranking; it is a server-side CTE composite score. Storage computes pgvector cosine `vec_sim`, FTS `ts_rank_cd`, a blended similarity score, then blends similarity with memory weight and multiplies by freshness, entity boost, recall boost, temporal/date-range boosts, currency, and status penalty (`core-storage-api/src/core_storage_api/services/postgres_service.py:895`, `core-storage-api/src/core_storage_api/services/postgres_service.py:904`, `core-storage-api/src/core_storage_api/services/postgres_service.py:919`, `core-storage-api/src/core_storage_api/services/postgres_service.py:973`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1050`). Null-embedding rows remain discoverable through FTS-only fallback instead of being ranked as null/zero-vector noise (`core-storage-api/src/core_storage_api/services/postgres_service.py:908`, `core-storage-api/src/core_storage_api/services/postgres_service.py:919`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1071`). Scope filtering happens in the same scored query: tenant/readable-tenants, deleted rows, fleet visibility, caller visibility, agent/type/status, and valid-time filters (`core-storage-api/src/core_storage_api/services/postgres_service.py:1101`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1111`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1120`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1129`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1142`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1157`). Results are ordered by score and recency (`core-storage-api/src/core_storage_api/services/postgres_service.py:1188`).\n\nResult shaping is intentionally bounded. MemClaw overfetches `top_k * SEARCH_OVERFETCH_FACTOR` from storage, then post-filters by minimum vector similarity and trims to the final requested `top_k` (`core-api/src/core_api/pipeline/steps/search/execute_scored_search.py:52`, `core-api/src/core_api/pipeline/steps/search/execute_scored_search.py:59`, `core-api/src/core_api/pipeline/steps/search/post_filter_results.py:20`, `core-api/src/core_api/pipeline/steps/search/post_filter_results.py:37`). FTS-only rows bypass the vector threshold via `has_embedding=False`, preserving recall during pending-embedding windows (`core-api/src/core_api/pipeline/steps/search/post_filter_results.py:21`, `core-api/src/core_api/pipeline/steps/search/post_filter_results.py:30`). Serialization returns `MemoryOut` items with entity links and rounded composite score as `similarity` (`core-api/src/core_api/pipeline/steps/search/load_and_serialize.py:85`). `/recall` then wraps search with a token-bounded LLM brief; its formatter exposes only type/title/status/content fields to the summarizer (`core-api/src/core_api/services/recall_service.py:44`, `core-api/src/core_api/services/recall_service.py:51`, `core-api/src/core_api/services/recall_service.py:65`).\n\n## Teachings for Spec Kit Memory\n- **Claim** · Add a bounded query-strategy classifier before normal hybrid retrieval. **Evidence** · MemClaw short-circuits specific entity queries to entity graph lookup and skips embedding/scored search, but declines over-broad entity matches above a calibrated cap (`core-api/src/core_api/pipeline/steps/search/classify_query.py:82`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:90`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:125`, `core-api/src/core_api/pipeline/steps/search/classify_query.py:128`, `core-api/src/core_api/constants.py:450`). **Maps-to** · 027 child 007 semantic-trigger-fallback plus new sub-packet for query-strategy classification; Spec Kit already has hybrid lexical+semantic retrieval. **Verdict** · ADAPT. **Risk** · Entity short-circuit can overfit to broad topical terms and skip the stronger fused scorer. **Confidence** · High. **Why it transfers (or not)** · It transfers if “entity” means local anchors such as spec folder, file path, symbol, memory title, trigger phrase, or causal node; it should not copy fleet graph traversal wholesale.\n\n- **Claim** · Preserve lexical-only recall during vector gaps with overfetch-before-thresholding. **Evidence** · MemClaw admits null-embedding rows only when they match FTS, scores them by FTS rather than zero-vector blend, overfetches `top_k * 2`, then trims after min-sim filtering (`core-storage-api/src/core_storage_api/services/postgres_service.py:908`, `core-storage-api/src/core_storage_api/services/postgres_service.py:919`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1071`, `core-api/src/core_api/pipeline/steps/search/execute_scored_search.py:59`, `core-api/src/core_api/pipeline/steps/search/post_filter_results.py:21`, `core-api/src/core_api/constants.py:473`). **Maps-to** · 027 child 007 semantic-trigger-fallback; Spec Kit already has separate SQLite index plus separate vector store and pending vectors. **Verdict** · ADOPT. **Risk** · Lexical-only rows can crowd out semantic rows if FTS normalization is too permissive. **Confidence** · High. **Why it transfers (or not)** · This is directly relevant to a local self-maintaining index: SQLite/BM25 rows should remain searchable while the separate vector store is lagging, failed, or reconciling.\n\n- **Claim** · Cache query embeddings with embedder-version keys and a cold-miss stampede guard. **Evidence** · MemClaw’s query cache key includes model, vector dimension, instruction, tenant, and normalized query; concurrent cold callers await the same in-flight future (`core-api/src/core_api/services/memory_service.py:2599`, `core-api/src/core_api/services/memory_service.py:2652`, `core-api/src/core_api/services/memory_service.py:2661`, `core-api/src/core_api/services/memory_service.py:2672`, `core-api/src/core_api/services/memory_service.py:2687`). **Maps-to** · new sub-packet; Spec Kit already has local ollama/nomic vectors and embedder pointer management. **Verdict** · ADAPT. **Risk** · Stale cache if the key omits active embedder manifest, dimension, prompt/instruction, or normalization version. **Confidence** · Medium-high. **Why it transfers (or not)** · The tenant dimension does not transfer, but model/dimension/instruction/query and active embedder manifest do; it improves local latency without adopting fleet cache infrastructure.\n\n- **Claim** · Keep retrieval diagnostics as first-class output for tuning, not just logs. **Evidence** · Diagnostic mode widens candidate capture and records all candidates, search params, retrieval strategy, and original top_k (`core-api/src/core_api/pipeline/steps/search/execute_scored_search.py:52`, `core-api/src/core_api/services/memory_service.py:3084`, `core-api/src/core_api/services/memory_service.py:3087`, `core-api/src/core_api/services/recall_service.py:205`, `core-api/src/core_api/services/recall_service.py:210`). **Maps-to** · new sub-packet; Spec Kit already has shadow-first learning-feedback reducers and rich MCP search surfaces. **Verdict** · ADAPT. **Risk** · Diagnostic payloads can become token-expensive if exposed by default. **Confidence** · Medium. **Why it transfers (or not)** · Single-user local systems benefit from transparent “why this result” traces, but should keep them opt-in/debug-profile only.\n\n## Negative knowledge\n- Do not copy MemClaw’s tenant/fleet/trust visibility machinery into Spec Kit Memory. It exists to prevent cross-tenant/fleet disclosure and agent-scope leaks (`core-api/src/core_api/routes/memories.py:1408`, `core-api/src/core_api/routes/memories.py:1438`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1101`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1129`).\n\n- Do not copy PostgreSQL/pgvector-specific CTE implementation details as-is. MemClaw stores vectors in `pgvector` and text search in PostgreSQL `TSVECTOR` (`common/models/memory.py:4`, `common/models/memory.py:24`, `common/models/memory.py:42`); Spec Kit uses SQLite plus a separate vector store, so only the scoring shape transfers.\n\n- Do not introduce RRF/cross-encoder reranking from MemClaw; this pass found composite scoring, not RRF or a reranker. The active scoring is explicit blend/multiplier math in storage (`core-storage-api/src/core_storage_api/services/postgres_service.py:973`, `core-storage-api/src/core_storage_api/services/postgres_service.py:1050`).\n\n- Do not copy per-agent retrieval profiles literally. MemClaw advertises per-agent retrieval tuning for fleets (`README.md:267`, `README.md:269`), while Spec Kit is single-user/local; any equivalent should be a local profile or shadow-learned configuration, not agent governance.\n\n- Defer recall-count boost and decay lessons to iteration 089. MemClaw multiplies scores by recent recall count (`core-storage-api/src/core_storage_api/services/postgres_service.py:954`, `core-storage-api/src/core_storage_api/services/postgres_service.py:963`), but this overlaps ranking/decay and may conflict with Spec Kit’s FSRS decay/co-activation model.\n\n## Open questions\n- Should Spec Kit’s “entity lookup” equivalent be based on trigger phrases, causal nodes, file/symbol anchors, spec-folder aliases, or a combination?\n\n- What local threshold should decline broad entity/anchor short-circuits, analogous to MemClaw’s `ENTITY_LOOKUP_MAX_MATCHES=20`?\n\n- Should `memory_search` expose an opt-in debug profile containing retrieval strategy, candidate pools, channel scores, and post-filter reasons?\n\n- Can Spec Kit’s pending-vector path guarantee BM25/FTS-only rows bypass semantic thresholds without weakening existing 007 semantic-trigger-fallback behavior?\n\nDELTA_JSON: {\"iteration\":\"082\",\"focus\":\"recall / search / retrieval architecture\",\"findingsCount\":4,\"newInfoRatio\":0.68,\"topVerdicts\":[\"ADAPT: bounded query-strategy classifier with entity/anchor short-circuit\",\"ADOPT: overfetch plus FTS-only fallback during vector gaps\",\"ADAPT: embedder-versioned query embedding cache with stampede guard\"],\"sources\":[\"core-api/src/core_api/pipeline/compositions/search.py:17\",\"core-api/src/core_api/pipeline/steps/search/classify_query.py:82\",\"core-api/src/core_api/pipeline/steps/search/execute_scored_search.py:59\",\"core-storage-api/src/core_storage_api/services/postgres_service.py:919\",\"core-api/src/core_api/pipeline/steps/search/post_filter_results.py:21\"]}","time":{"start":1780727850980,"end":1780727911095},"metadata":{"openai":{"itemId":"msg_0a170844ce9a733b016a23c02af42c8191851078e4380e2472","phase":"final_answer"}}}}
