"emit\": true\n  },\n  \"stopPolicy\": \"max-iterations\",\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n    \"tunableFields\": [\n      \"convergenceThreshold\",\n      \"stuckThreshold\",\n      \"maxIterations\"\n    ],\n    \"lockedFields\": [\n      \"lineageMode\",\n      \"reducer\",\n      \"fileProtection\",\n      \"sessionId\",\n      \"mode\",\n      \"reviewDimensions\",\n      \"antiConvergence.convergenceMode\",\n      \"antiConvergence.stopPolicy\"\n    ],\n    \"promotionMode\": \"advisory-only\"\n  }\n}","lineStart":1,"lineEnd":115,"totalLines":115,"truncated":false}},"title":".opencode/specs/deep-loops/032-goal-opencode-plugin/review_archive/2026-07-04-documentation-staleness-audit/deep-review-config.json","time":{"start":1783146860965,"end":1783146860968}},"id":"prt_f2bd5d18a001QhmGKUIMXl9P63","sessionID":"ses_0d42abedcffewM196xEPACWSgW","messageID":"msg_f2bd5c590001jl9rHpiQ6aNmZ0"}}
