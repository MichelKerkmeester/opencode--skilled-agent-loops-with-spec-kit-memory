 }\n39: \n40: interface ChokidarModule {\n41:   default: {\n42:     watch: (paths: string[], options: Record<string, unknown>) => FSWatcher;\n43:   };\n44: }\n45: \n46: /* ───────────────────────────────────────────────────────────────\n47:    3. CONSTANTS\n48: ──────────────────────────────────────────────────────────────── */\n49: \n50: const DEFAULT_DEBOUNCE_MS = 2000;\n51: const RETRY_DELAYS_MS = [1000, 2000, 4000];\n52: const MAX_BUSY_RETRIES = RETRY_DELAYS_MS.length;\n53: const busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n54: \n55: // Watcher metrics counters\n56: let filesReindexed = 0;\n57: let totalReindexTimeMs = 0;\n58: let chokidarModule: ChokidarModule | null = null;\n59: let chokidarModulePromise: Promise<ChokidarModule | null> | null = null;\n60: let chokidarModuleLoadError: string | null = null;\n61: \n62: /** Return accumulated watcher metrics for diagnostics. */\n63: export function getWatcherMetrics(): { filesReindexed: number; avgReindexTimeMs: number } {\n64:   return {\n65:     filesReindexed,\n66:     avgReindexTimeMs: filesReindexed > 0 ? Math.round(totalReindexTimeMs / filesReindexed) : 0,\n67:   };\n68: }\n69: \n70: export function resetWatcherMetrics(): void {\n71:   filesReindexed = 0;\n72:   totalReindexTimeMs = 0;\n73: }\n74: \n75: /* ───────────────────────────────────────────────────────────────\n76:    4. HELPERS\n77: ──────────────────────────────────────────────────────────────── */\n78: \n79: function sleep(ms: number): Promise<void> {\n80:   return new Promise((resolve) => setTimeout(resolve, ms));\n81: }\n82: \n83: /**\n84:  * Coordinates early wake-up of in-flight retry sleeps so a watcher shutdown\n85:  * never has to wait for a pending backoff timer to expire. A retry sleep\n86:  * registers a `wake` callback; `wakeAll()` settles every outstanding sleep\n87:  * immediately, letting each one re-check its abort condition. This keeps\n88:  * `close()` from blocking on a non-cancellable timer (and from deadlocking\n89:  * under fake timers, where the backoff timeout would otherwise never fire).\n90:  */\n91: interface RetryWaker {\n92:   register(wake: () => void): () => void;\n93:   wakeAll(): void;\n94: }\n95: \n96: function createRetryWaker(): RetryWaker {\n97:   const waiters = new Set<() => void>();\n98:   let woken = false;\n99:   return {\n100:     register(wake: () => void): () => void {\n101:       // Sticky after wakeAll(): a sleep entered after shutdown began is woken\n102:       // at once, so a task that hits SQLITE_BUSY mid-close still exits promptly\n103:       // instead of stalling close() on a fresh retry timer.\n104:       if (woken) {\n105:         wake();\n106:         return () => undefined;\n107:       }\n108:       waiters.add(wake);\n109:       return () => { waiters.delete(wake); };\n110:     },\n111:     wakeAll(): void {\n112:       woken = true;\n113:       const pending = Array.from(waiters);\n114:       waiters.clear();\n115:       for (const wake of pending) {\n116:         wake();\n117:       }\n118:     },\n119:   };\n120: }\n121: \n122: /**\n123:  * Sleep that resolves either when `ms` elapses or when woken early via the\n124:  * supplied waker. On early wake the backoff timer is cleared so no stray timer\n125:  * survives shutdown.\n126:  */\n127: function abortableSleep(ms: number, waker?: RetryWaker): Promise<void> {\n128:   if (!waker) {\n129:     return sleep(ms);\n130:   }\n131:   return new Promise((resolve) => {\n132:     let settled = false;\n133:     let unregister = (): void => undefined;\n134:     const finish = (): void => {\n135:       if (settled) return;\n136:       settled = true;\n137:       clearTimeout(timer);\n138:       unregister();\n139:       resolve();\n140:     };\n141:     const timer = setTimeout(finish, ms);\n142:     unregister = waker.register(finish);\n143:   });\n144: }\n145: \n146: async function loadChokidarModule(): Promise<ChokidarModule | null> {\n147:   if (chokidarModule !==