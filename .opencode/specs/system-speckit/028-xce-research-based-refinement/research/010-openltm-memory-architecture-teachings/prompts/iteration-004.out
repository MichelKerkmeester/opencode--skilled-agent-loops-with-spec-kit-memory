{"type":"tool_use","timestamp":1780925301453,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_1RYYMRQLLI2HCbFIJ5umBV9P","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from \"fs\";\n3: import { join } from \"path\";\n4: import { resolveProject, registerPath, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n5: import { readStdin, parseHookInput, trimToLines, readFileSafe, safeRun } from \"../lib/hookUtils.js\";\n6: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n7: import { EVENTS } from \"../lib/eventNames.js\";\n8: import { spawnSync } from \"child_process\";\n9: import { getContextMerge, getSimilarMemories, getContextMergeWithGraph, computeDecayScore,\n10:          embedText, getDb, listMemoryIdsMissingEmbedding, exportContextMarkdown,\n11:          runPendingMigrations, getRecentConflicts, emitEvent } from \"@rohirik/openltm-core\";\n12: import { readConfigSync } from \"../../src/config.js\";\n13: \n14: const TMP_DIR      = join(CLAUDE_DIR, \"tmp\");\n15: const COUNTER_FILE = join(TMP_DIR, \"session-tool-count.txt\");\n16: const DB_PATH      = getDbPath();\n17: const MAX_INJECT_LINES = 60;\n18: const MAX_LTM_LINES    = 30;\n19: const MAX_CONFLICT_LINES = 5;\n20: const MAX_AGE_MS       = 30 * 24 * 60 * 60 * 1000;\n21: const LTM_REMINDER     = \"⚡ LTM MCP live — use mcp__plugin_openltm_memory__recall before tasks, mcp__plugin_openltm_memory__learn after discoveries.\\n\";\n22: const LTM_REPO_SLUG    = \"RohiRIK/OpenLtm\";\n23: const LTM_DIRECTIVE   = \"⚡ LTM Active — Before starting work: call `recall` with task keywords. Check `context` for project state. After decisions: call `learn` to store them.\\n\\n\";\n24: \n25: function defaultName(cwd: string): string {\n26:   const last = cwd.replace(/\\/$/, \"\").split(\"/\").pop() ?? \"\";\n27:   return last.toLowerCase().replace(/[^a-z0-9]+/g, \"-\").replace(/^-|-$/g, \"\");\n28: }\n29: \n30: async function buildLtmSection(project: string, sessionContext?: string): Promise<string> {\n31:   if (!existsSync(DB_PATH)) return \"\";\n32:   try {\n33:     let globals: Array<{ id: number; content: string }>;\n34:     let scoped: Array<{ id: number; content: string; importance: number }>;\n35:     let graphInsights: string | undefined;\n36: \n37:     const queryVec = sessionContext ? await embedText(sessionContext) : null;\n38:     if (queryVec) {\n39:       const db = getDb();\n40:       globals = getSimilarMemories(db, queryVec, { minImportance: 4, limit: 16 });\n41:       scoped  = getSimilarMemories(db, queryVec, { projectScope: project, minImportance: 2, limit: 15 });\n42:       process.stderr.write(`[SessionStart] Semantic LTM: ${globals.length} globals, ${scoped.length} scoped\\n`);\n43:     } else {\n44:       const merged = getContextMerge(project) as { globals: Array<{ id: number; content: string }>; scoped: Array<{ id: number; content: string; importance: number }> };\n45:       globals = merged.globals;\n46:       scoped  = merged.scoped;\n47:     }\n48: \n49:     const cfg = readConfigSync();\n50:     if (cfg?.ltm?.graphReasoning) {\n51:       const withGraph = await getContextMergeWithGraph(project);\n52:       graphInsights = withGraph.graphInsights;\n53:     }\n54: \n55:     if (globals.length === 0 && scoped.length === 0) return \"\";\n56: \n57:     const lines: string[] = [\"LTM:\", \"\"];\n58:     if (globals.length > 0) { lines.push(\"globals:\"); for (const m of globals) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n59:     if (scoped.length > 0) { lines.push(\"project:\"); for (const m of scoped) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n60:     if (graphInsights) { lines.push(graphInsights); lines.push(\"\"); }\n61: \n62:     const allLines = lines.join(\"\\n\").split(\"\\n\");\n63:     if (allLines.length > MAX_LTM_LINES) return allLines.slice(0, MAX_LTM_LINES).join(\"\\n\") + \"\\n… (truncated)\\n\";\n64:     return lines.join(\"\\n\");\n65:   } catch (err) {\n66:     process.stderr.write(`[SessionStart:buildLtmSection] ${err}\\n`);\n67:     return \"\";\n68:   }\n69: }\n70: \n71: function buildConflictSection(project: string): string {\n72:   if (!existsSync(DB_PATH)) return \"\";\n73:   try {\n74:     const db = getDb();\n75:     const conflicts = getRecentConflicts(db, project, MAX_CONFLICT_LINES);\n76: \n77:     if (conflicts.length === 0) return \"\";\n78: \n79:     const lines: string[] = [\"⚠️ Memory Conflicts Detected\", \"\"];\n80:     for (const c of conflicts) {\n81:       lines.push(`- [${c.olderId}] superseded by [${c.newerId}]`);\n82:     }\n83:     if (conflicts.length >= MAX_CONFLICT_LINES) {\n84:       lines.push(`… and ${conflicts.length - MAX_CONFLICT_LINES + 1} more conflicts`);\n85:     }\n86:     return lines.join(\"\\n\");\n87:   } catch (err) {\n88:     process.stderr.write(`[SessionStart:buildConflictSection] ${err}\\n`);\n89:     return \"\";\n90:   }\n91: }\n92: \n93: const BACKFILL_HINT_FILE = join(TMP_DIR, \"ltm-backfill-hint.flag\");\n94: \n95: function buildBackfillHint(): string {\n96:   if (!existsSync(DB_PATH)) return \"\";\n97:   try {\n98:     const cfg = readConfigSync();\n99:     if (!cfg.embeddings || cfg.embeddings.provider === \"disabled\") return \"\";\n100: \n101:     const today = new Date().toISOString().slice(0, 10);\n102:     try {\n103:       if (readFileSync(BACKFILL_HINT_FILE, \"utf-8\").trim() === today) return \"\";\n104:     } catch { /* file absent — first run today */ }\n105: \n106:     const db = getDb();\n107:     const missing = listMemoryIdsMissingEmbedding(db, 1);\n108:     if (missing.length === 0) return \"\";\n109: \n110:     writeFileSync(BACKFILL_HINT_FILE, today);\n111:     return `\\n💡 Embedding backfill: ${cfg.embeddings.provider} provider is configured but some memories lack embeddings. Run \\`/openltm:admin backfill\\` to enable semantic recall.\\n`;\n112:   } catch {\n113:     return \"\";\n114:   }\n115: }\n116: \n117: function refreshMarketplaceClone(): void {\n118:   const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n119:   if (!pluginRoot) return;\n120:   spawnSync(\"git\", [\"fetch\", \"--quiet\"], { cwd: pluginRoot, stdio: \"ignore\", timeout: 5000 });\n121: }\n122: \n123: function patchMarketplaceSource(): void {\n124:   const knownPath = join(CLAUDE_DIR, \"plugins\", \"known_marketplaces.json\");\n125:   try {\n126:     const data = JSON.parse(readFileSync(knownPath, \"utf-8\")) as Record<string, unknown>;\n127:     const ltm = data[\"ltm\"] as Record<string, unknown> | undefined;\n128:     const src = ltm?.[\"source\"] as Record<string, unknown> | undefined;\n129:     if (src?.[\"source\"] === \"git\" && String(src?.[\"url\"] ?? \"\").includes(LTM_REPO_SLUG)) {\n130:       data[\"ltm\"] = { ...ltm, source: { source: \"github\", repo: LTM_REPO_SLUG } };\n131:       writeFileSync(knownPath, JSON.stringify(data, null, 2));\n132:     }\n133:   } catch {}\n134: }\n135: \n136: async function main(): Promise<void> {\n137:   refreshMarketplaceClone();\n138:   patchMarketplaceSource();\n139: \n140:   try { const results = await runPendingMigrations(); if (results.length > 0) process.stderr.write(`[SessionStart] Applied ${results.length} migration(s)\\n`); }\n141:   catch (e) { process.stderr.write(`[SessionStart] Migration warning: ${e}\\n`); }\n142: \n143:   const raw = await readStdin();\n144:   const parsed = parseHookInput(raw);\n145:   if (!existsSync(TMP_DIR)) mkdirSync(TMP_DIR, { recursive: true });\n146:   writeFileSync(COUNTER_FILE, \"0\");\n147: \n148:   if (!parsed) {\n149:     process.stderr.write(\"[SessionStart] No cwd in input, skipping context injection\\n\");\n150:     process.stdout.write(\"**Context not restored:** registry_miss\\n\");\n151:     return;\n152:   }\n153:   const { cwd } = parsed;\n154:   const { name, projectDir, isNew, registeredPath } = resolveProject(cwd);\n155: \n156:   // P5-0.5: auto-onboard on first SessionStart (global flag, fire-once)\n157:   const pluginData = process.env.CLAUDE_PLUGIN_DATA ?? join(CLAUDE_DIR, \"plugins\", \"data\", \"OpenLtm-openltm\");\n158:   const onboardedFlagPath = join(pluginData, \"onboarded.flag\");\n159:   if (!existsSync(onboardedFlagPath)) {\n160:     const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n161:     if (pluginRoot) {\n162:       spawnSync(\"bun\", [\"run\", join(pluginRoot, \"src\", \"onboard.ts\"), \"--non-interactive\"],\n163:         { stdio: \"pipe\", timeout: 30_000 });\n164:     }\n165:     const displayName = isNew ? defaultName(cwd) : name;\n166:     process.stdout.write(`LTM: auto-onboarded \"${displayName}\" — run /openltm:onboard to customize\\n`);\n167:   }\n168: \n169:   if (isNew) {\n170:     const suggested = defaultName(cwd);\n171:     registerPath(cwd, suggested);\n172:     mkdirSync(join(PROJECTS_DIR, suggested), { recursive: true });\n173:     process.stdout.write(\n174:       `**Context not restored:** fresh_project\\n\\n` +\n175:       `# New Project Detected\\n\\nNo context files found for: \\`${cwd}\\`\\n\\n` +\n176:       `I've registered this project as **\"${suggested}\"**.\\n` +\n177:       `Should I create the 4 context files now? (yes/no)\\n`,\n178:     );\n179:     return;\n180:   }\n181: \n182:   if (existsSync(DB_PATH)) { try { exportContextMarkdown(name); } catch (_) {} } // silent: export failure doesn't block context injection\n183: \n184:   const summaryPath = join(projectDir, \"context-summary.md\");\n185:   if (!existsSync(summaryPath)) {\n186:     const contextFiles = [\"context-goals.md\", \"context-decisions.md\", \"context-progress.md\", \"context-gotchas.md\"];\n187:     if (!contextFiles.some(f => existsSync(join(projectDir, f)))) {\n188:       process.stdout.write(\n189:         `**Context not restored:** fresh_project\\n\\n` +\n190:         `# Project Registered — No Context Files Yet\\n\\nProject **\"${name}\"** has no context files.\\nShould I create them now? (yes/no)\\n`,\n191:       );\n192:     } else {\n193:       process.stdout.write(`**Context not restored:** fresh_project\\n`);\n194:     }\n195:     return;\n196:   }\n197: \n198:   if (Date.now() - statSync(summaryPath).mtimeMs > MAX_AGE_MS) {\n199:     process.stderr.write(`[SessionStart] Context for \"${name}\" is older than 30 days — skipping\\n`);\n200:     process.stdout.write(`**Context not restored:** stale_context\\n`);\n201:     return;\n202:   }\n203: \n204:   const summaryText = readFileSync(summaryPath, \"utf-8\");\n205:   const injected = trimToLines(summaryText, MAX_INJECT_LINES);\n206:   const sessionContext = summaryText.slice(0, 500).trim() || undefined;\n207: \n208:   let useDirective = true;\n209:   try { const cfg = readConfigSync(); useDirective = cfg?.ltm?.autoRecall !== false; } catch (_) {} // silent: missing/malformed config falls back to default (autoRecall=true)\n210: \n211:   // Override injectTopN from project settings if set\n212:   const injectTopN = readConfigSync().ltm?.injectTopN ?? 15;\n213:   const ltmSection = await buildLtmSection(name, sessionContext);\n214:   const directive = useDirective ? LTM_DIRECTIVE : \"\";\n215:   const conflictSection = buildConflictSection(name);\n216:   const backfillHint = buildBackfillHint();\n217: \n218:   // Count memories for panel header\n219:   const memoryCount = ltmSection\n220:     ? ltmSection.split(\"\\n\").filter(l => l.startsWith(\"- [\")).length\n221:     : 0;\n222:   const ctxLines = trimToLines(summaryText, MAX_INJECT_LINES).split(\"\\n\").filter(Boolean).length;\n223:   const slug = name.slice(0, 24);\n224:   const statusLine = `## LTM Session: ${slug} | restored: ${ctxLines} ctx items, ${memoryCount} top memories\\n`;\n225: \n226:   // Build output: status line + injected + directive + ltmSection + conflicts + reminder + backfill hint\n227:   let output = statusLine + \"\\n\" + injected;\n228:   if (ltmSection) {\n229:     output += `\\n\\n${directive}${ltmSection}`;\n230:     if (conflictSection) output += `\\n${conflictSection}`;\n231:     output += `\\n${LTM_REMINDER}`;\n232:   } else {\n233:     output += `\\n${directive}${LTM_REMINDER}`;\n234:   }\n235:   if (backfillHint) output += backfillHint;\n236: \n237:   process.stdout.write(output);\n238:   logHook(\"SessionStart\", \"info\", `Injected context for \"${name}\" (${registeredPath ? \"registry\" : \"slug fallback\"})`);\n239:   logEvent(\"SessionStart\", EVENTS.SESSION_START, { project: name });\n240:   emitEvent({ hook: \"SessionStart\", event: EVENTS.SESSION_START, project: name, count: memoryCount, ts: new Date().toISOString() });\n\n(Showing lines 1-240 of 247. Use offset=241 to continue.)\n</content>\n\n<system-reminder>\nInstructions from: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/AGENTS.md\n# OpenLTM — agent instructions\n\nHost-agnostic guidance for any AI coding agent working in this repo (Claude Code reads `CLAUDE.md`; OpenCode and other tools read this file). OpenLTM gives agents persistent semantic memory across sessions via a local SQLite database.\n\n## Using memory\n\nThe memory tools are exposed over MCP as `recall`, `learn`, `context`, `forget`, `relate` (in Claude Code, prefixed `mcp__plugin_openltm_memory__*`). The goal is automatic knowledge retrieval and capture — use judgment, not a call before every sentence.\n\n- **`recall`** before a non-trivial task, or when the work touches past decisions or an unfamiliar area. Skip for trivial one-liners.\n- **`learn`** after discovering a non-obvious pattern, architectural decision, or gotcha worth keeping across sessions.\n- **`context`** at session start or when switching projects, to restore goals, decisions, and gotchas.\n\nCategories: `preference | architecture | gotcha | pattern | workflow | constraint`. Importance `5` never decays; everything else ages out as it goes unused.\n\n## Working in this repo\n\n- **Runtime is Bun**, not npm/node. Use `bun`, `bunx`, `bun test`.\n- **Tests + typecheck must pass**: `bun test && bun run typecheck`.\n- **Version bumps are mandatory** on any change — `bun run bump <version>` then `bun run verify-version` (it gates all version sources: `package.json`, `.claude-plugin/plugin.json`, `.claude-plugin/marketplace.json`, every `packages/*/package.json`, and the README badge).\n- **No secrets, no database files** in commits. `data/*.db*` is gitignored; keep it that way.\n\n## Shipping to OpenCode\n\nInstalling OpenLTM into OpenCode (`bunx @rohirik/openltm-core --opencode`) does two things: registers the `@rohirik/opencode-ltm` plugin in `opencode.json`, and deploys the bundled customization (agents, skills, plugins) from the package's `assets/opencode/` into the user's OpenCode config directory.\n\n## Releasing\n\nTag-driven and tokenless: bump versions, add a `CHANGELOG.md` entry, then `git tag vX.Y.Z && git push origin main vX.Y.Z`. The tag fires the Release and Publish workflows; npm packages publish via OIDC trusted publishing with provenance — no stored token. Full detail in `CONTRIBUTING.md`.\n\n## Docs\n\nUser-facing docs are in [`docs/`](docs/README.md); internal design specs in [`docs/internal/`](docs/internal/README.md).\n\n</system-reminder>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { resolveProject, registerPath, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdin, parseHookInput, trimToLines, readFileSafe, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { spawnSync } from \"child_process\";\nimport { getContextMerge, getSimilarMemories, getContextMergeWithGraph, computeDecayScore,\n         embedText, getDb, listMemoryIdsMissingEmbedding, exportContextMarkdown,\n         runPendingMigrations, getRecentConflicts, emitEvent } from \"@rohirik/openltm-core\";\nimport { readConfigSync } from \"../../src/config.js\";\n\nconst TMP_DIR      = join(CLAUDE_DIR, \"tmp\");\nconst COUNTER_FILE = join(TMP_DIR, \"session-tool-count.txt\");\nconst DB_PATH      = getDbPath();\nconst MAX_INJECT_LINES = 60;\nconst MAX_LTM_LINES    = 30;\nconst MAX_CONFLICT_LINES = 5;\nconst MAX_AGE_MS       = 30 * 24 * 60 * 60 * 1000;","truncated":true,"loaded":["/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/AGENTS.md"],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { resolveProject, registerPath, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdin, parseHookInput, trimToLines, readFileSafe, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { spawnSync } from \"child_process\";\nimport { getContextMerge, getSimilarMemories, getContextMergeWithGraph, computeDecayScore,\n         embedText, getDb, listMemoryIdsMissingEmbedding, exportContextMarkdown,\n         runPendingMigrations, getRecentConflicts, emitEvent } from \"@rohirik/openltm-core\";\nimport { readConfigSync } from \"../../src/config.js\";\n\nconst TMP_DIR      = join(CLAUDE_DIR, \"tmp\");\nconst COUNTER_FILE = join(TMP_DIR, \"session-tool-count.txt\");\nconst DB_PATH      = getDbPath();\nconst MAX_INJECT_LINES = 60;\nconst MAX_LTM_LINES    = 30;\nconst MAX_CONFLICT_LINES = 5;\nconst MAX_AGE_MS       = 30 * 24 * 60 * 60 * 1000;\nconst LTM_REMINDER     = \"⚡ LTM MCP live — use mcp__plugin_openltm_memory__recall before tasks, mcp__plugin_openltm_memory__learn after discoveries.\\n\";\nconst LTM_REPO_SLUG    = \"RohiRIK/OpenLtm\";\nconst LTM_DIRECTIVE   = \"⚡ LTM Active — Before starting work: call `recall` with task keywords. Check `context` for project state. After decisions: call `learn` to store them.\\n\\n\";\n\nfunction defaultName(cwd: string): string {\n  const last = cwd.replace(/\\/$/, \"\").split(\"/\").pop() ?? \"\";\n  return last.toLowerCase().replace(/[^a-z0-9]+/g, \"-\").replace(/^-|-$/g, \"\");\n}\n\nasync function buildLtmSection(project: string, sessionContext?: string): Promise<string> {\n  if (!existsSync(DB_PATH)) return \"\";\n  try {\n    let globals: Array<{ id: number; content: string }>;\n    let scoped: Array<{ id: number; content: string; importance: number }>;\n    let graphInsights: string | undefined;\n\n    const queryVec = sessionContext ? await embedText(sessionContext) : null;\n    if (queryVec) {\n      const db = getDb();\n      globals = getSimilarMemories(db, queryVec, { minImportance: 4, limit: 16 });\n      scoped  = getSimilarMemories(db, queryVec, { projectScope: project, minImportance: 2, limit: 15 });\n      process.stderr.write(`[SessionStart] Semantic LTM: ${globals.length} globals, ${scoped.length} scoped\\n`);\n    } else {\n      const merged = getContextMerge(project) as { globals: Array<{ id: number; content: string }>; scoped: Array<{ id: number; content: string; importance: number }> };\n      globals = merged.globals;\n      scoped  = merged.scoped;\n    }\n\n    const cfg = readConfigSync();\n    if (cfg?.ltm?.graphReasoning) {\n      const withGraph = await getContextMergeWithGraph(project);\n      graphInsights = withGraph.graphInsights;\n    }\n\n    if (globals.length === 0 && scoped.length === 0) return \"\";\n\n    const lines: string[] = [\"LTM:\", \"\"];\n    if (globals.length > 0) { lines.push(\"globals:\"); for (const m of globals) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n    if (scoped.length > 0) { lines.push(\"project:\"); for (const m of scoped) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n    if (graphInsights) { lines.push(graphInsights); lines.push(\"\"); }\n\n    const allLines = lines.join(\"\\n\").split(\"\\n\");\n    if (allLines.length > MAX_LTM_LINES) return allLines.slice(0, MAX_LTM_LINES).join(\"\\n\") + \"\\n… (truncated)\\n\";\n    return lines.join(\"\\n\");\n  } catch (err) {\n    process.stderr.write(`[SessionStart:buildLtmSection] ${err}\\n`);\n    return \"\";\n  }\n}\n\nfunction buildConflictSection(project: string): string {\n  if (!existsSync(DB_PATH)) return \"\";\n  try {\n    const db = getDb();\n    const conflicts = getRecentConflicts(db, project, MAX_CONFLICT_LINES);\n\n    if (conflicts.length === 0) return \"\";\n\n    const lines: string[] = [\"⚠️ Memory Conflicts Detected\", \"\"];\n    for (const c of conflicts) {\n      lines.push(`- [${c.olderId}] superseded by [${c.newerId}]`);\n    }\n    if (conflicts.length >= MAX_CONFLICT_LINES) {\n      lines.push(`… and ${conflicts.length - MAX_CONFLICT_LINES + 1} more conflicts`);\n    }\n    return lines.join(\"\\n\");\n  } catch (err) {\n    process.stderr.write(`[SessionStart:buildConflictSection] ${err}\\n`);\n    return \"\";\n  }\n}\n\nconst BACKFILL_HINT_FILE = join(TMP_DIR, \"ltm-backfill-hint.flag\");\n\nfunction buildBackfillHint(): string {\n  if (!existsSync(DB_PATH)) return \"\";\n  try {\n    const cfg = readConfigSync();\n    if (!cfg.embeddings || cfg.embeddings.provider === \"disabled\") return \"\";\n\n    const today = new Date().toISOString().slice(0, 10);\n    try {\n      if (readFileSync(BACKFILL_HINT_FILE, \"utf-8\").trim() === today) return \"\";\n    } catch { /* file absent — first run today */ }\n\n    const db = getDb();\n    const missing = listMemoryIdsMissingEmbedding(db, 1);\n    if (missing.length === 0) return \"\";\n\n    writeFileSync(BACKFILL_HINT_FILE, today);\n    return `\\n💡 Embedding backfill: ${cfg.embeddings.provider} provider is configured but some memories lack embeddings. Run \\`/openltm:admin backfill\\` to enable semantic recall.\\n`;\n  } catch {\n    return \"\";\n  }\n}\n\nfunction refreshMarketplaceClone(): void {\n  const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n  if (!pluginRoot) return;\n  spawnSync(\"git\", [\"fetch\", \"--quiet\"], { cwd: pluginRoot, stdio: \"ignore\", timeout: 5000 });\n}\n\nfunction patchMarketplaceSource(): void {\n  const knownPath = join(CLAUDE_DIR, \"plugins\", \"known_marketplaces.json\");\n  try {\n    const data = JSON.parse(readFileSync(knownPath, \"utf-8\")) as Record<string, unknown>;\n    const ltm = data[\"ltm\"] as Record<string, unknown> | undefined;\n    const src = ltm?.[\"source\"] as Record<string, unknown> | undefined;\n    if (src?.[\"source\"] === \"git\" && String(src?.[\"url\"] ?? \"\").includes(LTM_REPO_SLUG)) {\n      data[\"ltm\"] = { ...ltm, source: { source: \"github\", repo: LTM_REPO_SLUG } };\n      writeFileSync(knownPath, JSON.stringify(data, null, 2));\n    }\n  } catch {}\n}\n\nasync function main(): Promise<void> {\n  refreshMarketplaceClone();\n  patchMarketplaceSource();\n\n  try { const results = await runPendingMigrations(); if (results.length > 0) process.stderr.write(`[SessionStart] Applied ${results.length} migration(s)\\n`); }\n  catch (e) { process.stderr.write(`[SessionStart] Migration warning: ${e}\\n`); }\n\n  const raw = await readStdin();\n  const parsed = parseHookInput(raw);\n  if (!existsSync(TMP_DIR)) mkdirSync(TMP_DIR, { recursive: true });\n  writeFileSync(COUNTER_FILE, \"0\");\n\n  if (!parsed) {\n    process.stderr.write(\"[SessionStart] No cwd in input, skipping context injection\\n\");\n    process.stdout.write(\"**Context not restored:** registry_miss\\n\");\n    return;\n  }\n  const { cwd } = parsed;\n  const { name, projectDir, isNew, registeredPath } = resolveProject(cwd);\n\n  // P5-0.5: auto-onboard on first SessionStart (global flag, fire-once)\n  const pluginData = process.env.CLAUDE_PLUGIN_DATA ?? join(CLAUDE_DIR, \"plugins\", \"data\", \"OpenLtm-openltm\");\n  const onboardedFlagPath = join(pluginData, \"onboarded.flag\");\n  if (!existsSync(onboardedFlagPath)) {\n    const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n    if (pluginRoot) {\n      spawnSync(\"bun\", [\"run\", join(pluginRoot, \"src\", \"onboard.ts\"), \"--non-interactive\"],\n        { stdio: \"pipe\", timeout: 30_000 });\n    }\n    const displayName = isNew ? defaultName(cwd) : name;\n    process.stdout.write(`LTM: auto-onboarded \"${displayName}\" — run /openltm:onboard to customize\\n`);\n  }\n\n  if (isNew) {\n    const suggested = defaultName(cwd);\n    registerPath(cwd, suggested);\n    mkdirSync(join(PROJECTS_DIR, suggested), { recursive: true });\n    process.stdout.write(\n      `**Context not restored:** fresh_project\\n\\n` +\n      `# New Project Detected\\n\\nNo context files found for: \\`${cwd}\\`\\n\\n` +\n      `I've registered this project as **\"${suggested}\"**.\\n` +\n      `Should I create the 4 context files now? (yes/no)\\n`,\n    );\n    return;\n  }\n\n  if (existsSync(DB_PATH)) { try { exportContextMarkdown(name); } catch (_) {} } // silent: export failure doesn't block context injection\n\n  const summaryPath = join(projectDir, \"context-summary.md\");\n  if (!existsSync(summaryPath)) {\n    const contextFiles = [\"context-goals.md\", \"context-decisions.md\", \"context-progress.md\", \"context-gotchas.md\"];\n    if (!contextFiles.some(f => existsSync(join(projectDir, f)))) {\n      process.stdout.write(\n        `**Context not restored:** fresh_project\\n\\n` +\n        `# Project Registered — No Context Files Yet\\n\\nProject **\"${name}\"** has no context files.\\nShould I create them now? (yes/no)\\n`,\n      );\n    } else {\n      process.stdout.write(`**Context not restored:** fresh_project\\n`);\n    }\n    return;\n  }\n\n  if (Date.now() - statSync(summaryPath).mtimeMs > MAX_AGE_MS) {\n    process.stderr.write(`[SessionStart] Context for \"${name}\" is older than 30 days — skipping\\n`);\n    process.stdout.write(`**Context not restored:** stale_context\\n`);\n    return;\n  }\n\n  const summaryText = readFileSync(summaryPath, \"utf-8\");\n  const injected = trimToLines(summaryText, MAX_INJECT_LINES);\n  const sessionContext = summaryText.slice(0, 500).trim() || undefined;\n\n  let useDirective = true;\n  try { const cfg = readConfigSync(); useDirective = cfg?.ltm?.autoRecall !== false; } catch (_) {} // silent: missing/malformed config falls back to default (autoRecall=true)\n\n  // Override injectTopN from project settings if set\n  const injectTopN = readConfigSync().ltm?.injectTopN ?? 15;\n  const ltmSection = await buildLtmSection(name, sessionContext);\n  const directive = useDirective ? LTM_DIRECTIVE : \"\";\n  const conflictSection = buildConflictSection(name);\n  const backfillHint = buildBackfillHint();\n\n  // Count memories for panel header\n  const memoryCount = ltmSection\n    ? ltmSection.split(\"\\n\").filter(l => l.startsWith(\"- [\")).length\n    : 0;\n  const ctxLines = trimToLines(summaryText, MAX_INJECT_LINES).split(\"\\n\").filter(Boolean).length;\n  const slug = name.slice(0, 24);\n  const statusLine = `## LTM Session: ${slug} | restored: ${ctxLines} ctx items, ${memoryCount} top memories\\n`;\n\n  // Build output: status line + injected + directive + ltmSection + conflicts + reminder + backfill hint\n  let output = statusLine + \"\\n\" + injected;\n  if (ltmSection) {\n    output += `\\n\\n${directive}${ltmSection}`;\n    if (conflictSection) output += `\\n${conflictSection}`;\n    output += `\\n${LTM_REMINDER}`;\n  } else {\n    output += `\\n${directive}${LTM_REMINDER}`;\n  }\n  if (backfillHint) output += backfillHint;\n\n  process.stdout.write(output);\n  logHook(\"SessionStart\", \"info\", `Injected context for \"${name}\" (${registeredPath ? \"registry\" : \"slug fallback\"})`);\n  logEvent(\"SessionStart\", EVENTS.SESSION_START, { project: name });\n  emitEvent({ hook: \"SessionStart\", event: EVENTS.SESSION_START, project: name, count: memoryCount, ts: new Date().toISOString() });","lineStart":1,"lineEnd":240,"totalLines":247,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts","time":{"start":1780925301435,"end":1780925301451}},"metadata":{"openai":{"itemId":"fc_01912d2d21a8a9f5016a26c3755360819988f98b6bf31701b4"}},"id":"prt_ea76b82b1001hICg0eBfyrisI1","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b415e001LUzRigYS5qPHAw"}}
{"type":"tool_use","timestamp":1780925301479,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_e6whV89PqHGrL1uG1j3MFq4T","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\n3: import { homedir } from \"os\";\n4: import { join } from \"path\";\n5: import { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n6: import { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\n7: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n8: import { EVENTS } from \"../lib/eventNames.js\";\n9: import { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n10: \n11: const TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\n12: const MAX_PROGRESS_LINES = 20;\n13: const MAX_DISPLAY_FILES = 5;\n14: const DB_PATH = getDbPath();\n15: \n16: function findTranscriptPath(\n17:   transcriptPath: string | undefined,\n18:   sessionId: string | undefined\n19: ): string | null {\n20:   if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;\n21: \n22:   const historyFile = join(CLAUDE_DIR, \"history.jsonl\");\n23:   if (!existsSync(historyFile)) return null;\n24: \n25:   const lines = readFileSync(historyFile, \"utf-8\").trim().split(\"\\n\");\n26:   let entry: Record<string, unknown> | null = null;\n27: \n28:   if (sessionId) {\n29:     for (let i = lines.length - 1; i >= 0; i--) {\n30:       try {\n31:         const parsed = JSON.parse(lines[i] ?? \"\") as Record<string, unknown>;\n32:         if (parsed.sessionId === sessionId) { entry = parsed; break; }\n33:       } catch {}\n34:     }\n35:   } else {\n36:     try { entry = JSON.parse(lines[lines.length - 1] ?? \"\") as Record<string, unknown>; } catch {}\n37:   }\n38: \n39:   if (!entry?.sessionId || !entry?.project) return null;\n40: \n41:   const filename = `${entry.sessionId}.jsonl`;\n42:   const { projectDir } = resolveProject(entry.project as string);\n43:   const primary = join(projectDir, filename);\n44:   if (existsSync(primary)) return primary;\n45: \n46:   try {\n47:     for (const dir of readdirSync(PROJECTS_DIR)) {\n48:       const candidate = join(PROJECTS_DIR, dir, filename);\n49:       if (existsSync(candidate)) return candidate;\n50:     }\n51:   } catch {}\n52: \n53:   return null;\n54: }\n55: \n56: function collectModifiedFiles(messages: Array<Record<string, unknown>>): Set<string> {\n57:   const files = new Set<string>();\n58:   for (const m of messages) {\n59:     const content = (m.message as Record<string, unknown> | undefined)?.content;\n60:     if (!Array.isArray(content)) continue;\n61:     for (const block of content as Array<Record<string, unknown>>) {\n62:       if (block.type === \"tool_use\" && TOOL_NAMES.has(block.name as string)) {\n63:         const input = block.input as Record<string, string> | undefined;\n64:         const p = input?.file_path || input?.path;\n65:         if (p) files.add(p);\n66:       }\n67:     }\n68:   }\n69:   return files;\n70: }\n71: \n72: function parseJsonLines(raw: string): Array<Record<string, unknown>> {\n73:   return raw.trim().split(\"\\n\")\n74:     .map(line => { try { return JSON.parse(line) as Record<string, unknown>; } catch { return null; } })\n75:     .filter(Boolean) as Array<Record<string, unknown>>;\n76: }\n77: \n78: async function main(): Promise<void> {\n79:   const raw = await readStdinPassthrough();\n80: \n81:   const parsed = parseHookInput(raw);\n82:   if (!parsed) return;\n83: \n84:   const { input, cwd } = parsed;\n85:   const { name, projectDir } = resolveProject(cwd);\n86:   if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n87: \n88:   const tPath = findTranscriptPath(\n89:     input.transcript_path as string | undefined,\n90:     input.session_id as string | undefined\n91:   );\n92:   if (!tPath) return;\n93: \n94:   const messages = parseJsonLines(readFileSync(tPath, \"utf-8\"));\n95:   if (messages.length < 3) return;\n96: \n97:   const sessionTag = input.session_id ? (input.session_id as string).substring(0, 8) : null;\n98:   const today = new Date().toISOString().split(\"T\")[0];\n99:   const tagPart = sessionTag ? ` [${sessionTag}]` : \"\";\n100: \n101:   const filesModified = collectModifiedFiles(messages);\n102:   const sessionLine = filesModified.size > 0\n103:     ? `✓ [${today}]${tagPart} Modified: ${[...filesModified].slice(0, MAX_DISPLAY_FILES).map(f => f.replace(homedir(), \"~\")).join(\", \")}`\n104:     : `✓ [${today}]${tagPart} Session (read-only, ${messages.length} messages)`;\n105: \n106:   // Write to DB if available, fall back to .md file\n107:   if (existsSync(DB_PATH)) {\n108:     try {\n109:       const prefixMatch = sessionLine.match(/^\\[(decision|gotcha)\\]\\s*/i);\n110:       if (prefixMatch) {\n111:         const type = prefixMatch[1]!.toLowerCase() as \"decision\" | \"gotcha\";\n112:         const strippedContent = sessionLine.slice(prefixMatch[0].length);\n113:         if (type === \"decision\") addDecision(name, strippedContent);\n114:         else addGotcha(name, strippedContent);\n115:       } else {\n116:         appendProgress(name, sessionLine, sessionTag ?? undefined);\n117:       }\n118:       logHook(\"UpdateContext\", \"info\", `context DB updated for ${name}`);\n119:       logEvent(\"UpdateContext\", EVENTS.CONTEXT_UPDATED, { project: name });\n120:       emitEvent({ hook: \"UpdateContext\", event: EVENTS.CONTEXT_UPDATED, project: name, ts: new Date().toISOString() });\n121:       return;\n122:     } catch (dbErr) {\n123:       logHook(\"UpdateContext\", \"warn\", \"DB write failed, falling back to .md\", String(dbErr));\n124:       process.stderr.write(`[UpdateContext] DB write failed, falling back to .md: ${dbErr}\\n`);\n125:     }\n126:   }\n127: \n128:   // Fallback: write to markdown file\n129:   const progressFile = join(projectDir, \"context-progress.md\");\n130:   const existing = readFileSafe(progressFile);\n131:   if (sessionTag && existing.includes(sessionTag)) return;\n132: \n133:   appendLine(progressFile, sessionLine);\n134: \n135:   const content = readFileSafe(progressFile);\n136:   const lines = content.split(\"\\n\").filter(Boolean);\n137:   if (lines.length > MAX_PROGRESS_LINES) {\n138:     writeFileSync(progressFile, trimToLines(content, MAX_PROGRESS_LINES));\n139:   }\n140: \n141:   logHook(\"UpdateContext\", \"info\", `context-progress.md updated for ${name}`);\n142: }\n143: \n144: await safeRun(\"UpdateContext\", main);\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\nimport { homedir } from \"os\";\nimport { join } from \"path\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n\nconst TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\nconst MAX_PROGRESS_LINES = 20;\nconst MAX_DISPLAY_FILES = 5;\nconst DB_PATH = getDbPath();\n\nfunction findTranscriptPath(\n  transcriptPath: string | undefined,\n  sessionId: string | undefined\n): string | null {\n  if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\nimport { homedir } from \"os\";\nimport { join } from \"path\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n\nconst TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\nconst MAX_PROGRESS_LINES = 20;\nconst MAX_DISPLAY_FILES = 5;\nconst DB_PATH = getDbPath();\n\nfunction findTranscriptPath(\n  transcriptPath: string | undefined,\n  sessionId: string | undefined\n): string | null {\n  if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;\n\n  const historyFile = join(CLAUDE_DIR, \"history.jsonl\");\n  if (!existsSync(historyFile)) return null;\n\n  const lines = readFileSync(historyFile, \"utf-8\").trim().split(\"\\n\");\n  let entry: Record<string, unknown> | null = null;\n\n  if (sessionId) {\n    for (let i = lines.length - 1; i >= 0; i--) {\n      try {\n        const parsed = JSON.parse(lines[i] ?? \"\") as Record<string, unknown>;\n        if (parsed.sessionId === sessionId) { entry = parsed; break; }\n      } catch {}\n    }\n  } else {\n    try { entry = JSON.parse(lines[lines.length - 1] ?? \"\") as Record<string, unknown>; } catch {}\n  }\n\n  if (!entry?.sessionId || !entry?.project) return null;\n\n  const filename = `${entry.sessionId}.jsonl`;\n  const { projectDir } = resolveProject(entry.project as string);\n  const primary = join(projectDir, filename);\n  if (existsSync(primary)) return primary;\n\n  try {\n    for (const dir of readdirSync(PROJECTS_DIR)) {\n      const candidate = join(PROJECTS_DIR, dir, filename);\n      if (existsSync(candidate)) return candidate;\n    }\n  } catch {}\n\n  return null;\n}\n\nfunction collectModifiedFiles(messages: Array<Record<string, unknown>>): Set<string> {\n  const files = new Set<string>();\n  for (const m of messages) {\n    const content = (m.message as Record<string, unknown> | undefined)?.content;\n    if (!Array.isArray(content)) continue;\n    for (const block of content as Array<Record<string, unknown>>) {\n      if (block.type === \"tool_use\" && TOOL_NAMES.has(block.name as string)) {\n        const input = block.input as Record<string, string> | undefined;\n        const p = input?.file_path || input?.path;\n        if (p) files.add(p);\n      }\n    }\n  }\n  return files;\n}\n\nfunction parseJsonLines(raw: string): Array<Record<string, unknown>> {\n  return raw.trim().split(\"\\n\")\n    .map(line => { try { return JSON.parse(line) as Record<string, unknown>; } catch { return null; } })\n    .filter(Boolean) as Array<Record<string, unknown>>;\n}\n\nasync function main(): Promise<void> {\n  const raw = await readStdinPassthrough();\n\n  const parsed = parseHookInput(raw);\n  if (!parsed) return;\n\n  const { input, cwd } = parsed;\n  const { name, projectDir } = resolveProject(cwd);\n  if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n\n  const tPath = findTranscriptPath(\n    input.transcript_path as string | undefined,\n    input.session_id as string | undefined\n  );\n  if (!tPath) return;\n\n  const messages = parseJsonLines(readFileSync(tPath, \"utf-8\"));\n  if (messages.length < 3) return;\n\n  const sessionTag = input.session_id ? (input.session_id as string).substring(0, 8) : null;\n  const today = new Date().toISOString().split(\"T\")[0];\n  const tagPart = sessionTag ? ` [${sessionTag}]` : \"\";\n\n  const filesModified = collectModifiedFiles(messages);\n  const sessionLine = filesModified.size > 0\n    ? `✓ [${today}]${tagPart} Modified: ${[...filesModified].slice(0, MAX_DISPLAY_FILES).map(f => f.replace(homedir(), \"~\")).join(\", \")}`\n    : `✓ [${today}]${tagPart} Session (read-only, ${messages.length} messages)`;\n\n  // Write to DB if available, fall back to .md file\n  if (existsSync(DB_PATH)) {\n    try {\n      const prefixMatch = sessionLine.match(/^\\[(decision|gotcha)\\]\\s*/i);\n      if (prefixMatch) {\n        const type = prefixMatch[1]!.toLowerCase() as \"decision\" | \"gotcha\";\n        const strippedContent = sessionLine.slice(prefixMatch[0].length);\n        if (type === \"decision\") addDecision(name, strippedContent);\n        else addGotcha(name, strippedContent);\n      } else {\n        appendProgress(name, sessionLine, sessionTag ?? undefined);\n      }\n      logHook(\"UpdateContext\", \"info\", `context DB updated for ${name}`);\n      logEvent(\"UpdateContext\", EVENTS.CONTEXT_UPDATED, { project: name });\n      emitEvent({ hook: \"UpdateContext\", event: EVENTS.CONTEXT_UPDATED, project: name, ts: new Date().toISOString() });\n      return;\n    } catch (dbErr) {\n      logHook(\"UpdateContext\", \"warn\", \"DB write failed, falling back to .md\", String(dbErr));\n      process.stderr.write(`[UpdateContext] DB write failed, falling back to .md: ${dbErr}\\n`);\n    }\n  }\n\n  // Fallback: write to markdown file\n  const progressFile = join(projectDir, \"context-progress.md\");\n  const existing = readFileSafe(progressFile);\n  if (sessionTag && existing.includes(sessionTag)) return;\n\n  appendLine(progressFile, sessionLine);\n\n  const content = readFileSafe(progressFile);\n  const lines = content.split(\"\\n\").filter(Boolean);\n  if (lines.length > MAX_PROGRESS_LINES) {\n    writeFileSync(progressFile, trimToLines(content, MAX_PROGRESS_LINES));\n  }\n\n  logHook(\"UpdateContext\", \"info\", `context-progress.md updated for ${name}`);\n}\n\nawait safeRun(\"UpdateContext\", main);","lineStart":1,"lineEnd":144,"totalLines":144,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","time":{"start":1780925301467,"end":1780925301476}},"metadata":{"openai":{"itemId":"fc_01912d2d21a8a9f5016a26c37553708199aea250431792c5e5"}},"id":"prt_ea76b82d4001WFg4ANDeaJJ18f","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b415e001LUzRigYS5qPHAw"}}
{"type":"tool_use","timestamp":1780925301569,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_h1p5T96bD4ozfbn319VZzLPn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/PreCompact.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/PreCompact.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, writeFileSync } from \"fs\";\n3: import { join } from \"path\";\n4: import { resolveProject, getDbPath } from \"../lib/resolveProject.js\";\n5: import { readStdin, parseHookInput, readFileSafe, budgetSection, safeRun } from \"../lib/hookUtils.js\";\n6: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n7: import { EVENTS } from \"../lib/eventNames.js\";\n8: import { getItems, exportContextMarkdown, emitEvent } from \"@rohirik/openltm-core\";\n9: \n10: const DB_PATH = getDbPath();\n11: \n12: async function buildSummaryFromDb(name: string, cwd: string): Promise<string | null> {\n13:   try {\n14:     exportContextMarkdown(name);\n15:     const toLines = (items: Array<{ content: string }>) => items.map(i => i.content);\n16:     const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n17:     return [\n18:       `# Context Summary\\n**Project:** ${name} (${cwd})\\n**Compaction checkpoint:** ${timestamp}\\n`,\n19:       budgetSection(toLines(getItems(name, \"goal\")),       \"Current Goal\",        10),\n20:       budgetSection(toLines(getItems(name, \"progress\", 20)), \"Recent Progress\",   20),\n21:       budgetSection(toLines(getItems(name, \"decision\")),   \"Key Decisions\",       15),\n22:       budgetSection(toLines(getItems(name, \"gotcha\")),     \"Gotchas / Watch Out\", 15),\n23:     ].join(\"\");\n24:   } catch (_) {\n25:     return null;\n26:   }\n27: }\n28: \n29: function buildSummaryFromFiles(name: string, cwd: string, projectDir: string): string {\n30:   const toLines = (raw: string) => raw.split(\"\\n\").filter(Boolean);\n31:   const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n32:   return [\n33:     `# Context Summary\\n**Project:** ${name} (${cwd})\\n**Compaction checkpoint:** ${timestamp}\\n`,\n34:     budgetSection(toLines(readFileSafe(join(projectDir, \"context-goals.md\"))),     \"Current Goal\",        10),\n35:     budgetSection(toLines(readFileSafe(join(projectDir, \"context-progress.md\"))),  \"Recent Progress\",     20),\n36:     budgetSection(toLines(readFileSafe(join(projectDir, \"context-decisions.md\"))), \"Key Decisions\",       15),\n37:     budgetSection(toLines(readFileSafe(join(projectDir, \"context-gotchas.md\"))),   \"Gotchas / Watch Out\", 15),\n38:   ].join(\"\");\n39: }\n40: \n41: async function main(): Promise<void> {\n42:   const raw = await readStdin();\n43:   const parsed = parseHookInput(raw);\n44: \n45:   if (!parsed) {\n46:     logHook(\"PreCompact\", \"warn\", \"No cwd found in input, skipping\");\n47:     process.stderr.write(\"[PreCompact] No cwd found in input, skipping\\n\");\n48:     return;\n49:   }\n50: \n51:   const { cwd } = parsed;\n52:   const { name, projectDir } = resolveProject(cwd);\n53: \n54:   if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n55: \n56:   // Try DB first; fall back to .md files if DB doesn't exist yet\n57:   const finalSummary = existsSync(DB_PATH)\n58:     ? ((await buildSummaryFromDb(name, cwd)) ?? buildSummaryFromFiles(name, cwd, projectDir))\n59:     : buildSummaryFromFiles(name, cwd, projectDir);\n60: \n61:   writeFileSync(join(projectDir, \"context-summary.md\"), finalSummary);\n62:   logHook(\"PreCompact\", \"info\", `Saved context summary for \"${name}\" (${finalSummary.split(\"\\n\").length} lines)`);\n63:   logEvent(\"PreCompact\", EVENTS.COMPACT_PRE, { project: name });\n64:   emitEvent({ hook: \"PreCompact\", event: EVENTS.COMPACT_PRE, project: name, ts: new Date().toISOString() });\n65: }\n66: \n67: await safeRun(\"PreCompact\", main);\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { resolveProject, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdin, parseHookInput, readFileSafe, budgetSection, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { getItems, exportContextMarkdown, emitEvent } from \"@rohirik/openltm-core\";\n\nconst DB_PATH = getDbPath();\n\nasync function buildSummaryFromDb(name: string, cwd: string): Promise<string | null> {\n  try {\n    exportContextMarkdown(name);\n    const toLines = (items: Array<{ content: string }>) => items.map(i => i.content);\n    const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n    return [\n      `# Context Summary\\n**Project:** ${name} (${cwd})\\n**Compaction checkpoint:** ${timestamp}\\n`,\n      budgetSection(toLines(getItems(name, \"goal\")),       \"Current Goal\",        10),\n      budgetSection(toLines(getItems(name, \"progress\", 20)), \"Recent Progress\",   20),","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/PreCompact.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { resolveProject, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdin, parseHookInput, readFileSafe, budgetSection, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { getItems, exportContextMarkdown, emitEvent } from \"@rohirik/openltm-core\";\n\nconst DB_PATH = getDbPath();\n\nasync function buildSummaryFromDb(name: string, cwd: string): Promise<string | null> {\n  try {\n    exportContextMarkdown(name);\n    const toLines = (items: Array<{ content: string }>) => items.map(i => i.content);\n    const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n    return [\n      `# Context Summary\\n**Project:** ${name} (${cwd})\\n**Compaction checkpoint:** ${timestamp}\\n`,\n      budgetSection(toLines(getItems(name, \"goal\")),       \"Current Goal\",        10),\n      budgetSection(toLines(getItems(name, \"progress\", 20)), \"Recent Progress\",   20),\n      budgetSection(toLines(getItems(name, \"decision\")),   \"Key Decisions\",       15),\n      budgetSection(toLines(getItems(name, \"gotcha\")),     \"Gotchas / Watch Out\", 15),\n    ].join(\"\");\n  } catch (_) {\n    return null;\n  }\n}\n\nfunction buildSummaryFromFiles(name: string, cwd: string, projectDir: string): string {\n  const toLines = (raw: string) => raw.split(\"\\n\").filter(Boolean);\n  const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n  return [\n    `# Context Summary\\n**Project:** ${name} (${cwd})\\n**Compaction checkpoint:** ${timestamp}\\n`,\n    budgetSection(toLines(readFileSafe(join(projectDir, \"context-goals.md\"))),     \"Current Goal\",        10),\n    budgetSection(toLines(readFileSafe(join(projectDir, \"context-progress.md\"))),  \"Recent Progress\",     20),\n    budgetSection(toLines(readFileSafe(join(projectDir, \"context-decisions.md\"))), \"Key Decisions\",       15),\n    budgetSection(toLines(readFileSafe(join(projectDir, \"context-gotchas.md\"))),   \"Gotchas / Watch Out\", 15),\n  ].join(\"\");\n}\n\nasync function main(): Promise<void> {\n  const raw = await readStdin();\n  const parsed = parseHookInput(raw);\n\n  if (!parsed) {\n    logHook(\"PreCompact\", \"warn\", \"No cwd found in input, skipping\");\n    process.stderr.write(\"[PreCompact] No cwd found in input, skipping\\n\");\n    return;\n  }\n\n  const { cwd } = parsed;\n  const { name, projectDir } = resolveProject(cwd);\n\n  if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n\n  // Try DB first; fall back to .md files if DB doesn't exist yet\n  const finalSummary = existsSync(DB_PATH)\n    ? ((await buildSummaryFromDb(name, cwd)) ?? buildSummaryFromFiles(name, cwd, projectDir))\n    : buildSummaryFromFiles(name, cwd, projectDir);\n\n  writeFileSync(join(projectDir, \"context-summary.md\"), finalSummary);\n  logHook(\"PreCompact\", \"info\", `Saved context summary for \"${name}\" (${finalSummary.split(\"\\n\").length} lines)`);\n  logEvent(\"PreCompact\", EVENTS.COMPACT_PRE, { project: name });\n  emitEvent({ hook: \"PreCompact\", event: EVENTS.COMPACT_PRE, project: name, ts: new Date().toISOString() });\n}\n\nawait safeRun(\"PreCompact\", main);","lineStart":1,"lineEnd":67,"totalLines":67,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/PreCompact.ts","time":{"start":1780925301557,"end":1780925301566}},"metadata":{"openai":{"itemId":"fc_01912d2d21a8a9f5016a26c375538081998fda733d9a4684a8"}},"id":"prt_ea76b8334001ZmM0rXXDeKKpDU","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b415e001LUzRigYS5qPHAw"}}
{"type":"tool_use","timestamp":1780925301569,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_JDeFgK0yX9xxOWaE6wMHzRzG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: /**\n3:  * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n4:  *\n5:  * Two modes:\n6:  *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n7:  *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n8:  *\n9:  * Installed globally via ~/.claude/hooks/git/post-commit\n10:  * Controlled by config.ltm.gitLearnEnabled (default: false)\n11:  */\n12: import { existsSync } from \"fs\";\n13: import { join } from \"path\";\n14: import { homedir } from \"os\";\n15: import { spawnSync } from \"child_process\";\n16: import { resolveProject, CLAUDE_DIR } from \"../lib/resolveProject.js\";\n17: import { safeRun } from \"../lib/hookUtils.js\";\n18: import { emitEvent } from \"@rohirik/openltm-core\";\n19: import { EVENTS } from \"../lib/eventNames.js\";\n20: import { readConfigSync } from \"../../src/config.js\";\n21: import type { Config } from \"../../src/config.js\";\n22: \n23: const PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"plugins\", \"ltm\");\n24: const MAX_DIFF_CHARS = 4000;\n25: \n26: // ── Git helpers ───────────────────────────────────────────────────────────────\n27: \n28: function getProjectRoot(): string {\n29:   // GIT_DIR is set to .git/ inside a hook — go one level up\n30:   const gitDir = process.env.GIT_DIR;\n31:   if (gitDir) return join(gitDir, \"..\") ;\n32:   return process.cwd();\n33: }\n34: \n35: function runGit(args: string[], cwd: string): string {\n36:   const result = spawnSync(\"git\", args, { cwd, encoding: \"utf-8\", env: process.env });\n37:   return result.stdout?.trim() ?? \"\";\n38: }\n39: \n40: function getCommitMeta(cwd: string): { hash: string; message: string; files: string[] } {\n41:   const hash = runGit([\"log\", \"-1\", \"--pretty=format:%H\"], cwd);\n42:   const message = runGit([\"log\", \"-1\", \"--pretty=format:%s\"], cwd);\n43:   const fileList = runGit([\"diff-tree\", \"--no-commit-id\", \"-r\", \"--name-only\", \"HEAD\"], cwd);\n44:   const files = fileList ? fileList.split(\"\\n\").filter(Boolean) : [];\n45:   return { hash, message, files };\n46: }\n47: \n48: function getDiffText(cwd: string, maxChars: number): string {\n49:   const diff = runGit([\"diff\", \"HEAD~1\", \"HEAD\", \"--unified=3\", \"--no-color\"], cwd);\n50:   if (!diff) return runGit([\"show\", \"--unified=3\", \"--no-color\", \"HEAD\"], cwd).slice(0, maxChars);\n51:   return diff.length > maxChars ? diff.slice(0, maxChars) : diff;\n52: }\n53: \n54: function matchesPattern(filename: string, pattern: string): boolean {\n55:   if (pattern.startsWith(\"*.\")) return filename.endsWith(pattern.slice(1));\n56:   if (pattern.endsWith(\"/\")) return filename.includes(pattern);\n57:   return filename.includes(pattern);\n58: }\n59: \n60: function applyIgnorePatterns(diff: string, patterns: string[]): string {\n61:   if (patterns.length === 0) return diff;\n62:   const lines = diff.split(\"\\n\");\n63:   let skip = false;\n64:   return lines.filter(line => {\n65:     if (line.startsWith(\"diff --git\")) {\n66:       // Extract filename from \"diff --git a/path b/path\"\n67:       const match = line.match(/diff --git a\\/.+ b\\/(.+)$/);\n68:       const filename = match?.[1] ?? line;\n69:       skip = patterns.some(p => matchesPattern(filename, p));\n70:     }\n71:     return !skip;\n72:   }).join(\"\\n\");\n73: }\n74: \n75: function shouldSkipRepo(projectRoot: string): boolean {\n76:   return existsSync(join(projectRoot, \".ltmignore\"));\n77: }\n78: \n79: // ── Extract mode ──────────────────────────────────────────────────────────────\n80: \n81: async function runExtract(payload: {\n82:   diff: string;\n83:   commitMsg: string;\n84:   hash: string;\n85:   files: string[];\n86:   projectName: string;\n87: }): Promise<void> {\n88:   const { extractAndLearn } = await import(\"../lib/llmExtract.js\");\n89: \n90:   const preamble = `Git commit: ${payload.commitMsg}\\nFiles changed: ${payload.files.slice(0, 5).join(\", \")}`;\n91: \n92:   await extractAndLearn(payload.diff, payload.projectName, {\n93:     source: `git-commit:${payload.hash}`,\n94:     tags: payload.files.slice(0, 5),\n95:     preamble,\n96:   });\n97: }\n98: \n99: // ── Hook mode (main entry) ────────────────────────────────────────────────────\n100: \n101: async function main(): Promise<void> {\n102:   // Extract mode — reads payload from stdin, called by detached subprocess\n103:   if (process.argv.includes(\"--extract\")) {\n104:     try {\n105:       let raw = \"\";\n106:       for await (const chunk of Bun.stdin.stream()) raw += new TextDecoder().decode(chunk);\n107:       const payload = JSON.parse(raw);\n108:       await runExtract(payload);\n109:     } catch (err) {\n110:       process.stderr.write(`[GitCommit] extract error: ${err}\\n`);\n111:     }\n112:     process.exit(0);\n113:   }\n114: \n115:   // Hook mode — must exit 0 immediately, never block git\n116:   try {\n117:     const cfg = readConfigSync() as Config;\n118:     if (!cfg.ltm?.gitLearnEnabled) process.exit(0);\n119: \n120:     const projectRoot = getProjectRoot();\n121:     if (shouldSkipRepo(projectRoot)) process.exit(0);\n122: \n123:     const { hash, message, files } = getCommitMeta(projectRoot);\n124:     if (!hash) process.exit(0);\n125: \n126:     const ignorePatterns = cfg.ltm?.gitLearnIgnorePatterns ?? [\"package-lock.json\", \"*.lock\", \"dist/\", \".min.js\"];\n127:     const minDiffChars = cfg.ltm?.gitLearnMinDiffChars ?? 200;\n128: \n129:     let diff = getDiffText(projectRoot, MAX_DIFF_CHARS);\n130:     diff = applyIgnorePatterns(diff, ignorePatterns);\n131: \n132:     if (diff.length < minDiffChars) process.exit(0);\n133: \n134:     const projectName = resolveProject(projectRoot).name;\n135: \n136:     const payload = { diff, commitMsg: message, hash, files, projectName };\n137: \n138:     // Spawn detached so git doesn't wait for LLM extraction — pipe payload via stdin\n139:     const child = Bun.spawn(\n140:       [\"bun\", join(PLUGIN_ROOT, \"hooks/GitCommit.bundle.mjs\"), \"--extract\"],\n141:       {\n142:         detached: true,\n143:         stdin: \"pipe\",\n144:         stdout: \"ignore\",\n145:         stderr: \"ignore\",\n146:         env: { ...process.env, CLAUDE_PLUGIN_ROOT: PLUGIN_ROOT },\n147:       },\n148:     );\n149:     child.stdin.write(JSON.stringify(payload));\n150:     child.stdin.end();\n151:     child.unref();\n152:   } catch (err) {\n153:     process.stderr.write(`[GitCommit] hook error: ${err}\\n`);\n154:   }\n155: \n156:   emitEvent({ hook: \"GitCommit\", event: EVENTS.GIT_COMMIT, ts: new Date().toISOString() });\n157:   process.exit(0);\n158: }\n159: \n160: await safeRun(\"GitCommit\", main);\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n *\n * Two modes:\n *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n *\n * Installed globally via ~/.claude/hooks/git/post-commit\n * Controlled by config.ltm.gitLearnEnabled (default: false)\n */\nimport { existsSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { spawnSync } from \"child_process\";\nimport { resolveProject, CLAUDE_DIR } from \"../lib/resolveProject.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { readConfigSync } from \"../../src/config.js\";","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts","text":"#!/usr/bin/env bun\n/**\n * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n *\n * Two modes:\n *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n *\n * Installed globally via ~/.claude/hooks/git/post-commit\n * Controlled by config.ltm.gitLearnEnabled (default: false)\n */\nimport { existsSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { spawnSync } from \"child_process\";\nimport { resolveProject, CLAUDE_DIR } from \"../lib/resolveProject.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { readConfigSync } from \"../../src/config.js\";\nimport type { Config } from \"../../src/config.js\";\n\nconst PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"plugins\", \"ltm\");\nconst MAX_DIFF_CHARS = 4000;\n\n// ── Git helpers ───────────────────────────────────────────────────────────────\n\nfunction getProjectRoot(): string {\n  // GIT_DIR is set to .git/ inside a hook — go one level up\n  const gitDir = process.env.GIT_DIR;\n  if (gitDir) return join(gitDir, \"..\") ;\n  return process.cwd();\n}\n\nfunction runGit(args: string[], cwd: string): string {\n  const result = spawnSync(\"git\", args, { cwd, encoding: \"utf-8\", env: process.env });\n  return result.stdout?.trim() ?? \"\";\n}\n\nfunction getCommitMeta(cwd: string): { hash: string; message: string; files: string[] } {\n  const hash = runGit([\"log\", \"-1\", \"--pretty=format:%H\"], cwd);\n  const message = runGit([\"log\", \"-1\", \"--pretty=format:%s\"], cwd);\n  const fileList = runGit([\"diff-tree\", \"--no-commit-id\", \"-r\", \"--name-only\", \"HEAD\"], cwd);\n  const files = fileList ? fileList.split(\"\\n\").filter(Boolean) : [];\n  return { hash, message, files };\n}\n\nfunction getDiffText(cwd: string, maxChars: number): string {\n  const diff = runGit([\"diff\", \"HEAD~1\", \"HEAD\", \"--unified=3\", \"--no-color\"], cwd);\n  if (!diff) return runGit([\"show\", \"--unified=3\", \"--no-color\", \"HEAD\"], cwd).slice(0, maxChars);\n  return diff.length > maxChars ? diff.slice(0, maxChars) : diff;\n}\n\nfunction matchesPattern(filename: string, pattern: string): boolean {\n  if (pattern.startsWith(\"*.\")) return filename.endsWith(pattern.slice(1));\n  if (pattern.endsWith(\"/\")) return filename.includes(pattern);\n  return filename.includes(pattern);\n}\n\nfunction applyIgnorePatterns(diff: string, patterns: string[]): string {\n  if (patterns.length === 0) return diff;\n  const lines = diff.split(\"\\n\");\n  let skip = false;\n  return lines.filter(line => {\n    if (line.startsWith(\"diff --git\")) {\n      // Extract filename from \"diff --git a/path b/path\"\n      const match = line.match(/diff --git a\\/.+ b\\/(.+)$/);\n      const filename = match?.[1] ?? line;\n      skip = patterns.some(p => matchesPattern(filename, p));\n    }\n    return !skip;\n  }).join(\"\\n\");\n}\n\nfunction shouldSkipRepo(projectRoot: string): boolean {\n  return existsSync(join(projectRoot, \".ltmignore\"));\n}\n\n// ── Extract mode ──────────────────────────────────────────────────────────────\n\nasync function runExtract(payload: {\n  diff: string;\n  commitMsg: string;\n  hash: string;\n  files: string[];\n  projectName: string;\n}): Promise<void> {\n  const { extractAndLearn } = await import(\"../lib/llmExtract.js\");\n\n  const preamble = `Git commit: ${payload.commitMsg}\\nFiles changed: ${payload.files.slice(0, 5).join(\", \")}`;\n\n  await extractAndLearn(payload.diff, payload.projectName, {\n    source: `git-commit:${payload.hash}`,\n    tags: payload.files.slice(0, 5),\n    preamble,\n  });\n}\n\n// ── Hook mode (main entry) ────────────────────────────────────────────────────\n\nasync function main(): Promise<void> {\n  // Extract mode — reads payload from stdin, called by detached subprocess\n  if (process.argv.includes(\"--extract\")) {\n    try {\n      let raw = \"\";\n      for await (const chunk of Bun.stdin.stream()) raw += new TextDecoder().decode(chunk);\n      const payload = JSON.parse(raw);\n      await runExtract(payload);\n    } catch (err) {\n      process.stderr.write(`[GitCommit] extract error: ${err}\\n`);\n    }\n    process.exit(0);\n  }\n\n  // Hook mode — must exit 0 immediately, never block git\n  try {\n    const cfg = readConfigSync() as Config;\n    if (!cfg.ltm?.gitLearnEnabled) process.exit(0);\n\n    const projectRoot = getProjectRoot();\n    if (shouldSkipRepo(projectRoot)) process.exit(0);\n\n    const { hash, message, files } = getCommitMeta(projectRoot);\n    if (!hash) process.exit(0);\n\n    const ignorePatterns = cfg.ltm?.gitLearnIgnorePatterns ?? [\"package-lock.json\", \"*.lock\", \"dist/\", \".min.js\"];\n    const minDiffChars = cfg.ltm?.gitLearnMinDiffChars ?? 200;\n\n    let diff = getDiffText(projectRoot, MAX_DIFF_CHARS);\n    diff = applyIgnorePatterns(diff, ignorePatterns);\n\n    if (diff.length < minDiffChars) process.exit(0);\n\n    const projectName = resolveProject(projectRoot).name;\n\n    const payload = { diff, commitMsg: message, hash, files, projectName };\n\n    // Spawn detached so git doesn't wait for LLM extraction — pipe payload via stdin\n    const child = Bun.spawn(\n      [\"bun\", join(PLUGIN_ROOT, \"hooks/GitCommit.bundle.mjs\"), \"--extract\"],\n      {\n        detached: true,\n        stdin: \"pipe\",\n        stdout: \"ignore\",\n        stderr: \"ignore\",\n        env: { ...process.env, CLAUDE_PLUGIN_ROOT: PLUGIN_ROOT },\n      },\n    );\n    child.stdin.write(JSON.stringify(payload));\n    child.stdin.end();\n    child.unref();\n  } catch (err) {\n    process.stderr.write(`[GitCommit] hook error: ${err}\\n`);\n  }\n\n  emitEvent({ hook: \"GitCommit\", event: EVENTS.GIT_COMMIT, ts: new Date().toISOString() });\n  process.exit(0);\n}\n\nawait safeRun(\"GitCommit\", main);","lineStart":1,"lineEnd":160,"totalLines":160,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts","time":{"start":1780925301561,"end":1780925301568}},"metadata":{"openai":{"itemId":"fc_01912d2d21a8a9f5016a26c37553848199addae15efa834783"}},"id":"prt_ea76b83360012DJSxxuurCsxz5","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b415e001LUzRigYS5qPHAw"}}
{"type":"tool_use","timestamp":1780925301571,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_UDKWx92cZeFy8wmvYJ8vrQZI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync } from \"fs\";\n3: import { join } from \"path\";\n4: import { homedir } from \"os\";\n5: import { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n6: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n7: import { EVENTS } from \"../lib/eventNames.js\";\n8: import { safeRun } from \"../lib/hookUtils.js\";\n9: import { extractProposals } from \"../lib/llmExtract.js\";\n10: import { writeProposals, type MemoryProposal } from \"../lib/proposalQueue.js\";\n11: import { readConfigSync } from \"../../src/config.js\";\n12: import type { Config } from \"../../src/config.js\";\n13: import { emitEvent } from \"@rohirik/openltm-core\";\n14: \n15: const PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"memory\");\n16: const LEARNED_DIR = join(PLUGIN_ROOT, \"skills\", \"Learned\");\n17: const PATTERNS_DIR = join(LEARNED_DIR, \"patterns\");\n18: const SUMMARY_FILE = join(LEARNED_DIR, \"summary.md\");\n19: const HISTORY_FILE = join(CLAUDE_DIR, \"history.jsonl\");\n20: const MAX_SUMMARY_LINES = 50;\n21: const SUMMARY_HEADER_LINES = 10;\n22: const MIN_SESSION_MESSAGES = 5; // Lowered for testing\n23: \n24: // Proposals dir: ${CLAUDE_PLUGIN_DATA}/proposals/ or fallback to plugin data dir\n25: const PLUGIN_DATA_DIR = process.env.CLAUDE_PLUGIN_DATA\n26:   ?? join(homedir(), \".claude\", \"plugins\", \"data\", \"OpenLtm-openltm\");\n27: const PROPOSALS_DIR = join(PLUGIN_DATA_DIR, \"proposals\");\n28: \n29: async function findTranscript(sessionId: string | undefined): Promise<{ path: string, id: string } | null> {\n30:   if (!existsSync(HISTORY_FILE)) return null;\n31: \n32:   const historyLines = readFileSync(HISTORY_FILE, \"utf-8\").trim().split('\\n');\n33:   if (historyLines.length === 0) return null;\n34: \n35:   // Find the entry matching sessionId, or the last one if not provided\n36:   let historyEntry: any = null;\n37:   if (sessionId) {\n38:     // Search backwards\n39:     for (let i = historyLines.length - 1; i >= 0; i--) {\n40:       try {\n41:         const line = JSON.parse(historyLines[i] ?? \"\");\n42:         if (line.sessionId === sessionId) {\n43:           historyEntry = line;\n44:           break;\n45:         }\n46:       } catch (e) {} // silent: malformed JSONL lines are expected and safely skipped\n47:     }\n48:   } else {\n49:     // Just take the last valid one\n50:     try {\n51:       historyEntry = JSON.parse(historyLines[historyLines.length - 1] ?? \"\");\n52:     } catch (e) {} // silent: malformed JSONL line is safely skipped\n53:   }\n54: \n55:   if (!historyEntry) return null;\n56: \n57:   const finalSessionId = historyEntry.sessionId;\n58:   const projectPath = historyEntry.project;\n59:   if (!finalSessionId || !projectPath) return null;\n60: \n61:   const filename = `${finalSessionId}.jsonl`;\n62: \n63:   // Try registry-resolved project dir first, then scan all project dirs for the session file\n64:   const { projectDir } = resolveProject(projectPath);\n65:   let transcriptPath = join(projectDir, filename);\n66: \n67:   if (!existsSync(transcriptPath)) {\n68:     // Claude Code may use a different slug format — scan all dirs\n69:     try {\n70:       const dirs = readdirSync(PROJECTS_DIR);\n71:       for (const dir of dirs) {\n72:         const candidate = join(PROJECTS_DIR, dir, filename);\n73:         if (existsSync(candidate)) {\n74:           transcriptPath = candidate;\n75:           break;\n76:         }\n77:       }\n78:     } catch (_) {} // silent: dir scan failure means we fall through to existsSync check\n79:   }\n80: \n81:   if (!existsSync(transcriptPath)) return null;\n82: \n83:   return { path: transcriptPath, id: finalSessionId };\n84: }\n85: \n86: function extractAssistantText(messages: any[]): string {\n87:   const parts: string[] = [];\n88:   for (const m of messages) {\n89:     const content = m?.message?.content;\n90:     if (!Array.isArray(content)) continue;\n91:     if (m?.message?.role !== \"assistant\") continue;\n92:     for (const block of content) {\n93:       if (block?.type === \"text\" && typeof block.text === \"string\")\n94:         parts.push(block.text.trim());\n95:     }\n96:   }\n97:   const full = parts.join(\"\\n\\n\");\n98:   return full.length > 8000 ? full.slice(-8000) : full;\n99: }\n100: \n101: async function main() {\n102:   let inputStr = \"\";\n103:   // Hook inputs are optional for this tool now, but we pass through stdin\n104:   try {\n105:     for await (const chunk of Bun.stdin.stream()) {\n106:       const text = new TextDecoder().decode(chunk);\n107:       inputStr += text;\n108:       process.stdout.write(chunk); // Pass through immediately\n109:     }\n110:   } catch (stdinErr) {\n111:     // Stdin might be empty or closed — non-fatal\n112:     logHook(\"EvaluateSession\", \"warn\", \"stdin read failed\", String(stdinErr));\n113:   }\n114: \n115:   let input: any = {};\n116:   try {\n117:     input = JSON.parse(inputStr);\n118:   } catch {\n119:     // Non-JSON input is acceptable — hooks may receive empty or plain-text stdin\n120:   }\n121: \n122:   {\n123:     let transcriptPath = input.transcript_path;\n124:     let sessionId = input.session_id;\n125: \n126:     if (!transcriptPath || !existsSync(transcriptPath)) {\n127:       const found = await findTranscript(sessionId);\n128:       if (found) {\n129:         transcriptPath = found.path;\n130:         sessionId = found.id;\n131:       }\n132:     }\n133: \n134:     if (!transcriptPath || !existsSync(transcriptPath)) {\n135:       return;\n136:     }\n137: \n138:     const transcriptContent = readFileSync(transcriptPath, \"utf-8\");\n139:     // Parse JSONL\n140:     const messages = transcriptContent.trim().split('\\n').map(l => {\n141:         try { return JSON.parse(l); } catch(e) { return null; }\n142:     }).filter(Boolean);\n143: \n144:     const messageCount = messages.length;\n145: \n146:     if (messageCount < MIN_SESSION_MESSAGES) {\n147:       return;\n148:     }\n149: \n150:     if (!existsSync(PATTERNS_DIR)) mkdirSync(PATTERNS_DIR, { recursive: true });\n151: \n152:     const today = new Date().toISOString().split('T')[0];\n153:     const patternFile = join(PATTERNS_DIR, `${today}.md`);\n154: \n155:     let fileContent = `# Session Patterns: ${today}\\n`;\n156:     fileContent += `**Session ID:** ${sessionId || \"unknown\"}\\n`;\n157:     fileContent += `**Messages:** ${messageCount}\\n\\n---\\n\\n`;\n158: \n159:     // Collect all tool_use content blocks from assistant messages\n160:     const toolUseBlocks: any[] = [];\n161:     messages.forEach((m: any) => {\n162:       const content = m.message?.content;\n163:       if (Array.isArray(content)) {\n164:         content.forEach((block: any) => {\n165:           if (block.type === 'tool_use') toolUseBlocks.push(block);\n166:         });\n167:       }\n168:     });\n169: \n170:     // Collect tool result blocks (errors) from user messages\n171:     const errorBlocks: string[] = [];\n172:     messages.forEach((m: any) => {\n173:       const content = m.message?.content;\n174:       if (Array.isArray(content)) {\n175:         content.forEach((block: any) => {\n176:           if (block.type === 'tool_result' && block.is_error) {\n177:             const output = Array.isArray(block.content)\n178:               ? block.content.map((c: any) => c.text || '').join(' ')\n179:               : String(block.content || '');\n180:             errorBlocks.push(output.substring(0, 200).replace(/\\n/g, ' '));\n181:           }\n182:         });\n183:       }\n184:       // Also catch top-level error messages\n185:       if (m.type === 'error') {\n186:         errorBlocks.push((m.error?.message || 'Unknown error').substring(0, 200));\n187:       }\n188:     });\n189: \n190:     fileContent += \"## Errors Encountered\\n\";\n191:     errorBlocks.slice(0, 10).forEach(msg => fileContent += `- ${msg}\\n`);\n192:     fileContent += \"\\n\";\n193: \n194:     // Extract Tool Usage\n195:     const toolUsage: Record<string, number> = {};\n196:     toolUseBlocks.forEach((block: any) => {\n197:       toolUsage[block.name] = (toolUsage[block.name] || 0) + 1;\n198:     });\n199: \n200:     fileContent += \"## Tools Used\\n\";\n201:     Object.entries(toolUsage)\n202:       .sort(([,a], [,b]) => (b as number) - (a as number))\n203:       .slice(0, 10)\n204:       .forEach(([tool, count]) => fileContent += `- ${tool} (${count} times)\\n`);\n205:     fileContent += \"\\n\";\n206: \n207:     // Extract Files Modified\n208:     const files = new Set<string>();\n209:     toolUseBlocks.forEach((block: any) => {\n210:       if (block.name === 'Write' || block.name === 'Edit' || block.name === 'MultiEdit') {\n211:         const path = block.input?.file_path || block.input?.path;\n212:         if (path) files.add(path);\n213:       }\n214:     });\n215:     fileContent += \"## Files Modified\\n\";\n216:     [...files].slice(0, 20).forEach(f => fileContent += `- ${f}\\n`);\n217:     fileContent += \"\\n\";\n218: \n219:     writeFileSync(patternFile, fileContent);\n220: \n221:     const projectName = resolveProject(input.cwd ?? \"\").name;\n222: \n223:     const proposals: MemoryProposal[] = [];\n224: \n225:     for (const msg of errorBlocks.slice(0, 3)) {\n226:       if (msg.trim().length > 20) {\n227:         proposals.push({\n228:           content: msg.trim(),\n229:           category: \"gotcha\",\n230:           importance: 3,\n231:           source: \"evaluate-session\",\n232:         });\n233:       }\n234:     }\n235: \n236:     try {\n237:       if ((readConfigSync() as Config).ltm?.evaluateSessionLlm) {\n238:         const assistantText = extractAssistantText(messages);\n239:         if (assistantText.length > 100) {\n240:           extractProposals(assistantText, projectName, { source: \"evaluate-session\", sessionId })\n241:             .then(({ proposals: llmProposals }) => {\n242:               const merged = [...proposals, ...llmProposals];\n243:               if (merged.length > 0) {\n244:                 const sid = sessionId ?? `unknown-${Date.now()}`;\n245:                 const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n246:                 writeProposals(proposalsPath, merged);\n247:                 process.stdout.write(\n248:                   JSON.stringify({ type: \"ltm_proposal\", count: merged.length, proposalsPath }) + \"\\n\"\n249:                 );\n250:                 logHook(\"EvaluateSession\", \"info\", `${merged.length} proposals written`, proposalsPath);\n251:               }\n252:             })\n253:             .catch((err: unknown) => {\n254:               logHook(\"EvaluateSession\", \"warn\", \"LLM extraction failed\", String(err));\n255:               if (proposals.length > 0) {\n256:                 const sid = sessionId ?? `unknown-${Date.now()}`;\n257:                 const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n258:                 writeProposals(proposalsPath, proposals);\n259:                 process.stdout.write(\n260:                   JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n261:                 );\n262:               }\n263:             });\n264:         } else if (proposals.length > 0) {\n265:           // No LLM extraction but we have error-block proposals\n266:           const sid = sessionId ?? `unknown-${Date.now()}`;\n267:           const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n268:           writeProposals(proposalsPath, proposals);\n269:           process.stdout.write(\n270:             JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n271:           );\n272:           logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n273:         }\n274:       } else if (proposals.length > 0) {\n275:         // LLM disabled — write error-block proposals only\n276:         const sid = sessionId ?? `unknown-${Date.now()}`;\n277:         const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n278:         writeProposals(proposalsPath, proposals);\n279:         process.stdout.write(\n280:           JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n281:         );\n282:         logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n283:       }\n284:     } catch (cfgErr) {\n285:       logHook(\"EvaluateSession\", \"warn\", \"Failed to read config for LLM extraction\", String(cfgErr));\n286:     }\n287: \n288:     logEvent(\"EvaluateSession\", EVENTS.SESSION_EVALUATED, { project: projectName, count: messageCount });\n289:     emitEvent({ hook: \"EvaluateSession\", event: EVENTS.SESSION_EVALUATED, project: projectName, count: messageCount, ts: new Date().toISOString() });\n290: \n291:     // Update Summary (deduplicate by sessionId)\n292:     if (!existsSync(SUMMARY_FILE)) {\n293:       writeFileSync(SUMMARY_FILE, \"# Learned Patterns Summary\\n\\nThis file is auto-updated.\\n\\n---\\n\\n## Recent Sessions\\n\\n\");\n294:     }\n295: \n296:     const summaryContent = readFileSync(SUMMARY_FILE, \"utf-8\");\n297:     const shortId = sessionId ? sessionId.substring(0, 8) : 'unknown';\n298:     if (!summaryContent.includes(shortId)) {\n299:       const newLine = `- **${today}** (${messageCount} msgs): Session ${shortId}... (Errors: ${errorBlocks.length})\\n`;\n300:       const updatedLines = (summaryContent + newLine).split('\\n');\n301:       const newSummary = updatedLines.length > MAX_SUMMARY_LINES\n302:         ? updatedLines.slice(0, SUMMARY_HEADER_LINES)\n303:             .concat(updatedLines.slice(updatedLines.length - (MAX_SUMMARY_LINES - SUMMARY_HEADER_LINES)))\n304:             .join('\\n')\n305:         : summaryContent + newLine;\n306:       writeFileSync(SUMMARY_FILE, newSummary);\n307:     }\n308:   }\n309: }\n310: \n311: await safeRun(\"EvaluateSession\", main);\n\n(End of file - total 311 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { extractProposals } from \"../lib/llmExtract.js\";\nimport { writeProposals, type MemoryProposal } from \"../lib/proposalQueue.js\";\nimport { readConfigSync } from \"../../src/config.js\";\nimport type { Config } from \"../../src/config.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\n\nconst PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"memory\");\nconst LEARNED_DIR = join(PLUGIN_ROOT, \"skills\", \"Learned\");\nconst PATTERNS_DIR = join(LEARNED_DIR, \"patterns\");\nconst SUMMARY_FILE = join(LEARNED_DIR, \"summary.md\");\nconst HISTORY_FILE = join(CLAUDE_DIR, \"history.jsonl\");\nconst MAX_SUMMARY_LINES = 50;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { extractProposals } from \"../lib/llmExtract.js\";\nimport { writeProposals, type MemoryProposal } from \"../lib/proposalQueue.js\";\nimport { readConfigSync } from \"../../src/config.js\";\nimport type { Config } from \"../../src/config.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\n\nconst PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"memory\");\nconst LEARNED_DIR = join(PLUGIN_ROOT, \"skills\", \"Learned\");\nconst PATTERNS_DIR = join(LEARNED_DIR, \"patterns\");\nconst SUMMARY_FILE = join(LEARNED_DIR, \"summary.md\");\nconst HISTORY_FILE = join(CLAUDE_DIR, \"history.jsonl\");\nconst MAX_SUMMARY_LINES = 50;\nconst SUMMARY_HEADER_LINES = 10;\nconst MIN_SESSION_MESSAGES = 5; // Lowered for testing\n\n// Proposals dir: ${CLAUDE_PLUGIN_DATA}/proposals/ or fallback to plugin data dir\nconst PLUGIN_DATA_DIR = process.env.CLAUDE_PLUGIN_DATA\n  ?? join(homedir(), \".claude\", \"plugins\", \"data\", \"OpenLtm-openltm\");\nconst PROPOSALS_DIR = join(PLUGIN_DATA_DIR, \"proposals\");\n\nasync function findTranscript(sessionId: string | undefined): Promise<{ path: string, id: string } | null> {\n  if (!existsSync(HISTORY_FILE)) return null;\n\n  const historyLines = readFileSync(HISTORY_FILE, \"utf-8\").trim().split('\\n');\n  if (historyLines.length === 0) return null;\n\n  // Find the entry matching sessionId, or the last one if not provided\n  let historyEntry: any = null;\n  if (sessionId) {\n    // Search backwards\n    for (let i = historyLines.length - 1; i >= 0; i--) {\n      try {\n        const line = JSON.parse(historyLines[i] ?? \"\");\n        if (line.sessionId === sessionId) {\n          historyEntry = line;\n          break;\n        }\n      } catch (e) {} // silent: malformed JSONL lines are expected and safely skipped\n    }\n  } else {\n    // Just take the last valid one\n    try {\n      historyEntry = JSON.parse(historyLines[historyLines.length - 1] ?? \"\");\n    } catch (e) {} // silent: malformed JSONL line is safely skipped\n  }\n\n  if (!historyEntry) return null;\n\n  const finalSessionId = historyEntry.sessionId;\n  const projectPath = historyEntry.project;\n  if (!finalSessionId || !projectPath) return null;\n\n  const filename = `${finalSessionId}.jsonl`;\n\n  // Try registry-resolved project dir first, then scan all project dirs for the session file\n  const { projectDir } = resolveProject(projectPath);\n  let transcriptPath = join(projectDir, filename);\n\n  if (!existsSync(transcriptPath)) {\n    // Claude Code may use a different slug format — scan all dirs\n    try {\n      const dirs = readdirSync(PROJECTS_DIR);\n      for (const dir of dirs) {\n        const candidate = join(PROJECTS_DIR, dir, filename);\n        if (existsSync(candidate)) {\n          transcriptPath = candidate;\n          break;\n        }\n      }\n    } catch (_) {} // silent: dir scan failure means we fall through to existsSync check\n  }\n\n  if (!existsSync(transcriptPath)) return null;\n\n  return { path: transcriptPath, id: finalSessionId };\n}\n\nfunction extractAssistantText(messages: any[]): string {\n  const parts: string[] = [];\n  for (const m of messages) {\n    const content = m?.message?.content;\n    if (!Array.isArray(content)) continue;\n    if (m?.message?.role !== \"assistant\") continue;\n    for (const block of content) {\n      if (block?.type === \"text\" && typeof block.text === \"string\")\n        parts.push(block.text.trim());\n    }\n  }\n  const full = parts.join(\"\\n\\n\");\n  return full.length > 8000 ? full.slice(-8000) : full;\n}\n\nasync function main() {\n  let inputStr = \"\";\n  // Hook inputs are optional for this tool now, but we pass through stdin\n  try {\n    for await (const chunk of Bun.stdin.stream()) {\n      const text = new TextDecoder().decode(chunk);\n      inputStr += text;\n      process.stdout.write(chunk); // Pass through immediately\n    }\n  } catch (stdinErr) {\n    // Stdin might be empty or closed — non-fatal\n    logHook(\"EvaluateSession\", \"warn\", \"stdin read failed\", String(stdinErr));\n  }\n\n  let input: any = {};\n  try {\n    input = JSON.parse(inputStr);\n  } catch {\n    // Non-JSON input is acceptable — hooks may receive empty or plain-text stdin\n  }\n\n  {\n    let transcriptPath = input.transcript_path;\n    let sessionId = input.session_id;\n\n    if (!transcriptPath || !existsSync(transcriptPath)) {\n      const found = await findTranscript(sessionId);\n      if (found) {\n        transcriptPath = found.path;\n        sessionId = found.id;\n      }\n    }\n\n    if (!transcriptPath || !existsSync(transcriptPath)) {\n      return;\n    }\n\n    const transcriptContent = readFileSync(transcriptPath, \"utf-8\");\n    // Parse JSONL\n    const messages = transcriptContent.trim().split('\\n').map(l => {\n        try { return JSON.parse(l); } catch(e) { return null; }\n    }).filter(Boolean);\n\n    const messageCount = messages.length;\n\n    if (messageCount < MIN_SESSION_MESSAGES) {\n      return;\n    }\n\n    if (!existsSync(PATTERNS_DIR)) mkdirSync(PATTERNS_DIR, { recursive: true });\n\n    const today = new Date().toISOString().split('T')[0];\n    const patternFile = join(PATTERNS_DIR, `${today}.md`);\n\n    let fileContent = `# Session Patterns: ${today}\\n`;\n    fileContent += `**Session ID:** ${sessionId || \"unknown\"}\\n`;\n    fileContent += `**Messages:** ${messageCount}\\n\\n---\\n\\n`;\n\n    // Collect all tool_use content blocks from assistant messages\n    const toolUseBlocks: any[] = [];\n    messages.forEach((m: any) => {\n      const content = m.message?.content;\n      if (Array.isArray(content)) {\n        content.forEach((block: any) => {\n          if (block.type === 'tool_use') toolUseBlocks.push(block);\n        });\n      }\n    });\n\n    // Collect tool result blocks (errors) from user messages\n    const errorBlocks: string[] = [];\n    messages.forEach((m: any) => {\n      const content = m.message?.content;\n      if (Array.isArray(content)) {\n        content.forEach((block: any) => {\n          if (block.type === 'tool_result' && block.is_error) {\n            const output = Array.isArray(block.content)\n              ? block.content.map((c: any) => c.text || '').join(' ')\n              : String(block.content || '');\n            errorBlocks.push(output.substring(0, 200).replace(/\\n/g, ' '));\n          }\n        });\n      }\n      // Also catch top-level error messages\n      if (m.type === 'error') {\n        errorBlocks.push((m.error?.message || 'Unknown error').substring(0, 200));\n      }\n    });\n\n    fileContent += \"## Errors Encountered\\n\";\n    errorBlocks.slice(0, 10).forEach(msg => fileContent += `- ${msg}\\n`);\n    fileContent += \"\\n\";\n\n    // Extract Tool Usage\n    const toolUsage: Record<string, number> = {};\n    toolUseBlocks.forEach((block: any) => {\n      toolUsage[block.name] = (toolUsage[block.name] || 0) + 1;\n    });\n\n    fileContent += \"## Tools Used\\n\";\n    Object.entries(toolUsage)\n      .sort(([,a], [,b]) => (b as number) - (a as number))\n      .slice(0, 10)\n      .forEach(([tool, count]) => fileContent += `- ${tool} (${count} times)\\n`);\n    fileContent += \"\\n\";\n\n    // Extract Files Modified\n    const files = new Set<string>();\n    toolUseBlocks.forEach((block: any) => {\n      if (block.name === 'Write' || block.name === 'Edit' || block.name === 'MultiEdit') {\n        const path = block.input?.file_path || block.input?.path;\n        if (path) files.add(path);\n      }\n    });\n    fileContent += \"## Files Modified\\n\";\n    [...files].slice(0, 20).forEach(f => fileContent += `- ${f}\\n`);\n    fileContent += \"\\n\";\n\n    writeFileSync(patternFile, fileContent);\n\n    const projectName = resolveProject(input.cwd ?? \"\").name;\n\n    const proposals: MemoryProposal[] = [];\n\n    for (const msg of errorBlocks.slice(0, 3)) {\n      if (msg.trim().length > 20) {\n        proposals.push({\n          content: msg.trim(),\n          category: \"gotcha\",\n          importance: 3,\n          source: \"evaluate-session\",\n        });\n      }\n    }\n\n    try {\n      if ((readConfigSync() as Config).ltm?.evaluateSessionLlm) {\n        const assistantText = extractAssistantText(messages);\n        if (assistantText.length > 100) {\n          extractProposals(assistantText, projectName, { source: \"evaluate-session\", sessionId })\n            .then(({ proposals: llmProposals }) => {\n              const merged = [...proposals, ...llmProposals];\n              if (merged.length > 0) {\n                const sid = sessionId ?? `unknown-${Date.now()}`;\n                const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n                writeProposals(proposalsPath, merged);\n                process.stdout.write(\n                  JSON.stringify({ type: \"ltm_proposal\", count: merged.length, proposalsPath }) + \"\\n\"\n                );\n                logHook(\"EvaluateSession\", \"info\", `${merged.length} proposals written`, proposalsPath);\n              }\n            })\n            .catch((err: unknown) => {\n              logHook(\"EvaluateSession\", \"warn\", \"LLM extraction failed\", String(err));\n              if (proposals.length > 0) {\n                const sid = sessionId ?? `unknown-${Date.now()}`;\n                const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n                writeProposals(proposalsPath, proposals);\n                process.stdout.write(\n                  JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n                );\n              }\n            });\n        } else if (proposals.length > 0) {\n          // No LLM extraction but we have error-block proposals\n          const sid = sessionId ?? `unknown-${Date.now()}`;\n          const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n          writeProposals(proposalsPath, proposals);\n          process.stdout.write(\n            JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n          );\n          logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n        }\n      } else if (proposals.length > 0) {\n        // LLM disabled — write error-block proposals only\n        const sid = sessionId ?? `unknown-${Date.now()}`;\n        const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n        writeProposals(proposalsPath, proposals);\n        process.stdout.write(\n          JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n        );\n        logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n      }\n    } catch (cfgErr) {\n      logHook(\"EvaluateSession\", \"warn\", \"Failed to read config for LLM extraction\", String(cfgErr));\n    }\n\n    logEvent(\"EvaluateSession\", EVENTS.SESSION_EVALUATED, { project: projectName, count: messageCount });\n    emitEvent({ hook: \"EvaluateSession\", event: EVENTS.SESSION_EVALUATED, project: projectName, count: messageCount, ts: new Date().toISOString() });\n\n    // Update Summary (deduplicate by sessionId)\n    if (!existsSync(SUMMARY_FILE)) {\n      writeFileSync(SUMMARY_FILE, \"# Learned Patterns Summary\\n\\nThis file is auto-updated.\\n\\n---\\n\\n## Recent Sessions\\n\\n\");\n    }\n\n    const summaryContent = readFileSync(SUMMARY_FILE, \"utf-8\");\n    const shortId = sessionId ? sessionId.substring(0, 8) : 'unknown';\n    if (!summaryContent.includes(shortId)) {\n      const newLine = `- **${today}** (${messageCount} msgs): Session ${shortId}... (Errors: ${errorBlocks.length})\\n`;\n      const updatedLines = (summaryContent + newLine).split('\\n');\n      const newSummary = updatedLines.length > MAX_SUMMARY_LINES\n        ? updatedLines.slice(0, SUMMARY_HEADER_LINES)\n            .concat(updatedLines.slice(updatedLines.length - (MAX_SUMMARY_LINES - SUMMARY_HEADER_LINES)))\n            .join('\\n')\n        : summaryContent + newLine;\n      writeFileSync(SUMMARY_FILE, newSummary);\n    }\n  }\n}\n\nawait safeRun(\"EvaluateSession\", main);","lineStart":1,"lineEnd":311,"totalLines":311,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts","time":{"start":1780925301555,"end":1780925301570}},"metadata":{"openai":{"itemId":"fc_01912d2d21a8a9f5016a26c37553788199b64d625fd5de672b"}},"id":"prt_ea76b8330001DAO95HtcKEZ9p0","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b415e001LUzRigYS5qPHAw"}}
