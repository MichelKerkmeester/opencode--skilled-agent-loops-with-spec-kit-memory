  {"id":"F-16-1","area":"activation","finding":"HUB_CHILD is a runtime engine-dispatch table, not merely the duplicate eligibility allowlist ADR-002 assumes it is.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:35-58","severity":"P0","actionable":"Separate manifest-derived eligibility from engine discovery, standardize one per-hub engine entrypoint, then remove HUB_CHILD only after all hubs use that contract.","novelty":"refines:F-6-3"},
  {"id":"F-16-2","area":"activation","finding":"Copying resolve.cjs alone cannot remove spec-tree coupling because its activation root and compiled engine dependency closure are both resolved relative to the current spec directories.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/resolve.cjs:15-20","severity":"P0","actionable":"Promote the resolver, engine loader, activation state, and compiled per-hub bundles together so runtime imports and reads never enter .opencode/specs.","novelty":"new"},
  {"id":"F-16-3","area":"activation","finding":"The current serving manifest lacks the hub identity, engine locator, and source-hash data required to implement valid-fresh-manifest eligibility without another mapping.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/sk-code/manifest.json:1","severity":"P0","actionable":"Version the runtime manifest with hubId, bundle identity, selected-policy identity, and live-input hashes, then make one shared validator serve advisor, resolver, onboarding, and benchmark consumers.","novelty":"new"},
  {"id":"F-16-4","area":"sk-code-align","finding":"verify_alignment_drift.py has no cross-file contract mechanism capable of checking eligibility equality, resolver-copy freshness, or forbidden runtime-to-spec imports.","evidence":".opencode/skills/sk-code/code-opencode/assets/scripts/verify_alignment_drift.py:457-497","severity":"P0","actionable":"Add a compiled-routing contract helper invoked by the named verifier, with fixtures for consumer parity, bundle freshness, and zero runtime imports from .opencode/specs.","novelty":"refines:F-6-5"},
  {"id":"F-16-5","area":"unnamed","finding":"The compiled engine cache is keyed only by hub ID and therefore would retain a stale snapshot if the promoted resolver becomes long-lived across a manifest re-mint.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:33-36","severity":"P1","actionable":"Key or invalidate cached engines by selected-policy hash and source signature, and add a same-process re-mint test before moving compiled routing in-process.","novelty":"new"}
]
