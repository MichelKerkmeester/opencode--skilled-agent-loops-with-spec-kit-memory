nant, publish ``EMBED_REQUESTED``.\n\n  Line 96:             # Fetch the memory's content + content_hash by id. The\n\n  Line 122:                 await publish_memory_embed_request(\n\n  Line 126:                     content_hash=memory.get(\"content_hash\"),\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/clients/storage_client.py:\n  Line 451:     async def find_by_content_hash(\n\n  Line 454:         content_hash: str,\n\n  Line 458:         params: dict[str, Any] = {\"tenant_id\": tenant_id, \"content_hash\": content_hash}\n\n  Line 468:         # bulk_find_by_content_hashes and find_semantic_duplicate.\n\n  Line 471:     async def find_embedding_by_content_hash(\n\n  Line 474:         content_hash: str,\n\n  Line 483:             content_hash=content_hash,\n\n  Line 489:         content_hash: str,\n\n  Line 492:         params: dict[str, Any] = {\"tenant_id\": tenant_id, \"content_hash\": content_hash}\n\n  Line 499:     async def bulk_find_by_content_hashes(\n\n  Line 506:         \"\"\"Look up existing rows by content_hash for the dedup gate.\n\n  Line 508:         Returns ``{content_hash: {\"id\": str, \"client_request_id\": str | None}}``.\n\n  Line 537:         # through. See bulk_find_by_content_hashes for the same reasoning.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/cli.py:\n  Line 10: ``012_vector_dim_1024``) and publishes one ``EMBED_REQUESTED`` event per\n\n\n(Results truncated: showing 100 of 323 matches (223 hidden). Consider using a more specific path or pattern.)","metadata":{"matches":323,"truncated":true},"title":"publish_memory_embed_request|MemoryEmbedRequest|EMBED_REQUESTED|content_hash","time":{"start":1780728111554,"end":1780728111573}},"metadata":{"opena