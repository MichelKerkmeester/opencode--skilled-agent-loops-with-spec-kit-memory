\n723:     if (!hasMatchingEvidence) errors.push('sourceEvidence:not-attested-by-artifact');\n724:   }\n725:   return { valid: errors.length === 0, errors };\n726: }\n727: \n728: function isKnownRetrievalUnavailable(error) {\n729:   return isRetrievalUnavailableError(error);\n730: }\n731: \n732: async function hydrateTemporalOwner(card, engineOptions) {\n733:   try {\n734:     return await runHydrate({\n735:       id: card.id,\n736:       generationHash: card.generationHash,\n737:       mode: 'motion',\n738:       usage: 'reference',\n739:       includes: ['DESIGN.md', 'source.md'],\n740:       maxBytes: HYDRATION_BYTES,\n741:     }, engineOptions);\n742:   } catch (error) {\n743:     if (!isKnownRetrievalUnavailable(error)) throw error;\n744:     return { ok: false, error: error.code ?? 'manifest-invalid' };\n745:   }\n746: }\n747: \n748: // ─────────────────────────────────────────────────────────────────────────────\n749: // 6. PUBLIC API\n750: // ─────────────────────────────────────────────────────────────────────────────\n751: \n752: /**\n753:  * Run restraint first, then retrieve at most one eligible temporal owner.\n754:  *\n755:  * @param {Object} input - Closed target gate, eligibility, and authority records.\n756:  * @param {Object} engineOptions - Retrieval-engine corpus and manifest paths.\n757:  * @returns {Promise<Object>} Motion evidence, negative baseline, or refusal.\n758:  */\n759: export async function buildMotionEvidencePlan(input, engineOptions = {}) {\n760:   const validation = validateMotionEvidenceRequest(input);\n761:   if (!validation.valid) {\n762:     return { ok: false, error: 'invalid-motion-request', details: validation.errors };\n763:   }\n764:   const request = immutableSnapshot(input);\n765:   const authoritySnapshot = request.authorityInputs;\n766:   const gate = evaluateMotionRestraint(request.restraintAssessment);\n767:   const blockedOutcome = blockingPlanOutcome(request.contextPlan);\n768:   if (blockedOutcome) {\n769:     return negativeResult(\n770:       request,\n771:       gate,\n772:       'corpus-unavailable',\n773:       blockedOutcome,\n774:       false,\n775:     );\n776:   }\n777:   if (gate.verdict === 'do-not-move') {\n778:     return negativeResult(request, gate, 'target-no-motion', 'no-fit', false);\n779:   }\n780: \n781:   const eligibility = classifyAttestedCandidates(request.eligibility);\n782:   if (!eligibility.candidate) {\n783:     const kind = eligibility.hardNegatives.length > 0\n784:       ? 'hard-negative-rejection'\n785:       : 'no-corpus-temporal-authority';\n786:     return negativeResult(request, gate, kind, 'no-fit', false);\n787:   }\n788: \n789:   let query;\n790:   try {\n791:     query = await runQuery({\n792:       ...(request.retrievalRequest ?? {}),\n793:       usage: 'reference',\n794:       exactReuse: false,\n795:       limit: MAX_QUERY_CARDS,\n796:     }, engineOptions);\n797:   } catch (error) {\n798:     if (!isKnownRetrievalUnavailable(error)) throw error;\n799:     return negativeResult(\n800:       request,\n801:       gate,\n802:       'corpus-unavailable',\n803:       'no-fit',\n804:       true,\n805:       [`retrieval-unavailable:${error.code ?? 'invalid-manifest'}`],\n806:     );\n807:   }\n808:   if (query.generationHash !== request.contextPlan.generationIdentity.observedGenerationHash) {\n809:     return negativeResult(\n810:       request,\n811:       gate,\n812:       'corpus-unavailable',\n813:       'no-fit',\n814:       true,\n815:       ['retrieval-unavailable:generation-mismatch'],\n816:     );\n817:   }\n818:   const card = query.cards.find((candidate) => candidate.id === eligibility.candidate.sourceId);\n819:   if (!card) {\n820:     return negativeResult(request, gate, 'no-corpus-temporal-authority', 'no-fit', true);\n821:   }\n822:   const hydration = await hydrateTemporalOwner(card, engineOptions);\n823:   if (!hydration.ok) {\n824:     if (!HYDRATION_UNAVAILABLE_CODES.has(hydration.error)) {\n825:       return { ok: false, error: `temporal-owner-${hydration.error}` };\n826:     }\n827:     return negativeResult(\n828:       request,\n829:       gate,\n830:       'corpus-unavailable',\n831:       'no-fit',\n832:       true,\n833:       [`temporal-owner-unavailable:${hydration.error}`],\n834:     );\n\n(Showing lines 700-834 of 882. Use offset=835 to continue.)\n</content>","metadata":{"preview":"function validateHydratedAttestation(candidate, card, hydration) {\n  const errors = [];\n  const attestation = candidate.attestation;\n  if (attestation.sourceId !== card.id) errors.push('sourceId:card-mismatch');\n  if (attestation.generationHash !== card.generationHash) {\n    errors.push('generationHash:card-mismatch');\n  }\n  if (attestation.generationHash !== hydration.generationHash) {\n    errors.push('generationHash:hydration-mismatch');\n  }\n  if (attestation.contentHash !== card.contentHash) errors.push('contentHash:card-mismatch');\n  const artifact = hydration.artifacts.find((entry) => entry.path === attestation.artifactPath);\n  if (!artifact) {\n    errors.push('artifactPath:not-hydrated');\n  } else {\n    if (artifact.sha256 !== attestation.artifactHash) errors.push('artifactHash:mismatch');\n    if (artifact.truncated) errors.push('artifact:truncated');\n    const evidenceRecords = typedEvidenceRecords(artifact.content);\n    const hasMatchingEvidence = evidenceRecords.some((record) => {\n      const recordErrors = [];","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/design-motion/corpus/motion-evidence.mjs","text":"function validateHydratedAttestation(candidate, card, hydration) {\n  const errors = [];\n  const attestation = candidate.attestation;\n  if (attestation.sourceId !== card.id) errors.push('sourceId:card-mismatch');\n  if (attestation.generationHash !== card.generationHash) {\n    errors.push('generationHash:card-mismatch');\n  }\n  if (attestation.generationHash !== hydration.generationHash) {\n    errors.push('generationHash:hydration-mismatch');\n  }\n  if (attestation.contentHash !== card.contentHash) errors.push('contentHash:card-mismatch');\n  const artifact = hydration.artifacts.find((entry) => entry.path === attestation.artifactPath);\n  if (!artifact) {\n    errors.push('artifactPath:not-hydrated');\n  } else {\n    if (artifact.sha256 !== attestation.artifactHash) errors.push('artifactHash:mismatch');\n    if (artifact.truncated) errors.push('artifact:truncated');\n    const evidenceRecords = typedEvidenceRecords(artifact.content);\n    const hasMatchingEvidence = evidenceRecords.some((record) => {\n      const recordErrors = [];\n      validateMotionSourceEvidence(recordErrors, record, 'sourceEvidence');\n      return recordErrors.length === 0 && isDeepStrictEqual(record, attestation.evidence);\n    });\n    if (!hasMatchingEvidence) errors.push('sourceEvidence:not-attested-by-artifact');\n  }\n  return { valid: errors.length === 0, errors };\n}\n\nfunction isKnownRetrievalUnavailable(error) {\n  return isRetrievalUnavailableError(error);\n}\n\nasync function hydrateTemporalOwner(card, engineOptions) {\n  try {\n    return await runHydrate({\n      id: card.id,\n      generationHash: card.generationHash,\n      mode: 'motion',\n      usage: 'reference',\n      includes: ['DESIGN.md', 'source.md'],\n      maxBytes: HYDRATION_BYTES,\n    }, engineOptions);\n  } catch (error) {\n    if (!isKnownRetrievalUnavailable(error)) throw error;\n    return { ok: false, error: error.code ?? 'manifest-invalid' };\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. PUBLIC API\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Run restraint first, then retrieve at most one eligible temporal owner.\n *\n * @param {Object} input - Closed target gate, eligibility, and authority records.\n * @param {Object} engineOptions - Retrieval-engine corpus and manifest paths.\n * @returns {Promise<Object>} Motion evidence, negative baseline, or refusal.\n */\nexport async function buildMotionEvidencePlan(input, engineOptions = {}) {\n  const validation = validateMotionEvidenceRequest(input);\n  if (!validation.valid) {\n    return { ok: false, error: 'invalid-motion-request', details: validation.errors };\n  }\n  const request = immutableSnapshot(input);\n  const authoritySnapshot = request.authorityInputs;\n  const gate = evaluateMotionRestraint(request.restraintAssessment);\n  const blockedOutcome = blockingPlanOutcome(request.contextPlan);\n  if (blockedOutcome) {\n    return negativeResult(\n      request,\n      gate,\n      'corpus-unavailable',\n      blockedOutcome,\n      false,\n    );\n  }\n  if (gate.verdict === 'do-not-move') {\n    return negativeResult(request, gate, 'target-no-motion', 'no-fit', false);\n  }\n\n  const eligibility = classifyAttestedCandidates(request.eligibility);\n  if (!eligibility.candidate) {\n    const kind = eligibility.hardNegatives.length > 0\n      ? 'hard-negative-rejection'\n      : 'no-corpus-temporal-authority';\n    return negativeResult(request, gate, kind, 'no-fit', false);\n  }\n\n  let query;\n  try {\n    query = await runQuery({\n      ...(request.retrievalRequest ?? {}),\n      usage: 'reference',\n      exactReuse: false,\n      limit: MAX_QUERY_CARDS,\n    }, engineOptions);\n  } catch (error) {\n    if (!isKnownRetrievalUnavailable(error)) throw error;\n    return negativeResult(\n      request,\n      gate,\n      'corpus-unavailable',\n      'no-fit',\n      true,\n      [`retrieval-unavailable:${error.code ?? 'invalid-manifest'}`],\n    );\n  }\n  if (query.generationHash !== request.contextPlan.generationIdentity.observedGenerationHash) {\n    return negativeResult(\n      request,\n      gate,\n      'corpus-unavailable',\n      'no-fit',\n      true,\n      ['retrieval-unavailable:generation-mismatch'],\n    );\n  }\n  const card = query.cards.find((candidate) => candidate.id === eligibility.candidate.sourceId);\n  if (!card) {\n    return negativeResult(request, gate, 'no-corpus-temporal-authority', 'no-fit', true);\n  }\n  const hydration = await hydrateTemporalOwner(card, engineOptions);\n  if (!hydration.ok) {\n    if (!HYDRATION_UNAVAILABLE_CODES.has(hydration.error)) {\n      return { ok: false, error: `temporal-owner-${hydration.error}` };\n    }\n    return negativeResult(\n      request,\n      gate,\n      'corpus-unavailable',\n      'no-fit',\n      true,\n      [`temporal-owner-unavailable:${hydration.error}`],\n    );","lineStart":700,"lineEnd":834,"totalLines":882,"truncated":true}},"title":".opencode/skills/sk-design/design-motion/corpus/motion-evidence.mjs","time":{"start":1784623065243,"end":1784623065313}},"metadata":{"openai":{"itemId":"fc_04d4f234fc391bda016a5f2fd913e0819191336a5e5dead30b"}},"id":"prt_f83d2e893001wRI7rKNSVUeT1m","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d2bc16001LU4sPU2KLao3nN"}}
