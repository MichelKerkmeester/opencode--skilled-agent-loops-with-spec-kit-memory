    48	        iter_allowed_tools as _iter_allowed_tools,
    49	        DESCRIPTION_SOFT_TARGET_COMMAND as _DESC_SOFT_COMMAND,
    50	        DESCRIPTION_HARD_CAP as _DESC_HARD_CAP,
    51	    )
    52	except Exception:  # pragma: no cover - defensive fallback if the sibling is unavailable
    53	    _DESC_SOFT_COMMAND, _DESC_HARD_CAP = 110, 1536
    54	
    55	    def _strip_matching_quotes(value: str) -> str:
    56	        value = value.strip()
    57	        if len(value) >= 2 and value[0] == value[-1] and value[0] in ('"', "'"):
    58	            return value[1:-1]
    59	        return value
    60	
    61	    def _check_description_length(description, soft_target, hard_cap=_DESC_HARD_CAP):
    62	        length = len(description)
    63	        if length > hard_cap:
    64	            return (
    65	                f"Description is {length} chars, exceeds hard cap of {hard_cap} chars.",
    66	                None,
    67	            )
    68	        if length > soft_target:
    69	            return (None, f"Description is {length} chars, exceeds soft target of {soft_target}.")
    70	        return (None, None)
    71	
    72	    _MCP_NAMESPACE_RE = re.compile(r'^mcp_', re.IGNORECASE)
    73	    _MCP_FQ_RE = re.compile(
    74	        r'^mcp__[a-z0-9]+(?:[_-][a-z0-9]+)*__(?:\*|[a-z0-9]+(?:[_-][a-z0-9]+)*)$',
    75	        re.IGNORECASE,
    76	    )
    77	
    78	    def _is_non_fq_mcp_token(token: str) -> bool:
    79	        token = token.strip()
    80	        return bool(_MCP_NAMESPACE_RE.match(token)) and not bool(_MCP_FQ_RE.match(token))
