   actor,\n383:       metadata: input.provenanceMetadata ?? null,\n384:     });\n385:     const afterSnap = snapshotMemory(db, newId);\n386:     insertAudit(db, {\n387:       memory_id: newId, op: \"insert\", actor,\n388:       session_id: input.sessionId,\n389:       before_json: null,\n390:       after_json: afterSnap ? JSON.stringify(afterSnap) : null,\n391:     });\n392:   });\n393: \n394:   if (!skipExport) exportMarkdown();\n395: \n396:   // Embedding generation: prefer the durable Honker queue (a long-lived worker\n397:   // claims + embeds with retry/dead-letter — short-lived hooks just enqueue and\n398:   // exit). When no queue is available, embed inline as before. Auto-relate runs\n399:   // inline regardless: it embeds the query text fresh and compares against other\n400:   // memories' stored vectors, so it does not depend on this memory's own row.\n401:   const enqueuedJobId = enqueueEmbedding(newId);\n402:   import(\"./embeddings.js\").then(async ({ embedMemory, getSimilarMemories, classifyRelation }) => {\n403:     if (enqueuedJobId === null) await embedMemory(db, newId);\n404:     await autoDetectRelations(newId, content, getSimilarMemories, classifyRelation);\n405:   }).catch(err => process.stderr.write(`[learn] Background task failed for memory ${newId}: ${err}\\n`));\n406: \n407:   // Push a cross-process liveness event so any graph-app listener refreshes\n408:   // without waiting on the file-watcher. No-op when Honker is unavailable.\n409:   notifyLtm({ type: \"refresh\", reason: \"memory_created\", id: newId });\n410:   // Opt-in cross-agent sync: notify sibling processes of the new memory. No-op\n411:   // unless the ltm.crossProcessSync flag is on AND Honker is available.\n412:   notifyMemoryAdded({ id: newId, project_scope: input.project_scope ?? null });\n413: \n414:   return { action: \"created\", id: newId, confirm_count: 1 };\n415: }\n416: \n417: export async function recall(input: RecallInput = {}): Promise<MemoryWithRelations[]> {\n418:   const db = getDb();\n419:   const limit = input.limit ?? 10;\n420: \n421:   let ids: Set<number> | null = null;\n422:   const ftsRanks = new Map<number, number>();      // id → normalized [0,1]\n423:   const semanticScores = new Map<number, number>(); // id → cosine similarity [0,1]\n424: \n425:   if (input.query) {\n426:     // Sanitize for FTS5: quote each token (prevents reserved-word errors) and join with OR\n427:     const ftsQuery = input.query\n428:       .trim()\n429:       .split(/\\s+/)\n\n(Showing lines 300-429 of 780. Use offset=430 to continue.)\n</content>","metadata":{"preview":"    process.stderr.write(`[autoDetectRelations] error for memory ${newId}: ${err}\\n`);\n  }\n}\n\nexport function learn(input: LearnInput): LearnResult {\n  const db = getDb();\n\n  // Scrub secrets before any DB write or dedup check\n  const { scrubbed, redactions } = scrubSecrets(input.content);\n  if (redactions.length > 0) {\n    process.stderr.write(`[learn] Scrubbed ${redactions.length} secret(s): ${redactions.join(\", \")}\\n`);\n  }\n  const content = scrubbed;\n\n  const dedupKey = normalizeKey(content);\n  const skipExport = input.skipExport ?? false;\n\n  const existing = db.query<Memory, [string]>(`SELECT * FROM memories WHERE dedup_key=?`).get(dedupKey);\n\n  const actor = input.actor ?? \"mcp:ltm_learn\";","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","text":"    process.stderr.write(`[autoDetectRelations] error for memory ${newId}: ${err}\\n`);\n  }\n}\n\nexport function learn(input: LearnInput): LearnResult {\n  const db = getDb();\n\n  // Scrub secrets before any DB write or dedup check\n  const { scrubbed, redactions } = scrubSecrets(input.content);\n  if (redactions.length > 0) {\n    process.stderr.write(`[learn] Scrubbed ${redactions.length} secret(s): ${redactions.join(\", \")}\\n`);\n  }\n  const content = scrubbed;\n\n  const dedupKey = normalizeKey(content);\n  const skipExport = input.skipExport ?? false;\n\n  const existing = db.query<Memory, [string]>(`SELECT * FROM memories WHERE dedup_key=?`).get(dedupKey);\n\n  const actor = input.actor ?? \"mcp:ltm_learn\";\n\n  if (existing) {\n    const beforeSnap = snapshotMemory(db, existing.id);\n    db.run(\n      `UPDATE memories SET confirm_count=confirm_count+1, last_confirmed_at=datetime('now'),\n       confidence=MIN(1.0, confidence+0.05) WHERE id=?`,\n      [existing.id]\n    );\n    if (input.tags) attachTags(db, existing.id, input.tags);\n    if (input.relate_to) {\n      for (const rel of input.relate_to) {\n        relate({ source_id: existing.id, target_id: rel.id, relationship_type: rel.relationship_type });\n      }\n    }\n    tryAudit(() => {\n      const afterSnap = snapshotMemory(db, existing.id);\n      insertAudit(db, {\n        memory_id: existing.id, op: \"update\", actor,\n        session_id: input.sessionId,\n        before_json: beforeSnap ? JSON.stringify(beforeSnap) : null,\n        after_json: afterSnap ? JSON.stringify(afterSnap) : null,\n      });\n    });\n    if (!skipExport) exportMarkdown();\n    const updated = db.query<{ confirm_count: number }, [number]>(\n      `SELECT confirm_count FROM memories WHERE id=?`\n    ).get(existing.id);\n    return { action: \"reinforced\", id: existing.id, confirm_count: updated?.confirm_count ?? existing.confirm_count + 1 };\n  }\n\n  const title = input.title?.trim().slice(0, 60) || deriveTitle(content);\n\n  const result = db.run(\n    `INSERT INTO memories (content, title, category, importance, confidence, source, project_scope, dedup_key, created_by)\n     VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n    [\n      content,\n      title,\n      input.category,\n      input.importance ?? 3,\n      input.confidence ?? 1.0,\n      input.source ?? null,\n      input.project_scope ?? null,\n      dedupKey,\n      actor,\n    ]\n  );\n\n  const newId = Number(result.lastInsertRowid);\n\n  if (input.tags) attachTags(db, newId, input.tags);\n  if (input.relate_to) {\n    for (const rel of input.relate_to) {\n      relate({ source_id: newId, target_id: rel.id, relationship_type: rel.relationship_type });\n    }\n  }\n\n  tryAudit(() => {\n    insertProvenance(db, {\n      memory_id: newId,\n      source_type: input.provenanceSourceType ?? \"learn\",\n      source_ref: input.provenanceSourceRef ?? input.sessionId ?? null,\n      actor,\n      metadata: input.provenanceMetadata ?? null,\n    });\n    const afterSnap = snapshotMemory(db, newId);\n    insertAudit(db, {\n      memory_id: newId, op: \"insert\", actor,\n      session_id: input.sessionId,\n      before_json: null,\n      after_json: afterSnap ? JSON.stringify(afterSnap) : null,\n    });\n  });\n\n  if (!skipExport) exportMarkdown();\n\n  // Embedding generation: prefer the durable Honker queue (a long-lived worker\n  // claims + embeds with retry/dead-letter — short-lived hooks just enqueue and\n  // exit). When no queue is available, embed inline as before. Auto-relate runs\n  // inline regardless: it embeds the query text fresh and compares against other\n  // memories' stored vectors, so it does not depend on this memory's own row.\n  const enqueuedJobId = enqueueEmbedding(newId);\n  import(\"./embeddings.js\").then(async ({ embedMemory, getSimilarMemories, classifyRelation }) => {\n    if (enqueuedJobId === null) await embedMemory(db, newId);\n    await autoDetectRelations(newId, content, getSimilarMemories, classifyRelation);\n  }).catch(err => process.stderr.write(`[learn] Background task failed for memory ${newId}: ${err}\\n`));\n\n  // Push a cross-process liveness event so any graph-app listener refreshes\n  // without waiting on the file-watcher. No-op when Honker is unavailable.\n  notifyLtm({ type: \"refresh\", reason: \"memory_created\", id: newId });\n  // Opt-in cross-agent sync: notify sibling processes of the new memory. No-op\n  // unless the ltm.crossProcessSync flag is on AND Honker is available.\n  notifyMemoryAdded({ id: newId, project_scope: input.project_scope ?? null });\n\n  return { action: \"created\", id: newId, confirm_count: 1 };\n}\n\nexport async function recall(input: RecallInput = {}): Promise<MemoryWithRelations[]> {\n  const db = getDb();\n  const limit = input.limit ?? 10;\n\n  let ids: Set<number> | null = null;\n  const ftsRanks = new Map<number, number>();      // id → normalized [0,1]\n  const semanticScores = new Map<number, number>(); // id → cosine similarity [0,1]\n\n  if (input.query) {\n    // Sanitize for FTS5: quote each token (prevents reserved-word errors) and join with OR\n    const ftsQuery = input.query\n      .trim()\n      .split(/\\s+/)","lineStart":300,"lineEnd":429,"totalLines":780,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","time":{"start":1780929033203,"end":1780929033215}},"metadata":{"openai":{"itemId":"fc_0991ebbe93efbe7d016a26d208ebb881918f39543a181b3724"}},"id":"prt_ea7a472f3001xEiciQsVCG0Jp2","sessionID":"ses_1585c7ef3ffeE8bQgxmNtEsbEj","messageID":"msg_ea7a45ac70012UTdSHRbYtJtFX"}}
