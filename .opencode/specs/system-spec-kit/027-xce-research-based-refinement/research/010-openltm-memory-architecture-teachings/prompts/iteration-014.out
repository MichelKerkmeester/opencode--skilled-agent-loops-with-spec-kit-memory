tring): number {\n287:   return (database.prepare(`\n288:     SELECT COUNT(*) AS n FROM memory_index m\n289:     WHERE m.embedding_status = 'success'\n290:       AND (\n291:         NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = m.id)\n292:         OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = m.id)\n293:       )\n294:   `).get() as { n: number }).n;\n295: }\n296: \n297: /**\n298:  * Reconcile memory_index.embedding_status against active vector coverage.\n299:  * Assumes the active shard is attached as `active_vec` (the runtime attaches it\n300:  * during initialization; tests attach it explicitly).\n301:  */\n302: export function runMemoryEmbeddingReconcile(\n303:   database: Database.Database,\n304:   args: EmbeddingReconcileArgs = {},\n305: ): EmbeddingReconcileResult {\n306:   const startTime = Date.now();\n307:   const mode: EmbeddingReconcileMode = args.mode === 'apply' ? 'apply' : 'dry-run';\n308:   const resetMissing = args.resetMissing !== false;\n309:   const requireActiveShard = args.requireActiveShard !== false;\n310:   const repairSuccessCoverage = args.repairSuccessCoverage === true;\n311: \n312:   const active = readActiveEmbedder(database);\n313: \n314:   if (!hasTable(database, 'main', 'memory_index')) {\n315:     return {\n316:       mode,\n317:       activeEmbedder: { provider: active.provider, name: active.name, dim: active.dim, shard: null },\n318:       safety: { activeShardVerified: false, vectorPresenceSource: 'vec_memories_rowids', dimensionTableChecked: null, reason: 'memory_index table missing' },\n319:       buckets: emptyBuckets(),\n320:       plannedMutations: [\n321:         { name: 'reconcile_vector_present_to_success', rows: 0 },\n322:         { name: 'reset_missing_active_vector_to_retry_eligible', rows: 0 },\n323:       ],\n324:       applied: mode === 'apply' ? { reconciledToSuccess: 0, resetToRetry: 0 } : undefined,\n325:       durationMs: Date.now() - startTime,\n326:     };\n327:   }\n328: \n329:   const verification = verifyActiveShard(database, active);\n330:   const activeEmbedder: ReconcileActiveEmbedder = {\n331:     provider: active.provider,\n332:     name: active.name,\n333:     dim: active.dim,\n334:     shard: verification.shardPath,\n335:   };\n336:   const safety: ReconcileSafety = {\n337:     activeShardVerified: verification.verified,\n338:     vectorPresenceSource: 'vec_memories_rowids',\n339:     dimensionTableChecked: verification.dimTable,\n340:     ...(verification.verified ? {} : { reason: verification.reason }),\n341:   };\n342: \n343:   if (!verification.verified || verification.dimTable == null) {\n344:     if (requireActiveShard && mode === 'apply') {\n345:       throw new ActiveShardGuardError(verification.reason ?? 'unknown');\n346:     }\n347:     // Dry-run (or apply with requireActiveShard disabled): fail closed to zero work.\n348:     return {\n349:       mode,\n350:       activeEmbedder,\n351:       safety,\n352:       buckets: emptyBuckets(),\n353:       plannedMutations: [\n354:         { name: 'reconcile_vector_present_to_success', rows: 0 },\n355:         { name: 'reset_missing_active_vector_to_retry_eligible', rows: 0 },\n356:       ],\n357:       applied: mode === 'apply' ? { reconciledToSuccess: 0, resetToRetry: 0 } : undefined,\n358:       durationMs: Date.now() - startTime,\n359:     };\n360:   }\n361: \n362:   const dimTable = verification.dimTable;\n363:   const buckets = computeBuckets(database, dimTable);\n364:   const coverage: ReconcileCoverage = { successMissingActiveVector: computeSuccessCoverage(database, dimTable) };\n365:   const plannedMutations: ReconcilePlannedMutation[] = [\n366:     { name: 'reconcile_vector_present_to_success', rows: buckets.vector_present_status_stale.count },\n367:     { name: 'reset_missing_active_vector_to_retry_eligible', rows: resetMissing ? buckets.missing_active_vector_retry_eligible.count : 0 },\n368:   ];\n369:   if (repairSuccessCoverage) {\n370:     plannedMutations.push({ name: 'repair_success_missing_active_vector_to_retry', rows: coverage.successMissingActiveVector });\n371:   }\n372: \n373:   if (mode === 'dry-run') {\n374:     return { mode, activeEmbedder, safety, buckets, plannedMutations, coverage, durationMs: Date.now() - startTime };\n375:   }\n376: \n377:   // ── Apply: one BEGIN IMMEDIATE transaction, reconcile-before-reset (F2). ──\n378:   // .immediate() takes the write lock at BEGIN so a concurrent daemon writer\n379:   // cannot trigger a mid-transaction lock-upgrade failure (NFR-P02).\n380:   const applied: ReconcileApplied = { reconciledToSuccess: 0, resetToRetry: 0 };\n381:   const reconcileTx = database.transaction(() => {\n382:     const reconcile = database.prepare(`\n383:       UPDATE memory_index\n384:       SET embedding_status = 'success',\n385:           embedding_generated_at = COALESCE(embedding_generated_at, CURRENT_TIMESTAMP),\n386:           failure_reason = NULL,\n387:           updated_at = CURRENT_TIMESTAMP\n388:       WHERE embedding_status IN ('failed', 'pending', 'retry')\n389:         AND EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = memory_index.id)\n390:         AND EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = memory_index.id)\n391:     `).run();\n392:     applied.reconciledToSuccess = reconcile.changes;\n393: \n394:     if (resetMissing) {\n395:       // Reset only parked retention FAILURES missing a vector surface back to\n396:       // retry. failed -> retry makes this idempotent (a second apply finds no\n397:       // matching 'failed' rows) and never touches already-queued pending/retry\n398:       // rows' retry_count. Missing = either surface absent (OR), matching the\n399:       // retryEligible bucket above.\n400:       const reset = database.prepare(`\n401:         UPDATE memory_index\n402:         SET embedding_status = 'retry',\n403:             retry_count = 0,\n404:             last_retry_at = NULL,\n405:             failure_reason = NULL,\n406:             updated_at = CURRENT_TIMESTAMP\n407:         WHERE embedding_status = 'failed'\n408:           AND failure_reason LIKE 'Retry retention%'\n409:           AND (\n410:             NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = memory_index.id)\n411:             OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = memory_index.id)\n412:           )\n413:       `).run();\n414:       applied.resetToRetry = reset.changes;\n415:     }\n416: \n417:     if (repairSuccessCoverage) {\n418:       const repair = database.prepare(`\n419:         UPDATE memory_index\n420:         SET embedding_status = 'retry',\n421:             retry_count = 0,\n422:             last_retry_at = NULL,\n423:             failure_reason = NULL,\n424:             updated_at = CURRENT_TIMESTAMP\n425:         WHERE embedding_status = 'success'\n426:           AND (\n427:             NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = memory_index.id)\n428:             OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = memory_index.id)\n429:           )\n430:       `).run();\n431:       applied.successCoverageReset = repair.changes;\n432:     }\n433:   });\n434:   reconcileTx.immediate();\n435: \n436:   // Recompute buckets + coverage post-apply so the response reflects the converged state.\n437:   const postBuckets = computeBuckets(database, dimTable);\n438:   const postCoverage: ReconcileCoverage = { successMissingActiveVector: computeSuccessCoverage(database, dimTable) };\n439:   return {\n440:     mode,\n441:     activeEmbedder,\n442:     safety,\n443:     buckets: postBuckets,\n444:     plannedMutations,\n445:     applied,\n446:     coverage: postCoverage,\n447:     durationMs: Date.now() - startTime,\n448:   };\n449: }\n\n(End of file - total 449 lines)\n</content>","metadata":{"preview":"             COALESCE(anchor_id, '') AS anchor_key,\n             MAX(id) AS latest_id\n      FROM memory_index\n      GROUP BY COALESCE(canonical_file_path, file_path), COALESCE(anchor_id, '')\n    )\n    SELECT COUNT(*) AS n FROM memory_index m\n    JOIN latest ON latest.canonical_path = COALESCE(m.canonical_file_path, m.file_path)\n              AND latest.anchor_key = COALESCE(m.anchor_id, '')\n    WHERE m.embedding_status = 'failed' AND m.id <> latest.latest_id\n  `).get() as { n: number }).n;\n\n  return {\n    vector_present_status_stale: { count: staleCount, byStatus },\n    missing_active_vector_retry_eligible: { count: retryEligible },\n    missing_active_vector_provider_failure: { count: providerFailure },\n    failed_masked_by_newer_latest_path_anchor_row: { count: masked, overlapsBucket: 'vector_present_status_stale', policy: 'reconcile' },\n  };\n}\n\n/**","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/embedding-reconcile.ts","text":"             COALESCE(anchor_id, '') AS anchor_key,\n             MAX(id) AS latest_id\n      FROM memory_index\n      GROUP BY COALESCE(canonical_file_path, file_path), COALESCE(anchor_id, '')\n    )\n    SELECT COUNT(*) AS n FROM memory_index m\n    JOIN latest ON latest.canonical_path = COALESCE(m.canonical_file_path, m.file_path)\n              AND latest.anchor_key = COALESCE(m.anchor_id, '')\n    WHERE m.embedding_status = 'failed' AND m.id <> latest.latest_id\n  `).get() as { n: number }).n;\n\n  return {\n    vector_present_status_stale: { count: staleCount, byStatus },\n    missing_active_vector_retry_eligible: { count: retryEligible },\n    missing_active_vector_provider_failure: { count: providerFailure },\n    failed_masked_by_newer_latest_path_anchor_row: { count: masked, overlapsBucket: 'vector_present_status_stale', policy: 'reconcile' },\n  };\n}\n\n/**\n * Count `success` rows MISSING an active vector surface — the inverse hazard of\n * status-stale rows. A success row is repairable when EITHER the rowid marker OR\n * the active-dim vector row is absent; both surfaces are checked so this dry-run\n * count predicts exactly what the apply repair UPDATE will mutate.\n */\nfunction computeSuccessCoverage(database: Database.Database, dimTable: string): number {\n  return (database.prepare(`\n    SELECT COUNT(*) AS n FROM memory_index m\n    WHERE m.embedding_status = 'success'\n      AND (\n        NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = m.id)\n        OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = m.id)\n      )\n  `).get() as { n: number }).n;\n}\n\n/**\n * Reconcile memory_index.embedding_status against active vector coverage.\n * Assumes the active shard is attached as `active_vec` (the runtime attaches it\n * during initialization; tests attach it explicitly).\n */\nexport function runMemoryEmbeddingReconcile(\n  database: Database.Database,\n  args: EmbeddingReconcileArgs = {},\n): EmbeddingReconcileResult {\n  const startTime = Date.now();\n  const mode: EmbeddingReconcileMode = args.mode === 'apply' ? 'apply' : 'dry-run';\n  const resetMissing = args.resetMissing !== false;\n  const requireActiveShard = args.requireActiveShard !== false;\n  const repairSuccessCoverage = args.repairSuccessCoverage === true;\n\n  const active = readActiveEmbedder(database);\n\n  if (!hasTable(database, 'main', 'memory_index')) {\n    return {\n      mode,\n      activeEmbedder: { provider: active.provider, name: active.name, dim: active.dim, shard: null },\n      safety: { activeShardVerified: false, vectorPresenceSource: 'vec_memories_rowids', dimensionTableChecked: null, reason: 'memory_index table missing' },\n      buckets: emptyBuckets(),\n      plannedMutations: [\n        { name: 'reconcile_vector_present_to_success', rows: 0 },\n        { name: 'reset_missing_active_vector_to_retry_eligible', rows: 0 },\n      ],\n      applied: mode === 'apply' ? { reconciledToSuccess: 0, resetToRetry: 0 } : undefined,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  const verification = verifyActiveShard(database, active);\n  const activeEmbedder: ReconcileActiveEmbedder = {\n    provider: active.provider,\n    name: active.name,\n    dim: active.dim,\n    shard: verification.shardPath,\n  };\n  const safety: ReconcileSafety = {\n    activeShardVerified: verification.verified,\n    vectorPresenceSource: 'vec_memories_rowids',\n    dimensionTableChecked: verification.dimTable,\n    ...(verification.verified ? {} : { reason: verification.reason }),\n  };\n\n  if (!verification.verified || verification.dimTable == null) {\n    if (requireActiveShard && mode === 'apply') {\n      throw new ActiveShardGuardError(verification.reason ?? 'unknown');\n    }\n    // Dry-run (or apply with requireActiveShard disabled): fail closed to zero work.\n    return {\n      mode,\n      activeEmbedder,\n      safety,\n      buckets: emptyBuckets(),\n      plannedMutations: [\n        { name: 'reconcile_vector_present_to_success', rows: 0 },\n        { name: 'reset_missing_active_vector_to_retry_eligible', rows: 0 },\n      ],\n      applied: mode === 'apply' ? { reconciledToSuccess: 0, resetToRetry: 0 } : undefined,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  const dimTable = verification.dimTable;\n  const buckets = computeBuckets(database, dimTable);\n  const coverage: ReconcileCoverage = { successMissingActiveVector: computeSuccessCoverage(database, dimTable) };\n  const plannedMutations: ReconcilePlannedMutation[] = [\n    { name: 'reconcile_vector_present_to_success', rows: buckets.vector_present_status_stale.count },\n    { name: 'reset_missing_active_vector_to_retry_eligible', rows: resetMissing ? buckets.missing_active_vector_retry_eligible.count : 0 },\n  ];\n  if (repairSuccessCoverage) {\n    plannedMutations.push({ name: 'repair_success_missing_active_vector_to_retry', rows: coverage.successMissingActiveVector });\n  }\n\n  if (mode === 'dry-run') {\n    return { mode, activeEmbedder, safety, buckets, plannedMutations, coverage, durationMs: Date.now() - startTime };\n  }\n\n  // ── Apply: one BEGIN IMMEDIATE transaction, reconcile-before-reset (F2). ──\n  // .immediate() takes the write lock at BEGIN so a concurrent daemon writer\n  // cannot trigger a mid-transaction lock-upgrade failure (NFR-P02).\n  const applied: ReconcileApplied = { reconciledToSuccess: 0, resetToRetry: 0 };\n  const reconcileTx = database.transaction(() => {\n    const reconcile = database.prepare(`\n      UPDATE memory_index\n      SET embedding_status = 'success',\n          embedding_generated_at = COALESCE(embedding_generated_at, CURRENT_TIMESTAMP),\n          failure_reason = NULL,\n          updated_at = CURRENT_TIMESTAMP\n      WHERE embedding_status IN ('failed', 'pending', 'retry')\n        AND EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = memory_index.id)\n        AND EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = memory_index.id)\n    `).run();\n    applied.reconciledToSuccess = reconcile.changes;\n\n    if (resetMissing) {\n      // Reset only parked retention FAILURES missing a vector surface back to\n      // retry. failed -> retry makes this idempotent (a second apply finds no\n      // matching 'failed' rows) and never touches already-queued pending/retry\n      // rows' retry_count. Missing = either surface absent (OR), matching the\n      // retryEligible bucket above.\n      const reset = database.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            retry_count = 0,\n            last_retry_at = NULL,\n            failure_reason = NULL,\n            updated_at = CURRENT_TIMESTAMP\n        WHERE embedding_status = 'failed'\n          AND failure_reason LIKE 'Retry retention%'\n          AND (\n            NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = memory_index.id)\n            OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = memory_index.id)\n          )\n      `).run();\n      applied.resetToRetry = reset.changes;\n    }\n\n    if (repairSuccessCoverage) {\n      const repair = database.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            retry_count = 0,\n            last_retry_at = NULL,\n            failure_reason = NULL,\n            updated_at = CURRENT_TIMESTAMP\n        WHERE embedding_status = 'success'\n          AND (\n            NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = memory_index.id)\n            OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = memory_index.id)\n          )\n      `).run();\n      applied.successCoverageReset = repair.changes;\n    }\n  });\n  reconcileTx.immediate();\n\n  // Recompute buckets + coverage post-apply so the response reflects the converged state.\n  const postBuckets = computeBuckets(database, dimTable);\n  const postCoverage: ReconcileCoverage = { successMissingActiveVector: computeSuccessCoverage(database, dimTable) };\n  return {\n    mode,\n    activeEmbedder,\n    safety,\n    buckets: postBuckets,\n    plannedMutations,\n    applied,\n    coverage: postCoverage,\n    durationMs: Date.now() - startTime,\n  };\n}","lineStart":261,"lineEnd":449,"totalLines":449,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/embedding-reconcile.ts","time":{"start":1780929377837,"end":1780929377854}},"metadata":{"openai":{"itemId":"fc_0bad2189a5e8c9bd016a26d360cb088191b8ecefda5af72915"}},"id":"prt_ea7a9b233001goTfHbITrn3bX7","sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","messageID":"msg_ea7a9a1d5001ViQmByg3SSqM38"}}
