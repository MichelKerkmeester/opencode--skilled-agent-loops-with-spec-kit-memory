pecFolder !== 'string') throw new Error('specFolder must be a string');\n76:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n77: \n78:   let numericId: number | null = null;\n79:   if (id !== undefined && id !== null) {\n80:     numericId = parseMemoryId(id);\n81:   }\n82: \n83:   let deletedCount = 0;\n84:   let checkpointName: string | null = null;\n85:   let mutationLedgerWarning: string | null = null;\n86:   const database = vectorIndex.getDb();\n87: \n88:   if (!database) {\n89:     // Unified DB-unavailable contract for single and bulk delete paths.\n90:     return createDatabaseUnavailableDeleteResponse();\n91:   }\n92: \n93:   if (numericId !== null) {\n94:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n95: \n96:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n97:     // Cleanup, ledger append) in a transaction for atomicity on error.\n98:     database.transaction(() => {\n99:       deletedCount = vectorIndex.deleteMemory(numericId) ? 1 : 0;\n100: \n101:       if (deletedCount > 0) {\n102:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n103:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n104:         try {\n105:           recordHistory(\n106:             numericId,\n107:             'DELETE',\n108:             singleSnapshot?.file_path ?? null,\n109:             null,\n110:             'mcp:memory_delete',\n111:             singleSnapshot?.spec_folder ?? null,\n112:           );\n113:         } catch (_histErr: unknown) {\n114:           // History recording is best-effort\n115:         }\n116: \n117:         causalEdges.init(database);\n118:         causalEdges.deleteEdgesForMemory(String(numericId));\n119:         // H1 FIX: Use db-specific invalidation instead of the no-op global version\n120:         clearDegreeCacheForDb(database);\n121: \n122:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n123:           mutationType: 'delete',\n124:           reason: 'memory_delete: single memory delete',\n125:           priorHash: singleSnapshot?.content_hash ?? null,\n126:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n127:           linkedMemoryIds: [numericId],\n128:           decisionMeta: {\n129:             tool: 'memory_delete',\n130:             bulk: false,\n131:             memoryId: numericId,\n132:             specFolder: singleSnapshot?.spec_folder ?? null,\n133:             filePath: singleSnapshot?.file_path ?? null,\n134:           },\n135:           actor: 'mcp:memory_delete',\n136:         });\n137:         if (!ledgerRecorded) {\n138:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n139:         }\n140:       }\n141:     })();\n142:   } else {\n143:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n144:     const deletedIds: number[] = [];\n145:     const hashById = new Map<number, MemoryHashSnapshot>();\n146: \n147:     if (database && 'prepare' in database) {\n148:       try {\n149:         const rows = database.prepare(`\n150:           SELECT id, content_hash, spec_folder, file_path\n151:           FROM memory_index\n152:           WHERE spec_folder = ?\n153:         `).all(specFolder as string) as MemoryHashSnapshot[];\n154: \n155:         for (const row of rows) {\n156:           hashById.set(row.id, row);\n157:         }\n158:       } catch (_err: unknown) {\n159:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n160:       }\n161:     }\n162: \n163:     if (memories.length > 0) {\n164:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n165:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n166:       try {\n167:         const checkpoint = checkpoints.createChec