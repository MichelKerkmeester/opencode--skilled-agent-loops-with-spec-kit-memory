    24	// ─────────────────────────────────────────────────────────────────────────────
    25	// 2. CORE LOGIC
    26	// ─────────────────────────────────────────────────────────────────────────────
    27	
    28	/**
    29	 * Allocate the next artifact subfolder name under an artifact root directory
    30	 * using the {phaseSlug}-pt-{NN} naming convention.
    31	 *
    32	 * The phase slug is the FULL first-segment folder name under the spec tree
    33	 * root (e.g. "019-system-hardening").  NN is a two-digit zero-padded counter:
    34	 * 1 + the number of existing pt-folders whose slug prefix matches the requested
    35	 * phase, so repeated calls produce sequential names without any stored counter.
    36	 *
    37	 * @param {string} rootDir   - Absolute path to the artifact root (research/ or review/)
    38	 * @param {string} phaseSlug - Full phase folder name (e.g. "019-system-hardening")
    39	 * @returns {string} Subfolder name, e.g. "019-system-hardening-pt-03"
    40	 */
    41	function allocateShortSubfolder(rootDir, phaseSlug) {
    42	  let existingCount = 0;
    43	
    44	  if (fs.existsSync(rootDir)) {
    45	    const prefix = `${phaseSlug}-pt-`;
    46	    existingCount = fs.readdirSync(rootDir).filter(
    47	      (entry) => entry.startsWith(prefix),
    48	    ).length;
    49	  }
    50	
    51	  const nn = String(existingCount + 1).padStart(2, '0');
    52	  return `${phaseSlug}-pt-${nn}`;
    53	}
    54	
    55	function normalizeSpecFolderReference(specFolder) {
    56	  if (!specFolder) {
    57	    return null;
    58	  }
    59	
    60	  const normalized = String(specFolder)
    61	    .trim()
    62	    .replace(/\\/g, '/')
    63	    .replace(/\/+$/g, '');
    64	
    65	  if (!normalized) {
    66	    return null;
    67	  }
    68	
    69	  const opencodeSpecsMarker = '/.opencode/specs/';
    70	  const specsMarker = '/specs/';
    71	  const opencodeIndex = normalized.lastIndexOf(opencodeSpecsMarker);
    72	  if (opencodeIndex !== -1) {
    73	    return normalized.slice(opencodeIndex + opencodeSpecsMarker.length);
    74	  }
    75	
    76	  const specsIndex = normalized.lastIndexOf(specsMarker);
    77	  if (specsIndex !== -1) {
    78	    return normalized.slice(specsIndex + specsMarker.length);
    79	  }
    80	
    81	  return normalized
    82	    .replace(/^\.\/+/, '')
    83	    .replace(/^\.opencode\/specs\//, '')
    84	    .replace(/^specs\//, '');
    85	}
    86	
    87	function findAncestorSpecFolder(specFolder) {
    88	  let current = path.resolve(specFolder);
    89	
    90	  while (true) {
    91	    const parent = path.dirname(current);
    92	
    93	    if (parent === current || path.basename(parent) === 'specs') {
    94	      return null;
    95	    }
    96	
    97	    if (fs.existsSync(path.join(parent, 'spec.md'))) {
    98	      return parent;
    99	    }
   100	
   101	    current = parent;
   102	  }
   103	}
   104	
   105	function readPacketSpecFolder(packetDir, mode) {
   106	  const configPath = path.join(packetDir, MODE_CONFIG_FILE[mode]);
   107	  if (fs.existsSync(configPath)) {
   108	    try {
   109	      const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));
   110	      return normalizeSpecFolderReference(config.specFolder);
   111	    } catch (_error) {
   112	      // Fall through to state log probing.
   113	    }
   114	  }
   115	
   116	  const stateLogPath = path.join(packetDir, MODE_STATE_FILE[mode]);
   117	  if (!fs.existsSync(stateLogPath)) {
   118	    return null;
   119	  }
   120	
   121	  try {
   122	    const lines = fs.readFileSync(stateLogPath, 'utf8').split(/\r?\n/);
   123	    for (const line of lines) {
   124	      if (!line.trim()) {
   125	        continue;
   126	      }
   127	      const parsed = JSON.parse(line);
   128	      return normalizeSpecFolderReference(parsed.specFolder);
   129	    }
   130	  } catch (_error) {
   131	    return null;
   132	  }
   133	
   134	  return null;
   135	}
   136	
   137	function listPacketDirectories(rootDir) {
   138	  if (!fs.existsSync(rootDir)) {
   139	    return [];
   140	  }
   141	
   142	  return fs.readdirSync(rootDir, { withFileTypes: true })
   143	    .filter((entry) => entry.isDirectory() && /-pt-\d+$/.test(entry.name))
   144	    .map((entry) => entry.name)
   145	    .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }));
   146	}
   147	
   148	function findExistingPacket(rootDir, specFolder, mode) {
   149	  const targetSpecFolder = normalizeSpecFolderReference(specFolder);
   150	
   151	  if (!targetSpecFolder) {
   152	    return null;
   153	  }
   154	
   155	  const matches = [];
   156	  for (const packetName of listPacketDirectories(rootDir)) {
   157	    const packetDir = path.join(rootDir, packetName);
   158	    if (readPacketSpecFolder(packetDir, mode) === targetSpecFolder) {
   159	      matches.push(packetName);
   160	    }
   161	  }
   162	
   163	  return matches.at(-1) || null;
   164	}
   165	
   166	/**
   167	 * Resolve the canonical artifact directory for review or research output.
   168	 *
   169	 * Conventions (post-028 contract fix):
   170	 *   - Root specs ALWAYS use flat: {spec_folder}/{mode}/
   171	 *   - Child phases use FLAT-FIRST:
   172	 *       (a) First run with empty {mode}/ directory → flat (subfolder=null)
   173	 *       (b) Continuation when flat artifact's config matches current target → reuse flat
   174	 *       (c) Existing pt-NN packet matches current target → reuse pt-NN
   175	 *       (d) Prior content exists for non-matching target → allocate pt-NN
   176	 *
   177	 * Subfolder naming convention (when pt-NN allocation kicks in): {phaseSlug}-pt-{NN}
   178	 *   - phaseSlug: the FULL immediate child phase segment under the spec tree
   179	 *     root (e.g. "019-system-hardening")
   180	 *   - NN: sequential two-digit counter scoped to that phase within the
   181	 *     artifact root directory; allocated by counting existing same-prefix
   182	 *     entries at call time
   183	 *
   184	 * Example:
   185	 *   - root spec run → {spec_folder}/research/
   186	 *   - child phase first run → {spec_folder}/research/   (flat, no pt-NN wrapper)
   187	 *   - child phase second run with prior content for different target → {spec_folder}/research/{phaseSlug}-pt-NN/
   188	 *   - child phase same-target continuation → reuses prior flat or pt-NN
   189	 *
   190	 * @param {string} specFolder - Absolute or relative path to the target spec folder
   191	 * @param {'review'|'research'} [mode='review'] - Which artifact type to resolve
   192	 *
   193	 * @returns {{
   194	 *   rootDir: string,
   195	 *   subfolder: string|null,
   196	 *   artifactDir: string,
   197	 *   artifactArchiveRoot: string
   198	 * }} Resolved packet root plus canonical packet/archive directories
   199	 */
   200	function resolveArtifactRoot(specFolder, mode = 'review') {
   201	  const resolved = path.resolve(specFolder);
   202	  const rootDir = path.join(resolved, mode);
   203	  const artifactArchiveRoot = path.join(resolved, `${mode}_archive`);
   204	  const ancestorSpecFolder = findAncestorSpecFolder(resolved);
   205	
   206	  // ROOT spec: always flat
   207	  if (!ancestorSpecFolder) {
   208	    return {
   209	      rootDir,
   210	      subfolder: null,
   211	      artifactDir: rootDir,
   212	      artifactArchiveRoot,
   213	    };
   214	  }
   215	
   216	  // CHILD phase: prefer existing pt-NN packet for current target if any
   217	  const existingPacket = findExistingPacket(rootDir, resolved, mode);
   218	  if (existingPacket) {
   219	    return {
   220	      rootDir,
   221	      subfolder: existingPacket,
   222	      artifactDir: path.join(rootDir, existingPacket),
   223	      artifactArchiveRoot: path.join(artifactArchiveRoot, existingPacket),
   224	    };
   225	  }
   226	
   227	  // CHILD phase: check for flat artifact at rootDir
   228	  const targetSpecFolder = normalizeSpecFolderReference(resolved);
   229	  const flatConfigPath = path.join(rootDir, MODE_CONFIG_FILE[mode]);
   230	  const flatStateLogPath = path.join(rootDir, MODE_STATE_FILE[mode]);
   231	  const hasFlatArtifact = fs.existsSync(flatConfigPath) || fs.existsSync(flatStateLogPath);
   232	
   233	  if (hasFlatArtifact) {
   234	    const flatSpecFolder = readPacketSpecFolder(rootDir, mode);
   235	    if (flatSpecFolder === null || flatSpecFolder === targetSpecFolder) {
   236	      // Flat artifact matches current target (or its config is unreadable but rootDir is owned by this target's path) → reuse flat
   237	      return {
   238	        rootDir,
   239	        subfolder: null,
   240	        artifactDir: rootDir,
   241	        artifactArchiveRoot,
   242	      };
   243	    }
   244	    // Flat artifact is for a different target — fall through to allocate pt-NN
   245	  }
   246	
   247	  const ptFolders = listPacketDirectories(rootDir);
   248	  const hasPtFolders = ptFolders.length > 0;
   249	
   250	  // CHILD phase first run: empty rootDir → flat
   251	  if (!hasFlatArtifact && !hasPtFolders) {
   252	    return {
   253	      rootDir,
   254	      subfolder: null,
   255	      artifactDir: rootDir,
   256	      artifactArchiveRoot,
   257	    };
   258	  }
   259	
   260	  // CHILD phase: prior content exists (flat for different target, or pt-NN folders)
EXECUTOR CONFIG
     1	// ───────────────────────────────────────────────────────────────
     2	// MODULE: Deep-Loop Executor Config
     3	// ───────────────────────────────────────────────────────────────
     4	
     5	import { z } from 'zod';
     6	
     7	export const EXECUTOR_KINDS = ['native', 'cli-codex', 'cli-gemini', 'cli-claude-code'] as const;
     8	export type ExecutorKind = typeof EXECUTOR_KINDS[number];
     9	
    10	export const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh'] as const;
    11	export type ReasoningEffort = typeof REASONING_EFFORTS[number];
    12	
    13	export const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;
    14	export type ServiceTier = typeof SERVICE_TIERS[number];
    15	
    16	const SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;
    17	export type SandboxMode = typeof SANDBOX_MODES[number];
    18	export type GeminiSandboxMode = 'docker' | 'none';
    19	export type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';
    20	
    21	export const executorConfigSchema = z.object({
    22	  kind: z.enum(EXECUTOR_KINDS).default('native'),
    23	  model: z.string().min(1).nullable().default(null),
    24	  reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),
    25	  serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),
    26	  sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),
    27	  timeoutSeconds: z.number().int().positive().default(900),
    28	});
    29	
    30	export type ExecutorConfig = z.infer<typeof executorConfigSchema>;
    31	
    32	export const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {
    33	  native: [],
    34	  'cli-codex': ['model', 'reasoningEffort', 'serviceTier', 'sandboxMode', 'timeoutSeconds'],
    35	  'cli-gemini': ['model', 'sandboxMode', 'timeoutSeconds'],
    36	  'cli-claude-code': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],
    37	};
    38	
    39	export const GEMINI_SUPPORTED_MODELS = ['gemini-3.1-pro-preview'] as const;
    40	export type GeminiSupportedModel = typeof GEMINI_SUPPORTED_MODELS[number];
    41	
    42	function normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {
    43	  return mode ?? 'workspace-write';
    44	}
    45	
    46	export function resolveCodexSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {
    47	  return normalizeSandboxMode(mode);
    48	}
    49	
    50	export function resolveGeminiSandboxMode(mode: SandboxMode | null | undefined): GeminiSandboxMode {
    51	  return normalizeSandboxMode(mode) === 'danger-full-access' ? 'none' : 'docker';
    52	}
    53	
    54	export function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {
    55	  switch (normalizeSandboxMode(mode)) {
    56	    case 'read-only':
    57	      return 'plan';
    58	    case 'danger-full-access':
    59	      return 'bypassPermissions';
    60	    default:
    61	      return 'acceptEdits';
    62	  }
    63	}
    64	
    65	type ExecutorConfigIssue = {
    66	  path: PropertyKey[];
    67	  message: string;
    68	};
    69	
    70	export class ExecutorNotWiredError extends Error {
    71	  kind: Extract<ExecutorKind, 'cli-gemini' | 'cli-claude-code'>;
    72	
    73	  constructor(kind: Extract<ExecutorKind, 'cli-gemini' | 'cli-claude-code'>) {
    74	    super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);
    75	    this.name = 'ExecutorNotWiredError';
    76	    this.kind = kind;
    77	  }
    78	}
    79	
    80	export class ExecutorConfigError extends Error {
    81	  issues: ExecutorConfigIssue[];
    82	
    83	  constructor(input: { issues: ExecutorConfigIssue[] }) {
    84	    super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));
    85	    this.name = 'ExecutorConfigError';
    86	    this.issues = input.issues;
    87	  }
    88	}
    89	
    90	function normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {
    91	  return error.issues.map((issue) => ({
    92	    path: issue.path,
    93	    message: issue.message,
    94	  }));
    95	}
    96	
    97	export function parseExecutorConfig(raw: unknown): ExecutorConfig {
    98	  const parsed = executorConfigSchema.safeParse(raw);
    99	  if (!parsed.success) {
   100	    throw new ExecutorConfigError({
   101	      issues: normalizeIssues(parsed.error),
   102	    });
   103	  }
   104	
   105	  const config = parsed.data;
   106	  if (config.kind === 'cli-codex' && config.model === null) {
   107	    throw new ExecutorConfigError({
   108	      issues: [{ path: ['model'], message: 'model is required when kind is cli-codex' }],
   109	    });
   110	  }
   111	
   112	  const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];
   113	  const unsupportedFields: string[] = [];
   114	  const allOptionalFields: (keyof ExecutorConfig)[] = [
   115	    'model',
   116	    'reasoningEffort',
   117	    'serviceTier',
   118	    'sandboxMode',
   119	    'timeoutSeconds',
   120	  ];
   121	
   122	  for (const field of allOptionalFields) {
   123	    if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {
   124	      unsupportedFields.push(field);
   125	    }
   126	  }
   127	
   128	  if (unsupportedFields.length > 0) {
   129	    throw new ExecutorConfigError({
   130	      issues: unsupportedFields.map((field) => ({
   131	        path: [field],
   132	        message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${
   133	          supportedFlags.length ? supportedFlags.join(', ') : 'none'
   134	        }.`,
   135	      })),
   136	    });
   137	  }
   138	
   139	  if (
   140	    config.kind === 'cli-gemini' &&
   141	    config.model !== null &&
   142	    !GEMINI_SUPPORTED_MODELS.some((model) => model === config.model)
   143	  ) {
   144	    throw new ExecutorConfigError({
   145	      issues: [
   146	        {
   147	          path: ['model'],
   148	          message: `model '${config.model}' is not a supported cli-gemini model. Supported: ${GEMINI_SUPPORTED_MODELS.join(', ')}.`,
   149	        },
   150	      ],
   151	    });
   152	  }
   153	
   154	  return config;
   155	}
   156	
   157	export function resolveExecutorConfig(sources: {
   158	  cli?: Partial<ExecutorConfig>;
   159	  file?: Partial<ExecutorConfig>;
   160	}): ExecutorConfig {
   161	  const merged = {
   162	    ...(sources.file ?? {}),
   163	    ...(sources.cli ?? {}),
   164	  };
   165	  return parseExecutorConfig(merged);
   166	}
PROMPT PACK
     1	// ───────────────────────────────────────────────────────────────
     2	// MODULE: Deep-Loop Prompt Pack Renderer
     3	// ───────────────────────────────────────────────────────────────
     4	
     5	import { readFileSync } from 'node:fs';
     6	import { z } from 'zod';
     7	
     8	export type PromptPackVariables = Record<string, string | number>;
     9	
    10	const PROMPT_PACK_TOKEN_PATTERN = /\{([a-zA-Z_][a-zA-Z0-9_]*)\}/g;
    11	const promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);
    12	
    13	export class PromptPackError extends Error {
    14	  missingVariables: string[];
    15	
    16	  constructor(missingVariables: string[]) {
    17	    super(`Missing prompt pack variables: ${missingVariables.join(', ')}`);
    18	    this.name = 'PromptPackError';
    19	    this.missingVariables = missingVariables;
    20	  }
    21	}
    22	
    23	function extractTemplateTokens(template: string): string[] {
    24	  const tokens = new Set<string>();
    25	
    26	  for (const match of template.matchAll(PROMPT_PACK_TOKEN_PATTERN)) {
    27	    const tokenName = match[1];
    28	    if (promptPackVariableNameSchema.safeParse(tokenName).success) {
    29	      tokens.add(tokenName);
    30	    }
    31	  }
    32	
    33	  return [...tokens];
    34	}
    35	
    36	export function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {
    37	  const template = readFileSync(templatePath, 'utf8');
    38	  const missingVariables = new Set<string>();
    39	
    40	  const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {
    41	    if (!(tokenName in variables)) {
    42	      missingVariables.add(tokenName);
    43	      return `{${tokenName}}`;
    44	    }
    45	
    46	    return String(variables[tokenName]);
    47	  });
    48	
    49	  if (missingVariables.size > 0) {
    50	    throw new PromptPackError([...missingVariables]);
    51	  }
    52	
    53	  return rendered;
    54	}
    55	
    56	export function validatePromptPackTemplate(
    57	  templatePath: string,
    58	  expectedVariables: string[],
    59	): { present: string[]; missing: string[]; extra: string[] } {
    60	  const template = readFileSync(templatePath, 'utf8');
    61	  const templateTokens = extractTemplateTokens(template);
    62	  const templateTokenSet = new Set(templateTokens);
    63	  const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));
    64	
    65	  return {
    66	    present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),
    67	    missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),
    68	    extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),
    69	  };
    70	}
REDUCE STATE PATH ENTRY
  1160	 * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.
  1161	 *
  1162	 * @param {string} specFolder - Path to the target spec folder for the review packet
  1163	 * @param {Object} [options] - Reducer options
  1164	 * @param {boolean} [options.write=true] - Write outputs to disk when true
  1165	 * @returns {Object} Paths and content for registry, strategy, and dashboard
  1166	 */
  1167	function reduceReviewState(specFolder, options = {}) {
  1168	  const write = options.write !== false;
  1169	  const lenient = Boolean(options.lenient);
  1170	  const createMissingAnchors = Boolean(options.createMissingAnchors);
  1171	  const emitResourceMapOutput = Boolean(options.emitResourceMap);
  1172	  const resolvedSpecFolder = path.resolve(specFolder);
  1173	  const { artifactDir: reviewDir } = resolveArtifactRoot(resolvedSpecFolder, 'review');
  1174	  const configPath = path.join(reviewDir, 'deep-review-config.json');
  1175	  const stateLogPath = path.join(reviewDir, 'deep-review-state.jsonl');
  1176	  const strategyPath = path.join(reviewDir, 'deep-review-strategy.md');
  1177	  const registryPath = path.join(reviewDir, 'deep-review-findings-registry.json');
  1178	  const dashboardPath = path.join(reviewDir, 'deep-review-dashboard.md');
  1179	  const resourceMapPath = path.join(reviewDir, 'resource-map.md');
  1180	  const iterationDir = path.join(reviewDir, 'iterations');
  1181	  const deltaDir = path.join(reviewDir, 'deltas');
  1182	
  1183	  const config = readJson(configPath);
  1184	  const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(stateLogPath));
  1185	  const terminalStop = buildTerminalStopState(records);
  1186	  const lineage = buildLineageState(config, records, terminalStop);
  1187	  config.sessionId = lineage.sessionId || config.sessionId || '';
  1188	  config.parentSessionId = lineage.parentSessionId;
  1189	  config.lineageMode = lineage.lineageMode;
  1190	  config.generation = lineage.generation;
  1191	  config.continuedFromRun = lineage.continuedFromRun;
  1192	  if (terminalStop?.stopReason) {
  1193	    config.stopReason = terminalStop.stopReason;
  1194	  }
  1195	  const strategyContent = fs.existsSync(strategyPath) ? readUtf8(strategyPath) : '';
  1196	  const strategyDimensions = parseStrategyDimensions(strategyContent);
  1197	  const iterationFiles = fs.existsSync(iterationDir)
  1198	    ? fs.readdirSync(iterationDir)
  1199	        .filter((fileName) => /^iteration-\d+\.md$/.test(fileName))
  1200	        .sort()
  1201	        .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))
  1202	    : [];
  1203	
  1204	  const registry = buildRegistry(strategyDimensions, iterationFiles, records, config, corruptionWarnings);
  1205	  const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, { createMissingAnchors }, records);
POST DISPATCH VALIDATE
     1	// MODULE: Deep-Loop Post-Dispatch Validator
     2	
     3	import { readFileSync, existsSync, statSync } from 'node:fs';
     4	
     5	import type { ExecutorKind } from './executor-config.js';
     6	
     7	export type PostDispatchValidateInput = {
     8	  iterationFile: string;
     9	  stateLogPath: string;
    10	  previousStateLogSize: number;
    11	  requiredJsonlFields: string[];
    12	  executorKind?: ExecutorKind;
    13	  /**
    14	   * Per-iteration delta file path (e.g. `deltas/iter-003.jsonl`). When supplied,
    15	   * the validator asserts the file exists and is non-empty. The file is the
    16	   * structured-delta stream that complements the canonical state-log append —
    17	   * it MUST include at least one record whose `type === 'iteration'` so the
    18	   * reducer can rehydrate iteration state from the delta after interruption.
    19	   */
    20	  deltaFilePath?: string;
    21	};
    22	
    23	export type PostDispatchValidateResult =
    24	  | { ok: true }
    25	  | {
    26	      ok: false;
    27	      reason:
    28	        | 'iteration_file_missing'
    29	        | 'iteration_file_empty'
    30	        | 'jsonl_not_appended'
    31	        | 'jsonl_missing_fields'
    32	        | 'jsonl_parse_error'
    33	        | 'jsonl_wrong_type'
    34	        | 'delta_file_missing'
    35	        | 'delta_file_empty'
    36	        | 'delta_file_missing_iteration_record'
    37	        | 'executor_missing'
    38	        | 'dispatch_failure_logged';
    39	      details: string;
    40	    };
    41	
    42	function getLastNonEmptyLine(content: string): string | null {
    43	  const lines = content.split(/\r?\n/);
    44	
    45	  for (let index = lines.length - 1; index >= 0; index -= 1) {
    46	    const line = lines[index];
    47	    if (line.trim() !== '') {
    48	      return line;
    49	    }
    50	  }
    51	
    52	  return null;
    53	}
    54	
    55	function isObjectRecord(value: unknown): value is Record<string, unknown> {
    56	  return value !== null && !Array.isArray(value) && typeof value === 'object';
    57	}
    58	
    59	/**
    60	 * Canonical iteration record type. The reducer counts records where
    61	 * `type === CANONICAL_ITERATION_TYPE` ONLY. Variants such as
    62	 * `"iteration_delta"`, `"iter"`, or any other spelling are silently ignored and
    63	 * will surface as iteration-count drift in the reducer output.
    64	 */
    65	const CANONICAL_ITERATION_TYPE = 'iteration' as const;
    66	const REVIEW_ITERATION_FIELDS = [
    67	  'type',
    68	  'iteration',
    69	  'mode',
    70	  'run',
    71	  'status',
    72	  'focus',
    73	  'dimensions',
    74	  'filesReviewed',
    75	  'findingsCount',
    76	  'findingsSummary',
    77	  'findingsNew',
    78	  'findingDetails',
    79	  'newFindingsRatio',
    80	  'sessionId',
    81	  'generation',
    82	  'lineageMode',
    83	  'timestamp',
    84	  'durationMs',
    85	] as const;
    86	
    87	function findLastIterationRecord(content: string): Record<string, unknown> | null {
    88	  const lines = content.split(/\r?\n/);
    89	  for (let index = lines.length - 1; index >= 0; index -= 1) {
    90	    const line = lines[index]?.trim();
    91	    if (!line) continue;
    92	    try {
    93	      const parsed = JSON.parse(line);
    94	      if (isObjectRecord(parsed) && parsed.type === CANONICAL_ITERATION_TYPE) {
    95	        return parsed;
    96	      }
    97	    } catch {
    98	      // fall through
    99	    }
   100	  }
   101	  return null;
   102	}
   103	
   104	export function validateIterationOutputs(input: PostDispatchValidateInput): PostDispatchValidateResult {
   105	  if (statSync(input.stateLogPath).size <= input.previousStateLogSize) {
   106	    return {
   107	      ok: false,
   108	      reason: 'jsonl_not_appended',
   109	      details: `no new records since ${input.previousStateLogSize} bytes`,
   110	    };
   111	  }
   112	
   113	  const stateLogContent = readFileSync(input.stateLogPath, 'utf8');
   114	  const lastLine = getLastNonEmptyLine(stateLogContent);
   115	
   116	  try {
   117	    const parsedRecord = JSON.parse(lastLine ?? '');
   118	    if (!isObjectRecord(parsedRecord)) {
   119	      return {
   120	        ok: false,
   121	        reason: 'jsonl_parse_error',
   122	        details: 'Last JSONL line is not an object',
   123	      };
   124	    }
   125	
   126	    if (parsedRecord.type === 'event' && parsedRecord.event === 'dispatch_failure') {
   127	      return {
   128	        ok: false,
   129	        reason: 'dispatch_failure_logged',
   130	        details:
   131	          typeof parsedRecord.reason === 'string'
   132	            ? `dispatch_failure:${parsedRecord.reason}${typeof parsedRecord.detail === 'string' ? `:${parsedRecord.detail}` : ''}`
   133	            : 'dispatch_failure',
   134	      };
   135	    }
   136	
   137	    if (!existsSync(input.iterationFile)) {
   138	      return { ok: false, reason: 'iteration_file_missing', details: input.iterationFile };
   139	    }
   140	
   141	    if (statSync(input.iterationFile).size === 0) {
   142	      return { ok: false, reason: 'iteration_file_empty', details: input.iterationFile };
   143	    }
   144	
   145	    // Canonical type guard: the state-log append MUST use `"type":"iteration"`.
   146	    // Variants such as `"iteration_delta"` are silently dropped by the reducer.
   147	    if (parsedRecord.type !== CANONICAL_ITERATION_TYPE) {
   148	      return {
   149	        ok: false,
   150	        reason: 'jsonl_wrong_type',
   151	        details: `last record uses type='${String(parsedRecord.type)}' (expected '${CANONICAL_ITERATION_TYPE}')`,
   152	      };
   153	    }
   154	
   155	    const requiredFields = new Set([
   156	      ...input.requiredJsonlFields,
   157	      ...(
   158	        input.requiredJsonlFields.includes('findingsSummary') || input.requiredJsonlFields.includes('filesReviewed')
   159	          ? REVIEW_ITERATION_FIELDS
   160	          : []
   161	      ),
   162	    ]);
   163	    const missingFields = [...requiredFields].filter((field) => !(field in parsedRecord));
   164	
   165	    if (missingFields.length > 0) {
   166	      return {
   167	        ok: false,
   168	        reason: 'jsonl_missing_fields',
   169	        details: `missing: ${missingFields.join(',')}`,
   170	      };
   171	    }
   172	
   173	    if (requiredFields.has('filesReviewed') && !Array.isArray(parsedRecord.filesReviewed)) {
   174	      return {
   175	        ok: false,
   176	        reason: 'jsonl_missing_fields',
   177	        details: 'filesReviewed must be an array of reviewed file paths',
   178	      };
   179	    }
   180	    if (requiredFields.has('dimensions') && !Array.isArray(parsedRecord.dimensions)) {
   181	      return {
   182	        ok: false,
   183	        reason: 'jsonl_missing_fields',
   184	        details: 'dimensions must be an array',
   185	      };
   186	    }
   187	    if (requiredFields.has('findingDetails') && !Array.isArray(parsedRecord.findingDetails)) {
   188	      return {
   189	        ok: false,
   190	        reason: 'jsonl_missing_fields',
   191	        details: 'findingDetails must be an array',
   192	      };
   193	    }
   194	    if (requiredFields.has('newFindingsRatio') && typeof parsedRecord.newFindingsRatio !== 'number') {
   195	      return {
   196	        ok: false,
   197	        reason: 'jsonl_missing_fields',
   198	        details: 'newFindingsRatio must be a number',
   199	      };
   200	    }
   201	
   202	    if (input.executorKind && input.executorKind !== 'native' && !isObjectRecord(parsedRecord.executor)) {
   203	      return {
   204	        ok: false,
   205	        reason: 'executor_missing',
   206	        details: `missing executor provenance for non-native executor kind '${input.executorKind}'`,
   207	      };
   208	    }
   209	
   210	    // Per-iteration delta file assertion (when requested by the caller).
   211	    if (input.deltaFilePath) {
   212	      if (!existsSync(input.deltaFilePath)) {
   213	        return { ok: false, reason: 'delta_file_missing', details: input.deltaFilePath };
   214	      }
   215	      if (statSync(input.deltaFilePath).size === 0) {
   216	        return { ok: false, reason: 'delta_file_empty', details: input.deltaFilePath };
   217	      }
   218	      const deltaContent = readFileSync(input.deltaFilePath, 'utf8');
   219	      const deltaIterationRecord = findLastIterationRecord(deltaContent);
   220	      if (!deltaIterationRecord) {
   221	        return {
   222	          ok: false,
   223	          reason: 'delta_file_missing_iteration_record',
   224	          details: `${input.deltaFilePath} has no record with type='${CANONICAL_ITERATION_TYPE}'`,
   225	        };
   226	      }
   227	    }
   228	  } catch (error: unknown) {
   229	    const details = error instanceof Error ? error.message : String(error);
   230	    return { ok: false, reason: 'jsonl_parse_error', details };
   231	  }
   232	
   233	  return { ok: true };
   234	}
   235	
   236	export class PostDispatchValidationError extends Error {
   237	  result: PostDispatchValidateResult;
   238	
   239	  constructor(result: PostDispatchValidateResult) {
   240	    super(result.ok ? 'Post-dispatch validation unexpectedly succeeded' : `${result.reason}: ${result.details}`);

