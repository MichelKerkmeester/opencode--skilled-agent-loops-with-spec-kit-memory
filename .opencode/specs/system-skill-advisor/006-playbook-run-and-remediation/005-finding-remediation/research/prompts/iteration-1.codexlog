   288	export function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {
   289	  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);
   290	  const weights = effectiveScorerWeights(options.laneWeightsOverride);
   291	  const disabled = new Set(options.disabledLanes ?? []);
   292	  const affordances = normalize(options.affordances ?? []);
   293	  const laneScores = buildLaneScores(prompt, projection, disabled, affordances);
   294	  const laneScoreIndexes = Object.fromEntries(
   295	    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),
   296	  ) as Record<ScorerLane, LaneMatchIndex>;
   297	  const liveTotal = SCORER_LANES
   298	    .filter((lane) => !disabled.has(lane))
   299	    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();
   300	  if (isSpeckitMetricsEnabled() && liveTotal > 0) {
   301	    for (const lane of SCORER_LANES) {
   302	      if (!isLiveScorerLane(lane) || disabled.has(lane)) continue;
   303	      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });
   304	    }
   305	  }
   306	  const promptLower = prompt.toLowerCase();
   307	  const readOnlyExplainer = isReadOnlyExplainer(promptLower);
   308	  const hasTaskIntent = TASK_INTENT.test(promptLower);
   309	  const recommendations: AdvisorScoredRecommendation[] = [];
   310	
   311	  for (const skill of projection.skills) {
   312	    if (!isDefaultRoutable(promptLower, skill)) continue;
   313	    const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {
   314	      const laneMatch = laneScoreIndexes[lane].get(skill.id);
   315	      const rawScore = laneMatch?.rawScore ?? 0;
   316	      const shadowOnly = !isLiveScorerLane(lane);
   317	      return {
   318	        lane,
   319	        rawScore,
   320	        weightedScore: shadowOnly || disabled.has(lane) ? 0 : rawScore * weights[lane],
   321	        weight: disabled.has(lane) ? 0 : weights[lane],
   322	        evidence: laneMatch?.evidence ?? [],
   323	        shadowOnly,
   324	      };
   325	    });
   326	    const score = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);
   327	    if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;
   328	    if (isSpeckitMetricsEnabled()) {
   329	      for (const contribution of contributions) {
   330	        if (contribution.weightedScore !== 0) {
   331	          speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });
   332	        }
   333	      }
   334	    }
   335	
   336	    const directScore = Math.max(
   337	      contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,
   338	      contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,
   339	    );
   340	    const derivedDominant = isDerivedDominant(contributions);
   341	    const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);
   342	    const liveNormalized = score / liveTotal;
   343	    let confidence = confidenceFor({
   344	      liveNormalized,
   345	      directScore,
   346	      readOnlyExplainer,
   347	      hasExplicitWorkflowSignal: explicitSignal,
   348	      hasTaskIntent,
   349	      readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),
   350	      derivedDominant,
   351	      skillId: skill.id,
   352	    });
   353	    if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {
   354	      confidence = Math.min(confidence, 0.49);
   355	    }
   356	    recommendations.push({
   357	      skill: skill.id,
   358	      kind: skill.kind,
   359	      confidence,
   360	      uncertainty: uncertaintyFor(contributions, confidence, 0),
   361	      passes_threshold: false,
   362	      reason: attributionReason(contributions),
   363	      score: Number(score.toFixed(6)),
   364	      laneContributions: contributions,
   365	      dominantLane: dominantLane(contributions),
   366	      redirectTo: skill.redirectTo ?? undefined,
   367	      redirectFrom: skill.redirectFrom,
   368	      lifecycleStatus: skill.lifecycleStatus,
   369	    });
   370	  }
   371	
   372	  if (isSpeckitMetricsEnabled()) {
   373	    for (const recommendation of recommendations) {
   374	      if (primaryIntentBonus(promptLower, recommendation) !== 0) {
   375	        speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });
   376	      }
   377	    }
   378	  }
   379	  let ranked = recommendations.sort((left, right) => {
   380	    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;
   381	    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;
   382	    const leftIntent = primaryIntentBonus(promptLower, left);
   383	    const rightIntent = primaryIntentBonus(promptLower, right);
   384	    return (right.score + rightCommandBonus + rightIntent) - (left.score + leftCommandBonus + leftIntent)
   385	      || right.confidence - left.confidence
   386	      || left.skill.localeCompare(right.skill);
   387	  });
   388	
   389	  ranked = ranked.map((recommendation, index) => {
   390	    const next = ranked[index + 1];
   391	    const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;
   392	    const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);
   393	    return {
   394	      ...recommendation,
   395	      uncertainty,
   396	      passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)
   397	        && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),
   398	    };
   399	  });
   400	  ranked = applyAmbiguity(ranked);
   401	
   402	  const passing = ranked.filter((recommendation) => recommendation.passes_threshold);
   403	  const visible = options.includeAllCandidates ? ranked : passing;
   404	  const top = passing[0] ?? null;
   405	  if (isSpeckitMetricsEnabled() && top) {
   406	    const runtimeLabel = normalizeRuntimeLabel(process.env.SPECKIT_RUNTIME);
   407	    const freshnessLabel = normalizeFreshnessLabel(process.env.SPECKIT_ADVISOR_FRESHNESS);
   408	    if (runtimeLabel && freshnessLabel) {
   409	      speckitMetrics.incrementCounter('spec_kit.advisor.recommendation_emitted_total', { runtime: runtimeLabel, freshness_state: freshnessLabel });
   410	    }
   411	    speckitMetrics.recordConfidenceBracket(top.confidence);
   412	  }
   413	  return {
   414	    recommendations: visible,
   415	    topSkill: top?.skill ?? null,
   416	    unknown: !top,
   417	    ambiguous: isAmbiguousTopTwo(ranked),
   418	    metrics: {
   419	      candidateCount: ranked.length,
   420	      liveLaneCount: SCORER_LANES.filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane)).length,
   421	    },
   422	  };
   423	}

