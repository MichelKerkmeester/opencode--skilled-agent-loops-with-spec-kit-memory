{"type":"tool_use","timestamp":1781764128679,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_lV6DvFWBxXbGcFoIejJ63wrR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","offset":1,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC Socket Server (multi-client launcher bridge)\n3: // ───────────────────────────────────────────────────────────────\n4: // Canonical bridge logic shared by every daemon launcher (memory,\n5: // code-index, skill-advisor). Each service supplies its own socket/db\n6: // PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n7: // and race-safety contract stays identical across services.\n8: \n9: import fs from 'node:fs';\n10: import net from 'node:net';\n11: import os from 'node:os';\n12: import path from 'node:path';\n13: \n14: import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n15: \n16: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n17: // Every live session's launcher holds one persistent slot, and multi-seat\n18: // fan-outs run well past 8 concurrent sessions. A refused connection is\n19: // accepted then closed, which probes cannot distinguish from a dead daemon,\n20: // so the cap must exceed any realistic session fleet.\n21: const DEFAULT_MAX_SECONDARY_CLIENTS = 64;\n22: const TCP_EADDRINUSE_RETRY_DELAYS_MS = [100, 250, 500, 1000, 1500] as const;\n23: \n24: interface IpcBridgeStats {\n25:   socket_path: string | null;\n26:   secondary_clients_count: number;\n27:   total_secondary_messages_in: number;\n28:   total_secondary_messages_out: number;\n29: }\n30: \n31: // Structural shape of the only MCP server capability this bridge uses. Typed structurally (a\n32: // method, so its transport param is bivariant) rather than against a concrete `Server` import so\n33: // every consuming package satisfies it with its own `@modelcontextprotocol/sdk` copy — the three\n34: // daemons each install the SDK separately and its private members make the classes nominally\n35: // distinct, which a concrete import would reject across package boundaries.\n36: interface McpServerLike {\n37:   connect(transport: StdioServerTransport): Promise<void>;\n38: }\n39: \n40: interface IpcSocketServerOptions {\n41:   readonly socketPath: string;\n42:   readonly createServer: () => McpServerLike;\n43:   readonly maxClients?: number;\n44:   readonly log?: (message: string) => void;\n45:   readonly onActivity?: () => void;\n46: }\n47: \n48: interface IpcSocketServerHandle {\n49:   readonly socketPath: string;\n50:   readonly close: () => Promise<void>;\n51: }\n52: \n53: let activeServer: net.Server | null = null;\n54: let activeSocketPath: string | null = null;\n55: const activeSockets = new Set<net.Socket>();\n56: const activeTransports = new Map<net.Socket, StdioServerTransport>();\n57: let totalSecondaryMessagesIn = 0;\n58: let totalSecondaryMessagesOut = 0;\n59: \n60: function countJsonRpcFrames(chunk: unknown): number {\n61:   const text = Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n62:   const newlineCount = text.split('\\n').length - 1;\n63:   return Math.max(1, newlineCount);\n64: }\n65: \n66: // Window for a connection refused at the client cap to identify itself as a\n67: // liveness probe by sending its first JSON-RPC frame. Kept short so a non-probe\n68: // (real bridge client) is refused promptly, and bounded so probe traffic cannot\n69: // accumulate durable resources above the cap.\n70: const PROBE_AT_CAP_WINDOW_MS = 1000;\n71: \n72: // When at the durable client cap, peek the first frame. A liveness probe sends a\n73: // JSON-RPC `initialize` with clientInfo.name === 'liveness-probe' and treats ANY\n74: // reply carrying its id (result OR error) as proof the daemon is alive. Answer it\n75: // with a matching-id JSON-RPC error and close, without ever adding it to\n76: // activeSockets — so transient probe bursts can never exhaust the cap that exists\n77: // for durable bridge sessions. A non-probe first frame is refused like before.\n78: function answerProbeOrRefuseAtCap(\n79:   socket: net.Socket,\n80:   maxClients: number,\n81:   log: (message: string) => void,\n82: ): void {\n83:   let settled = false;\n84:   let buffer = '';\n85:   const finish = (refusedReason: string) => {\n86:     if (settled) return;\n87:     settled = true;\n88:     clearTimeout(timer);\n89:     log(`[ipc-bridge] refusing secondary connection: max clients ${maxClients} reached${refusedReason}`);\n90:     socket.end();\n91:     socket.destroy();\n92:   };\n93:   const timer = setTimeout(() => finish(' (no probe frame)'), PROBE_AT_CAP_WINDOW_MS);\n94:   timer.unref?.();\n95:   socket.on('error', () => finish(' (socket error)'));\n96:   socket.on('data', (chunk: Buffer | string) => {\n97:     if (settled) return;\n98:     buffer += Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n99:     let newlineIndex = buffer.indexOf('\\n');\n100:     while (newlineIndex !== -1) {\n101:       const line = buffer.slice(0, newlineIndex).trim();\n102:       buffer = buffer.slice(newlineIndex + 1);\n103:       newlineIndex = buffer.indexOf('\\n');\n104:       if (!line) continue;\n105:       let parsed: unknown;\n106:       try {\n107:         parsed = JSON.parse(line);\n108:       } catch {\n109:         finish(' (non-json frame at cap)');\n110:         return;\n111:       }\n112:       const frame = parsed as { id?: unknown; method?: unknown; params?: { clientInfo?: { name?: unknown } } };\n113:       const isProbe = frame\n114:         && frame.method === 'initialize'\n115:         && frame.params?.clientInfo?.name === 'liveness-probe';\n116:       if (isProbe) {\n117:         settled = true;\n118:         clearTimeout(timer);\n119:         const reply = `${JSON.stringify({\n120:           jsonrpc: '2.0',\n121:           id: frame.id ?? null,\n122:           error: { code: -32000, message: 'daemon at client capacity; liveness probe acknowledged' },\n123:         })}\\n`;\n124:         socket.end(reply);\n125:         log('[ipc-bridge] answered liveness probe at client cap without occupying a durable slot');\n126:         return;\n127:       }\n128:       finish(' (non-probe frame at cap)');\n129:       return;\n130:     }\n131:   });\n132: }\n133: \n134: function parseMaxClients(rawValue = process.env.SPECKIT_MAX_SECONDARY_CLIENTS): number {\n135:   if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') {\n136:     return DEFAULT_MAX_SECONDARY_CLIENTS;\n137:   }\n138:   const parsed = Number.parseInt(String(rawValue), 10);\n139:   if (!Number.isFinite(parsed) || parsed < 1) {\n140:     return DEFAULT_MAX_SECONDARY_CLIENTS;\n141:   }\n142:   return parsed;\n143: }\n144: \n145: function sleep(ms: number): Promise<void> {\n146:   return new Promise((resolve) => setTimeout(resolve, ms));\n147: }\n148: \n149: // Canonicalize a path via realpath, even when the leaf does not exist yet. realpath the nearest\n150: // existing ancestor (so symlinked roots like macOS `/tmp` -> `/private/tmp` normalize) and\n151: // re-append the missing tail. Without ancestor canonicalization, a socket dir that was cleared\n152: // (e.g. `/tmp/<service>` after a reboot) stays literal `/tmp/...` and fails the allowed-root\n153: // check below — which canonicalizes `/tmp` to `/private/tmp` — crashing the server.\n154: // Fail closed: an existing ancestor that cannot be canonicalized (permission/loop error) must\n155: // abort rather than return a non-canonical path, which would weaken the allowed-root containment\n156: // check that downstream binds rely on.\n157: function canonicalizePath(target: string): string {\n158:   const resolved = path.resolve(target);\n159:   const tail: string[] = [];\n160:   let current = resolved;\n161:   while (!fs.existsSync(current)) {\n162:     const parent = path.dirname(current);\n163:     if (parent === current) {\n164:       return resolved;\n165:     }\n166:     tail.unshift(path.basename(current));\n167:     current = parent;\n168:   }\n169:   return path.join(fs.realpathSync.native(current), ...tail);\n170: }\n171: \n172: // Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it.\n173: // Both inputs MUST already be canonicalized. Inlined here so the shared bridge carries no\n174: // cross-module dependency for a single containment call.\n175: function isWithinRoot(root: string, candidate: string): boolean {\n176:   if (candidate === root) {\n177:     return true;\n178:   }\n179:   const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n180:   return candidate.startsWith(prefix);\n181: }\n182: \n183: // Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n184: // The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n185: // `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n186: // `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n187: // the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n188: // `canUnlinkExistingSocket` preserves the unlink-hardening intent.\n189: function allowedSocketRoots(): string[] {\n190:   const roots = new Set<string>();\n191:   roots.add(canonicalizePath(process.cwd()));\n192:   roots.add(canonicalizePath(os.tmpdir()));\n193:   roots.add(canonicalizePath('/tmp'));\n194:   return [...roots];\n195: }\n196: \n197: function isWithinAllowedSocketRoot(candidate: string): boolean {\n198:   return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n199: }\n200: \n201: function resolveIpcSocketPath(dbDir: string): string {\n202:   const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n203:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n204:     : path.resolve(dbDir);\n205:   const socketDir = canonicalizePath(rawSocketDir);\n206:   if (!isWithinAllowedSocketRoot(socketDir)) {\n207:     throw new Error(\n208:       `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n209:     );\n210:   }\n211:   return path.join(socketDir, SOCKET_FILE_NAME);\n212: }\n213: \n214: // Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n215: // inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n216: // Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n217: // socket they own at the bind path.\n218: function canUnlinkExistingSocket(socketPath: string): boolean {\n219:   let parent: string;\n220:   try {\n221:     parent = fs.realpathSync.native(path.dirname(socketPath));\n222:   } catch (error: unknown) {\n223:     // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n224:     // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n225:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n226:       return true;\n227:     }\n228:     throw error;\n229:   }\n230:   if (!isWithinAllowedSocketRoot(parent)) {\n231:     return false;\n232:   }\n233:   try {\n234:     const stat = fs.lstatSync(socketPath);\n235:     if (!stat.isSocket()) {\n236:       return false;\n237:     }\n238:     if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n239:       return false;\n240:     }\n241:     return true;\n242:   } catch (error: unknown) {\n243:     // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n244:     // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n245:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n246:       return true;\n247:     }\n248:     throw error;\n249:   }\n250: }\n251: \n252: function getIpcBridgeStats(): IpcBridgeStats {\n253:   return {\n254:     socket_path: activeSocketPath,\n255:     secondary_clients_count: activeSockets.size,\n256:     total_secondary_messages_in: totalSecondaryMessagesIn,\n257:     total_secondary_messages_out: totalSecondaryMessagesOut,\n258:   };\n259: }\n260: \n261: async function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n262:   await new Promise<void>((resolve, reject) => {\n263:     const onError = (error: NodeJS.ErrnoException) => {\n264:       server.off('listening', onListening);\n265:       reject(error);\n266:     };\n267:     const onListening = () => {\n268:       server.off('error', onError);\n269:       resolve();\n270:     };\n271:     server.once('error', onError);\n272:     server.once('listening', onListening);\n273:     if (socketPath.startsWith('tcp://')) {\n274:       const url = new URL(socketPath);\n275:       server.listen(Number.parseInt(url.port, 10), url.hostname);\n276:       return;\n277:     }\n278:     server.listen(socketPath);\n279:   });\n280: }\n281: \n282: // TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n283: // unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n284: // few times before giving up. Returns true once a retry binds, false if the port stays in use.\n285: async function retryTcpListenAfterEaddrInUse(\n286:   server: net.Server,\n287:   socketPath: string,\n288:   log: (message: string) => void,\n289: ): Promise<boolean> {\n290:   for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n291:     log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n292:     await sleep(delayMs);\n293:     try {\n294:       await listenOnce(server, socketPath);\n295:       return true;\n296:     } catch (error: unknown) {\n297:       const err = error as NodeJS.ErrnoException;\n298:       if (err.code !== 'EADDRINUSE') {\n299:         throw err;\n300:       }\n301:     }\n302:   }\n303:   return false;\n304: }\n305: \n306: // Tear down any server still registered in the module-global slots before a new bind reuses them.\n307: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n308: // dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n309: // shared stats. Re-entrancy must close the prior server first.\n310: async function disposeActiveServer(): Promise<void> {\n311:   const priorServer = activeServer;\n312:   for (const socket of activeSockets) {\n313:     socket.destroy();\n314:   }\n315:   activeSockets.clear();\n316:   activeTransports.clear();\n317:   if (priorServer) {\n318:     await new Promise<void>((resolve) => {\n319:       priorServer.close(() => resolve());\n320:     });\n321:   }\n322:   activeServer = null;\n323:   activeSocketPath = null;\n324: }\n325: \n326: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n327:   if (activeServer) {\n328:     await disposeActiveServer();\n329:   }\n330:   const socketPath = options.socketPath.startsWith('tcp://')\n331:     ? options.socketPath\n332:     : path.resolve(options.socketPath);\n333:   const log = options.log ?? ((message: string) => console.error(message));\n334:   const maxClients = options.maxClients ?? parseMaxClients();\n335:   const onActivity = options.onActivity ?? (() => undefined);\n336:   if (!socketPath.startsWith('tcp://')) {\n337:     const socketDir = path.dirname(socketPath);\n338:     fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n339:     // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n340:     // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n341:     // so refuse to bind under a dir not owned by us or that is group/world-writable.\n342:     try {\n343:       const st = fs.statSync(socketDir);\n344:       const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n345:       if (uid !== null && st.uid !== uid) {\n346:         throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n347:       }\n348:       if ((st.mode & 0o022) !== 0) {\n349:         throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n350:       }\n351:     } catch (error: unknown) {\n352:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n353:       if (code !== 'ENOENT') throw error;\n354:     }\n355:     // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n356:     // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n357:     // protection so a symlink whose target we would later chmod cannot be used to redirect the\n358:     // permission change onto an arbitrary file.\n359:     try {\n360:       const linkStat = fs.lstatSync(socketPath);\n361:       if (linkStat.isSymbolicLink()) {\n362:         throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n363:       }\n364:     } catch (error: unknown) {\n365:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n366:       if (code !== 'ENOENT') throw error;\n367:     }\n368:   }\n369: \n370:   const server = net.createServer((socket) => {\n371:     if (activeSockets.size >= maxClients) {\n372:       // A bare close here is indistinguishable from a dead daemon to a liveness\n373:       // probe, which makes a sibling launcher reap a healthy-but-cap-saturated\n374:       // daemon. Give the connection a brief window to send its first frame: if it\n375:       // is a liveness probe, answer it (proving the daemon alive) and close WITHOUT\n376:       // occupying a durable slot; only refuse genuine bridge clients at the cap.\n377:       answerProbeOrRefuseAtCap(socket, maxClients, log);\n378:       return;\n379:     }\n380: \n381:     activeSockets.add(socket);\n382:     onActivity();\n383:     log('[ipc-bridge] secondary connected pid=?');\n384: \n385:     const originalWrite = socket.write.bind(socket);\n386:     socket.write = ((chunk: unknown, ...args: unknown[]) => {\n387:       onActivity();\n388:       totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n389:       return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n390:     }) as typeof socket.write;\n391: \n392:     socket.on('data', (chunk) => {\n393:       onActivity();\n394:       totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n395:     });\n396: \n397:     const transport = new StdioServerTransport(socket, socket);\n398:     activeTransports.set(socket, transport);\n399:     const secondaryServer = options.createServer();\n400:     secondaryServer.connect(transport).catch((error: unknown) => {\n401:       const message = error instanceof Error ? error.message : String(error);\n402:       log(`[ipc-bridge] secondary connect error: ${message}`);\n403:       socket.destroy();\n404:     });\n405: \n406:     socket.once('close', () => {\n407:       activeSockets.delete(socket);\n408:       activeTransports.delete(socket);\n409:       void transport.close();\n410:       log('[ipc-bridge] disconnect');\n411:     });\n412:     socket.once('error', (error) => {\n413:       log(`[ipc-bridge] socket error: ${error.message}`);\n414:     });\n415:   });\n416: \n417:   try {\n418:     await listenOnce(server, socketPath);\n419:   } catch (error: unknown) {\n420:     const err = error as NodeJS.ErrnoException;\n421:     if (err.code !== 'EADDRINUSE') {\n422:       throw err;\n423:     }\n424:     if (socketPath.startsWith('tcp://')) {\n425:       // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n426:       // never frees, run without the secondary bridge rather than aborting the whole daemon.\n427:       const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n428:       if (!listened) {\n429:         log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n430:         return {\n431:           socketPath,\n432:           close: async () => {\n433:             for (const socket of activeSockets) {\n434:               socket.destroy();\n435:             }\n436:             activeSockets.clear();\n437:             activeTransports.clear();\n438:           },\n439:         };\n440:       }\n441:     } else {\n442:       // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n443:       // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n444:       // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n445:       if (!canUnlinkExistingSocket(socketPath)) {\n446:         throw err;\n447:       }\n448:       try {\n449:         fs.unlinkSync(socketPath);\n450:       } catch (unlinkError: unknown) {\n451:         const unlinkErr = unlinkError as NodeJS.ErrnoException;\n452:         if (unlinkErr.code !== 'ENOENT') {\n453:           throw unlinkErr;\n454:         }\n455:       }\n456:       await listenOnce(server, socketPath);\n457:     }\n458:   }\n459: \n460:   const address = server.address();\n461:   const listenedPath = typeof address === 'object' && address\n462:     ? `tcp://${address.address}:${address.port}`\n463:     : socketPath;\n464:   if (!socketPath.startsWith('tcp://')) {\n465:     // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n466:     // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n467:     const boundStat = fs.lstatSync(socketPath);\n468:     if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n469:       throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n470:     }\n471:     fs.chmodSync(socketPath, 0o600);\n472:   }\n473:   activeServer = server;\n474:   activeSocketPath = listenedPath;\n475:   log(`[ipc-bridge] socket listening at ${listenedPath}`);\n476: \n477:   return {\n478:     socketPath: listenedPath,\n479:     close: async () => {\n480:       for (const socket of activeSockets) {\n481:         socket.destroy();\n482:       }\n483:       activeSockets.clear();\n484:       activeTransports.clear();\n485:       await new Promise<void>((resolve) => {\n486:         server.close(() => resolve());\n487:       });\n488:       if (activeServer === server) {\n489:         activeServer = null;\n490:         activeSocketPath = null;\n491:       }\n492:       if (!socketPath.startsWith('tcp://')) {\n493:         try {\n494:           fs.unlinkSync(socketPath);\n495:         } catch (error: unknown) {\n496:           const err = error as NodeJS.ErrnoException;\n497:           if (err.code !== 'ENOENT') {\n498:             throw err;\n499:           }\n500:         }\n501:       }\n502:     },\n503:   };\n504: }\n505: \n506: export {\n507:   canUnlinkExistingSocket,\n508:   getIpcBridgeStats,\n509:   parseMaxClients,\n510:   resolveIpcSocketPath,\n511:   startIpcSocketServer,\n512: };\n513: \n514: export type {\n515:   IpcBridgeStats,\n516:   IpcSocketServerHandle,\n517:   IpcSocketServerOptions,\n518: };\n\n(End of file - total 518 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Canonical bridge logic shared by every daemon launcher (memory,\n// code-index, skill-advisor). Each service supplies its own socket/db\n// PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n// and race-safety contract stays identical across services.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\n// Every live session's launcher holds one persistent slot, and multi-seat\n// fan-outs run well past 8 concurrent sessions. A refused connection is\n// accepted then closed, which probes cannot distinguish from a dead daemon,\n// so the cap must exceed any realistic session fleet.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Canonical bridge logic shared by every daemon launcher (memory,\n// code-index, skill-advisor). Each service supplies its own socket/db\n// PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n// and race-safety contract stays identical across services.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\n// Every live session's launcher holds one persistent slot, and multi-seat\n// fan-outs run well past 8 concurrent sessions. A refused connection is\n// accepted then closed, which probes cannot distinguish from a dead daemon,\n// so the cap must exceed any realistic session fleet.\nconst DEFAULT_MAX_SECONDARY_CLIENTS = 64;\nconst TCP_EADDRINUSE_RETRY_DELAYS_MS = [100, 250, 500, 1000, 1500] as const;\n\ninterface IpcBridgeStats {\n  socket_path: string | null;\n  secondary_clients_count: number;\n  total_secondary_messages_in: number;\n  total_secondary_messages_out: number;\n}\n\n// Structural shape of the only MCP server capability this bridge uses. Typed structurally (a\n// method, so its transport param is bivariant) rather than against a concrete `Server` import so\n// every consuming package satisfies it with its own `@modelcontextprotocol/sdk` copy — the three\n// daemons each install the SDK separately and its private members make the classes nominally\n// distinct, which a concrete import would reject across package boundaries.\ninterface McpServerLike {\n  connect(transport: StdioServerTransport): Promise<void>;\n}\n\ninterface IpcSocketServerOptions {\n  readonly socketPath: string;\n  readonly createServer: () => McpServerLike;\n  readonly maxClients?: number;\n  readonly log?: (message: string) => void;\n  readonly onActivity?: () => void;\n}\n\ninterface IpcSocketServerHandle {\n  readonly socketPath: string;\n  readonly close: () => Promise<void>;\n}\n\nlet activeServer: net.Server | null = null;\nlet activeSocketPath: string | null = null;\nconst activeSockets = new Set<net.Socket>();\nconst activeTransports = new Map<net.Socket, StdioServerTransport>();\nlet totalSecondaryMessagesIn = 0;\nlet totalSecondaryMessagesOut = 0;\n\nfunction countJsonRpcFrames(chunk: unknown): number {\n  const text = Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n  const newlineCount = text.split('\\n').length - 1;\n  return Math.max(1, newlineCount);\n}\n\n// Window for a connection refused at the client cap to identify itself as a\n// liveness probe by sending its first JSON-RPC frame. Kept short so a non-probe\n// (real bridge client) is refused promptly, and bounded so probe traffic cannot\n// accumulate durable resources above the cap.\nconst PROBE_AT_CAP_WINDOW_MS = 1000;\n\n// When at the durable client cap, peek the first frame. A liveness probe sends a\n// JSON-RPC `initialize` with clientInfo.name === 'liveness-probe' and treats ANY\n// reply carrying its id (result OR error) as proof the daemon is alive. Answer it\n// with a matching-id JSON-RPC error and close, without ever adding it to\n// activeSockets — so transient probe bursts can never exhaust the cap that exists\n// for durable bridge sessions. A non-probe first frame is refused like before.\nfunction answerProbeOrRefuseAtCap(\n  socket: net.Socket,\n  maxClients: number,\n  log: (message: string) => void,\n): void {\n  let settled = false;\n  let buffer = '';\n  const finish = (refusedReason: string) => {\n    if (settled) return;\n    settled = true;\n    clearTimeout(timer);\n    log(`[ipc-bridge] refusing secondary connection: max clients ${maxClients} reached${refusedReason}`);\n    socket.end();\n    socket.destroy();\n  };\n  const timer = setTimeout(() => finish(' (no probe frame)'), PROBE_AT_CAP_WINDOW_MS);\n  timer.unref?.();\n  socket.on('error', () => finish(' (socket error)'));\n  socket.on('data', (chunk: Buffer | string) => {\n    if (settled) return;\n    buffer += Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n    let newlineIndex = buffer.indexOf('\\n');\n    while (newlineIndex !== -1) {\n      const line = buffer.slice(0, newlineIndex).trim();\n      buffer = buffer.slice(newlineIndex + 1);\n      newlineIndex = buffer.indexOf('\\n');\n      if (!line) continue;\n      let parsed: unknown;\n      try {\n        parsed = JSON.parse(line);\n      } catch {\n        finish(' (non-json frame at cap)');\n        return;\n      }\n      const frame = parsed as { id?: unknown; method?: unknown; params?: { clientInfo?: { name?: unknown } } };\n      const isProbe = frame\n        && frame.method === 'initialize'\n        && frame.params?.clientInfo?.name === 'liveness-probe';\n      if (isProbe) {\n        settled = true;\n        clearTimeout(timer);\n        const reply = `${JSON.stringify({\n          jsonrpc: '2.0',\n          id: frame.id ?? null,\n          error: { code: -32000, message: 'daemon at client capacity; liveness probe acknowledged' },\n        })}\\n`;\n        socket.end(reply);\n        log('[ipc-bridge] answered liveness probe at client cap without occupying a durable slot');\n        return;\n      }\n      finish(' (non-probe frame at cap)');\n      return;\n    }\n  });\n}\n\nfunction parseMaxClients(rawValue = process.env.SPECKIT_MAX_SECONDARY_CLIENTS): number {\n  if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') {\n    return DEFAULT_MAX_SECONDARY_CLIENTS;\n  }\n  const parsed = Number.parseInt(String(rawValue), 10);\n  if (!Number.isFinite(parsed) || parsed < 1) {\n    return DEFAULT_MAX_SECONDARY_CLIENTS;\n  }\n  return parsed;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n// Canonicalize a path via realpath, even when the leaf does not exist yet. realpath the nearest\n// existing ancestor (so symlinked roots like macOS `/tmp` -> `/private/tmp` normalize) and\n// re-append the missing tail. Without ancestor canonicalization, a socket dir that was cleared\n// (e.g. `/tmp/<service>` after a reboot) stays literal `/tmp/...` and fails the allowed-root\n// check below — which canonicalizes `/tmp` to `/private/tmp` — crashing the server.\n// Fail closed: an existing ancestor that cannot be canonicalized (permission/loop error) must\n// abort rather than return a non-canonical path, which would weaken the allowed-root containment\n// check that downstream binds rely on.\nfunction canonicalizePath(target: string): string {\n  const resolved = path.resolve(target);\n  const tail: string[] = [];\n  let current = resolved;\n  while (!fs.existsSync(current)) {\n    const parent = path.dirname(current);\n    if (parent === current) {\n      return resolved;\n    }\n    tail.unshift(path.basename(current));\n    current = parent;\n  }\n  return path.join(fs.realpathSync.native(current), ...tail);\n}\n\n// Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it.\n// Both inputs MUST already be canonicalized. Inlined here so the shared bridge carries no\n// cross-module dependency for a single containment call.\nfunction isWithinRoot(root: string, candidate: string): boolean {\n  if (candidate === root) {\n    return true;\n  }\n  const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n  return candidate.startsWith(prefix);\n}\n\n// Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n// The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n// `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n// `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n// the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n// `canUnlinkExistingSocket` preserves the unlink-hardening intent.\nfunction allowedSocketRoots(): string[] {\n  const roots = new Set<string>();\n  roots.add(canonicalizePath(process.cwd()));\n  roots.add(canonicalizePath(os.tmpdir()));\n  roots.add(canonicalizePath('/tmp'));\n  return [...roots];\n}\n\nfunction isWithinAllowedSocketRoot(candidate: string): boolean {\n  return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n}\n\nfunction resolveIpcSocketPath(dbDir: string): string {\n  const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(dbDir);\n  const socketDir = canonicalizePath(rawSocketDir);\n  if (!isWithinAllowedSocketRoot(socketDir)) {\n    throw new Error(\n      `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n    );\n  }\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\n// Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n// inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n// Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n// socket they own at the bind path.\nfunction canUnlinkExistingSocket(socketPath: string): boolean {\n  let parent: string;\n  try {\n    parent = fs.realpathSync.native(path.dirname(socketPath));\n  } catch (error: unknown) {\n    // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n    // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n  if (!isWithinAllowedSocketRoot(parent)) {\n    return false;\n  }\n  try {\n    const stat = fs.lstatSync(socketPath);\n    if (!stat.isSocket()) {\n      return false;\n    }\n    if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n    // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n}\n\nfunction getIpcBridgeStats(): IpcBridgeStats {\n  return {\n    socket_path: activeSocketPath,\n    secondary_clients_count: activeSockets.size,\n    total_secondary_messages_in: totalSecondaryMessagesIn,\n    total_secondary_messages_out: totalSecondaryMessagesOut,\n  };\n}\n\nasync function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n  await new Promise<void>((resolve, reject) => {\n    const onError = (error: NodeJS.ErrnoException) => {\n      server.off('listening', onListening);\n      reject(error);\n    };\n    const onListening = () => {\n      server.off('error', onError);\n      resolve();\n    };\n    server.once('error', onError);\n    server.once('listening', onListening);\n    if (socketPath.startsWith('tcp://')) {\n      const url = new URL(socketPath);\n      server.listen(Number.parseInt(url.port, 10), url.hostname);\n      return;\n    }\n    server.listen(socketPath);\n  });\n}\n\n// TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n// unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n// few times before giving up. Returns true once a retry binds, false if the port stays in use.\nasync function retryTcpListenAfterEaddrInUse(\n  server: net.Server,\n  socketPath: string,\n  log: (message: string) => void,\n): Promise<boolean> {\n  for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n    log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n    await sleep(delayMs);\n    try {\n      await listenOnce(server, socketPath);\n      return true;\n    } catch (error: unknown) {\n      const err = error as NodeJS.ErrnoException;\n      if (err.code !== 'EADDRINUSE') {\n        throw err;\n      }\n    }\n  }\n  return false;\n}\n\n// Tear down any server still registered in the module-global slots before a new bind reuses them.\n// startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n// dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n// shared stats. Re-entrancy must close the prior server first.\nasync function disposeActiveServer(): Promise<void> {\n  const priorServer = activeServer;\n  for (const socket of activeSockets) {\n    socket.destroy();\n  }\n  activeSockets.clear();\n  activeTransports.clear();\n  if (priorServer) {\n    await new Promise<void>((resolve) => {\n      priorServer.close(() => resolve());\n    });\n  }\n  activeServer = null;\n  activeSocketPath = null;\n}\n\nasync function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n  if (activeServer) {\n    await disposeActiveServer();\n  }\n  const socketPath = options.socketPath.startsWith('tcp://')\n    ? options.socketPath\n    : path.resolve(options.socketPath);\n  const log = options.log ?? ((message: string) => console.error(message));\n  const maxClients = options.maxClients ?? parseMaxClients();\n  const onActivity = options.onActivity ?? (() => undefined);\n  if (!socketPath.startsWith('tcp://')) {\n    const socketDir = path.dirname(socketPath);\n    fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n    // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n    // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n    // so refuse to bind under a dir not owned by us or that is group/world-writable.\n    try {\n      const st = fs.statSync(socketDir);\n      const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n      if (uid !== null && st.uid !== uid) {\n        throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n      }\n      if ((st.mode & 0o022) !== 0) {\n        throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n    // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n    // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n    // protection so a symlink whose target we would later chmod cannot be used to redirect the\n    // permission change onto an arbitrary file.\n    try {\n      const linkStat = fs.lstatSync(socketPath);\n      if (linkStat.isSymbolicLink()) {\n        throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n  }\n\n  const server = net.createServer((socket) => {\n    if (activeSockets.size >= maxClients) {\n      // A bare close here is indistinguishable from a dead daemon to a liveness\n      // probe, which makes a sibling launcher reap a healthy-but-cap-saturated\n      // daemon. Give the connection a brief window to send its first frame: if it\n      // is a liveness probe, answer it (proving the daemon alive) and close WITHOUT\n      // occupying a durable slot; only refuse genuine bridge clients at the cap.\n      answerProbeOrRefuseAtCap(socket, maxClients, log);\n      return;\n    }\n\n    activeSockets.add(socket);\n    onActivity();\n    log('[ipc-bridge] secondary connected pid=?');\n\n    const originalWrite = socket.write.bind(socket);\n    socket.write = ((chunk: unknown, ...args: unknown[]) => {\n      onActivity();\n      totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n      return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n    }) as typeof socket.write;\n\n    socket.on('data', (chunk) => {\n      onActivity();\n      totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n    });\n\n    const transport = new StdioServerTransport(socket, socket);\n    activeTransports.set(socket, transport);\n    const secondaryServer = options.createServer();\n    secondaryServer.connect(transport).catch((error: unknown) => {\n      const message = error instanceof Error ? error.message : String(error);\n      log(`[ipc-bridge] secondary connect error: ${message}`);\n      socket.destroy();\n    });\n\n    socket.once('close', () => {\n      activeSockets.delete(socket);\n      activeTransports.delete(socket);\n      void transport.close();\n      log('[ipc-bridge] disconnect');\n    });\n    socket.once('error', (error) => {\n      log(`[ipc-bridge] socket error: ${error.message}`);\n    });\n  });\n\n  try {\n    await listenOnce(server, socketPath);\n  } catch (error: unknown) {\n    const err = error as NodeJS.ErrnoException;\n    if (err.code !== 'EADDRINUSE') {\n      throw err;\n    }\n    if (socketPath.startsWith('tcp://')) {\n      // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n      // never frees, run without the secondary bridge rather than aborting the whole daemon.\n      const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n      if (!listened) {\n        log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n        return {\n          socketPath,\n          close: async () => {\n            for (const socket of activeSockets) {\n              socket.destroy();\n            }\n            activeSockets.clear();\n            activeTransports.clear();\n          },\n        };\n      }\n    } else {\n      // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n      // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n      // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n      if (!canUnlinkExistingSocket(socketPath)) {\n        throw err;\n      }\n      try {\n        fs.unlinkSync(socketPath);\n      } catch (unlinkError: unknown) {\n        const unlinkErr = unlinkError as NodeJS.ErrnoException;\n        if (unlinkErr.code !== 'ENOENT') {\n          throw unlinkErr;\n        }\n      }\n      await listenOnce(server, socketPath);\n    }\n  }\n\n  const address = server.address();\n  const listenedPath = typeof address === 'object' && address\n    ? `tcp://${address.address}:${address.port}`\n    : socketPath;\n  if (!socketPath.startsWith('tcp://')) {\n    // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n    // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n    const boundStat = fs.lstatSync(socketPath);\n    if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n      throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n    }\n    fs.chmodSync(socketPath, 0o600);\n  }\n  activeServer = server;\n  activeSocketPath = listenedPath;\n  log(`[ipc-bridge] socket listening at ${listenedPath}`);\n\n  return {\n    socketPath: listenedPath,\n    close: async () => {\n      for (const socket of activeSockets) {\n        socket.destroy();\n      }\n      activeSockets.clear();\n      activeTransports.clear();\n      await new Promise<void>((resolve) => {\n        server.close(() => resolve());\n      });\n      if (activeServer === server) {\n        activeServer = null;\n        activeSocketPath = null;\n      }\n      if (!socketPath.startsWith('tcp://')) {\n        try {\n          fs.unlinkSync(socketPath);\n        } catch (error: unknown) {\n          const err = error as NodeJS.ErrnoException;\n          if (err.code !== 'ENOENT') {\n            throw err;\n          }\n        }\n      }\n    },\n  };\n}\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n};\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,\n  IpcSocketServerOptions,\n};","lineStart":1,"lineEnd":518,"totalLines":518,"truncated":false}},"title":".opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","time":{"start":1781764128663,"end":1781764128677}},"metadata":{"openai":{"itemId":"fc_0fd6864107e7bcf6016a33901fe7bc819187dc3b23b5826c55"}},"id":"prt_ed96afcbb001AsFVKmRGH9mt97","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed96ae3ac001dUfG238I05hxR0"}}
{"type":"step_finish","timestamp":1781764129062,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"id":"prt_ed96b0124001F4IhZVL51Qn74H","reason":"tool-calls","snapshot":"0cbb3f453def76ed51880b6d15995f8b048af6c1","messageID":"msg_ed96ae3ac001dUfG238I05hxR0","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","type":"step-finish","tokens":{"total":138192,"input":829,"output":58,"reasoning":89,"cache":{"write":0,"read":137216}},"cost":0}}
{"type":"step_start","timestamp":1781764145554,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"id":"prt_ed96b4191001RtBcv8J0zWm5ed","messageID":"msg_ed96b0229001C2JMcV17MZjIyn","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","snapshot":"0cbb3f453def76ed51880b6d15995f8b048af6c1","type":"step-start"}}
{"type":"tool_use","timestamp":1781764152646,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_nnsm1wIhQmmWyi1ozxYqPgoD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1840,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1840:       if (cold.admitted > 0) {\n1841:         console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n1842:       }\n1843:     } catch (_: unknown) { /* best-effort */ }\n1844: \n1845:   try {\n1846:     const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n1847:     vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n1848:     console.error(\n1849:       `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n1850:     );\n1851:   } catch (error: unknown) {\n1852:     const message = error instanceof Error ? error.message : String(error);\n1853:     console.error(`[context-server] FATAL: ${message}`);\n1854:     // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n1855:     // structured error while the shared daemon stays alive. The init guard resets and retries\n1856:     // on the next memory-runtime call, so a transient embedder failure self-heals.\n1857:     throw new Error(`memory runtime init failed (embedder): ${message}`);\n1858:   }\n1859: \n1860:   // Pre-Flight API Key Validation\n1861:   // Validates API key at startup to fail fast with actionable error messages\n1862:   // Skip validation if SPECKIT_SKIP_API_VALIDATION=true (for testing/CI)\n1863:   let startupEmbeddingConfig: Awaited<ReturnType<typeof resolveStartupEmbeddingConfig>> | null = null;\n1864:   if (process.env.SPECKIT_SKIP_API_VALIDATION !== 'true') {\n1865:     console.error('[context-server] Validating embedding API key...');\n1866:     try {\n1867:       startupEmbeddingConfig = await resolveStartupEmbeddingConfig({ timeout: API_KEY_VALIDATION_TIMEOUT_MS });\n1868:       const validation: ApiKeyValidation = startupEmbeddingConfig.validation;\n1869: \n1870:       if (!validation.valid) {\n1871:         if (validation.networkError) {\n1872:           // Transient network failure — warn and continue, validation will occur on first use\n1873:           console.warn('[context-server] ===== API KEY VALIDATION SKIPPED (network error) =====');\n1874:           console.warn(`[context-server] Provider: ${validation.provider}`);\n1875:           console.warn(`[context-server] Error: ${validation.error}`);\n1876:           if (validation.actions) {\n1877:             console.warn('[context-server] Recovery Actions:');\n1878:             validation.actions.forEach((action: string, i: number) => {\n1879:               console.warn(`[context-server]   ${i + 1}. ${action}`);\n1880:             });\n1881:           }\n1882:           console.warn('[context-server] Continuing startup — validation will occur on first use');\n1883:         } else {\n1884:           console.error('[context-server] ===== API KEY VALIDATION FAILED =====');\n1885:           console.error(`[context-server] Provider: ${validation.provider}`);\n1886:           console.error(`[context-server] Error: ${validation.error}`);\n1887:           console.error(`[context-server] Error Code: ${validation.errorCode || 'E050'}`);\n1888:           if (validation.actions) {\n1889:             console.error('[context-server] Recovery Actions:');\n1890:             validation.actions.forEach((action: string, i: number) => {\n1891:               console.error(`[context-server]   ${i + 1}. ${action}`);\n1892:             });\n1893:           }\n1894:           console.error('[context-server] =====================================');\n1895:           console.error('[context-server] FATAL: Cannot start MCP server with invalid API key');\n1896:           console.error('[context-server] Set SPECKIT_SKIP_API_VALIDATION=true to bypass (not recommended)');\n1897:           // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n1898:           // the enclosing transient-error catch RE-THROWS it (rather than swallowing it into the\n1899:           // \"continue\" path), letting the init guard surface it as a structured tool error + retry.\n1900:           throw Object.assign(\n1901:             new Error(`embedding API key validation failed: ${validation.error ?? validation.errorCode ?? 'invalid key'}`),\n1902:             { speckitInitHardFail: true },\n1903:           );\n1904:         }\n1905:       }\n1906: \n1907:       if (validation.warning) {\n1908:         console.warn(`[context-server] API key warning: ${validation.warning}`);\n1909:       }\n1910: \n1911:       if (validation.valid) {\n1912:         console.error(`[context-server] API key validated (provider: ${validation.provider})`);\n1913:       }\n1914:     } catch (validationError: unknown) {\n1915:       // A tagged hard-fail (invalid API key) must propagate to the init guard so the daemon does\n1916:       // not silently start with a known-bad key; only genuine transient validation errors fall\n1917:       // through to \"continue, validate on first use\".\n1918:       if (validationError && typeof validationError === 'object'\n1919:           && (validationError as { speckitInitHardFail?: boolean }).speckitInitHardFail) {\n1920:         throw validationError;\n1921:       }\n1922:       const message = validationError instanceof Error ? validationError.message : String(validationError);\n1923:       console.error(`[context-server] API key validation error: ${message}`);\n1924:       console.error('[context-server] Continuing startup - validation will occur on first use');\n1925:     }\n1926:   } else {\n1927:     console.warn('[context-server] API key validation skipped (SPECKIT_SKIP_API_VALIDATION=true)');\n1928:   }\n1929: \n1930:   if (!process.env.EMBEDDING_DIM) {\n1931:     process.env.EMBEDDING_DIM = String(\n1932:       startupEmbeddingConfig?.dimension ?? getStartupEmbeddingDimension(),\n1933:     );\n1934:   }\n1935: \n1936:   // Initialize db-state module with dependencies\n1937:   // P4-12/P4-19 FIX: Pass sessionManager and incrementalIndex so db-state can\n1938:   // Refresh their DB handles during reinitializeDatabase(), preventing stale refs.\n1939:   initDbState({\n1940:     vectorIndex,\n1941:     checkpoints: checkpointsLib,\n1942:     accessTracker,\n1943:     hybridSearch,\n1944:     sessionManager,\n1945:     incrementalIndex,\n1946:     dbConsumers: [\n1947:       sessionBoost,\n1948:       causalBoost,\n1949:       historyStore,\n1950:       workingMemory,\n1951:       attentionDecay,\n1952:       coActivation,\n1953:     ],\n1954:   });\n1955: \n1956:   console.error('[context-server] Lazy loading enabled - embedding model will initialize on first use');\n1957:   console.error('[context-server] SPECKIT_EAGER_WARMUP and SPECKIT_LAZY_LOADING are deprecated compatibility flags');\n1958: \n1959:   // Integrity check and module initialization\n1960:   try {\n1961:     const report = vectorIndex.verifyIntegrity();\n1962:     console.error(`[context-server] Integrity check: ${report.totalMemories}/${report.totalMemories + report.missingVectors} valid entries`);\n1963:     if (report.orphanedVectors > 0) console.error(`[context-server] WARNING: ${report.orphanedVectors} orphaned entries detected`);\n1964: \n1965:     // Validate embedding dimension matches database\n1966:     const dimValidation = vectorIndex.validateEmbeddingDimension();\n1967:     if (!dimValidation.valid) {\n1968:       console.error(`[context-server] ===== EMBEDDING DIMENSION MISMATCH =====`);\n1969:       console.error(`[context-server] ${dimValidation.warning}`);\n1970:       console.error(`[context-server] =========================================`);\n1971:       console.error('[context-server] FATAL: Refusing to start with mismatched embedding dimensions');\n1972:       throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n1973:     } else if (dimValidation.stored) {\n1974:       console.error(`[context-server] Embedding dimension validated: ${dimValidation.stored}`);\n1975:     }\n1976: \n1977:     const database = vectorIndex.getDb();\n1978:     if (!database) {\n1979:       throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n1980:     }\n1981: \n1982:     try {\n1983:       initScoringObservability(database);\n1984:       console.error('[context-server] Scoring observability initialized');\n1985:     } catch (scoringObsErr: unknown) {\n1986:       const message = scoringObsErr instanceof Error ? scoringObsErr.message : String(scoringObsErr);\n1987:       console.warn('[context-server] Scoring observability init failed (non-fatal):', message);\n1988:     }\n1989: \n1990:     const installGraphRefresh = (refreshDb: Database.Database): void => {\n1991:       registerGlobalRefreshFn(() => {\n1992:         const dirtyNodeIds = Array.from(getDirtyNodes().nodeIds);\n1993:         if (dirtyNodeIds.length === 0) {\n1994:           return;\n1995:         }\n1996: \n1997:         const updatedEdges = recomputeLocal(refreshDb, dirtyNodeIds);\n1998:         clearDirtyNodes();\n1999:         console.error(\n2000:           '[context-server] Scheduled graph refresh applied: dirty_nodes=%d, updated_edges=%d',\n2001:           dirtyNodeIds.length,\n2002:           updatedEdges,\n2003:         );\n2004:       });\n2005:     };\n2006: \n2007:     registerDatabaseRebindListener((nextDatabase) => {\n2008:       const reboundDatabase = nextDatabase as Database.Database;\n2009:       rebindScoringObservability(reboundDatabase);\n2010:       rebindExtractionAdapter(reboundDatabase);\n2011: \n2012:       cancelScheduledRefresh();\n2013:       installGraphRefresh(reboundDatabase);\n2014:       if (getDirtyNodes().nodeIds.size > 0) {\n2015:         scheduleGlobalRefresh();\n2016:       }\n2017: \n2018:       shadowEvaluationRuntime.stopShadowEvaluationScheduler();\n2019:       shadowEvaluationRuntime.startShadowEvaluationScheduler(reboundDatabase);\n2020:     });\n2021: \n2022:     if (isLearnedFeedbackEnabled()) {\n2023:       try {\n2024:         const migrated = migrateLearnedTriggers(database);\n2025:         const isolated = verifyFts5Isolation(database);\n2026:         console.error(`[context-server] Learned triggers ready (migrated=${migrated}, fts5Isolated=${isolated})`);\n2027:       } catch (learnedErr: unknown) {\n2028:         const message = learnedErr instanceof Error ? learnedErr.message : String(learnedErr);\n2029:         throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n2030:       }\n2031:     }\n2032: \n2033:     // Check SQLite version meets minimum requirement (3.35.0+)\n2034:     checkSqliteVersion(database);\n2035: \n2036:     // Verify WAL mode is active for operational concurrency guarantees.\n2037:     const walRow = database.prepare('PRAGMA journal_mode').get() as { journal_mode?: string } | undefined;\n2038:     const journalMode = String(walRow?.journal_mode ?? '').toLowerCase();\n2039:     if (journalMode !== 'wal') {\n2040:       database.pragma('journal_mode = WAL');\n2041:       console.warn('[context-server] journal_mode was not WAL; forcing WAL mode');\n2042:     }\n2043: \n2044:     const memoryCountRow = database.prepare('SELECT COUNT(*) as cnt FROM memory_index').get() as { cnt?: number } | undefined;\n2045:     const memoryCount = Number(memoryCountRow?.cnt ?? 0);\n2046:     let projectionCount = 0;\n2047:     let projectionTableExists = true;\n2048: \n2049:     try {\n2050:       const projectionCountRow = database.prepare('SELECT COUNT(*) as cnt FROM active_memory_projection').get() as { cnt?: number } | undefined;\n2051:       projectionCount = Number(projectionCountRow?.cnt ?? 0);\n2052:     } catch {\n2053:       projectionTableExists = false;\n2054:     }\n2055: \n2056:     console.error('[context-server] Startup health: memory_index=%d, active_memory_projection=%d', memoryCount, projectionCount);\n2057: \n2058:     if (memoryCount > 0 && (!projectionTableExists || projectionCount === 0)) {\n2059:       const result = runLineageBackfill(database);\n2060:       console.error('[context-server] Auto-backfill triggered: %d rows seeded into active_memory_projection', result.seeded);\n2061:     }\n2062: \n2063:     if (memoryCount === 0 && projectionCount === 0) {\n2064:       console.error('[context-server] WARNING: Database has 0 memories — search will return no results until memories are saved');\n2065:     }\n2066: \n2067:     const graphSearchFn = isGraphUnifiedEnabled()\n2068:       ? createUnifiedGraphSearchFn(database)\n2069:       : null;\n2070: \n2071:     checkpointsLib.init(database);\n2072:     accessTracker.init(database);\n2073:     hybridSearch.init(database, vectorIndex.vectorSearch, graphSearchFn);\n2074: \n2075:     // Keep db-state reinitialization wiring aligned with startup search wiring.\n2076:     initDbState({ graphSearchFn });\n2077:     sessionBoost.init(database);\n2078:     causalBoost.init(database);\n2079:     installGraphRefresh(database);\n2080:     console.error('[context-server] Checkpoints, access tracker, hybrid search, session boost, and causal boost initialized');\n2081:     runCheckpointNeedsRebuildRepair(database, 'boot');\n2082: \n2083:     // P3-04/014: Warm in-memory BM25 only when the selected lexical engine needs it.\n2084:     if (bm25Index.shouldWarmInMemoryBm25(database)) {\n2085:       try {\n2086:         const bm25 = bm25Index.getIndex();\n2087:         const count = bm25.rebuildFromDatabase(database);\n2088:         console.error(`[context-server] BM25 index rebuilt from database: ${count} documents`);\n2089:       } catch (bm25Err: unknown) {\n2090:         const message = bm25Err instanceof Error ? bm25Err.message : String(bm25Err);\n2091:         console.warn('[context-server] BM25 index rebuild failed:', message);\n2092:       }\n2093:     }\n2094: \n2095:     // Cognitive memory modules\n2096:     try {\n2097:       workingMemory.init(database);\n2098:       attentionDecay.init(database);\n2099:       coActivation.init(database);\n\n(Showing lines 1840-2099 of 2341. Use offset=2100 to continue.)\n</content>","metadata":{"preview":"      if (cold.admitted > 0) {\n        console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n      }\n    } catch (_: unknown) { /* best-effort */ }\n\n  try {\n    const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n    vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n    console.error(\n      `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n    );\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] FATAL: ${message}`);\n    // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n    // structured error while the shared daemon stays alive. The init guard resets and retries\n    // on the next memory-runtime call, so a transient embedder failure self-heals.\n    throw new Error(`memory runtime init failed (embedder): ${message}`);\n  }\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"      if (cold.admitted > 0) {\n        console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n      }\n    } catch (_: unknown) { /* best-effort */ }\n\n  try {\n    const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n    vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n    console.error(\n      `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n    );\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] FATAL: ${message}`);\n    // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n    // structured error while the shared daemon stays alive. The init guard resets and retries\n    // on the next memory-runtime call, so a transient embedder failure self-heals.\n    throw new Error(`memory runtime init failed (embedder): ${message}`);\n  }\n\n  // Pre-Flight API Key Validation\n  // Validates API key at startup to fail fast with actionable error messages\n  // Skip validation if SPECKIT_SKIP_API_VALIDATION=true (for testing/CI)\n  let startupEmbeddingConfig: Awaited<ReturnType<typeof resolveStartupEmbeddingConfig>> | null = null;\n  if (process.env.SPECKIT_SKIP_API_VALIDATION !== 'true') {\n    console.error('[context-server] Validating embedding API key...');\n    try {\n      startupEmbeddingConfig = await resolveStartupEmbeddingConfig({ timeout: API_KEY_VALIDATION_TIMEOUT_MS });\n      const validation: ApiKeyValidation = startupEmbeddingConfig.validation;\n\n      if (!validation.valid) {\n        if (validation.networkError) {\n          // Transient network failure — warn and continue, validation will occur on first use\n          console.warn('[context-server] ===== API KEY VALIDATION SKIPPED (network error) =====');\n          console.warn(`[context-server] Provider: ${validation.provider}`);\n          console.warn(`[context-server] Error: ${validation.error}`);\n          if (validation.actions) {\n            console.warn('[context-server] Recovery Actions:');\n            validation.actions.forEach((action: string, i: number) => {\n              console.warn(`[context-server]   ${i + 1}. ${action}`);\n            });\n          }\n          console.warn('[context-server] Continuing startup — validation will occur on first use');\n        } else {\n          console.error('[context-server] ===== API KEY VALIDATION FAILED =====');\n          console.error(`[context-server] Provider: ${validation.provider}`);\n          console.error(`[context-server] Error: ${validation.error}`);\n          console.error(`[context-server] Error Code: ${validation.errorCode || 'E050'}`);\n          if (validation.actions) {\n            console.error('[context-server] Recovery Actions:');\n            validation.actions.forEach((action: string, i: number) => {\n              console.error(`[context-server]   ${i + 1}. ${action}`);\n            });\n          }\n          console.error('[context-server] =====================================');\n          console.error('[context-server] FATAL: Cannot start MCP server with invalid API key');\n          console.error('[context-server] Set SPECKIT_SKIP_API_VALIDATION=true to bypass (not recommended)');\n          // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n          // the enclosing transient-error catch RE-THROWS it (rather than swallowing it into the\n          // \"continue\" path), letting the init guard surface it as a structured tool error + retry.\n          throw Object.assign(\n            new Error(`embedding API key validation failed: ${validation.error ?? validation.errorCode ?? 'invalid key'}`),\n            { speckitInitHardFail: true },\n          );\n        }\n      }\n\n      if (validation.warning) {\n        console.warn(`[context-server] API key warning: ${validation.warning}`);\n      }\n\n      if (validation.valid) {\n        console.error(`[context-server] API key validated (provider: ${validation.provider})`);\n      }\n    } catch (validationError: unknown) {\n      // A tagged hard-fail (invalid API key) must propagate to the init guard so the daemon does\n      // not silently start with a known-bad key; only genuine transient validation errors fall\n      // through to \"continue, validate on first use\".\n      if (validationError && typeof validationError === 'object'\n          && (validationError as { speckitInitHardFail?: boolean }).speckitInitHardFail) {\n        throw validationError;\n      }\n      const message = validationError instanceof Error ? validationError.message : String(validationError);\n      console.error(`[context-server] API key validation error: ${message}`);\n      console.error('[context-server] Continuing startup - validation will occur on first use');\n    }\n  } else {\n    console.warn('[context-server] API key validation skipped (SPECKIT_SKIP_API_VALIDATION=true)');\n  }\n\n  if (!process.env.EMBEDDING_DIM) {\n    process.env.EMBEDDING_DIM = String(\n      startupEmbeddingConfig?.dimension ?? getStartupEmbeddingDimension(),\n    );\n  }\n\n  // Initialize db-state module with dependencies\n  // P4-12/P4-19 FIX: Pass sessionManager and incrementalIndex so db-state can\n  // Refresh their DB handles during reinitializeDatabase(), preventing stale refs.\n  initDbState({\n    vectorIndex,\n    checkpoints: checkpointsLib,\n    accessTracker,\n    hybridSearch,\n    sessionManager,\n    incrementalIndex,\n    dbConsumers: [\n      sessionBoost,\n      causalBoost,\n      historyStore,\n      workingMemory,\n      attentionDecay,\n      coActivation,\n    ],\n  });\n\n  console.error('[context-server] Lazy loading enabled - embedding model will initialize on first use');\n  console.error('[context-server] SPECKIT_EAGER_WARMUP and SPECKIT_LAZY_LOADING are deprecated compatibility flags');\n\n  // Integrity check and module initialization\n  try {\n    const report = vectorIndex.verifyIntegrity();\n    console.error(`[context-server] Integrity check: ${report.totalMemories}/${report.totalMemories + report.missingVectors} valid entries`);\n    if (report.orphanedVectors > 0) console.error(`[context-server] WARNING: ${report.orphanedVectors} orphaned entries detected`);\n\n    // Validate embedding dimension matches database\n    const dimValidation = vectorIndex.validateEmbeddingDimension();\n    if (!dimValidation.valid) {\n      console.error(`[context-server] ===== EMBEDDING DIMENSION MISMATCH =====`);\n      console.error(`[context-server] ${dimValidation.warning}`);\n      console.error(`[context-server] =========================================`);\n      console.error('[context-server] FATAL: Refusing to start with mismatched embedding dimensions');\n      throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n    } else if (dimValidation.stored) {\n      console.error(`[context-server] Embedding dimension validated: ${dimValidation.stored}`);\n    }\n\n    const database = vectorIndex.getDb();\n    if (!database) {\n      throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n    }\n\n    try {\n      initScoringObservability(database);\n      console.error('[context-server] Scoring observability initialized');\n    } catch (scoringObsErr: unknown) {\n      const message = scoringObsErr instanceof Error ? scoringObsErr.message : String(scoringObsErr);\n      console.warn('[context-server] Scoring observability init failed (non-fatal):', message);\n    }\n\n    const installGraphRefresh = (refreshDb: Database.Database): void => {\n      registerGlobalRefreshFn(() => {\n        const dirtyNodeIds = Array.from(getDirtyNodes().nodeIds);\n        if (dirtyNodeIds.length === 0) {\n          return;\n        }\n\n        const updatedEdges = recomputeLocal(refreshDb, dirtyNodeIds);\n        clearDirtyNodes();\n        console.error(\n          '[context-server] Scheduled graph refresh applied: dirty_nodes=%d, updated_edges=%d',\n          dirtyNodeIds.length,\n          updatedEdges,\n        );\n      });\n    };\n\n    registerDatabaseRebindListener((nextDatabase) => {\n      const reboundDatabase = nextDatabase as Database.Database;\n      rebindScoringObservability(reboundDatabase);\n      rebindExtractionAdapter(reboundDatabase);\n\n      cancelScheduledRefresh();\n      installGraphRefresh(reboundDatabase);\n      if (getDirtyNodes().nodeIds.size > 0) {\n        scheduleGlobalRefresh();\n      }\n\n      shadowEvaluationRuntime.stopShadowEvaluationScheduler();\n      shadowEvaluationRuntime.startShadowEvaluationScheduler(reboundDatabase);\n    });\n\n    if (isLearnedFeedbackEnabled()) {\n      try {\n        const migrated = migrateLearnedTriggers(database);\n        const isolated = verifyFts5Isolation(database);\n        console.error(`[context-server] Learned triggers ready (migrated=${migrated}, fts5Isolated=${isolated})`);\n      } catch (learnedErr: unknown) {\n        const message = learnedErr instanceof Error ? learnedErr.message : String(learnedErr);\n        throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n      }\n    }\n\n    // Check SQLite version meets minimum requirement (3.35.0+)\n    checkSqliteVersion(database);\n\n    // Verify WAL mode is active for operational concurrency guarantees.\n    const walRow = database.prepare('PRAGMA journal_mode').get() as { journal_mode?: string } | undefined;\n    const journalMode = String(walRow?.journal_mode ?? '').toLowerCase();\n    if (journalMode !== 'wal') {\n      database.pragma('journal_mode = WAL');\n      console.warn('[context-server] journal_mode was not WAL; forcing WAL mode');\n    }\n\n    const memoryCountRow = database.prepare('SELECT COUNT(*) as cnt FROM memory_index').get() as { cnt?: number } | undefined;\n    const memoryCount = Number(memoryCountRow?.cnt ?? 0);\n    let projectionCount = 0;\n    let projectionTableExists = true;\n\n    try {\n      const projectionCountRow = database.prepare('SELECT COUNT(*) as cnt FROM active_memory_projection').get() as { cnt?: number } | undefined;\n      projectionCount = Number(projectionCountRow?.cnt ?? 0);\n    } catch {\n      projectionTableExists = false;\n    }\n\n    console.error('[context-server] Startup health: memory_index=%d, active_memory_projection=%d', memoryCount, projectionCount);\n\n    if (memoryCount > 0 && (!projectionTableExists || projectionCount === 0)) {\n      const result = runLineageBackfill(database);\n      console.error('[context-server] Auto-backfill triggered: %d rows seeded into active_memory_projection', result.seeded);\n    }\n\n    if (memoryCount === 0 && projectionCount === 0) {\n      console.error('[context-server] WARNING: Database has 0 memories — search will return no results until memories are saved');\n    }\n\n    const graphSearchFn = isGraphUnifiedEnabled()\n      ? createUnifiedGraphSearchFn(database)\n      : null;\n\n    checkpointsLib.init(database);\n    accessTracker.init(database);\n    hybridSearch.init(database, vectorIndex.vectorSearch, graphSearchFn);\n\n    // Keep db-state reinitialization wiring aligned with startup search wiring.\n    initDbState({ graphSearchFn });\n    sessionBoost.init(database);\n    causalBoost.init(database);\n    installGraphRefresh(database);\n    console.error('[context-server] Checkpoints, access tracker, hybrid search, session boost, and causal boost initialized');\n    runCheckpointNeedsRebuildRepair(database, 'boot');\n\n    // P3-04/014: Warm in-memory BM25 only when the selected lexical engine needs it.\n    if (bm25Index.shouldWarmInMemoryBm25(database)) {\n      try {\n        const bm25 = bm25Index.getIndex();\n        const count = bm25.rebuildFromDatabase(database);\n        console.error(`[context-server] BM25 index rebuilt from database: ${count} documents`);\n      } catch (bm25Err: unknown) {\n        const message = bm25Err instanceof Error ? bm25Err.message : String(bm25Err);\n        console.warn('[context-server] BM25 index rebuild failed:', message);\n      }\n    }\n\n    // Cognitive memory modules\n    try {\n      workingMemory.init(database);\n      attentionDecay.init(database);\n      coActivation.init(database);","lineStart":1840,"lineEnd":2099,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781764152629,"end":1781764152644}},"metadata":{"openai":{"itemId":"fc_0b59d6370c9822fa016a339038440c819186848b47b8562e55"}},"id":"prt_ed96b5be6001dbYMZtTjfmJ1QG","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed96b0229001C2JMcV17MZjIyn"}}
