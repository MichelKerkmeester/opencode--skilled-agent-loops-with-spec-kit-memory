{"type":"tool_use","timestamp":1781762733410,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_EFcuz1Zqv5BhNX3LrRPyccZ9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/session-learning.ts","offset":180,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/session-learning.ts</path>\n<type>file</type>\n<content>\n180:   'knowledge_gaps',\n181:   'post_knowledge_score',\n182:   'post_uncertainty_score',\n183:   'post_context_score',\n184:   'delta_knowledge',\n185:   'delta_uncertainty',\n186:   'delta_context',\n187:   'learning_index',\n188:   'gaps_closed',\n189:   'new_gaps_discovered',\n190:   'created_at',\n191:   'updated_at',\n192:   'completed_at',\n193: ].join(', ');\n194: \n195: // Track schema init per database instance, not as a process-global boolean.\n196: // If the server swaps to a fresh DB connection, the old global would skip init.\n197: const schemaInitializedDbs = new WeakSet<Database>();\n198: \n199: function normalizeSessionId(value: string | null | undefined): string | null {\n200:   if (typeof value !== 'string') {\n201:     return null;\n202:   }\n203:   const trimmed = value.trim();\n204:   return trimmed.length > 0 ? trimmed : null;\n205: }\n206: \n207: function hasLegacyUniqueConstraint(database: Database): boolean {\n208:   const row = database.prepare(`\n209:     SELECT sql\n210:     FROM sqlite_master\n211:     WHERE type = 'table' AND name = 'session_learning'\n212:   `).get() as { sql?: string | null } | undefined;\n213: \n214:   return typeof row?.sql === 'string' && row.sql.includes('UNIQUE(spec_folder, task_id)');\n215: }\n216: \n217: function migrateLegacySchema(database: Database): void {\n218:   const tempTableName = 'session_learning_legacy_migration';\n219: \n220:   try {\n221:     database.exec('BEGIN IMMEDIATE');\n222:     database.exec(`ALTER TABLE session_learning RENAME TO ${tempTableName}`);\n223:     database.exec(SCHEMA_SQL);\n224:     database.exec(`\n225:       INSERT INTO session_learning (${SESSION_LEARNING_COLUMNS})\n226:       SELECT ${SESSION_LEARNING_COLUMNS}\n227:       FROM ${tempTableName}\n228:       ORDER BY id ASC\n229:     `);\n230:     database.exec(`DROP TABLE ${tempTableName}`);\n231:     database.exec('COMMIT');\n232:   } catch (err: unknown) {\n233:     try {\n234:       database.exec('ROLLBACK');\n235:     } catch {\n236:       // Best-effort rollback only.\n237:     }\n238:     const message = toErrorMessage(err);\n239:     throw new MemoryError(\n240:       ErrorCodes.DATABASE_ERROR,\n241:       'Failed to migrate session_learning schema',\n242:       { originalError: message }\n243:     );\n244:   }\n245: }\n246: \n247: /** Initialize the session_learning table schema if not already created */\n248: function ensureSchema(database: Database): void {\n249:   if (schemaInitializedDbs.has(database)) return;\n250: \n251:   try {\n252:     database.exec(SCHEMA_SQL);\n253:     if (hasLegacyUniqueConstraint(database)) {\n254:       migrateLegacySchema(database);\n255:     }\n256:     database.exec(INDEX_SQL);\n257:     database.exec(TASK_LOOKUP_INDEX_SQL);\n258:     schemaInitializedDbs.add(database);\n259:     console.error('[session-learning] Schema initialized');\n260:   } catch (err: unknown) {\n261:     const message = toErrorMessage(err);\n262:     console.error('[session-learning] Schema initialization failed:', message);\n263:     throw new MemoryError(\n264:       ErrorCodes.DATABASE_ERROR,\n265:       'Failed to initialize session_learning schema',\n266:       { originalError: message }\n267:     );\n268:   }\n269: }\n\n(Showing lines 180-269 of 886. Use offset=270 to continue.)\n</content>","metadata":{"preview":"  'knowledge_gaps',\n  'post_knowledge_score',\n  'post_uncertainty_score',\n  'post_context_score',\n  'delta_knowledge',\n  'delta_uncertainty',\n  'delta_context',\n  'learning_index',\n  'gaps_closed',\n  'new_gaps_discovered',\n  'created_at',\n  'updated_at',\n  'completed_at',\n].join(', ');\n\n// Track schema init per database instance, not as a process-global boolean.\n// If the server swaps to a fresh DB connection, the old global would skip init.\nconst schemaInitializedDbs = new WeakSet<Database>();\n\nfunction normalizeSessionId(value: string | null | undefined): string | null {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/session-learning.ts","text":"  'knowledge_gaps',\n  'post_knowledge_score',\n  'post_uncertainty_score',\n  'post_context_score',\n  'delta_knowledge',\n  'delta_uncertainty',\n  'delta_context',\n  'learning_index',\n  'gaps_closed',\n  'new_gaps_discovered',\n  'created_at',\n  'updated_at',\n  'completed_at',\n].join(', ');\n\n// Track schema init per database instance, not as a process-global boolean.\n// If the server swaps to a fresh DB connection, the old global would skip init.\nconst schemaInitializedDbs = new WeakSet<Database>();\n\nfunction normalizeSessionId(value: string | null | undefined): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction hasLegacyUniqueConstraint(database: Database): boolean {\n  const row = database.prepare(`\n    SELECT sql\n    FROM sqlite_master\n    WHERE type = 'table' AND name = 'session_learning'\n  `).get() as { sql?: string | null } | undefined;\n\n  return typeof row?.sql === 'string' && row.sql.includes('UNIQUE(spec_folder, task_id)');\n}\n\nfunction migrateLegacySchema(database: Database): void {\n  const tempTableName = 'session_learning_legacy_migration';\n\n  try {\n    database.exec('BEGIN IMMEDIATE');\n    database.exec(`ALTER TABLE session_learning RENAME TO ${tempTableName}`);\n    database.exec(SCHEMA_SQL);\n    database.exec(`\n      INSERT INTO session_learning (${SESSION_LEARNING_COLUMNS})\n      SELECT ${SESSION_LEARNING_COLUMNS}\n      FROM ${tempTableName}\n      ORDER BY id ASC\n    `);\n    database.exec(`DROP TABLE ${tempTableName}`);\n    database.exec('COMMIT');\n  } catch (err: unknown) {\n    try {\n      database.exec('ROLLBACK');\n    } catch {\n      // Best-effort rollback only.\n    }\n    const message = toErrorMessage(err);\n    throw new MemoryError(\n      ErrorCodes.DATABASE_ERROR,\n      'Failed to migrate session_learning schema',\n      { originalError: message }\n    );\n  }\n}\n\n/** Initialize the session_learning table schema if not already created */\nfunction ensureSchema(database: Database): void {\n  if (schemaInitializedDbs.has(database)) return;\n\n  try {\n    database.exec(SCHEMA_SQL);\n    if (hasLegacyUniqueConstraint(database)) {\n      migrateLegacySchema(database);\n    }\n    database.exec(INDEX_SQL);\n    database.exec(TASK_LOOKUP_INDEX_SQL);\n    schemaInitializedDbs.add(database);\n    console.error('[session-learning] Schema initialized');\n  } catch (err: unknown) {\n    const message = toErrorMessage(err);\n    console.error('[session-learning] Schema initialization failed:', message);\n    throw new MemoryError(\n      ErrorCodes.DATABASE_ERROR,\n      'Failed to initialize session_learning schema',\n      { originalError: message }\n    );\n  }\n}","lineStart":180,"lineEnd":269,"totalLines":886,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/session-learning.ts","time":{"start":1781762733402,"end":1781762733408}},"metadata":{"openai":{"itemId":"fc_02b347955bc8f484016a338aad47288191b5c1a0d39964f0c1"}},"id":"prt_ed955b520001VHPxoRF28DZz7b","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9558ef5001CJMhn9lj1faUmJ"}}
{"type":"tool_use","timestamp":1781762733450,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_v8nTSkKP0Rl29KGZqHXq7vWU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud List\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { randomUUID } from 'node:crypto';\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n13: import * as vectorIndex from '../lib/search/vector-index.js';\n14: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { safeJsonParseTyped } from '../utils/json-helpers.js';\n18: \n19: import type { MCPResponse } from './types.js';\n20: import type { ListArgs } from './memory-crud-types.js';\n21: \n22: // Feature catalog: Memory browser (memory_list)\n23: // Feature catalog: Validation feedback (memory_validate)\n24: \n25: \n26: /* ───────────────────────────────────────────────────────────────\n27:    CORE LOGIC\n28: ──────────────────────────────────────────────────────────────── */\n29: \n30: /** Handle memory_list tool -- returns paginated memory entries. */\n31: async function handleMemoryList(args: ListArgs): Promise<MCPResponse> {\n32:   await ensureMemoryRuntimeInitialized('handler:memory_list');\n33:   const startTime = Date.now();\n34:   const requestId = randomUUID();\n35:   try {\n36:     await checkDatabaseUpdated();\n37:   } catch (dbStateErr: unknown) {\n38:     const message = toErrorMessage(dbStateErr);\n39:     console.error(`[memory-list] Database refresh failed [requestId=${requestId}]: ${message}`);\n40:     return createMCPErrorResponse({\n41:       tool: 'memory_list',\n42:       error: 'Database refresh failed before query execution. Retry the request or restart the MCP server.',\n43:       code: 'E021',\n44:       details: { requestId },\n45:       startTime,\n46:     });\n47:   }\n48: \n49:   const {\n50:     limit: rawLimit = 20,\n51:     offset: rawOffset = 0,\n52:     specFolder,\n53:     sortBy = 'created_at',\n54:     includeChunks = false,\n55:   } = args;\n56: \n57:   if (specFolder !== undefined && typeof specFolder !== 'string') {\n58:     return createMCPErrorResponse({\n59:       tool: 'memory_list',\n60:       error: 'specFolder must be a string',\n61:       code: 'E_INVALID_INPUT',\n62:       details: { requestId },\n63:       startTime,\n64:     });\n65:   }\n66:   if (includeChunks !== undefined && typeof includeChunks !== 'boolean') {\n67:     return createMCPErrorResponse({\n68:       tool: 'memory_list',\n69:       error: 'includeChunks must be a boolean',\n70:       code: 'E_INVALID_INPUT',\n71:       details: { requestId },\n72:       startTime,\n73:     });\n74:   }\n75:   if (rawLimit !== undefined && (typeof rawLimit !== 'number' || !Number.isFinite(rawLimit))) {\n76:     return createMCPErrorResponse({\n77:       tool: 'memory_list',\n78:       error: 'limit must be a finite number',\n79:       code: 'E_INVALID_INPUT',\n80:       details: { requestId },\n81:       startTime,\n82:     });\n83:   }\n84:   if (rawOffset !== undefined && (typeof rawOffset !== 'number' || !Number.isFinite(rawOffset))) {\n85:     return createMCPErrorResponse({\n86:       tool: 'memory_list',\n87:       error: 'offset must be a finite number',\n88:       code: 'E_INVALID_INPUT',\n89:       details: { requestId },\n90:       startTime,\n91:     });\n92:   }\n93: \n94:   const safeLimit = Math.max(1, Math.min(Math.floor(rawLimit || 20), 100));\n95:   const safeOffset = Math.max(0, Math.floor(rawOffset || 0));\n96:   const database = vectorIndex.getDb();\n97: \n98:   if (!database) {\n99:     return createMCPErrorResponse({\n100:       tool: 'memory_list',\n101:       error: 'Database not initialized. Run memory_index_scan() to trigger schema creation, or restart the MCP server.',\n102:       code: 'E020',\n103:       details: { requestId },\n104:       startTime,\n105:     });\n106:   }\n107: \n108:   let total = 0;\n109:   let rows: unknown[];\n110:   const sortColumn = ['created_at', 'updated_at', 'importance_weight'].includes(sortBy)\n111:     ? sortBy\n112:     : 'created_at';\n113: \n114:   try {\n115:     const whereParts: string[] = [];\n116:     const baseParams: unknown[] = [];\n117: \n118:     if (!includeChunks) {\n119:       whereParts.push('parent_id IS NULL');\n120:     }\n121: \n122:     if (specFolder) {\n123:       whereParts.push('spec_folder = ?');\n124:       baseParams.push(specFolder);\n125:     }\n126: \n127:     const whereClause = whereParts.length > 0 ? `WHERE ${whereParts.join(' AND ')}` : '';\n128: \n129:     const countSql = `SELECT COUNT(*) as count FROM memory_index ${whereClause}`;\n130:     const countResult = database.prepare(countSql).get(...baseParams) as Record<string, unknown> | undefined;\n131:     total = (countResult && typeof countResult.count === 'number') ? countResult.count : 0;\n132: \n133:     const sql = `SELECT id, spec_folder, file_path, title, trigger_phrases, importance_weight, created_at, updated_at FROM memory_index ${whereClause} ORDER BY ${sortColumn} DESC LIMIT ? OFFSET ?`;\n134:     const params = [...baseParams, safeLimit, safeOffset];\n135:     rows = database.prepare(sql).all(...params);\n136:   } catch (dbErr: unknown) {\n137:     const message = toErrorMessage(dbErr);\n138:     console.error(`[memory-list] Database query failed: ${message}`);\n139:     return createMCPErrorResponse({\n140:       tool: 'memory_list',\n141:       error: `Database query failed: ${message}`,\n142:       code: 'E021',\n143:       details: { requestId },\n144:       startTime,\n145:     });\n146:   }\n147: \n148:   const memories = (rows as Record<string, unknown>[]).map((row: Record<string, unknown>) => ({\n149:     id: row.id,\n150:     specFolder: row.spec_folder,\n151:     title: (row.title as string) || '(untitled)',\n152:     createdAt: row.created_at,\n153:     updatedAt: row.updated_at,\n154:     importanceWeight: row.importance_weight,\n155:     triggerCount: safeJsonParseTyped<unknown[]>(row.trigger_phrases as string, 'array', []).length,\n156:     filePath: row.file_path,\n157:   }));\n158: \n159:   const summary = `Listed ${memories.length} of ${total} memories`;\n160:   const hints: string[] = [];\n161:   if (safeOffset + memories.length < total) {\n162:     hints.push(`More results available: use offset: ${safeOffset + safeLimit}`);\n163:   }\n164:   if (memories.length === 0 && total > 0) {\n165:     hints.push('Offset exceeds total count - try offset: 0');\n166:   }\n167: \n168:   return createMCPSuccessResponse({\n169:     tool: 'memory_list',\n170:     summary,\n171:     data: {\n172:       total,\n173:       offset: safeOffset,\n174:       limit: safeLimit,\n175:       sortBy: sortColumn,\n176:       includeChunks,\n177:       count: memories.length,\n178:       results: memories,\n179:     },\n180:     hints,\n\n(Showing lines 1-180 of 189. Use offset=181 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud List\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { safeJsonParseTyped } from '../utils/json-helpers.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { ListArgs } from './memory-crud-types.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud List\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { safeJsonParseTyped } from '../utils/json-helpers.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { ListArgs } from './memory-crud-types.js';\n\n// Feature catalog: Memory browser (memory_list)\n// Feature catalog: Validation feedback (memory_validate)\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_list tool -- returns paginated memory entries. */\nasync function handleMemoryList(args: ListArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_list');\n  const startTime = Date.now();\n  const requestId = randomUUID();\n  try {\n    await checkDatabaseUpdated();\n  } catch (dbStateErr: unknown) {\n    const message = toErrorMessage(dbStateErr);\n    console.error(`[memory-list] Database refresh failed [requestId=${requestId}]: ${message}`);\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'Database refresh failed before query execution. Retry the request or restart the MCP server.',\n      code: 'E021',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  const {\n    limit: rawLimit = 20,\n    offset: rawOffset = 0,\n    specFolder,\n    sortBy = 'created_at',\n    includeChunks = false,\n  } = args;\n\n  if (specFolder !== undefined && typeof specFolder !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'specFolder must be a string',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n  if (includeChunks !== undefined && typeof includeChunks !== 'boolean') {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'includeChunks must be a boolean',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n  if (rawLimit !== undefined && (typeof rawLimit !== 'number' || !Number.isFinite(rawLimit))) {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'limit must be a finite number',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n  if (rawOffset !== undefined && (typeof rawOffset !== 'number' || !Number.isFinite(rawOffset))) {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'offset must be a finite number',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  const safeLimit = Math.max(1, Math.min(Math.floor(rawLimit || 20), 100));\n  const safeOffset = Math.max(0, Math.floor(rawOffset || 0));\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'Database not initialized. Run memory_index_scan() to trigger schema creation, or restart the MCP server.',\n      code: 'E020',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  let total = 0;\n  let rows: unknown[];\n  const sortColumn = ['created_at', 'updated_at', 'importance_weight'].includes(sortBy)\n    ? sortBy\n    : 'created_at';\n\n  try {\n    const whereParts: string[] = [];\n    const baseParams: unknown[] = [];\n\n    if (!includeChunks) {\n      whereParts.push('parent_id IS NULL');\n    }\n\n    if (specFolder) {\n      whereParts.push('spec_folder = ?');\n      baseParams.push(specFolder);\n    }\n\n    const whereClause = whereParts.length > 0 ? `WHERE ${whereParts.join(' AND ')}` : '';\n\n    const countSql = `SELECT COUNT(*) as count FROM memory_index ${whereClause}`;\n    const countResult = database.prepare(countSql).get(...baseParams) as Record<string, unknown> | undefined;\n    total = (countResult && typeof countResult.count === 'number') ? countResult.count : 0;\n\n    const sql = `SELECT id, spec_folder, file_path, title, trigger_phrases, importance_weight, created_at, updated_at FROM memory_index ${whereClause} ORDER BY ${sortColumn} DESC LIMIT ? OFFSET ?`;\n    const params = [...baseParams, safeLimit, safeOffset];\n    rows = database.prepare(sql).all(...params);\n  } catch (dbErr: unknown) {\n    const message = toErrorMessage(dbErr);\n    console.error(`[memory-list] Database query failed: ${message}`);\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: `Database query failed: ${message}`,\n      code: 'E021',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  const memories = (rows as Record<string, unknown>[]).map((row: Record<string, unknown>) => ({\n    id: row.id,\n    specFolder: row.spec_folder,\n    title: (row.title as string) || '(untitled)',\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    importanceWeight: row.importance_weight,\n    triggerCount: safeJsonParseTyped<unknown[]>(row.trigger_phrases as string, 'array', []).length,\n    filePath: row.file_path,\n  }));\n\n  const summary = `Listed ${memories.length} of ${total} memories`;\n  const hints: string[] = [];\n  if (safeOffset + memories.length < total) {\n    hints.push(`More results available: use offset: ${safeOffset + safeLimit}`);\n  }\n  if (memories.length === 0 && total > 0) {\n    hints.push('Offset exceeds total count - try offset: 0');\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_list',\n    summary,\n    data: {\n      total,\n      offset: safeOffset,\n      limit: safeLimit,\n      sortBy: sortColumn,\n      includeChunks,\n      count: memories.length,\n      results: memories,\n    },\n    hints,","lineStart":1,"lineEnd":180,"totalLines":189,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts","time":{"start":1781762733434,"end":1781762733449}},"metadata":{"openai":{"itemId":"fc_02b347955bc8f484016a338aad473881918e52a8a81adef3e4"}},"id":"prt_ed955b570001kFtFtUJx87dyHQ","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9558ef5001CJMhn9lj1faUmJ"}}
{"type":"tool_use","timestamp":1781762733454,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_ZzZkkO7LJz0jUGRTVNtcD7cC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Post Insert Metadata\n3: // ───────────────────────────────────────────────────────────────\n4: // Shared post-insert metadata updates extracted from handlers/save\n5: // so storage-layer writers do not depend on handler modules.\n6: \n7: import type Database from 'better-sqlite3';\n8: import {\n9:   buildGovernanceLogicalKey,\n10:   recordTierDowngradeAudit,\n11: } from '../governance/scope-governance.js';\n12: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n13: \n14: // ───────────────────────────────────────────────────────────────\n15: // 1. TYPES\n16: // ───────────────────────────────────────────────────────────────\n17: \n18: /**\n19:  * Field map accepted by the post-insert metadata update helper.\n20:  * Keys align to the guarded `memory_index` columns below.\n21:  */\n22: export interface PostInsertMetadataFields {\n23:   content_hash?: string;\n24:   context_type?: string;\n25:   importance_tier?: string;\n26:   memory_type?: string;\n27:   type_inference_source?: string;\n28:   stability?: number;\n29:   difficulty?: number;\n30:   review_count?: number;\n31:   file_mtime_ms?: number | null;\n32:   embedding_status?: string;\n33:   encoding_intent?: string | null;\n34:   document_type?: string;\n35:   spec_level?: number | null;\n36:   quality_score?: number;\n37:   quality_flags?: string;\n38:   parent_id?: number;\n39:   chunk_index?: number;\n40:   chunk_label?: string;\n41:   tenant_id?: string;\n42:   user_id?: string;\n43:   agent_id?: string;\n44:   session_id?: string;\n45:   provenance_source?: string;\n46:   provenance_actor?: string;\n47:   governed_at?: string;\n48:   retention_policy?: string;\n49:   delete_after?: string | null;\n50:   governance_metadata?: string;\n51: }\n52: \n53: // ───────────────────────────────────────────────────────────────\n54: // 2. CONSTANTS\n55: // ───────────────────────────────────────────────────────────────\n56: \n57: /** Allowed column names for the dynamic UPDATE builder (injection guard). */\n58: export const ALLOWED_POST_INSERT_COLUMNS = new Set<string>([\n59:   'content_hash', 'context_type', 'importance_tier', 'memory_type',\n60:   'type_inference_source', 'stability', 'difficulty', 'review_count',\n61:   'file_mtime_ms', 'embedding_status', 'encoding_intent', 'document_type',\n62:   'spec_level', 'quality_score', 'quality_flags', 'parent_id',\n63:   'chunk_index', 'chunk_label', 'tenant_id', 'user_id', 'agent_id',\n64:   'session_id',\n65:   'provenance_source', 'provenance_actor',\n66:   'governed_at', 'retention_policy', 'delete_after', 'governance_metadata',\n67: ]);\n68: \n69: // ───────────────────────────────────────────────────────────────\n70: // 3. HELPERS\n71: // ───────────────────────────────────────────────────────────────\n72: \n73: /**\n74:  * Build and execute a dynamic `UPDATE memory_index SET ... WHERE id = ?`\n75:  * from the supplied field map.\n76:  *\n77:  * Special handling:\n78:  * - `encoding_intent` uses `COALESCE(?, encoding_intent)`\n79:  * - `last_review` is always refreshed to `datetime('now')`\n80:  *\n81:  * @param db - Database connection that stores memory rows.\n82:  * @param memoryId - Inserted memory identifier to enrich.\n83:  * @param fields - Column/value map for the metadata update.\n84:  */\n85: export function applyPostInsertMetadata(\n86:   db: Database.Database,\n87:   memoryId: number,\n88:   fields: PostInsertMetadataFields,\n89: ): void {\n90:   const normalizedFields: PostInsertMetadataFields = { ...fields };\n91:   if (normalizedFields.importance_tier === 'constitutional') {\n92:     const row = db.prepare(`\n93:       SELECT spec_folder, anchor_id, file_path, canonical_file_path\n94:       FROM memory_index\n95:       WHERE id = ?\n96:     `).get(memoryId) as {\n97:       spec_folder: string | null;\n98:       anchor_id: string | null;\n99:       file_path: string | null;\n100:       canonical_file_path: string | null;\n101:     } | undefined;\n102: \n103:     const guardPath = row?.canonical_file_path || row?.file_path || null;\n104:     if (guardPath && !isIndexableConstitutionalMemoryPath(guardPath)) {\n105:       normalizedFields.importance_tier = 'important';\n106:       try {\n107:         recordTierDowngradeAudit(db, {\n108:           memoryId,\n109:           logicalKey: buildGovernanceLogicalKey(row?.spec_folder, guardPath, row?.anchor_id),\n110:           requestedTier: 'constitutional',\n111:           nextTier: 'important',\n112:           source: 'applyPostInsertMetadata',\n113:           filePath: row?.file_path ?? null,\n114:           canonicalFilePath: row?.canonical_file_path ?? null,\n115:         });\n116:       } catch (error: unknown) {\n117:         console.warn(\n118:           '[post-insert-metadata] governance_audit insert failed for tier downgrade:',\n119:           error instanceof Error ? error.message : String(error),\n120:         );\n121:       }\n122:     }\n123:   }\n124: \n125:   const setClauses: string[] = [];\n126:   const values: unknown[] = [];\n127: \n128:   for (const [col, val] of Object.entries(normalizedFields)) {\n129:     if (val === undefined) continue;\n130:     if (!ALLOWED_POST_INSERT_COLUMNS.has(col)) continue;\n131: \n132:     if (col === 'encoding_intent') {\n133:       setClauses.push('encoding_intent = COALESCE(?, encoding_intent)');\n134:     } else {\n135:       setClauses.push(`${col} = ?`);\n136:     }\n137:     values.push(val);\n138:   }\n139: \n140:   setClauses.push(\"last_review = datetime('now')\");\n141: \n142:   values.push(memoryId);\n143: \n144:   db.prepare(`\n145:     UPDATE memory_index\n146:     SET ${setClauses.join(',\\n        ')}\n147:     WHERE id = ?\n148:   `).run(...values);\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Post Insert Metadata\n// ───────────────────────────────────────────────────────────────\n// Shared post-insert metadata updates extracted from handlers/save\n// so storage-layer writers do not depend on handler modules.\n\nimport type Database from 'better-sqlite3';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Field map accepted by the post-insert metadata update helper.\n * Keys align to the guarded `memory_index` columns below.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Post Insert Metadata\n// ───────────────────────────────────────────────────────────────\n// Shared post-insert metadata updates extracted from handlers/save\n// so storage-layer writers do not depend on handler modules.\n\nimport type Database from 'better-sqlite3';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Field map accepted by the post-insert metadata update helper.\n * Keys align to the guarded `memory_index` columns below.\n */\nexport interface PostInsertMetadataFields {\n  content_hash?: string;\n  context_type?: string;\n  importance_tier?: string;\n  memory_type?: string;\n  type_inference_source?: string;\n  stability?: number;\n  difficulty?: number;\n  review_count?: number;\n  file_mtime_ms?: number | null;\n  embedding_status?: string;\n  encoding_intent?: string | null;\n  document_type?: string;\n  spec_level?: number | null;\n  quality_score?: number;\n  quality_flags?: string;\n  parent_id?: number;\n  chunk_index?: number;\n  chunk_label?: string;\n  tenant_id?: string;\n  user_id?: string;\n  agent_id?: string;\n  session_id?: string;\n  provenance_source?: string;\n  provenance_actor?: string;\n  governed_at?: string;\n  retention_policy?: string;\n  delete_after?: string | null;\n  governance_metadata?: string;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────\n\n/** Allowed column names for the dynamic UPDATE builder (injection guard). */\nexport const ALLOWED_POST_INSERT_COLUMNS = new Set<string>([\n  'content_hash', 'context_type', 'importance_tier', 'memory_type',\n  'type_inference_source', 'stability', 'difficulty', 'review_count',\n  'file_mtime_ms', 'embedding_status', 'encoding_intent', 'document_type',\n  'spec_level', 'quality_score', 'quality_flags', 'parent_id',\n  'chunk_index', 'chunk_label', 'tenant_id', 'user_id', 'agent_id',\n  'session_id',\n  'provenance_source', 'provenance_actor',\n  'governed_at', 'retention_policy', 'delete_after', 'governance_metadata',\n]);\n\n// ───────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Build and execute a dynamic `UPDATE memory_index SET ... WHERE id = ?`\n * from the supplied field map.\n *\n * Special handling:\n * - `encoding_intent` uses `COALESCE(?, encoding_intent)`\n * - `last_review` is always refreshed to `datetime('now')`\n *\n * @param db - Database connection that stores memory rows.\n * @param memoryId - Inserted memory identifier to enrich.\n * @param fields - Column/value map for the metadata update.\n */\nexport function applyPostInsertMetadata(\n  db: Database.Database,\n  memoryId: number,\n  fields: PostInsertMetadataFields,\n): void {\n  const normalizedFields: PostInsertMetadataFields = { ...fields };\n  if (normalizedFields.importance_tier === 'constitutional') {\n    const row = db.prepare(`\n      SELECT spec_folder, anchor_id, file_path, canonical_file_path\n      FROM memory_index\n      WHERE id = ?\n    `).get(memoryId) as {\n      spec_folder: string | null;\n      anchor_id: string | null;\n      file_path: string | null;\n      canonical_file_path: string | null;\n    } | undefined;\n\n    const guardPath = row?.canonical_file_path || row?.file_path || null;\n    if (guardPath && !isIndexableConstitutionalMemoryPath(guardPath)) {\n      normalizedFields.importance_tier = 'important';\n      try {\n        recordTierDowngradeAudit(db, {\n          memoryId,\n          logicalKey: buildGovernanceLogicalKey(row?.spec_folder, guardPath, row?.anchor_id),\n          requestedTier: 'constitutional',\n          nextTier: 'important',\n          source: 'applyPostInsertMetadata',\n          filePath: row?.file_path ?? null,\n          canonicalFilePath: row?.canonical_file_path ?? null,\n        });\n      } catch (error: unknown) {\n        console.warn(\n          '[post-insert-metadata] governance_audit insert failed for tier downgrade:',\n          error instanceof Error ? error.message : String(error),\n        );\n      }\n    }\n  }\n\n  const setClauses: string[] = [];\n  const values: unknown[] = [];\n\n  for (const [col, val] of Object.entries(normalizedFields)) {\n    if (val === undefined) continue;\n    if (!ALLOWED_POST_INSERT_COLUMNS.has(col)) continue;\n\n    if (col === 'encoding_intent') {\n      setClauses.push('encoding_intent = COALESCE(?, encoding_intent)');\n    } else {\n      setClauses.push(`${col} = ?`);\n    }\n    values.push(val);\n  }\n\n  setClauses.push(\"last_review = datetime('now')\");\n\n  values.push(memoryId);\n\n  db.prepare(`\n    UPDATE memory_index\n    SET ${setClauses.join(',\\n        ')}\n    WHERE id = ?\n  `).run(...values);\n}","lineStart":1,"lineEnd":149,"totalLines":149,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts","time":{"start":1781762733439,"end":1781762733454}},"metadata":{"openai":{"itemId":"fc_02b347955bc8f484016a338aad474081918927a996bea220b9"}},"id":"prt_ed955b57d001BVrSdbVBsTE8Mx","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9558ef5001CJMhn9lj1faUmJ"}}
{"type":"tool_use","timestamp":1781762733457,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_WHiX3MsPDF12uC58aNa5DFu1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/write-provenance.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/write-provenance.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Write Provenance\n3: // ───────────────────────────────────────────────────────────────\n4: import { normalizeScopeValue } from '../governance/scope-governance.js';\n5: import { scrubSecrets } from '../parsing/secret-scrubber.js';\n6: \n7: export type SourceKind = 'human' | 'agent' | 'system' | 'import' | 'feedback';\n8: \n9: export interface WriteProvenanceContext {\n10:   provenanceSource?: unknown;\n11:   provenanceActor?: unknown;\n12:   provenance_source?: unknown;\n13:   provenance_actor?: unknown;\n14:   tool?: unknown;\n15:   filePath?: unknown;\n16:   scope?: {\n17:     tenantId?: string | null;\n18:     userId?: string | null;\n19:     agentId?: string | null;\n20:     sessionId?: string | null;\n21:   };\n22: }\n23: \n24: type WriteProvenanceStatement = {\n25:   all: (...params: any[]) => unknown[];\n26:   run: (...params: any[]) => unknown;\n27: };\n28: \n29: export type WriteProvenanceDatabase = {\n30:   prepare: (sql: string) => WriteProvenanceStatement;\n31: };\n32: \n33: const SOURCE_KINDS = new Set<SourceKind>(['human', 'agent', 'system', 'import', 'feedback']);\n34: \n35: export function normalizeSourceKind(value: unknown): SourceKind | null {\n36:   if (typeof value !== 'string') {\n37:     return null;\n38:   }\n39:   const normalized = value.trim().toLowerCase();\n40:   return SOURCE_KINDS.has(normalized as SourceKind) ? normalized as SourceKind : null;\n41: }\n42: \n43: export function isManualSourceKind(value: unknown): boolean {\n44:   if (typeof value !== 'string') {\n45:     return false;\n46:   }\n47:   const normalized = value.trim().toLowerCase();\n48:   return normalized === 'manual' || normalizeSourceKind(normalized) === 'human';\n49: }\n50: \n51: function normalizeOptionalString(value: unknown): string | null {\n52:   if (typeof value !== 'string') {\n53:     return null;\n54:   }\n55:   const normalized = value.trim();\n56:   return normalized.length > 0 ? normalized : null;\n57: }\n58: \n59: function sourceKindFromLabel(value: unknown): SourceKind | null {\n60:   const normalized = normalizeOptionalString(value)?.toLowerCase();\n61:   if (!normalized) {\n62:     return null;\n63:   }\n64:   if (/\\b(human|manual|user|operator|author)\\b/.test(normalized)) {\n65:     return 'human';\n66:   }\n67:   if (normalized.includes('feedback') || normalized.includes('validate') || normalized.includes('validation')) {\n68:     return 'feedback';\n69:   }\n70:   if (normalized.includes('import') || normalized.includes('ingest') || normalized.includes('scan') || normalized.includes('index')) {\n71:     return 'import';\n72:   }\n73:   if (/\\b(agent|assistant|claude|codex|opencode|automation|bot)\\b/.test(normalized)) {\n74:     return 'agent';\n75:   }\n76:   if (/\\b(system|runtime|daemon|scheduler|hook|reconsolidation)\\b/.test(normalized)) {\n77:     return 'system';\n78:   }\n79:   return null;\n80: }\n81: \n82: export function deriveSourceKindFromContext(context: WriteProvenanceContext = {}): SourceKind {\n83:   const fromSource = sourceKindFromLabel(context.provenanceSource ?? context.provenance_source);\n84:   if (fromSource) {\n85:     return fromSource;\n86:   }\n87:   const fromActor = sourceKindFromLabel(context.provenanceActor ?? context.provenance_actor);\n88:   if (fromActor) {\n89:     return fromActor;\n90:   }\n91:   const fromTool = sourceKindFromLabel(context.tool);\n92:   if (fromTool) {\n93:     return fromTool;\n94:   }\n95:   const scope = context.scope ?? {};\n96:   const hasUser = normalizeScopeValue(scope.userId) !== null;\n97:   const hasAgent = normalizeScopeValue(scope.agentId) !== null;\n98:   if (hasAgent && !hasUser) {\n99:     return 'agent';\n100:   }\n101:   // No filePath heuristic: a human save whose path merely contains a word\n102:   // like \"index\" or \"scan\" must not be classified as an automated import,\n103:   // because that strips the manual-overwrite protection from the row. Real\n104:   // scan/ingest writes are classified by their tool label or explicit tags.\n105:   return 'human';\n106: }\n107: \n108: function getTableColumns(database: WriteProvenanceDatabase, tableName: string): Set<string> {\n109:   try {\n110:     return new Set(\n111:       (database.prepare(`PRAGMA table_info(${tableName})`).all() as Array<{ name: string }>)\n112:         .map((column) => column.name),\n113:     );\n114:   } catch {\n115:     return new Set();\n116:   }\n117: }\n118: \n119: function scrubOptional(value: string | null | undefined): string | null | undefined {\n120:   return value == null ? value : scrubSecrets(value);\n121: }\n122: \n123: export function buildPostInsertProvenanceFields(context: WriteProvenanceContext): {\n124:   provenance_source?: string;\n125:   provenance_actor?: string;\n126: } {\n127:   // Provenance labels are caller-supplied free text that lands in a persisted\n128:   // column, so they pass through the same fail-closed scrubber as content.\n129:   const provenanceSource = scrubOptional(normalizeOptionalString(context.provenanceSource ?? context.provenance_source));\n130:   const provenanceActor = scrubOptional(normalizeOptionalString(context.provenanceActor ?? context.provenance_actor));\n131:   return {\n132:     ...(provenanceSource ? { provenance_source: provenanceSource } : {}),\n133:     ...(provenanceActor ? { provenance_actor: provenanceActor } : {}),\n134:   };\n135: }\n136: \n137: export function persistSourceKind(\n138:   database: WriteProvenanceDatabase | null | undefined,\n139:   memoryId: number,\n140:   sourceKind: SourceKind,\n141: ): void {\n142:   if (!database || !getTableColumns(database, 'memory_index').has('source_kind')) {\n143:     return;\n144:   }\n145:   database.prepare('UPDATE memory_index SET source_kind = ? WHERE id = ?').run(sourceKind, memoryId);\n146: }\n147: \n148: export function persistProvenanceMetadata(\n149:   database: WriteProvenanceDatabase | null | undefined,\n150:   memoryId: number,\n151:   context: WriteProvenanceContext,\n152: ): void {\n153:   if (!database) {\n154:     return;\n155:   }\n156:   const fields = buildPostInsertProvenanceFields(context);\n157:   const columns = getTableColumns(database, 'memory_index');\n158:   const setClauses: string[] = [];\n159:   const values: string[] = [];\n160:   for (const [column, value] of Object.entries(fields)) {\n161:     if (!columns.has(column)) {\n162:       continue;\n163:     }\n164:     setClauses.push(`${column} = ?`);\n165:     values.push(value);\n166:   }\n167:   if (setClauses.length === 0) {\n168:     return;\n169:   }\n170:   database.prepare(`UPDATE memory_index SET ${setClauses.join(', ')} WHERE id = ?`).run(...values, memoryId);\n171: }\n172: \n173: export function applyWriteProvenance(\n174:   database: WriteProvenanceDatabase | null | undefined,\n175:   memoryId: number,\n176:   context: WriteProvenanceContext = {},\n177: ): SourceKind {\n178:   const sourceKind = deriveSourceKindFromContext(context);\n179:   persistSourceKind(database, memoryId, sourceKind);\n180:   persistProvenanceMetadata(database, memoryId, context);\n181:   return sourceKind;\n182: }\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Write Provenance\n// ───────────────────────────────────────────────────────────────\nimport { normalizeScopeValue } from '../governance/scope-governance.js';\nimport { scrubSecrets } from '../parsing/secret-scrubber.js';\n\nexport type SourceKind = 'human' | 'agent' | 'system' | 'import' | 'feedback';\n\nexport interface WriteProvenanceContext {\n  provenanceSource?: unknown;\n  provenanceActor?: unknown;\n  provenance_source?: unknown;\n  provenance_actor?: unknown;\n  tool?: unknown;\n  filePath?: unknown;\n  scope?: {\n    tenantId?: string | null;\n    userId?: string | null;\n    agentId?: string | null;\n    sessionId?: string | null;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/write-provenance.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Write Provenance\n// ───────────────────────────────────────────────────────────────\nimport { normalizeScopeValue } from '../governance/scope-governance.js';\nimport { scrubSecrets } from '../parsing/secret-scrubber.js';\n\nexport type SourceKind = 'human' | 'agent' | 'system' | 'import' | 'feedback';\n\nexport interface WriteProvenanceContext {\n  provenanceSource?: unknown;\n  provenanceActor?: unknown;\n  provenance_source?: unknown;\n  provenance_actor?: unknown;\n  tool?: unknown;\n  filePath?: unknown;\n  scope?: {\n    tenantId?: string | null;\n    userId?: string | null;\n    agentId?: string | null;\n    sessionId?: string | null;\n  };\n}\n\ntype WriteProvenanceStatement = {\n  all: (...params: any[]) => unknown[];\n  run: (...params: any[]) => unknown;\n};\n\nexport type WriteProvenanceDatabase = {\n  prepare: (sql: string) => WriteProvenanceStatement;\n};\n\nconst SOURCE_KINDS = new Set<SourceKind>(['human', 'agent', 'system', 'import', 'feedback']);\n\nexport function normalizeSourceKind(value: unknown): SourceKind | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim().toLowerCase();\n  return SOURCE_KINDS.has(normalized as SourceKind) ? normalized as SourceKind : null;\n}\n\nexport function isManualSourceKind(value: unknown): boolean {\n  if (typeof value !== 'string') {\n    return false;\n  }\n  const normalized = value.trim().toLowerCase();\n  return normalized === 'manual' || normalizeSourceKind(normalized) === 'human';\n}\n\nfunction normalizeOptionalString(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction sourceKindFromLabel(value: unknown): SourceKind | null {\n  const normalized = normalizeOptionalString(value)?.toLowerCase();\n  if (!normalized) {\n    return null;\n  }\n  if (/\\b(human|manual|user|operator|author)\\b/.test(normalized)) {\n    return 'human';\n  }\n  if (normalized.includes('feedback') || normalized.includes('validate') || normalized.includes('validation')) {\n    return 'feedback';\n  }\n  if (normalized.includes('import') || normalized.includes('ingest') || normalized.includes('scan') || normalized.includes('index')) {\n    return 'import';\n  }\n  if (/\\b(agent|assistant|claude|codex|opencode|automation|bot)\\b/.test(normalized)) {\n    return 'agent';\n  }\n  if (/\\b(system|runtime|daemon|scheduler|hook|reconsolidation)\\b/.test(normalized)) {\n    return 'system';\n  }\n  return null;\n}\n\nexport function deriveSourceKindFromContext(context: WriteProvenanceContext = {}): SourceKind {\n  const fromSource = sourceKindFromLabel(context.provenanceSource ?? context.provenance_source);\n  if (fromSource) {\n    return fromSource;\n  }\n  const fromActor = sourceKindFromLabel(context.provenanceActor ?? context.provenance_actor);\n  if (fromActor) {\n    return fromActor;\n  }\n  const fromTool = sourceKindFromLabel(context.tool);\n  if (fromTool) {\n    return fromTool;\n  }\n  const scope = context.scope ?? {};\n  const hasUser = normalizeScopeValue(scope.userId) !== null;\n  const hasAgent = normalizeScopeValue(scope.agentId) !== null;\n  if (hasAgent && !hasUser) {\n    return 'agent';\n  }\n  // No filePath heuristic: a human save whose path merely contains a word\n  // like \"index\" or \"scan\" must not be classified as an automated import,\n  // because that strips the manual-overwrite protection from the row. Real\n  // scan/ingest writes are classified by their tool label or explicit tags.\n  return 'human';\n}\n\nfunction getTableColumns(database: WriteProvenanceDatabase, tableName: string): Set<string> {\n  try {\n    return new Set(\n      (database.prepare(`PRAGMA table_info(${tableName})`).all() as Array<{ name: string }>)\n        .map((column) => column.name),\n    );\n  } catch {\n    return new Set();\n  }\n}\n\nfunction scrubOptional(value: string | null | undefined): string | null | undefined {\n  return value == null ? value : scrubSecrets(value);\n}\n\nexport function buildPostInsertProvenanceFields(context: WriteProvenanceContext): {\n  provenance_source?: string;\n  provenance_actor?: string;\n} {\n  // Provenance labels are caller-supplied free text that lands in a persisted\n  // column, so they pass through the same fail-closed scrubber as content.\n  const provenanceSource = scrubOptional(normalizeOptionalString(context.provenanceSource ?? context.provenance_source));\n  const provenanceActor = scrubOptional(normalizeOptionalString(context.provenanceActor ?? context.provenance_actor));\n  return {\n    ...(provenanceSource ? { provenance_source: provenanceSource } : {}),\n    ...(provenanceActor ? { provenance_actor: provenanceActor } : {}),\n  };\n}\n\nexport function persistSourceKind(\n  database: WriteProvenanceDatabase | null | undefined,\n  memoryId: number,\n  sourceKind: SourceKind,\n): void {\n  if (!database || !getTableColumns(database, 'memory_index').has('source_kind')) {\n    return;\n  }\n  database.prepare('UPDATE memory_index SET source_kind = ? WHERE id = ?').run(sourceKind, memoryId);\n}\n\nexport function persistProvenanceMetadata(\n  database: WriteProvenanceDatabase | null | undefined,\n  memoryId: number,\n  context: WriteProvenanceContext,\n): void {\n  if (!database) {\n    return;\n  }\n  const fields = buildPostInsertProvenanceFields(context);\n  const columns = getTableColumns(database, 'memory_index');\n  const setClauses: string[] = [];\n  const values: string[] = [];\n  for (const [column, value] of Object.entries(fields)) {\n    if (!columns.has(column)) {\n      continue;\n    }\n    setClauses.push(`${column} = ?`);\n    values.push(value);\n  }\n  if (setClauses.length === 0) {\n    return;\n  }\n  database.prepare(`UPDATE memory_index SET ${setClauses.join(', ')} WHERE id = ?`).run(...values, memoryId);\n}\n\nexport function applyWriteProvenance(\n  database: WriteProvenanceDatabase | null | undefined,\n  memoryId: number,\n  context: WriteProvenanceContext = {},\n): SourceKind {\n  const sourceKind = deriveSourceKindFromContext(context);\n  persistSourceKind(database, memoryId, sourceKind);\n  persistProvenanceMetadata(database, memoryId, context);\n  return sourceKind;\n}","lineStart":1,"lineEnd":182,"totalLines":182,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/write-provenance.ts","time":{"start":1781762733452,"end":1781762733456}},"metadata":{"openai":{"itemId":"fc_02b347955bc8f484016a338aad474881919c099d9061624a02"}},"id":"prt_ed955b580001XH51TdG3S0XY10","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9558ef5001CJMhn9lj1faUmJ"}}
