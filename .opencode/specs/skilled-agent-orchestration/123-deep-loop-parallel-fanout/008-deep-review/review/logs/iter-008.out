   112	    .map((blocker) => `${blocker.type}:${blocker.count}`)
   113	    .join(',');
   114	}
   115	
   116	function computeCompositeScore(signals, loopType) {
   117	  if (!signals || typeof signals !== 'object') return 0;
   118	  const clamp = (value) => Math.max(0, Math.min(1, value));
   119	  const safe = (value) => (typeof value === 'number' && Number.isFinite(value) ? value : 0);
   120	  if (loopType === 'research') {
   121	    const normalizedDiversity = Math.min(safe(signals.sourceDiversity) / 3.0, 1.0);
   122	    const normalizedDepth = Math.min(safe(signals.evidenceDepth) / 5.0, 1.0);
   123	    const invertedContradictions = 1.0 - clamp(safe(signals.contradictionDensity));
   124	    const score =
   125	      clamp(safe(signals.questionCoverage)) * 0.30 +
   126	      clamp(safe(signals.claimVerificationRate)) * 0.25 +
   127	      invertedContradictions * 0.15 +
   128	      normalizedDiversity * 0.15 +
   129	      normalizedDepth * 0.15;
   130	    return Math.round(clamp(score) * 1000) / 1000;
   131	  }
   132	  const score =
   133	    clamp(safe(signals.dimensionCoverage)) * 0.25 +
   134	    clamp(safe(signals.findingStability)) * 0.20 +
   135	    clamp(safe(signals.p0ResolutionRate)) * 0.25 +
   136	    clamp(safe(signals.evidenceDensity)) * 0.15 +
   137	    clamp(safe(signals.hotspotSaturation)) * 0.15;
   138	  return Math.round(clamp(score) * 1000) / 1000;
   139	}
   140	
   141	function parseMetadata(metadata) {
   142	  return metadata && typeof metadata === 'object' ? metadata : {};
   143	}
   144	
   145	function buildReviewSignals(nodes, edges) {
   146	  const dimensionIds = new Set(nodes.filter((node) => node.kind === 'DIMENSION').map((node) => node.id));
   147	  const findingNodes = nodes.filter((node) => node.kind === 'FINDING');
   148	  const fileNodes = nodes.filter((node) => node.kind === 'FILE');
   149	  const coversEdges = edges.filter((edge) => edge.relation === 'COVERS');
   150	  const contradictionEdges = edges.filter((edge) => edge.relation === 'CONTRADICTS');
   151	  const evidenceEdges = edges.filter((edge) => edge.relation === 'EVIDENCE_FOR');
   152	  const resolvesTargetIds = new Set(edges.filter((edge) => edge.relation === 'RESOLVES').map((edge) => edge.targetId));
   153	  const coveredDimensionIds = new Set(
   154	    coversEdges.map((edge) => edge.sourceId).filter((sourceId) => dimensionIds.has(sourceId)),
   155	  );
   156	  const contradictionNodeIds = new Set();
   157	  for (const edge of contradictionEdges) {
   158	    contradictionNodeIds.add(edge.sourceId);
   159	    contradictionNodeIds.add(edge.targetId);
   160	  }
   161	  const p0Findings = findingNodes.filter((node) => parseMetadata(node.metadata).severity === 'P0');
   162	  const hotspotFiles = fileNodes.filter((node) => {
   163	    const hotspotScore = parseMetadata(node.metadata).hotspot_score;
   164	    return typeof hotspotScore === 'number' && hotspotScore > 0;
   165	  });
   166	  let saturatedHotspots = 0;
   167	  for (const file of hotspotFiles) {
   168	    const coveringDimensions = new Set(
   169	      coversEdges
   170	        .filter((edge) => edge.targetId === file.id)
   171	        .map((edge) => edge.sourceId)
   172	        .filter((sourceId) => dimensionIds.has(sourceId)),
   173	    );
   174	    if (coveringDimensions.size >= 2) saturatedHotspots += 1;
   175	  }
   176	  return {
   177	    dimensionCoverage: dimensionIds.size > 0 ? coveredDimensionIds.size / dimensionIds.size : 0,
   178	    findingStability: findingNodes.length > 0
   179	      ? findingNodes.filter((node) => !contradictionNodeIds.has(node.id)).length / findingNodes.length
   180	      : 0,
   181	    p0ResolutionRate: p0Findings.length > 0
   182	      ? p0Findings.filter((node) => resolvesTargetIds.has(node.id)).length / p0Findings.length
   183	      : 1,
   184	    evidenceDensity: findingNodes.length > 0 ? evidenceEdges.length / findingNodes.length : 0,
   185	    hotspotSaturation: hotspotFiles.length > 0 ? saturatedHotspots / hotspotFiles.length : 1,
   186	  };
   187	}
   188	
   189	function evaluateResearch(signals, gaps, contradictions, unverified) {
   190	  const thresholds = {
   191	    questionCoverage: 0.7,
   192	    claimVerificationRate: 0.6,
   193	    contradictionDensity: 0.15,
   194	    sourceDiversity: 1.5,
   195	    evidenceDepth: 1.5,
   196	  };
   197	  const blockers = [];
   198	  const trace = [
   199	    { signal: 'questionCoverage', value: signals.questionCoverage, threshold: thresholds.questionCoverage, passed: signals.questionCoverage >= thresholds.questionCoverage, role: 'weighted' },
   200	    { signal: 'claimVerificationRate', value: signals.claimVerificationRate, threshold: thresholds.claimVerificationRate, passed: signals.claimVerificationRate >= thresholds.claimVerificationRate, role: 'weighted' },
   201	    { signal: 'contradictionDensity', value: signals.contradictionDensity, threshold: thresholds.contradictionDensity, passed: signals.contradictionDensity <= thresholds.contradictionDensity, role: 'weighted' },
   202	    { signal: 'sourceDiversity', value: signals.sourceDiversity, threshold: thresholds.sourceDiversity, passed: signals.sourceDiversity >= thresholds.sourceDiversity, role: 'blocking_guard' },
   203	    { signal: 'evidenceDepth', value: signals.evidenceDepth, threshold: thresholds.evidenceDepth, passed: signals.evidenceDepth >= thresholds.evidenceDepth, role: 'blocking_guard' },
   204	  ];
   205	  if (signals.sourceDiversity < thresholds.sourceDiversity) {
   206	    blockers.push({ type: 'source_diversity_guard', description: `Source diversity (${signals.sourceDiversity.toFixed(2)}) is below the blocking threshold (${thresholds.sourceDiversity}). STOP is blocked until diverse sources cover key questions.`, count: 1, severity: 'blocking' });
   207	  }
   208	  if (signals.evidenceDepth < thresholds.evidenceDepth) {
   209	    blockers.push({ type: 'evidence_depth_guard', description: `Evidence depth (${signals.evidenceDepth.toFixed(2)}) is below the blocking threshold (${thresholds.evidenceDepth}). STOP is blocked until question->finding->source chains are deeper.`, count: 1, severity: 'blocking' });
   210	  }
   211	  if (gaps.length > 0) {
   212	    blockers.push({ type: 'uncovered_questions', description: `${gaps.length} question(s) have no coverage edges`, count: gaps.length, severity: signals.questionCoverage < thresholds.questionCoverage ? 'blocking' : 'warning' });
   213	  }
   214	  if (contradictions.length > 0 && signals.contradictionDensity > thresholds.contradictionDensity) {
   215	    blockers.push({ type: 'high_contradiction_density', description: `${contradictions.length} contradiction(s) detected with density above threshold`, count: contradictions.length, severity: 'blocking' });
   216	  }
   217	  if (unverified.length > 0) {
   218	    blockers.push({ type: 'unverified_claims', description: `${unverified.length} claim(s) remain unverified`, count: unverified.length, severity: signals.claimVerificationRate < thresholds.claimVerificationRate ? 'blocking' : 'warning' });
   219	  }
   220	  return { blockers, trace };

