   672	function runCliRecommend(input, env, timeoutMs) {
   673	  // Thread the caller's thresholds into the subprocess payload so the CLI
   674	  // scorer applies the same floor/ceiling as the in-process path. Omitting
   675	  // them made the scorer fall back to its built-in defaults while the response
   676	  // metadata still reported the caller-supplied thresholds.
   677	  const payload = {
   678	    prompt: input.prompt,
   679	    options: {
   680	      topK: 3,
   515	  function runBridge({ projectDir, prompt, options }) {
   516	    const startedAt = Date.now();
   517	    state.bridgeInvocations += 1;
   518	
   519	    return new Promise((resolve) => {
   520	      let stdout = '';
   521	      let stdoutBytes = 0;
   522	      let settled = false;
   523	      let timedOut = false;
   524	      let termTimer = null;
   525	      let deadlineTimer = null;
   526	      let child = null;
   527	
   528	      const finish = (response) => {
   529	        if (settled) {
   530	          return;
   531	        }
   532	        settled = true;
   533	        if (termTimer) clearTimeout(termTimer);
   534	        if (deadlineTimer) clearTimeout(deadlineTimer);
   535	        state.lastBridgeStatus = response.status;
   536	        state.lastErrorCode = response.error ?? null;
   537	        state.lastDurationMs = Date.now() - startedAt;
   538	        resolve(response);
   539	      };
   540	
   541	      try {
   542	        child = options.spawnBridge(options.nodeBinary, [BRIDGE_PATH], {
   543	          cwd: projectDir,
   544	          env: process.env,
   545	          stdio: ['pipe', 'pipe', 'ignore'],
   546	        });
   547	      } catch {
   548	        finish({ brief: null, status: 'fail_open', error: 'SPAWN_ERROR', metadata: {} });
   549	        return;
   550	      }
   551	
   552	      const graceMs = Math.min(BRIDGE_TERMINATION_GRACE_MS, options.bridgeTimeoutMs);
   553	      termTimer = setTimeout(() => {
   554	        if (settled) return;
   555	        timedOut = true;
   556	        child.kill('SIGTERM');
   557	      }, Math.max(0, options.bridgeTimeoutMs - graceMs));
   558	      deadlineTimer = setTimeout(() => {
   559	        if (settled) return;
   560	        timedOut = true;
   561	        child.kill('SIGKILL');
   562	        finish({ brief: null, status: 'fail_open', error: 'TIMEOUT', metadata: {} });
   563	      }, options.bridgeTimeoutMs);
   564	      termTimer.unref?.();
   565	      deadlineTimer.unref?.();
   566	
   567	      child.stdout?.setEncoding?.('utf8');
   568	      child.stdout?.on('data', (chunk) => {
   569	        if (settled) return;
   570	        const text = String(chunk);
   571	        stdoutBytes += Buffer.byteLength(text, 'utf8');
   572	        if (stdoutBytes > MAX_BRIDGE_STDOUT_BYTES) {
   573	          child.kill('SIGKILL');
   574	          finish({ brief: null, status: 'fail_open', error: 'BRIDGE_OUTPUT_LIMIT', metadata: {} });
   575	          return;
   576	        }
   577	        stdout += text;
   578	      });
   579	
   580	      child.on('error', () => {
   581	        finish({
   582	          brief: null,
   583	          status: 'fail_open',
   584	          error: timedOut ? 'TIMEOUT' : 'SPAWN_ERROR',
   585	          metadata: {},
   586	        });
   587	      });
   588	
   589	      child.on('close', (code) => {
   590	        if (settled) return;
   591	
   592	        const response = timedOut
   593	          ? { brief: null, status: 'fail_open', error: 'TIMEOUT', metadata: {} }
   594	          : parseBridgeResponse(stdout);
   595	        if (!timedOut && code !== 0 && response.status !== 'fail_open') {
   596	          response.status = 'fail_open';
   597	          response.brief = null;
   598	          response.error = 'NONZERO_EXIT';
   599	        }
   600	
   601	        finish(response);
   602	      });
   603	
   604	      try {
   605	        child.stdin?.end(bridgePayloadJson({ prompt, projectDir, options }));
   606	      } catch {
   607	        child.kill('SIGKILL');
   608	        finish({ brief: null, status: 'fail_open', error: 'STDIN_WRITE_ERROR', metadata: {} });
   609	      }
   610	    });
   611	  }
   612	
   613	  /**
   614	   * Resolve advisor context for a prompt using cache and in-flight deduplication.
   615	   *
   616	   * @param {Object} params - Advisor lookup parameters
   617	   * @param {string} params.projectDir - Workspace root used by the advisor bridge
   618	   * @param {string} params.prompt - User prompt text for advisor matching
   619	   * @param {string} params.sessionID - Session identifier included in the cache key
   620	   * @param {Object} params.options - Normalized plugin options
   621	   * @returns {Promise<Object>} Advisor response with optional `brief` and status metadata
   622	   */
   623	  async function getAdvisorContext({ projectDir, prompt, sessionID, options }) {
   624	    const workspaceRoot = normalizeWorkspaceRoot(projectDir);
   625	    let cacheable = true;
   626	    let sourceSignature;
   627	    try {
   628	      sourceSignature = options.sourceSignatureOverride
   629	        ?? await options.sourceSignatureProvider(workspaceRoot);
   630	      if (typeof sourceSignature !== 'string' || !sourceSignature) {
   631	        throw new TypeError('Invalid source signature');
   632	      }
   633	    } catch {
   634	      cacheable = false;
   635	      sourceSignature = 'unavailable';
   636	    }
   637	    const key = cacheKeyForPrompt(prompt, options, sessionID, sourceSignature, workspaceRoot);
   638	    const now = Date.now();
   639	    const cached = cacheable ? state.advisorCache.get(key) : null;
   640	
   641	    state.advisorLookups += 1;
   642	    if (cached && cached.expiresAt > now) {
   643	      state.advisorCache.delete(key);
   644	      state.advisorCache.set(key, cached);
   645	      state.cacheHits += 1;
   646	      return cached.response;
   647	    }
   648	
   649	    const inFlight = state.inFlight.get(key);
   650	    if (inFlight) {
   651	      state.cacheHits += 1;
   652	      return inFlight;
   653	    }
   654	
   655	    state.cacheMisses += 1;
   656	    const epochAtStart = state.epoch;
   657	    const promise = runBridge({ projectDir, prompt, options }).finally(() => {
   658	      if (state.inFlight.get(key) === promise) {
   659	        state.inFlight.delete(key);
   660	      }
   661	    });
   662	    state.inFlight.set(key, promise);
   663	    const response = await promise;
   664	    if (cacheable && response.status === 'ok' && response.brief && state.epoch === epochAtStart) {
   665	      const completedAt = Date.now();
   666	      insertWithEviction(state.advisorCache, key, {
   667	        response,
   668	        expiresAt: completedAt + options.cacheTTLMs,
   669	        updatedAt: new Date(completedAt).toISOString(),
   670	      }, options.maxCacheEntries);
   671	    } else {
   672	      state.advisorCache.delete(key);
   673	    }
   674	    return response;
   675	  }
   676	
   677	  function resetRuntimeState() {
   678	    state.epoch += 1;
   679	    state.advisorCache.clear();
   680	    state.inFlight.clear();
   681	    state.runtimeReady = false;
   682	    state.lastBridgeStatus = 'uninitialized';
   683	    state.lastErrorCode = null;
   684	    state.lastDurationMs = 0;
   685	    state.bridgeInvocations = 0;
   686	    state.cacheHits = 0;
   687	    state.cacheMisses = 0;
   688	    state.advisorLookups = 0;
   689	    state.disabledReason = !options.enabled
   690	      ? (disabledEnvName() ?? 'config_enabled_false')
   691	      : null;
   692	  }
   693	
   694	  function cacheHitRate() {
   695	    const total = state.cacheHits + state.cacheMisses;
   696	    return total === 0 ? 0 : Number((state.cacheHits / total).toFixed(3));
   697	  }
   698	
   699	  /**
   700	   * Append an advisor brief to the OpenCode chat system output.
   701	   *
   702	   * @param {Object} [input={}] - OpenCode system-transform hook input
   703	   * @param {Object} [output={ system: [] }] - OpenCode system-transform hook output
   704	   * @param {Array<string>} [output.system] - System context entries mutated in place
   705	   * @returns {Promise<void>} Resolves after optional advisor context injection
   706	   */
   707	  async function appendAdvisorBrief(input = {}, output = { system: [] }) {
   708	    if (!output || typeof output !== 'object') {
   709	      return;
   710	    }
   711	    try {
   712	      output.system = Array.isArray(output?.system) ? output.system : [];
   713	
   714	      if (!options.enabled) {
   715	        return;
   716	      }
   717	      state.runtimeReady = true;
   718	
   719	      let prompt = extractPrompt(input);
   720	      const sessionID = sessionIdFrom(input);
   721	      if (!prompt && sessionID !== '__global__') {
   722	        try {
   723	          const result = await ctx?.client?.session?.messages?.({
   724	            path: { id: sessionID },
   725	            query: { directory: projectDir, limit: 20 },
   726	          });
   727	          const messages = Array.isArray(result?.data)
   728	            ? result.data
   729	            : (Array.isArray(result) ? result : []);
   730	
   731	          for (const entry of [...messages].reverse()) {
   732	            const info = entry?.info ?? entry?.message ?? entry;
   733	            if (info?.role !== 'user') {
   734	              continue;
   735	            }
   736	
   737	            const parts = Array.isArray(entry?.parts)
   738	              ? entry.parts
   739	              : (Array.isArray(info?.parts) ? info.parts : []);
   740	            const textPart = [...parts]
   740	            const textPart = [...parts]
   741	              .reverse()
   742	              .find((part) => part?.type === 'text' && typeof part.text === 'string' && part.text.trim());
   743	            if (textPart) {
   744	              prompt = textPart.text;
   745	              break;
   746	            }
   747	
   748	            prompt = extractPrompt(info);
   749	            if (prompt) {
   750	              break;
   751	            }
   752	          }
   753	        } catch {
   754	          prompt = null;
   755	        }
   756	      }
   757	
   758	      if (!prompt) {
   759	        state.lastBridgeStatus = 'skipped';
   760	        state.lastErrorCode = 'MISSING_PROMPT';
   761	        output.system.push(FALLBACK_DIRECTIVE);
   762	        return;
   763	      }
   764	
   765	      const response = await getAdvisorContext({
   766	        projectDir,
   767	        prompt,
   768	        sessionID,
   769	        options,
   770	      });
   771	      output.system.push(response.brief
   772	        ? clampBrief(response.brief, options.maxBriefChars)
   773	        : FALLBACK_DIRECTIVE);
   774	    } catch {
   775	      state.lastBridgeStatus = 'fail_open';
   776	      state.lastErrorCode = 'UNEXPECTED_HOOK_ERROR';
   777	      try {
   778	        if (options.enabled && Array.isArray(output.system) && !output.system.includes(FALLBACK_DIRECTIVE)) {
   779	          output.system.push(FALLBACK_DIRECTIVE);
   780	        }
   781	      } catch {
   782	        // A hostile output container must not turn advisor failure into prompt failure.
   783	      }
   784	    }
   785	  }
   786	
   787	  return {
   788	    event: async ({ event }) => {
   789	      const eventPayload = eventPayloadFrom(event);
   790	      const eventType = eventTypeFrom(event);
   791	
   792	      if (eventType === 'session.created') {
   793	        if (options.enabled) {
   794	          state.runtimeReady = true;
   795	          state.lastBridgeStatus = 'ready';
   796	        }
   797	        return;
   798	      }
   799	
   800	      if (eventType === 'session.deleted') {
