{"type":"tool_use","timestamp":1781151905471,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_NywBpnXHo8bcnR9XoQ7ThjB7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":260,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n260: function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n261:   const configured = resolveBm25Engine();\n262:   if (configured === 'legacy-inmemory') {\n263:     emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n264:     return 'legacy-inmemory';\n265:   }\n266: \n267:   if (configured === 'sqlite') {\n268:     emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n269:     return 'packed-inmemory';\n270:   }\n271: \n272:   if (configured === 'packed-inmemory') {\n273:     emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n274:     return 'packed-inmemory';\n275:   }\n276: \n277:   emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n278:   return 'packed-inmemory';\n279: }\n280: \n281: function buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n282:   return {\n283:     title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n284:     body: typeof row.content_text === 'string' && row.content_text.trim()\n285:       ? normalizeContentForBM25(row.content_text)\n286:       : '',\n287:     trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n288:     content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n289:   };\n290: }\n291: \n292: function buildBm25DocumentText(row: BM25DocumentSource): string {\n293:   const textParts: string[] = [];\n294: \n295:   if (typeof row.title === 'string' && row.title.trim()) {\n296:     textParts.push(row.title.trim());\n297:   }\n298: \n299:   if (typeof row.content_text === 'string' && row.content_text.trim()) {\n300:     textParts.push(normalizeContentForBM25(row.content_text));\n301:   }\n302: \n303:   const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n304:   if (triggerPhrases) {\n305:     textParts.push(triggerPhrases);\n306:   }\n307: \n308:   if (typeof row.file_path === 'string' && row.file_path.trim()) {\n309:     textParts.push(row.file_path.trim());\n310:   }\n311: \n312:   return textParts.join(' ').trim();\n313: }\n314: \n315: // ───────────────────────────────────────────────────────────────\n316: // 3. BM25 INDEX CLASS\n317: \n318: // ───────────────────────────────────────────────────────────────\n319: class BM25Index {\n320:   private k1: number;\n321:   private b: number;\n322:   private engine: InMemoryBm25Engine;\n323:   private documents: Map<string, LegacyDocumentRecord>;\n324:   private packedDocuments: Map<string, PackedDocumentRecord>;\n325:   private packedDocIds: string[];\n326:   private packedDocNumbersById: Map<string, number>;\n327:   private packedMutablePostings: Map<string, PackedPostingMutable>;\n328:   private packedPostings: Map<string, PackedPostingList>;\n329:   private packedDirtyTerms: Set<string>;\n330:   private documentFreq: Map<string, number>;\n331:   private totalDocLength: number;\n332:   private warmupHandle: ReturnType<typeof setTimeout> | null;\n333:   private warmupGeneration: number;\n334: \n335:   constructor(\n336:     k1: number = DEFAULT_K1,\n337:     b: number = DEFAULT_B,\n338:     engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n339:   ) {\n340:     this.k1 = k1;\n341:     this.b = b;\n342:     this.engine = engine;\n343:     this.documents = new Map();\n344:     this.packedDocuments = new Map();\n345:     this.packedDocIds = [];\n346:     this.packedDocNumbersById = new Map();\n347:     this.packedMutablePostings = new Map();\n348:     this.packedPostings = new Map();\n349:     this.packedDirtyTerms = new Set();\n350:     this.documentFreq = new Map();\n351:     this.totalDocLength = 0;\n352:     this.warmupHandle = null;\n353:     this.warmupGeneration = 0;\n354:   }\n355: \n356:   addDocument(id: string, text: string): void {\n357:     if (this.engine === 'packed-inmemory') {\n358:       this.addDocumentFields(id, { body: text });\n359:       return;\n360:     }\n361: \n362:     const tokens = tokenize(text);\n363:     const termFreq = getTermFrequencies(tokens);\n364: \n365:     if (this.documents.has(id)) {\n366:       this.removeDocument(id);\n367:     }\n368: \n369:     this.documents.set(id, { tokens, termFreq });\n370:     this.totalDocLength += tokens.length;\n371: \n372:     // Update document frequency\n373:     for (const term of termFreq.keys()) {\n374:       this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n375:     }\n376:   }\n377: \n378:   addDocumentFields(id: string, fields: BM25DocumentFields): void {\n379:     if (this.engine === 'legacy-inmemory') {\n380:       this.addDocument(id, this.joinDocumentFields(fields));\n381:       return;\n382:     }\n383: \n384:     if (this.packedDocuments.has(id)) {\n385:       this.removeDocument(id);\n386:     }\n387: \n388:     const termFreq = this.getPackedTermFrequencies(fields);\n389:     const length = Array.from(termFreq.values()).reduce((sum, freq) => sum + freq.total, 0);\n390:     if (length === 0) {\n391:       return;\n392:     }\n393: \n394:     const numericId = this.getPackedNumericId(id);\n395:     this.packedDocuments.set(id, { numericId, id, length, terms: Array.from(termFreq.keys()) });\n396:     this.totalDocLength += length;\n397: \n398:     for (const [term, frequency] of termFreq) {\n399:       const postings = this.ensurePackedMutablePostings(term);\n400:       this.setPackedMutablePosting(postings, numericId, frequency);\n401:       this.packedDirtyTerms.add(term);\n402:       this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n403:     }\n404:   }\n405: \n406:   removeDocument(id: string): boolean {\n407:     if (this.engine === 'packed-inmemory') {\n408:       return this.removePackedDocument(id);\n409:     }\n410: \n411:     const doc = this.documents.get(id);\n412:     if (!doc) return false;\n413: \n414:     this.totalDocLength -= doc.tokens.length;\n415: \n416:     for (const term of doc.termFreq.keys()) {\n417:       const count = this.documentFreq.get(term) || 0;\n418:       if (count <= 1) {\n419:         this.documentFreq.delete(term);\n420:       } else {\n421:         this.documentFreq.set(term, count - 1);\n422:       }\n423:     }\n424: \n425:     this.documents.delete(id);\n426:     return true;\n427:   }\n428: \n429:   calculateIdf(term: string): number {\n430:     const n = this.getDocumentCount();\n431:     const df = this.documentFreq.get(term) || 0;\n432:     if (df === 0 || n === 0) return 0;\n433:     return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n434:   }\n435: \n436:   calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n437:     if (this.engine === 'packed-inmemory') {\n438:       return this.calculatePackedScore(queryTokens, docId, options);\n439:     }\n440: \n441:     const doc = this.documents.get(docId);\n442:     if (!doc) return 0;\n443: \n444:     const avgDl = this.getAverageDocumentLength();\n445:     const dl = doc.tokens.length;\n446: \n447:     let score = 0;\n448:     for (const term of queryTokens) {\n449:       const tf = doc.termFreq.get(term) || 0;\n450:       if (tf === 0) continue;\n451: \n452:       const idf = this.calculateIdf(term);\n453:       const numerator = tf * (this.k1 + 1);\n454:       const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n455:       score += idf * (numerator / denominator);\n456:     }\n457: \n458:     return score;\n459:   }\n460: \n461:   search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n462:     const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n463:     if (queryTokens.length === 0) return [];\n464: \n465:     if (this.engine === 'packed-inmemory') {\n466:       return this.searchPacked(queryTokens, limit, options);\n467:     }\n468: \n469:     const results: BM25SearchResult[] = [];\n470: \n471:     for (const [id] of this.documents) {\n472:       const score = this.calculateScore(queryTokens, id);\n473:       if (score > 0) {\n474:         results.push({ id, score });\n475:       }\n476:     }\n477: \n478:     return results\n479:       .sort((a, b) => b.score - a.score)\n480:       .slice(0, limit);\n481:   }\n482: \n483:   getStats(): BM25Stats {\n484:     return {\n485:       documentCount: this.getDocumentCount(),\n486:       termCount: this.documentFreq.size,\n487:       avgDocLength: this.getAverageDocumentLength(),\n488:     };\n489:   }\n490: \n491:   clear(): void {\n492:     this.cancelWarmup();\n493:     this.documents.clear();\n494:     this.packedDocuments.clear();\n495:     this.packedDocIds = [];\n496:     this.packedDocNumbersById.clear();\n497:     this.packedMutablePostings.clear();\n498:     this.packedPostings.clear();\n499:     this.packedDirtyTerms.clear();\n500:     this.documentFreq.clear();\n501:     this.totalDocLength = 0;\n502:   }\n503: \n504:   addDocuments(docs: Array<{ id: string; text: string }>): void {\n505:     for (const doc of docs) {\n506:       this.addDocument(doc.id, doc.text);\n507:     }\n508:   }\n509: \n510:   finalizePackedPostings(): void {\n511:     if (this.engine === 'legacy-inmemory') {\n512:       return;\n513:     }\n514: \n515:     for (const term of Array.from(this.packedDirtyTerms)) {\n516:       this.getPackedPosting(term);\n517:     }\n518:     this.packedMutablePostings.clear();\n519:   }\n520: \n521:   /**\n522:    * Incrementally synchronize changed rows from the database into the in-memory index.\n523:    */\n524:   syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n525:     const normalizedIds = Array.from(\n526:       new Set(\n527:         rowIds\n528:           .map((rowId) => Number(rowId))\n529:           .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n530:       )\n531:     );\n532: \n533:     if (normalizedIds.length === 0) {\n534:       return 0;\n535:     }\n536: \n537:     try {\n538:       const placeholders = normalizedIds.map(() => '?').join(', ');\n539:       const rows = (database.prepare(\n540:         `SELECT id, title, content_text, trigger_phrases, file_path\n541:          FROM memory_index\n542:          WHERE id IN (${placeholders})`\n543:       ) as Database.Statement).all(...normalizedIds) as Array<{\n544:         id: number;\n545:         title: string | null;\n546:         content_text: string | null;\n547:         trigger_phrases: string | null;\n548:         file_path: string | null;\n549:       }>;\n550: \n551:       const activeRowMap = new Map<number, typeof rows[number]>();\n552:       for (const row of rows) {\n553:         activeRowMap.set(row.id, row);\n554:       }\n555: \n556:       for (const rowId of normalizedIds) {\n557:         const row = activeRowMap.get(rowId);\n558:         if (!row) {\n559:           this.removeDocument(String(rowId));\n560:           continue;\n561:         }\n562: \n563:         const fields = buildBm25DocumentFields(row);\n564:         if (this.joinDocumentFields(fields).trim()) {\n565:           this.addDocumentFields(String(row.id), fields);\n566:         } else {\n567:           this.removeDocument(String(row.id));\n568:         }\n569:       }\n570: \n571:       return normalizedIds.length;\n572:     } catch (error: unknown) {\n573:       const msg = error instanceof Error ? error.message : String(error);\n574:       console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n575:       return 0;\n576:     }\n577:   }\n578: \n579:   /**\n580:    * Defer full startup warmup into batched row-ID syncs so process\n581:    * initialization is not blocked by a monolithic in-memory rebuild.\n582:    */\n583:   rebuildFromDatabase(database: Database.Database): number {\n584:     this.clear();\n585: \n586:     try {\n587:       const rows = (database.prepare(\n588:         `SELECT id\n589:          FROM memory_index\n590:          ORDER BY id`\n591:       ) as Database.Statement).all() as Array<{ id: number }>;\n592: \n593:       const pendingIds = rows.map((row) => row.id);\n594:       if (pendingIds.length === 0) {\n595:         return 0;\n596:       }\n597: \n598:       const warmupGeneration = ++this.warmupGeneration;\n599:       const processBatch = () => {\n600:         if (warmupGeneration !== this.warmupGeneration) {\n601:           return;\n602:         }\n603: \n604:         const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n605:         if (batchIds.length === 0) {\n606:           this.finalizePackedPostings();\n607:           this.warmupHandle = null;\n608:           return;\n609:         }\n610: \n611:         this.syncChangedRows(database, batchIds);\n612: \n613:         if (pendingIds.length > 0) {\n614:           this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n615:         } else {\n616:           this.warmupHandle = null;\n617:         }\n618:       };\n619: \n\n(Showing lines 260-619 of 1095. Use offset=620 to continue.)\n</content>","metadata":{"preview":"function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n  const configured = resolveBm25Engine();\n  if (configured === 'legacy-inmemory') {\n    emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n    return 'legacy-inmemory';\n  }\n\n  if (configured === 'sqlite') {\n    emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n    return 'packed-inmemory';\n  }\n\n  if (configured === 'packed-inmemory') {\n    emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n    return 'packed-inmemory';\n  }\n\n  emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n  return 'packed-inmemory';\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n  const configured = resolveBm25Engine();\n  if (configured === 'legacy-inmemory') {\n    emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n    return 'legacy-inmemory';\n  }\n\n  if (configured === 'sqlite') {\n    emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n    return 'packed-inmemory';\n  }\n\n  if (configured === 'packed-inmemory') {\n    emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n    return 'packed-inmemory';\n  }\n\n  emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n  return 'packed-inmemory';\n}\n\nfunction buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n  return {\n    title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n    body: typeof row.content_text === 'string' && row.content_text.trim()\n      ? normalizeContentForBM25(row.content_text)\n      : '',\n    trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n    content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n  };\n}\n\nfunction buildBm25DocumentText(row: BM25DocumentSource): string {\n  const textParts: string[] = [];\n\n  if (typeof row.title === 'string' && row.title.trim()) {\n    textParts.push(row.title.trim());\n  }\n\n  if (typeof row.content_text === 'string' && row.content_text.trim()) {\n    textParts.push(normalizeContentForBM25(row.content_text));\n  }\n\n  const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n  if (triggerPhrases) {\n    textParts.push(triggerPhrases);\n  }\n\n  if (typeof row.file_path === 'string' && row.file_path.trim()) {\n    textParts.push(row.file_path.trim());\n  }\n\n  return textParts.join(' ').trim();\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. BM25 INDEX CLASS\n\n// ───────────────────────────────────────────────────────────────\nclass BM25Index {\n  private k1: number;\n  private b: number;\n  private engine: InMemoryBm25Engine;\n  private documents: Map<string, LegacyDocumentRecord>;\n  private packedDocuments: Map<string, PackedDocumentRecord>;\n  private packedDocIds: string[];\n  private packedDocNumbersById: Map<string, number>;\n  private packedMutablePostings: Map<string, PackedPostingMutable>;\n  private packedPostings: Map<string, PackedPostingList>;\n  private packedDirtyTerms: Set<string>;\n  private documentFreq: Map<string, number>;\n  private totalDocLength: number;\n  private warmupHandle: ReturnType<typeof setTimeout> | null;\n  private warmupGeneration: number;\n\n  constructor(\n    k1: number = DEFAULT_K1,\n    b: number = DEFAULT_B,\n    engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n  ) {\n    this.k1 = k1;\n    this.b = b;\n    this.engine = engine;\n    this.documents = new Map();\n    this.packedDocuments = new Map();\n    this.packedDocIds = [];\n    this.packedDocNumbersById = new Map();\n    this.packedMutablePostings = new Map();\n    this.packedPostings = new Map();\n    this.packedDirtyTerms = new Set();\n    this.documentFreq = new Map();\n    this.totalDocLength = 0;\n    this.warmupHandle = null;\n    this.warmupGeneration = 0;\n  }\n\n  addDocument(id: string, text: string): void {\n    if (this.engine === 'packed-inmemory') {\n      this.addDocumentFields(id, { body: text });\n      return;\n    }\n\n    const tokens = tokenize(text);\n    const termFreq = getTermFrequencies(tokens);\n\n    if (this.documents.has(id)) {\n      this.removeDocument(id);\n    }\n\n    this.documents.set(id, { tokens, termFreq });\n    this.totalDocLength += tokens.length;\n\n    // Update document frequency\n    for (const term of termFreq.keys()) {\n      this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n    }\n  }\n\n  addDocumentFields(id: string, fields: BM25DocumentFields): void {\n    if (this.engine === 'legacy-inmemory') {\n      this.addDocument(id, this.joinDocumentFields(fields));\n      return;\n    }\n\n    if (this.packedDocuments.has(id)) {\n      this.removeDocument(id);\n    }\n\n    const termFreq = this.getPackedTermFrequencies(fields);\n    const length = Array.from(termFreq.values()).reduce((sum, freq) => sum + freq.total, 0);\n    if (length === 0) {\n      return;\n    }\n\n    const numericId = this.getPackedNumericId(id);\n    this.packedDocuments.set(id, { numericId, id, length, terms: Array.from(termFreq.keys()) });\n    this.totalDocLength += length;\n\n    for (const [term, frequency] of termFreq) {\n      const postings = this.ensurePackedMutablePostings(term);\n      this.setPackedMutablePosting(postings, numericId, frequency);\n      this.packedDirtyTerms.add(term);\n      this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n    }\n  }\n\n  removeDocument(id: string): boolean {\n    if (this.engine === 'packed-inmemory') {\n      return this.removePackedDocument(id);\n    }\n\n    const doc = this.documents.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.tokens.length;\n\n    for (const term of doc.termFreq.keys()) {\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.documents.delete(id);\n    return true;\n  }\n\n  calculateIdf(term: string): number {\n    const n = this.getDocumentCount();\n    const df = this.documentFreq.get(term) || 0;\n    if (df === 0 || n === 0) return 0;\n    return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n  }\n\n  calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n    if (this.engine === 'packed-inmemory') {\n      return this.calculatePackedScore(queryTokens, docId, options);\n    }\n\n    const doc = this.documents.get(docId);\n    if (!doc) return 0;\n\n    const avgDl = this.getAverageDocumentLength();\n    const dl = doc.tokens.length;\n\n    let score = 0;\n    for (const term of queryTokens) {\n      const tf = doc.termFreq.get(term) || 0;\n      if (tf === 0) continue;\n\n      const idf = this.calculateIdf(term);\n      const numerator = tf * (this.k1 + 1);\n      const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n      score += idf * (numerator / denominator);\n    }\n\n    return score;\n  }\n\n  search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n    const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n    if (queryTokens.length === 0) return [];\n\n    if (this.engine === 'packed-inmemory') {\n      return this.searchPacked(queryTokens, limit, options);\n    }\n\n    const results: BM25SearchResult[] = [];\n\n    for (const [id] of this.documents) {\n      const score = this.calculateScore(queryTokens, id);\n      if (score > 0) {\n        results.push({ id, score });\n      }\n    }\n\n    return results\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  getStats(): BM25Stats {\n    return {\n      documentCount: this.getDocumentCount(),\n      termCount: this.documentFreq.size,\n      avgDocLength: this.getAverageDocumentLength(),\n    };\n  }\n\n  clear(): void {\n    this.cancelWarmup();\n    this.documents.clear();\n    this.packedDocuments.clear();\n    this.packedDocIds = [];\n    this.packedDocNumbersById.clear();\n    this.packedMutablePostings.clear();\n    this.packedPostings.clear();\n    this.packedDirtyTerms.clear();\n    this.documentFreq.clear();\n    this.totalDocLength = 0;\n  }\n\n  addDocuments(docs: Array<{ id: string; text: string }>): void {\n    for (const doc of docs) {\n      this.addDocument(doc.id, doc.text);\n    }\n  }\n\n  finalizePackedPostings(): void {\n    if (this.engine === 'legacy-inmemory') {\n      return;\n    }\n\n    for (const term of Array.from(this.packedDirtyTerms)) {\n      this.getPackedPosting(term);\n    }\n    this.packedMutablePostings.clear();\n  }\n\n  /**\n   * Incrementally synchronize changed rows from the database into the in-memory index.\n   */\n  syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n    const normalizedIds = Array.from(\n      new Set(\n        rowIds\n          .map((rowId) => Number(rowId))\n          .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n      )\n    );\n\n    if (normalizedIds.length === 0) {\n      return 0;\n    }\n\n    try {\n      const placeholders = normalizedIds.map(() => '?').join(', ');\n      const rows = (database.prepare(\n        `SELECT id, title, content_text, trigger_phrases, file_path\n         FROM memory_index\n         WHERE id IN (${placeholders})`\n      ) as Database.Statement).all(...normalizedIds) as Array<{\n        id: number;\n        title: string | null;\n        content_text: string | null;\n        trigger_phrases: string | null;\n        file_path: string | null;\n      }>;\n\n      const activeRowMap = new Map<number, typeof rows[number]>();\n      for (const row of rows) {\n        activeRowMap.set(row.id, row);\n      }\n\n      for (const rowId of normalizedIds) {\n        const row = activeRowMap.get(rowId);\n        if (!row) {\n          this.removeDocument(String(rowId));\n          continue;\n        }\n\n        const fields = buildBm25DocumentFields(row);\n        if (this.joinDocumentFields(fields).trim()) {\n          this.addDocumentFields(String(row.id), fields);\n        } else {\n          this.removeDocument(String(row.id));\n        }\n      }\n\n      return normalizedIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n      return 0;\n    }\n  }\n\n  /**\n   * Defer full startup warmup into batched row-ID syncs so process\n   * initialization is not blocked by a monolithic in-memory rebuild.\n   */\n  rebuildFromDatabase(database: Database.Database): number {\n    this.clear();\n\n    try {\n      const rows = (database.prepare(\n        `SELECT id\n         FROM memory_index\n         ORDER BY id`\n      ) as Database.Statement).all() as Array<{ id: number }>;\n\n      const pendingIds = rows.map((row) => row.id);\n      if (pendingIds.length === 0) {\n        return 0;\n      }\n\n      const warmupGeneration = ++this.warmupGeneration;\n      const processBatch = () => {\n        if (warmupGeneration !== this.warmupGeneration) {\n          return;\n        }\n\n        const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n        if (batchIds.length === 0) {\n          this.finalizePackedPostings();\n          this.warmupHandle = null;\n          return;\n        }\n\n        this.syncChangedRows(database, batchIds);\n\n        if (pendingIds.length > 0) {\n          this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n        } else {\n          this.warmupHandle = null;\n        }\n      };\n","lineStart":260,"lineEnd":619,"totalLines":1095,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781151905465,"end":1781151905470}},"metadata":{"openai":{"itemId":"fc_0e4f10340aca1d7f016a2a38a16df88191baffd336d6f1e991"}},"id":"prt_eb4ed36b2001UKJtahKLSnS55Z","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ed20a9001RJjjy09djEqgI5"}}
{"type":"tool_use","timestamp":1781151905518,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_DETfdjNC2LTrVrg0nQoKg4XL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":620,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n620:       this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n621:       return pendingIds.length;\n622:     } catch (error: unknown) {\n623:       const msg = error instanceof Error ? error.message : String(error);\n624:       console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n625:       return 0;\n626:     }\n627:   }\n628: \n629:   cancelWarmup(): void {\n630:     this.warmupGeneration += 1;\n631:     if (this.warmupHandle) {\n632:       clearRegisteredTimer(this.warmupHandle);\n633:       this.warmupHandle = null;\n634:     }\n635:   }\n636: \n637:   private getDocumentCount(): number {\n638:     return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n639:   }\n640: \n641:   private getAverageDocumentLength(): number {\n642:     const documentCount = this.getDocumentCount();\n643:     return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n644:   }\n645: \n646:   private joinDocumentFields(fields: BM25DocumentFields): string {\n647:     const parts: string[] = [];\n648:     for (const fieldName of BM25_FIELD_NAMES) {\n649:       const value = fields[fieldName];\n650:       if (Array.isArray(value)) {\n651:         parts.push(value.join(' '));\n652:       } else if (typeof value === 'string' && value.trim()) {\n653:         parts.push(value.trim());\n654:       }\n655:     }\n656:     return parts.join(' ').trim();\n657:   }\n658: \n659:   private getPackedNumericId(id: string): number {\n660:     const existing = this.packedDocNumbersById.get(id);\n661:     if (existing !== undefined) {\n662:       return existing;\n663:     }\n664: \n665:     const numericId = this.packedDocIds.length;\n666:     this.packedDocIds.push(id);\n667:     this.packedDocNumbersById.set(id, numericId);\n668:     return numericId;\n669:   }\n670: \n671:   private getPackedTermFrequencies(fields: BM25DocumentFields): Map<string, PackedTermFrequency> {\n672:     const termFreq = new Map<string, PackedTermFrequency>();\n673: \n674:     for (const fieldName of BM25_FIELD_NAMES) {\n675:       const rawValue = fields[fieldName];\n676:       const text = Array.isArray(rawValue) ? rawValue.join(' ') : (rawValue ?? '');\n677:       visitBm25Tokens(text, (token) => {\n678:         let frequency = termFreq.get(token);\n679:         if (!frequency) {\n680:           frequency = defaultPackedTermFrequency();\n681:           termFreq.set(token, frequency);\n682:         }\n683:         frequency.total += 1;\n684:         frequency.fields[fieldName] += 1;\n685:       });\n686:     }\n687: \n688:     return termFreq;\n689:   }\n690: \n691:   private removePackedDocument(id: string): boolean {\n692:     const doc = this.packedDocuments.get(id);\n693:     if (!doc) return false;\n694: \n695:     this.totalDocLength -= doc.length;\n696: \n697:     for (const term of doc.terms) {\n698:       const postings = this.ensurePackedMutablePostings(term);\n699:       this.deletePackedMutablePosting(postings, doc.numericId);\n700:       this.packedDirtyTerms.add(term);\n701: \n702:       const count = this.documentFreq.get(term) || 0;\n703:       if (count <= 1) {\n704:         this.documentFreq.delete(term);\n705:         this.packedMutablePostings.delete(term);\n706:         this.packedPostings.delete(term);\n707:       } else {\n708:         this.documentFreq.set(term, count - 1);\n709:       }\n710:     }\n711: \n712:     this.packedDocuments.delete(id);\n713:     return true;\n714:   }\n715: \n716:   private getPackedPosting(term: string): PackedPostingList | undefined {\n717:     if (!this.packedDirtyTerms.has(term)) {\n718:       return this.packedPostings.get(term);\n719:     }\n720: \n721:     const mutable = this.packedMutablePostings.get(term);\n722:     if (!mutable || mutable.docIds.length === 0) {\n723:       this.packedDirtyTerms.delete(term);\n724:       this.packedPostings.delete(term);\n725:       return undefined;\n726:     }\n727: \n728:     this.sortPackedMutablePosting(mutable);\n729: \n730:     const packed: PackedPostingList = {\n731:       docIds: Uint32Array.from(mutable.docIds),\n732:       totalTfs: Uint32Array.from(mutable.totalTfs),\n733:       titleTfs: Uint32Array.from(mutable.titleTfs),\n734:       triggerTfs: Uint32Array.from(mutable.triggerTfs),\n735:       pathTfs: Uint32Array.from(mutable.pathTfs),\n736:       bodyTfs: Uint32Array.from(mutable.bodyTfs),\n737:     };\n738:     this.packedPostings.set(term, packed);\n739:     this.packedDirtyTerms.delete(term);\n740:     return packed;\n741:   }\n742: \n743:   private ensurePackedMutablePostings(term: string): PackedPostingMutable {\n744:     const existing = this.packedMutablePostings.get(term);\n745:     if (existing) {\n746:       return existing;\n747:     }\n748: \n749:     const hydrated: PackedPostingMutable = {\n750:       docIds: [],\n751:       totalTfs: [],\n752:       titleTfs: [],\n753:       triggerTfs: [],\n754:       pathTfs: [],\n755:       bodyTfs: [],\n756:     };\n757:     const packed = this.packedPostings.get(term);\n758:     if (packed) {\n759:       for (let i = 0; i < packed.docIds.length; i += 1) {\n760:         hydrated.docIds.push(packed.docIds[i]);\n761:         hydrated.totalTfs.push(packed.totalTfs[i]);\n762:         hydrated.titleTfs.push(packed.titleTfs[i]);\n763:         hydrated.triggerTfs.push(packed.triggerTfs[i]);\n764:         hydrated.pathTfs.push(packed.pathTfs[i]);\n765:         hydrated.bodyTfs.push(packed.bodyTfs[i]);\n766:       }\n767:     }\n768: \n769:     this.packedMutablePostings.set(term, hydrated);\n770:     return hydrated;\n771:   }\n772: \n773:   private setPackedMutablePosting(\n774:     postings: PackedPostingMutable,\n775:     numericId: number,\n776:     frequency: PackedTermFrequency\n777:   ): void {\n778:     const existingIndex = postings.docIds.indexOf(numericId);\n779:     if (existingIndex >= 0) {\n780:       postings.totalTfs[existingIndex] = frequency.total;\n781:       postings.titleTfs[existingIndex] = frequency.fields.title;\n782:       postings.triggerTfs[existingIndex] = frequency.fields.trigger_phrases;\n783:       postings.pathTfs[existingIndex] = frequency.fields.content_generic;\n784:       postings.bodyTfs[existingIndex] = frequency.fields.body;\n785:       return;\n786:     }\n787: \n788:     postings.docIds.push(numericId);\n789:     postings.totalTfs.push(frequency.total);\n790:     postings.titleTfs.push(frequency.fields.title);\n791:     postings.triggerTfs.push(frequency.fields.trigger_phrases);\n792:     postings.pathTfs.push(frequency.fields.content_generic);\n793:     postings.bodyTfs.push(frequency.fields.body);\n794:   }\n795: \n796:   private deletePackedMutablePosting(postings: PackedPostingMutable, numericId: number): void {\n797:     const index = postings.docIds.indexOf(numericId);\n798:     if (index < 0) {\n799:       return;\n800:     }\n801:     postings.docIds.splice(index, 1);\n802:     postings.totalTfs.splice(index, 1);\n803:     postings.titleTfs.splice(index, 1);\n804:     postings.triggerTfs.splice(index, 1);\n805:     postings.pathTfs.splice(index, 1);\n806:     postings.bodyTfs.splice(index, 1);\n807:   }\n808: \n809:   private sortPackedMutablePosting(postings: PackedPostingMutable): void {\n810:     const order = postings.docIds.map((docId, index) => ({ docId, index }));\n811:     order.sort((a, b) => a.docId - b.docId);\n812: \n813:     postings.docIds = order.map((entry) => entry.docId);\n814:     postings.totalTfs = order.map((entry) => postings.totalTfs[entry.index]);\n815:     postings.titleTfs = order.map((entry) => postings.titleTfs[entry.index]);\n816:     postings.triggerTfs = order.map((entry) => postings.triggerTfs[entry.index]);\n817:     postings.pathTfs = order.map((entry) => postings.pathTfs[entry.index]);\n818:     postings.bodyTfs = order.map((entry) => postings.bodyTfs[entry.index]);\n819:   }\n820: \n821:   private calculatePackedScore(\n822:     queryTokens: string[],\n823:     docId: string,\n824:     options: BM25SearchOptions\n825:   ): number {\n826:     const doc = this.packedDocuments.get(docId);\n827:     if (!doc) return 0;\n828: \n829:     const weights = resolveBm25FieldWeights(options.fieldWeights);\n830:     const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n831:     let score = 0;\n832: \n833:     for (const term of queryTokens) {\n834:       const postings = this.getPackedPosting(term);\n835:       if (!postings) continue;\n836:       const postingIndex = this.findPackedPostingIndex(postings, doc.numericId);\n837:       if (postingIndex < 0) continue;\n838: \n839:       const weightedTf = this.calculateWeightedPostingFrequency(postings, postingIndex, weights);\n840:       if (weightedTf <= 0) continue;\n841: \n842:       const idf = this.calculateIdf(term);\n843:       score += this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n844:     }\n845: \n846:     return score;\n847:   }\n848: \n849:   private searchPacked(\n850:     queryTokens: string[],\n851:     limit: number,\n852:     options: BM25SearchOptions\n853:   ): BM25SearchResult[] {\n854:     const weights = resolveBm25FieldWeights(options.fieldWeights);\n855:     const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n856:     const scores = new Map<number, number>();\n857: \n858:     for (const term of queryTokens) {\n859:       const postings = this.getPackedPosting(term);\n860:       if (!postings) continue;\n861: \n862:       const idf = this.calculateIdf(term);\n863:       for (let i = 0; i < postings.docIds.length; i += 1) {\n864:         const numericId = postings.docIds[i];\n865:         const id = this.packedDocIds[numericId];\n866:         if (!id) continue;\n867:         const doc = this.packedDocuments.get(id);\n868:         if (!doc) continue;\n869: \n870:         const weightedTf = this.calculateWeightedPostingFrequency(postings, i, weights);\n871:         if (weightedTf <= 0) continue;\n872: \n873:         const termScore = this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n874:         scores.set(numericId, (scores.get(numericId) || 0) + termScore);\n875:       }\n876:     }\n877: \n878:     return Array.from(scores.entries())\n879:       .map(([numericId, score]) => ({ id: this.packedDocIds[numericId], score }))\n880:       .filter((result): result is BM25SearchResult => typeof result.id === 'string' && result.score > 0)\n881:       .sort((a, b) => b.score - a.score)\n882:       .slice(0, limit);\n883:   }\n884: \n885:   private calculateWeightedPostingFrequency(\n886:     postings: PackedPostingList,\n887:     index: number,\n888:     weights: BM25FieldWeights\n889:   ): number {\n890:     return (\n891:       postings.titleTfs[index] * weights.title +\n892:       postings.triggerTfs[index] * weights.trigger_phrases +\n893:       postings.pathTfs[index] * weights.content_generic +\n894:       postings.bodyTfs[index] * weights.body\n895:     );\n896:   }\n897: \n898:   private findPackedPostingIndex(postings: PackedPostingList, numericId: number): number {\n899:     let low = 0;\n900:     let high = postings.docIds.length - 1;\n901:     while (low <= high) {\n902:       const mid = Math.floor((low + high) / 2);\n903:       const value = postings.docIds[mid];\n904:       if (value === numericId) return mid;\n905:       if (value < numericId) {\n906:         low = mid + 1;\n907:       } else {\n908:         high = mid - 1;\n909:       }\n910:     }\n911:     return -1;\n912:   }\n913: \n914:   private calculateBm25TermScore(tf: number, dl: number, avgDl: number, idf: number): number {\n915:     const numerator = tf * (this.k1 + 1);\n916:     const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / avgDl));\n917:     return idf * (numerator / denominator);\n918:   }\n919: }\n920: \n921: // ───────────────────────────────────────────────────────────────\n922: // 4. SINGLETON\n923: \n924: // ───────────────────────────────────────────────────────────────\n925: let indexInstance: BM25Index | null = null;\n926: \n927: /**\n928:  * Retrieve the shared in-memory BM25 index singleton.\n929:  *\n930:  * @returns The process-wide {@link BM25Index} instance.\n931:  * @example\n932:  * ```ts\n933:  * const index = getIndex();\n934:  * index.addDocument('123', 'memory search');\n935:  * ```\n936:  */\n937: function getIndex(): BM25Index {\n938:   if (!indexInstance) {\n939:     indexInstance = new BM25Index();\n940:   }\n941:   return indexInstance;\n942: }\n943: \n944: /**\n945:  * Reset the shared BM25 index singleton.\n946:  *\n947:  * @returns Nothing.\n948:  * @example\n949:  * ```ts\n950:  * resetIndex();\n951:  * ```\n952:  */\n953: function resetIndex(): void {\n954:   indexInstance?.cancelWarmup();\n955:   indexInstance = null;\n956: }\n957: \n958: // ───────────────────────────────────────────────────────────────\n959: // 5. LEXICAL ENGINE ROUTING\n960: \n961: // ───────────────────────────────────────────────────────────────\n962: function resolveBm25Engine(): Bm25Engine {\n963:   const value = process.env.SPECKIT_BM25_ENGINE?.trim().toLowerCase();\n964:   if (!value) {\n965:     return 'auto';\n966:   }\n967: \n968:   if ((BM25_ENGINE_VALUES as readonly string[]).includes(value)) {\n969:     return value as Bm25Engine;\n970:   }\n971: \n972:   console.warn(`[bm25-index] Unsupported SPECKIT_BM25_ENGINE=${value}; falling back to auto`);\n973:   return 'auto';\n974: }\n975: \n976: function isMemoryFtsAvailable(database: Database.Database | null | undefined): boolean {\n977:   if (!database) {\n978:     return false;\n979:   }\n\n(Showing lines 620-979 of 1095. Use offset=980 to continue.)\n</content>","metadata":{"preview":"      this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n      return pendingIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n      return 0;\n    }\n  }\n\n  cancelWarmup(): void {\n    this.warmupGeneration += 1;\n    if (this.warmupHandle) {\n      clearRegisteredTimer(this.warmupHandle);\n      this.warmupHandle = null;\n    }\n  }\n\n  private getDocumentCount(): number {\n    return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"      this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n      return pendingIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n      return 0;\n    }\n  }\n\n  cancelWarmup(): void {\n    this.warmupGeneration += 1;\n    if (this.warmupHandle) {\n      clearRegisteredTimer(this.warmupHandle);\n      this.warmupHandle = null;\n    }\n  }\n\n  private getDocumentCount(): number {\n    return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n  }\n\n  private getAverageDocumentLength(): number {\n    const documentCount = this.getDocumentCount();\n    return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n  }\n\n  private joinDocumentFields(fields: BM25DocumentFields): string {\n    const parts: string[] = [];\n    for (const fieldName of BM25_FIELD_NAMES) {\n      const value = fields[fieldName];\n      if (Array.isArray(value)) {\n        parts.push(value.join(' '));\n      } else if (typeof value === 'string' && value.trim()) {\n        parts.push(value.trim());\n      }\n    }\n    return parts.join(' ').trim();\n  }\n\n  private getPackedNumericId(id: string): number {\n    const existing = this.packedDocNumbersById.get(id);\n    if (existing !== undefined) {\n      return existing;\n    }\n\n    const numericId = this.packedDocIds.length;\n    this.packedDocIds.push(id);\n    this.packedDocNumbersById.set(id, numericId);\n    return numericId;\n  }\n\n  private getPackedTermFrequencies(fields: BM25DocumentFields): Map<string, PackedTermFrequency> {\n    const termFreq = new Map<string, PackedTermFrequency>();\n\n    for (const fieldName of BM25_FIELD_NAMES) {\n      const rawValue = fields[fieldName];\n      const text = Array.isArray(rawValue) ? rawValue.join(' ') : (rawValue ?? '');\n      visitBm25Tokens(text, (token) => {\n        let frequency = termFreq.get(token);\n        if (!frequency) {\n          frequency = defaultPackedTermFrequency();\n          termFreq.set(token, frequency);\n        }\n        frequency.total += 1;\n        frequency.fields[fieldName] += 1;\n      });\n    }\n\n    return termFreq;\n  }\n\n  private removePackedDocument(id: string): boolean {\n    const doc = this.packedDocuments.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.length;\n\n    for (const term of doc.terms) {\n      const postings = this.ensurePackedMutablePostings(term);\n      this.deletePackedMutablePosting(postings, doc.numericId);\n      this.packedDirtyTerms.add(term);\n\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n        this.packedMutablePostings.delete(term);\n        this.packedPostings.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.packedDocuments.delete(id);\n    return true;\n  }\n\n  private getPackedPosting(term: string): PackedPostingList | undefined {\n    if (!this.packedDirtyTerms.has(term)) {\n      return this.packedPostings.get(term);\n    }\n\n    const mutable = this.packedMutablePostings.get(term);\n    if (!mutable || mutable.docIds.length === 0) {\n      this.packedDirtyTerms.delete(term);\n      this.packedPostings.delete(term);\n      return undefined;\n    }\n\n    this.sortPackedMutablePosting(mutable);\n\n    const packed: PackedPostingList = {\n      docIds: Uint32Array.from(mutable.docIds),\n      totalTfs: Uint32Array.from(mutable.totalTfs),\n      titleTfs: Uint32Array.from(mutable.titleTfs),\n      triggerTfs: Uint32Array.from(mutable.triggerTfs),\n      pathTfs: Uint32Array.from(mutable.pathTfs),\n      bodyTfs: Uint32Array.from(mutable.bodyTfs),\n    };\n    this.packedPostings.set(term, packed);\n    this.packedDirtyTerms.delete(term);\n    return packed;\n  }\n\n  private ensurePackedMutablePostings(term: string): PackedPostingMutable {\n    const existing = this.packedMutablePostings.get(term);\n    if (existing) {\n      return existing;\n    }\n\n    const hydrated: PackedPostingMutable = {\n      docIds: [],\n      totalTfs: [],\n      titleTfs: [],\n      triggerTfs: [],\n      pathTfs: [],\n      bodyTfs: [],\n    };\n    const packed = this.packedPostings.get(term);\n    if (packed) {\n      for (let i = 0; i < packed.docIds.length; i += 1) {\n        hydrated.docIds.push(packed.docIds[i]);\n        hydrated.totalTfs.push(packed.totalTfs[i]);\n        hydrated.titleTfs.push(packed.titleTfs[i]);\n        hydrated.triggerTfs.push(packed.triggerTfs[i]);\n        hydrated.pathTfs.push(packed.pathTfs[i]);\n        hydrated.bodyTfs.push(packed.bodyTfs[i]);\n      }\n    }\n\n    this.packedMutablePostings.set(term, hydrated);\n    return hydrated;\n  }\n\n  private setPackedMutablePosting(\n    postings: PackedPostingMutable,\n    numericId: number,\n    frequency: PackedTermFrequency\n  ): void {\n    const existingIndex = postings.docIds.indexOf(numericId);\n    if (existingIndex >= 0) {\n      postings.totalTfs[existingIndex] = frequency.total;\n      postings.titleTfs[existingIndex] = frequency.fields.title;\n      postings.triggerTfs[existingIndex] = frequency.fields.trigger_phrases;\n      postings.pathTfs[existingIndex] = frequency.fields.content_generic;\n      postings.bodyTfs[existingIndex] = frequency.fields.body;\n      return;\n    }\n\n    postings.docIds.push(numericId);\n    postings.totalTfs.push(frequency.total);\n    postings.titleTfs.push(frequency.fields.title);\n    postings.triggerTfs.push(frequency.fields.trigger_phrases);\n    postings.pathTfs.push(frequency.fields.content_generic);\n    postings.bodyTfs.push(frequency.fields.body);\n  }\n\n  private deletePackedMutablePosting(postings: PackedPostingMutable, numericId: number): void {\n    const index = postings.docIds.indexOf(numericId);\n    if (index < 0) {\n      return;\n    }\n    postings.docIds.splice(index, 1);\n    postings.totalTfs.splice(index, 1);\n    postings.titleTfs.splice(index, 1);\n    postings.triggerTfs.splice(index, 1);\n    postings.pathTfs.splice(index, 1);\n    postings.bodyTfs.splice(index, 1);\n  }\n\n  private sortPackedMutablePosting(postings: PackedPostingMutable): void {\n    const order = postings.docIds.map((docId, index) => ({ docId, index }));\n    order.sort((a, b) => a.docId - b.docId);\n\n    postings.docIds = order.map((entry) => entry.docId);\n    postings.totalTfs = order.map((entry) => postings.totalTfs[entry.index]);\n    postings.titleTfs = order.map((entry) => postings.titleTfs[entry.index]);\n    postings.triggerTfs = order.map((entry) => postings.triggerTfs[entry.index]);\n    postings.pathTfs = order.map((entry) => postings.pathTfs[entry.index]);\n    postings.bodyTfs = order.map((entry) => postings.bodyTfs[entry.index]);\n  }\n\n  private calculatePackedScore(\n    queryTokens: string[],\n    docId: string,\n    options: BM25SearchOptions\n  ): number {\n    const doc = this.packedDocuments.get(docId);\n    if (!doc) return 0;\n\n    const weights = resolveBm25FieldWeights(options.fieldWeights);\n    const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n    let score = 0;\n\n    for (const term of queryTokens) {\n      const postings = this.getPackedPosting(term);\n      if (!postings) continue;\n      const postingIndex = this.findPackedPostingIndex(postings, doc.numericId);\n      if (postingIndex < 0) continue;\n\n      const weightedTf = this.calculateWeightedPostingFrequency(postings, postingIndex, weights);\n      if (weightedTf <= 0) continue;\n\n      const idf = this.calculateIdf(term);\n      score += this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n    }\n\n    return score;\n  }\n\n  private searchPacked(\n    queryTokens: string[],\n    limit: number,\n    options: BM25SearchOptions\n  ): BM25SearchResult[] {\n    const weights = resolveBm25FieldWeights(options.fieldWeights);\n    const avgDl = Math.max(this.getAverageDocumentLength(), 1);\n    const scores = new Map<number, number>();\n\n    for (const term of queryTokens) {\n      const postings = this.getPackedPosting(term);\n      if (!postings) continue;\n\n      const idf = this.calculateIdf(term);\n      for (let i = 0; i < postings.docIds.length; i += 1) {\n        const numericId = postings.docIds[i];\n        const id = this.packedDocIds[numericId];\n        if (!id) continue;\n        const doc = this.packedDocuments.get(id);\n        if (!doc) continue;\n\n        const weightedTf = this.calculateWeightedPostingFrequency(postings, i, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = this.calculateBm25TermScore(weightedTf, doc.length, avgDl, idf);\n        scores.set(numericId, (scores.get(numericId) || 0) + termScore);\n      }\n    }\n\n    return Array.from(scores.entries())\n      .map(([numericId, score]) => ({ id: this.packedDocIds[numericId], score }))\n      .filter((result): result is BM25SearchResult => typeof result.id === 'string' && result.score > 0)\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  private calculateWeightedPostingFrequency(\n    postings: PackedPostingList,\n    index: number,\n    weights: BM25FieldWeights\n  ): number {\n    return (\n      postings.titleTfs[index] * weights.title +\n      postings.triggerTfs[index] * weights.trigger_phrases +\n      postings.pathTfs[index] * weights.content_generic +\n      postings.bodyTfs[index] * weights.body\n    );\n  }\n\n  private findPackedPostingIndex(postings: PackedPostingList, numericId: number): number {\n    let low = 0;\n    let high = postings.docIds.length - 1;\n    while (low <= high) {\n      const mid = Math.floor((low + high) / 2);\n      const value = postings.docIds[mid];\n      if (value === numericId) return mid;\n      if (value < numericId) {\n        low = mid + 1;\n      } else {\n        high = mid - 1;\n      }\n    }\n    return -1;\n  }\n\n  private calculateBm25TermScore(tf: number, dl: number, avgDl: number, idf: number): number {\n    const numerator = tf * (this.k1 + 1);\n    const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / avgDl));\n    return idf * (numerator / denominator);\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. SINGLETON\n\n// ───────────────────────────────────────────────────────────────\nlet indexInstance: BM25Index | null = null;\n\n/**\n * Retrieve the shared in-memory BM25 index singleton.\n *\n * @returns The process-wide {@link BM25Index} instance.\n * @example\n * ```ts\n * const index = getIndex();\n * index.addDocument('123', 'memory search');\n * ```\n */\nfunction getIndex(): BM25Index {\n  if (!indexInstance) {\n    indexInstance = new BM25Index();\n  }\n  return indexInstance;\n}\n\n/**\n * Reset the shared BM25 index singleton.\n *\n * @returns Nothing.\n * @example\n * ```ts\n * resetIndex();\n * ```\n */\nfunction resetIndex(): void {\n  indexInstance?.cancelWarmup();\n  indexInstance = null;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 5. LEXICAL ENGINE ROUTING\n\n// ───────────────────────────────────────────────────────────────\nfunction resolveBm25Engine(): Bm25Engine {\n  const value = process.env.SPECKIT_BM25_ENGINE?.trim().toLowerCase();\n  if (!value) {\n    return 'auto';\n  }\n\n  if ((BM25_ENGINE_VALUES as readonly string[]).includes(value)) {\n    return value as Bm25Engine;\n  }\n\n  console.warn(`[bm25-index] Unsupported SPECKIT_BM25_ENGINE=${value}; falling back to auto`);\n  return 'auto';\n}\n\nfunction isMemoryFtsAvailable(database: Database.Database | null | undefined): boolean {\n  if (!database) {\n    return false;\n  }","lineStart":620,"lineEnd":979,"totalLines":1095,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781151905510,"end":1781151905517}},"metadata":{"openai":{"itemId":"fc_0e4f10340aca1d7f016a2a38a16e0881919e53580d6889d105"}},"id":"prt_eb4ed36db0018w49sLv3J6H4Sy","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ed20a9001RJjjy09djEqgI5"}}
{"type":"tool_use","timestamp":1781151905537,"sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","part":{"type":"tool","tool":"read","callID":"call_zGtw7hAQKd8HIpMNVTL0dpJu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","offset":260,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts</path>\n<type>file</type>\n<content>\n260:     const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({\n261:       queryId: r.queryId,\n262:       memoryId: r.memoryId,\n263:       relevance: r.relevance,\n264:     }));\n265: \n266:     totalMRR += computeMRR(evalResults, groundTruth, 5);\n267:     totalNDCG += computeNDCG(evalResults, groundTruth, 10);\n268:     totalRecall += computeRecall(evalResults, groundTruth, k);\n269:     totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n270:   }\n271: \n272:   const safeCount = queries.length > 0 ? queries.length : 1;\n273:   return {\n274:     mrr5: totalMRR / safeCount,\n275:     ndcg10: totalNDCG / safeCount,\n276:     recall20: totalRecall / safeCount,\n277:     hitRate1: totalHitRate / safeCount,\n278:   };\n279: }\n280: \n281: /* ───────────────────────────────────────────────────────────────\n282:    2a. RELATIVE CONTINGENCY (Spec-Compliant)\n283:    Compares BM25 MRR@5 as a percentage of hybrid MRR@5.\n284:    Spec: \"BM25 >= 80% of hybrid MRR@5\" → PAUSE.\n285: ──────────────────────────────────────────────────────────────── */\n286: \n287: /**\n288:  * Evaluate BM25 performance relative to hybrid MRR@5 (spec-compliant).\n289:  *\n290:  * The spec defines contingency thresholds as ratios:\n291:  *   ratio = bm25MRR / hybridMRR\n292:  *\n293:  *   ratio >= 0.80 → PAUSE\n294:  *     BM25 achieves ≥80% of hybrid — multi-channel adds little value.\n295:  *\n296:  *   ratio 0.50–0.79 → RATIONALIZE\n297:  *     BM25 achieves 50-79% of hybrid — channels need per-channel evidence.\n298:  *\n299:  *   ratio < 0.50 → PROCEED\n300:  *     BM25 achieves <50% of hybrid — multi-channel clearly justified.\n301:  *\n302:  * @param bm25MRR   - BM25-only MRR@5 (must be in [0, 1]).\n303:  * @param hybridMRR - Hybrid/multi-channel MRR@5 (must be in (0, 1]).\n304:  * @returns ContingencyDecision with ratio, mode='relative', and interpretation.\n305:  */\n306: export function evaluateContingencyRelative(\n307:   bm25MRR: number,\n308:   hybridMRR: number,\n309: ): ContingencyDecision {\n310:   if (!Number.isFinite(bm25MRR) || !Number.isFinite(hybridMRR) || hybridMRR <= 0) {\n311:     return {\n312:       bm25MRR,\n313:       hybridMRR,\n314:       ratio: 0,\n315:       mode: 'relative',\n316:       threshold: '<0.5',\n317:       action: 'PROCEED',\n318:       interpretation:\n319:         'Hybrid/BM25 MRR@5 is non-finite, zero, or negative — cannot compute meaningful ratio. ' +\n320:         'Defaulting to PROCEED until hybrid baseline is established.',\n321:     };\n322:   }\n323: \n324:   const ratio = bm25MRR / hybridMRR;\n325: \n326:   if (ratio >= 0.80) {\n327:     return {\n328:       bm25MRR,\n329:       hybridMRR,\n330:       ratio,\n331:       mode: 'relative',\n332:       threshold: '>=0.8',\n333:       action: 'PAUSE',\n334:       interpretation:\n335:         `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n336:         `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n337:         'The multi-channel architecture adds marginal value over keyword search alone. ' +\n338:         'PAUSE Sprints 3-7 and evaluate whether the complexity is warranted.',\n339:     };\n340:   }\n341: \n342:   if (ratio >= 0.50) {\n343:     return {\n344:       bm25MRR,\n345:       hybridMRR,\n346:       ratio,\n347:       mode: 'relative',\n348:       threshold: '0.5-0.8',\n349:       action: 'RATIONALIZE',\n350:       interpretation:\n351:         `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n352:         `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n353:         'Each additional channel must show a statistically meaningful positive delta ' +\n354:         'in MRR@5. Track per-channel contribution and justify retained complexity.',\n355:     };\n356:   }\n357: \n358:   return {\n359:     bm25MRR,\n360:     hybridMRR,\n361:     ratio,\n362:     mode: 'relative',\n363:     threshold: '<0.5',\n364:     action: 'PROCEED',\n365:     interpretation:\n366:       `BM25 achieves only ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n367:       `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n368:       'Multi-channel retrieval provides substantial improvement over keyword search. ' +\n369:       'Proceed with hybrid search optimization.',\n370:   };\n371: }\n372: \n373: /* ───────────────────────────────────────────────────────────────\n374:    2b. BOOTSTRAP CONFIDENCE INTERVAL\n375:    Statistical significance testing for the contingency decision.\n376:    Uses bootstrap resampling to compute 95% CI for MRR@5.\n377: ──────────────────────────────────────────────────────────────── */\n378: \n379: /** Result of bootstrap confidence interval computation. */\n380: export interface BootstrapCIResult {\n381:   /** Point estimate (mean MRR@5 across all queries). */\n382:   pointEstimate: number;\n383:   /** Lower bound of 95% CI. */\n384:   ciLower: number;\n385:   /** Upper bound of 95% CI. */\n386:   ciUpper: number;\n387:   /** CI width (ciUpper - ciLower). Narrower is more confident. */\n388:   ciWidth: number;\n389:   /** Number of bootstrap iterations. */\n390:   iterations: number;\n391:   /** Number of queries in the sample. */\n392:   sampleSize: number;\n393:   /** Whether the CI excludes the contingency threshold boundaries.\n394:    *  true = the decision is statistically significant at p<0.05. */\n395:   isSignificant: boolean;\n396:   /** Which threshold boundary was tested. */\n397:   testedBoundary: number;\n398: }\n399: \n400: /**\n401:  * Compute bootstrap 95% confidence interval for MRR@5.\n402:  *\n403:  * Uses percentile bootstrap with 10,000 iterations (default).\n404:  * Statistical significance is determined by whether the CI\n405:  * excludes the nearest contingency threshold boundary.\n406:  *\n407:  * @param perQueryMRR - Array of per-query MRR@5 values (one per query).\n408:  * @param iterations - Number of bootstrap iterations (default: 10000).\n409:  * @returns BootstrapCIResult with CI bounds and significance.\n410:  */\n411: export function computeBootstrapCI(\n412:   perQueryMRR: number[],\n413:   iterations: number = 10000,\n414: ): BootstrapCIResult {\n415:   const safeIterations = Number.isFinite(iterations) ? Math.floor(iterations) : 0;\n416:   const boundedIterations = Math.min(safeIterations, 100_000);\n417:   // Filter out NaN/Infinity values to prevent poisoning bootstrap means\n418:   const cleanMRR = perQueryMRR.filter(v => Number.isFinite(v));\n419:   const n = cleanMRR.length;\n420:   if (n === 0) {\n421:     return {\n422:       pointEstimate: 0,\n423:       ciLower: 0,\n424:       ciUpper: 0,\n425:       ciWidth: 0,\n426:       iterations: Math.max(0, boundedIterations),\n427:       sampleSize: 0,\n428:       isSignificant: false,\n429:       testedBoundary: 0,\n430:     };\n431:   }\n432: \n433:   // Point estimate\n434:   const pointEstimate = cleanMRR.reduce((s, v) => s + v, 0) / n;\n435: \n436:   if (boundedIterations <= 0) {\n437:     return {\n438:       pointEstimate,\n439:       ciLower: pointEstimate,\n440:       ciUpper: pointEstimate,\n441:       ciWidth: 0,\n442:       iterations: 0,\n443:       sampleSize: n,\n444:       isSignificant: false,\n445:       testedBoundary: 0,\n446:     };\n447:   }\n448: \n449:   // Bootstrap resampling\n450:   const bootstrapMeans: number[] = [];\n451:   for (let i = 0; i < boundedIterations; i++) {\n452:     let sum = 0;\n453:     for (let j = 0; j < n; j++) {\n454:       sum += cleanMRR[Math.floor(Math.random() * n)];\n455:     }\n456:     bootstrapMeans.push(sum / n);\n457:   }\n458: \n459:   // Sort for percentile computation\n460:   bootstrapMeans.sort((a, b) => a - b);\n461: \n462:   // 95% CI = 2.5th and 97.5th percentiles\n463:   const lowerIdx = Math.ceil(boundedIterations * 0.025) - 1;\n464:   const upperIdx = Math.ceil(boundedIterations * 0.975) - 1;\n465:   const ciLower = bootstrapMeans[lowerIdx];\n466:   const ciUpper = bootstrapMeans[upperIdx];\n467: \n468:   // Determine nearest threshold boundary and test significance\n469:   let testedBoundary = 0;\n470:   let isSignificant = false;\n471: \n472:   if (pointEstimate >= 0.80) {\n473:     // Testing whether we're significantly above 0.80 (PAUSE)\n474:     testedBoundary = 0.80;\n475:     isSignificant = ciLower >= 0.80;\n476:   } else if (pointEstimate >= 0.50) {\n477:     // Testing RATIONALIZE band: CI should not cross either boundary\n478:     testedBoundary = pointEstimate >= 0.65 ? 0.80 : 0.50;\n479:     isSignificant = ciLower >= 0.50 && ciUpper < 0.80;\n480:   } else {\n481:     // Testing whether we're significantly below 0.50 (PROCEED)\n482:     testedBoundary = 0.50;\n483:     isSignificant = ciUpper < 0.50;\n484:   }\n485: \n486:   return {\n487:     pointEstimate,\n488:     ciLower,\n489:     ciUpper,\n490:     ciWidth: ciUpper - ciLower,\n491:     iterations: boundedIterations,\n492:     sampleSize: n,\n493:     isSignificant,\n494:     testedBoundary,\n495:   };\n496: }\n497: \n498: /* ───────────────────────────────────────────────────────────────\n499:    3. METRIC RECORDING\n500: ──────────────────────────────────────────────────────────────── */\n501: \n502: /**\n503:  * Record BM25 baseline metrics to the eval DB (eval_metric_snapshots table).\n504:  *\n505:  * Inserts one row per metric (mrr@5, ndcg@10, recall@20, hit_rate@1) plus\n506:  * one metadata row containing the full contingency decision.\n507:  *\n508:  * Channel is recorded as 'bm25' to distinguish from multi-channel runs.\n509:  *\n510:  * @param evalDb - An initialized better-sqlite3 Database instance.\n511:  * @param result - The BM25BaselineResult to persist.\n512:  */\n513: export function recordBaselineMetrics(\n514:   evalDb: Database.Database,\n515:   result: BM25BaselineResult,\n516: ): void {\n517:   // Use a synthetic eval_run_id for baseline runs: negative integer based on\n518:   // Timestamp to avoid collision with production run IDs (which start at 1).\n519:   const evalRunId = -(Date.parse(result.timestamp));\n520: \n521:   const insertSnapshot = evalDb.prepare(`\n522:     INSERT INTO eval_metric_snapshots\n523:       (eval_run_id, metric_name, metric_value, channel, query_count, metadata, created_at)\n524:     VALUES (?, ?, ?, ?, ?, ?, ?)\n525:   `);\n526: \n527:   const channel = 'bm25';\n528:   const createdAt = result.timestamp;\n529:   const queryCount = result.queryCount;\n530: \n531:   const writeAll = evalDb.transaction(() => {\n532:     // Core metrics\n533:     insertSnapshot.run(evalRunId, 'mrr@5',       result.metrics.mrr5,      channel, queryCount, null, createdAt);\n534:     insertSnapshot.run(evalRunId, 'ndcg@10',      result.metrics.ndcg10,    channel, queryCount, null, createdAt);\n535:     insertSnapshot.run(evalRunId, 'recall@20',    result.metrics.recall20,  channel, queryCount, null, createdAt);\n536:     insertSnapshot.run(evalRunId, 'hit_rate@1',   result.metrics.hitRate1,  channel, queryCount, null, createdAt);\n537: \n538:     // Contingency decision (stored as JSON metadata on a sentinel row)\n539:     const contingencyMeta = JSON.stringify(result.contingencyDecision);\n540:     insertSnapshot.run(\n541:       evalRunId,\n542:       'bm25_contingency_decision',\n543:       result.contingencyDecision.bm25MRR,\n544:       channel,\n545:       queryCount,\n546:       contingencyMeta,\n547:       createdAt,\n548:     );\n549:   });\n550: \n551:   writeAll();\n552: }\n553: \n554: /* ───────────────────────────────────────────────────────────────\n555:    4. BM25 BASELINE RUNNER\n556: ──────────────────────────────────────────────────────────────── */\n557: \n558: /**\n559:  * Run the BM25-only baseline measurement over the ground truth query set.\n\n(Showing lines 260-559 of 693. Use offset=560 to continue.)\n</content>","metadata":{"preview":"    const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({\n      queryId: r.queryId,\n      memoryId: r.memoryId,\n      relevance: r.relevance,\n    }));\n\n    totalMRR += computeMRR(evalResults, groundTruth, 5);\n    totalNDCG += computeNDCG(evalResults, groundTruth, 10);\n    totalRecall += computeRecall(evalResults, groundTruth, k);\n    totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n  }\n\n  const safeCount = queries.length > 0 ? queries.length : 1;\n  return {\n    mrr5: totalMRR / safeCount,\n    ndcg10: totalNDCG / safeCount,\n    recall20: totalRecall / safeCount,\n    hitRate1: totalHitRate / safeCount,\n  };\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","text":"    const groundTruth: GroundTruthEntry[] = q.relevances.map((r) => ({\n      queryId: r.queryId,\n      memoryId: r.memoryId,\n      relevance: r.relevance,\n    }));\n\n    totalMRR += computeMRR(evalResults, groundTruth, 5);\n    totalNDCG += computeNDCG(evalResults, groundTruth, 10);\n    totalRecall += computeRecall(evalResults, groundTruth, k);\n    totalHitRate += computeHitRate(evalResults, groundTruth, 1);\n  }\n\n  const safeCount = queries.length > 0 ? queries.length : 1;\n  return {\n    mrr5: totalMRR / safeCount,\n    ndcg10: totalNDCG / safeCount,\n    recall20: totalRecall / safeCount,\n    hitRate1: totalHitRate / safeCount,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2a. RELATIVE CONTINGENCY (Spec-Compliant)\n   Compares BM25 MRR@5 as a percentage of hybrid MRR@5.\n   Spec: \"BM25 >= 80% of hybrid MRR@5\" → PAUSE.\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Evaluate BM25 performance relative to hybrid MRR@5 (spec-compliant).\n *\n * The spec defines contingency thresholds as ratios:\n *   ratio = bm25MRR / hybridMRR\n *\n *   ratio >= 0.80 → PAUSE\n *     BM25 achieves ≥80% of hybrid — multi-channel adds little value.\n *\n *   ratio 0.50–0.79 → RATIONALIZE\n *     BM25 achieves 50-79% of hybrid — channels need per-channel evidence.\n *\n *   ratio < 0.50 → PROCEED\n *     BM25 achieves <50% of hybrid — multi-channel clearly justified.\n *\n * @param bm25MRR   - BM25-only MRR@5 (must be in [0, 1]).\n * @param hybridMRR - Hybrid/multi-channel MRR@5 (must be in (0, 1]).\n * @returns ContingencyDecision with ratio, mode='relative', and interpretation.\n */\nexport function evaluateContingencyRelative(\n  bm25MRR: number,\n  hybridMRR: number,\n): ContingencyDecision {\n  if (!Number.isFinite(bm25MRR) || !Number.isFinite(hybridMRR) || hybridMRR <= 0) {\n    return {\n      bm25MRR,\n      hybridMRR,\n      ratio: 0,\n      mode: 'relative',\n      threshold: '<0.5',\n      action: 'PROCEED',\n      interpretation:\n        'Hybrid/BM25 MRR@5 is non-finite, zero, or negative — cannot compute meaningful ratio. ' +\n        'Defaulting to PROCEED until hybrid baseline is established.',\n    };\n  }\n\n  const ratio = bm25MRR / hybridMRR;\n\n  if (ratio >= 0.80) {\n    return {\n      bm25MRR,\n      hybridMRR,\n      ratio,\n      mode: 'relative',\n      threshold: '>=0.8',\n      action: 'PAUSE',\n      interpretation:\n        `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n        `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n        'The multi-channel architecture adds marginal value over keyword search alone. ' +\n        'PAUSE Sprints 3-7 and evaluate whether the complexity is warranted.',\n    };\n  }\n\n  if (ratio >= 0.50) {\n    return {\n      bm25MRR,\n      hybridMRR,\n      ratio,\n      mode: 'relative',\n      threshold: '0.5-0.8',\n      action: 'RATIONALIZE',\n      interpretation:\n        `BM25 achieves ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n        `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n        'Each additional channel must show a statistically meaningful positive delta ' +\n        'in MRR@5. Track per-channel contribution and justify retained complexity.',\n    };\n  }\n\n  return {\n    bm25MRR,\n    hybridMRR,\n    ratio,\n    mode: 'relative',\n    threshold: '<0.5',\n    action: 'PROCEED',\n    interpretation:\n      `BM25 achieves only ${(ratio * 100).toFixed(1)}% of hybrid MRR@5 ` +\n      `(${bm25MRR.toFixed(4)} / ${hybridMRR.toFixed(4)}). ` +\n      'Multi-channel retrieval provides substantial improvement over keyword search. ' +\n      'Proceed with hybrid search optimization.',\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2b. BOOTSTRAP CONFIDENCE INTERVAL\n   Statistical significance testing for the contingency decision.\n   Uses bootstrap resampling to compute 95% CI for MRR@5.\n──────────────────────────────────────────────────────────────── */\n\n/** Result of bootstrap confidence interval computation. */\nexport interface BootstrapCIResult {\n  /** Point estimate (mean MRR@5 across all queries). */\n  pointEstimate: number;\n  /** Lower bound of 95% CI. */\n  ciLower: number;\n  /** Upper bound of 95% CI. */\n  ciUpper: number;\n  /** CI width (ciUpper - ciLower). Narrower is more confident. */\n  ciWidth: number;\n  /** Number of bootstrap iterations. */\n  iterations: number;\n  /** Number of queries in the sample. */\n  sampleSize: number;\n  /** Whether the CI excludes the contingency threshold boundaries.\n   *  true = the decision is statistically significant at p<0.05. */\n  isSignificant: boolean;\n  /** Which threshold boundary was tested. */\n  testedBoundary: number;\n}\n\n/**\n * Compute bootstrap 95% confidence interval for MRR@5.\n *\n * Uses percentile bootstrap with 10,000 iterations (default).\n * Statistical significance is determined by whether the CI\n * excludes the nearest contingency threshold boundary.\n *\n * @param perQueryMRR - Array of per-query MRR@5 values (one per query).\n * @param iterations - Number of bootstrap iterations (default: 10000).\n * @returns BootstrapCIResult with CI bounds and significance.\n */\nexport function computeBootstrapCI(\n  perQueryMRR: number[],\n  iterations: number = 10000,\n): BootstrapCIResult {\n  const safeIterations = Number.isFinite(iterations) ? Math.floor(iterations) : 0;\n  const boundedIterations = Math.min(safeIterations, 100_000);\n  // Filter out NaN/Infinity values to prevent poisoning bootstrap means\n  const cleanMRR = perQueryMRR.filter(v => Number.isFinite(v));\n  const n = cleanMRR.length;\n  if (n === 0) {\n    return {\n      pointEstimate: 0,\n      ciLower: 0,\n      ciUpper: 0,\n      ciWidth: 0,\n      iterations: Math.max(0, boundedIterations),\n      sampleSize: 0,\n      isSignificant: false,\n      testedBoundary: 0,\n    };\n  }\n\n  // Point estimate\n  const pointEstimate = cleanMRR.reduce((s, v) => s + v, 0) / n;\n\n  if (boundedIterations <= 0) {\n    return {\n      pointEstimate,\n      ciLower: pointEstimate,\n      ciUpper: pointEstimate,\n      ciWidth: 0,\n      iterations: 0,\n      sampleSize: n,\n      isSignificant: false,\n      testedBoundary: 0,\n    };\n  }\n\n  // Bootstrap resampling\n  const bootstrapMeans: number[] = [];\n  for (let i = 0; i < boundedIterations; i++) {\n    let sum = 0;\n    for (let j = 0; j < n; j++) {\n      sum += cleanMRR[Math.floor(Math.random() * n)];\n    }\n    bootstrapMeans.push(sum / n);\n  }\n\n  // Sort for percentile computation\n  bootstrapMeans.sort((a, b) => a - b);\n\n  // 95% CI = 2.5th and 97.5th percentiles\n  const lowerIdx = Math.ceil(boundedIterations * 0.025) - 1;\n  const upperIdx = Math.ceil(boundedIterations * 0.975) - 1;\n  const ciLower = bootstrapMeans[lowerIdx];\n  const ciUpper = bootstrapMeans[upperIdx];\n\n  // Determine nearest threshold boundary and test significance\n  let testedBoundary = 0;\n  let isSignificant = false;\n\n  if (pointEstimate >= 0.80) {\n    // Testing whether we're significantly above 0.80 (PAUSE)\n    testedBoundary = 0.80;\n    isSignificant = ciLower >= 0.80;\n  } else if (pointEstimate >= 0.50) {\n    // Testing RATIONALIZE band: CI should not cross either boundary\n    testedBoundary = pointEstimate >= 0.65 ? 0.80 : 0.50;\n    isSignificant = ciLower >= 0.50 && ciUpper < 0.80;\n  } else {\n    // Testing whether we're significantly below 0.50 (PROCEED)\n    testedBoundary = 0.50;\n    isSignificant = ciUpper < 0.50;\n  }\n\n  return {\n    pointEstimate,\n    ciLower,\n    ciUpper,\n    ciWidth: ciUpper - ciLower,\n    iterations: boundedIterations,\n    sampleSize: n,\n    isSignificant,\n    testedBoundary,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. METRIC RECORDING\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Record BM25 baseline metrics to the eval DB (eval_metric_snapshots table).\n *\n * Inserts one row per metric (mrr@5, ndcg@10, recall@20, hit_rate@1) plus\n * one metadata row containing the full contingency decision.\n *\n * Channel is recorded as 'bm25' to distinguish from multi-channel runs.\n *\n * @param evalDb - An initialized better-sqlite3 Database instance.\n * @param result - The BM25BaselineResult to persist.\n */\nexport function recordBaselineMetrics(\n  evalDb: Database.Database,\n  result: BM25BaselineResult,\n): void {\n  // Use a synthetic eval_run_id for baseline runs: negative integer based on\n  // Timestamp to avoid collision with production run IDs (which start at 1).\n  const evalRunId = -(Date.parse(result.timestamp));\n\n  const insertSnapshot = evalDb.prepare(`\n    INSERT INTO eval_metric_snapshots\n      (eval_run_id, metric_name, metric_value, channel, query_count, metadata, created_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const channel = 'bm25';\n  const createdAt = result.timestamp;\n  const queryCount = result.queryCount;\n\n  const writeAll = evalDb.transaction(() => {\n    // Core metrics\n    insertSnapshot.run(evalRunId, 'mrr@5',       result.metrics.mrr5,      channel, queryCount, null, createdAt);\n    insertSnapshot.run(evalRunId, 'ndcg@10',      result.metrics.ndcg10,    channel, queryCount, null, createdAt);\n    insertSnapshot.run(evalRunId, 'recall@20',    result.metrics.recall20,  channel, queryCount, null, createdAt);\n    insertSnapshot.run(evalRunId, 'hit_rate@1',   result.metrics.hitRate1,  channel, queryCount, null, createdAt);\n\n    // Contingency decision (stored as JSON metadata on a sentinel row)\n    const contingencyMeta = JSON.stringify(result.contingencyDecision);\n    insertSnapshot.run(\n      evalRunId,\n      'bm25_contingency_decision',\n      result.contingencyDecision.bm25MRR,\n      channel,\n      queryCount,\n      contingencyMeta,\n      createdAt,\n    );\n  });\n\n  writeAll();\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. BM25 BASELINE RUNNER\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Run the BM25-only baseline measurement over the ground truth query set.","lineStart":260,"lineEnd":559,"totalLines":693,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/eval/bm25-baseline.ts","time":{"start":1781151905534,"end":1781151905536}},"metadata":{"openai":{"itemId":"fc_0e4f10340aca1d7f016a2a38a16e108191bf197b0dcf4eeb5e"}},"id":"prt_eb4ed36f2001XUVVM9zjH2Q3TT","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4ed20a9001RJjjy09djEqgI5"}}
