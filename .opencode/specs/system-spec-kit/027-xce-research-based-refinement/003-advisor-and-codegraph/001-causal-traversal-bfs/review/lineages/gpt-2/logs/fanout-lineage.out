{"type":"tool_use","timestamp":1781150586149,"sessionID":"ses_14b28450fffeZz7MdRJGnUySqp","part":{"type":"tool","tool":"read","callID":"call_SotFThHZmqiztllnAv2NSkI3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/index.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/index.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports\n3: // -------------------------------------------------------------------\n4: \n5: export type { Awaitable, StorageId } from './common.js';\n6: export type {\n7:   BetterSqliteContentionPolicyOptions,\n8:   BusyTimeoutOptions,\n9:   ContentionRetryContext,\n10:   ContentionOperationOptions,\n11:   ContentionPolicy,\n12:   ContentionRetryOptions,\n13: } from './contention-policy.js';\n14: export { BetterSqliteContentionPolicy, isSqliteContentionError } from './contention-policy.js';\n15: export type {\n16:   BetterSqliteMaintenanceOptions,\n17:   CheckpointOptions,\n18:   Maintenance,\n19:   MaintenanceOperation,\n20:   MaintenanceResult,\n21: } from './maintenance.js';\n22: export { BetterSqliteMaintenance } from './maintenance.js';\n23: export {\n24:   BetterSqliteGraphTraversal,\n25:   type DirectedReachabilityOptions,\n26:   type DirectedTraversalEdge,\n27:   type GraphTraversal,\n28:   type GraphTraversalNode,\n29:   type WeightedTraversalEdge,\n30:   type WeightedWalkOptions,\n31:   type WeightedWalkResult,\n32: } from './graph-traversal.js';\n33: export {\n34:   PackedBm25LexicalSearch,\n35:   type LexicalDocumentFields,\n36:   type LexicalDocumentSource,\n37:   type LexicalSearch,\n38:   type LexicalSearchOptions,\n39:   type LexicalSearchResult,\n40:   type LexicalSearchStats,\n41: } from './lexical-search.js';\n42: export { BetterSqliteVectorStore } from './vector-store.js';\n43: export type {\n44:   VectorMetadata,\n45:   VectorRecord,\n46:   VectorSearchOptions,\n47:   VectorSearchResult,\n48:   VectorStore,\n49: } from './vector-store.js';\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports\n// -------------------------------------------------------------------\n\nexport type { Awaitable, StorageId } from './common.js';\nexport type {\n  BetterSqliteContentionPolicyOptions,\n  BusyTimeoutOptions,\n  ContentionRetryContext,\n  ContentionOperationOptions,\n  ContentionPolicy,\n  ContentionRetryOptions,\n} from './contention-policy.js';\nexport { BetterSqliteContentionPolicy, isSqliteContentionError } from './contention-policy.js';\nexport type {\n  BetterSqliteMaintenanceOptions,\n  CheckpointOptions,\n  Maintenance,\n  MaintenanceOperation,\n  MaintenanceResult,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/index.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports\n// -------------------------------------------------------------------\n\nexport type { Awaitable, StorageId } from './common.js';\nexport type {\n  BetterSqliteContentionPolicyOptions,\n  BusyTimeoutOptions,\n  ContentionRetryContext,\n  ContentionOperationOptions,\n  ContentionPolicy,\n  ContentionRetryOptions,\n} from './contention-policy.js';\nexport { BetterSqliteContentionPolicy, isSqliteContentionError } from './contention-policy.js';\nexport type {\n  BetterSqliteMaintenanceOptions,\n  CheckpointOptions,\n  Maintenance,\n  MaintenanceOperation,\n  MaintenanceResult,\n} from './maintenance.js';\nexport { BetterSqliteMaintenance } from './maintenance.js';\nexport {\n  BetterSqliteGraphTraversal,\n  type DirectedReachabilityOptions,\n  type DirectedTraversalEdge,\n  type GraphTraversal,\n  type GraphTraversalNode,\n  type WeightedTraversalEdge,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from './graph-traversal.js';\nexport {\n  PackedBm25LexicalSearch,\n  type LexicalDocumentFields,\n  type LexicalDocumentSource,\n  type LexicalSearch,\n  type LexicalSearchOptions,\n  type LexicalSearchResult,\n  type LexicalSearchStats,\n} from './lexical-search.js';\nexport { BetterSqliteVectorStore } from './vector-store.js';\nexport type {\n  VectorMetadata,\n  VectorRecord,\n  VectorSearchOptions,\n  VectorSearchResult,\n  VectorStore,\n} from './vector-store.js';","lineStart":1,"lineEnd":49,"totalLines":49,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/index.ts","time":{"start":1781150586146,"end":1781150586148}},"metadata":{"openai":{"itemId":"fc_0bef04dbc0ea1652016a2a337a09448191bfd0d96fc284c7df"}},"id":"prt_eb4d91504001gclCSXz3ZJqabB","sessionID":"ses_14b28450fffeZz7MdRJGnUySqp","messageID":"msg_eb4d8f2da001pP9dinjVwtAV3H"}}
