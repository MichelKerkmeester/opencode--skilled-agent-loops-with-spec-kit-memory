n1670:         failure.exitCode = exitCode;\n1671:         failure.timedOut = false;\n1672:         failure.salvage = salvage;\n1673:         failure.stopPolicyViolation = stopPolicyViolation;\n1674:         throw failure;\n1675:       }\n1676: \n1677:       // An exit-0 lineage whose salvage sweep could not recover every iteration\n1678:       // markdown is NOT fulfilled, even when the top-level report exists. Returning\n1679:       // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n1680:       // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n1681:       // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n1682:       if (salvage && salvage.failed > 0) {\n1683:         const failure = new Error(\n1684:           `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n1685:         );\n1686:         failure.label = lineage.label;\n1687:         failure.exitCode = exitCode;\n1688:         failure.timedOut = false;\n1689:         failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n1690:         failure.missingArtifacts = [];\n1691:         throw failure;\n1692:       }\n1693: \n1694:       return { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n1695:     },\n1696:   });\n1697: \n1698:   writeOrchestrationSummary(summaryPath, {\n1699:     run_id: runId,\n1700:     loop_type: loopType,\n1701:     spec_folder: specFolder,\n1702:     base_artifact_dir: baseArtifactDir,\n1703:     total_cli_lineages: cliLineages.length,\n1704:     orphaned_lineages: orphanedLineages,\n1705:     ...summary,\n1706:   });\n1707: \n1708:   const exitCode = summary.all_failed ? 3 : summary.failed > 0 ? 2 : 0;\n1709:   jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary });\n1710:   process.exit(exitCode);\n1711: }\n1712: \n1713: if (require.main === module && isTsxLoaded) {\n17