eep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\",\n75:       \"sha256\": \"a60d8a13cbe6e5804caa3545ce2db90048384c9488ad536de99582e3c8a761b7\",\n76:       \"section\": \"full\"\n77:     },\n78:     {\n79:       \"path\": \".opencode/agents/deep-review.md\",\n80:       \"sha256\": \"c1213b7ebbec8474d428126d4037aa570b6cfbf80f634a8233e632a7e32d1919\",\n81:       \"section\": \"full\"\n82:     },\n83:     {\n84:       \"path\": \".opencode/skills/system-deep-loop/shared/rollout/resolve-injection-mode.cjs\",\n85:       \"sha256\": \"3c801fbecbc5bb01a99a7578243a823b791368cc229966b930418cfb468500df\",\n86:       \"section\": \"full\"\n87:     }\n88:   ],\n89:   \"compiledBodyDigest\": \"fb026c34b73c53e162be5f600ce17b5bd96d474030c3a6d950136cf264563db9\"\n90: }\n91: GENERATED_COMMAND_CONTRACT_HEADER_END -->\n92: # Compiled Command Contract: /deep:review\n93: \n94: This generated contract collapses the maintained command authority chain into one grep-checkable executor contract. Maintained sources remain authoritative; regenerate this file when any source digest changes.\n95: \n96: ## autonomousExecutionDirective\n97: \n98: > Read this first. It is an imperative to you, the executor — not background information.\n99: \n100: You were invoked via `opencode run --command deep/review` with the `:auto` suffix and a bound spec_folder and target in your message. The `:auto` suffix plus the bound spec_folder mean setup is ALREADY resolved. Therefore:\n101: \n102: - DO NOT emit the consolidated setup question (target/mode, research topic, Spec Folder A/B/C/D/E, execution mode, max iterations, executor). The bound spec_folder is your write authority; do not ask which spec folder should own the writes.\n103: - DO NOT halt for the repo-wide `CLAUDE.md` Gate-3 documentation gate. Under AUTONOMOUS execution with a validated prebound spec folder, Gate 3 is already satisfied by that folder (see gate3Precedence below).\n104: - PROCEED immediately: load the auto workflow YAML and dispatch the `deep-review` agent to run ONE iteration of the review loop over the bound target.\n105: - DISPATCH ONLY: you dispatch `deep-review` to run one iteration; you do NOT read, edit, patch, or run the review loop over the target yourself. The auto workflow YAML owns the loop itself — setup, dispatch-per-iteration, reducer sync, convergence checks, synthesis, and all loop-level artifact writes; the `deep-review` leaf owns only its own single-iteration artifacts — mixing your own inline work with the dispatch is a route violation.\n106: - ROUTE PROOF: dispatch through the auto workflow with its prompt pack so `deep-review` writes each iteration state record with the route-proof fields present — `target_agent: \"deep-review\"`, `resolved_route`, `agent_definition_loaded: true`, and `mode: \"review\"`. A completed run whose iteration state records omit these fields is an incomplete delegation and does not pass.\n107: \n108: Your job is to DISPATCH `deep-review` to run ONE iteration of the review loop over the bound target — NOT to run the loop yourself, and NOT to review, analyze, or summarize this contract. The auto workflow YAML owns the loop itself (setup, dispatch-per-iteration, reducer sync, convergence, synthesis, and loop-level writes). This contract is your instruction set; the review target is the bound spec_folder/target named in your message, never this document.\n109: \n110: ## sourceAuthority\n111: \n112: 1. `.opencode/commands/deep/review.md`\n113: 2. `.opencode/commands/deep/assets/deep_review_presentation.txt`\n114: 3. `.opencode/skills/system-spec-kit/references/workflows/auto_mode_contract.md`\n115: 4. `.opencode/commands/deep/assets/deep_review_auto.yaml`\n116: 5. `.opencode/commands/deep/assets/deep_review_confirm.yaml`\n117: 6. `.opencode/skills/system-deep-loop/mode-registry.json`\n118: 7. `.opencode/skills/system-deep-loop/SKILL.md`\n119: 8. `.opencode/skills/system-deep-loop/deep-review/SKILL.md`\n120: 9. `.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md`\n121: 10. `.opencode/skills/system-deep-loop/deep-review/references/state/state_format.md`\n122: 11. `.opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml`\n123: 12. `.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md`\n124: 13. `.opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json`\n125: 14. `.opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl`\n126: 15. `.opencode/agents/deep-review.md`\n127: 16. `.opencode/skills/system-deep-loop/shared/rollout/resolve-injection-mode.cjs`\n128: \n129: ## gate3Precedence\n130: \n131: ```yaml\n132: block: gate3Precedence\n133: classifierPath: .opencode/skills/system-spec-kit/shared/gate-3-classifier.ts\n134: classifierLines:\n135:   commandContractShape: \"67-72\"\n136:   autonomousSatisfaction: \"653-680\"\n137: command: /deep:review\n138: executionMode: AUTONOMOUS\n139: commandContract:\n140:   declaresAutonomousExecution: true\n141:   ownsSpecFolderSetup: true\n142:   allowedSpecFolderSources:\n143:     - flag\n144:     - marker\n145:     - scope_extract\n146:   writeBoundary: \"{artifact_dir} resolved from spec_folder for review\"\n147: rule: \"When the classifier receives AUTONOMOUS execution, a validated prebound spec folder, and this command contract, Gate 3 is satisfied by the prebound folder before any write.\"\n148: ```\n149: \n150: ## renderBlocks.auto\n151: \n152: Rule: render the marked block verbatim; do not paraphrase, summarize, reorder, or substitute inside the START/END boundary.\n153: \n154: <!-- START renderBlocks.auto -->\n155: ~~~markdown\n156: ### `:auto` Setup Resolution\n157: \n158: Setup contract: see `.opencode/skills/system-spec-kit/references/workflows/auto_mode_contract.md`.\n159: \n160: Under `execution_mode = AUTONOMOUS` (from the `:auto` suffix), follow the three-tier flow:\n161: \n162: 1. **Tier 1 — Resolve confidently** (contract §1): parse `$ARGUMENTS` flags + `PRE-BOUND SETUP ANSWERS:` block (§2) + the Default Resolution Table below (§3). When every required field is resolved, resolve `{artifact_dir}` and persist to `{artifact_dir}/deep-review-config.json` (shape: `reviewTarget`, `reviewTargetType`, `reviewDimensions`, `specFolder`, `maxIterations`, `convergenceThreshold`, `antiConvergence.convergenceMode`, reserved `antiConvergence.divergent: {}`, `stopPolicy`, `executionMode: \"auto\"`, `lineageMode`, `resource_map.emit`, `config.executor.*`), bind runtime YAML placeholders, set `STATUS: PASSED`, load `.opencode/commands/deep/assets/deep_review_auto.yaml`. End §0.\n163: \n164: 2. **Tier 2 — Targeted ask** (contract §1): when 1-2 required fields are genuinely ambiguous AND no default exists, emit ONE narrow question per ambiguous field. Command-specific Tier-2-eligible fields (per the Default Resolution Table below): `review_target_type`, `spec_folder`. **Ordering rule**: if `review_target_type` is ambiguous, ask only for `review_target_type` first — the answer may make `spec_folder` self-evident on the next Tier 1 pass. Missing `review_target` is absence, not ambiguity — go to Tier 3.\n165: \n166: 3. **Tier 3 — Fail fast** (contract §4): emit the named-missing-inputs error format with `/deep:review:auto` as the command name. Exit non-zero. Do not load YAML.\n167: \n168: `:confirm` path stays unchanged — see the Consolidated Setup Prompt section below.\n169: \n170: ### PRE-BOUND SETUP ANSWERS Schema (for `:auto` non-interactive dispatch)\n171: \n172: The dispatched prompt body may contain one structured marker block. Parse it before applying defaults.\n173: \n174: ```yaml\n175: PRE-BOUND SETUP ANSWERS:\n176:   review_target: <spec-folder>\n177:   review_target_type: spec-folder  # one of: spec-folder | skill | agent | track | files\n178:   review_dimensions: all  # or comma-separated subset: correctness, security, traceability, maintainability\n179:   spec_folder: existing  # one of: existing | new | update-related | phase-folder, or an explicit specs/.opencode/specs path\n180:   execution_mode: AUTONOMOUS  # from :auto suffix\n181:  lineage_mode: auto  # one of: auto | resume | restart\n182:   maxIterations: 10\n183:   convergenceThreshold: 0.10\n184:   convergence_mode: default  # default | off | sliding-window | divergent\n185:   stop_policy: convergence  # one of: convergence | max-iterations\n186:   executor: native  # one of: native | cli-opencode | cli-claude-code\n187:   executor_model: \"\"  # optional, executor-specific (cli-opencode e.g. xiaomi-token-plan-ams/mimo-v2.5-pro, minimax-coding-plan/MiniMax-M2.7-highspeed)\n188:   executor_config_dir: \"\"  # optional, cli-claude-code only; maps to CLAUDE_CONFIG_DIR\n189:   executor_reasoning: \"\"  # optional\n190:   executor_service_tier: \"\"  # optional\n191:   executor_timeout: 900  # optional\n192:   resource_map_emit: true  # optional\n193: ```\n194: \n195: Rules:\n196: \n197: - Any unspecified field falls back to its documented default.\n198: - Marker fields take precedence over `$ARGUMENTS` flags because the caller explicitly bound setup in the prompt body.\n199: - Unknown fields are warnings, not errors.\n200: - Malformed lines, including missing `:`, emit a parse error naming the offending line. Known fields parsed before the error may still be used, and unresolved fields continue to Tier 2 or Tier 3.\n201: - Empty strings count as unresolved for required fields.\n202: - Compact legacy answer strings are only for the consolidated `:confirm` prompt. They are not a `:auto` marker format.\n203: \n204: ### Default Resolution Table\n205: \n206: | Field | Required | Resolves Via | Default | Tier-2 Candidate |\n207: |-------|----------|--------------|---------|------------------|\n208: | `review_target` | Y | `$ARGUMENTS` first positional target, or marker `review_target` | none | N |\n209: | `review_target_type` | Y | marker `review_target_type`, or auto-detect from `review_target` | inferred only | Y, when target is present but ambiguous |\n210: | `review_dimensions` | Y | flag `--dims` if supported by caller, marker `review_dimensions`, or default | `\"all\"` | N |\n211: | `spec_folder` | Y | flag `--spec-folder`, marker `spec_folder`, `scope-extract` → a target/scope path that resolves to an existing spec folder (auto-bound, per `auto_mode_contract` §1 source 3), or target path when target is a spec folder | none | Y, when target is not a spec folder |\n212: | `execution_mode` | Y | attached suffix `:auto` or marker `execution_mode` | `AUTONOMOUS` under `:auto` | N |\n213: | `lineage_mode` | Y | flag `--restart`, flag `--lineage-mode=auto|resume|restart`, marker `lineage_mode`, or default | `auto` | N |\n214: | `maxIterations` | Y | flag `--max-iterations`, marker `maxIterations`, or default | `7` | N |\n215: | `convergenceThreshold` | Y | flag `--convergence`, marker `convergenceThreshold`, or default | `0.10` | N |\n216: | `convergence_mode` | Y | flag `--convergence-mode=default|off|sliding-window|divergent`, marker `convergence_mode`, or default | `default` | N |\n217: | `stop_policy` | Y | flag `--stop-policy=convergence|max-iterations`, marker `stop_policy`, or default | `convergence` | N |\n218: | `executor` | N | flag `--executor`, marker `executor`, config file, or default | `native` | N |\n219: | `executor_model` | N | flag `--model`, marker `executor_model`, or executor-specific validation | none | N |\n220: | `executor_config_dir` | N | flag `--config-dir`, marker `executor_config_dir`, or executor-specific default | none | N |\n221: | `executor_reasoning` | N | flag `--reasoning-effort`, marker `executor_reasoning`, or executor default | none | N |\n222: | `executor_service_tier` | N | flag `--service-tier`, marker `executor_service_tier`, or executor default | none | N |\n223: | `executor_timeout` | N | flag `--executor-timeout`, marker `executor_timeout`, or default | `900` | N |\n224: | `resource_map_emit` | N | flag `--no-resource-map`, marker `resource_map_emit`, or default | `true` | N |\n225: | `config.fanout_lineage_artifact_dir` | N | internal flag `--fanout-lineage-artifact-dir=PATH` or marker `config.fanout_lineage_artifact_dir` | none | N |\n226: | `fanout_executors` | N | repeatable `--executor=<type>` flags or `--executors=<json>`; each group accepts `--model`, `--config-dir`, `--reasoning-effort`, `--service-tier`, `--executor-timeout`, `--iters`, `--label`, `--count` | none (single-executor when absent) | N |\n227: | `fanout_concurrency` | N | flag `--concurrency=N` | `2` | N |\n228: \n229: **Fan-out default policy:** 0–1 `--executor` flags and no `--executors` → `config.executor` (single-executor, default, unchanged). 2+ `--executor` flags, `--executors`, or any `--count > 1` → `config.fanout`. Review fan-out uses strongest-restriction: any lineage active P0 → merged FAIL. Native and CLI fan-out lineages run under `fanout-run.cjs` in the capped pool so every lineage shares retries, artifact checks, and stop-policy validation. The native adapter calls the `deep/review` command with the internal `--fanout-lineage-artifact-dir` override; it must not dispatch the LEAF `@deep-review` agent or a pasted phase-running prompt as a full-loop sub-agent. When fan-out includes `cli-opencode`, that lineage is an explicit parallel-detached OpenCode session with its own lineage directory and session id; this is the documented exception to the cli-opencode self-invocation guard. Single-executor `cli-opencode` remains cross-runtime only.\n230: \n231: **Lifecycle policy:** `lineage_mode=auto` preserves the existing classifier behavior, `lineage_mode=resume` continues a valid packet, and `lineage_mode=restart` archives the resolved `{artifact_dir}` before any config write, phase init, or fan-out spawn. In `:auto`, an explicit `--restart` or `--lineage-mode=restart` flag is operator authorization for this archive move, so do not ask for a second confirmation. Preserve rollback by moving the timestamped archive back to `review/` if needed. A restart request must never silently downgrade to resume; if the archive step cannot run, halt with `STATUS=FAIL`.\n232: \n233: **Stop policy:** `stop_policy=convergence` preserves normal deep-review behavior: legal convergence may stop before `maxIterations`. `stop_policy=max-iterations` makes convergence signals telemetry-only until the iteration ceiling; before `maxIterations`, broaden the next angle instead of synthesizing. Terminal manual pause, user stop, unrecoverable error, and `maxIterationsReached` still stop.\n234: ~~~\n235: <!-- END renderBlocks.auto -->\n236: \n237: ## renderBlocks.confirm\n238: \n239: Rule: render the marked block verbatim; do not paraphrase, summarize, reorder, or substitute inside the START/END boundary.\n240: \n241: <!-- START renderBlocks.confirm -->\n242: ~~~markdown\n243: ### Consolidated Setup Prompt for `:confirm` and No-Suffix Mode\n244: \n245: Use this block only when `execution_mode = \"INTERACTIVE\"` or when no suffix was supplied and Q2 must ask for the execution mode.\n246: \n247: **STATUS: ☐ BLOCKED**\n248: \n249: ```\n250: EXECUTE THIS SINGLE CONSOLIDATED PROMPT:\n251: \n252: 1. CHECK for mode suffix:\n253:    |-- \":auto\"    -> execution_mode = \"AUTONOMOUS\"\n254:    |-- \":confirm\" -> execution_mode = \"INTERACTIVE\"\n255:    +-- No suffix  -> execution_mode = \"ASK\" (include Q2)\n256: \n257: 2. CHECK $ARGUMENTS for target (review_target):\n258:    |-- Has content (ignoring suffixes and flags):\n259:    |     -> review_target = $ARGUMENTS, omit Q0\n260:    +-- Empty -> include Q0\n261: \n262: 3. PARSE optional flags from $ARGUMENTS:\n263:    |-- --max-iterations=N -> maxIterations = N\n264:    |-- --convergence=N -> convergenceThreshold = N\n265:    |-- --convergence-mode=default|off|sliding-window|divergent -> antiConvergence.convergenceMode = value\n266:    |-- --stop-policy=convergence|max-iterations -> stop_policy = value\n267:    |-- --spec-folder=PATH -> spec_path = PATH, omit Q1\n268:    |-- --restart -> lineage_mode = restart\n269:    |-- --lineage-mode=auto|resume|restart -> lineage_mode = value\n270:    |-- --executor=<type> -> config.executor.type (`native` | `cli-opencode` | `cli-claude-code`)\n271:    |-- --model=<id> -> config.executor.model (for example `gpt-5.4`)\n272:    |-- --config-dir=<path> -> config.executor.configDir (cli-claude-code only; fan-out sets CLAUDE_CONFIG_DIR)\n273:    |-- --reasoning-effort=<level> -> config.executor.reasoningEffort (`none` | `minimal` | `low` | `medium` | `high` | `xhigh` | `max`)\n274:    |-- --service-tier=<tier> -> config.executor.serviceTier (`priority` | `standard` | `fast`)\n275:    |-- --executor-timeout=<seconds> -> config.executor.timeoutSeconds (positive integer, default `900`)\n276:    |-- --no-resource-map -> config.resource_map.emit = false\n277:    |-- --fanout-lineage-artifact-dir=PATH -> config.fanout_lineage_artifact_dir = PATH (internal single-lineage command invocation only)\n278:    |-- --executor=<type> [--model=X] [--config-dir=PATH] [--reasoning-effort=Y] [--service-tier=Z] [--executor-timeout=N] [--iters=N] [--label=X] [--count=N]\n279:    |     (repeatable; each occurrence adds one entry to config.fanout.executors)\n280:    |-- --executors=<json> -> config.fanout.executors = parse(json) escape hatch\n281:    |-- --concurrency=N -> config.fanout.concurrency (default 2)\n282:    |\n283:    |   Fan-out default policy:\n284:    |   - 0 or 1 --executor (no --executors, no count>1): write config.executor (single, unchanged)\n285:    |   - 2+ --executor flags, --executors, or any count>1: write config.fanout\n286:    |   - Review fan-out verdict: strongest-restriction (any lineage active P0 → merged FAIL)\n287:    |\n288:    +-- Defaults: maxIterations=7, convergenceThreshold=0.10, antiConvergence.convergenceMode=`default`, antiConvergence.divergent=`{}`, stop_policy=`convergence`, lineage_mode=`auto`, config.executor.type=`native`, config.executor.timeoutSeconds=900, config.resource_map.emit=`true`\n289: \n290:    Executor precedence for setup resolution:\n291:    - CLI flag > config file > schema defaults\n292:    - The generated `deep-review-config.json` stores executor settings under `config.executor.*`\n293: \n294:    Parsing to config mapping:\n295:    - `--executor` -> `config.executor.type`\n296:    - `--model` -> `config.executor.model`\n297:    - `--config-dir` -> `config.executor.configDir`\n298:    - `--reasoning-effort` -> `config.executor.reasoningEffort`\n299:    - `--service-tier` -> `config.executor.serviceTier`\n300:    - `--executor-timeout` -> `config.executor.timeoutSeconds`\n301:    - `--convergence-mode` -> `antiConvergence.convergenceMode`\n302: \n303:    Validation hook:\n304:    - `parseExecutorConfig` from `.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts` runs at config-write time\n305:    - Invalid combinations fail fast with clear errors, including `cli-opencode` without `--model` and reserved-but-unwired executor kinds\n306: \n307: 4. Search for related spec folders across alias roots:\n308:    $ find specs .opencode/specs -mindepth 2 -maxdepth 2 -type d 2>/dev/null | sort | tail -10\n309: \n310: 5. Search for prior work (background):\n311:    - memory_context({ input: review_target OR \"deep-review\", mode: \"focused\", includeContent: true })\n312:    - Store: prior_work_found = [yes/no]\n313: \n314: 6. ASK with SINGLE prompt (include only applicable questions):\n315:    - Include Q-Exec only when `--executor` is NOT present and the target text does NOT already mention executor hints such as `cli-opencode`, ``, or `gpt-5.4`\n316:    - If Q-Exec is omitted and no executor is otherwise resolved, default to `native`\n317: \n318:    Q0. Review Target (if not in command): What to review?\n319:      Examples: spec folder path, `skill:sk-name`, `agent:name`, `track:NN--name`, or file paths/globs\n320: \n321:    Q1_type. Review Target Type (auto-detect from Q0, confirm):\n322:      A) spec-folder -- Review spec artifacts + implementation files\n323:      B) skill -- SKILL.md + references/ + assets/ + agents + commands\n324:      C) agent -- Agent family across all runtimes\n325:      D) track -- All child spec folders in a feature track\n326:      E) files -- Arbitrary file paths or globs\n327: \n328:    Q_dims. Which review dimensions? (default: all 4)\n329:      All: correctness, security, traceability, maintainability\n330:      Or specify a subset (e.g., \"correctness, security\")\n331: \n332:    Q1. Spec Folder (required):\n333:      A) Use existing [suggest if found]\n334:      B) Create new under `specs/[track]/[###]-[slug]/` (accept `.opencode/specs/` alias roots when already in use)\n335:      C) Update related [if match found]\n336:      D) Phase folder (e.g., `specs/NN-track/NNN-name/001-phase/` or matching `.opencode/specs/` alias)\n337: \n338:    Q2. Execution Mode (if no suffix):\n339:      A) Autonomous -- all iterations without approval\n340:      B) Interactive -- pause at each iteration for review\n341: \n342:    Q3. Max Iterations (if not set via flag):\n343:      Default is 7 for review. Change? [Enter number or press enter for default]\n344: \n345:    Q-Exec. Executor (optional, press enter for default):\n346:      A) Native (default) — dispatch via @deep-review agent with Opus.\n347:      B) cli-opencode — `opencode run --model X --format json --dangerously-skip-permissions --pure --dir {repo_root} [--variant Y] \"PROMPT\" </dev/null` (no `--agent`: current opencode rejects top-level `--agent general` — default agent runs; required for MiniMax/Xiaomi token-plan models). `reasoningEffort` maps to `--variant`. No service-tier.\n348:       C) cli-claude-code — `claude -p \"PROMPT\" --model X --permission-mode acceptEdits` with optional --effort and optional `--config-dir=PATH` for CLAUDE_CONFIG_DIR. No service-tier.\n349: \n350:    Reply format examples:\n351:    - `\"skill:deep-research, B, all, A, A\"`\n352:    - `\"review the deep-review packet output, E, correctness security, B, B, 5\"`\n353:    - `\"Review review/review-report.md contract drift, E, all, A, 7, 0.10, B, gpt-5.4, high, fast\"`\n354:    - `\"review executor drift across CLIs, E, all, A, 7, 0.10, C, gpt-5.4, _, _\"`\n355: \n356: 7. WAIT for user response (DO NOT PROCEED)\n357: \n358: 8. Parse response and store ALL results:\n359:    - review_target = [from Q0 or $ARGUMENTS]\n360:    - review_target_type = [from Q1_type, auto-detected]\n361:    - review_dimensions = [from Q_dims or default \"all\"]\n362:    - spec_choice = [A/B/C/D from Q1]\n363:    - spec_path = [derived path]\n364:    - execution_mode = [AUTONOMOUS/INTERACTIVE]\n365:    - lineage_mode = [auto/resume/restart from flag, marker, or default auto]\n366:    - maxIterations = [from Q3 or flag or default 7]\n367:    - convergenceThreshold = [from flag or default 0.10]\n368:    - convergence_mode = [from flag, marker, or default `default`; one of `default`, `off`, `sliding-window`, `divergent`]\n369:    - stop_policy = [from flag, marker, or default convergence]\n370:     - executor config = [CLI flags, compact reply, config file, or default `native`; map compact reply fields to `config.executor.type/model/configDir/reasoningEffort/serviceTier`, and accept an optional volunteered convergence value before executor fields]\n371: \n372: 9. SET STATUS: PASSED\n373: \n374: STOP HERE - Wait for user answers before continuing.\n375: \n376: DO NOT proceed until user explicitly answers\n377: NEVER auto-create spec folders without confirmation\n378: NEVER split questions into multiple prompts\n379: ```\n380: \n381: **Phase Output:**\n382: \n383: - `review_target` | `review_target_type` | `review_dimensions`\n384: - `spec_choice` | `spec_path` | `execution_mode` | `maxIterations` | `convergenceThreshold` | `convergence_mode` | `stop_policy`\n385: - `lineage_mode`\n386: - `config.fanout_lineage_artifact_dir` when present\n387: ~~~\n388: <!-- END renderBlocks.confirm -->\n389: \n390: ## setup\n391: \n392: ```yaml\n393: block: setup\n394: mode: \"AUTONOMOUS for :auto, INTERACTIVE for :confirm, ASK when no suffix is supplied\"\n395: requiredFields:\n396:   - \"review_target\"\n397:   - \"review_target_type\"\n398:   - \"review_dimensions\"\n399:   - \"spec_folder\"\n400:   - \"execution_mode\"\n401:   - \"lineage_mode\"\n402:   - \"maxIterations\"\n403:   - \"convergenceThreshold\"\n404:   - \"stop_policy\"\n405: optionalFields:\n406:   - \"executor\"\n407:   - \"executor_model\"\n408:   - \"executor_config_dir\"\n409:   - \"executor_reasoning\"\n410:   - \"executor_service_tier\"\n411:   - \"executor_timeout\"\n412:   - \"resource_map_emit\"\n413:   - \"config.fanout_lineage_artifact_dir\"\n414:   - \"fanout_executors\"\n415:   - \"fanout_concurrency\"\n416: autoWorkflow: .opencode/commands/deep/assets/deep_review_auto.yaml\n417: confirmWorkflow: .opencode/commands/deep/assets/deep_review_confirm.yaml\n418: ```\n419: \n420: ## outputTemplate\n421: \n422: ```yaml\n423: block: outputTemplate\n424: promptPackPath: .opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\n425: requiredArtifacts:\n426:   - \"{state_paths_iteration_pattern} iteration narrative markdown\"\n427:   - \"{state_paths_state_log} append-only canonical JSONL iteration record\"\n428:   - \"{state_paths_delta_pattern} per-iteration delta JSONL\"\n429: validation: \"YAML-owned post-dispatch validation rejects missing or malformed artifacts.\"\n430: ```\n431: \n432: ## writeBoundary\n433: \n434: ```yaml\n435: block: writeBoundary\n436: approvedRoot: \"{artifact_dir} resolved from spec_folder for review\"\n437: allowed:\n438:   - \"{state_paths_iteration_pattern}\"\n439:   - \"{state_paths_state_log} append only\"\n440:   - \"{state_paths_delta_pattern}\"\n441:   - \"{state_paths_strategy} in-place updates only\"\n442:   - \"{state_paths_findings_registry} in-place updates only\"\n443: readOnly:\n444:   - \"declared review target\"\n445:   - \"command Markdown\"\n446:   - \"workflow YAML assets\"\n447:   - \"agent definitions\"\n448:   - \"compiled contracts other than the selected build target\"\n449: banned:\n450:   - \"delete, rename, move, or truncate operations outside the allowed list\"\n451:   - \"writes outside the resolved review packet\"\n452:   - \"implementation fixes during review execution\"\n453: ```\n454: \n455: ## executorContract\n456: \n457: ```yaml\n458: block: executorContract\n459: appliesWhen:\n460:   executionMode: AUTONOMOUS\n461:   writeBoundaryResolved: true\n462: rules:\n463:   - \"The command Markdown resolves setup and selects YAML; YAML owns dispatch, workflow steps, and artifact writes.\"\n464:   - \"Executor dispatch must preserve route intent, selected mode, target agent, write boundary, and artifact paths.\"\n465:   - \"Native and CLI executors must produce only the required prompt-pack artifacts inside the resolved boundary.\"\n466:   - \"Fan-out receipt parity is not claimed here; fan-out remains governed by the workflow runner and merge contract.\"\n467:   - \"Missing or invalid receipt evidence makes route claims advisory only and forbids findings output.\"\n468: ```\n469: \n470: ## refs\n471: \n472: ```yaml\n473: block: refs\n474: dispatchReceipt:\n475:   writer: .opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts\n476:   validator: .opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts\n477:   rule: \"Reference the existing intent/completion receipt pair and validator; do not copy receipt logic into the command contract.\"\n478: progressRecord:\n479:   writer: .opencode/skills/system-deep-loop/shared/progress/progress-record.cjs\n480:   rule: \"Reference additive started/completed progress records as liveness evidence; progress records are not iteration, convergence, or completion records.\"\n481: ```\n482: \n483: ## tools\n484: \n485: ```yaml\n486: block: tools\n487: allowed:\n488:   - \"Read\"\n489:   - \"Write\"\n490:   - \"Edit\"\n491:   - \"Bash\"\n492:   - \"Grep\"\n493:   - \"Glob\"\n494:   - \"Task\"\n495:   - \"memory_context\"\n496:   - \"memory_search\"\n497:   - \"code_graph_query\"\n498:   - \"code_graph_context\"\n499: permittedByExecutor:\n500:   native:\n501:     - \"Read\"\n502:     - \"Write\"\n503:     - \"Edit\"\n504:     - \"Bash\"\n505:     - \"Grep\"\n506:     - \"Glob\"\n507:     - \"memory_context\"\n508:     - \"memory_search\"\n509:     - \"code_graph_query\"\n510:     - \"code_graph_context\"\n511:   cli-opencode:\n512:     - \"headless command execution through YAML-owned audited dispatch only\"\n513:   cli-claude-code:\n514:     - \"headless command execution through YAML-owned audited dispatch only\"\n515: ```\n516: \n517: ## absorptionAbort\n518: \n519: ```yaml\n520: block: absorptionAbort\n521: rule: \"Producing findings without a dispatch receipt is role absorption; write no findings.\"\n522: writePolicy: \"If receipt evidence is absent, invalid, or mismatched to command intent, emit an abort status and leave finding artifacts unwritten.\"\n523: ```\n\n(End of file - total 523 lines)\n</content>","metadata":{"preview":"<!-- GENERATED_COMMAND_CONTRACT_HEADER_START\n{\n  \"id\": \"deep/review\",\n  \"command\": \"/deep:review\",\n  \"version\": 1,\n  \"generatedBy\": \".opencode/skills/system-deep-loop/runtime/scripts/compile-command-contracts.cjs\",\n  \"sourceDigests\": [\n    {\n      \"path\": \".opencode/commands/deep/review.md\",\n      \"sha256\": \"be861c5a961ec8339743effc1baa40832d8be1aee005d8cd98a8764c7a3c702d\",\n      \"section\": \"full\"\n    },\n    {\n      \"path\": \".opencode/commands/deep/assets/deep_review_presentation.txt\",\n      \"sha256\": \"4283099c0835f8916cbb455d87b61d258d8bdae3b421afdbc1d1a762a54c0fb1\",\n      \"section\": \"full\"\n    },\n    {\n      \"path\": \".opencode/skills/system-spec-kit/references/workflows/auto_mode_contract.md\",\n      \"sha256\": \"cc283b7c5e62bd8b012a8f249f4cc63f4f353ad264358e1a5c9b