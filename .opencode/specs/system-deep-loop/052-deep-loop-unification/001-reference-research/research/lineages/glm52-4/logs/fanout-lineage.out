07:24 glm52-4\ndrwxr-xr-x@  3 michelkerkmeester  staff   96 Jul  8 07:24 glm52-5\ndrwxr-xr-x@ 14 michelkerkmeester  staff  448 Jul  8 07:24 gpt55-fast-1\ndrwxr-xr-x@  8 michelkerkmeester  staff  256 Jul  8 07:24 gpt55-fast-10\ndrwxr-xr-x@ 16 michelkerkmeester  staff  512 Jul  8 07:07 gpt55-fast-2\ndrwxr-xr-x@ 15 michelkerkmeester  staff  480 Jul  8 07:17 gpt55-fast-3\ndrwxr-xr-x@ 14 michelkerkmeester  staff  448 Jul  8 07:09 gpt55-fast-4\ndrwxr-xr-x@ 15 michelkerkmeester  staff  480 Jul  8 07:08 gpt55-fast-5\ndrwxr-xr-x@ 14 michelkerkmeester  staff  448 Jul  8 07:21 gpt55-fast-6\ndrwxr-xr-x@ 16 michelkerkmeester  staff  512 Jul  8 07:20 gpt55-fast-7\ndrwxr-xr-x@ 16 michelkerkmeester  staff  512 Jul  8 07:22 gpt55-fast-8\ndrwxr-xr-x@ 14 michelkerkmeester  staff  448 Jul  8 07:24 gpt55-fast-9\ndrwxr-xr-x@  3 michelkerkmeester  staff   96 Jul  8 07:24 sonnet5-1\n","metadata":{"output":"total 80\ndrwxr-xr-x@  9 michelkerkmeester  staff   288 Jul  8 06:46 .\ndrwxr-xr-x@ 10 michelkerkmeester  staff   320 Jul  8 07:23 ..\n-rw-r--r--@  1 michelkerkmeester  staff  3654 Jul  8 06:42 checklist.md\n-rw-r--r--@  1 michelkerkmeester  staff   768 Jul  8 06:36 description.json\n-rw-r--r--@  1 michelkerkmeester  staff  5231 Jul  8 06:43 graph-metadata.json\n-rw-r--r--@  1 michelkerkmeester  staff  8488 Jul  8 06:30 plan.md\ndrwxr-xr-x@  5 michelkerkmeester  staff   160 Jul  8 06:48 research\n-rw-r--r--@  1 michelkerkmeester  staff  7834 Jul  8 06:29 spec.md\n-rw-r--r--@  1 michelkerkmeester  staff  2655 Jul  8 06:30 tasks.md\n---LINEAGE DIR---\ntotal 0\ndrwxr-xr-x@  3 michelkerkmeester  staff   96 Jul  8 07:24 .\ndrwxr-xr-x@ 18 michelkerkmeester  staff  576 Jul  8 07:24 ..\ndrwxr-xr-x@  2 michelkerkmeester  staff   64 Jul  8 07:24 .executor-state\n---LINEAGES PARENT---\ntotal 0\ndrwxr-xr-x@ 18 michelkerkmeester  staff  576 Jul  8 07:24 .\ndrwxr-xr-x@  5 michelkerkmeester  staff  160 Jul  8 06:48 ..\ndrwxr-xr-x@ 10 michelkerkmeester  staff  320 Jul  8 07:23 glm52-1\ndrwxr-xr-x@  3 mi