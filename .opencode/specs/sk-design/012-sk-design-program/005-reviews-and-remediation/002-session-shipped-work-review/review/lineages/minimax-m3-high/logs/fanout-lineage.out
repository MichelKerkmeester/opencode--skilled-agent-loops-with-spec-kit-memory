{"type":"tool_use","timestamp":1784606370392,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d429aa7571b2ec9b43","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/generation-manifest.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/generation-manifest.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Versioned Multi-Artifact Generation Manifest                            ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // A generation's published state is a single content-addressed pointer that can\n6: // span more than one immutable artifact (the SQLite projection plus, when they\n7: // exist, screenshot features, model profiles, and an optional index). Publishing\n8: // is one atomic pointer flip; a reader either sees the whole prior manifest or\n9: // the whole new one, never a torn mixture. Legacy single-file pointers still\n10: // resolve so older publishers keep opening.\n11: \n12: import {\n13:   existsSync,\n14:   readFileSync,\n15:   realpathSync,\n16: } from 'node:fs';\n17: import { open, readFile, rename, rm } from 'node:fs/promises';\n18: import path from 'node:path';\n19: \n20: import { digest } from './canonical.mjs';\n21: \n22: export const MANIFEST_VERSION = 1;\n23: export const LEGACY_POINTER_VERSION = 1;\n24: \n25: // Roles the manifest may span. `sqlite` is mandatory today; the rest are\n26: // optional and additive so a sqlite-only publisher stays byte-compatible.\n27: export const MANIFEST_ARTIFACT_ROLES = Object.freeze([\n28:   'sqlite',\n29:   'screenshotFeatures',\n30:   'modelProfiles',\n31:   'index',\n32: ]);\n33: \n34: const ARTIFACT_SIDECAR_SUFFIXES = Object.freeze(['', '-wal', '-shm']);\n35: \n36: function manifestError(code, message, cause) {\n37:   const error = cause ? new Error(message, { cause }) : new Error(message);\n38:   error.code = code;\n39:   return error;\n40: }\n41: \n42: function isContained(rootPath, candidatePath) {\n43:   const relative = path.relative(rootPath, candidatePath);\n44:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n45: }\n46: \n47: function isBasename(value) {\n48:   return typeof value === 'string' && value.length > 0 && path.basename(value) === value;\n49: }\n50: \n51: /**\n52:  * Content-address a single artifact file by SHA-256 and byte length.\n53:  *\n54:  * @param {string} filePath - Absolute or relative artifact path.\n55:  * @returns {Promise<{sha256:string, bytes:number}>} Content identity.\n56:  */\n57: export async function hashArtifactFile(filePath) {\n58:   const buffer = await readFile(filePath);\n59:   return { sha256: digest([buffer]), bytes: buffer.byteLength };\n60: }\n61: \n62: /**\n63:  * Assemble a validated, immutable manifest document.\n64:  *\n65:  * @param {Object} input - Manifest fields.\n66:  * @param {string} input.generationHash - Generation identity hash.\n67:  * @param {string} input.createdAt - ISO timestamp for the publish event.\n68:  * @param {Object} input.artifacts - Role-keyed `{file, sha256, bytes}` entries.\n69:  * @param {string|null} [input.parentGenerationHash] - Prior generation identity.\n70:  * @returns {Object} Frozen manifest document.\n71:  */\n72: export function buildManifest({ generationHash, createdAt, artifacts, parentGenerationHash = null }) {\n73:   if (typeof generationHash !== 'string' || generationHash.length === 0) {\n74:     throw manifestError('manifest-invalid', 'Manifest requires a generation hash.');\n75:   }\n76:   if (!artifacts || typeof artifacts !== 'object' || !artifacts.sqlite) {\n77:     throw manifestError('manifest-invalid', 'Manifest requires at least a sqlite artifact.');\n78:   }\n79:   const normalizedArtifacts = {};\n80:   for (const role of MANIFEST_ARTIFACT_ROLES) {\n81:     const entry = artifacts[role];\n82:     if (!entry) continue;\n83:     if (!isBasename(entry.file)) {\n84:       throw manifestError('manifest-invalid', `Manifest artifact ${role} file must be a basename.`);\n85:     }\n86:     if (typeof entry.sha256 !== 'string' || !Number.isInteger(entry.bytes) || entry.bytes < 0) {\n87:       throw manifestError('manifest-invalid', `Manifest artifact ${role} needs sha256 and byte length.`);\n88:     }\n89:     normalizedArtifacts[role] = { role, file: entry.file, sha256: entry.sha256, bytes: entry.bytes };\n90:   }\n91:   return Object.freeze({\n92:     manifestVersion: MANIFEST_VERSION,\n93:     generationHash,\n94:     createdAt: typeof createdAt === 'string' ? createdAt : new Date(0).toISOString(),\n95:     parentGenerationHash: parentGenerationHash ?? null,\n96:     artifacts: normalizedArtifacts,\n97:   });\n98: }\n99: \n100: /**\n101:  * Render a manifest document as a stable, human-readable pointer payload.\n102:  *\n103:  * @param {Object} doc - Manifest document.\n104:  * @returns {string} Serialized manifest with a trailing newline.\n105:  */\n106: export function serializeManifest(doc) {\n107:   const artifacts = {};\n108:   for (const role of MANIFEST_ARTIFACT_ROLES) {\n109:     if (doc.artifacts[role]) artifacts[role] = doc.artifacts[role];\n110:   }\n111:   const ordered = {\n112:     manifestVersion: doc.manifestVersion,\n113:     generationHash: doc.generationHash,\n114:     createdAt: doc.createdAt,\n115:     parentGenerationHash: doc.parentGenerationHash ?? null,\n116:     artifacts,\n117:   };\n118:   return `${JSON.stringify(ordered, null, 2)}\\n`;\n119: }\n120: \n121: /**\n122:  * Normalize a parsed pointer payload, accepting manifest and legacy shapes.\n123:  *\n124:  * @param {*} raw - Parsed pointer JSON.\n125:  * @returns {{generationHash:string, sqliteFile:string, artifacts:Object, legacy:boolean}} Normalized pointer.\n126:  */\n127: export function normalizePointer(raw) {\n128:   if (raw && raw.manifestVersion === MANIFEST_VERSION) {\n129:     if (typeof raw.generationHash !== 'string'\n130:       || !raw.artifacts\n131:       || typeof raw.artifacts !== 'object'\n132:       || !raw.artifacts.sqlite\n133:       || !isBasename(raw.artifacts.sqlite.file)) {\n134:       throw manifestError('generation-pointer-invalid', 'Generation manifest has an invalid shape.');\n135:     }\n136:     return {\n137:       generationHash: raw.generationHash,\n138:       sqliteFile: raw.artifacts.sqlite.file,\n139:       artifacts: raw.artifacts,\n140:       legacy: false,\n141:     };\n142:   }\n143:   if (raw && raw.schemaVersion === LEGACY_POINTER_VERSION\n144:     && typeof raw.generationHash === 'string'\n145:     && isBasename(raw.databaseFile)) {\n146:     return {\n147:       generationHash: raw.generationHash,\n148:       sqliteFile: raw.databaseFile,\n149:       artifacts: { sqlite: { role: 'sqlite', file: raw.databaseFile } },\n150:       legacy: true,\n151:     };\n152:   }\n153:   throw manifestError('generation-pointer-invalid', 'Style database generation pointer has an invalid shape.');\n154: }\n155: \n156: /**\n157:  * Resolve the published SQLite target selected by an atomic pointer file.\n158:  *\n159:  * Containment and existence are always enforced; the SQLite artifact is bound\n160:  * to its generation hash by the caller rather than re-hashed on every open.\n161:  *\n162:  * @param {string} databasePath - Logical database path.\n163:  * @param {string} pointerSuffix - Pointer filename suffix.\n164:  * @returns {{databasePath:string, generationHash:string|null}} Resolved target.\n165:  */\n166: export function resolvePublishedTarget(databasePath, pointerSuffix) {\n167:   const pointerPath = `${databasePath}${pointerSuffix}`;\n168:   if (!existsSync(pointerPath)) return { databasePath, generationHash: null };\n169:   let raw;\n170:   try {\n171:     raw = JSON.parse(readFileSync(pointerPath, 'utf8'));\n172:   } catch (cause) {\n173:     throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n174:   }\n175:   const normalized = normalizePointer(raw);\n176:   const publishedPath = path.join(path.dirname(databasePath), normalized.sqliteFile);\n177:   if (!existsSync(publishedPath)) {\n178:     throw manifestError('generation-unavailable', 'Published style database generation is unavailable.');\n179:   }\n180:   const generationDirectory = realpathSync(path.dirname(databasePath));\n181:   const publishedRealPath = realpathSync(publishedPath);\n182:   if (!isContained(generationDirectory, publishedRealPath)) {\n183:     throw manifestError('generation-pointer-escape', 'Published style database generation escapes its directory.');\n184:   }\n185:   return { databasePath: publishedPath, generationHash: normalized.generationHash };\n186: }\n187: \n188: /**\n189:  * Read and normalize a pointer file without opening any artifact.\n190:  *\n191:  * @param {string} pointerPath - Absolute pointer path.\n192:  * @returns {Promise<Object>} Normalized pointer plus the manifest document.\n193:  */\n194: export async function readManifest(pointerPath) {\n195:   let raw;\n196:   try {\n197:     raw = JSON.parse(await readFile(pointerPath, 'utf8'));\n198:   } catch (cause) {\n199:     throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n200:   }\n201:   return { ...normalizePointer(raw), document: raw };\n202: }\n203: \n204: /**\n205:  * Validate every artifact a manifest references for a reader that binds it.\n206:  *\n207:  * @param {string} pointerPath - Absolute pointer path.\n208:  * @param {Object} [options] - Validation controls.\n209:  * @param {boolean} [options.verifyDigests=false] - Re-hash each artifact file.\n210:  * @returns {Promise<Object>} Resolved, validated artifact set.\n211:  */\n212: export async function resolveManifestArtifacts(pointerPath, { verifyDigests = false } = {}) {\n213:   const { generationHash, artifacts, legacy } = await readManifest(pointerPath);\n214:   const directory = path.dirname(pointerPath);\n215:   const directoryRealPath = realpathSync(directory);\n216:   const resolved = {};\n217:   for (const [role, entry] of Object.entries(artifacts)) {\n218:     const artifactPath = path.join(directory, entry.file);\n219:     if (!existsSync(artifactPath)) {\n220:       throw manifestError('generation-unavailable', `Manifest artifact ${role} is unavailable.`);\n221:     }\n222:     const artifactRealPath = realpathSync(artifactPath);\n223:     if (!isContained(directoryRealPath, artifactRealPath)) {\n224:       throw manifestError('generation-pointer-escape', `Manifest artifact ${role} escapes its directory.`);\n225:     }\n226:     if (verifyDigests && entry.sha256) {\n227:       const { sha256 } = await hashArtifactFile(artifactRealPath);\n228:       if (sha256 !== entry.sha256) {\n229:         throw manifestError('generation-artifact-tampered', `Manifest artifact ${role} failed digest verification.`);\n230:       }\n231:     }\n232:     resolved[role] = { role, file: entry.file, path: artifactPath, sha256: entry.sha256 ?? null };\n233:   }\n234:   return { generationHash, legacy, artifacts: resolved };\n235: }\n236: \n237: /**\n238:  * Atomically flip the pointer to a new manifest with fsync durability.\n239:  *\n240:  * The payload is written to a fresh temp file, fsynced, then renamed over the\n241:  * pointer, and the containing directory is fsynced so the flip survives crash.\n242:  *\n243:  * @param {string} pointerPath - Absolute pointer path.\n244:  * @param {Object} doc - Manifest document to publish.\n245:  * @param {Object} [options] - Hooks.\n246:  * @param {Function} [options.afterRename] - Invoked after the atomic rename.\n247:  * @returns {Promise<void>}\n248:  */\n249: export async function writeManifestPointer(pointerPath, doc, { afterRename } = {}) {\n250:   const serialized = serializeManifest(doc);\n251:   const temporaryPath = `${pointerPath}.tmp-${process.pid}-${Date.now()}`;\n252:   let temporaryHandle;\n253:   try {\n254:     temporaryHandle = await open(temporaryPath, 'wx');\n255:     await temporaryHandle.writeFile(serialized);\n256:     await temporaryHandle.sync();\n257:     await temporaryHandle.close();\n258:     temporaryHandle = null;\n259:     await rename(temporaryPath, pointerPath);\n260:     afterRename?.({ pointerPath, generationHash: doc.generationHash });\n261:     const directoryHandle = await open(path.dirname(pointerPath), 'r');\n262:     try {\n263:       await directoryHandle.sync();\n264:     } finally {\n265:       await directoryHandle.close();\n266:     }\n267:   } finally {\n268:     if (temporaryHandle) await temporaryHandle.close();\n269:     await rm(temporaryPath, { force: true });\n270:   }\n271: }\n272: \n273: /**\n274:  * List the artifact basenames a manifest document references.\n275:  *\n276:  * @param {Object} doc - Manifest document.\n277:  * @returns {string[]} Artifact basenames.\n278:  */\n279: export function manifestArtifactFiles(doc) {\n280:   return Object.values(doc.artifacts).map((artifact) => artifact.file);\n281: }\n282: \n283: /**\n284:  * Prune whole generations, keeping every artifact of the retained manifests.\n285:  *\n286:  * An artifact file is removed only when no retained manifest references it, so a\n287:  * generation is dropped as a unit rather than leaving orphaned artifacts.\n288:  *\n289:  * @param {Object} options - Retention inputs.\n290:  * @param {string} options.directory - Directory holding the artifact files.\n291:  * @param {Object[]} options.retain - Manifests to keep intact.\n292:  * @param {Object[]} options.prune - Manifests eligible for removal.\n293:  * @returns {Promise<{kept:string[], removed:string[]}>} Retention outcome.\n294:  */\n295: export async function pruneManifestGenerations({ directory, retain, prune }) {\n296:   const keep = new Set(retain.flatMap(manifestArtifactFiles));\n297:   const removed = [];\n298:   for (const doc of prune) {\n299:     for (const file of manifestArtifactFiles(doc)) {\n300:       if (keep.has(file)) continue;\n301:       for (const suffix of ARTIFACT_SIDECAR_SUFFIXES) {\n302:         await rm(path.join(directory, `${file}${suffix}`), { force: true });\n303:       }\n304:       removed.push(file);\n305:     }\n306:   }\n307:   return { kept: [...keep], removed };\n308: }\n\n(End of file - total 308 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Versioned Multi-Artifact Generation Manifest                            ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A generation's published state is a single content-addressed pointer that can\n// span more than one immutable artifact (the SQLite projection plus, when they\n// exist, screenshot features, model profiles, and an optional index). Publishing\n// is one atomic pointer flip; a reader either sees the whole prior manifest or\n// the whole new one, never a torn mixture. Legacy single-file pointers still\n// resolve so older publishers keep opening.\n\nimport {\n  existsSync,\n  readFileSync,\n  realpathSync,\n} from 'node:fs';\nimport { open, readFile, rename, rm } from 'node:fs/promises';\nimport path from 'node:path';\n\nimport { digest } from './canonical.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/generation-manifest.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Versioned Multi-Artifact Generation Manifest                            ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A generation's published state is a single content-addressed pointer that can\n// span more than one immutable artifact (the SQLite projection plus, when they\n// exist, screenshot features, model profiles, and an optional index). Publishing\n// is one atomic pointer flip; a reader either sees the whole prior manifest or\n// the whole new one, never a torn mixture. Legacy single-file pointers still\n// resolve so older publishers keep opening.\n\nimport {\n  existsSync,\n  readFileSync,\n  realpathSync,\n} from 'node:fs';\nimport { open, readFile, rename, rm } from 'node:fs/promises';\nimport path from 'node:path';\n\nimport { digest } from './canonical.mjs';\n\nexport const MANIFEST_VERSION = 1;\nexport const LEGACY_POINTER_VERSION = 1;\n\n// Roles the manifest may span. `sqlite` is mandatory today; the rest are\n// optional and additive so a sqlite-only publisher stays byte-compatible.\nexport const MANIFEST_ARTIFACT_ROLES = Object.freeze([\n  'sqlite',\n  'screenshotFeatures',\n  'modelProfiles',\n  'index',\n]);\n\nconst ARTIFACT_SIDECAR_SUFFIXES = Object.freeze(['', '-wal', '-shm']);\n\nfunction manifestError(code, message, cause) {\n  const error = cause ? new Error(message, { cause }) : new Error(message);\n  error.code = code;\n  return error;\n}\n\nfunction isContained(rootPath, candidatePath) {\n  const relative = path.relative(rootPath, candidatePath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction isBasename(value) {\n  return typeof value === 'string' && value.length > 0 && path.basename(value) === value;\n}\n\n/**\n * Content-address a single artifact file by SHA-256 and byte length.\n *\n * @param {string} filePath - Absolute or relative artifact path.\n * @returns {Promise<{sha256:string, bytes:number}>} Content identity.\n */\nexport async function hashArtifactFile(filePath) {\n  const buffer = await readFile(filePath);\n  return { sha256: digest([buffer]), bytes: buffer.byteLength };\n}\n\n/**\n * Assemble a validated, immutable manifest document.\n *\n * @param {Object} input - Manifest fields.\n * @param {string} input.generationHash - Generation identity hash.\n * @param {string} input.createdAt - ISO timestamp for the publish event.\n * @param {Object} input.artifacts - Role-keyed `{file, sha256, bytes}` entries.\n * @param {string|null} [input.parentGenerationHash] - Prior generation identity.\n * @returns {Object} Frozen manifest document.\n */\nexport function buildManifest({ generationHash, createdAt, artifacts, parentGenerationHash = null }) {\n  if (typeof generationHash !== 'string' || generationHash.length === 0) {\n    throw manifestError('manifest-invalid', 'Manifest requires a generation hash.');\n  }\n  if (!artifacts || typeof artifacts !== 'object' || !artifacts.sqlite) {\n    throw manifestError('manifest-invalid', 'Manifest requires at least a sqlite artifact.');\n  }\n  const normalizedArtifacts = {};\n  for (const role of MANIFEST_ARTIFACT_ROLES) {\n    const entry = artifacts[role];\n    if (!entry) continue;\n    if (!isBasename(entry.file)) {\n      throw manifestError('manifest-invalid', `Manifest artifact ${role} file must be a basename.`);\n    }\n    if (typeof entry.sha256 !== 'string' || !Number.isInteger(entry.bytes) || entry.bytes < 0) {\n      throw manifestError('manifest-invalid', `Manifest artifact ${role} needs sha256 and byte length.`);\n    }\n    normalizedArtifacts[role] = { role, file: entry.file, sha256: entry.sha256, bytes: entry.bytes };\n  }\n  return Object.freeze({\n    manifestVersion: MANIFEST_VERSION,\n    generationHash,\n    createdAt: typeof createdAt === 'string' ? createdAt : new Date(0).toISOString(),\n    parentGenerationHash: parentGenerationHash ?? null,\n    artifacts: normalizedArtifacts,\n  });\n}\n\n/**\n * Render a manifest document as a stable, human-readable pointer payload.\n *\n * @param {Object} doc - Manifest document.\n * @returns {string} Serialized manifest with a trailing newline.\n */\nexport function serializeManifest(doc) {\n  const artifacts = {};\n  for (const role of MANIFEST_ARTIFACT_ROLES) {\n    if (doc.artifacts[role]) artifacts[role] = doc.artifacts[role];\n  }\n  const ordered = {\n    manifestVersion: doc.manifestVersion,\n    generationHash: doc.generationHash,\n    createdAt: doc.createdAt,\n    parentGenerationHash: doc.parentGenerationHash ?? null,\n    artifacts,\n  };\n  return `${JSON.stringify(ordered, null, 2)}\\n`;\n}\n\n/**\n * Normalize a parsed pointer payload, accepting manifest and legacy shapes.\n *\n * @param {*} raw - Parsed pointer JSON.\n * @returns {{generationHash:string, sqliteFile:string, artifacts:Object, legacy:boolean}} Normalized pointer.\n */\nexport function normalizePointer(raw) {\n  if (raw && raw.manifestVersion === MANIFEST_VERSION) {\n    if (typeof raw.generationHash !== 'string'\n      || !raw.artifacts\n      || typeof raw.artifacts !== 'object'\n      || !raw.artifacts.sqlite\n      || !isBasename(raw.artifacts.sqlite.file)) {\n      throw manifestError('generation-pointer-invalid', 'Generation manifest has an invalid shape.');\n    }\n    return {\n      generationHash: raw.generationHash,\n      sqliteFile: raw.artifacts.sqlite.file,\n      artifacts: raw.artifacts,\n      legacy: false,\n    };\n  }\n  if (raw && raw.schemaVersion === LEGACY_POINTER_VERSION\n    && typeof raw.generationHash === 'string'\n    && isBasename(raw.databaseFile)) {\n    return {\n      generationHash: raw.generationHash,\n      sqliteFile: raw.databaseFile,\n      artifacts: { sqlite: { role: 'sqlite', file: raw.databaseFile } },\n      legacy: true,\n    };\n  }\n  throw manifestError('generation-pointer-invalid', 'Style database generation pointer has an invalid shape.');\n}\n\n/**\n * Resolve the published SQLite target selected by an atomic pointer file.\n *\n * Containment and existence are always enforced; the SQLite artifact is bound\n * to its generation hash by the caller rather than re-hashed on every open.\n *\n * @param {string} databasePath - Logical database path.\n * @param {string} pointerSuffix - Pointer filename suffix.\n * @returns {{databasePath:string, generationHash:string|null}} Resolved target.\n */\nexport function resolvePublishedTarget(databasePath, pointerSuffix) {\n  const pointerPath = `${databasePath}${pointerSuffix}`;\n  if (!existsSync(pointerPath)) return { databasePath, generationHash: null };\n  let raw;\n  try {\n    raw = JSON.parse(readFileSync(pointerPath, 'utf8'));\n  } catch (cause) {\n    throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n  }\n  const normalized = normalizePointer(raw);\n  const publishedPath = path.join(path.dirname(databasePath), normalized.sqliteFile);\n  if (!existsSync(publishedPath)) {\n    throw manifestError('generation-unavailable', 'Published style database generation is unavailable.');\n  }\n  const generationDirectory = realpathSync(path.dirname(databasePath));\n  const publishedRealPath = realpathSync(publishedPath);\n  if (!isContained(generationDirectory, publishedRealPath)) {\n    throw manifestError('generation-pointer-escape', 'Published style database generation escapes its directory.');\n  }\n  return { databasePath: publishedPath, generationHash: normalized.generationHash };\n}\n\n/**\n * Read and normalize a pointer file without opening any artifact.\n *\n * @param {string} pointerPath - Absolute pointer path.\n * @returns {Promise<Object>} Normalized pointer plus the manifest document.\n */\nexport async function readManifest(pointerPath) {\n  let raw;\n  try {\n    raw = JSON.parse(await readFile(pointerPath, 'utf8'));\n  } catch (cause) {\n    throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n  }\n  return { ...normalizePointer(raw), document: raw };\n}\n\n/**\n * Validate every artifact a manifest references for a reader that binds it.\n *\n * @param {string} pointerPath - Absolute pointer path.\n * @param {Object} [options] - Validation controls.\n * @param {boolean} [options.verifyDigests=false] - Re-hash each artifact file.\n * @returns {Promise<Object>} Resolved, validated artifact set.\n */\nexport async function resolveManifestArtifacts(pointerPath, { verifyDigests = false } = {}) {\n  const { generationHash, artifacts, legacy } = await readManifest(pointerPath);\n  const directory = path.dirname(pointerPath);\n  const directoryRealPath = realpathSync(directory);\n  const resolved = {};\n  for (const [role, entry] of Object.entries(artifacts)) {\n    const artifactPath = path.join(directory, entry.file);\n    if (!existsSync(artifactPath)) {\n      throw manifestError('generation-unavailable', `Manifest artifact ${role} is unavailable.`);\n    }\n    const artifactRealPath = realpathSync(artifactPath);\n    if (!isContained(directoryRealPath, artifactRealPath)) {\n      throw manifestError('generation-pointer-escape', `Manifest artifact ${role} escapes its directory.`);\n    }\n    if (verifyDigests && entry.sha256) {\n      const { sha256 } = await hashArtifactFile(artifactRealPath);\n      if (sha256 !== entry.sha256) {\n        throw manifestError('generation-artifact-tampered', `Manifest artifact ${role} failed digest verification.`);\n      }\n    }\n    resolved[role] = { role, file: entry.file, path: artifactPath, sha256: entry.sha256 ?? null };\n  }\n  return { generationHash, legacy, artifacts: resolved };\n}\n\n/**\n * Atomically flip the pointer to a new manifest with fsync durability.\n *\n * The payload is written to a fresh temp file, fsynced, then renamed over the\n * pointer, and the containing directory is fsynced so the flip survives crash.\n *\n * @param {string} pointerPath - Absolute pointer path.\n * @param {Object} doc - Manifest document to publish.\n * @param {Object} [options] - Hooks.\n * @param {Function} [options.afterRename] - Invoked after the atomic rename.\n * @returns {Promise<void>}\n */\nexport async function writeManifestPointer(pointerPath, doc, { afterRename } = {}) {\n  const serialized = serializeManifest(doc);\n  const temporaryPath = `${pointerPath}.tmp-${process.pid}-${Date.now()}`;\n  let temporaryHandle;\n  try {\n    temporaryHandle = await open(temporaryPath, 'wx');\n    await temporaryHandle.writeFile(serialized);\n    await temporaryHandle.sync();\n    await temporaryHandle.close();\n    temporaryHandle = null;\n    await rename(temporaryPath, pointerPath);\n    afterRename?.({ pointerPath, generationHash: doc.generationHash });\n    const directoryHandle = await open(path.dirname(pointerPath), 'r');\n    try {\n      await directoryHandle.sync();\n    } finally {\n      await directoryHandle.close();\n    }\n  } finally {\n    if (temporaryHandle) await temporaryHandle.close();\n    await rm(temporaryPath, { force: true });\n  }\n}\n\n/**\n * List the artifact basenames a manifest document references.\n *\n * @param {Object} doc - Manifest document.\n * @returns {string[]} Artifact basenames.\n */\nexport function manifestArtifactFiles(doc) {\n  return Object.values(doc.artifacts).map((artifact) => artifact.file);\n}\n\n/**\n * Prune whole generations, keeping every artifact of the retained manifests.\n *\n * An artifact file is removed only when no retained manifest references it, so a\n * generation is dropped as a unit rather than leaving orphaned artifacts.\n *\n * @param {Object} options - Retention inputs.\n * @param {string} options.directory - Directory holding the artifact files.\n * @param {Object[]} options.retain - Manifests to keep intact.\n * @param {Object[]} options.prune - Manifests eligible for removal.\n * @returns {Promise<{kept:string[], removed:string[]}>} Retention outcome.\n */\nexport async function pruneManifestGenerations({ directory, retain, prune }) {\n  const keep = new Set(retain.flatMap(manifestArtifactFiles));\n  const removed = [];\n  for (const doc of prune) {\n    for (const file of manifestArtifactFiles(doc)) {\n      if (keep.has(file)) continue;\n      for (const suffix of ARTIFACT_SIDECAR_SUFFIXES) {\n        await rm(path.join(directory, `${file}${suffix}`), { force: true });\n      }\n      removed.push(file);\n    }\n  }\n  return { kept: [...keep], removed };\n}","lineStart":1,"lineEnd":308,"totalLines":308,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/generation-manifest.mjs","time":{"start":1784606370386,"end":1784606370390}},"id":"prt_f82d42a20001VdiAtO26kJ4hdV","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d421ca001tJ0TD0vhxfQL8O"}}
