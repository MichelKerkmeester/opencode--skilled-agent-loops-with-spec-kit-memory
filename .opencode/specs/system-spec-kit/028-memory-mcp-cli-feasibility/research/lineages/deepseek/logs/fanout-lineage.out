{"type":"tool_use","timestamp":1780736007932,"sessionID":"ses_163de1863ffeK7dtB9Aq2sZ9Js","part":{"type":"tool","tool":"read","callID":"call_00_scoz0NPevBHV4JdqJTr86469","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   releaseRespawnLockFile,\n37:   sampleProcessTreeRssMb,\n38:   shouldSkipLaunch,\n39:   signalProcess,\n40:   superviseChildExit,\n41:   waitForPidExit,\n42: } = mss;\n43: \n44: const root = path.resolve(__dirname, '..', '..');\n45: const opencodeDir = path.join(root, '.opencode');\n46: \n47: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n48: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n49: // Minimal parser — no external dependency.\n50: function loadEnvFile(filePath) {\n51:   if (!fs.existsSync(filePath)) return 0;\n52:   let count = 0;\n53:   const raw = fs.readFileSync(filePath, 'utf8');\n54:   for (const line of raw.split('\\n')) {\n55:     const trimmed = line.trim();\n56:     if (!trimmed || trimmed.startsWith('#')) continue;\n57:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n58:     if (!m) continue;\n59:     const key = m[1];\n60:     let val = m[2];\n61:     // Strip matching outer quotes (single or double)\n62:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n63:       val = val.slice(1, -1);\n64:     }\n65:     if (!(key in process.env)) {\n66:       process.env[key] = val;\n67:       count++;\n68:     }\n69:   }\n70:   return count;\n71: }\n72: \n73: function isStrictModeDisabled(value) {\n74:   if (value === undefined || value === null) return false;\n75:   const v = String(value).trim().toLowerCase();\n76:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n77: }\n78: \n79: let skillsDir = path.join(opencodeDir, 'skills');\n80: let legacySkillDir = path.join(opencodeDir, 'skill');\n81: let kitDir = path.join(skillsDir, 'system-spec-kit');\n82: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n83: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n84: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n85: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n86: let stateFile = path.join(dbDir, PID_FILE_NAME);\n87: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n88: \n89: const rel = (p) => path.relative(root, p) || '.';\n90: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n91: const now = () => new Date().toISOString();\n92: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n93: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n94: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n95: let childProcess = null;\n96: let ownerLeasePid = null;\n97: let leaseStartedAt = null;\n98: let launcherShutdownInProgress = false;\n99: let rssBreachSelfExitInProgress = false;\n100: let rssWatchdogTimer = null;\n101: let crashLoopGuard = null;\n102: let supervisorRelaunchTimer = null;\n103: let ownerLeaseHeartbeatTimer = null;\n104: let ownerLeaseRequired = true;\n105: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n106: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n107: // orphaned sidecar after the child has already exited.\n108: let lastKnownDescendantPids = [];\n109: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n110: const durableWriteWarnings = new Set();\n111: \n112: function log(message) {\n113:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n114: }\n115: \n116: function isDurableWriteUnavailable(error) {\n117:   const code = error && typeof error === 'object' ? error.code : undefined;\n118:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n119: }\n120: \n121: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n122:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n123:   const key = `${operation}:${targetPath}:${code}`;\n124:   if (durableWriteWarnings.has(key)) return;\n125:   durableWriteWarnings.add(key);\n126:   const detail = error instanceof Error ? error.message : String(error ?? code);\n127:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n128: }\n129: \n130: function cleanupTmpFile(tmpPath) {\n131:   try {\n132:     fs.unlinkSync(tmpPath);\n133:   } catch (error) {\n134:     if (error.code !== 'ENOENT') {\n135:       // Best-effort cleanup only; the original durable-write failure is more useful.\n136:     }\n137:   }\n138: }\n139: \n140: function writeAtomicJsonFile(targetPath, payload, operation) {\n141:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n142:   const tmp = `${currentPath}.tmp.${process.pid}`;\n143:   try {\n144:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n145:     fs.renameSync(tmp, currentPath);\n146:     return true;\n147:   } catch (error) {\n148:     cleanupTmpFile(tmp);\n149:     if (isDurableWriteUnavailable(error)) {\n150:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n151:       return false;\n152:     }\n153:     throw error;\n154:   }\n155: }\n156: \n157: function loadProjectEnvFiles() {\n158:   for (const fname of ['.env.local', '.env']) {\n159:     const p = path.join(root, fname);\n160:     if (fs.existsSync(p)) {\n161:       const n = loadEnvFile(p);\n162:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n163:     }\n164:   }\n165: }\n166: \n167: function parsePositiveInteger(value, fallback) {\n168:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n169:   const parsed = Number.parseInt(String(value).trim(), 10);\n170:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n171: }\n172: \n173: function loadBridgeModule() {\n174:   try {\n175:     return require('./lib/launcher-ipc-bridge.cjs');\n176:   } catch (error) {\n177:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n178:     return {\n179:       async maybeBridgeLeaseHolder({ leaseResult }) {\n180:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n181:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n182:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n183:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n184:         return { action: 'report', reason: 'bridge-module-missing' };\n185:       },\n186:     };\n187:   }\n188: }\n189: \n190: function resolveSessionProxySocketPath() {\n191:   const { getIpcSocketPath } = loadBridgeModule();\n192:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n193: }\n194: \n195: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n196: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n197: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n198: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n199: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n200: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n201: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n202: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n203:   const createProxy = options.createProxy ?? createSessionProxy;\n204:   const sessionProxy = createProxy({\n205:     socketPath,\n206:     stdin: options.stdin ?? process.stdin,\n207:     stdout: options.stdout ?? process.stdout,\n208:     log,\n209:   });\n210:   return sessionProxy.start();\n211: }\n212: \n213: function refreshPaths() {\n214:   skillsDir = path.join(opencodeDir, 'skills');\n215:   legacySkillDir = path.join(opencodeDir, 'skill');\n216:   kitDir = path.join(skillsDir, 'system-spec-kit');\n217:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n218:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n219:   stateFile = path.join(dbDir, PID_FILE_NAME);\n220:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n221: }\n222: \n223: function exists(p) {\n224:   return fs.existsSync(p);\n225: }\n226: \n227: function writeState(payload) {\n228:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n229:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n230: }\n231: \n232: function resolvedDbDir() {\n233:   return canonicalizePath(dbDir);\n234: }\n235: \n236: function leasePath() {\n237:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n238: }\n239: \n240: function ownerLeasePath() {\n241:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n242: }\n243: \n244: function legacyLeasePaths() {\n245:   return [\n246:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n247:   ].map(canonicalizePath);\n248: }\n249: \n250: function readLeaseFile(filePath = leasePath()) {\n251:   try {\n252:     const raw = fs.readFileSync(filePath, 'utf8');\n253:     const parsed = JSON.parse(raw);\n254:     if (typeof parsed.pid === 'number') return parsed;\n255:   } catch {\n256:     // Missing or corrupt lease files are treated as no active lease.\n257:   }\n258:   return null;\n259: }\n260: \n261: function readOwnerLeaseFile(filePath = ownerLeasePath()) {\n262:   try {\n263:     const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n264:     if (\n265:       Number.isInteger(parsed.ownerPid) &&\n266:       Number.isInteger(parsed.ppid) &&\n267:       typeof parsed.executablePath === 'string' &&\n268:       typeof parsed.startedAtIso === 'string' &&\n269:       typeof parsed.lastHeartbeatIso === 'string' &&\n270:       Number.isInteger(parsed.ttlMs) &&\n271:       typeof parsed.canonicalDbDir === 'string'\n272:     ) {\n273:       return parsed;\n274:     }\n275:   } catch {\n276:     // Missing or corrupt owner leases are treated as no active owner.\n277:   }\n278:   return null;\n279: }\n280: \n281: function writeOwnerLeaseFile(lease) {\n282:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n283:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n284:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n285:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n286:   // after power loss and break ownership detection.\n287:   let fd;\n288:   try {\n289:     fd = fs.openSync(tmp, 'wx', 0o600);\n290:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n291:     fs.fsyncSync(fd);\n292:   } finally {\n293:     if (typeof fd === 'number') fs.closeSync(fd);\n294:   }\n295:   fs.renameSync(tmp, currentLeasePath);\n296: }\n297: \n298: function writeOwnerLeaseFileExclusive(lease) {\n299:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n300:   let fd;\n301:   try {\n302:     fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n303:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n304:     fs.fsyncSync(fd);\n305:     return true;\n306:   } catch (error) {\n307:     if (error.code === 'EEXIST') return false;\n308:     throw error;\n309:   } finally {\n310:     if (typeof fd === 'number') fs.closeSync(fd);\n311:   }\n312: }\n313: \n314: function buildOwnerLease(ownerPid = process.pid) {\n315:   return {\n316:     ownerPid,\n317:     ppid: process.ppid,\n318:     executablePath: process.execPath,\n319:     startedAtIso: new Date().toISOString(),\n320:     lastHeartbeatIso: new Date().toISOString(),\n321:     ttlMs: 60000,\n322:     canonicalDbDir: resolvedDbDir(),\n323:   };\n324: }\n325: \n326: function readParentPid(pid) {\n327:   if (!Number.isInteger(pid) || pid <= 0) return null;\n328:   if (process.platform === 'linux') {\n329:     try {\n330:       const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n331:       const match = status.match(/^PPid:\\s+(\\d+)$/m);\n332:       return match ? Number.parseInt(match[1], 10) : null;\n333:     } catch {\n334:       return null;\n335:     }\n336:   }\n337:   const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n338:     encoding: 'utf8',\n339:     stdio: ['ignore', 'pipe', 'ignore'],\n340:   });\n341:   if (result.status !== 0 || !result.stdout) return null;\n342:   const parsed = Number.parseInt(result.stdout.trim(), 10);\n343:   return Number.isInteger(parsed) ? parsed : null;\n344: }\n345: \n346: function classifyOwnerLease(lease) {\n347:   const liveness = processLiveness(lease.ownerPid);\n348:   if (liveness === 'dead') return 'stale-pid';\n349:   if (liveness === 'unknown-eperm') return 'unknown-eperm';\n350: \n351:   const actualPpid = readParentPid(lease.ownerPid);\n352:   if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n353:     return 'ppid-1-orphan';\n354:   }\n355: \n356:   const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n357:   const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n358:   if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n359:     return 'stale-heartbeat-reclaim';\n360:   }\n361: \n362:   return 'live-owner';\n363: }\n364: \n365: function acquireOwnerLeaseFile() {\n366:   const currentOwnerLeasePath = ownerLeasePath();\n367:   const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n368: \n369:   if (existing) {\n370:     const classification = classifyOwnerLease(existing);\n371:     if (classification === 'live-owner' || classification === 'unknown-eperm') {\n372:       return { acquired: false, holder: existing, classification };\n373:     }\n374:     log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n375:   }\n376: \n377:   const lease = buildOwnerLease(process.pid);\n378:   if (!existing) {\n379:     if (!writeOwnerLeaseFileExclusive(lease)) {\n380:       const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n381:       return {\n382:         acquired: false,\n383:         holder: holder || lease,\n384:         classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n385:       };\n386:     }\n387:     ownerLeasePid = process.pid;\n388:     return { acquired: true, lease, reclaimed: existing };\n389:   }\n390: \n391:   // Re-read after reclaim so two launchers racing a stale lease cannot both act as owner.\n392:   writeOwnerLeaseFile(lease);\n393:   const reread = readOwnerLeaseFile(currentOwnerLeasePath);\n394:   if (!reread || reread.ownerPid !== process.pid) {\n395:     return {\n396:       acquired: false,\n397:       holder: reread || lease,\n398:       classification: reread ? classifyOwnerLease(reread) : 'live-owner',\n399:     };\n400:   }\n401:   ownerLeasePid = process.pid;\n402:   return { acquired: true, lease, reclaimed: existing };\n403: }\n404: \n405: function refreshOwnerLeaseFile(ownerPid, patch = {}) {\n406:   const lease = readOwnerLeaseFile();\n407:   if (!lease || lease.ownerPid !== ownerPid) return false;\n408:   const nextOwnerPid = patch.ownerPid ?? ownerPid;\n409:   writeOwnerLeaseFile({\n410:     ...lease,\n411:     ...patch,\n412:     lastHeartbeatIso: new Date().toISOString(),\n413:   });\n414:   const reread = readOwnerLeaseFile();\n415:   if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n416:   ownerLeasePid = nextOwnerPid;\n417:   return true;\n418: }\n419: \n420: function clearOwnerLeaseHeartbeat() {\n421:   if (ownerLeaseHeartbeatTimer) {\n422:     clearInterval(ownerLeaseHeartbeatTimer);\n423:     ownerLeaseHeartbeatTimer = null;\n424:   }\n425: }\n426: \n427: function startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n428:   clearOwnerLeaseHeartbeat();\n429:   const lease = readOwnerLeaseFile();\n430:   const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n431:   const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n432:   ownerLeaseHeartbeatTimer = setInterval(() => {\n433:     if (refreshOwnerLeaseFile(ownerPid)) return;\n434:     log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n435:     clearOwnerLeaseHeartbeat();\n436:     void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n437:       log(error.stack || error.message);\n438:       clearAllLeaseFiles();\n439:       process.exit(128);\n440:     });\n441:   }, intervalMs);\n442:   ownerLeaseHeartbeatTimer.unref?.();\n443: }\n444: \n445: function ownsOwnerLeaseFile(ownerPid = process.pid) {\n446:   const lease = readOwnerLeaseFile();\n447:   return lease?.ownerPid === ownerPid;\n448: }\n449: \n450: function clearOwnerLeaseFile() {\n451:   if (!Number.isInteger(ownerLeasePid)) return;\n452:   try {\n453:     const lease = readOwnerLeaseFile();\n454:     if (lease && lease.ownerPid === ownerLeasePid\n455:         && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n456:       fs.unlinkSync(ownerLeasePath());\n457:     }\n458:   } catch {\n459:     // Idempotent cleanup.\n460:   } finally {\n461:     clearOwnerLeaseHeartbeat();\n462:     ownerLeasePid = null;\n463:   }\n464: }\n465: \n466: function clearOwnerLeaseFileIfOwner(ownerPid) {\n467:   try {\n468:     const lease = readOwnerLeaseFile();\n469:     if (lease && lease.ownerPid === ownerPid\n470:         && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n471:       fs.unlinkSync(ownerLeasePath());\n472:     }\n473:   } catch {\n474:     // Idempotent cleanup.\n475:   }\n476: }\n477: \n478: function leaseHeldFromFile(filePath, legacyPath = null) {\n479:   const lease = readLeaseFile(filePath);\n480:   if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };\n481:   const startedAt = lease.startedAt ?? new Date(0).toISOString();\n482:   // Surface the owner-recorded socket path so the bridge can prefer it over recomputing one that\n483:   // may diverge under a different SPECKIT_IPC_SOCKET_DIR. Null when the lease predates this field.\n484:   const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;\n485:   try {\n486:     process.kill(lease.pid, 0);\n487:     return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n488:   } catch (error) {\n489:     if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };\n490:     // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n491:     if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n492:     throw error;\n493:   }\n494: }\n495: \n496: function isLeaseHeld() {\n497:   const primary = leaseHeldFromFile(leasePath());\n498:   if (primary.held) return primary;\n499: \n500:   for (const legacyPath of legacyLeasePaths()) {\n501:     if (legacyPath === leasePath()) continue;\n502:     const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n503:     if (legacy.held || legacy.staleReclaimable) return legacy;\n504:   }\n505: \n506:   return primary;\n507: }\n508: \n509: function writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n510:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n511:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n512:   process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n513: }\n514: \n515: function writeLeaseHeldJsonRpcError(leaseResult, reason) {\n516:   process.stdout.write(`${JSON.stringify({\n517:     jsonrpc: '2.0',\n518:     id: null,\n519:     error: {\n520:       code: -32001,\n521:       message: `mk-spec-memory: lease held by pid ${leaseResult.ownerPid} but session bridge unavailable (${reason}); reconnect`,\n522:       data: { retryable: true },\n523:     },\n524:   })}\\n`);\n525: }\n526: \n527: function bridgeReadiness(leaseResult) {\n528:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n529:     return { ready: false, reason: 'bridge-disabled' };\n530:   }\n531:   const storedSocketPath = leaseResult.socketPath;\n532:   if (\n533:     typeof storedSocketPath === 'string' &&\n534:     storedSocketPath.length > 0 &&\n535:     (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n536:   ) {\n537:     return { ready: true, socketPath: storedSocketPath };\n538:   }\n539:   const { getIpcSocketPath } = loadBridgeModule();\n540:   if (typeof getIpcSocketPath !== 'function') {\n541:     return { ready: false, reason: 'bridge-module-missing' };\n542:   }\n543:   const socketPath = getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n544:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n545:     return { ready: false, reason: 'no-bridge-socket' };\n546:   }\n547:   return { ready: true, socketPath };\n548: }\n549: \n550: function leaseResultForOwnerLease(ownerLease) {\n551:   const pidLeaseResult = isLeaseHeld();\n552:   if (pidLeaseResult.held && pidLeaseResult.ownerPid === ownerLease.ownerPid) {\n553:     return pidLeaseResult;\n554:   }\n555:   return {\n556:     held: true,\n557:     ownerPid: ownerLease.ownerPid,\n558:     staleReclaimable: false,\n559:     startedAt: ownerLease.startedAtIso,\n560:     legacyPath: null,\n561:     socketPath: null,\n562:   };\n563: }\n564: \n565: function respawnLockPath() {\n566:   return path.join(resolvedDbDir(), '.mk-spec-memory-respawn.lock');\n567: }\n568: \n569: function modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath()) {\n570:   return mss.modelServerRespawnLockPath(socketPath, { dbDir: resolvedDbDir });\n571: }\n572: \n573: function acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n574:   return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n575: }\n576: \n577: function acquireRespawnLockFile() {\n578:   return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n579: }\n580: \n581: function acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n582:   return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n583: }\n584: \n585: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n586: \n587: // The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n588: // successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n589: // child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n590: // DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n591: // guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\n592: function uncleanShutdownMarkerPath() {\n593:   const override = process.env.MEMORY_DB_PATH;\n594:   const dir = override ? path.dirname(override) : resolvedDbDir();\n595:   return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n596: }\n597: \n598: function uncleanMarkerPresent() {\n599:   try {\n600:     return fs.existsSync(uncleanShutdownMarkerPath());\n601:   } catch {\n602:     return false;\n603:   }\n604: }\n605: \n606: // A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n607: // clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n608: // replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\n609: function cleanCloseAfterReap({ killed, markerPresent }) {\n610:   return !killed && !markerPresent;\n611: }\n612: \n613: async function reapLeaseChildBeforeRespawn(childPid) {\n614:   const liveness = processLiveness(childPid);\n615:   if (liveness === 'unknown-eperm') {\n616:     return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n617:   }\n618:   if (liveness === 'dead') {\n619:     return {\n620:       allowed: true,\n621:       reaped: false,\n622:       cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n623:       reason: 'child-already-dead',\n624:     };\n625:   }\n626: \n627:   log(`confirmed-dead socket; reaping recorded context-server child pid ${childPid} before respawn`);\n628:   signalProcess(childPid, 'SIGTERM');\n629:   reapProcessTreeGroups(childPid, { signal: signalProcess });\n630:   const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n631:   let killed = false;\n632:   if (!exitedAfterTerm) {\n633:     log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n634:     signalProcess(childPid, 'SIGKILL');\n635:     await waitForPidExit(childPid, 1000);\n636:     killed = true;\n637:   }\n638: \n639:   // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n640:   // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n641:   // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n642:   // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n643:   const markerPresent = uncleanMarkerPresent();\n644:   const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n645:   if (!cleanClose) {\n646:     log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n647:   }\n648:   return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n649: }\n650: \n651: async function reapOwnerBeforeRespawn(ownerPid) {\n652:   const liveness = processLiveness(ownerPid);\n653:   if (liveness === 'unknown-eperm') {\n654:     return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n655:   }\n656:   if (liveness === 'dead') {\n657:     return { allowed: true, reason: 'owner-already-dead' };\n658:   }\n659: \n660:   log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n661:   signalProcess(ownerPid, 'SIGTERM');\n662:   const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n663:   if (!exitedAfterTerm) {\n664:     log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n665:     signalProcess(ownerPid, 'SIGKILL');\n666:     await waitForPidExit(ownerPid, 1000);\n667:   }\n668:   return { allowed: true, reason: 'owner-reaped' };\n669: }\n670: \n671: async function respawnAfterDeadSocket(leaseResult, decision) {\n672:   if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n673:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n674:     return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n675:   }\n676: \n677:   const ownerPid = leaseResult.ownerPid;\n678:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n679:     log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n680:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n681:     return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n682:   }\n683: \n684:   const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n685:   const childPid = lease?.childPid;\n686:   if (!Number.isInteger(childPid) || childPid <= 0) {\n687:     log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n688:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n689:     return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n690:   }\n691: \n692:   let bootstrapLockHeld = false;\n693:   let respawnLock = null;\n694:   try {\n695:     bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n696:     respawnLock = acquireRespawnLockFile();\n697:     if (!respawnLock.acquired) {\n698:       log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n699:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n700:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n701:     }\n702: \n703:     const currentOwner = readOwnerLeaseFile();\n704:     if (currentOwner?.ownerPid !== ownerPid) {\n705:       log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n706:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n707:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n708:     }\n709: \n710:     const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n711:     if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n712:       log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n713:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n714:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n715:     }\n716: \n717:     const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n718:     if (!ownerReapResult.allowed) {\n719:       log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n720:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n721:       return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n722:     }\n723: \n724:     clearOwnerLeaseFileIfOwner(ownerPid);\n725:     const ownerLease = buildOwnerLease(process.pid);\n726:     if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n727:       const holder = readOwnerLeaseFile();\n728:       log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n729:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n730:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n731:     }\n732:     ownerLeasePid = process.pid;\n733: \n734:     const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n735:     if (!reapResult.allowed) {\n736:       log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n737:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n738:       return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n739:     }\n740: \n741:     buildIfNeeded([]);\n742:     leaseStartedAt = new Date().toISOString();\n743:     writeLeaseFile();\n744:     launchServer();\n745:     return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n746:   } finally {\n747:     releaseRespawnLockFile(respawnLock);\n748:     if (bootstrapLockHeld) {\n749:       fs.rmSync(lockDir, { recursive: true, force: true });\n750:     }\n751:   }\n752: }\n753: \n754: async function bridgeOrReportLeaseHeld(leaseResult) {\n755:   const readiness = bridgeReadiness(leaseResult);\n756:   if (!readiness.ready) {\n757:     writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n758:     return { action: 'report', reason: readiness.reason };\n759:   }\n760:   const { maybeBridgeLeaseHolder } = loadBridgeModule();\n761:   const decision = await maybe