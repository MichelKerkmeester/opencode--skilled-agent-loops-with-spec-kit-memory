{"type":"tool_use","timestamp":1781128869592,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_EWCKM8V2bj9XhBFbXWbH0qLj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor 5-Lane Fusion\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\n6: import { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\n7: import {\n8:   ADVISOR_HOOK_FRESHNESS_VALUES,\n9:   ADVISOR_RUNTIME_VALUES,\n10:   isSpeckitMetricsEnabled,\n11:   speckitMetrics,\n12: } from '../metrics.js';\n13: import { normalize } from '../affordance-normalizer.js';\n14: import { scoreDerivedLane } from './lanes/derived.js';\n15: import { scoreExplicitLane } from './lanes/explicit.js';\n16: import { scoreGraphCausalLane } from './lanes/graph-causal.js';\n17: import { scoreLexicalLane } from './lanes/lexical.js';\n18: import { scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\n19: import { loadAdvisorProjection } from './projection.js';\n20: import { SCORING_CALIBRATION } from './scoring-constants.js';\n21: import { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\n22: import {\n23:   DEFAULT_SCORER_WEIGHTS,\n24:   SCORER_LANES,\n25:   liveWeightTotal,\n26: } from './weights-config.js';\n27: import { isLiveScorerLane } from './lane-registry.js';\n28: import { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\n29: import type {\n30:   AdvisorProjection,\n31:   AdvisorScoredRecommendation,\n32:   AdvisorScoringOptions,\n33:   AdvisorScoringResult,\n34:   LaneContribution,\n35:   LaneMatch,\n36:   LaneScores,\n37:   ScorerLane,\n38:   SkillProjection,\n39: } from './types.js';\n40: import type { NormalizedAffordance } from '../affordance-normalizer.js';\n41: \n42: const DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\n43: const DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\n44: const TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\n45: const DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\n46: const FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\n47: const MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n48: // Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n49: // multi-concern optimization is under-specified for single-skill routing.\n50: const BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\n51: const BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n52: // Narrow anchors that make a broad-build prompt specific enough to route.\n53: const BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\n54: const MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\n55: const CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\n56: const CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\n57: \n58: type MutableLaneScores = {\n59:   -readonly [K in keyof LaneScores]: LaneMatch[];\n60: };\n61: \n62: type AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\n63: type AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\n64: \n65: function emptyLaneScores(): MutableLaneScores {\n66:   return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n67: }\n68: \n69: function effectiveScorerWeights(\n70:   override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n71: ): Readonly<Record<ScorerLane, number>> {\n72:   if (!override) return DEFAULT_SCORER_WEIGHTS;\n73:   const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n74:   const runtimeOverride = override as Partial<Record<string, number>>;\n75:   for (const lane of SCORER_LANES) {\n76:     const value = runtimeOverride[lane];\n77:     if (typeof value === 'number' && Number.isFinite(value)) {\n78:       weights[lane] = value;\n79:     }\n80:   }\n81:   return weights;\n82: }\n83: \n84: function normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n85:   if (value === undefined) {\n86:     return null;\n87:   }\n88:   return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n89: }\n90: \n91: function normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n92:   if (value === undefined) {\n93:     return 'unavailable';\n94:   }\n95:   return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n96: }\n97: \n98: type LaneMatchIndex = Map<string, { rawScore: number; evidence: string[] }>;\n99: \n100: function buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n101:   const index: LaneMatchIndex = new Map();\n102:   for (const match of matches) {\n103:     const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [] };\n104:     existing.rawScore = Math.max(existing.rawScore, match.score);\n105:     if (existing.evidence.length < 6) {\n106:       existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n107:     }\n108:     index.set(match.skillId, existing);\n109:   }\n110:   return index;\n111: }\n112: \n113: function promptMentionsSkill(promptLower: string, skill: SkillProjection): boolean {\n114:   return [skill.id, skill.name, skill.id.replace(/-/g, ' ')].some((phrase) => matchesPhraseBoundary(promptLower, phrase.toLowerCase()));\n115: }\n116: \n117: function isDefaultRoutable(promptLower: string, skill: SkillProjection): boolean {\n118:   if (skill.lifecycleStatus === 'archived' || skill.lifecycleStatus === 'future') return false;\n119:   if (skill.lifecycleStatus === 'deprecated') return promptMentionsSkill(promptLower, skill);\n120:   return true;\n121: }\n122: \n123: function confidenceFor(args: {\n124:   liveNormalized: number;\n125:   directScore: number;\n126:   readOnlyExplainer: boolean;\n127:   hasExplicitWorkflowSignal: boolean;\n128:   hasTaskIntent: boolean;\n129:   readOnlyRouteAllowed: boolean;\n130:   derivedDominant: boolean;\n131:   skillId: string;\n132: }): number {\n133:   const C = SCORING_CALIBRATION.confidence;\n134:   if (args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n135:   const base = C.baseConstant\n136:     + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;\n137:   if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;\n138:   if (args.readOnlyRouteAllowed) {\n139:     return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));\n140:   }\n141:   if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {\n142:     return C.derivedDominantConfidence;\n143:   }\n144:   if (args.hasTaskIntent\n145:     && (args.directScore >= C.taskIntentDirectScoreFloor\n146:       || args.liveNormalized >= C.taskIntentLiveNormalizedFloor)) {\n147:     // Token-stuffing dispersion guard. Without this, a prompt\n148:     // with task-intent + many weak signals (saturating liveNormalized) but\n149:     // no strong direct anchor would force confidence to taskIntentFloor for\n150:     // many unrelated skills. The guard fires when liveNormalized is near-\n151:     // saturated AND directScore is below the directScoreLiftThreshold —\n152:     // the precise signature of a token-stuffed prompt. Legitimate task-intent\n153:     // prompts have at least one strong direct hit and pass via directScore;\n154:     // they don't hit this branch. When the guard fires we fall through to\n155:     // the standard `base + directBonus` math below.\n156:     const dispersionGuardTripped = args.liveNormalized >= 0.95\n157:       && args.directScore < C.directScoreLiftThreshold;\n158:     if (!dispersionGuardTripped) {\n159:       return Number(Math.max(base, C.taskIntentFloor).toFixed(4));\n160:     }\n161:   }\n162:   if (args.directScore >= C.directScoreLiftThreshold) {\n163:     return Number(Math.max(base, C.directScoreFloor).toFixed(4));\n164:   }\n165:   const directBonus = args.directScore >= C.directScoreBonusThreshold ? C.directScoreBonus : 0;\n166:   return Number(Math.max(0, Math.min(C.hardCeiling, base + directBonus)).toFixed(4));\n167: }\n168: \n169: function uncertaintyFor(contributions: readonly LaneContribution[], confidence: number, ambiguousPressure: number): number {\n170:   const U = SCORING_CALIBRATION.uncertainty;\n171:   const evidenceCount = contributions.reduce((total, contribution) => total + contribution.evidence.length, 0);\n172:   const direct = contributions\n173:     .filter((contribution) => contribution.lane === 'explicit_author' || contribution.lane === 'lexical')\n174:     .reduce((max, contribution) => Math.max(max, contribution.rawScore), 0);\n175:   let uncertainty = U.noEvidenceDefault;\n176:   if (evidenceCount >= U.highEvidenceCount) uncertainty = U.lowFloor;\n177:   else if (evidenceCount >= U.mediumEvidenceCount) uncertainty = U.mediumFloor;\n178:   else if (evidenceCount >= U.someEvidenceCount) uncertainty = U.elevatedFloor;\n179:   if (direct >= U.directEvidenceDiscountThreshold) uncertainty -= U.directEvidenceDiscount;\n180:   if (confidence < U.lowConfidencePenaltyThreshold) uncertainty += U.lowConfidencePenalty;\n181:   uncertainty += ambiguousPressure;\n182:   return Number(Math.max(U.hardFloor, Math.min(U.hardCeiling, uncertainty)).toFixed(2));\n183: }\n184: \n185: function buildLaneScores(\n186:   prompt: string,\n187:   projection: AdvisorProjection,\n188:   disabled: Set<ScorerLane>,\n189:   affordances: readonly NormalizedAffordance[],\n190: ): LaneScores {\n191:   const scores = emptyLaneScores();\n192:   if (!disabled.has('explicit_author')) scores.explicit_author = scoreExplicitLane(prompt, projection);\n193:   if (!disabled.has('lexical')) scores.lexical = scoreLexicalLane(prompt, projection);\n194:   if (!disabled.has('derived_generated')) scores.derived_generated = scoreDerivedLane(prompt, projection, new Date(), affordances);\n195:   if (!disabled.has('semantic_shadow')) scores.semantic_shadow = scoreSemanticShadowLane(prompt, projection);\n196:   if (!disabled.has('graph_causal')) {\n197:     scores.graph_causal = scoreGraphCausalLane([\n198:       ...scores.explicit_author,\n199:       ...scores.lexical,\n200:       ...scores.derived_generated,\n201:     ], projection, {}, affordances);\n202:   }\n203:   return scores;\n204: }\n205: \n206: function hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n207:   const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n208:   if (!explicit || explicit.rawScore < 0.55) return false;\n209:   return explicit.evidence.some((entry) => (\n210:     entry.startsWith('phrase:')\n211:     || entry.startsWith('explicit:')\n212:     || entry.startsWith('author:')\n213:     || entry.includes(skillId)\n214:     || entry.includes('loop')\n215:     || entry.includes('write-')\n216:   ));\n217: }\n218: \n219: function readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n220:   if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n221:     return false;\n222:   }\n223:   if (skillId === 'sk-code-review' && /\\b(compare|audit|review)\\b/.test(promptLower)\n224:     && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n225:     return true;\n226:   }\n227:   if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n228:     return true;\n229:   }\n230:   if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n231:     return true;\n232:   }\n233:   if (skillId === 'deep-ai-council' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n234:     return true;\n235:   }\n236:   if (skillId === 'mcp-chrome-devtools' && /\\b(\\.codex\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n237:     return true;\n238:   }\n239:   // Browser/devtools inspection is a genuine chrome-devtools task even though\n240:   // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n241:   // explainer floor when the prompt carries devtools-specific vocabulary.\n242:   if (skillId === 'mcp-chrome-devtools'\n243:     && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n244:     return true;\n245:   }\n246:   if (skillId === 'cli-codex' && /\\b\\.codex\\/agents\\b/.test(promptLower)) {\n247:     return true;\n248:   }\n249:   if (skillId === 'sk-code' && /\\bgate-3-classifier\\.ts\\b/.test(promptLower)) {\n250:     return true;\n251:   }\n252:   return false;\n253: }\n254: \n255: function isPlainFileSavePrompt(promptLower: string): boolean {\n256:   return FILE_SAVE_OPERATION.test(promptLower) && !MEMORY_SAVE_CONTEXT_ANCHOR.test(promptLower.replace(/\\bfile(s)?\\b/g, ''));\n257: }\n258: \n259: function primaryIntentBonus(promptLower: string, recommendation: AdvisorScoredRecommendation): number {\n260:   const R = SCORING_CALIBRATION.routing;\n\n(Showing lines 1-260 of 536. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLane } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\nimport { loadAdvisorProjection } from './projection.js';\nimport { SCORING_CALIBRATION } from './scoring-constants.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLane } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\nimport { loadAdvisorProjection } from './projection.js';\nimport { SCORING_CALIBRATION } from './scoring-constants.js';\nimport { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\nimport {\n  DEFAULT_SCORER_WEIGHTS,\n  SCORER_LANES,\n  liveWeightTotal,\n} from './weights-config.js';\nimport { isLiveScorerLane } from './lane-registry.js';\nimport { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\nimport type {\n  AdvisorProjection,\n  AdvisorScoredRecommendation,\n  AdvisorScoringOptions,\n  AdvisorScoringResult,\n  LaneContribution,\n  LaneMatch,\n  LaneScores,\n  ScorerLane,\n  SkillProjection,\n} from './types.js';\nimport type { NormalizedAffordance } from '../affordance-normalizer.js';\n\nconst DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\nconst DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\nconst TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\nconst DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\nconst FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\nconst MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n// Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n// multi-concern optimization is under-specified for single-skill routing.\nconst BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\nconst BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n// Narrow anchors that make a broad-build prompt specific enough to route.\nconst BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\nconst MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\nconst CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\nconst CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\n\ntype MutableLaneScores = {\n  -readonly [K in keyof LaneScores]: LaneMatch[];\n};\n\ntype AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\ntype AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\n\nfunction emptyLaneScores(): MutableLaneScores {\n  return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n}\n\nfunction effectiveScorerWeights(\n  override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n): Readonly<Record<ScorerLane, number>> {\n  if (!override) return DEFAULT_SCORER_WEIGHTS;\n  const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n  const runtimeOverride = override as Partial<Record<string, number>>;\n  for (const lane of SCORER_LANES) {\n    const value = runtimeOverride[lane];\n    if (typeof value === 'number' && Number.isFinite(value)) {\n      weights[lane] = value;\n    }\n  }\n  return weights;\n}\n\nfunction normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n  if (value === undefined) {\n    return null;\n  }\n  return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n}\n\nfunction normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n  if (value === undefined) {\n    return 'unavailable';\n  }\n  return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n}\n\ntype LaneMatchIndex = Map<string, { rawScore: number; evidence: string[] }>;\n\nfunction buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n  const index: LaneMatchIndex = new Map();\n  for (const match of matches) {\n    const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [] };\n    existing.rawScore = Math.max(existing.rawScore, match.score);\n    if (existing.evidence.length < 6) {\n      existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n    }\n    index.set(match.skillId, existing);\n  }\n  return index;\n}\n\nfunction promptMentionsSkill(promptLower: string, skill: SkillProjection): boolean {\n  return [skill.id, skill.name, skill.id.replace(/-/g, ' ')].some((phrase) => matchesPhraseBoundary(promptLower, phrase.toLowerCase()));\n}\n\nfunction isDefaultRoutable(promptLower: string, skill: SkillProjection): boolean {\n  if (skill.lifecycleStatus === 'archived' || skill.lifecycleStatus === 'future') return false;\n  if (skill.lifecycleStatus === 'deprecated') return promptMentionsSkill(promptLower, skill);\n  return true;\n}\n\nfunction confidenceFor(args: {\n  liveNormalized: number;\n  directScore: number;\n  readOnlyExplainer: boolean;\n  hasExplicitWorkflowSignal: boolean;\n  hasTaskIntent: boolean;\n  readOnlyRouteAllowed: boolean;\n  derivedDominant: boolean;\n  skillId: string;\n}): number {\n  const C = SCORING_CALIBRATION.confidence;\n  if (args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n  const base = C.baseConstant\n    + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;\n  if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;\n  if (args.readOnlyRouteAllowed) {\n    return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));\n  }\n  if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {\n    return C.derivedDominantConfidence;\n  }\n  if (args.hasTaskIntent\n    && (args.directScore >= C.taskIntentDirectScoreFloor\n      || args.liveNormalized >= C.taskIntentLiveNormalizedFloor)) {\n    // Token-stuffing dispersion guard. Without this, a prompt\n    // with task-intent + many weak signals (saturating liveNormalized) but\n    // no strong direct anchor would force confidence to taskIntentFloor for\n    // many unrelated skills. The guard fires when liveNormalized is near-\n    // saturated AND directScore is below the directScoreLiftThreshold —\n    // the precise signature of a token-stuffed prompt. Legitimate task-intent\n    // prompts have at least one strong direct hit and pass via directScore;\n    // they don't hit this branch. When the guard fires we fall through to\n    // the standard `base + directBonus` math below.\n    const dispersionGuardTripped = args.liveNormalized >= 0.95\n      && args.directScore < C.directScoreLiftThreshold;\n    if (!dispersionGuardTripped) {\n      return Number(Math.max(base, C.taskIntentFloor).toFixed(4));\n    }\n  }\n  if (args.directScore >= C.directScoreLiftThreshold) {\n    return Number(Math.max(base, C.directScoreFloor).toFixed(4));\n  }\n  const directBonus = args.directScore >= C.directScoreBonusThreshold ? C.directScoreBonus : 0;\n  return Number(Math.max(0, Math.min(C.hardCeiling, base + directBonus)).toFixed(4));\n}\n\nfunction uncertaintyFor(contributions: readonly LaneContribution[], confidence: number, ambiguousPressure: number): number {\n  const U = SCORING_CALIBRATION.uncertainty;\n  const evidenceCount = contributions.reduce((total, contribution) => total + contribution.evidence.length, 0);\n  const direct = contributions\n    .filter((contribution) => contribution.lane === 'explicit_author' || contribution.lane === 'lexical')\n    .reduce((max, contribution) => Math.max(max, contribution.rawScore), 0);\n  let uncertainty = U.noEvidenceDefault;\n  if (evidenceCount >= U.highEvidenceCount) uncertainty = U.lowFloor;\n  else if (evidenceCount >= U.mediumEvidenceCount) uncertainty = U.mediumFloor;\n  else if (evidenceCount >= U.someEvidenceCount) uncertainty = U.elevatedFloor;\n  if (direct >= U.directEvidenceDiscountThreshold) uncertainty -= U.directEvidenceDiscount;\n  if (confidence < U.lowConfidencePenaltyThreshold) uncertainty += U.lowConfidencePenalty;\n  uncertainty += ambiguousPressure;\n  return Number(Math.max(U.hardFloor, Math.min(U.hardCeiling, uncertainty)).toFixed(2));\n}\n\nfunction buildLaneScores(\n  prompt: string,\n  projection: AdvisorProjection,\n  disabled: Set<ScorerLane>,\n  affordances: readonly NormalizedAffordance[],\n): LaneScores {\n  const scores = emptyLaneScores();\n  if (!disabled.has('explicit_author')) scores.explicit_author = scoreExplicitLane(prompt, projection);\n  if (!disabled.has('lexical')) scores.lexical = scoreLexicalLane(prompt, projection);\n  if (!disabled.has('derived_generated')) scores.derived_generated = scoreDerivedLane(prompt, projection, new Date(), affordances);\n  if (!disabled.has('semantic_shadow')) scores.semantic_shadow = scoreSemanticShadowLane(prompt, projection);\n  if (!disabled.has('graph_causal')) {\n    scores.graph_causal = scoreGraphCausalLane([\n      ...scores.explicit_author,\n      ...scores.lexical,\n      ...scores.derived_generated,\n    ], projection, {}, affordances);\n  }\n  return scores;\n}\n\nfunction hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n  const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n  if (!explicit || explicit.rawScore < 0.55) return false;\n  return explicit.evidence.some((entry) => (\n    entry.startsWith('phrase:')\n    || entry.startsWith('explicit:')\n    || entry.startsWith('author:')\n    || entry.includes(skillId)\n    || entry.includes('loop')\n    || entry.includes('write-')\n  ));\n}\n\nfunction readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n  if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n    return false;\n  }\n  if (skillId === 'sk-code-review' && /\\b(compare|audit|review)\\b/.test(promptLower)\n    && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'deep-ai-council' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'mcp-chrome-devtools' && /\\b(\\.codex\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n    return true;\n  }\n  // Browser/devtools inspection is a genuine chrome-devtools task even though\n  // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n  // explainer floor when the prompt carries devtools-specific vocabulary.\n  if (skillId === 'mcp-chrome-devtools'\n    && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'cli-codex' && /\\b\\.codex\\/agents\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'sk-code' && /\\bgate-3-classifier\\.ts\\b/.test(promptLower)) {\n    return true;\n  }\n  return false;\n}\n\nfunction isPlainFileSavePrompt(promptLower: string): boolean {\n  return FILE_SAVE_OPERATION.test(promptLower) && !MEMORY_SAVE_CONTEXT_ANCHOR.test(promptLower.replace(/\\bfile(s)?\\b/g, ''));\n}\n\nfunction primaryIntentBonus(promptLower: string, recommendation: AdvisorScoredRecommendation): number {\n  const R = SCORING_CALIBRATION.routing;","lineStart":1,"lineEnd":260,"totalLines":536,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1781128869587,"end":1781128869591}},"metadata":{"openai":{"itemId":"fc_0dd033b1b48708a3016a29dea584c481919f1c52aa2f2cce8f"}},"id":"prt_eb38db69d001zce9CQV5qFrXQN","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d87470019hUcDvNGZ2jco9"}}
{"type":"tool_use","timestamp":1781128869612,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_aDYbU4wOA63nHQmgwf774MGX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":260,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n260:   const R = SCORING_CALIBRATION.routing;\n261:   if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n262:     if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n263:   }\n264:   if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n265:     if (recommendation.skill === 'sk-code-review') return R.deepReviewSkCodeReviewPenalty;\n266:   }\n267:   if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n268:     if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code-review') return R.deepResearchOtherSkillsPenalty;\n269:   }\n270:   if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n271:     if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code-review' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n272:   }\n273:   if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n274:     if (recommendation.skill === 'sk-code-review') return R.compareAuditCodeReviewBonus;\n275:     if (recommendation.skill === 'sk-code') return R.compareAuditCodeOpenCodePenalty;\n276:   }\n277:   if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n278:     if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n279:     if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;\n280:   }\n281:   if (promptLower.includes('/speckit:resume')) {\n282:     if (recommendation.skill === 'system-spec-kit') return R.speckitResumeSpecKitBonus;\n283:     if (recommendation.skill === 'command-spec-kit') return R.speckitResumeCommandPenalty;\n284:   }\n285:   if (promptLower.includes('/speckit:plan')) {\n286:     if (recommendation.skill === 'command-spec-kit') return R.speckitPlanCommandBonus;\n287:     if (recommendation.skill === 'sk-doc') return R.speckitPlanSkDocPenalty;\n288:   }\n289:   // External-tool-chain (\"call_tool_chain\") vocabulary belongs to mcp-code-mode,\n290:   // not the generic code skill. Disambiguate so the best guess for these\n291:   // toolchain-shaped prompts is mcp-code-mode.\n292:   // Toolchain + external-data-source vocabulary (webflow CMS, cms collection)\n293:   // is mcp-code-mode territory, not the generic code skill.\n294:   if (/\\b(call_tool_chain|code mode|tool ?chain|api chain|webflow cms|cms collection)\\b/.test(promptLower)) {\n295:     if (recommendation.skill === 'mcp-code-mode') return R.mcpToolchainCodeModeBonus;\n296:     if (recommendation.skill === 'sk-code') return R.mcpToolchainSkCodePenalty;\n297:   }\n298:   // A \"code audit\" is a code-review task, not a deep-review loop. On the\n299:   // near-tie this phrase produces, prefer sk-code-review over deep-review.\n300:   if (/\\bcode audit\\b/.test(promptLower)) {\n301:     if (recommendation.skill === 'sk-code-review') return R.codeAuditCodeReviewBonus;\n302:     if (recommendation.skill === 'deep-review') return R.codeAuditDeepReviewPenalty;\n303:   }\n304:   // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n305:   // loop; rank it above single-pass code review.\n306:   if (/:review:(auto|confirm)\\b/.test(promptLower)) {\n307:     if (recommendation.skill === 'deep-review') return R.reviewLoopDeepReviewBonus;\n308:     if (recommendation.skill === 'sk-code-review') return R.deepReviewSkCodeReviewPenalty;\n309:   }\n310:   // Auditing recommendation quality is a review task, not an advisor-self task.\n311:   if (/\\baudit\\b/.test(promptLower) && /\\b(recommendation|recommendations|recommendation quality|routing quality)\\b/.test(promptLower)) {\n312:     if (recommendation.skill === 'sk-code-review') return R.auditRecsCodeReviewBonus;\n313:     if (recommendation.skill === 'system-skill-advisor') return R.auditRecsAdvisorPenalty;\n314:   }\n315:   if (/\\b(save context|save memory)\\b/.test(promptLower)) {\n316:     if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;\n317:     if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;\n318:   }\n319:   if (/\\b(create (a )?new agent|create agent)\\b/.test(promptLower) || promptLower.includes('/create:agent')) {\n320:     if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;\n321:     if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;\n322:   }\n323:   if (/\\bcreate (a )?(test|testing) playbook\\b/.test(promptLower) || promptLower.includes('/create:testing-playbook')) {\n324:     if (recommendation.skill === 'create:testing-playbook' || recommendation.skill === 'command-create-testing-playbook') return R.createTestingPlaybookBonus;\n325:     if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;\n326:     if (recommendation.skill === 'deep-improvement') return R.createTestingPlaybookOtherSkillsPenalty;\n327:   }\n328:   if (/\\bphase folder\\b/.test(promptLower)) {\n329:     if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n330:   }\n331:   return 0;\n332: }\n333: \n334: export function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n335:   const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n336:   const weights = effectiveScorerWeights(options.laneWeightsOverride);\n337:   const disabled = new Set(options.disabledLanes ?? []);\n338:   const affordances = normalize(options.affordances ?? []);\n339:   const laneScores = buildLaneScores(prompt, projection, disabled, affordances);\n340:   const laneScoreIndexes = Object.fromEntries(\n341:     SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n342:   ) as Record<ScorerLane, LaneMatchIndex>;\n343:   const liveTotal = SCORER_LANES\n344:     .filter((lane) => !disabled.has(lane))\n345:     .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n346:   if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n347:     for (const lane of SCORER_LANES) {\n348:       if (!isLiveScorerLane(lane) || disabled.has(lane)) continue;\n349:       speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n350:     }\n351:   }\n352:   const promptLower = prompt.toLowerCase();\n353:   const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n354:   const hasTaskIntent = TASK_INTENT.test(promptLower);\n355:   const recommendations: AdvisorScoredRecommendation[] = [];\n356: \n357:   for (const skill of projection.skills) {\n358:     if (!isDefaultRoutable(promptLower, skill)) continue;\n359:     const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n360:       const laneMatch = laneScoreIndexes[lane].get(skill.id);\n361:       const rawScore = laneMatch?.rawScore ?? 0;\n362:       const shadowOnly = !isLiveScorerLane(lane);\n363:       return {\n364:         lane,\n365:         rawScore,\n366:         weightedScore: shadowOnly || disabled.has(lane) ? 0 : rawScore * weights[lane],\n367:         weight: disabled.has(lane) ? 0 : weights[lane],\n368:         evidence: laneMatch?.evidence ?? [],\n369:         shadowOnly,\n370:       };\n371:     });\n372:     const score = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n373:     if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n374:     if (isSpeckitMetricsEnabled()) {\n375:       for (const contribution of contributions) {\n376:         if (contribution.weightedScore !== 0) {\n377:           speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n378:         }\n379:       }\n380:     }\n381: \n382:     const directScore = Math.max(\n383:       contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n384:       contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n385:     );\n386:     const derivedDominant = isDerivedDominant(contributions);\n387:     const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n388:     const liveNormalized = score / liveTotal;\n389:     let confidence = confidenceFor({\n390:       liveNormalized,\n391:       directScore,\n392:       readOnlyExplainer,\n393:       hasExplicitWorkflowSignal: explicitSignal,\n394:       hasTaskIntent,\n395:       readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n396:       derivedDominant,\n397:       skillId: skill.id,\n398:     });\n399:     if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n400:       confidence = Math.min(confidence, 0.49);\n401:     }\n402:     recommendations.push({\n403:       skill: skill.id,\n404:       kind: skill.kind,\n405:       confidence,\n406:       uncertainty: uncertaintyFor(contributions, confidence, 0),\n407:       passes_threshold: false,\n408:       reason: attributionReason(contributions),\n409:       score: Number(score.toFixed(6)),\n410:       laneContributions: contributions,\n411:       dominantLane: dominantLane(contributions),\n412:       redirectTo: skill.redirectTo ?? undefined,\n413:       redirectFrom: skill.redirectFrom,\n414:       lifecycleStatus: skill.lifecycleStatus,\n415:     });\n416:   }\n417: \n418:   if (isSpeckitMetricsEnabled()) {\n419:     for (const recommendation of recommendations) {\n420:       if (primaryIntentBonus(promptLower, recommendation) !== 0) {\n421:         speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n422:       }\n423:     }\n424:   }\n425:   let ranked = recommendations.sort((left, right) => {\n426:     const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n427:     const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n428:     const leftIntent = primaryIntentBonus(promptLower, left);\n429:     const rightIntent = primaryIntentBonus(promptLower, right);\n430:     return (right.score + rightCommandBonus + rightIntent) - (left.score + leftCommandBonus + leftIntent)\n431:       || right.confidence - left.confidence\n432:       || left.skill.localeCompare(right.skill);\n433:   });\n434: \n435:   ranked = ranked.map((recommendation, index) => {\n436:     const next = ranked[index + 1];\n437:     const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n438:     const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n439:     return {\n440:       ...recommendation,\n441:       uncertainty,\n442:       passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n443:         && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n444:     };\n445:   });\n446:   ranked = applyAmbiguity(ranked);\n447: \n448:   // Low-information ambiguity abstention: a short, intent-less prompt that lands\n449:   // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n450:   // every cluster member's uncertainty above the strict threshold so strict\n451:   // callers abstain, while confidence-only callers still surface the best guess\n452:   // (the disambiguated top-ranked candidate).\n453:   const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n454:   const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n455:   if (lowInfoPrompt) {\n456:     const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n457:     // Only abstain when the cluster's lead is built from diffuse, shared\n458:     // single-word keyword matches rather than a distinctive multi-word phrase\n459:     // anchor (an explicit-author/derived phrase match such as \"code audit\").\n460:     // A multi-word anchor means the prompt does pin a specific skill, so it\n461:     // should route instead of abstaining.\n462:     const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (\n463:       recommendation.laneContributions.some((contribution) => (\n464:         (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')\n465:         && contribution.evidence.some((entry) => entry.includes(' '))\n466:       ))\n467:     ));\n468:     if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {\n469:       const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n470:       const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n471:       const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n472:       ranked = ranked.map((recommendation) => {\n473:         if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;\n474:         const uncertainty = Math.max(recommendation.uncertainty, floor);\n475:         return {\n476:           ...recommendation,\n477:           uncertainty,\n478:           passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n479:         };\n\n(Showing lines 260-479 of 536. Use offset=480 to continue.)\n</content>","metadata":{"preview":"  const R = SCORING_CALIBRATION.routing;\n  if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n  }\n  if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code-review') return R.deepReviewSkCodeReviewPenalty;\n  }\n  if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code-review') return R.deepResearchOtherSkillsPenalty;\n  }\n  if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code-review' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n  }\n  if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code-review') return R.compareAuditCodeReviewBonus;\n    if (recommendation.skill === 'sk-code') return R.compareAuditCodeOpenCodePenalty;\n  }\n  if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n    if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"  const R = SCORING_CALIBRATION.routing;\n  if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n  }\n  if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code-review') return R.deepReviewSkCodeReviewPenalty;\n  }\n  if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code-review') return R.deepResearchOtherSkillsPenalty;\n  }\n  if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code-review' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n  }\n  if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code-review') return R.compareAuditCodeReviewBonus;\n    if (recommendation.skill === 'sk-code') return R.compareAuditCodeOpenCodePenalty;\n  }\n  if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n    if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;\n  }\n  if (promptLower.includes('/speckit:resume')) {\n    if (recommendation.skill === 'system-spec-kit') return R.speckitResumeSpecKitBonus;\n    if (recommendation.skill === 'command-spec-kit') return R.speckitResumeCommandPenalty;\n  }\n  if (promptLower.includes('/speckit:plan')) {\n    if (recommendation.skill === 'command-spec-kit') return R.speckitPlanCommandBonus;\n    if (recommendation.skill === 'sk-doc') return R.speckitPlanSkDocPenalty;\n  }\n  // External-tool-chain (\"call_tool_chain\") vocabulary belongs to mcp-code-mode,\n  // not the generic code skill. Disambiguate so the best guess for these\n  // toolchain-shaped prompts is mcp-code-mode.\n  // Toolchain + external-data-source vocabulary (webflow CMS, cms collection)\n  // is mcp-code-mode territory, not the generic code skill.\n  if (/\\b(call_tool_chain|code mode|tool ?chain|api chain|webflow cms|cms collection)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'mcp-code-mode') return R.mcpToolchainCodeModeBonus;\n    if (recommendation.skill === 'sk-code') return R.mcpToolchainSkCodePenalty;\n  }\n  // A \"code audit\" is a code-review task, not a deep-review loop. On the\n  // near-tie this phrase produces, prefer sk-code-review over deep-review.\n  if (/\\bcode audit\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code-review') return R.codeAuditCodeReviewBonus;\n    if (recommendation.skill === 'deep-review') return R.codeAuditDeepReviewPenalty;\n  }\n  // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n  // loop; rank it above single-pass code review.\n  if (/:review:(auto|confirm)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'deep-review') return R.reviewLoopDeepReviewBonus;\n    if (recommendation.skill === 'sk-code-review') return R.deepReviewSkCodeReviewPenalty;\n  }\n  // Auditing recommendation quality is a review task, not an advisor-self task.\n  if (/\\baudit\\b/.test(promptLower) && /\\b(recommendation|recommendations|recommendation quality|routing quality)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code-review') return R.auditRecsCodeReviewBonus;\n    if (recommendation.skill === 'system-skill-advisor') return R.auditRecsAdvisorPenalty;\n  }\n  if (/\\b(save context|save memory)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;\n    if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;\n  }\n  if (/\\b(create (a )?new agent|create agent)\\b/.test(promptLower) || promptLower.includes('/create:agent')) {\n    if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;\n    if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;\n  }\n  if (/\\bcreate (a )?(test|testing) playbook\\b/.test(promptLower) || promptLower.includes('/create:testing-playbook')) {\n    if (recommendation.skill === 'create:testing-playbook' || recommendation.skill === 'command-create-testing-playbook') return R.createTestingPlaybookBonus;\n    if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;\n    if (recommendation.skill === 'deep-improvement') return R.createTestingPlaybookOtherSkillsPenalty;\n  }\n  if (/\\bphase folder\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n  }\n  return 0;\n}\n\nexport function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n  const weights = effectiveScorerWeights(options.laneWeightsOverride);\n  const disabled = new Set(options.disabledLanes ?? []);\n  const affordances = normalize(options.affordances ?? []);\n  const laneScores = buildLaneScores(prompt, projection, disabled, affordances);\n  const laneScoreIndexes = Object.fromEntries(\n    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n  ) as Record<ScorerLane, LaneMatchIndex>;\n  const liveTotal = SCORER_LANES\n    .filter((lane) => !disabled.has(lane))\n    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n  if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n    for (const lane of SCORER_LANES) {\n      if (!isLiveScorerLane(lane) || disabled.has(lane)) continue;\n      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n    }\n  }\n  const promptLower = prompt.toLowerCase();\n  const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n  const hasTaskIntent = TASK_INTENT.test(promptLower);\n  const recommendations: AdvisorScoredRecommendation[] = [];\n\n  for (const skill of projection.skills) {\n    if (!isDefaultRoutable(promptLower, skill)) continue;\n    const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n      const laneMatch = laneScoreIndexes[lane].get(skill.id);\n      const rawScore = laneMatch?.rawScore ?? 0;\n      const shadowOnly = !isLiveScorerLane(lane);\n      return {\n        lane,\n        rawScore,\n        weightedScore: shadowOnly || disabled.has(lane) ? 0 : rawScore * weights[lane],\n        weight: disabled.has(lane) ? 0 : weights[lane],\n        evidence: laneMatch?.evidence ?? [],\n        shadowOnly,\n      };\n    });\n    const score = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n    if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n    if (isSpeckitMetricsEnabled()) {\n      for (const contribution of contributions) {\n        if (contribution.weightedScore !== 0) {\n          speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n        }\n      }\n    }\n\n    const directScore = Math.max(\n      contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n      contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n    );\n    const derivedDominant = isDerivedDominant(contributions);\n    const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n    const liveNormalized = score / liveTotal;\n    let confidence = confidenceFor({\n      liveNormalized,\n      directScore,\n      readOnlyExplainer,\n      hasExplicitWorkflowSignal: explicitSignal,\n      hasTaskIntent,\n      readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n      derivedDominant,\n      skillId: skill.id,\n    });\n    if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n      confidence = Math.min(confidence, 0.49);\n    }\n    recommendations.push({\n      skill: skill.id,\n      kind: skill.kind,\n      confidence,\n      uncertainty: uncertaintyFor(contributions, confidence, 0),\n      passes_threshold: false,\n      reason: attributionReason(contributions),\n      score: Number(score.toFixed(6)),\n      laneContributions: contributions,\n      dominantLane: dominantLane(contributions),\n      redirectTo: skill.redirectTo ?? undefined,\n      redirectFrom: skill.redirectFrom,\n      lifecycleStatus: skill.lifecycleStatus,\n    });\n  }\n\n  if (isSpeckitMetricsEnabled()) {\n    for (const recommendation of recommendations) {\n      if (primaryIntentBonus(promptLower, recommendation) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n      }\n    }\n  }\n  let ranked = recommendations.sort((left, right) => {\n    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const leftIntent = primaryIntentBonus(promptLower, left);\n    const rightIntent = primaryIntentBonus(promptLower, right);\n    return (right.score + rightCommandBonus + rightIntent) - (left.score + leftCommandBonus + leftIntent)\n      || right.confidence - left.confidence\n      || left.skill.localeCompare(right.skill);\n  });\n\n  ranked = ranked.map((recommendation, index) => {\n    const next = ranked[index + 1];\n    const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n    const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n    return {\n      ...recommendation,\n      uncertainty,\n      passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n        && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n    };\n  });\n  ranked = applyAmbiguity(ranked);\n\n  // Low-information ambiguity abstention: a short, intent-less prompt that lands\n  // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n  // every cluster member's uncertainty above the strict threshold so strict\n  // callers abstain, while confidence-only callers still surface the best guess\n  // (the disambiguated top-ranked candidate).\n  const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n  const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n  if (lowInfoPrompt) {\n    const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n    // Only abstain when the cluster's lead is built from diffuse, shared\n    // single-word keyword matches rather than a distinctive multi-word phrase\n    // anchor (an explicit-author/derived phrase match such as \"code audit\").\n    // A multi-word anchor means the prompt does pin a specific skill, so it\n    // should route instead of abstaining.\n    const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (\n      recommendation.laneContributions.some((contribution) => (\n        (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')\n        && contribution.evidence.some((entry) => entry.includes(' '))\n      ))\n    ));\n    if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {\n      const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n      const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n      const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n      ranked = ranked.map((recommendation) => {\n        if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;\n        const uncertainty = Math.max(recommendation.uncertainty, floor);\n        return {\n          ...recommendation,\n          uncertainty,\n          passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n        };","lineStart":260,"lineEnd":479,"totalLines":536,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1781128869603,"end":1781128869610}},"metadata":{"openai":{"itemId":"fc_0dd033b1b48708a3016a29dea584d88191b3bd8455395c9e4f"}},"id":"prt_eb38db6e0001HPW3e3f3FtsL50","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d87470019hUcDvNGZ2jco9"}}
{"type":"tool_use","timestamp":1781128869613,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_Li6v9KZ9dWjECfYTEE5WbsMl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/types.ts","offset":1,"limit":150},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/types.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Scorer Types\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AffordanceInput } from '../affordance-normalizer.js';\n6: import type { ScorerLaneId } from './lane-registry.js';\n7: // SkillLifecycleStatus now derives from the canonical tuple in\n8: // lifecycle/status-values.ts. The re-export here keeps every existing consumer\n9: // importing from `scorer/types.js`.\n10: import {\n11:   SKILL_LIFECYCLE_STATUS_VALUES,\n12:   isSkillLifecycleStatus,\n13:   type SkillLifecycleStatus,\n14: } from '../lifecycle/status-values.js';\n15: \n16: export type ScorerLane = ScorerLaneId;\n17: \n18: export {\n19:   SKILL_LIFECYCLE_STATUS_VALUES,\n20:   isSkillLifecycleStatus,\n21:   type SkillLifecycleStatus,\n22: };\n23: \n24: export interface SkillProjection {\n25:   readonly id: string;\n26:   readonly kind: 'skill' | 'command';\n27:   readonly family: string;\n28:   readonly category: string;\n29:   readonly name: string;\n30:   readonly description: string;\n31:   readonly keywords: readonly string[];\n32:   readonly domains: readonly string[];\n33:   readonly intentSignals: readonly string[];\n34:   readonly derivedTriggers: readonly string[];\n35:   readonly derivedKeywords: readonly string[];\n36:   readonly derivedDemotion?: number;\n37:   readonly sourcePath: string | null;\n38:   readonly lifecycleStatus: SkillLifecycleStatus;\n39:   readonly redirectTo?: string | null;\n40:   readonly redirectFrom?: readonly string[];\n41: }\n42: \n43: export interface SkillEdgeProjection {\n44:   readonly sourceId: string;\n45:   readonly targetId: string;\n46:   readonly edgeType: 'depends_on' | 'enhances' | 'siblings' | 'conflicts_with' | 'prerequisite_for';\n47:   readonly weight: number;\n48:   readonly context?: string;\n49: }\n50: \n51: // 'filesystem-fallback' is set when SQLite projection threw\n52: // (corrupt DB, schema mismatch, etc.) and we degraded to filesystem scan; the\n53: // optional `fallbackReason` carries the underlying error so operators can\n54: // distinguish a clean filesystem-only run ('filesystem' source) from a\n55: // degraded one. 'filesystem' is preserved for the legitimate first-run path\n56: // where the SQLite DB simply does not exist yet.\n57: export interface AdvisorProjection {\n58:   readonly skills: readonly SkillProjection[];\n59:   readonly edges: readonly SkillEdgeProjection[];\n60:   readonly generatedAt: string;\n61:   readonly source: 'sqlite' | 'filesystem' | 'filesystem-fallback' | 'fixture';\n62:   readonly fallbackReason?: string;\n63: }\n64: \n65: export interface LaneMatch {\n66:   readonly skillId: string;\n67:   readonly lane: ScorerLane;\n68:   readonly score: number;\n69:   readonly evidence: readonly string[];\n70:   readonly shadowOnly?: boolean;\n71: }\n72: \n73: export type LaneScores = Readonly<Record<ScorerLane, readonly LaneMatch[]>>;\n74: \n75: export interface LaneDampingConfig {\n76:   readonly threshold: number;\n77:   readonly floor: number;\n78: }\n79: \n80: export interface LaneContribution {\n81:   readonly lane: ScorerLane;\n82:   readonly rawScore: number;\n83:   readonly weightedScore: number;\n84:   readonly weight: number;\n85:   readonly evidence: readonly string[];\n86:   readonly shadowOnly: boolean;\n87: }\n88: \n89: export interface AdvisorScoredRecommendation {\n90:   readonly skill: string;\n91:   readonly kind: 'skill' | 'command';\n92:   readonly confidence: number;\n93:   readonly uncertainty: number;\n94:   readonly passes_threshold: boolean;\n95:   readonly reason: string;\n96:   readonly score: number;\n97:   readonly laneContributions: readonly LaneContribution[];\n98:   readonly dominantLane: ScorerLane | null;\n99:   readonly ambiguousWith?: readonly string[];\n100:   readonly redirectTo?: string;\n101:   readonly redirectFrom?: readonly string[];\n102:   readonly lifecycleStatus: SkillLifecycleStatus;\n103: }\n104: \n105: export interface AdvisorScoringOptions {\n106:   readonly workspaceRoot: string;\n107:   readonly projection?: AdvisorProjection;\n108:   readonly affordances?: readonly AffordanceInput[];\n109:   readonly confidenceThreshold?: number;\n110:   readonly uncertaintyThreshold?: number;\n111:   readonly includeAllCandidates?: boolean;\n112:   readonly disabledLanes?: readonly ScorerLane[];\n113:   /**\n114:    * Optional scorer lane weights for one scoring call. Overrides are merged over\n115:    * the default vector without renormalizing; callers own sensible totals. The\n116:    * lane registry's `live` flag still gates contribution, so overriding a\n117:    * shadow-only lane's weight does not make it contribute.\n118:    */\n119:   readonly laneWeightsOverride?: Partial<Record<ScorerLane, number>>;\n120:   /**\n121:    * Optional per-call contribution damping. Overrides are merged over registry\n122:    * defaults. When a lane's raw score falls below `threshold`, fusion scales the\n123:    * lane's effective weight by `floor`.\n124:    */\n125:   readonly dampingOverride?: Partial<Record<ScorerLane, LaneDampingConfig>>;\n126: }\n127: \n128: export interface AdvisorScoringResult {\n129:   readonly recommendations: readonly AdvisorScoredRecommendation[];\n130:   readonly topSkill: string | null;\n131:   readonly unknown: boolean;\n132:   readonly ambiguous: boolean;\n133:   readonly metrics: {\n134:     readonly candidateCount: number;\n135:     readonly liveLaneCount: number;\n136:   };\n137: }\n\n(End of file - total 137 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Types\n// ───────────────────────────────────────────────────────────────\n\nimport type { AffordanceInput } from '../affordance-normalizer.js';\nimport type { ScorerLaneId } from './lane-registry.js';\n// SkillLifecycleStatus now derives from the canonical tuple in\n// lifecycle/status-values.ts. The re-export here keeps every existing consumer\n// importing from `scorer/types.js`.\nimport {\n  SKILL_LIFECYCLE_STATUS_VALUES,\n  isSkillLifecycleStatus,\n  type SkillLifecycleStatus,\n} from '../lifecycle/status-values.js';\n\nexport type ScorerLane = ScorerLaneId;\n\nexport {\n  SKILL_LIFECYCLE_STATUS_VALUES,\n  isSkillLifecycleStatus,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/types.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Types\n// ───────────────────────────────────────────────────────────────\n\nimport type { AffordanceInput } from '../affordance-normalizer.js';\nimport type { ScorerLaneId } from './lane-registry.js';\n// SkillLifecycleStatus now derives from the canonical tuple in\n// lifecycle/status-values.ts. The re-export here keeps every existing consumer\n// importing from `scorer/types.js`.\nimport {\n  SKILL_LIFECYCLE_STATUS_VALUES,\n  isSkillLifecycleStatus,\n  type SkillLifecycleStatus,\n} from '../lifecycle/status-values.js';\n\nexport type ScorerLane = ScorerLaneId;\n\nexport {\n  SKILL_LIFECYCLE_STATUS_VALUES,\n  isSkillLifecycleStatus,\n  type SkillLifecycleStatus,\n};\n\nexport interface SkillProjection {\n  readonly id: string;\n  readonly kind: 'skill' | 'command';\n  readonly family: string;\n  readonly category: string;\n  readonly name: string;\n  readonly description: string;\n  readonly keywords: readonly string[];\n  readonly domains: readonly string[];\n  readonly intentSignals: readonly string[];\n  readonly derivedTriggers: readonly string[];\n  readonly derivedKeywords: readonly string[];\n  readonly derivedDemotion?: number;\n  readonly sourcePath: string | null;\n  readonly lifecycleStatus: SkillLifecycleStatus;\n  readonly redirectTo?: string | null;\n  readonly redirectFrom?: readonly string[];\n}\n\nexport interface SkillEdgeProjection {\n  readonly sourceId: string;\n  readonly targetId: string;\n  readonly edgeType: 'depends_on' | 'enhances' | 'siblings' | 'conflicts_with' | 'prerequisite_for';\n  readonly weight: number;\n  readonly context?: string;\n}\n\n// 'filesystem-fallback' is set when SQLite projection threw\n// (corrupt DB, schema mismatch, etc.) and we degraded to filesystem scan; the\n// optional `fallbackReason` carries the underlying error so operators can\n// distinguish a clean filesystem-only run ('filesystem' source) from a\n// degraded one. 'filesystem' is preserved for the legitimate first-run path\n// where the SQLite DB simply does not exist yet.\nexport interface AdvisorProjection {\n  readonly skills: readonly SkillProjection[];\n  readonly edges: readonly SkillEdgeProjection[];\n  readonly generatedAt: string;\n  readonly source: 'sqlite' | 'filesystem' | 'filesystem-fallback' | 'fixture';\n  readonly fallbackReason?: string;\n}\n\nexport interface LaneMatch {\n  readonly skillId: string;\n  readonly lane: ScorerLane;\n  readonly score: number;\n  readonly evidence: readonly string[];\n  readonly shadowOnly?: boolean;\n}\n\nexport type LaneScores = Readonly<Record<ScorerLane, readonly LaneMatch[]>>;\n\nexport interface LaneDampingConfig {\n  readonly threshold: number;\n  readonly floor: number;\n}\n\nexport interface LaneContribution {\n  readonly lane: ScorerLane;\n  readonly rawScore: number;\n  readonly weightedScore: number;\n  readonly weight: number;\n  readonly evidence: readonly string[];\n  readonly shadowOnly: boolean;\n}\n\nexport interface AdvisorScoredRecommendation {\n  readonly skill: string;\n  readonly kind: 'skill' | 'command';\n  readonly confidence: number;\n  readonly uncertainty: number;\n  readonly passes_threshold: boolean;\n  readonly reason: string;\n  readonly score: number;\n  readonly laneContributions: readonly LaneContribution[];\n  readonly dominantLane: ScorerLane | null;\n  readonly ambiguousWith?: readonly string[];\n  readonly redirectTo?: string;\n  readonly redirectFrom?: readonly string[];\n  readonly lifecycleStatus: SkillLifecycleStatus;\n}\n\nexport interface AdvisorScoringOptions {\n  readonly workspaceRoot: string;\n  readonly projection?: AdvisorProjection;\n  readonly affordances?: readonly AffordanceInput[];\n  readonly confidenceThreshold?: number;\n  readonly uncertaintyThreshold?: number;\n  readonly includeAllCandidates?: boolean;\n  readonly disabledLanes?: readonly ScorerLane[];\n  /**\n   * Optional scorer lane weights for one scoring call. Overrides are merged over\n   * the default vector without renormalizing; callers own sensible totals. The\n   * lane registry's `live` flag still gates contribution, so overriding a\n   * shadow-only lane's weight does not make it contribute.\n   */\n  readonly laneWeightsOverride?: Partial<Record<ScorerLane, number>>;\n  /**\n   * Optional per-call contribution damping. Overrides are merged over registry\n   * defaults. When a lane's raw score falls below `threshold`, fusion scales the\n   * lane's effective weight by `floor`.\n   */\n  readonly dampingOverride?: Partial<Record<ScorerLane, LaneDampingConfig>>;\n}\n\nexport interface AdvisorScoringResult {\n  readonly recommendations: readonly AdvisorScoredRecommendation[];\n  readonly topSkill: string | null;\n  readonly unknown: boolean;\n  readonly ambiguous: boolean;\n  readonly metrics: {\n    readonly candidateCount: number;\n    readonly liveLaneCount: number;\n  };\n}","lineStart":1,"lineEnd":137,"totalLines":137,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/types.ts","time":{"start":1781128869604,"end":1781128869612}},"metadata":{"openai":{"itemId":"fc_0dd033b1b48708a3016a29dea584e48191ad1acf004dc5a5fa"}},"id":"prt_eb38db6e3001ZG5HSDTiMseNcY","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d87470019hUcDvNGZ2jco9"}}
