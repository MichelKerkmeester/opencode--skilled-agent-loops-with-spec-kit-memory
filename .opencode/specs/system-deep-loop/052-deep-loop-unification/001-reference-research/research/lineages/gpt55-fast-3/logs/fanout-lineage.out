ailed > 0) {\n180:     // Mixed salvage: at least one iteration was recovered but some artifact/iteration\n181:     // markdown was unrecoverable or a top-level artifact went missing. This is a\n182:     // transient artifact-recovery gap, not a fatal exit, so it should be retried rather\n183:     // than consumed as terminal. Without this branch a { salvaged: >0, failed: >0 }\n184:     // lineage fell through to EXIT (fatal) and was never retried.\n185:     failureClass = LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n186:   }\n187: \n188:   const retryable =\n189:     failureClass === LINEAGE_FAILURE_CLASSES.TIMEOUT\n190:     || failureClass === LINEAGE_FAILURE_CLASSES.SALVAGE_MISS\n191:     || failureClass === LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n192:   return {\n193:     failure_class: failureClass,\n194:     retry_verdict: retryable ? LINEAGE_RETRY_VERDICTS.TRANSIENT : LINEAGE_RETRY_VERDICTS.FATAL,\n195:     retryable,\n196:     exit_code: exitCode,\n197:     timed_out: timedOut,\n198:     salvage,\n199:   };\n200: }\n201: \n202: /**\n203:  * Throw a synthetic fault when the DEEP_LOOP_TEST_FAULT environment\n204:  * variable is set. Used by contract tests to verify that scripts\n205:  * handle injected DB and script-level errors correctly.\n206:  *\n207:  * @throws {Error} With code DB_ERROR or generic script error.\n208:  */\n209: function maybeThrowTestFault() {\n210:   if (process.env.DEEP_LOOP_TEST_FAULT === 'db') {\n211:     const err = new Error('Injected DB fault for deep-loop script contract tests');\n212:     err.code = 'DB_ERROR';\n213:     throw err;\n214:   }\n215:   if (process.env.DEEP_LOOP_TEST_FAULT === 'script') {\n216:     throw new Error('Injected script fault for deep-loop script contract tests');\n217:   }\n218: }\n219: \n220: /**\n221:  * Synchronous sleep using Atomics.wait on a shared buffer.\n222:  *\n223:  * @param {number} ms - Milliseconds to sleep. Non-positive values are\n224:  *   ignored.\n225:  */\n226: function sleepSync(ms) {\n227:   if (!Number.isFinite(ms) || ms <= 0) return;\n228:   const buffer = new SharedArrayBuffer(4);\n229:   const view = new Int32Array(buffer);\n230:   Atomics.wait(view, 0, 0, ms);\n231: }\n232: \n233: function readNonNegativeEnvNumber(name, fallback) {\n234:   const raw = process.env[name];\n235:   if (raw === undefined || raw === '') return fallback;\n236:   const value = Number(raw);\n237:   return Number.isFinite(value) && value >= 0 ? value : fallback;\n238: }\n239: \n\n(Showing lines 150-239 of 517. Use offset=240 to continue.)\n</content>","metadata":{"preview":"  return number !== null && number >= 0 ? number : null;\n}\n\nfunction normalizeSalvageSummary(value) {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) {\n    return null;\n  }\n  return {\n    salvaged: readNonNegativeInteger(value.salvaged) ?? 0,\n    failed: readNonNegativeInteger(value.failed) ?? 0,\n  };\n}\n\n/**\n * Classify a lineage failure using only bounded process and salvage signals.\n *\n * @param {Error|Object} error - Error object from a failed lineage worker.\n * @returns {{failure_class:string,retry_verdict:string,retryable:boolean,exit_code:number|null,timed_out:boolean,salvage:{salvaged:number,failed:number}|null}}\n */\nfunction classifyLineageFailure(error) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs","text":"  return number !== null && number >= 0 ? number : null;\n}\n\nfunction normalizeSalvageSummary(value) {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) {\n    return null;\n  }\n  return {\n    salvaged: readNonNegativeInteger(value.salvaged) ?? 0,\n    failed: readNonNegativeInteger(value.failed) ?? 0,\n  };\n}\n\n/**\n * Classify a lineage failure using only bounded process and salvage signals.\n *\n * @param {Error|Object} error - Error object from a failed lineage worker.\n * @returns {{failure_class:string,retry_verdict:string,retryable:boolean,exit_code:number|null,timed_out:boolean,salvage:{salvaged:number,failed:number}|null}}\n */\nfunction classifyLineageFailure(error) {\n  const timedOut = Boolean(error && typeof error === 'object' && error.timedOut === true);\n  const exitCode = error && typeof error === 'object' ? readFiniteInteger(error.exitCode) : null;\n  const salvage = error && typeof error === 'object' ? normalizeSalvageSummary(error.salvage) : null;\n\n  let failureClass = LINEAGE_FAILURE_CLASSES.EXIT;\n  if (timedOut) {\n    failureClass = LINEAGE_FAILURE_CLASSES.TIMEOUT;\n  } else if (salvage && salvage.failed > 0 && salvage.salvaged === 0) {\n    failureClass = LINEAGE_FAILURE_CLASSES.SALVAGE_MISS;\n  } else if (salvage && salvage.failed > 0) {\n    // Mixed salvage: at least one iteration was recovered but some artifact/iteration\n    // markdown was unrecoverable or a top-level artifact went missing. This is a\n    // transient artifact-recovery gap, not a fatal exit, so it should be retried rather\n    // than consumed as terminal. Without this branch a { salvaged: >0, failed: >0 }\n    // lineage fell through to EXIT (fatal) and was never retried.\n    failureClass = LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n  }\n\n  const retryable =\n    failureClass === LINEAGE_FAILURE_CLASSES.TIMEOUT\n    || failureClass === LINEAGE_FAILURE_CLASSES.SALVAGE_MISS\n    || failureClass === LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n  return {\n    failure_class: failureClass,\n    retry_verdict: retryable ? LINEAGE_RETRY_VERDICTS.TRANSIENT : LINEAGE_RETRY_VERDICTS.FATAL,\n    retryable,\n    exit_code: exitCode,\n    timed_out: timedOut,\n    salvage,\n  };\n}\n\n/**\n * Throw a synthetic fault when the DEEP_LOOP_TEST_FAULT environment\n * variable is set. Used by contract tests to verify that scripts\n * handle injected DB and script-level errors correctly.\n *\n * @throws {Error} With code DB_ERROR or generic script error.\n */\nfunction maybeThrowTestFault() {\n  if (process.env.DEEP_LOOP_TEST_FAULT === 'db') {\n    const err = new Error('Injected DB fault for deep-loop script contract tests');\n    err.code = 'DB_ERROR';\n    throw err;\n  }\n  if (process.env.DEEP_LOOP_TEST_FAULT === 'script') {\n    throw new Error('Injected script fault for deep-loop script contract tests');\n  }\n}\n\n/**\n * Synchronous sleep using Atomics.wait on a shared buffer.\n *\n * @param {number} ms - Milliseconds to sleep. Non-positive values are\n *   ignored.\n */\nfunction sleepSync(ms) {\n  if (!Number.isFinite(ms) || ms <= 0) return;\n  const buffer = new SharedArrayBuffer(4);\n  const view = new Int32Array(buffer);\n  Atomics.wait(view, 0, 0, ms);\n}\n\nfunction readNonNegativeEnvNumber(name, fallback) {\n  const raw = process.env[name];\n  if (raw === undefined || raw === '') return fallback;\n  const value = Number(raw);\n  return Number.isFinite(value) && value >= 0 ? value : fallback;\n}\n","lineStart":150,"lineEnd":239,"totalLines":517,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs","time":{"start":1783487332849,"end":1783487332859}},"metadata":{"openai":{"itemId":"fc_07cfe05cfbb4e1aa016a4ddb64b87c819194e4b1effc8a40ed"}},"id":"prt_f402101e8001w30V5SI9oPv9E3","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f4020dfcc001Zv5tEs3FwnzGp3"}}
