{"type":"tool_use","timestamp":1780729397701,"sessionID":"ses_164436585ffexoEvsPd4ItVAfq","part":{"type":"tool","tool":"grep","callID":"call_wQePKCziui9ihpsBV8qHL5hr","state":{"status":"completed","input":{"pattern":"eval_run_ablation|eval_reporting_dashboard|memory_health|FSRS|fsrs|decay|Token Budget|token budget","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit","include":"*.ts"},"output":"Found 1136 matches (showing first 100)\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts:\n  Line 1030:         : 'Top N unlinked records unavailable; run memory_health({ autoRepair: true, confirmed: true }) to backfill.';\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/quality-loop.vitest.ts:\n  Line 93: /** Content that exceeds token budget */\n\n  Line 197:     expect(result.issues[0]).toMatch(/exceeds token budget/i);\n\n  Line 416:     const result = attemptAutoFix(oversized, metadata, ['Content exceeds token budget']);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts:\n  Line 125: import * as attentionDecay from './lib/cognitive/attention-decay.js';\n\n  Line 266:   'eval_run_ablation',\n\n  Line 267:   'eval_reporting_dashboard',\n\n  Line 923:   // 'error' recommends memory_health because structural context is\n\n  Line 932:           snap.graphFreshness === 'error' ? 'call memory_health (structural context unavailable)' :\n\n  Line 956:   lines.push('- If \"unavailable\" (DB unreachable / readiness probe failed): call memory_health for repair guidance instead of mcp__mk_code_index__code_graph_query');\n\n  Line 963:   // recommend mcp__mk_code_index__code_graph_scan; 'error' → recommend memory_health\n\n  Line 976:       routingRules.push('Structural queries → unavailable: c