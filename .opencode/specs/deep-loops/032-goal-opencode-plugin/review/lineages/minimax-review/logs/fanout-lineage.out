replied' || eventType === 'question.rejected') {\n2532:       if (sessionID) {\n2533:         runtimeState.blockedByPromptSessions.delete(sessionID);\n2534:         await setBlockedByPrompt(sessionID, false, eventOptions);\n2535:       }\n2536:       return;\n2537:     }\n2538: \n2539:     if (eventType === 'session.idle') {\n2540:       if (!sessionID) {\n2541:         await maybeContinueGoal(sessionID, {\n2542:           ...eventOptions,\n2543:           client: ctx?.client,\n2544:           directory: ctx?.directory,\n2545:           runtimeState,\n2546:         });\n2547:         return;\n2548:       }\n2549:       runtimeState.sessionStatuses.set(sessionID, 'idle');\n2550:       if (runtimeState.inFlightVerifications.has(sessionID)) return;\n2551:       runtimeState.inFlightVerifications.add(sessionID);\n2552:       let verifierResult = null;\n2553:       try {\n2554:         verifierResult = await maybeVerifyGoal(sessionID, {\n2555:           ...rawOptions,\n2556:           client: ctx?.client,\n2557:         });\n2558:       } finally {\n2559:         runtimeState.inFlightVerifications.delete(sessionID);\n2560:       }\n2561:       await maybeContinueGoal(sessionID, {\n2562:         ...eventOptions,\n2563:         client: ctx?.client,\n2564:         directory: ctx?.directory,\n2565:         runtimeState,\n2566:         verifierResult,\n2567:       });\n2568:       return;\n2569:     }\n2570: \n2571:     if (eventType === 'session.deleted') {\n2572:       flushVolatileLocks(sessionID);\n2573:       if (sessionID) {\n2574:         try {\n2575:           await archiveGoalStateFile(sessionID, eventOptions);\n2576:         } catch {\n2577:           return;\n2578:         }\n2579:       }\n2580:       return;\n2581:     }\n2582: \n2583:     if (eventType.endsWith('.disposed')) {\n\n(Showing lines 2494-2583 of 2657. Use offset=2584 to continue.)\n</content>","metadata":{"preview":"  async function handleEvent(event) {\n    const eventOptions = normalizeOptions(rawOptions);\n    if (!eventOptions.enabled) return;\n    const eventType = eventTypeFrom(event);\n    const sessionID = extractEventSessionID(event);\n    if (!eventType) return;\n    await logDebugEvent(eventType, sessionID, eventOptions);\n\n    if (eventType === 'session.created') {\n      if (sessionID) await restoreActiveGoal(sessionID, eventOptions);\n      try {\n        await sweepOrphanedActiveStates(eventOptions, runtimeState);\n      } catch {\n        return;\n      }\n      return;\n    }\n\n    if (eventType === 'message.updated') {\n      if (sessionID) await recordMessageUpdated(sessionID, event, eventOptions);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","text":"  async function handleEvent(event) {\n    const eventOptions = normalizeOptions(rawOptions);\n    if (!eventOptions.enabled) return;\n    const eventType = eventTypeFrom(event);\n    const sessionID = extractEventSessionID(event);\n    if (!eventType) return;\n    await logDebugEvent(eventType, sessionID, eventOptions);\n\n    if (eventType === 'session.created') {\n      if (sessionID) await restoreActiveGoal(sessionID, eventOptions);\n      try {\n        await sweepOrphanedActiveStates(eventOptions, runtimeState);\n      } catch {\n        return;\n      }\n      return;\n    }\n\n    if (eventType === 'message.updated') {\n      if (sessionID) await recordMessageUpdated(sessionID, event, eventOptions);\n      return;\n    }\n\n    if (eventType === 'session.status') {\n      const status = extractEventSessionStatus(event);\n      if (sessionID && status) runtimeState.sessionStatuses.set(sessionID, status);\n      return;\n    }\n\n    if (eventType === 'permission.asked' || eventType === 'question.asked') {\n      if (sessionID) {\n        runtimeState.blockedByPromptSessions.add(sessionID);\n        await setBlockedByPrompt(sessionID, true, eventOptions);\n      }\n      return;\n    }\n\n    if (eventType === 'permission.replied' || eventType === 'question.replied' || eventType === 'question.rejected') {\n      if (sessionID) {\n        runtimeState.blockedByPromptSessions.delete(sessionID);\n        await setBlockedByPrompt(sessionID, false, eventOptions);\n      }\n      return;\n    }\n\n    if (eventType === 'session.idle') {\n      if (!sessionID) {\n        await maybeContinueGoal(sessionID, {\n          ...eventOptions,\n          client: ctx?.client,\n          directory: ctx?.directory,\n          runtimeState,\n        });\n        return;\n      }\n      runtimeState.sessionStatuses.set(sessionID, 'idle');\n      if (runtimeState.inFlightVerifications.has(sessionID)) return;\n      runtimeState.inFlightVerifications.add(sessionID);\n      let verifierResult = null;\n      try {\n        verifierResult = await maybeVerifyGoal(sessionID, {\n          ...rawOptions,\n          client: ctx?.client,\n        });\n      } finally {\n        runtimeState.inFlightVerifications.delete(sessionID);\n      }\n      await maybeContinueGoal(sessionID, {\n        ...eventOptions,\n        client: ctx?.client,\n        directory: ctx?.directory,\n        runtimeState,\n        verifierResult,\n      });\n      return;\n    }\n\n    if (eventType === 'session.deleted') {\n      flushVolatileLocks(sessionID);\n      if (sessionID) {\n        try {\n          await archiveGoalStateFile(sessionID, eventOptions);\n        } catch {\n          return;\n        }\n      }\n      return;\n    }\n\n    if (eventType.endsWith('.disposed')) {","lineStart":2494,"lineEnd":2583,"totalLines":2657,"truncated":true}},"title":".opencode/plugins/mk-goal.js","time":{"start":1783147323102,"end":1783147323106}},"id":"prt_f2bdcdd92001n5hU0Uytzb2tTJ","sessionID":"ses_0d42abedcffewM196xEPACWSgW","messageID":"msg_f2bdcd2b1001Qq6aqHkbHEv5Um"}}
