.py\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/scripts/design_search.py\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/03--quality-floor-gate/quality-floor-gate-on-built-ui.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/01--direction-freedom-and-deviation/free-axis-brainstorm-and-deviation.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/manual_testing_playbook.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/06--licensing-and-provenance/licensing-and-provenance-integrity.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/02--brief-pinning-and-precedence/pinned-brief-followed-verbatim.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/04--data-as-critique-against/query-default-then-deviate.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/05--abstention-and-routing/docs-task-routes-to-sk-doc.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/manual_testing_playbook/05--abstention-and-routing/pure-logic-routes-to-sk-code.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/README.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/LICENSE-ui-ux-pro-max.txt\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-interface-design/feature_catalog/01--design-p