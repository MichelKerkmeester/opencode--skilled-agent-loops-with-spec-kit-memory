import fs from \"node:fs\";
import { resolve } from \"node:path\";
import { scoreAdvisorPrompt } from \"./.opencode/skills/system-skill-advisor/mcp_server/dist/mcp_server/lib/scorer/fusion.js\";
import { skillMatchesAlias, skillInAliasSet } from \"./.opencode/skills/system-skill-advisor/mcp_server/dist/mcp_server/lib/scorer/aliases.js\";
const workspaceRoot=process.cwd();
const corpus=fs.readFileSync(\".opencode/skills/system-skill-advisor/mcp_server/scripts/routing-accuracy/labeled-prompts.jsonl\",\"utf8\").trim().split(/\\n/).map(JSON.parse);
function gold(r){ return r.skill_top_1 === \"none\" ? null : r.skill_top_1; }
function holdout(rows,target=40){ const groups=new Map(); for(const row of rows) groups.set(row.skill_top_1,[...(groups.get(row.skill_top_1)||[]),row]); const selected=[]; for(const group of [...groups.values()].sort((a,b)=>a[0].skill_top_1.localeCompare(b[0].skill_top_1))){ const take=Math.max(1,Math.round(group.length*0.2)); selected.push(...group.filter((_,i)=>i%5===0).slice(0,take)); } for(const row of rows){ if(selected.length>=target) break; if("'!selected.includes(row)) selected.push(row); } return selected.slice(0,target); }
function evalRows(rows, alias=false){ let correct=0, unknown=0, falseFire=0; const agg={}; const driftFixes=[]; const genuine=[]; for(const r of rows){ const expected=gold(r); const res=scoreAdvisorPrompt(r.prompt,{workspaceRoot}); const actual=res.topSkill; if(actual===null) unknown++; if(expected===null && actual!==null) falseFire++; const ok=alias ? (expected===actual || (expected!==null && actual!==null && skillMatchesAlias(actual, expected))) : actual===expected; if(ok) correct++; if(expected!==null){ agg[expected]??={total:0,matched:0,aliasMatched:0}; agg[expected].total++; if(actual===expected) agg[expected].matched++; if(actual!==expected && actual!==null && skillMatchesAlias(actual, expected)){ agg[expected].aliasMatched++; driftFixes.push({id:r.id, expected, actual}); } else if(!ok) genuine.push({id:r.id, expected, actual}); } }
 return {correct,total:rows.length,accuracy:Number((correct/rows.length).toFixed(4)),unknown,falseFire,agg,driftFixesCount:driftFixes.length,genuineCount:genuine.length}; }
const fullStrict=evalRows(corpus,false); const fullAlias=evalRows(corpus,true); const h=holdout(corpus); const holdStrict=evalRows(h,false); const holdAlias=evalRows(h,true);
const fixtures=fs.readFileSync(".opencode/skills/system-skill-advisor/mcp_server/scripts/fixtures/skill_advisor_regression_cases.jsonl","utf8").trim().split(/'"\\n/).map(JSON.parse);
const ids=new Set([\"P0-MEM-001\",\"P0-UNC-001\",\"P0-UNC-002\",\"P0-CMD-001\",\"P0-CMD-002\",\"P0-CMD-003\"]);
const p0Details=fixtures.filter(r=>ids.has(r.id)).map(r=>{ const res=scoreAdvisorPrompt(r.prompt,{workspaceRoot,confidenceThreshold:0.8,uncertaintyThreshold:r.confidence_only?1:0.35}); const top=res.recommendations[0]??null; const expected=r.expected_top_any??[]; const strict=r.expect_result?Boolean(top&&expected.includes(top.skill)):top===null; const alias=r.expect_result?Boolean(top&&skillInAliasSet(top.skill, expected)):top===null; return {id:r.id, prompt:r.prompt, confidence_only:"'!!r.confidence_only, expect_result:r.expect_result, expected, top:top&&{skill:top.skill,kind:top.kind,confidence:top.confidence,uncertainty:top.uncertainty,passes:top.passes_threshold,score:top.score,dominantLane:top.dominantLane}, strict, alias, candidateCount:res.metrics.candidateCount, ambiguous:res.ambiguous}; });
console.log(JSON.stringify({fullStrict,fullAlias,holdStrict,holdAlias,p0Details},null,2));
