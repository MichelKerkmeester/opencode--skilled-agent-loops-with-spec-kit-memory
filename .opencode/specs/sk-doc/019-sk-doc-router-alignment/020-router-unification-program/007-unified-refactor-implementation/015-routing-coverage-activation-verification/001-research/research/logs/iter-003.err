.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deltas/iter-003.jsonl:1:{"type":"iteration","iteration":3,"run":3,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.82,"status":"complete","focus":"Automation surfaces and existing art for serialized publication and recovery","findingsCount":8,"noveltyJustification":"Compared local hooks, wrappers, daemons, remote queues, and adjacent tools; identified the daemon plus clean publisher as the low-latency surface and merge queues/Gerrit as stronger CI-gated remote analogues.","keyQuestions":["Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?","What do the named existing tools and workflows demonstrate or fail to guarantee?","Which conflict-avoidance and conflict-handling rules make concurrent additive work tractable?"],"answeredQuestions":["Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?"],"ruledOut":[{"approach":"client hooks as the sole serializer","reason":"Hooks can reject or notify but do not provide durable shared queue ownership","evidence":"https://git-scm.com/docs/githooks"},{"approach":"force-push mirroring as shared-branch default","reason":"The cited action explicitly uses force push and requires a mirror backup","evidence":"https://github.com/wei/git-sync"},{"approach":"Syncthing-style file mirroring as Git integration","reason":"Replicates files but does not establish Git ref parentage or fast-forward publication","evidence":"https://docs.syncthing.net/users/faq.html"}],"graphEvents":[{"type":"node","id":"q-rq5","kind":"QUESTION","label":"RQ5 automation surface"},{"type":"node","id":"q-rq6","kind":"QUESTION","label":"RQ6 conflict handling"},{"type":"node","id":"q-rq7","kind":"QUESTION","label":"RQ7 existing art"},{"type":"node","id":"f-hooks-edge","kind":"CLAIM","label":"Hooks are guardrails, not the multi-writer coordinator"},{"type":"node","id":"f-launch-lifecycle","kind":"CLAIM","label":"Launch wrapper allocates isolated workspaces but cannot serialize publication"},{"type":"node","id":"f-daemon-surface","kind":"CLAIM","label":"Background daemon is the right local queue and recovery surface"},{"type":"node","id":"f-gh-queue","kind":"CLAIM","label":"GitHub merge queue serializes tested PR integration"},{"type":"node","id":"f-gerrit-submit","kind":"CLAIM","label":"Gerrit provides pending changes and submit requirements"},{"type":"node","id":"f-git-town","kind":"CLAIM","label":"Git Town demonstrates stash and undo UX without a shared multiplexer"},{"type":"node","id":"f-adjacent-tools","kind":"CLAIM","label":"mob, git-sync, git-auto-sync, and Syncthing solve adjacent bounded problems"},{"type":"node","id":"s-hooks-3","kind":"SOURCE","label":"githooks manual"},{"type":"node","id":"s-gh-queue-3","kind":"SOURCE","label":"GitHub merge queue documentation"},{"type":"node","id":"s-gerrit-3","kind":"SOURCE","label":"Gerrit submit requirements"},{"type":"node","id":"s-town-3","kind":"SOURCE","label":"Git Town sync documentation"},{"type":"node","id":"s-auto-3","kind":"SOURCE","label":"git-auto-sync package documentation"},{"type":"node","id":"s-gitsync-3","kind":"SOURCE","label":"simonthum git-sync repository"},{"type":"node","id":"s-mob-3","kind":"SOURCE","label":"mob documentation"},{"type":"node","id":"s-sync-3","kind":"SOURCE","label":"Syncthing FAQ"},{"type":"edge","id":"e-hooks-rq5","source":"f-hooks-edge","target":"q-rq5","relation":"COVERS"},{"type":"edge","id":"e-launch-rq5","source":"f-launch-lifecycle","target":"q-rq5","relation":"COVERS"},{"type":"edge","id":"e-daemon-rq5","source":"f-daemon-surface","target":"q-rq5","relation":"COVERS"},{"type":"edge","id":"e-gh-rq1","source":"f-gh-queue","target":"q-rq1","relation":"COVERS"},{"type":"edge","id":"e-gerrit-rq7","source":"f-gerrit-submit","target":"q-rq7","relation":"COVERS"},{"type":"edge","id":"e-town-rq4","source":"f-git-town","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-adj-rq7","source":"f-adjacent-tools","target":"q-rq7","relation":"COVERS"},{"type":"edge","id":"e-hooks-src","source":"s-hooks-3","target":"f-hooks-edge","relation":"SUPPORTS"},{"type":"edge","id":"e-gh-src","source":"s-gh-queue-3","target":"f-gh-queue","relation":"SUPPORTS"},{"type":"edge","id":"e-gerrit-src","source":"s-gerrit-3","target":"f-gerrit-submit","relation":"SUPPORTS"},{"type":"edge","id":"e-town-src","source":"s-town-3","target":"f-git-town","relation":"SUPPORTS"},{"type":"edge","id":"e-auto-src","source":"s-auto-3","target":"f-daemon-surface","relation":"SUPPORTS"},{"type":"edge","id":"e-gitsync-src","source":"s-gitsync-3","target":"f-adjacent-tools","relation":"SUPPORTS"},{"type":"edge","id":"e-mob-src","source":"s-mob-3","target":"f-adjacent-tools","relation":"SUPPORTS"},{"type":"edge","id":"e-sync-src","source":"s-sync-3","target":"f-adjacent-tools","relation":"SUPPORTS"}],"executor":{"kind":"cli-codex","model":"gpt-5.6-luna","reasoningEffort":"max","serviceTier":"fast","sandboxMode":"workspace-write"},"timestamp":"2026-07-14T04:59:00Z","sessionId":"fanout-parallel-git-luna-1784004109977-h2q92q","generation":1}
.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deltas/iter-005.jsonl:1:{"type":"iteration","iteration":5,"run":5,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.68,"status":"complete","focus":"Adversarial architecture review, crash recovery, and final acceptance matrix","findingsCount":6,"noveltyJustification":"Stress-tested the candidate architectures against crash windows, ambiguous push acknowledgments, object reachability, rollback, and the exact boundary of the no-loss contract.","keyQuestions":["Which integration strategy handles concurrent publication and push races with the strongest correctness and liveness properties?","Which workspace model prevents sessions from overwriting each other's files while keeping the shared branch current?","How can a local IDE checkout stay current without disturbing uncommitted changes?","Which invariants prevent orphaned autostashes, overwritten work, force-push loss, and make rollback reliable?","Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?","Which conflict-avoidance and conflict-handling rules make concurrent additive work tractable?","What do the named existing tools and workflows demonstrate or fail to guarantee?"],"answeredQuestions":["Which integration strategy handles concurrent publication and push races with the strongest correctness and liveness properties?","Which workspace model prevents sessions from overwriting each other's files while keeping the shared branch current?","How can a local IDE checkout stay current without disturbing uncommitted changes?","Which invariants prevent orphaned autostashes, overwritten work, force-push loss, and make rollback reliable?","Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?","Which conflict-avoidance and conflict-handling rules make concurrent additive work tractable?","What do the named existing tools and workflows demonstrate or fail to guarantee?"],"ruledOut":[{"approach":"independent session push loops as the default","reason":"Cannot own durable retries or hide races without central coordination","evidence":"https://git-scm.com/docs/git-push"},{"approach":"git fsck discovery as the durable queue","reason":"Recovery scanning is not submission ownership","evidence":"https://git-scm.com/docs/git-fsck"},{"approach":"including unsaved editor buffers in the Git no-loss guarantee","reason":"Git cannot observe state never written to disk","evidence":"https://git-scm.com/docs/git-bundle"}],"graphEvents":[{"type":"node","id":"q-all-rq","kind":"QUESTION","label":"RQ1-RQ7 complete architecture review"},{"type":"node","id":"f-default-arch","kind":"CLAIM","label":"Isolated session worktrees plus one serialized merge-tree/CAS publisher is the low-latency default"},{"type":"node","id":"f-strategy-matrix","kind":"CLAIM","label":"Independent retry, serialized daemon, remote queue, and scratch publisher have distinct trade-offs"},{"type":"node","id":"f-reachability","kind":"CLAIM","label":"Pending refs or bundles are needed across crashes before final publication"},{"type":"node","id":"f-ack-reconcile","kind":"CLAIM","label":"Ambiguous push acknowledgments require read-after-write reconciliation"},{"type":"node","id":"f-contract-boundary","kind":"CLAIM","label":"No-loss covers saved managed files, not unsaved buffers or arbitrary semantic overlap"},{"type":"node","id":"f-acceptance-matrix","kind":"CLAIM","label":"Acceptance spans races, liveness, overlap, dirty worktrees, crash, rollback, and observability"},{"type":"node","id":"s-push-5","kind":"SOURCE","label":"git-push manual"},{"type":"node","id":"s-update-5","kind":"SOURCE","label":"git-update-ref manual"},{"type":"node","id":"s-tree-5","kind":"SOURCE","label":"git-merge-tree manual"},{"type":"node","id":"s-fsck-5","kind":"SOURCE","label":"git-fsck manual"},{"type":"node","id":"s-bundle-5","kind":"SOURCE","label":"git-bundle manual"},{"type":"node","id":"s-worktree-5","kind":"SOURCE","label":"git-worktree manual"},{"type":"edge","id":"e-default-all","source":"f-default-arch","target":"q-all-rq","relation":"COVERS"},{"type":"edge","id":"e-matrix-all","source":"f-strategy-matrix","target":"q-all-rq","relation":"COVERS"},{"type":"edge","id":"e-reach-rq4","source":"f-reachability","target":"q-all-rq","relation":"COVERS"},{"type":"edge","id":"e-ack-rq1","source":"f-ack-reconcile","target":"q-all-rq","relation":"COVERS"},{"type":"edge","id":"e-boundary-rq4","source":"f-contract-boundary","target":"q-all-rq","relation":"COVERS"},{"type":"edge","id":"e-accept-all","source":"f-acceptance-matrix","target":"q-all-rq","relation":"COVERS"},{"type":"edge","id":"e-push-default","source":"s-push-5","target":"f-default-arch","relation":"SUPPORTS"},{"type":"edge","id":"e-update-default","source":"s-update-5","target":"f-default-arch","relation":"SUPPORTS"},{"type":"edge","id":"e-tree-default","target":"f-default-arch","relation":"SUPPORTS"},{"type":"edge","id":"e-fsck-reach","source":"s-fsck-5","target":"f-reachability","relation":"SUPPORTS"},{"type":"edge","id":"e-bundle-reach","source":"s-bundle-5","target":"f-reachability","relation":"SUPPORTS"},{"type":"edge","id":"e-worktree-boundary","source":"s-worktree-5","target":"f-contract-boundary","relation":"SUPPORTS"}],"executor":{"kind":"cli-codex","model":"gpt-5.6-luna","reasoningEffort":"max","serviceTier":"fast","sandboxMode":"workspace-write"},"timestamp":"2026-07-14T05:02:58Z","sessionId":"fanout-parallel-git-luna-1784004109977-h2q92q","generation":1}
.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deltas/iter-002.jsonl:1:{"type":"iteration","iteration":2,"run":2,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.88,"status":"complete","focus":"Safe checkout freshness, autostash failure modes, guarded updates, and rollback","findingsCount":6,"noveltyJustification":"Established the fetch-only versus working-tree freshness boundary and documented why autostash and destructive reset cannot provide a no-loss invariant.","keyQuestions":["How can a local IDE checkout stay current without disturbing uncommitted changes?","Which invariants prevent orphaned autostashes, overwritten work, force-push loss, and make rollback reliable?","Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?"],"answeredQuestions":["How can a local IDE checkout stay current without disturbing uncommitted changes?"],"ruledOut":[{"approach":"blind pull --rebase --autostash in a dirty shared IDE worktree","reason":"Autostash application can conflict and temporary stash state can remain after quit","evidence":"https://git-scm.com/docs/git-pull"},{"approach":"blind git reset --hard for checkout freshness","reason":"Can overwrite tracked edits and remove obstructing untracked files","evidence":"https://git-scm.com/docs/git-reset"},{"approach":"fast-forward-only as the complete integration strategy","reason":"Refuses when local and incoming histories diverge","evidence":"https://git-scm.com/docs/git-merge"}],"graphEvents":[{"type":"node","id":"q-rq3","kind":"QUESTION","label":"RQ3 current checkout"},{"type":"node","id":"q-rq4","kind":"QUESTION","label":"RQ4 safety and rollback"},{"type":"node","id":"q-rq5","kind":"QUESTION","label":"RQ5 automation surface"},{"type":"node","id":"f-fetch-watch","kind":"CLAIM","label":"Fetch-only watcher refreshes refs without rewriting the worktree"},{"type":"node","id":"f-ff-view","kind":"CLAIM","label":"Fast-forward-only update belongs on a clean current-view worktree"},{"type":"node","id":"f-autostash","kind":"CLAIM","label":"Autostash needs identity tracking and post-apply verification"},{"type":"node","id":"f-reset-keep","kind":"CLAIM","label":"reset --keep refuses overlap while reset --hard can lose work"},{"type":"node","id":"f-split-ownership","kind":"CLAIM","label":"Always-current files and lossless arbitrary dirty edits require separate ownership"},{"type":"node","id":"f-rollback","kind":"CLAIM","label":"Rollback needs explicit old state and retained recovery material"},{"type":"node","id":"s-fetch-2","kind":"SOURCE","label":"git-fetch manual"},{"type":"node","id":"s-pull-2","kind":"SOURCE","label":"git-pull manual"},{"type":"node","id":"s-merge-2","kind":"SOURCE","label":"git-merge manual"},{"type":"node","id":"s-reset-2","kind":"SOURCE","label":"git-reset manual"},{"type":"node","id":"s-rebase-2","kind":"SOURCE","label":"git-rebase manual"},{"type":"node","id":"s-reflog-2","kind":"SOURCE","label":"git-reflog manual"},{"type":"edge","id":"e-fetch-rq3","source":"f-fetch-watch","target":"q-rq3","relation":"COVERS"},{"type":"edge","id":"e-view-rq3","source":"f-ff-view","target":"q-rq3","relation":"COVERS"},{"type":"edge","id":"e-auto-rq4","source":"f-autostash","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-reset-rq4","source":"f-reset-keep","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-split-rq3","source":"f-split-ownership","target":"q-rq3","relation":"COVERS"},{"type":"edge","id":"e-roll-rq4","source":"f-rollback","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-fetch-src","source":"s-fetch-2","target":"f-fetch-watch","relation":"SUPPORTS"},{"type":"edge","id":"e-pull-src","source":"s-pull-2","target":"f-autostash","relation":"SUPPORTS"},{"type":"edge","id":"e-merge-src","source":"s-merge-2","target":"f-ff-view","relation":"SUPPORTS"},{"type":"edge","id":"e-reset-src","source":"s-reset-2","target":"f-reset-keep","relation":"SUPPORTS"},{"type":"edge","id":"e-rebase-src","source":"s-rebase-2","target":"f-autostash","relation":"SUPPORTS"},{"type":"edge","id":"e-reflog-src","source":"s-reflog-2","target":"f-rollback","relation":"SUPPORTS"}],"executor":{"kind":"cli-codex","model":"gpt-5.6-luna","reasoningEffort":"max","serviceTier":"fast","sandboxMode":"workspace-write"},"timestamp":"2026-07-14T04:58:00Z","sessionId":"fanout-parallel-git-luna-1784004109977-h2q92q","generation":1}
.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deltas/iter-004.jsonl:1:{"type":"iteration","iteration":4,"run":4,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.76,"status":"complete","focus":"Conflict avoidance and handling policies with non-destructive merge preflight","findingsCount":7,"noveltyJustification":"Converted Git merge-tree, rerere, merge-driver, and sparse-checkout semantics into explicit conflict rules and an executable acceptance suite.","keyQuestions":["Which conflict-avoidance and conflict-handling rules make concurrent additive work tractable?","Which integration strategy should be the default when low latency matters more than CI-gated queueing?","Which safety and rollback invariants must be made acceptance tests rather than documentation claims?"],"answeredQuestions":["Which conflict-avoidance and conflict-handling rules make concurrent additive work tractable?"],"ruledOut":[{"approach":"additive-only without unique paths or keys","reason":"Shared generated files, duplicate names, renames, and deletes can still conflict","evidence":"https://git-scm.com/docs/git-merge-tree"},{"approach":"sparse checkout as session isolation","reason":"Projects files but does not isolate refs or ownership","evidence":"https://git-scm.com/docs/git-sparse-checkout"},{"approach":"unconditional rerere or ours/theirs merge drivers","reason":"Can encode an unverified semantic choice","evidence":"https://git-scm.com/docs/git-rerere"}],"graphEvents":[{"type":"node","id":"q-rq1","kind":"QUESTION","label":"RQ1 integration strategy"},{"type":"node","id":"q-rq2","kind":"QUESTION","label":"RQ2 workspace model"},{"type":"node","id":"q-rq4","kind":"QUESTION","label":"RQ4 safety and rollback"},{"type":"node","id":"q-rq6","kind":"QUESTION","label":"RQ6 conflict handling"},{"type":"node","id":"f-path-manifest","kind":"CLAIM","label":"Disjoint path ownership is the strongest structural conflict avoidance rule"},{"type":"node","id":"f-additive-subtrees","kind":"CLAIM","label":"Per-session subtrees help only with unique paths or keys"},{"type":"node","id":"f-merge-tree","kind":"CLAIM","label":"merge-tree provides non-destructive clean/conflicted merge preflight"},{"type":"node","id":"f-rerere","kind":"CLAIM","label":"rerere accelerates repeated resolutions but is not correctness proof"},{"type":"node","id":"f-merge-driver","kind":"CLAIM","label":"Custom merge drivers need fail-closed domain policy"},{"type":"node","id":"f-sparse","kind":"CLAIM","label":"Sparse checkout is a projection optimization, not ref isolation"},{"type":"node","id":"f-acceptance","kind":"CLAIM","label":"Acceptance tests must verify no silent loss, durable conflicts, CAS, and rollback"},{"type":"node","id":"s-merge-tree-4","kind":"SOURCE","label":"git-merge-tree manual"},{"type":"node","id":"s-rerere-4","kind":"SOURCE","label":"git-rerere manual"},{"type":"node","id":"s-attrs-4","kind":"SOURCE","label":"gitattributes manual"},{"type":"node","id":"s-sparse-4","kind":"SOURCE","label":"git-sparse-checkout manual"},{"type":"node","id":"s-update-ref-4","kind":"SOURCE","label":"git-update-ref manual"},{"type":"edge","id":"e-path-rq6","source":"f-path-manifest","target":"q-rq6","relation":"COVERS"},{"type":"edge","id":"e-add-rq6","source":"f-additive-subtrees","target":"q-rq6","relation":"COVERS"},{"type":"edge","id":"e-tree-rq1","source":"f-merge-tree","target":"q-rq1","relation":"COVERS"},{"type":"edge","id":"e-rerere-rq6","source":"f-rerere","target":"q-rq6","relation":"COVERS"},{"type":"edge","id":"e-driver-rq6","source":"f-merge-driver","target":"q-rq6","relation":"COVERS"},{"type":"edge","id":"e-sparse-rq2","source":"f-sparse","target":"q-rq2","relation":"COVERS"},{"type":"edge","id":"e-accept-rq4","source":"f-acceptance","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-tree-src","source":"s-merge-t