resolveIpcSocketPath(dbDir: string): string {\n\n  Line 202:   const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n\n  Line 203:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n\n  Line 218: function canUnlinkExistingSocket(socketPath: string): boolean {\n\n  Line 273:     if (socketPath.startsWith('tcp://')) {\n\n  Line 283: // unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n\n  Line 307: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n\n  Line 326: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n\n  Line 330:   const socketPath = options.socketPath.startsWith('tcp://')\n\n  Line 336:   if (!socketPath.startsWith('tcp://')) {\n\n  Line 338:     fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n\n  Line 339:     // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n\n  Line 348:       if ((st.mode & 0o022) !== 0) {\n\n  Line 349:         throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n\n  Line 357:     // protection so a symlink whose target we would later chmod cannot be used to redirect the\n\n  Line 424:     if (socketPath.startsWith('tcp://')) {\n\n  Line 462:     ? `tcp://${address.address}:${address.port}`\n\n  Line 464:   if (!socketPath.startsWith('tcp://')) {\n\n  Line 465:     // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n\n  Line 466:     // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n\n  Line 469:       throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n\n  Line 471:     fs.chmodSync(socketPath, 0o600);\n\n  Line 492:       if (!socketPath.startsWith('tcp://')) {\n\n  Line 510:   resolveIpcSocketPath,\n\n  Line 511:   startIpcSocketServer,\n","metadata