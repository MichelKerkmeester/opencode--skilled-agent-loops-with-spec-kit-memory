     1	// ───────────────────────────────────────────────────────────────
     2	// MODULE: Advisor Scorer Calibration Constants
     3	// ───────────────────────────────────────────────────────────────
     4	// Single source of truth for the numeric tuning constants used by
     5	// `lib/scorer/fusion.ts` (`confidenceFor`, `uncertaintyFor`, and
     6	// `primaryIntentBonus`). The scorer-calibration bench
     7	// (`bench/scorer-calibration.bench.ts`) treats these values as the
     8	// "tuned" surface — naming them here lets a calibration pass be diffed
     9	// in PRs and rolled back in one place.
    10	//
    11	// IMPORTANT: This refactor MUST be byte-equivalent to the prior inline
    12	// numerics. Tweaking any value here is a behavior change, not a refactor.
    13	
    14	/**
    15	 * Confidence-assembly knobs used by `confidenceFor` in `fusion.ts`.
    16	 */
    17	export interface ConfidenceCalibration {
    18	  /** Floor confidence assigned to read-only explainer prompts that target the
    19	   * advisor itself, OR read-only explainer prompts where the read-only route
    20	   * is not allow-listed. */
    21	  readonly readOnlyExplainerFloor: number;
    22	  /** Base term added to the live-normalized confidence ramp. */
    23	  readonly baseConstant: number;
    24	  /** Multiplier applied to `liveNormalized` before clipping at 1.0. */
    25	  readonly liveNormalizedRampGain: number;
    26	  /** Coefficient on the ramp output that decides how much live-evidence
    27	   * pressure can lift base confidence. */
    28	  readonly liveNormalizedRampCoefficient: number;
    29	  /** When `readOnlyRouteAllowed` is true, base confidence is lifted to at
    30	   * least this value before rounding. */
    31	  readonly readOnlyRouteAllowedFloor: number;
    32	  /** When the derived lane dominates and direct evidence is below the
    33	   * `derivedDominantDirectScoreCeiling`, confidence is pinned to this value. */
    34	  readonly derivedDominantConfidence: number;
    35	  /** Maximum direct score still considered "low direct evidence" for the
    36	   * derived-dominant short-circuit. */
    37	  readonly derivedDominantDirectScoreCeiling: number;
    38	  /** Direct-score floor that, when paired with task-intent, lifts confidence
    39	   * to at least the task-intent floor. */
    40	  readonly taskIntentDirectScoreFloor: number;
    41	  /** Live-normalized floor that, when paired with task-intent, lifts
    42	   * confidence to at least the task-intent floor. */
    43	  readonly taskIntentLiveNormalizedFloor: number;
    44	  /** Confidence floor applied when task-intent is met. */
    45	  readonly taskIntentFloor: number;
    46	  /** Direct score above which confidence is lifted to at least the
    47	   * `directScoreFloor` (regardless of task-intent). */
    48	  readonly directScoreLiftThreshold: number;
    49	  /** Confidence floor applied to high-direct-score prompts. */
    50	  readonly directScoreFloor: number;
    51	  /** Direct-score threshold above which a fixed bonus is added to the base
    52	   * confidence (without forcing the floor). */
    53	  readonly directScoreBonusThreshold: number;
    54	  /** Bonus added when the direct score clears `directScoreBonusThreshold`. */
    55	  readonly directScoreBonus: number;
    56	  /** Hard ceiling on the final assembled confidence value. */
    57	  readonly hardCeiling: number;
    58	}
    59	
    60	/**
    61	 * Uncertainty-assembly knobs used by `uncertaintyFor` in `fusion.ts`.
    62	 */
    63	export interface UncertaintyCalibration {
    64	  /** Default uncertainty when no evidence is observed. */
    65	  readonly noEvidenceDefault: number;
    66	  /** Evidence count that drops uncertainty to the low floor. */
    67	  readonly highEvidenceCount: number;
    68	  /** Uncertainty applied at and above the high evidence count. */
    69	  readonly lowFloor: number;
    70	  /** Evidence count for the medium uncertainty band. */
    71	  readonly mediumEvidenceCount: number;
    72	  /** Uncertainty applied at the medium evidence band. */
    73	  readonly mediumFloor: number;
    74	  /** Evidence count for the elevated uncertainty band. */
    75	  readonly someEvidenceCount: number;
    76	  /** Uncertainty applied at the elevated band. */
    77	  readonly elevatedFloor: number;
    78	  /** Direct evidence threshold that triggers an uncertainty discount. */
    79	  readonly directEvidenceDiscountThreshold: number;
    80	  /** Discount applied when direct evidence clears the threshold. */
    81	  readonly directEvidenceDiscount: number;
    82	  /** Confidence threshold below which an uncertainty penalty is applied. */
    83	  readonly lowConfidencePenaltyThreshold: number;
    84	  /** Penalty added when confidence falls below the threshold. */
    85	  readonly lowConfidencePenalty: number;
    86	  /** Hard floor on the final uncertainty value. */
    87	  readonly hardFloor: number;
    88	  /** Hard ceiling on the final uncertainty value. */
    89	  readonly hardCeiling: number;
    90	}
    91	
    92	/**
    93	 * Per-skill routing biases applied by `primaryIntentBonus` in `fusion.ts`.
    94	 *
    95	 * Naming convention: `<intent>SkillBonus` for positive (upweight) terms,
    96	 * `<intent>SkillPenalty` for negative (downweight) terms. The leading
    97	 * `routing.` namespace keeps the calibration surface scannable as a single
    98	 * block per call site.
    99	 */
   100	export interface RoutingCalibration {
   101	  // semantic search intent
   102	  readonly semanticSearchCodeGraphBonus: number;
   103	  // deep-review intent
   104	  readonly deepReviewSkCodeReviewPenalty: number;
   105	  // deep-research intent (text-only)
   106	  readonly deepResearchOtherSkillsPenalty: number;
   107	  // deep-research-cycle phrase intent
   108	  readonly deepResearchCycleOtherSkillsPenalty: number;
   109	  // compare/audit/review + classifier-vocabulary intent
   110	  readonly compareAuditCodeReviewBonus: number;
   111	  readonly compareAuditCodeOpenCodePenalty: number;
   112	  // corpus/predictions/continuation/study-config intent
   113	  readonly corpusStudySpecKitBonus: number;
   114	  readonly corpusStudyOtherSkillsPenalty: number;
   115	  // explicit slash-command bonuses
   116	  readonly speckitResumeSpecKitBonus: number;
   117	  readonly speckitResumeCommandPenalty: number;
   118	  // phase-folder intent
   119	  readonly phaseFolderSpecKitBonus: number;
   120	  // save-context / save-memory intent
   121	  readonly saveContextMemorySaveBonus: number;
   122	  readonly saveContextMemorySpecKitPenalty: number;
   123	  // create-agent intent
   124	  readonly createAgentCreateAgentBonus: number;
   125	  readonly createAgentSkDocPenalty: number;
   126	  // create-testing-playbook intent
   127	  readonly createTestingPlaybookBonus: number;
   128	  readonly createTestingPlaybookSkDocPenalty: number;
   129	  readonly createTestingPlaybookOtherSkillsPenalty: number;
   130	}
   131	
   132	export interface ScoringCalibration {
   133	  readonly confidence: ConfidenceCalibration;
   134	  readonly uncertainty: UncertaintyCalibration;
   135	  readonly routing: RoutingCalibration;
   136	}
   137	
   138	export const SCORING_CALIBRATION: ScoringCalibration = Object.freeze({
   139	  confidence: Object.freeze({
   140	    readOnlyExplainerFloor: 0.25,
   141	    baseConstant: 0.52,
   142	    liveNormalizedRampGain: 1.25,
   143	    liveNormalizedRampCoefficient: 0.43,
   144	    readOnlyRouteAllowedFloor: 0.82,
   145	    derivedDominantConfidence: 0.72,
   146	    derivedDominantDirectScoreCeiling: 0.2,
   147	    taskIntentDirectScoreFloor: 0.18,
   148	    taskIntentLiveNormalizedFloor: 0.2,
   149	    taskIntentFloor: 0.82,
   150	    directScoreLiftThreshold: 0.65,
   151	    directScoreFloor: 0.82,
   152	    directScoreBonusThreshold: 0.85,
   153	    directScoreBonus: 0.04,
   154	    hardCeiling: 0.95,
   155	  }),
   156	  uncertainty: Object.freeze({
   157	    noEvidenceDefault: 0.42,
   158	    highEvidenceCount: 5,
   159	    lowFloor: 0.18,
   160	    mediumEvidenceCount: 3,
   161	    mediumFloor: 0.22,
   162	    someEvidenceCount: 1,
   163	    elevatedFloor: 0.30,
   164	    directEvidenceDiscountThreshold: 0.75,
   165	    directEvidenceDiscount: 0.06,
   166	    lowConfidencePenaltyThreshold: 0.8,
   167	    lowConfidencePenalty: 0.08,
   168	    hardFloor: 0.08,
   169	    hardCeiling: 0.95,
   170	  }),
   171	  routing: Object.freeze({
   172	    semanticSearchCodeGraphBonus: 0.5,
   173	    deepReviewSkCodeReviewPenalty: -0.25,
   174	    deepResearchOtherSkillsPenalty: -0.18,
   175	    deepResearchCycleOtherSkillsPenalty: -0.18,
   176	    compareAuditCodeReviewBonus: 0.35,
   177	    compareAuditCodeOpenCodePenalty: -0.18,
   178	    corpusStudySpecKitBonus: 0.35,
   179	    corpusStudyOtherSkillsPenalty: -0.16,
   180	    speckitResumeSpecKitBonus: 0.16,
   181	    speckitResumeCommandPenalty: -0.12,
   182	    phaseFolderSpecKitBonus: 0.35,
   183	    saveContextMemorySaveBonus: 0.55,
   184	    saveContextMemorySpecKitPenalty: -0.25,
   185	    createAgentCreateAgentBonus: 0.55,
   186	    createAgentSkDocPenalty: -0.18,
   187	    createTestingPlaybookBonus: 0.65,
   188	    createTestingPlaybookSkDocPenalty: -0.3,
   189	    createTestingPlaybookOtherSkillsPenalty: -0.2,
   190	  }),
   191	});
   192	
   193	export interface RoutingCalibrationOverride {
   194	  memorySaveBonus?: number;
   195	  createAgentBonus?: number;
   196	  testingPlaybookBonus?: number;
   197	}
   198	
   199	export function resolvedCalibration(): ScoringCalibration {
   200	  const raw = process.env.SPECKIT_ADVISOR_CALIBRATION_OVERRIDE_JSON;
   201	  if (!raw) return SCORING_CALIBRATION;
   202	  try {
   203	    const override = JSON.parse(raw) as RoutingCalibrationOverride;
   204	    return {
   205	      ...SCORING_CALIBRATION,
   206	      routing: Object.freeze({
   207	        ...SCORING_CALIBRATION.routing,
   208	        ...(override.memorySaveBonus !== undefined ? { saveContextMemorySaveBonus: override.memorySaveBonus } : {}),
   209	        ...(override.createAgentBonus !== undefined ? { createAgentCreateAgentBonus: override.createAgentBonus } : {}),
   210	        ...(override.testingPlaybookBonus !== undefined ? { createTestingPlaybookBonus: override.testingPlaybookBonus } : {}),
   211	      }),
   212	    };
   213	  } catch {
   214	    console.warn('[skill-advisor] Failed to parse SPECKIT_ADVISOR_CALIBRATION_OVERRIDE_JSON; using defaults');
   215	    return SCORING_CALIBRATION;
   216	  }
   217	}

