{"type":"tool_use","timestamp":1781459223840,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_00_4EbQ1BGVPDsPxuA4NYF84625","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/_common.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/_common.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Shared helpers for mcp-figma scripts. Source this; do not run directly.\n3: # WHY: every script must resolve the silships binary the same way, because the\n4: # npm package literally named \"figma-cli\" is an UNRELATED tool (unic/figma-cli,\n5: # which installs a bin named \"figma\"). The silships tool is \"figma-ds-cli\".\n6: \n7: set -euo pipefail\n8: \n9: _c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\n10: log()  { printf '%s\\n' \"$*\"; }\n11: info() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\n12: ok()   { printf '%s✓ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\n13: warn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\n14: err()  { printf '%s✗ %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n15: \n16: # Resolve the silships figma-cli binary.\n17: # Order: figma-ds-cli (npm canonical, unambiguous) -> figma-cli (silships repo build only).\n18: # A bare \"figma\" is NOT ours (that is unic/figma-cli) and is never selected.\n19: figma_bin() {\n20:   if command -v figma-ds-cli >/dev/null 2>&1; then printf 'figma-ds-cli'; return 0; fi\n21:   if command -v figma-cli   >/dev/null 2>&1; then printf 'figma-cli';   return 0; fi\n22:   return 1\n23: }\n24: \n25: # Node major version (echoes integer or empty).\n26: node_major() {\n27:   command -v node >/dev/null 2>&1 || { printf ''; return 0; }\n28:   node -p 'process.versions.node.split(\".\")[0]' 2>/dev/null || printf ''\n29: }\n30: \n31: # Locate Figma Desktop without launching it.\n32: figma_desktop_path() {\n33:   for p in \"/Applications/Figma.app\" \"$HOME/Applications/Figma.app\"; do\n34:     [ -d \"$p\" ] && { printf '%s' \"$p\"; return 0; }\n35:   done\n36:   return 1\n37: }\n38: \n39: # Is a TCP port listening on localhost? (best-effort, no install)\n40: port_listening() {\n41:   local port=\"$1\"\n42:   if command -v lsof >/dev/null 2>&1; then\n43:     lsof -nP -iTCP:\"$port\" -sTCP:LISTEN >/dev/null 2>&1 && return 0 || return 1\n44:   fi\n45:   return 2  # unknown\n46: }\n47: \n48: DAEMON_TOKEN_FILE=\"$HOME/.figma-ds-cli/.daemon-token\"\n49: DAEMON_PID_FILE=\"$HOME/.figma-cli-daemon.pid\"\n50: DAEMON_PORT=3456\n51: CDP_PORT=9222\n\n(End of file - total 51 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Shared helpers for mcp-figma scripts. Source this; do not run directly.\n# WHY: every script must resolve the silships binary the same way, because the\n# npm package literally named \"figma-cli\" is an UNRELATED tool (unic/figma-cli,\n# which installs a bin named \"figma\"). The silships tool is \"figma-ds-cli\".\n\nset -euo pipefail\n\n_c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\nlog()  { printf '%s\\n' \"$*\"; }\ninfo() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\nok()   { printf '%s✓ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\nwarn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\nerr()  { printf '%s✗ %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n\n# Resolve the silships figma-cli binary.\n# Order: figma-ds-cli (npm canonical, unambiguous) -> figma-cli (silships repo build only).\n# A bare \"figma\" is NOT ours (that is unic/figma-cli) and is never selected.\nfigma_bin() {\n  if command -v figma-ds-cli >/dev/null 2>&1; then printf 'figma-ds-cli'; return 0; fi","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/_common.sh","text":"#!/usr/bin/env bash\n# Shared helpers for mcp-figma scripts. Source this; do not run directly.\n# WHY: every script must resolve the silships binary the same way, because the\n# npm package literally named \"figma-cli\" is an UNRELATED tool (unic/figma-cli,\n# which installs a bin named \"figma\"). The silships tool is \"figma-ds-cli\".\n\nset -euo pipefail\n\n_c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\nlog()  { printf '%s\\n' \"$*\"; }\ninfo() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\nok()   { printf '%s✓ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\nwarn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\nerr()  { printf '%s✗ %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n\n# Resolve the silships figma-cli binary.\n# Order: figma-ds-cli (npm canonical, unambiguous) -> figma-cli (silships repo build only).\n# A bare \"figma\" is NOT ours (that is unic/figma-cli) and is never selected.\nfigma_bin() {\n  if command -v figma-ds-cli >/dev/null 2>&1; then printf 'figma-ds-cli'; return 0; fi\n  if command -v figma-cli   >/dev/null 2>&1; then printf 'figma-cli';   return 0; fi\n  return 1\n}\n\n# Node major version (echoes integer or empty).\nnode_major() {\n  command -v node >/dev/null 2>&1 || { printf ''; return 0; }\n  node -p 'process.versions.node.split(\".\")[0]' 2>/dev/null || printf ''\n}\n\n# Locate Figma Desktop without launching it.\nfigma_desktop_path() {\n  for p in \"/Applications/Figma.app\" \"$HOME/Applications/Figma.app\"; do\n    [ -d \"$p\" ] && { printf '%s' \"$p\"; return 0; }\n  done\n  return 1\n}\n\n# Is a TCP port listening on localhost? (best-effort, no install)\nport_listening() {\n  local port=\"$1\"\n  if command -v lsof >/dev/null 2>&1; then\n    lsof -nP -iTCP:\"$port\" -sTCP:LISTEN >/dev/null 2>&1 && return 0 || return 1\n  fi\n  return 2  # unknown\n}\n\nDAEMON_TOKEN_FILE=\"$HOME/.figma-ds-cli/.daemon-token\"\nDAEMON_PID_FILE=\"$HOME/.figma-cli-daemon.pid\"\nDAEMON_PORT=3456\nCDP_PORT=9222","lineStart":1,"lineEnd":51,"totalLines":51,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/_common.sh","time":{"start":1781459223833,"end":1781459223839}},"id":"prt_ec73e838d0010KLjxjZa7jlykO","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459224187,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_01_FDhuJyr6F2nbpnWgXGfV4406","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/install.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/install.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # mcp-figma installer: install + verify ONLY. Never connects, never patches Figma.\n3: # Canonical package = figma-ds-cli (silships). NEVER `npm i -g figma-cli` (that is\n4: # unic/figma-cli, an unrelated tool that installs a bin named \"figma\").\n5: \n6: set -euo pipefail\n7: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n8: # shellcheck source=_common.sh\n9: . \"$HERE/_common.sh\"\n10: \n11: SOURCE=\"auto\"           # auto | npm | repo\n12: REPO_URL=\"https://github.com/silships/figma-cli.git\"\n13: INSTALL_ROOT=\"$HOME/.figma-ds-cli/source\"\n14: FORCE=0; SKIP_VERIFY=0; VERBOSE=0\n15: \n16: usage() {\n17:   cat <<EOF\n18: mcp-figma install.sh — install + verify the silships figma-cli (as figma-ds-cli).\n19: \n20: Usage: install.sh [options]\n21:   --source auto|npm|repo   Install source (default: auto = try npm, fall back to repo)\n22:   --repo-url <url>         Git URL for repo install (default: $REPO_URL)\n23:   --install-root <path>    Clone location for repo install (default: $INSTALL_ROOT)\n24:   --force                  Reinstall even if a working binary is present\n25:   --skip-verify            Skip post-install verification\n26:   --verbose                Verbose npm/git output\n27:   --help                   This help\n28: \n29: This script NEVER runs connect, NEVER patches Figma, and NEVER installs the\n30: unrelated npm package named figma-cli. It installs figma-ds-cli (npm) or builds\n31: from the silships repo (which also exposes a figma-cli command).\n32: EOF\n33: }\n34: \n35: while [ $# -gt 0 ]; do\n36:   case \"$1\" in\n37:     --source) SOURCE=\"${2:?}\"; shift 2;;\n38:     --repo-url) REPO_URL=\"${2:?}\"; shift 2;;\n39:     --install-root) INSTALL_ROOT=\"${2:?}\"; shift 2;;\n40:     --force) FORCE=1; shift;;\n41:     --skip-verify) SKIP_VERIFY=1; shift;;\n42:     --verbose) VERBOSE=1; shift;;\n43:     --help|-h) usage; exit 0;;\n44:     *) err \"Unknown option: $1\"; usage; exit 2;;\n45:   esac\n46: done\n47: \n48: npm_q() { [ \"$VERBOSE\" = 1 ] && npm \"$@\" || npm \"$@\" >/dev/null 2>&1; }\n49: \n50: # Full documented surface (safe connect, daemon, extract, most commands) needs >= this.\n51: MIN_FULL_VERSION=\"1.2.0\"\n52: installed_version() { local b; b=\"$(figma_bin)\" 2>/dev/null || { printf ''; return 0; }; \"$b\" --version 2>/dev/null | head -1 | tr -d '[:space:]'; }\n53: # version_lt A B -> true (0) when A < B\n54: version_lt() { [ \"$1\" = \"$2\" ] && return 1; [ \"$(printf '%s\\n%s\\n' \"$1\" \"$2\" | sort -V | head -1)\" = \"$1\" ]; }\n55: \n56: check_prerequisites() {\n57:   log \"== Prerequisites ==\"\n58:   case \"$(uname -s)\" in\n59:     Darwin) ok \"macOS (supported baseline)\";;\n60:     *) warn \"$(uname -s) is unsupported/unverified for figma-cli; macOS is the baseline\";;\n61:   esac\n62:   command -v node >/dev/null 2>&1 || { err \"Node.js not found; install Node >=18\"; exit 1; }\n63:   local nm; nm=\"$(node_major)\"\n64:   if [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null; then ok \"Node $(node -v) (>=18)\"; else err \"Node >=18 required (found $(node -v 2>/dev/null||echo none))\"; exit 1; fi\n65:   command -v npm >/dev/null 2>&1 || { err \"npm not found\"; exit 1; }\n66:   ok \"npm $(npm -v)\"\n67:   if [ \"$SOURCE\" = \"repo\" ]; then command -v git >/dev/null 2>&1 || { err \"git required for --source repo\"; exit 1; }; fi\n68: }\n69: \n70: detect_figma_desktop() {\n71:   log \"== Figma Desktop (not installed by this script) ==\"\n72:   if p=\"$(figma_desktop_path)\"; then ok \"Figma Desktop found: $p\"; else warn \"Figma Desktop not found — required at connect time, not for install\"; fi\n73: }\n74: \n75: check_existing() {\n76:   local b; if b=\"$(figma_bin)\"; then\n77:     ok \"Existing binary: $b ($(\"$b\" --version 2>/dev/null | head -1 || echo '?'))\"\n78:     return 0\n79:   fi\n80:   info \"No silships figma binary on PATH yet.\"\n81:   return 1\n82: }\n83: \n84: install_npm() {\n85:   log \"== npm install (figma-ds-cli) ==\"\n86:   info \"Running: npm install -g figma-ds-cli\"\n87:   npm_q install -g figma-ds-cli\n88: }\n89: \n90: install_repo() {\n91:   log \"== repo install (silships/figma-cli) ==\"\n92:   mkdir -p \"$(dirname \"$INSTALL_ROOT\")\"\n93:   if [ -d \"$INSTALL_ROOT/.git\" ]; then\n94:     info \"Updating existing checkout: $INSTALL_ROOT\"\n95:     git -C \"$INSTALL_ROOT\" pull --ff-only ${VERBOSE:+} >/dev/null 2>&1 || warn \"git pull failed; using existing checkout\"\n96:   else\n97:     info \"Cloning $REPO_URL -> $INSTALL_ROOT (outside this repo; not vendored)\"\n98:     git clone --depth 1 \"$REPO_URL\" \"$INSTALL_ROOT\" >/dev/null 2>&1\n99:   fi\n100:   ( cd \"$INSTALL_ROOT\" && npm_q install && npm_q install -g . )\n101: }\n102: \n103: verify_install() {\n104:   [ \"$SKIP_VERIFY\" = 1 ] && { warn \"Skipping verification (--skip-verify)\"; return 0; }\n105:   log \"== Verify ==\"\n106:   local b; if ! b=\"$(figma_bin)\"; then\n107:     err \"No figma-ds-cli / figma-cli on PATH after install.\"\n108:     err \"Check: npm config get prefix ; ensure its bin dir is on PATH.\"\n109:     err \"Do NOT 'npm i -g figma-cli' (that installs the unrelated unic/figma-cli, bin 'figma').\"\n110:     exit 1\n111:   fi\n112:   ok \"Binary: $b\"\n113:   \"$b\" --version 2>/dev/null | head -1 || warn \"--version produced no output\"\n114:   \"$b\" --help >/dev/null 2>&1 && ok \"--help OK\" || warn \"--help failed\"\n115:   if [ \"$b\" = \"figma-ds-cli\" ]; then ok \"Canonical binary present\"; else warn \"Using 'figma-cli' (silships repo build); 'figma-ds-cli' is the canonical name\"; fi\n116:   local v; v=\"$(installed_version)\"\n117:   if [ -n \"$v\" ] && version_lt \"$v\" \"$MIN_FULL_VERSION\"; then\n118:     warn \"Version $v is STALE/minimal — the documented skill surface (safe connect, daemon, extract, most commands) needs >=$MIN_FULL_VERSION.\"\n119:     warn \"Run: install.sh --source repo   (builds $MIN_FULL_VERSION from silships/figma-cli)\"\n120:   else\n121:     ok \"Version $v (full surface)\"\n122:   fi\n123: }\n124: \n125: report_next_steps() {\n126:   log \"\"\n127:   log \"== Next steps (manual, gated) ==\"\n128:   log \"  1) Open Figma Desktop with a file.\"\n129:   log \"  2) Connect (SAFE, no patch):  $HERE/connect-safe.sh\"\n130:   log \"     or via CLI:                $(figma_bin 2>/dev/null || echo figma-ds-cli) connect --safe\"\n131:   log \"  3) Check daemon:              $HERE/daemon.sh status\"\n132:   log \"  Yolo (patches Figma, gated):  $HERE/connect-yolo.sh --i-understand-this-patches-figma\"\n133:   log \"  Diagnostics (read-only):      $HERE/doctor.sh\"\n134: }\n135: \n136: main() {\n137:   check_prerequisites\n138:   detect_figma_desktop\n139:   if check_existing && [ \"$FORCE\" = 0 ]; then\n140:     ok \"figma-cli already installed; nothing to do (use --force to reinstall).\"\n141:     verify_install; report_next_steps; exit 0\n142:   fi\n143:   case \"$SOURCE\" in\n144:     npm)  install_npm;;\n145:     repo) install_repo;;\n146:     auto)\n147:       install_npm || true\n148:       if ! figma_bin >/dev/null 2>&1; then\n149:         warn \"npm install did not yield a usable binary; trying repo install\"\n150:         install_repo\n151:       else\n152:         v=\"$(installed_version)\"\n153:         if [ -n \"$v\" ] && version_lt \"$v\" \"$MIN_FULL_VERSION\"; then\n154:           warn \"npm figma-ds-cli is $v — stale/minimal (lacks safe connect, daemon, and most commands).\"\n155:           warn \"Upgrading from the silships repo for the full $MIN_FULL_VERSION surface.\"\n156:           install_repo\n157:         fi\n158:       fi\n159:       ;;\n160:     *) err \"Invalid --source: $SOURCE\"; exit 2;;\n161:   esac\n162:   verify_install\n163:   report_next_steps\n164: }\n165: main\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# mcp-figma installer: install + verify ONLY. Never connects, never patches Figma.\n# Canonical package = figma-ds-cli (silships). NEVER `npm i -g figma-cli` (that is\n# unic/figma-cli, an unrelated tool that installs a bin named \"figma\").\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nSOURCE=\"auto\"           # auto | npm | repo\nREPO_URL=\"https://github.com/silships/figma-cli.git\"\nINSTALL_ROOT=\"$HOME/.figma-ds-cli/source\"\nFORCE=0; SKIP_VERIFY=0; VERBOSE=0\n\nusage() {\n  cat <<EOF\nmcp-figma install.sh — install + verify the silships figma-cli (as figma-ds-cli).\n\nUsage: install.sh [options]","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/install.sh","text":"#!/usr/bin/env bash\n# mcp-figma installer: install + verify ONLY. Never connects, never patches Figma.\n# Canonical package = figma-ds-cli (silships). NEVER `npm i -g figma-cli` (that is\n# unic/figma-cli, an unrelated tool that installs a bin named \"figma\").\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nSOURCE=\"auto\"           # auto | npm | repo\nREPO_URL=\"https://github.com/silships/figma-cli.git\"\nINSTALL_ROOT=\"$HOME/.figma-ds-cli/source\"\nFORCE=0; SKIP_VERIFY=0; VERBOSE=0\n\nusage() {\n  cat <<EOF\nmcp-figma install.sh — install + verify the silships figma-cli (as figma-ds-cli).\n\nUsage: install.sh [options]\n  --source auto|npm|repo   Install source (default: auto = try npm, fall back to repo)\n  --repo-url <url>         Git URL for repo install (default: $REPO_URL)\n  --install-root <path>    Clone location for repo install (default: $INSTALL_ROOT)\n  --force                  Reinstall even if a working binary is present\n  --skip-verify            Skip post-install verification\n  --verbose                Verbose npm/git output\n  --help                   This help\n\nThis script NEVER runs connect, NEVER patches Figma, and NEVER installs the\nunrelated npm package named figma-cli. It installs figma-ds-cli (npm) or builds\nfrom the silships repo (which also exposes a figma-cli command).\nEOF\n}\n\nwhile [ $# -gt 0 ]; do\n  case \"$1\" in\n    --source) SOURCE=\"${2:?}\"; shift 2;;\n    --repo-url) REPO_URL=\"${2:?}\"; shift 2;;\n    --install-root) INSTALL_ROOT=\"${2:?}\"; shift 2;;\n    --force) FORCE=1; shift;;\n    --skip-verify) SKIP_VERIFY=1; shift;;\n    --verbose) VERBOSE=1; shift;;\n    --help|-h) usage; exit 0;;\n    *) err \"Unknown option: $1\"; usage; exit 2;;\n  esac\ndone\n\nnpm_q() { [ \"$VERBOSE\" = 1 ] && npm \"$@\" || npm \"$@\" >/dev/null 2>&1; }\n\n# Full documented surface (safe connect, daemon, extract, most commands) needs >= this.\nMIN_FULL_VERSION=\"1.2.0\"\ninstalled_version() { local b; b=\"$(figma_bin)\" 2>/dev/null || { printf ''; return 0; }; \"$b\" --version 2>/dev/null | head -1 | tr -d '[:space:]'; }\n# version_lt A B -> true (0) when A < B\nversion_lt() { [ \"$1\" = \"$2\" ] && return 1; [ \"$(printf '%s\\n%s\\n' \"$1\" \"$2\" | sort -V | head -1)\" = \"$1\" ]; }\n\ncheck_prerequisites() {\n  log \"== Prerequisites ==\"\n  case \"$(uname -s)\" in\n    Darwin) ok \"macOS (supported baseline)\";;\n    *) warn \"$(uname -s) is unsupported/unverified for figma-cli; macOS is the baseline\";;\n  esac\n  command -v node >/dev/null 2>&1 || { err \"Node.js not found; install Node >=18\"; exit 1; }\n  local nm; nm=\"$(node_major)\"\n  if [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null; then ok \"Node $(node -v) (>=18)\"; else err \"Node >=18 required (found $(node -v 2>/dev/null||echo none))\"; exit 1; fi\n  command -v npm >/dev/null 2>&1 || { err \"npm not found\"; exit 1; }\n  ok \"npm $(npm -v)\"\n  if [ \"$SOURCE\" = \"repo\" ]; then command -v git >/dev/null 2>&1 || { err \"git required for --source repo\"; exit 1; }; fi\n}\n\ndetect_figma_desktop() {\n  log \"== Figma Desktop (not installed by this script) ==\"\n  if p=\"$(figma_desktop_path)\"; then ok \"Figma Desktop found: $p\"; else warn \"Figma Desktop not found — required at connect time, not for install\"; fi\n}\n\ncheck_existing() {\n  local b; if b=\"$(figma_bin)\"; then\n    ok \"Existing binary: $b ($(\"$b\" --version 2>/dev/null | head -1 || echo '?'))\"\n    return 0\n  fi\n  info \"No silships figma binary on PATH yet.\"\n  return 1\n}\n\ninstall_npm() {\n  log \"== npm install (figma-ds-cli) ==\"\n  info \"Running: npm install -g figma-ds-cli\"\n  npm_q install -g figma-ds-cli\n}\n\ninstall_repo() {\n  log \"== repo install (silships/figma-cli) ==\"\n  mkdir -p \"$(dirname \"$INSTALL_ROOT\")\"\n  if [ -d \"$INSTALL_ROOT/.git\" ]; then\n    info \"Updating existing checkout: $INSTALL_ROOT\"\n    git -C \"$INSTALL_ROOT\" pull --ff-only ${VERBOSE:+} >/dev/null 2>&1 || warn \"git pull failed; using existing checkout\"\n  else\n    info \"Cloning $REPO_URL -> $INSTALL_ROOT (outside this repo; not vendored)\"\n    git clone --depth 1 \"$REPO_URL\" \"$INSTALL_ROOT\" >/dev/null 2>&1\n  fi\n  ( cd \"$INSTALL_ROOT\" && npm_q install && npm_q install -g . )\n}\n\nverify_install() {\n  [ \"$SKIP_VERIFY\" = 1 ] && { warn \"Skipping verification (--skip-verify)\"; return 0; }\n  log \"== Verify ==\"\n  local b; if ! b=\"$(figma_bin)\"; then\n    err \"No figma-ds-cli / figma-cli on PATH after install.\"\n    err \"Check: npm config get prefix ; ensure its bin dir is on PATH.\"\n    err \"Do NOT 'npm i -g figma-cli' (that installs the unrelated unic/figma-cli, bin 'figma').\"\n    exit 1\n  fi\n  ok \"Binary: $b\"\n  \"$b\" --version 2>/dev/null | head -1 || warn \"--version produced no output\"\n  \"$b\" --help >/dev/null 2>&1 && ok \"--help OK\" || warn \"--help failed\"\n  if [ \"$b\" = \"figma-ds-cli\" ]; then ok \"Canonical binary present\"; else warn \"Using 'figma-cli' (silships repo build); 'figma-ds-cli' is the canonical name\"; fi\n  local v; v=\"$(installed_version)\"\n  if [ -n \"$v\" ] && version_lt \"$v\" \"$MIN_FULL_VERSION\"; then\n    warn \"Version $v is STALE/minimal — the documented skill surface (safe connect, daemon, extract, most commands) needs >=$MIN_FULL_VERSION.\"\n    warn \"Run: install.sh --source repo   (builds $MIN_FULL_VERSION from silships/figma-cli)\"\n  else\n    ok \"Version $v (full surface)\"\n  fi\n}\n\nreport_next_steps() {\n  log \"\"\n  log \"== Next steps (manual, gated) ==\"\n  log \"  1) Open Figma Desktop with a file.\"\n  log \"  2) Connect (SAFE, no patch):  $HERE/connect-safe.sh\"\n  log \"     or via CLI:                $(figma_bin 2>/dev/null || echo figma-ds-cli) connect --safe\"\n  log \"  3) Check daemon:              $HERE/daemon.sh status\"\n  log \"  Yolo (patches Figma, gated):  $HERE/connect-yolo.sh --i-understand-this-patches-figma\"\n  log \"  Diagnostics (read-only):      $HERE/doctor.sh\"\n}\n\nmain() {\n  check_prerequisites\n  detect_figma_desktop\n  if check_existing && [ \"$FORCE\" = 0 ]; then\n    ok \"figma-cli already installed; nothing to do (use --force to reinstall).\"\n    verify_install; report_next_steps; exit 0\n  fi\n  case \"$SOURCE\" in\n    npm)  install_npm;;\n    repo) install_repo;;\n    auto)\n      install_npm || true\n      if ! figma_bin >/dev/null 2>&1; then\n        warn \"npm install did not yield a usable binary; trying repo install\"\n        install_repo\n      else\n        v=\"$(installed_version)\"\n        if [ -n \"$v\" ] && version_lt \"$v\" \"$MIN_FULL_VERSION\"; then\n          warn \"npm figma-ds-cli is $v — stale/minimal (lacks safe connect, daemon, and most commands).\"\n          warn \"Upgrading from the silships repo for the full $MIN_FULL_VERSION surface.\"\n          install_repo\n        fi\n      fi\n      ;;\n    *) err \"Invalid --source: $SOURCE\"; exit 2;;\n  esac\n  verify_install\n  report_next_steps\n}\nmain","lineStart":1,"lineEnd":165,"totalLines":165,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/install.sh","time":{"start":1781459224178,"end":1781459224186}},"id":"prt_ec73e852f001je2wj6Oc4XDFgt","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459224537,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_02_aONlIoEuTIL6i3YMLd7c9283","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/daemon.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/daemon.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Thin wrapper over `figma-ds-cli daemon <verb>`. Read verbs are safe; start/stop/\n3: # restart/reconnect change daemon state (not the Figma document).\n4: \n5: set -euo pipefail\n6: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7: # shellcheck source=_common.sh\n8: . \"$HERE/_common.sh\"\n9: \n10: verb=\"${1:-status}\"\n11: case \"$verb\" in\n12:   status|diagnose|start|stop|restart|reconnect) ;;\n13:   -h|--help|help) echo \"Usage: daemon.sh {status|diagnose|start|stop|restart|reconnect}\"; exit 0;;\n14:   *) err \"Unknown daemon verb: $verb\"; echo \"Use: status|diagnose|start|stop|restart|reconnect\" >&2; exit 2;;\n15: esac\n16: \n17: b=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first\"; exit 1; }\n18: info \"Running: $b daemon $verb\"\n19: \"$b\" daemon \"$verb\"\n\n(End of file - total 19 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Thin wrapper over `figma-ds-cli daemon <verb>`. Read verbs are safe; start/stop/\n# restart/reconnect change daemon state (not the Figma document).\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nverb=\"${1:-status}\"\ncase \"$verb\" in\n  status|diagnose|start|stop|restart|reconnect) ;;\n  -h|--help|help) echo \"Usage: daemon.sh {status|diagnose|start|stop|restart|reconnect}\"; exit 0;;\n  *) err \"Unknown daemon verb: $verb\"; echo \"Use: status|diagnose|start|stop|restart|reconnect\" >&2; exit 2;;\nesac\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first\"; exit 1; }\ninfo \"Running: $b daemon $verb\"\n\"$b\" daemon \"$verb\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/daemon.sh","text":"#!/usr/bin/env bash\n# Thin wrapper over `figma-ds-cli daemon <verb>`. Read verbs are safe; start/stop/\n# restart/reconnect change daemon state (not the Figma document).\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nverb=\"${1:-status}\"\ncase \"$verb\" in\n  status|diagnose|start|stop|restart|reconnect) ;;\n  -h|--help|help) echo \"Usage: daemon.sh {status|diagnose|start|stop|restart|reconnect}\"; exit 0;;\n  *) err \"Unknown daemon verb: $verb\"; echo \"Use: status|diagnose|start|stop|restart|reconnect\" >&2; exit 2;;\nesac\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first\"; exit 1; }\ninfo \"Running: $b daemon $verb\"\n\"$b\" daemon \"$verb\"","lineStart":1,"lineEnd":19,"totalLines":19,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/daemon.sh","time":{"start":1781459224533,"end":1781459224536}},"id":"prt_ec73e86b1001j1zaEOsls7i3bK","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459224907,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_03_SKqyranGO3s5nfHmWJiE9839","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-safe.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-safe.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Guided SAFE connect (FigCli plugin bridge). Never patches Figma Desktop.\n3: \n4: set -euo pipefail\n5: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n6: # shellcheck source=_common.sh\n7: . \"$HERE/_common.sh\"\n8: \n9: b=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first (do NOT 'npm i -g figma-cli')\"; exit 1; }\n10: figma_desktop_path >/dev/null || warn \"Figma Desktop not found; safe connect needs it open with a file.\"\n11: \n12: cat <<EOF\n13: == SAFE connect (no patch) ==\n14: Safe mode uses the FigCli plugin instead of patching Figma Desktop.\n15: Before continuing, in Figma Desktop:\n16:   1) Open the target Figma file.\n17:   2) One-time: import the FigCli plugin manifest (plugin/manifest.json from the figma-cli install).\n18:   3) Open: Plugins -> Development -> FigCli  (keep it open during the session).\n19: EOF\n20: printf 'Proceed with safe connect now? [y/N] '\n21: read -r ans\n22: case \"$ans\" in y|Y|yes|YES) ;; *) info \"Aborted.\"; exit 0;; esac\n23: \n24: info \"Running: $b connect --safe\"\n25: \"$b\" connect --safe\n26: info \"Daemon status:\"; \"$b\" daemon status || warn \"daemon status failed; try: $HERE/daemon.sh diagnose\"\n\n(End of file - total 26 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Guided SAFE connect (FigCli plugin bridge). Never patches Figma Desktop.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first (do NOT 'npm i -g figma-cli')\"; exit 1; }\nfigma_desktop_path >/dev/null || warn \"Figma Desktop not found; safe connect needs it open with a file.\"\n\ncat <<EOF\n== SAFE connect (no patch) ==\nSafe mode uses the FigCli plugin instead of patching Figma Desktop.\nBefore continuing, in Figma Desktop:\n  1) Open the target Figma file.\n  2) One-time: import the FigCli plugin manifest (plugin/manifest.json from the figma-cli install).\n  3) Open: Plugins -> Development -> FigCli  (keep it open during the session).\nEOF\nprintf 'Proceed with safe connect now? [y/N] '","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-safe.sh","text":"#!/usr/bin/env bash\n# Guided SAFE connect (FigCli plugin bridge). Never patches Figma Desktop.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first (do NOT 'npm i -g figma-cli')\"; exit 1; }\nfigma_desktop_path >/dev/null || warn \"Figma Desktop not found; safe connect needs it open with a file.\"\n\ncat <<EOF\n== SAFE connect (no patch) ==\nSafe mode uses the FigCli plugin instead of patching Figma Desktop.\nBefore continuing, in Figma Desktop:\n  1) Open the target Figma file.\n  2) One-time: import the FigCli plugin manifest (plugin/manifest.json from the figma-cli install).\n  3) Open: Plugins -> Development -> FigCli  (keep it open during the session).\nEOF\nprintf 'Proceed with safe connect now? [y/N] '\nread -r ans\ncase \"$ans\" in y|Y|yes|YES) ;; *) info \"Aborted.\"; exit 0;; esac\n\ninfo \"Running: $b connect --safe\"\n\"$b\" connect --safe\ninfo \"Daemon status:\"; \"$b\" daemon status || warn \"daemon status failed; try: $HERE/daemon.sh diagnose\"","lineStart":1,"lineEnd":26,"totalLines":26,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/connect-safe.sh","time":{"start":1781459224903,"end":1781459224906}},"id":"prt_ec73e880a001c4dr413LAomyMW","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459225283,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_04_XalZ69CGRR0l4M4gWWKx2112","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-yolo.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-yolo.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # YOLO connect — PATCHES Figma Desktop (app.asar) and restarts it with CDP on 9222.\n3: # Gated behind an explicit consent flag. Rollback: unpatch.sh (figma-ds-cli unpatch).\n4: \n5: set -euo pipefail\n6: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7: # shellcheck source=_common.sh\n8: . \"$HERE/_common.sh\"\n9: \n10: CONSENT=0\n11: [ \"${1:-}\" = \"--i-understand-this-patches-figma\" ] && CONSENT=1\n12: \n13: if [ \"$CONSENT\" != 1 ]; then\n14:   cat >&2 <<EOF\n15: ${_c_ylw}REFUSED: yolo connect patches Figma Desktop.${_c_rst}\n16: \n17: Effect:  modifies Figma's app.asar (remote-debugging switch), codesigns the app\n18:          on macOS, restarts Figma, and exposes CDP on 127.0.0.1:$CDP_PORT.\n19: Risks:   may require Full Disk Access / admin; a Figma update can invalidate the\n20:          patch and require re-running connect.\n21: Rollback: $HERE/unpatch.sh   (runs: figma-ds-cli unpatch)\n22: \n23: Prefer SAFE mode: $HERE/connect-safe.sh\n24: To proceed anyway, re-run with: $0 --i-understand-this-patches-figma\n25: EOF\n26:   exit 2\n27: fi\n28: \n29: b=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first\"; exit 1; }\n30: figma_desktop_path >/dev/null || { err \"Figma Desktop not found; cannot patch.\"; exit 1; }\n31: \n32: warn \"Consent received. Patching Figma Desktop and starting yolo connect.\"\n33: info \"Running: $b connect\"\n34: \"$b\" connect\n35: info \"Daemon status:\"; \"$b\" daemon status || warn \"daemon status failed; try: $HERE/daemon.sh diagnose\"\n36: info \"Rollback any time with: $HERE/unpatch.sh\"\n\n(End of file - total 36 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# YOLO connect — PATCHES Figma Desktop (app.asar) and restarts it with CDP on 9222.\n# Gated behind an explicit consent flag. Rollback: unpatch.sh (figma-ds-cli unpatch).\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nCONSENT=0\n[ \"${1:-}\" = \"--i-understand-this-patches-figma\" ] && CONSENT=1\n\nif [ \"$CONSENT\" != 1 ]; then\n  cat >&2 <<EOF\n${_c_ylw}REFUSED: yolo connect patches Figma Desktop.${_c_rst}\n\nEffect:  modifies Figma's app.asar (remote-debugging switch), codesigns the app\n         on macOS, restarts Figma, and exposes CDP on 127.0.0.1:$CDP_PORT.\nRisks:   may require Full Disk Access / admin; a Figma update can invalidate the\n         patch and require re-running connect.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/connect-yolo.sh","text":"#!/usr/bin/env bash\n# YOLO connect — PATCHES Figma Desktop (app.asar) and restarts it with CDP on 9222.\n# Gated behind an explicit consent flag. Rollback: unpatch.sh (figma-ds-cli unpatch).\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nCONSENT=0\n[ \"${1:-}\" = \"--i-understand-this-patches-figma\" ] && CONSENT=1\n\nif [ \"$CONSENT\" != 1 ]; then\n  cat >&2 <<EOF\n${_c_ylw}REFUSED: yolo connect patches Figma Desktop.${_c_rst}\n\nEffect:  modifies Figma's app.asar (remote-debugging switch), codesigns the app\n         on macOS, restarts Figma, and exposes CDP on 127.0.0.1:$CDP_PORT.\nRisks:   may require Full Disk Access / admin; a Figma update can invalidate the\n         patch and require re-running connect.\nRollback: $HERE/unpatch.sh   (runs: figma-ds-cli unpatch)\n\nPrefer SAFE mode: $HERE/connect-safe.sh\nTo proceed anyway, re-run with: $0 --i-understand-this-patches-figma\nEOF\n  exit 2\nfi\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH — run install.sh first\"; exit 1; }\nfigma_desktop_path >/dev/null || { err \"Figma Desktop not found; cannot patch.\"; exit 1; }\n\nwarn \"Consent received. Patching Figma Desktop and starting yolo connect.\"\ninfo \"Running: $b connect\"\n\"$b\" connect\ninfo \"Daemon status:\"; \"$b\" daemon status || warn \"daemon status failed; try: $HERE/daemon.sh diagnose\"\ninfo \"Rollback any time with: $HERE/unpatch.sh\"","lineStart":1,"lineEnd":36,"totalLines":36,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/connect-yolo.sh","time":{"start":1781459225280,"end":1781459225282}},"id":"prt_ec73e8989001B8GzWEzPggMAjP","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459225632,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_05_P6KjjRjpShFuRWVj7Emt3421","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/unpatch.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/unpatch.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Roll back the yolo patch: restore Figma Desktop's original app.asar.\n3: \n4: set -euo pipefail\n5: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n6: # shellcheck source=_common.sh\n7: . \"$HERE/_common.sh\"\n8: \n9: b=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH\"; exit 1; }\n10: info \"Running: $b unpatch  (restores Figma Desktop to its original state)\"\n11: \"$b\" unpatch\n12: ok \"Unpatch complete. If Figma still misbehaves, update/reinstall Figma Desktop, then reconnect with connect-safe.sh.\"\n\n(End of file - total 12 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Roll back the yolo patch: restore Figma Desktop's original app.asar.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH\"; exit 1; }\ninfo \"Running: $b unpatch  (restores Figma Desktop to its original state)\"\n\"$b\" unpatch\nok \"Unpatch complete. If Figma still misbehaves, update/reinstall Figma Desktop, then reconnect with connect-safe.sh.\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/unpatch.sh","text":"#!/usr/bin/env bash\n# Roll back the yolo patch: restore Figma Desktop's original app.asar.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nb=\"$(figma_bin)\" || { err \"No figma-ds-cli on PATH\"; exit 1; }\ninfo \"Running: $b unpatch  (restores Figma Desktop to its original state)\"\n\"$b\" unpatch\nok \"Unpatch complete. If Figma still misbehaves, update/reinstall Figma Desktop, then reconnect with connect-safe.sh.\"","lineStart":1,"lineEnd":12,"totalLines":12,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/unpatch.sh","time":{"start":1781459225624,"end":1781459225631}},"id":"prt_ec73e8ae1001ZTeaiklv3CX4cX","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459226015,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_06_Q5EUN7JACPngnOlpDEK53992","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # mcp-figma doctor: REPORT-ONLY diagnostics. Changes nothing, installs nothing,\n3: # never exposes the daemon token, never connects or patches.\n4: \n5: set -euo pipefail\n6: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7: # shellcheck source=_common.sh\n8: . \"$HERE/_common.sh\"\n9: \n10: log \"== mcp-figma doctor (read-only) ==\"\n11: \n12: # Platform / runtime\n13: case \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\n14: if command -v node >/dev/null 2>&1; then\n15:   nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null||echo none) (<18)\"\n16: else warn \"Node not found\"; fi\n17: command -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n18: \n19: # Binary identity (the collision check)\n20: log \"-- figma binary --\"\n21: if command -v figma-ds-cli >/dev/null 2>&1; then ok \"figma-ds-cli: $(command -v figma-ds-cli) ($(figma-ds-cli --version 2>/dev/null|head -1||echo '?'))\"; else info \"figma-ds-cli: not on PATH\"; fi\n22: if command -v figma-cli >/dev/null 2>&1; then ok \"figma-cli: $(command -v figma-cli) (silships repo build, if from upstream)\"; else info \"figma-cli: not on PATH (expected unless installed from the silships repo)\"; fi\n23: if command -v figma >/dev/null 2>&1; then warn \"a 'figma' command is on PATH — this is likely the UNRELATED unic/figma-cli, NOT the silships tool\"; fi\n24: if b=\"$(figma_bin)\"; then ok \"Resolved skill binary: $b\"; else err \"No silships figma binary resolved — run install.sh (do NOT 'npm i -g figma-cli')\"; fi\n25: \n26: # Figma Desktop\n27: log \"-- Figma Desktop --\"\n28: if p=\"$(figma_desktop_path)\"; then ok \"Found: $p\"; else warn \"Not found in /Applications or ~/Applications\"; fi\n29: \n30: # Daemon\n31: log \"-- Daemon --\"\n32: if [ -f \"$DAEMON_TOKEN_FILE\" ]; then ok \"Token file present: $DAEMON_TOKEN_FILE (contents NOT shown)\"; else info \"No token file ($DAEMON_TOKEN_FILE) — daemon not initialized yet\"; fi\n33: if [ -f \"$DAEMON_PID_FILE\" ]; then info \"PID file: $DAEMON_PID_FILE ($(cat \"$DAEMON_PID_FILE\" 2>/dev/null||echo '?'))\"; else info \"No PID file ($DAEMON_PID_FILE)\"; fi\n34: case \"$(port_listening \"$DAEMON_PORT\"; echo $?)\" in\n35:   0) ok \"Daemon port $DAEMON_PORT: LISTENING\";;\n36:   1) info \"Daemon port $DAEMON_PORT: not listening\";;\n37:   *) info \"Daemon port $DAEMON_PORT: unknown (lsof unavailable)\";;\n38: esac\n39: case \"$(port_listening \"$CDP_PORT\"; echo $?)\" in\n40:   0) info \"CDP port $CDP_PORT: LISTENING (yolo/remote-debugging active or another CDP client)\";;\n41:   1) info \"CDP port $CDP_PORT: not listening\";;\n42:   *) info \"CDP port $CDP_PORT: unknown\";;\n43: esac\n44: \n45: # Optional MCP (Code Mode, Framelink figma manual)\n46: log \"-- Optional Figma MCP via Code Mode (Framelink) --\"\n47: UTCP=\"$HERE/../../../../.utcp_config.json\"\n48: if [ -f \"$UTCP\" ]; then\n49:   if grep -q '\"figma\"' \"$UTCP\" 2>/dev/null; then ok \"Code Mode 'figma' manual registered in .utcp_config.json\"; else info \"No 'figma' manual in .utcp_config.json\"; fi\n50: else info \".utcp_config.json not found at expected repo root (optional MCP is opt-in)\"; fi\n51: info \"Token must be in .env as: figma_FIGMA_API_KEY=figd_... (Code Mode prefixes the manual name)\"\n52: \n53: log \"\"\n54: log \"Doctor is read-only. To connect: connect-safe.sh (safe) or connect-yolo.sh (gated patch).\"\n\n(End of file - total 54 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# mcp-figma doctor: REPORT-ONLY diagnostics. Changes nothing, installs nothing,\n# never exposes the daemon token, never connects or patches.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nlog \"== mcp-figma doctor (read-only) ==\"\n\n# Platform / runtime\ncase \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\nif command -v node >/dev/null 2>&1; then\n  nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null||echo none) (<18)\"\nelse warn \"Node not found\"; fi\ncommand -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n\n# Binary identity (the collision check)\nlog \"-- figma binary --\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh","text":"#!/usr/bin/env bash\n# mcp-figma doctor: REPORT-ONLY diagnostics. Changes nothing, installs nothing,\n# never exposes the daemon token, never connects or patches.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nlog \"== mcp-figma doctor (read-only) ==\"\n\n# Platform / runtime\ncase \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\nif command -v node >/dev/null 2>&1; then\n  nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null||echo none) (<18)\"\nelse warn \"Node not found\"; fi\ncommand -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n\n# Binary identity (the collision check)\nlog \"-- figma binary --\"\nif command -v figma-ds-cli >/dev/null 2>&1; then ok \"figma-ds-cli: $(command -v figma-ds-cli) ($(figma-ds-cli --version 2>/dev/null|head -1||echo '?'))\"; else info \"figma-ds-cli: not on PATH\"; fi\nif command -v figma-cli >/dev/null 2>&1; then ok \"figma-cli: $(command -v figma-cli) (silships repo build, if from upstream)\"; else info \"figma-cli: not on PATH (expected unless installed from the silships repo)\"; fi\nif command -v figma >/dev/null 2>&1; then warn \"a 'figma' command is on PATH — this is likely the UNRELATED unic/figma-cli, NOT the silships tool\"; fi\nif b=\"$(figma_bin)\"; then ok \"Resolved skill binary: $b\"; else err \"No silships figma binary resolved — run install.sh (do NOT 'npm i -g figma-cli')\"; fi\n\n# Figma Desktop\nlog \"-- Figma Desktop --\"\nif p=\"$(figma_desktop_path)\"; then ok \"Found: $p\"; else warn \"Not found in /Applications or ~/Applications\"; fi\n\n# Daemon\nlog \"-- Daemon --\"\nif [ -f \"$DAEMON_TOKEN_FILE\" ]; then ok \"Token file present: $DAEMON_TOKEN_FILE (contents NOT shown)\"; else info \"No token file ($DAEMON_TOKEN_FILE) — daemon not initialized yet\"; fi\nif [ -f \"$DAEMON_PID_FILE\" ]; then info \"PID file: $DAEMON_PID_FILE ($(cat \"$DAEMON_PID_FILE\" 2>/dev/null||echo '?'))\"; else info \"No PID file ($DAEMON_PID_FILE)\"; fi\ncase \"$(port_listening \"$DAEMON_PORT\"; echo $?)\" in\n  0) ok \"Daemon port $DAEMON_PORT: LISTENING\";;\n  1) info \"Daemon port $DAEMON_PORT: not listening\";;\n  *) info \"Daemon port $DAEMON_PORT: unknown (lsof unavailable)\";;\nesac\ncase \"$(port_listening \"$CDP_PORT\"; echo $?)\" in\n  0) info \"CDP port $CDP_PORT: LISTENING (yolo/remote-debugging active or another CDP client)\";;\n  1) info \"CDP port $CDP_PORT: not listening\";;\n  *) info \"CDP port $CDP_PORT: unknown\";;\nesac\n\n# Optional MCP (Code Mode, Framelink figma manual)\nlog \"-- Optional Figma MCP via Code Mode (Framelink) --\"\nUTCP=\"$HERE/../../../../.utcp_config.json\"\nif [ -f \"$UTCP\" ]; then\n  if grep -q '\"figma\"' \"$UTCP\" 2>/dev/null; then ok \"Code Mode 'figma' manual registered in .utcp_config.json\"; else info \"No 'figma' manual in .utcp_config.json\"; fi\nelse info \".utcp_config.json not found at expected repo root (optional MCP is opt-in)\"; fi\ninfo \"Token must be in .env as: figma_FIGMA_API_KEY=figd_... (Code Mode prefixes the manual name)\"\n\nlog \"\"\nlog \"Doctor is read-only. To connect: connect-safe.sh (safe) or connect-yolo.sh (gated patch).\"","lineStart":1,"lineEnd":54,"totalLines":54,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/doctor.sh","time":{"start":1781459226010,"end":1781459226014}},"id":"prt_ec73e8c82001b2Y1ULCKQ3af6f","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
{"type":"tool_use","timestamp":1781459226406,"sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","part":{"type":"tool","tool":"read","callID":"call_07_K2kmjkmpJqrykaC2i7kK1348","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/print-utcp-snippets.sh"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/print-utcp-snippets.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Print the OPTIONAL Code Mode wiring for the Framelink figma MCP manual.\n3: # PRINTS ONLY — never edits .utcp_config.json or .env. The official Figma Dev Mode\n4: # MCP is out of scope for this skill release.\n5: \n6: set -euo pipefail\n7: \n8: cat <<'EOF'\n9: == Optional Figma MCP via Code Mode (Framelink) — print only ==\n10: \n11: This project already ships a Code Mode manual named \"figma\" (figma-developer-mcp).\n12: If it is missing from .utcp_config.json, add this entry under manual_call_templates[]:\n13: \n14: {\n15:   \"name\": \"figma\",\n16:   \"call_template_type\": \"mcp\",\n17:   \"config\": {\n18:     \"mcpServers\": {\n19:       \"figma\": {\n20:         \"transport\": \"stdio\",\n21:         \"command\": \"npx\",\n22:         \"args\": [\"-y\", \"figma-developer-mcp@latest\", \"--stdio\"],\n23:         \"env\": { \"FIGMA_API_KEY\": \"${FIGMA_API_KEY}\" }\n24:       }\n25:     }\n26:   }\n27: }\n28: \n29: Then add the token to .env (Code Mode PREFIXES the variable with the manual name):\n30: \n31:   figma_FIGMA_API_KEY=figd_your_token_here\n32: \n33: Get a token: Figma -> Settings -> Security -> Personal access tokens.\n34: \n35: Verify in Code Mode (do not guess tool names):\n36:   list_tools()                       # confirm a \"figma.*\" manual appears\n37:   search_tools({ task_description: \"figma design file\", limit: 10 })\n38:   tool_info({ tool_name: \"figma.figma_<tool>\" })\n39: \n40: Call pattern (naming = {manual}.{manual}_{tool}):\n41:   call_tool_chain({ code: `\n42:     const data = await figma.figma_get_file({ /* args per tool_info */ });\n43:     return { data };\n44:   ` })\n45: \n46: This script changed nothing. Edit .utcp_config.json / .env yourself after review.\n47: EOF\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Print the OPTIONAL Code Mode wiring for the Framelink figma MCP manual.\n# PRINTS ONLY — never edits .utcp_config.json or .env. The official Figma Dev Mode\n# MCP is out of scope for this skill release.\n\nset -euo pipefail\n\ncat <<'EOF'\n== Optional Figma MCP via Code Mode (Framelink) — print only ==\n\nThis project already ships a Code Mode manual named \"figma\" (figma-developer-mcp).\nIf it is missing from .utcp_config.json, add this entry under manual_call_templates[]:\n\n{\n  \"name\": \"figma\",\n  \"call_template_type\": \"mcp\",\n  \"config\": {\n    \"mcpServers\": {\n      \"figma\": {\n        \"transport\": \"stdio\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/print-utcp-snippets.sh","text":"#!/usr/bin/env bash\n# Print the OPTIONAL Code Mode wiring for the Framelink figma MCP manual.\n# PRINTS ONLY — never edits .utcp_config.json or .env. The official Figma Dev Mode\n# MCP is out of scope for this skill release.\n\nset -euo pipefail\n\ncat <<'EOF'\n== Optional Figma MCP via Code Mode (Framelink) — print only ==\n\nThis project already ships a Code Mode manual named \"figma\" (figma-developer-mcp).\nIf it is missing from .utcp_config.json, add this entry under manual_call_templates[]:\n\n{\n  \"name\": \"figma\",\n  \"call_template_type\": \"mcp\",\n  \"config\": {\n    \"mcpServers\": {\n      \"figma\": {\n        \"transport\": \"stdio\",\n        \"command\": \"npx\",\n        \"args\": [\"-y\", \"figma-developer-mcp@latest\", \"--stdio\"],\n        \"env\": { \"FIGMA_API_KEY\": \"${FIGMA_API_KEY}\" }\n      }\n    }\n  }\n}\n\nThen add the token to .env (Code Mode PREFIXES the variable with the manual name):\n\n  figma_FIGMA_API_KEY=figd_your_token_here\n\nGet a token: Figma -> Settings -> Security -> Personal access tokens.\n\nVerify in Code Mode (do not guess tool names):\n  list_tools()                       # confirm a \"figma.*\" manual appears\n  search_tools({ task_description: \"figma design file\", limit: 10 })\n  tool_info({ tool_name: \"figma.figma_<tool>\" })\n\nCall pattern (naming = {manual}.{manual}_{tool}):\n  call_tool_chain({ code: `\n    const data = await figma.figma_get_file({ /* args per tool_info */ });\n    return { data };\n  ` })\n\nThis script changed nothing. Edit .utcp_config.json / .env yourself after review.\nEOF","lineStart":1,"lineEnd":47,"totalLines":47,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/print-utcp-snippets.sh","time":{"start":1781459226402,"end":1781459226405}},"id":"prt_ec73e8de0001m9t8d6zEHimeqD","sessionID":"ses_138c2bafbfferH0GdGNnzVMgNJ","messageID":"msg_ec73e7a7a0012nau0MMCpR2P5z"}}
