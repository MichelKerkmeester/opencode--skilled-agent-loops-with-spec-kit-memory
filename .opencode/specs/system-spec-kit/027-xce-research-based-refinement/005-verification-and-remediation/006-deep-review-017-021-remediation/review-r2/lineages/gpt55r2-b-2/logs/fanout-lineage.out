ne 247:         tombstoned_at,\n\n  Line 254:     const tombstonedAt = new Date().toISOString();\n\n  Line 260:         tombstonedAt,\n\n  Line 265:       tombstoneIds.push(Number(insertResult.lastInsertRowid));\n\n  Line 272:       tombstoned: tombstoneIds.length,\n\n  Line 275:       tombstoneIds,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edge-tombstones.vitest.ts:\n  Line 17: const SPEC_FOLDER = 'specs/tombstone-fixture';\n\n  Line 18: const SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\n  Line 24: function tombstones(db: Database.Database): Array<Record<string, any>> {\n\n  Line 26:     SELECT * FROM causal_edge_tombstones ORDER BY id ASC\n\n  Line 35:   const row = db.prepare('SELECT deleted_at FROM memory_index WHERE id = ?').get(id) as { deleted_at: string | null };\n\n  Line 36:   return row.deleted_at;\n\n  Line 39: describe('causal edge tombstones', () => {\n\n  Line 71:     expect(tombstones(db)).toHaveLength(1);\n\n  Line 74:   it('tombstones incoming and outgoing edges before single memory delete', async () => {\n\n  Line 101:     const rows = tombstones(db);\n\n  Line 119:   it('tombstones each removed active edge during bulk delete', async () => {\n\n  Line 136:     expect(tombstones(db)).toHaveLength(2);\n\n  Line 139:   it('preserves the first tombstone timestamp on repeated single delete', async () => {\n\n  Line 161:   it('preserves the first tombstone timestamp on repeated bulk delete', async () => {\n\n  Line 218:     const [row] = tombstones(db);\n\n  Line 232:   it('reports orphan edges before confirmed health repair and tombstones on repair', async () => {\n\n  Line 251:     expect(tombstones(db)).toHaveLength(0);\n\n  Line 260:     expect(repaired.data.causalEdges.tombstoned).toBe(1);\n\n  Line 262:     const [row] = tombstones(db);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts:\n  Line 200: // Counter lives in causal-generation.ts so the tombstone sweep (which this\n\n  Line 928: function cleanupOrphanedEdges(): { deleted: number; tombstoned: number; edgeIds: number[] } {\n\n  Line 929:   if (!db) return { deleted: 0, tombstoned: 0, edgeIds: [] };\n\n  Line 934:         return { deleted: 0, tombstoned: 0, edgeIds: [] };\n\n  Line 953:     return { deleted: result.deleted, tombstoned: result.tombstoned, edgeIds: result.edgeIds };\n\n  Line 957:     return { deleted: 0, tombstoned: 0, edgeIds: [] };\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/release-cleanup-new-surfaces-stress.vitest.ts:\n  Line 53:   'SPECKIT_SOFT_DELETE_TOMBSTONES',\n\n  Line 221:           'deleted_at',\n\n  Line 230:         expect(indexSql(database, 'idx_memory_active_recall')).toContain('WHERE deleted_at IS NULL');\n\n  Line 231:         expect(indexSql(database, 'idx_memory_purgeable_retention')).toContain('WHERE deleted_at IS NOT NULL');\n\n  Line 278:   it('keeps hard delete default behavior and preserves first tombstone under repeated gated delete', async () => {\n\n  Line 281:       delete process.env.SPECKIT_SOFT_DELETE_TOMBSTONES;\n\n  Line 292:       process.env.SPECKIT_SOFT_DELETE_TOMBSTONES = 'true';\n\n  Line 305:         SELECT deleted_at, COUNT(*) AS count\n\n  Line 307:         GROUP BY deleted_at\n\n  Line 308:       `).all() as Array<{ deleted_at: string | null; count: number }>;\n\n  Line 309:       expect(rows).toEqual([{ deleted_at: '2026-06-10T00:00:00.000Z', count: 40 }]);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/metadata-edge-promoter-stress.vitest.ts:\n  Line 148: function tombstoneCount(database: Database.Database): number {\n\n  Line 151:     FROM causal_edge_tombstones\n\n  Line 259:   it('tombstones stale generated edges at volume while preserving protected edges', () => {\n\n  Line 278:     expect(tombstoneCount(db)).toBe(expectedStaleEdges);\n\n  Line 308:       expect(tombstoneCount(db)).toBe(totalTombstones);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-generation.ts:\n  Line 7: // its own module because both the edge store and the tombstone sweep must\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts:\n  Line 82:   tombstoneState: {\n\n  Line 134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n\n  Line 142:   const hasDeletedAt = presentColumns.has('deleted_at');\n\n  Line 147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n\n  Line 148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n\n  Line 170:       ${tombstonePredicate}\n\n  Line 207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n\n  Line 208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n\n  Line 230:       ${tombstonePredicate}\n\n  Line 254: ): MemoryRetentionSweepResult['tombstoneState'] {\n\n  Line 259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n\n  Line 424:       tombstoneState: {\n\n  Line 458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n\n  Line 486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n\n  Line 645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-retention-sweep.vitest.ts:\n  Line 14: const SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\n  Line 115:   it('reaps expired active rows by default even when deleted_at is present', () => {\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"deleted_at|SPECKIT_SOFT_DELETE_TOMBSTONES|soft delete|tombstone","time":{"start":1781761607103,"end":1781761607118}},"metadata":{"openai":{"itemId":"fc_0aa40f593c9423f6016a338646b86c8191b8afe8bcf0918995"}},"id":"prt_ed9448441001RjXmmaQNg6GeSI","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed9446a1f001wAwgJpqLgzSINo"}}
