eration},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  Line 267:           action: \"Archive the current research packet under the root-level research_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n\n  Line 271:             parent_session_id: \"{prior_session_id}\"\n\n  Line 273:           append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  Line 307:           lineage.sessionId: \"{AUTO_SESSION_ID}\"\n\n  Line 428:           const sessionId = String(config.lineage?.sessionId ?? '{AUTO_SESSION_ID}');\n\n  Line 437:             sessionId,\n\n  Line 443:             diffData: { event: row.event, label: row.label, sessionId, generation, gauges: { iterations: 0, score: 0 } },\n\n  Line 451:                 subject: { label: row.label, sessionId, generation },\n\n  Line 530:           const sessionId = \"{config.lineage.sessionId}\";\n\n  Line 542:                 sessionId,\n\n  Line 586:           log_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n  Line 595:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"fallback\":0,\"message\":\"minIterations missing; using no convergence floor for backward compatibility.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n  Line 598:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warn