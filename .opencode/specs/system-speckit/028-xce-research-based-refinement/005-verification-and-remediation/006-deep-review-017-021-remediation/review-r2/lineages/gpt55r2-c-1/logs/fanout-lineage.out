s';\n83: import { VectorIndexError, VectorIndexErrorCode } from './lib/search/vector-index-types.js';\n84: import * as _embeddings from './lib/providers/embeddings.js';\n85: import * as checkpointsLib from './lib/storage/checkpoints.js';\n86: import * as accessTracker from './lib/storage/access-tracker.js';\n87: import { runLineageBackfill, backfillColdOrphanProjection } from './lib/storage/lineage-state.js';\n88: import * as hybridSearch from './lib/search/hybrid-search.js';\n89: import { createUnifiedGraphSearchFn } from './lib/search/graph-search-fn.js';\n90: import { isGraphUnifiedEnabled } from './lib/search/graph-flags.js';\n91: import { callCodeGraphTool } from './lib/code-graph-boundary.js';\n92: import { detectRuntime, type RuntimeInfo } from './lib/runtime-detection.js';\n93: import {\n94:   ensureMemoryRuntimeInitialized,\n95:   isMemoryRuntimeInitialized,\n96:   registerInitTasks,\n97: } from './lib/runtime/memory-runtime-guard.js';\n98: import * as sessionBoost from './lib/search/session-boost.js';\n99: import * as causalBoost from './lib/search/causal-boost.js';\n100: import * as bm25Index from './lib/search/bm25-index.js';\n101: import { getSpecsBasePaths } from './lib/search/folder-discovery.js';\n102: import {\n103:   registerGlobalRefreshFn,\n104:   getDirtyNodes,\n105:   clearDirtyNodes,\n106:   recomputeLocal,\n107:   cancelScheduledRefresh,\n108:   scheduleGlobalRefresh,\n109: } from './lib/search/graph-lifecycle.js';\n110: import {\n111:   isDegreeBoostEnabled,\n112:   isDynamicInitEnabled,\n113:   isFileWatcherEnabled,\n114: } from './lib/search/search-flags.js';\n115: import { runCleanupStep, runAsyncCleanupStep } from './lib/utils/cleanup-helpers.js';\n116: import { clearAllTimers, clearRegisteredTimer, registerInterval, registerTimeout } from './lib/runtime/timer-registry.js';\n117: import { runShutdownHooks } from './lib/runtime/shutdown-hooks.js';\n118: import {\n119:   getIpcBridgeStats,\n120:   resolveIpcSocketPath,\n121:   startIpcSock