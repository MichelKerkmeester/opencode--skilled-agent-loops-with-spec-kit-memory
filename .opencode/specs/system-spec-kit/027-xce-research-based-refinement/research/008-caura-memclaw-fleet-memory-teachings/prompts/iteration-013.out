/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/__init__.py:\n  Line 4: from core_storage_api.routers.documents import router as documents_router\n\n  Line 22:     \"documents_router\",\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/database/migrations/versions/003_documents_embedding.py:\n  Line 1: \"\"\"Add ``embedding`` column + HNSW index to ``documents``.\n\n  Line 30:         \"documents\",\n\n  Line 37:         CREATE INDEX ix_documents_embedding_hnsw ON documents\n\n  Line 45:     op.execute(\"DROP INDEX IF EXISTS ix_documents_embedding_hnsw\")\n\n  Line 46:     op.drop_column(\"documents\", \"embedding\")\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/database/migrations/versions/017_memories_run_id_index.py:\n  Line 13: writes) and the new ``documents (collection='ingest-sources')`` row joins\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/database/migrations/versions/001_initial_schema.py:\n  Line 256:     # ── documents ──\n\n  Line 258:         \"documents\",\n\n  Line 267:         sa.UniqueConstraint(\"tenant_id\", \"collection\", \"doc_id\", name=\"uq_documents_tenant_collection_doc\"),\n\n  Line 269:     op.create_index(\"ix_documents_tenant_collection\", \"documents\", [\"tenant_id\", \"collection\"])\n\n  Line 289:     op.drop_table(\"documents\")\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/database/migrations/versions/012_vector_dim_1024.py:\n  Line 14: - ``documents.embedding``        — opt-in document semantic search\n\n  Line 38: After upgrade, all existing memories/entities/documents have NULL\n\n  Line 145:                 \"+ (SELECT COUNT(*) FROM documents WHERE embedding      IS NOT NULL)::bigint \"\n\n  Line 167:         op.execute(\"DROP INDEX CONCURRENTLY IF EXISTS ix_documents_embedding_hnsw\")\n\n  Line 189:         op.execute(\"UPDATE documents SET embedding = NULL WHERE embedding IS NOT NULL\")\n\n  Line 207:     op.execute(\"ALTER TABLE documents ALTER COLUMN embedding TYPE vector(1024)\")\n\n  Line 222:             CREATE INDEX CONCURRENTLY IF NOT EXISTS ix_documents_embedding_hnsw\n\n  Line 223:             ON documents\n\n  Line 238:         op.execute(\"DROP INDEX CONCURRENTLY IF EXISTS ix_documents_embedding_hnsw\")\n\n  Line 247:         op.execute(\"UPDATE documents SET embedding = NULL WHERE embedding IS NOT NULL\")\n\n  Line 257:     op.execute(\"ALTER TABLE documents ALTER COLUMN embedding TYPE vector(768)\")\n\n  Line 270:             CREATE INDEX CONCURRENTLY IF NOT EXISTS ix_documents_embedding_hnsw\n\n  Line 271:             ON documents\n","metadata":{"matches":54,"truncated":false},"title":"upsert_keystone|delete_keystone|list_keystones|_keystones|documents","time":{"start":1780728956140,"end":1780728956153}},"metadata":{"openai":{"itemId":"fc_04d064667f4f22d8016a23c47c0f048191888ba12b47820df5"}},"id":"prt_e9bb784e4001h6SQZb3I1cx3hQ","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb75e220014fMZTULe9tLHu4"}}
