{"type":"text","timestamp":1781151307352,"sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","part":{"id":"prt_eb4e413cb0017c9FnJvBHZcYU3","messageID":"msg_eb4e3cc5a001rVj5YBDZfkHvXY","sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","type":"text","text":"I found a high-risk area to replay carefully: the repair reindex atomically renames a staged shard over the live shard while the same DB connection can still have the previous shard attached. I’m reading tests and adjacent code before deciding severity.","time":{"start":1781151306699,"end":1781151307348},"metadata":{"openai":{"itemId":"msg_094727126f7d43f3016a2a364ab14881919a8a7ba2f0f655af","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781151307410,"sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","part":{"type":"tool","tool":"read","callID":"call_Xb2mF8wNudVosPdVjja7oowD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts</path>\n<type>file</type>\n<content>\n1: import * as fs from 'node:fs';\n2: import * as os from 'node:os';\n3: import * as path from 'node:path';\n4: import { randomUUID } from 'node:crypto';\n5: \n6: import Database from 'better-sqlite3';\n7: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n8: \n9: const TEST_DIM = 4;\n10: const TEST_MODEL = 'test-vector-repair-embedder';\n11: const TEST_BACKEND = 'sentence-transformers' as const;\n12: \n13: type EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\n14: let embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n15: \n16: vi.mock('../lib/embedders/registry.js', () => ({\n17:   getManifest: (name: string) => (\n18:     name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n19:   ),\n20: }));\n21: \n22: vi.mock('../lib/embedders/execution-router.js', () => ({\n23:   getEmbedderAdapter: () => ({\n24:     embed: async (texts: string[]) => embedImpl(texts),\n25:   }),\n26:   teardownEmbedderAfterSwap: async () => {},\n27: }));\n28: \n29: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n30: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n31: import * as core from '../core/index.js';\n32: import { handleMemoryHealth } from '../handlers/memory-crud-health.js';\n33: import {\n34:   attachActiveVectorShard,\n35:   closeDb,\n36:   detachActiveVectorShard,\n37:   initializeDb,\n38: } from '../lib/search/vector-index-store.js';\n39: import {\n40:   getDegradedVectorObservabilitySnapshot,\n41:   resetDegradedVectorObservabilityForTest,\n42: } from '../lib/observability/retrieval-observability.js';\n43: \n44: function parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n45:   return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n46: }\n47: \n48: async function waitUntil(predicate: () => boolean, label: string): Promise<void> {\n49:   const deadline = Date.now() + 2000;\n50:   while (Date.now() < deadline) {\n51:     if (predicate()) return;\n52:     await new Promise<void>((resolve) => setImmediate(resolve));\n53:   }\n54:   throw new Error(`Timed out waiting for ${label}`);\n55: }\n56: \n57: function profile(): EmbeddingProfile {\n58:   return new EmbeddingProfile({\n59:     provider: TEST_BACKEND,\n60:     model: TEST_MODEL,\n61:     dim: TEST_DIM,\n62:     dtype: null,\n63:     baseUrl: null,\n64:   });\n65: }\n66: \n67: function vectorIds(shardPath: string): number[] {\n68:   const shard = new Database(shardPath, { readonly: true });\n69:   try {\n70:     return (shard.prepare(`SELECT id FROM vec_${TEST_DIM} ORDER BY id ASC`).all() as Array<{ id: number }>)\n71:       .map((row) => row.id);\n72:   } finally {\n73:     shard.close();\n74:   }\n75: }\n76: \n77: describe('vector shard read-path resilience', () => {\n78:   const originalMemoryDbPath = process.env.MEMORY_DB_PATH;\n79:   const originalAllowedPaths = process.env.MEMORY_ALLOWED_PATHS;\n80:   const originalBatchSize = process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n81:   let tempDir: string;\n82:   let dbPath: string;\n83: \n84:   beforeEach(() => {\n85:     tempDir = fs.mkdtempSync(path.join(os.tmpdir(), `vector-shard-resilience-${randomUUID().slice(0, 8)}-`));\n86:     dbPath = path.join(tempDir, 'context-index.sqlite');\n87:     process.env.MEMORY_DB_PATH = dbPath;\n88:     process.env.MEMORY_ALLOWED_PATHS = tempDir;\n89:     process.env.EMBEDDER_REINDEX_BATCH_SIZE = '50';\n90:     resetDegradedVectorObservabilityForTest();\n91:     embedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n92:     vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n93:   });\n94: \n95:   afterEach(() => {\n96:     vi.restoreAllMocks();\n97:     closeDb();\n98:     resetDegradedVectorObservabilityForTest();\n99:     if (originalMemoryDbPath === undefined) delete process.env.MEMORY_DB_PATH;\n100:     else process.env.MEMORY_DB_PATH = originalMemoryDbPath;\n101:     if (originalAllowedPaths === undefined) delete process.env.MEMORY_ALLOWED_PATHS;\n102:     else process.env.MEMORY_ALLOWED_PATHS = originalAllowedPaths;\n103:     if (originalBatchSize === undefined) delete process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n104:     else process.env.EMBEDDER_REINDEX_BATCH_SIZE = originalBatchSize;\n105:     fs.rmSync(tempDir, { recursive: true, force: true });\n106:   });\n107: \n108:   it('detects, quarantines, rebuilds, and returns healthy after a corrupted copied shard', async () => {\n109:     const db = initializeDb(dbPath);\n110:     const activeProfile = profile();\n111:     setActiveEmbedder(db, TEST_MODEL, TEST_DIM, TEST_BACKEND);\n112:     attachActiveVectorShard(db, activeProfile);\n113:     const now = new Date().toISOString();\n114:     db.prepare(`\n115:       INSERT INTO memory_index (spec_folder, file_path, title, content_text, embedding_status, created_at, updated_at, trigger_phrases)\n116:       VALUES (?, ?, ?, ?, 'pending', ?, ?, '[]'), (?, ?, ?, ?, 'pending', ?, ?, '[]')\n117:     `).run(\n118:       'specs/tmp', 'a.md', 'A', 'alpha', now, now,\n119:       'specs/tmp', 'b.md', 'B', 'beta', now, now,\n120:     );\n121: \n122:     const shardPath = activeProfile.getVectorShardPath(tempDir);\n123:     expect(shardPath.startsWith(tempDir)).toBe(true);\n124:     expect(shardPath).not.toContain('/mcp_server/database/');\n125:     detachActiveVectorShard(db);\n126: \n127:     const fixtureShardPath = path.join(tempDir, 'fixture-shard.sqlite');\n128:     fs.copyFileSync(shardPath, fixtureShardPath);\n129:     fs.copyFileSync(fixtureShardPath, shardPath);\n130:     fs.writeFileSync(shardPath, Buffer.from('not a sqlite database'));\n131: \n132:     let releaseEmbedding: (() => void) | null = null;\n133:     embedImpl = async (texts) => {\n134:       await new Promise<void>((resolve) => {\n135:         releaseEmbedding = resolve;\n136:       });\n137:       return texts.map(() => Float32Array.from([2, 2, 2, 2]));\n138:     };\n139: \n140:     attachActiveVectorShard(db, activeProfile);\n141:     await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'rebuilding', 'repair job to start');\n142: \n143:     const rebuildingHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n144:     const rebuildingDegradation = rebuildingHealth.recallDegradation as Record<string, unknown>;\n145:     expect((rebuildingDegradation.degradedVector as Record<string, unknown>).state).toBe('rebuilding');\n146:     expect(rebuildingDegradation.degraded).toBe(true);\n147:     expect(fs.readdirSync(path.dirname(shardPath)).some((name) => name.includes('.quarantined-'))).toBe(true);\n148: \n149:     releaseEmbedding?.();\n150:     await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'healthy', 'repair job to complete');\n151: \n152:     const finalHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n153:     const finalDegradation = finalHealth.recallDegradation as Record<string, unknown>;\n154:     const degradedVector = finalDegradation.degradedVector as Record<string, unknown>;\n155:     expect(degradedVector.state).toBe('healthy');\n156:     expect(degradedVector.detections).toBe(1);\n157:     expect(degradedVector.quarantines).toBe(1);\n158:     expect(degradedVector.rebuildsStarted).toBe(1);\n159:     expect(degradedVector.rebuildsCompleted).toBe(1);\n160:     expect(vectorIds(shardPath)).toEqual([1, 2]);\n161:   });\n162: });\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst TEST_DIM = 4;\nconst TEST_MODEL = 'test-vector-repair-embedder';\nconst TEST_BACKEND = 'sentence-transformers' as const;\n\ntype EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\nlet embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n\nvi.mock('../lib/embedders/registry.js', () => ({\n  getManifest: (name: string) => (\n    name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n  ),\n}));","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","text":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst TEST_DIM = 4;\nconst TEST_MODEL = 'test-vector-repair-embedder';\nconst TEST_BACKEND = 'sentence-transformers' as const;\n\ntype EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\nlet embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n\nvi.mock('../lib/embedders/registry.js', () => ({\n  getManifest: (name: string) => (\n    name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n  ),\n}));\n\nvi.mock('../lib/embedders/execution-router.js', () => ({\n  getEmbedderAdapter: () => ({\n    embed: async (texts: string[]) => embedImpl(texts),\n  }),\n  teardownEmbedderAfterSwap: async () => {},\n}));\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport * as core from '../core/index.js';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health.js';\nimport {\n  attachActiveVectorShard,\n  closeDb,\n  detachActiveVectorShard,\n  initializeDb,\n} from '../lib/search/vector-index-store.js';\nimport {\n  getDegradedVectorObservabilitySnapshot,\n  resetDegradedVectorObservabilityForTest,\n} from '../lib/observability/retrieval-observability.js';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n}\n\nasync function waitUntil(predicate: () => boolean, label: string): Promise<void> {\n  const deadline = Date.now() + 2000;\n  while (Date.now() < deadline) {\n    if (predicate()) return;\n    await new Promise<void>((resolve) => setImmediate(resolve));\n  }\n  throw new Error(`Timed out waiting for ${label}`);\n}\n\nfunction profile(): EmbeddingProfile {\n  return new EmbeddingProfile({\n    provider: TEST_BACKEND,\n    model: TEST_MODEL,\n    dim: TEST_DIM,\n    dtype: null,\n    baseUrl: null,\n  });\n}\n\nfunction vectorIds(shardPath: string): number[] {\n  const shard = new Database(shardPath, { readonly: true });\n  try {\n    return (shard.prepare(`SELECT id FROM vec_${TEST_DIM} ORDER BY id ASC`).all() as Array<{ id: number }>)\n      .map((row) => row.id);\n  } finally {\n    shard.close();\n  }\n}\n\ndescribe('vector shard read-path resilience', () => {\n  const originalMemoryDbPath = process.env.MEMORY_DB_PATH;\n  const originalAllowedPaths = process.env.MEMORY_ALLOWED_PATHS;\n  const originalBatchSize = process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n  let tempDir: string;\n  let dbPath: string;\n\n  beforeEach(() => {\n    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), `vector-shard-resilience-${randomUUID().slice(0, 8)}-`));\n    dbPath = path.join(tempDir, 'context-index.sqlite');\n    process.env.MEMORY_DB_PATH = dbPath;\n    process.env.MEMORY_ALLOWED_PATHS = tempDir;\n    process.env.EMBEDDER_REINDEX_BATCH_SIZE = '50';\n    resetDegradedVectorObservabilityForTest();\n    embedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n    vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n  });\n\n  afterEach(() => {\n    vi.restoreAllMocks();\n    closeDb();\n    resetDegradedVectorObservabilityForTest();\n    if (originalMemoryDbPath === undefined) delete process.env.MEMORY_DB_PATH;\n    else process.env.MEMORY_DB_PATH = originalMemoryDbPath;\n    if (originalAllowedPaths === undefined) delete process.env.MEMORY_ALLOWED_PATHS;\n    else process.env.MEMORY_ALLOWED_PATHS = originalAllowedPaths;\n    if (originalBatchSize === undefined) delete process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n    else process.env.EMBEDDER_REINDEX_BATCH_SIZE = originalBatchSize;\n    fs.rmSync(tempDir, { recursive: true, force: true });\n  });\n\n  it('detects, quarantines, rebuilds, and returns healthy after a corrupted copied shard', async () => {\n    const db = initializeDb(dbPath);\n    const activeProfile = profile();\n    setActiveEmbedder(db, TEST_MODEL, TEST_DIM, TEST_BACKEND);\n    attachActiveVectorShard(db, activeProfile);\n    const now = new Date().toISOString();\n    db.prepare(`\n      INSERT INTO memory_index (spec_folder, file_path, title, content_text, embedding_status, created_at, updated_at, trigger_phrases)\n      VALUES (?, ?, ?, ?, 'pending', ?, ?, '[]'), (?, ?, ?, ?, 'pending', ?, ?, '[]')\n    `).run(\n      'specs/tmp', 'a.md', 'A', 'alpha', now, now,\n      'specs/tmp', 'b.md', 'B', 'beta', now, now,\n    );\n\n    const shardPath = activeProfile.getVectorShardPath(tempDir);\n    expect(shardPath.startsWith(tempDir)).toBe(true);\n    expect(shardPath).not.toContain('/mcp_server/database/');\n    detachActiveVectorShard(db);\n\n    const fixtureShardPath = path.join(tempDir, 'fixture-shard.sqlite');\n    fs.copyFileSync(shardPath, fixtureShardPath);\n    fs.copyFileSync(fixtureShardPath, shardPath);\n    fs.writeFileSync(shardPath, Buffer.from('not a sqlite database'));\n\n    let releaseEmbedding: (() => void) | null = null;\n    embedImpl = async (texts) => {\n      await new Promise<void>((resolve) => {\n        releaseEmbedding = resolve;\n      });\n      return texts.map(() => Float32Array.from([2, 2, 2, 2]));\n    };\n\n    attachActiveVectorShard(db, activeProfile);\n    await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'rebuilding', 'repair job to start');\n\n    const rebuildingHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n    const rebuildingDegradation = rebuildingHealth.recallDegradation as Record<string, unknown>;\n    expect((rebuildingDegradation.degradedVector as Record<string, unknown>).state).toBe('rebuilding');\n    expect(rebuildingDegradation.degraded).toBe(true);\n    expect(fs.readdirSync(path.dirname(shardPath)).some((name) => name.includes('.quarantined-'))).toBe(true);\n\n    releaseEmbedding?.();\n    await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'healthy', 'repair job to complete');\n\n    const finalHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n    const finalDegradation = finalHealth.recallDegradation as Record<string, unknown>;\n    const degradedVector = finalDegradation.degradedVector as Record<string, unknown>;\n    expect(degradedVector.state).toBe('healthy');\n    expect(degradedVector.detections).toBe(1);\n    expect(degradedVector.quarantines).toBe(1);\n    expect(degradedVector.rebuildsStarted).toBe(1);\n    expect(degradedVector.rebuildsCompleted).toBe(1);\n    expect(vectorIds(shardPath)).toEqual([1, 2]);\n  });\n});","lineStart":1,"lineEnd":162,"totalLines":162,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","time":{"start":1781151307396,"end":1781151307408}},"metadata":{"openai":{"itemId":"fc_094727126f7d43f3016a2a364b53708191a0085aae66167309"}},"id":"prt_eb4e41656001lR74tOjb9Xa2Nr","sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","messageID":"msg_eb4e3cc5a001rVj5YBDZfkHvXY"}}
