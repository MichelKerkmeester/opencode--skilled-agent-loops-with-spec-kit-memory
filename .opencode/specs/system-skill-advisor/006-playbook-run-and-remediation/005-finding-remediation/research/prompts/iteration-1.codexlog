   451	  return {
   452	    diagnostics: {
   453	      recordsPath: advisorHookDiagnosticsPath(workspaceRoot),
   454	      recordsRetained: telemetryHealth.lastInvocations.length,
   455	      rollingCacheHitRate: telemetryHealth.rollingCacheHitRate,
   456	      rollingP95Ms: telemetryHealth.rollingP95Ms,
   457	      rollingFailOpenRate: telemetryHealth.rollingFailOpenRate,
   458	    },
   459	    outcomes: {
   460	      recordsPath: advisorHookOutcomesPath(workspaceRoot),
   461	      recordedThisRun: args.outcomeEvents?.length ?? 0,
   462	      scope: {
   463	        kind: selectedSkillSlug === null ? 'workspace' : 'skill',
   464	        skillSlug: selectedSkillSlug,
   465	      },
   466	      totals: { ...totals },
   467	    },
   468	  };
   469	}
   470	
   471	export function validateAdvisor(input: AdvisorValidateInput = { confirmHeavyRun: true }): AdvisorValidateOutput {
   472	  const args = AdvisorValidateInputSchema.parse(input);
   473	  // F-005-A5-01: Canonicalize via realpath after the schema allowlist check.
   474	  const workspaceRoot = args.workspaceRoot
   475	    ? canonicalizeWorkspaceRoot(args.workspaceRoot)
   476	    : findWorkspaceRoot();
   477	  const selectedSkillSlug = args.skillSlug ?? null;
   478	  for (const outcomeEvent of args.outcomeEvents ?? []) {
   479	    persistAdvisorHookOutcomeRecord(workspaceRoot, createAdvisorHookOutcomeRecord({
   480	      runtime: outcomeEvent.runtime,
   481	      outcome: outcomeEvent.outcome,
   482	      skillLabel: outcomeEvent.skillId,
   483	      correctedSkillLabel: outcomeEvent.correctedSkillId,
   484	      timestamp: outcomeEvent.timestamp,
   485	    }));
   486	  }
   487	  const corpus = loadCorpus(workspaceRoot)
   488	    .filter((row) => selectedSkillSlug ? row.skill_top_1 === selectedSkillSlug : true);
   489	  const full = evaluateRows(corpus, workspaceRoot);
   490	  const holdout = stratifiedHoldout(corpus);
   491	  const holdoutResult = evaluateRows(holdout, workspaceRoot);
   492	  const fullSlice = countSlice(full.correct, corpus.length, FULL_CORPUS_THRESHOLD);
   493	  const holdoutSlice = countSlice(holdoutResult.correct, holdout.length, HOLDOUT_THRESHOLD);
   494	  const explicitRegressions = parityRegressions(corpus, workspaceRoot);
   495	  const baselineGoldNoneFalseFire = pythonGoldNoneFalseFire(corpus, workspaceRoot);
   496	  const derivedComplete = derivedAttributionComplete(workspaceRoot);
   497	  const ambiguity = ambiguityStable();
   498	  const safety = adversarialStuffingBlocked(workspaceRoot);
   499	  const latency = runPromotionLatencyBench(workspaceRoot);
   500	  const regressionSuite = evaluateRegressionCases(loadRegressionCases(workspaceRoot), workspaceRoot);
   501	  const outcomeSummary = summarizeAdvisorHookOutcomeRecords(workspaceRoot);
   502	  const scopedOutcomeTotals = summarizeScopedOutcomeTotals(outcomeSummary.records, selectedSkillSlug);
   503	  const perSkill = [...full.aggregates.entries()]
   504	    .sort(([left], [right]) => left.localeCompare(right))
   505	    .map(([skillId, aggregate]) => ({
   506	      skillId,
   507	      status: aggregate.total === 0
   508	        ? 'skipped' as const
   509	        : aggregate.matched / aggregate.total >= PER_SKILL_THRESHOLD ? 'pass' as const : 'fail' as const,
   510	      matched: aggregate.matched,
   511	      total: aggregate.total,
   512	    }));
   513	  const output: AdvisorValidateOutput = {
   514	    workspaceRoot,
   515	    skillSlug: selectedSkillSlug,
   516	    // Keep the operator-facing threshold contract centralized so playbooks and schema docs verify the same surface.
   517	    thresholdSemantics: buildThresholdSemantics(),
   518	    overallAccuracy: fullSlice.percentage,
   519	    perSkill,
   520	    slices: {
   521	      corpus: {
   522	        full_corpus_top1: fullSlice,
   523	        unknown_count: {
   524	          value: full.unknown,
   525	          targetMax: UNKNOWN_TARGET_MAX,
   526	          passed: full.unknown <= UNKNOWN_TARGET_MAX,
   527	        },
   528	        gold_none_false_fire_count: {
   529	          value: full.falseFire,
   530	          baselineDelta: full.falseFire - baselineGoldNoneFalseFire,
   531	        },
   532	      },
   533	      holdout: {
   534	        holdout_top1: holdoutSlice,
   535	      },
   536	      parity: {
   537	        explicit_skill_top1_regression: {
   538	          passed: explicitRegressions.length === 0,
   539	          regressions: explicitRegressions,
   540	        },
   541	        ambiguity_slice_stable: {
   542	          passed: ambiguity,
   543	          top2Within005: ambiguity,
   544	        },
   545	        derived_lane_attribution_complete: derivedComplete,
   546	      },
   547	      safety: {
   548	        adversarial_stuffing_blocked: {
   549	          passed: safety,
   550	          fixtureCount: 1,
   551	        },
   552	      },
   553	      latency: {
   554	        regression_suite_status: {
   555	          p0PassRate: regressionSuite.p0PassRate,
   556	          failedCount: regressionSuite.failedCount,
   557	          commandBridgeFalsePositiveRate: regressionSuite.commandBridgeFalsePositiveRate,
   558	          cacheHitP95Ms: latency.cacheHitP95Ms,
   559	          uncachedP95Ms: latency.uncachedP95Ms,
   560	        },
   561	      },
   562	    },
   563	    telemetry: buildTelemetrySummary(args, workspaceRoot, selectedSkillSlug, scopedOutcomeTotals),
   564	    generatedAt: new Date().toISOString(),
   565	  };
   566	  return AdvisorValidateOutputSchema.parse(output);
   567	}
