   649	/**
   650	 * Detect CLI failures caused by stale or missing generated advisor output.
   651	 *
   652	 * @param {number|null} exitCode - CLI process exit code.
   653	 * @param {string} stderr - Captured CLI stderr.
   654	 * @returns {object|null} Stale-dist metadata, or null for other failures.
   655	 */
   656	function classifyCliStaleDist(exitCode, stderr) {
   657	  if (exitCode !== ADVISOR_CLI_STALE_EXIT || !/dist entrypoint is (stale|missing)/i.test(stderr)) {
   658	    return null;
   659	  }
   660	  return {
   661	    freshness: 'dist_stale',
   662	    retryable: false,
   663	    exitCode: ADVISOR_CLI_STALE_EXIT,
   664	    state: 'dist_stale_rebuild_required',
   665	    staleDist: true,
   666	    rebuildRequired: true,
   667	    action: 'run the skill-advisor TypeScript build',
   668	    stderr: stderr ? '[stderr-present]' : null,
   669	  };
   670	}
