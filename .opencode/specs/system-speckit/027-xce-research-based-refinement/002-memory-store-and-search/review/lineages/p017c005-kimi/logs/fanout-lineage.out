{"type":"tool_use","timestamp":1781723720690,"sessionID":"ses_128ff49bbffeaBi7hiBur0TbQX","part":{"type":"tool","tool":"read","callID":"tool_8P2H7U69TXAq6sXvOSNIsEm0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":2400,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n2400:     if (!deduped.has(key)) {\n2401:       deduped.set(key, result);\n2402:     }\n2403:   }\n2404:   return Array.from(deduped.values());\n2405: }\n2406: \n2407: /** Apply caller limit after merges that can expand result count. */\n2408: function applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n2409:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n2410:     return results;\n2411:   }\n2412:   return results.slice(0, limit);\n2413: }\n2414: \n2415: /** Depth of the result head rebalanced by the cosine-primary reorder. */\n2416: const COSINE_TOPN_REORDER_DEPTH = 10;\n2417: \n2418: /**\n2419:  * Cosine-primary reorder of the result head.\n2420:  *\n2421:  * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n2422:  * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n2423:  * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n2424:  * decisive for downstream consumers — is rebalanced toward the strongest absolute\n2425:  * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n2426:  * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n2427:  * and membership are invariant — this only permutes the head.\n2428:  */\n2429: function reorderTopNByCosine(\n2430:   results: HybridSearchResult[],\n2431:   depth: number = COSINE_TOPN_REORDER_DEPTH\n2432: ): HybridSearchResult[] {\n2433:   const headCount = Math.min(depth, results.length);\n2434:   if (headCount <= 1) return results;\n2435: \n2436:   const head = results.slice(0, headCount);\n2437:   // Decorate with the original index so equal-relevance ties resolve to fused\n2438:   // order regardless of the engine's sort stability.\n2439:   const reordered = head\n2440:     .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n2441:     .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n2442:     .map((entry) => entry.row);\n2443: \n2444:   return [...reordered, ...results.slice(headCount)];\n2445: }\n2446: \n2447: /** Tier-3 structural results are capped at this fraction of the top existing score. */\n2448: const TIER3_CAP_RATIO = 0.5;\n2449: /** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\n2450: const TIER3_DECAY_PER_RANK = 0.08;\n2451: \n2452: /**\n2453:  * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n2454:  * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n2455:  */\n2456: function calibrateTier3Scores(\n2457:   existing: HybridSearchResult[],\n2458:   tier3: HybridSearchResult[]\n2459: ): HybridSearchResult[] {\n2460:   const topExisting = existing.reduce((max, row) => {\n2461:     if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n2462:       return max;\n2463:     }\n2464:     return Math.max(max, row.score);\n2465:   }, 0);\n2466: \n2467:   if (topExisting <= 0) {\n2468:     return tier3;\n2469:   }\n2470: \n2471:   const topCap = topExisting * TIER3_CAP_RATIO;\n2472:   const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n2473: \n2474:   return tier3.map((row, index) => {\n2475:     const calibrated = Math.max(0, topCap - (index * decayPerRank));\n2476:     return {\n2477:       ...row,\n2478:       score: Math.min(row.score, calibrated),\n2479:     };\n2480:   });\n2481: }\n2482: \n2483: // 13. TIERED FALLBACK (PI-A2)\n2484: \n2485: /**\n2486:  * Evaluate whether results meet quality thresholds.\n2487:  * Returns null if thresholds are met, or a DegradationTrigger if not.\n2488:  */\n2489: function checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n\n(Showing lines 2400-2489 of 2972. Use offset=2490 to continue.)\n</content>","metadata":{"preview":"    if (!deduped.has(key)) {\n      deduped.set(key, result);\n    }\n  }\n  return Array.from(deduped.values());\n}\n\n/** Apply caller limit after merges that can expand result count. */\nfunction applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return results;\n  }\n  return results.slice(0, limit);\n}\n\n/** Depth of the result head rebalanced by the cosine-primary reorder. */\nconst COSINE_TOPN_REORDER_DEPTH = 10;\n\n/**\n * Cosine-primary reorder of the result head.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"    if (!deduped.has(key)) {\n      deduped.set(key, result);\n    }\n  }\n  return Array.from(deduped.values());\n}\n\n/** Apply caller limit after merges that can expand result count. */\nfunction applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return results;\n  }\n  return results.slice(0, limit);\n}\n\n/** Depth of the result head rebalanced by the cosine-primary reorder. */\nconst COSINE_TOPN_REORDER_DEPTH = 10;\n\n/**\n * Cosine-primary reorder of the result head.\n *\n * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n * decisive for downstream consumers — is rebalanced toward the strongest absolute\n * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n * and membership are invariant — this only permutes the head.\n */\nfunction reorderTopNByCosine(\n  results: HybridSearchResult[],\n  depth: number = COSINE_TOPN_REORDER_DEPTH\n): HybridSearchResult[] {\n  const headCount = Math.min(depth, results.length);\n  if (headCount <= 1) return results;\n\n  const head = results.slice(0, headCount);\n  // Decorate with the original index so equal-relevance ties resolve to fused\n  // order regardless of the engine's sort stability.\n  const reordered = head\n    .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n    .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n    .map((entry) => entry.row);\n\n  return [...reordered, ...results.slice(headCount)];\n}\n\n/** Tier-3 structural results are capped at this fraction of the top existing score. */\nconst TIER3_CAP_RATIO = 0.5;\n/** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\nconst TIER3_DECAY_PER_RANK = 0.08;\n\n/**\n * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n */\nfunction calibrateTier3Scores(\n  existing: HybridSearchResult[],\n  tier3: HybridSearchResult[]\n): HybridSearchResult[] {\n  const topExisting = existing.reduce((max, row) => {\n    if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n      return max;\n    }\n    return Math.max(max, row.score);\n  }, 0);\n\n  if (topExisting <= 0) {\n    return tier3;\n  }\n\n  const topCap = topExisting * TIER3_CAP_RATIO;\n  const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n\n  return tier3.map((row, index) => {\n    const calibrated = Math.max(0, topCap - (index * decayPerRank));\n    return {\n      ...row,\n      score: Math.min(row.score, calibrated),\n    };\n  });\n}\n\n// 13. TIERED FALLBACK (PI-A2)\n\n/**\n * Evaluate whether results meet quality thresholds.\n * Returns null if thresholds are met, or a DegradationTrigger if not.\n */\nfunction checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {","lineStart":2400,"lineEnd":2489,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781723720683,"end":1781723720689}},"id":"prt_ed7026935001RKlrueLVp1DE6S","sessionID":"ses_128ff49bbffeaBi7hiBur0TbQX","messageID":"msg_ed70247fa001x9hDX21pgW647r"}}
