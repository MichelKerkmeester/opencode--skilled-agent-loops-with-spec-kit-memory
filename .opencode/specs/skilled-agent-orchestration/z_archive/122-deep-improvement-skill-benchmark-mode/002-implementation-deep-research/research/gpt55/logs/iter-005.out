   309	  }
   310	  // Auditing recommendation quality is a review task, not an advisor-self task.
   311	  if (/\baudit\b/.test(promptLower) && /\b(recommendation|recommendations|recommendation quality|routing quality)\b/.test(promptLower)) {
   312	    if (recommendation.skill === 'sk-code-review') return R.auditRecsCodeReviewBonus;
   313	    if (recommendation.skill === 'system-skill-advisor') return R.auditRecsAdvisorPenalty;
   314	  }
   315	  if (/\b(save context|save memory)\b/.test(promptLower)) {
   316	    if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;
   317	    if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;
   318	  }
   319	  if (/\b(create (a )?new agent|create agent)\b/.test(promptLower) || promptLower.includes('/create:agent')) {
   320	    if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;
   321	    if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;
   322	  }
   323	  if (/\bcreate (a )?(test|testing) playbook\b/.test(promptLower) || promptLower.includes('/create:testing-playbook')) {
   324	    if (recommendation.skill === 'create:testing-playbook' || recommendation.skill === 'command-create-testing-playbook') return R.createTestingPlaybookBonus;
   325	    if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;
   326	    if (recommendation.skill === 'deep-agent-improvement') return R.createTestingPlaybookOtherSkillsPenalty;
   327	  }
   328	  if (/\bphase folder\b/.test(promptLower)) {
   329	    if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;
   330	  }
   331	  return 0;
   332	}
