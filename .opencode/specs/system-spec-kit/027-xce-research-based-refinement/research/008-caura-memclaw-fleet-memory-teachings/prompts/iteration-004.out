       \"min_similarity\": sp.get(\"min_similarity\", MIN_SEARCH_SIMILARITY),\n36:             \"fts_weight\": (sp[\"fts_weight\"] if \"fts_weight\" in sp else _adaptive_fts_weight(query)),\n37:             \"freshness_floor\": sp.get(\"freshness_floor\", FRESHNESS_FLOOR),\n38:             \"freshness_decay_days\": sp.get(\"freshness_decay_days\", FRESHNESS_DECAY_DAYS),\n39:             \"recall_boost_cap\": sp.get(\"recall_boost_cap\", RECALL_BOOST_CAP),\n40:             \"recall_decay_window_days\": sp.get(\"recall_decay_window_days\", RECALL_DECAY_WINDOW_DAYS),\n41:             \"graph_max_hops\": sp.get(\"graph_max_hops\", GRAPH_MAX_HOPS),\n42:             \"similarity_blend\": sp.get(\"similarity_blend\", SIMILARITY_BLEND),\n43:         }\n44:         return None\n\n(End of file - total 44 lines)\n</content>","metadata":{"preview":"\"\"\"ResolveSearchProfile — resolve per-agent search profile with fallback to constants.\"\"\"\n\nfrom __future__ import annotations\n\nfrom core_api.constants import (\n    FRESHNESS_DECAY_DAYS,\n    FRESHNESS_FLOOR,\n    GRAPH_MAX_HOPS,\n    MIN_SEARCH_SIMILARITY,\n    RECALL_BOOST_CAP,\n    RECALL_DECAY_WINDOW_DAYS,\n    SIMILARITY_BLEND,\n)\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepResult\nfrom core_api.services.memory_service import _adaptive_fts_weight\n\n\nclass ResolveSearchProfile:\n    @property","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/resolve_search_profile.py","text":"\"\"\"ResolveSearchProfile — resolve per-agent search profile with fallback to constants.\"\"\"\n\nfrom __future__ import annotations\n\nfrom core_api.constants import (\n    FRESHNESS_DECAY_DAYS,\n    FRESHNESS_FLOOR,\n    GRAPH_MAX_HOPS,\n    MIN_SEARCH_SIMILARITY,\n    RECALL_BOOST_CAP,\n    RECALL_DECAY_WINDOW_DAYS,\n    SIMILARITY_BLEND,\n)\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepResult\nfrom core_api.services.memory_service import _adaptive_fts_weight\n\n\nclass ResolveSearchProfile:\n    @property\n    def name(self) -> str:\n        return \"resolve_search_profile\"\n\n    async def execute(self, ctx: PipelineContext) -> StepResult | None:\n        from core_api.services.organization_settings import validate_search_profile\n\n        search_profile = ctx.data.get(\"search_profile\")\n        sp = validate_search_profile(search_profile) if search_profile else {}\n\n        query = ctx.data[\"query\"]\n        top_k = ctx.data[\"top_k\"]\n\n        ctx.data[\"search_params\"] = {\n            \"top_k\": sp.get(\"top_k\", top_k),\n            \"min_similarity\": sp.get(\"min_similarity\", MIN_SEARCH_SIMILARITY),\n            \"fts_weight\": (sp[\"fts_weight\"] if \"fts_weight\" in sp else _adaptive_fts_weight(query)),\n            \"freshness_floor\": sp.get(\"freshness_floor\", FRESHNESS_FLOOR),\n            \"freshness_decay_days\": sp.get(\"freshness_decay_days\", FRESHNESS_DECAY_DAYS),\n            \"recall_boost_cap\": sp.get(\"recall_boost_cap\", RECALL_BOOST_CAP),\n            \"recall_decay_window_days\": sp.get(\"recall_decay_window_days\", RECALL_DECAY_WINDOW_DAYS),\n            \"graph_max_hops\": sp.get(\"graph_max_hops\", GRAPH_MAX_HOPS),\n            \"similarity_blend\": sp.get(\"similarity_blend\", SIMILARITY_BLEND),\n        }\n        return None","lineStart":1,"lineEnd":44,"totalLines":44,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/resolve_search_profile.py","time":{"start":1780727746100,"end":1780727746122}},"metadata":{"openai":{"itemId":"fc_00faf3f4aa03904b016a23bfc1ea188191baa6025e54e27fe4"}},"id":"prt_e9ba50e33001SbuTUiVdh0xl2a","sessionID":"ses_1645cad34ffe2dSeSw3HI64S6Y","messageID":"msg_e9ba4ced7001RSO9lSaf2O9QnB"}}
{"type":"tool_use","timestamp":1780727746124,"sessionID":"ses_1645cad34ffe2dSeSw3HI64S6Y","part":{"type":"tool","tool":"read","callID":"call_3HHPLMjcoROpPLDGgGZjMZA7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/track_recalls.py","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/track_recalls.py</path>\n<type>file</type>\n<content>\n1: \"\"\"TrackRecalls — fire-and-forget recall tracking in a background task.\n2: \n3: Uses its own DB session so the search response returns immediately without\n4: waiting for the recall_count UPDATE + COMMIT round-trip.\n5: \"\"\"\n6: \n7: from __future__ import annotations\n8: \n9: import logging\n10: from uuid import UUID\n11: \n12: from core_api.pipeline.context import PipelineContext\n13: from core_api.pipeline.step import StepResult\n14: from core_api.services.hooks import get_hooks\n15: from core_api.tasks import track_task\n16: \n17: logger = logging.getLogger(__name__)\n18: \n19: \n20: async def _track_recalls_background(memory_ids: list[UUID]) -> None:\n21:     \"\"\"Background task: update recall stats in an independent DB session.\"\"\"\n22:     from core_api.db.session import async_session\n23: \n24:     try:\n25:         _hooks = get_hooks()\n26:         if _hooks.on_recall:\n27:             async with async_session() as db:\n28:                 await _hooks.on_recall(db, memory_ids)\n29:                 await db.commit()\n30:     except Exception:\n31:         logger.warning(\"Background recall tracking failed\", exc_info=True)\n32: \n33: \n34: class TrackRecalls:\n35:     @property\n36:     def name(self) -> str:\n37:         return \"track_recalls\"\n38: \n39:     async def execute(self, ctx: PipelineContext) -> StepResult | None:\n40:         memory_ids = [row.Memory.id for row in ctx.data[\"filtered_rows\"]]\n41:         if memory_ids:\n42:             track_task(_track_recalls_background(memory_ids))\n43:         return None\n\n(End of file - total 43 lines)\n</content>","metadata":{"preview":"\"\"\"TrackRecalls — fire-and-forget recall tracking in a background task.\n\nUses its own DB session so the search response returns immediately without\nwaiting for the recall_count UPDATE + COMMIT round-trip.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom uuid import UUID\n\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepResult\nfrom core_api.services.hooks import get_hooks\nfrom core_api.tasks import track_task\n\nlogger = logging.getLogger(__name__)\n\n\nasync def _track_recalls_background(memory_ids: list[UUID]) -> None:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/track_recalls.py","text":"\"\"\"TrackRecalls — fire-and-forget recall tracking in a background task.\n\nUses its own DB session so the search response returns immediately without\nwaiting for the recall_count UPDATE + COMMIT round-trip.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom uuid import UUID\n\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepResult\nfrom core_api.services.hooks import get_hooks\nfrom core_api.tasks import track_task\n\nlogger = logging.getLogger(__name__)\n\n\nasync def _track_recalls_background(memory_ids: list[UUID]) -> None:\n    \"\"\"Background task: update recall stats in an independent DB session.\"\"\"\n    from core_api.db.session import async_session\n\n    try:\n        _hooks = get_hooks()\n        if _hooks.on_recall:\n            async with async_session() as db:\n                await _hooks.on_recall(db, memory_ids)\n                await db.commit()\n    except Exception:\n        logger.warning(\"Background recall tracking failed\", exc_info=True)\n\n\nclass TrackRecalls:\n    @property\n    def name(self) -> str:\n        return \"track_recalls\"\n\n    async def execute(self, ctx: PipelineContext) -> StepResult | None:\n        memory_ids = [row.Memory.id for row in ctx.data[\"filtered_rows\"]]\n        if memory_ids:\n            track_task(_track_recalls_background(memory_ids))\n        return None","lineStart":1,"lineEnd":43,"totalLines":43,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/track_recalls.py","time":{"start":1780727746103,"end":1780727746123}},"metadata":{"openai":{"itemId":"fc_00faf3f4aa03904b016a23bfc1ee5481918a915ac19121c4c9"}},"id":"prt_e9ba50e35001gEn9r0lQ7jrUCO","sessionID":"ses_1645cad34ffe2dSeSw3HI64S6Y","messageID":"msg_e9ba4ced7001RSO9lSaf2O9QnB"}}
{"type":"tool_use","timestamp":1780727746127,"sessionID":"ses_1645cad34ffe2dSeSw3HI64S6Y","part":{"type":"tool","tool":"read","callID":"call_kkiXDMnYU0Yu6m6s4vIEdCEq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/repositories/memory_repository.py","offset":340,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/repositories/memory_repository.py</path>\n<type>file</type>\n<content>\n340: \n341:         _fts_weight = sp[\"fts_weight\"]\n342:         _freshness_floor = sp[\"freshness_floor\"]\n343:         _freshness_decay_days = sp[\"freshness_decay_days\"]\n344:         _recall_boost_cap = sp[\"recall_boost_cap\"]\n345:         _recall_decay_window_days = sp[\"recall_decay_window_days\"]\n346:         _similarity_blend = sp[\"similarity_blend\"]\n347:         _top_k = sp.get(\"top_k\", top_k)\n348: \n349:         # ── Scoring expressions ──\n350:         distance = Memory.embedding.cosine_distance(embedding)\n351:         vec_sim = (1.0 - distance).label(\"vec_sim\")\n352: \n353:         ts_query = func.plainto_tsquery(\"english\", query)\n354:         raw_fts = func.ts_rank_cd(Memory.search_vector, ts_query)\n355:         fts_score = (raw_fts / (1.0 + raw_fts)).label(\"fts_score\")\n356: \n357:         similarity = ((1.0 - _fts_weight) * vec_sim + _fts_weight * fts_score).label(\"similarity\")\n358: \n359:         anchor = func.greatest(\n360:             Memory.created_at,\n361:             func.coalesce(Memory.ts_valid_start, Memory.created_at),\n362:         )\n363:         age_days = func.extract(\"epoch\", func.now() - anchor) / 86400.0\n364: \n365:         type_decay = case(\n366:             *[(Memory.memory_type == mt, float(days)) for mt, days in TYPE_DECAY_DAYS.items()],\n367:             else_=float(_freshness_decay_days),\n368:         ).label(\"type_decay_days\")\n369: \n370:         freshness = case(\n371:             (\n372:                 and_(\n373:                     Memory.ts_valid_end.is_not(None),\n374:                     Memory.ts_valid_end < func.now(),\n375:                 ),\n376:                 _freshness_floor,\n377:             ),\n378:             (Memory.ts_valid_end.is_not(None), 1.0),\n379:             (\n380:                 age_days < type_decay,\n381:                 1.0 - (age_days / type_decay) * (1.0 - _freshness_floor),\n382:             ),\n383:             else_=_freshness_floor,\n384:         ).label(\"freshness\")\n385: \n386:         if recall_boost_enabled:\n387:             days_since_recall = (\n388:                 func.extract(\n389:                     \"epoch\",\n390:                     func.now() - func.coalesce(Memory.last_recalled_at, Memory.created_at),\n391:                 )\n392:                 / 86400.0\n393:             )\n394:             recency_factor = func.greatest(0.0, 1.0 - days_since_recall / _recall_decay_window_days)\n395:             recall_boost_expr = (\n396:                 1.0\n397:                 + (_recall_boost_cap - 1.0)\n398:                 * recency_factor\n399:                 * Memory.recall_count\n400:                 / (Memory.recall_count + RECALL_BOOST_SCALE)\n401:             ).label(\"recall_boost\")\n402:         else:\n403:             recall_boost_expr = literal_column(\"1.0\").label(\"recall_boost\")\n404: \n405:         base_score = (_similarity_blend * similarity + (1.0 - _similarity_blend) * Memory.weight).label(\n406:             \"base_score\"\n407:         )\n408: \n409:         if temporal_window is not None:\n410:             cutoff = func.now() - temporal_window\n411:             temporal_boost = case(\n412:                 (Memory.created_at >= cutoff, 1.3),\n413:                 else_=1.0,\n414:             ).label(\"temporal_boost\")\n415:         else:\n416:             temporal_boost = literal_column(\"1.0\").label(\"temporal_boost\")\n417: \n418:         if boosted_memory_ids:\n419:             boost_tiers: dict[float, list[UUID]] = {}\n420:             for mid, factor in memory_boost_factor.items():\n421:                 boost_tiers.setdefault(factor, []).append(mid)\n422:             whens = [\n423:                 (Memory.id.in_(mids), factor) for factor, mids in sorted(boost_tiers.items(), reverse=True)\n424:             ]\n425:             entity_boost = case(*whens, else_=1.0).label(\"entity_boost\")\n426:             score = (base_score * freshness * entity_boost * recall_boost_expr * temporal_boost).label(\n427:                 \"score\"\n428:             )\n429:         else:\n430:             score = (base_score * freshness * recall_boost_expr * temporal_boost).label(\"score\")\n431: \n432:         # ── Build scored CTE ──\n433:         scored_stmt = (\n434:             select(\n435:                 Memory.id.label(\"mem_id\"),\n436:                 score,\n437:                 similarity,\n438:                 vec_sim,\n439:             )\n\n(Showing lines 340-439 of 1061. Use offset=440 to continue.)\n</content>","metadata":{"preview":"\n        _fts_weight = sp[\"fts_weight\"]\n        _freshness_floor = sp[\"freshness_floor\"]\n        _freshness_decay_days = sp[\"freshness_decay_days\"]\n        _recall_boost_cap = sp[\"recall_boost_cap\"]\n        _recall_decay_window_days = sp[\"recall_decay_window_days\"]\n        _similarity_blend = sp[\"similarity_blend\"]\n        _top_k = sp.get(\"top_k\", top_k)\n\n        # ── Scoring expressions ──\n        distance = Memory.embedding.cosine_distance(embedding)\n        vec_sim = (1.0 - distance).label(\"vec_sim\")\n\n        ts_query = func.plainto_tsquery(\"english\", query)\n        raw_fts = func.ts_rank_cd(Memory.search_vector, ts_query)\n        fts_score = (raw_fts / (1.0 + raw_fts)).label(\"fts_score\")\n\n        similarity = ((1.0 - _fts_weight) * vec_sim + _fts_weight * fts_score).label(\"similarity\")\n\n        anchor = func.greatest(","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/repositories/memory_repository.py","text":"\n        _fts_weight = sp[\"fts_weight\"]\n        _freshness_floor = sp[\"freshness_floor\"]\n        _freshness_decay_days = sp[\"freshness_decay_days\"]\n        _recall_boost_cap = sp[\"recall_boost_cap\"]\n        _recall_decay_window_days = sp[\"recall_decay_window_days\"]\n        _similarity_blend = sp[\"similarity_blend\"]\n        _top_k = sp.get(\"top_k\", top_k)\n\n        # ── Scoring expressions ──\n        distance = Memory.embedding.cosine_distance(embedding)\n        vec_sim = (1.0 - distance).label(\"vec_sim\")\n\n        ts_query = func.plainto_tsquery(\"english\", query)\n        raw_fts = func.ts_rank_cd(Memory.search_vector, ts_query)\n        fts_score = (raw_fts / (1.0 + raw_fts)).label(\"fts_score\")\n\n        similarity = ((1.0 - _fts_weight) * vec_sim + _fts_weight * fts_score).label(\"similarity\")\n\n        anchor = func.greatest(\n            Memory.created_at,\n            func.coalesce(Memory.ts_valid_start, Memory.created_at),\n        )\n        age_days = func.extract(\"epoch\", func.now() - anchor) / 86400.0\n\n        type_decay = case(\n            *[(Memory.memory_type == mt, float(days)) for mt, days in TYPE_DECAY_DAYS.items()],\n            else_=float(_freshness_decay_days),\n        ).label(\"type_decay_days\")\n\n        freshness = case(\n            (\n                and_(\n                    Memory.ts_valid_end.is_not(None),\n                    Memory.ts_valid_end < func.now(),\n                ),\n                _freshness_floor,\n            ),\n            (Memory.ts_valid_end.is_not(None), 1.0),\n            (\n                age_days < type_decay,\n                1.0 - (age_days / type_decay) * (1.0 - _freshness_floor),\n            ),\n            else_=_freshness_floor,\n        ).label(\"freshness\")\n\n        if recall_boost_enabled:\n            days_since_recall = (\n                func.extract(\n                    \"epoch\",\n                    func.now() - func.coalesce(Memory.last_recalled_at, Memory.created_at),\n                )\n                / 86400.0\n            )\n            recency_factor = func.greatest(0.0, 1.0 - days_since_recall / _recall_decay_window_days)\n            recall_boost_expr = (\n                1.0\n                + (_recall_boost_cap - 1.0)\n                * recency_factor\n                * Memory.recall_count\n                / (Memory.recall_count + RECALL_BOOST_SCALE)\n            ).label(\"recall_boost\")\n        else:\n            recall_boost_expr = literal_column(\"1.0\").label(\"recall_boost\")\n\n        base_score = (_similarity_blend * similarity + (1.0 - _similarity_blend) * Memory.weight).label(\n            \"base_score\"\n        )\n\n        if temporal_window is not None:\n            cutoff = func.now() - temporal_window\n            temporal_boost = case(\n                (Memory.created_at >= cutoff, 1.3),\n                else_=1.0,\n            ).label(\"temporal_boost\")\n        else:\n            temporal_boost = literal_column(\"1.0\").label(\"temporal_boost\")\n\n        if boosted_memory_ids:\n            boost_tiers: dict[float, list[UUID]] = {}\n            for mid, factor in memory_boost_factor.items():\n                boost_tiers.setdefault(factor, []).append(mid)\n            whens = [\n                (Memory.id.in_(mids), factor) for factor, mids in sorted(boost_tiers.items(), reverse=True)\n            ]\n            entity_boost = case(*whens, else_=1.0).label(\"entity_boost\")\n            score = (base_score * freshness * entity_boost * recall_boost_expr * temporal_boost).label(\n                \"score\"\n            )\n        else:\n            score = (base_score * freshness * recall_boost_expr * temporal_boost).label(\"score\")\n\n        # ── Build scored CTE ──\n        scored_stmt = (\n            select(\n                Memory.id.label(\"mem_id\"),\n                score,\n                similarity,\n                vec_sim,\n            )","lineStart":340,"lineEnd":439,"totalLines":1061,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/repositories/memory_repository.py","time":{"start":1780727746105,"end":1780727746125}},"metadata":{"openai":{"itemId":"fc_00faf3f4aa03904b016a23bfc1ee608191a1164cf62b8daf24"}},"id":"prt_e9ba50e37001lsLLftVhjiTjP4","sessionID":"ses_1645cad34ffe2dSeSw3HI64S6Y","messageID":"msg_e9ba4ced7001RSO9lSaf2O9QnB"}}
