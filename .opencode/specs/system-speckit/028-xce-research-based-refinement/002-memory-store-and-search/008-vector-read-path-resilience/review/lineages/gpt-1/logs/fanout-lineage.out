{"type":"tool_use","timestamp":1781151304282,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_w7chSkH2JEjIIqEexLd7ES4f","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":224,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n224:   return {\n225:     corpusSize,\n226:     iterations,\n227:     scalarJoinAverageMs,\n228:     matchAverageMs,\n229:     matchSupported: matchAverageMs !== null,\n230:     matchImprovementPct,\n231:     decision,\n232:     reason: decision === 'adopt_match'\n233:       ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n234:       : matchError\n235:         ? `MATCH unavailable: ${matchError}`\n236:         : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n237:   };\n238: }\n239: \n240: /* ───────────────────────────────────────────────────────────────\n241:    SIMPLE QUERIES\n242: ----------------------------------------------------------------*/\n243: \n244: /**\n245:  * Gets one indexed memory by identifier.\n246:  * @param id - The memory identifier.\n247:  * @returns The matching memory row, if found.\n248:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n249:  * @example\n250:  * ```ts\n251:  * const memory = get_memory(42);\n252:  * ```\n253:  */\n254: export function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n255:   const stmts = init_prepared_statements(database);\n256:   const row = stmts.get_by_id.get(id);\n257: \n258:   if (row) {\n259:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n260:     row.isConstitutional = row.importance_tier === 'constitutional';\n261:   }\n262: \n263:   return row || null;\n264: }\n265: \n266: /**\n267:  * Gets indexed memories for a spec folder.\n268:  * @param spec_folder - The spec folder to query.\n269:  * @returns The memory rows for the folder.\n270:  */\n271: export function get_memories_by_folder(\n272:   spec_folder: string,\n273:   database: Database.Database = initialize_db(),\n274: ): MemoryRow[] {\n275:   const rows = database.prepare(`\n276:     SELECT m.*\n277:     FROM memory_index m\n278:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n279:     WHERE (m.spec_folder = ? OR m.spec_folder LIKE ?)\n280:     ORDER BY m.created_at DESC\n281:   `).all(spec_folder, `${spec_folder}/%`) as MemoryRow[];\n282: \n283:   return rows.map((row: MemoryRow) => {\n284:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n285:     row.isConstitutional = row.importance_tier === 'constitutional';\n286:     return row;\n287:   });\n288: }\n289: \n290: /**\n291:  * Gets the total number of indexed memories.\n292:  * @returns The total memory count.\n293:  */\n294: export function get_memory_count(database: Database.Database = initialize_db()): number {\n295:   const stmts = init_prepared_statements(database);\n296:   const result = stmts.count_all.get();\n297:   return result?.count ?? 0;\n298: }\n299: \n300: /**\n301:  * Gets memory counts grouped by embedding status.\n302:  * @returns The counts for each embedding status.\n303:  */\n304: export function get_status_counts(\n305:   database: Database.Database = initialize_db(),\n306: ): { pending: number; success: number; failed: number; retry: number; partial: number } {\n307:   const rows = database.prepare(`\n308:     SELECT m.embedding_status, COUNT(*) as count\n309:     FROM memory_index m\n310:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n311:     GROUP BY m.embedding_status\n312:   `).all();\n313: \n314:   // Include 'partial' status in counts.\n315:   const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n316:   for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n317:     if (row.embedding_status in counts) {\n318:       counts[row.embedding_status] = row.count;\n319:     }\n320:   }\n321: \n322:   return counts;\n323: }\n324: \n325: /**\n326:  * Gets summary counts for indexed memories.\n327:  * @returns The aggregate memory statistics.\n328:  */\n329: export function get_stats(\n330:   database: Database.Database = initialize_db(),\n331: ): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n332:   const counts = get_status_counts(database);\n333:   const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n334: \n335:   return {\n336:     total,\n337:     ...counts\n338:   };\n339: }\n340: \n341: /* ───────────────────────────────────────────────────────────────\n342:    VECTOR SEARCH\n343: ----------------------------------------------------------------*/\n344: \n345: /**\n346:  * Searches indexed memories by vector similarity.\n347:  * @param query_embedding - The query embedding to search with.\n348:  * @param options - Search options.\n349:  * @returns The matching memory rows.\n350:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n351:  * @example\n352:  * ```ts\n353:  * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n354:  * ```\n355:  */\n356: export function vector_search(\n357:   query_embedding: EmbeddingInput,\n358:   options: VectorSearchOptions = {},\n359:   database: Database.Database = initialize_db(),\n360: ): MemoryRow[] {\n361:   const sqlite_vec = get_sqlite_vec_available();\n362:   if (!sqlite_vec) {\n363:     console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n364:     return [];\n365:   }\n366: \n367:   const {\n368:     limit = 10,\n369:     specFolder = null,\n370:     minSimilarity = 0,\n371:     useDecay = true,\n372:     tier = null,\n373:     contextType = null,\n374:     includeConstitutional = true,\n375:     includeArchived = false\n376:   } = options;\n377: \n378:   const vectorSource = getActiveVectorSourceForQuery(database);\n379:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n380:     throw new VectorIndexError(\n381:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n382:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n383:     );\n384:   }\n385: \n386:   const query_buffer = to_embedding_buffer(query_embedding);\n387:   const max_distance = 2 * (1 - minSimilarity / 100);\n388: \n389:   // FSRS-preferred decay with half-life fallback\n390:   const decay_expr = useDecay\n391:     ? `CASE\n392:          WHEN m.is_pinned = 1 THEN m.importance_weight\n393:          WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n\n(Showing lines 224-393 of 1706. Use offset=394 to continue.)\n</content>","metadata":{"preview":"  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n\n/**\n * Gets one indexed memory by identifier.\n * @param id - The memory identifier.\n * @returns The matching memory row, if found.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const memory = get_memory(42);\n * ```\n */\nexport function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n  const stmts = init_prepared_statements(database);\n  const row = stmts.get_by_id.get(id);\n\n  if (row) {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n  }\n\n  return row || null;\n}\n\n/**\n * Gets indexed memories for a spec folder.\n * @param spec_folder - The spec folder to query.\n * @returns The memory rows for the folder.\n */\nexport function get_memories_by_folder(\n  spec_folder: string,\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const rows = database.prepare(`\n    SELECT m.*\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE (m.spec_folder = ? OR m.spec_folder LIKE ?)\n    ORDER BY m.created_at DESC\n  `).all(spec_folder, `${spec_folder}/%`) as MemoryRow[];\n\n  return rows.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/**\n * Gets the total number of indexed memories.\n * @returns The total memory count.\n */\nexport function get_memory_count(database: Database.Database = initialize_db()): number {\n  const stmts = init_prepared_statements(database);\n  const result = stmts.count_all.get();\n  return result?.count ?? 0;\n}\n\n/**\n * Gets memory counts grouped by embedding status.\n * @returns The counts for each embedding status.\n */\nexport function get_status_counts(\n  database: Database.Database = initialize_db(),\n): { pending: number; success: number; failed: number; retry: number; partial: number } {\n  const rows = database.prepare(`\n    SELECT m.embedding_status, COUNT(*) as count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    GROUP BY m.embedding_status\n  `).all();\n\n  // Include 'partial' status in counts.\n  const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n  for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n    if (row.embedding_status in counts) {\n      counts[row.embedding_status] = row.count;\n    }\n  }\n\n  return counts;\n}\n\n/**\n * Gets summary counts for indexed memories.\n * @returns The aggregate memory statistics.\n */\nexport function get_stats(\n  database: Database.Database = initialize_db(),\n): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n  const counts = get_status_counts(database);\n  const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n\n  return {\n    total,\n    ...counts\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories by vector similarity.\n * @param query_embedding - The query embedding to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const {\n    limit = 10,\n    specFolder = null,\n    minSimilarity = 0,\n    useDecay = true,\n    tier = null,\n    contextType = null,\n    includeConstitutional = true,\n    includeArchived = false\n  } = options;\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const query_buffer = to_embedding_buffer(query_embedding);\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  // FSRS-preferred decay with half-life fallback\n  const decay_expr = useDecay\n    ? `CASE\n         WHEN m.is_pinned = 1 THEN m.importance_weight\n         WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN","lineStart":224,"lineEnd":393,"totalLines":1706,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781151304277,"end":1781151304281}},"metadata":{"openai":{"itemId":"fc_0057ee78801644c8016a2a36483bac8191b497f20d9b43f0a2"}},"id":"prt_eb4e40a3b001MrbFnyxpcPl8YV","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3e7f1001Uvxcy5l1gLFGBH"}}
