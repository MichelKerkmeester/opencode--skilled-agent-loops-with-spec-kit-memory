{"type":"tool_use","timestamp":1784606358904,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_00_UW4q8j8oAqGEHQd1pomC7916","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/query-set.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/query-set.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Fixed Oracle Query Matrix                                               ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // A frozen matrix of retrieval requests that exercises each ranking path the\n6: // differential oracle must pin: structured-only, lexical FTS, facet filtering,\n7: // exclusions, vector-only, hybrid, channel-local degradation, exact-reuse\n8: // rights, and cursor pagination. The embedder is deterministic so the vector\n9: // lane reproduces byte-for-byte without a real embedding model.\n10: \n11: export const ORACLE_VECTOR_PROFILE = Object.freeze({\n12:   id: 'style-default-v1',\n13:   provider: 'external',\n14:   model: 'configured',\n15:   dimensions: 2,\n16:   configHash: 'style-default-v1',\n17: });\n18: \n19: /**\n20:  * Deterministically embed document text into a fixed two-dimensional vector.\n21:  *\n22:  * @param {string} text - Document text passed by the vector drain.\n23:  * @returns {number[]} A stable unit-basis vector.\n24:  */\n25: export function oracleEmbedder(text) {\n26:   return text.includes('Alpha Editorial') ? [1, 0] : [0, 1];\n27: }\n28: \n29: export const ORACLE_QUERY_SET = Object.freeze([\n30:   { name: 'structured-only', request: { text: '', requiredFacets: [] } },\n31:   { name: 'fts-text', request: { text: 'editorial serif' } },\n32:   { name: 'facet-filter', request: { text: 'motion animation transition kinetic', requiredFacets: ['warm-surface'] } },\n33:   { name: 'exclusions', request: { text: 'editorial serif interface', exclusions: ['motion'] } },\n34:   { name: 'vector-only', request: { queryVector: [1, 0], vectorProfile: 'style-default-v1', disableFts: true } },\n35:   { name: 'hybrid', request: { text: 'editorial serif', queryVector: [1, 0], vectorProfile: 'style-default-v1' } },\n36:   { name: 'degraded-disable-fts', request: { text: 'editorial serif', disableFts: true } },\n37:   { name: 'exact-reuse', request: { text: 'editorial', usage: 'exact-reuse' } },\n38:   {\n39:     name: 'paged',\n40:     request: { text: 'style reference', limit: 1 },\n41:     follow: (result) => ({ text: 'style reference', limit: 1, cursor: result.nextCursor }),\n42:   },\n43: ]);\n\n(End of file - total 43 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Fixed Oracle Query Matrix                                               ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A frozen matrix of retrieval requests that exercises each ranking path the\n// differential oracle must pin: structured-only, lexical FTS, facet filtering,\n// exclusions, vector-only, hybrid, channel-local degradation, exact-reuse\n// rights, and cursor pagination. The embedder is deterministic so the vector\n// lane reproduces byte-for-byte without a real embedding model.\n\nexport const ORACLE_VECTOR_PROFILE = Object.freeze({\n  id: 'style-default-v1',\n  provider: 'external',\n  model: 'configured',\n  dimensions: 2,\n  configHash: 'style-default-v1',\n});\n\n/**\n * Deterministically embed document text into a fixed two-dimensional vector.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/query-set.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Fixed Oracle Query Matrix                                               ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A frozen matrix of retrieval requests that exercises each ranking path the\n// differential oracle must pin: structured-only, lexical FTS, facet filtering,\n// exclusions, vector-only, hybrid, channel-local degradation, exact-reuse\n// rights, and cursor pagination. The embedder is deterministic so the vector\n// lane reproduces byte-for-byte without a real embedding model.\n\nexport const ORACLE_VECTOR_PROFILE = Object.freeze({\n  id: 'style-default-v1',\n  provider: 'external',\n  model: 'configured',\n  dimensions: 2,\n  configHash: 'style-default-v1',\n});\n\n/**\n * Deterministically embed document text into a fixed two-dimensional vector.\n *\n * @param {string} text - Document text passed by the vector drain.\n * @returns {number[]} A stable unit-basis vector.\n */\nexport function oracleEmbedder(text) {\n  return text.includes('Alpha Editorial') ? [1, 0] : [0, 1];\n}\n\nexport const ORACLE_QUERY_SET = Object.freeze([\n  { name: 'structured-only', request: { text: '', requiredFacets: [] } },\n  { name: 'fts-text', request: { text: 'editorial serif' } },\n  { name: 'facet-filter', request: { text: 'motion animation transition kinetic', requiredFacets: ['warm-surface'] } },\n  { name: 'exclusions', request: { text: 'editorial serif interface', exclusions: ['motion'] } },\n  { name: 'vector-only', request: { queryVector: [1, 0], vectorProfile: 'style-default-v1', disableFts: true } },\n  { name: 'hybrid', request: { text: 'editorial serif', queryVector: [1, 0], vectorProfile: 'style-default-v1' } },\n  { name: 'degraded-disable-fts', request: { text: 'editorial serif', disableFts: true } },\n  { name: 'exact-reuse', request: { text: 'editorial', usage: 'exact-reuse' } },\n  {\n    name: 'paged',\n    request: { text: 'style reference', limit: 1 },\n    follow: (result) => ({ text: 'style reference', limit: 1, cursor: result.nextCursor }),\n  },\n]);","lineStart":1,"lineEnd":43,"totalLines":43,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/oracle/query-set.mjs","time":{"start":1784606358895,"end":1784606358903}},"id":"prt_f82d3faee001QqSbazjq8ilPNM","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ed3a001dQxAQi6HjoUqXN"}}
{"type":"tool_use","timestamp":1784606359797,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"glob","callID":"call_01_qCRe6apggoCC52NDMLNA4059","state":{"status":"completed","input":{"pattern":"**/styles/_db/__tests__/*.test.mjs","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/operator.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/fixtures.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/judgments.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/indexer.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/schema.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/adapter.test.mjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/retrieval.test.mjs","metadata":{"count":10,"truncated":false},"title":".opencode/skills/sk-design","time":{"start":1784606359741,"end":1784606359794}},"id":"prt_f82d3fda0001q8GwUzrdpnIKP9","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ed3a001dQxAQi6HjoUqXN"}}
{"type":"tool_use","timestamp":1784606360658,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"grep","callID":"call_02_WxSCYUEPhZR1mXSi7X0q8437","state":{"status":"completed","input":{"pattern":"/design:","include":"*.md","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design"},"output":"Found 13 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/README.md:\n  Line 70: The canonical creation surface maps `/interface:{design,foundations,motion,audit,design-reference}` to the stable `interface`, `foundations`, `motion`, `audit`, and `md-generator` modes. All five commands share [`shared/creation-contract.md`](./shared/creation-contract.md). The former `/design:*` alias namespace is retired — `/interface:*` is the sole creation surface.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/SKILL.md:\n  Line 288: - Canonical commands: `/interface:design`, `/interface:foundations`, `/interface:motion`, `/interface:audit`, and `/interface:design-reference`. These are the sole public design command surface; the former `/design:*` alias namespace is retired.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/changelog/v1.4.3.0.md:\n  Line 8: > Covers the net cumulative change since v1.2.0.0's mode-local procedure operating model: the five `/design:*` commands moved to a router+assets shape, a sixth transport mode joined the registry, and the first-ever full manual execution of the playbook found and fixed a real routing/authoring-boundary defect for every mode.\n\n  Line 15: - Router+assets command shape for all five `/design:*` commands, mirroring the `speckit`/`create`/`deep` command family pattern: a thin router file plus `assets/design_<mode>_{auto,confirm,presentation}` files.\n\n  Line 27: - `command-metadata.json`'s `preferSiblingWhen` entries no longer present `/design:design-mcp-open-design` as a runnable sibling command; the transport has none.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/changelog/v1.6.0.0.md:\n  Line 26: - `/design:interface`, `/design:foundations`, `/design:motion`, `/design:audit` and `/design:md-generator` remain thin compatibility aliases.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/feature-catalog/creation-command-surface/interface-creation-commands.md:\n  Line 3: description: \"Five canonical /interface:* creation commands, one shared nine-stage contract, and additive /design:* compatibility aliases.\"\n\n  Line 20: The former `/design:{interface,foundations,motion,audit,md-generator}` commands remain thin compatibility aliases. The aliases are additive and preserve arguments while executing the canonical contracts in place.\n\n  Line 30: Compatibility metadata maps each `/design:*` alias one-to-one to a canonical `/interface:*` command. The alias layer does not create new modes, remove old consumers or change the stable mode roster.\n\n  Line 43: | `.opencode/commands/design/*.md` | Compatibility routers | Preserves the five `/design:*` aliases. |\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/feature-catalog/feature-catalog.md:\n  Line 201: `/interface:{design,foundations,motion,audit,design-reference}` maps to the unchanged `interface`, `foundations`, `motion`, `audit` and `md-generator` mode IDs. All five commands reference one shared nine-stage creation contract. The corresponding `/design:*` commands remain thin compatibility aliases.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/manual-testing-playbook.md:\n  Line 3: description: \"Lean manual scenarios for verifying the packet-012 style database (adapter modes, indexer, operator surface) and the /interface:* creation commands + /design:* aliases.\"\n\n  Line 29: | CMD-03 | `/design:*` aliases resolve to the canonical commands | Backward compatibility preserved | `commands/design/*.md` |\n","metadata":{"matches":13,"truncated":false},"title":"/design:","time":{"start":1784606360567,"end":1784606360656}},"id":"prt_f82d4011a001uyd0Ne8u5bDd7m","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ed3a001dQxAQi6HjoUqXN"}}
{"type":"step_finish","timestamp":1784606361258,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"id":"prt_f82d406a80013aeX6lUXHbBhVI","reason":"tool-calls","snapshot":"c3159b8fb1be7e72dbb3139c74e75c59f1854613","messageID":"msg_f82d3ed3a001dQxAQi6HjoUqXN","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","type":"step-finish","tokens":{"total":118161,"input":28745,"output":302,"reasoning":26,"cache":{"write":0,"read":89088}},"cost":0.013112379}}
{"type":"step_start","timestamp":1784606364059,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"id":"prt_f82d41195001zxcDV6ISZN5dgS","messageID":"msg_f82d408a6001ziYd5JSdTvS6bC","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","snapshot":"c3159b8fb1be7e72dbb3139c74e75c59f1854613","type":"step-start"}}
{"type":"tool_use","timestamp":1784606365998,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_00_LymvSPPEFJvwKQ6M1fsz3660","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Generation Manifest Tests                                                ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import assert from 'node:assert/strict';\n6: import { existsSync } from 'node:fs';\n7: import { mkdtemp, readdir, readFile, rm, writeFile } from 'node:fs/promises';\n8: import os from 'node:os';\n9: import path from 'node:path';\n10: import test from 'node:test';\n11: \n12: import { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\n13: import { buildStyleDatabase } from '../indexer.mjs';\n14: import { resolvePublishedDatabasePath, STYLE_DATABASE_POINTER_SUFFIX } from '../schema.mjs';\n15: import {\n16:   buildManifest,\n17:   hashArtifactFile,\n18:   pruneManifestGenerations,\n19:   readManifest,\n20:   resolveManifestArtifacts,\n21:   resolvePublishedTarget,\n22:   writeManifestPointer,\n23: } from '../generation-manifest.mjs';\n24: \n25: async function scratchDir() {\n26:   const base = await mkdtemp(path.join(os.tmpdir(), 'style-manifest-'));\n27:   return base;\n28: }\n29: \n30: async function writeArtifact(directory, file, bytes) {\n31:   await writeFile(path.join(directory, file), bytes);\n32:   const { sha256, bytes: byteLength } = await hashArtifactFile(path.join(directory, file));\n33:   return { role: file, file, sha256, bytes: byteLength };\n34: }\n35: \n36: test('a build publishes a manifest pointer that resolves every artifact', async (context) => {\n37:   const fixture = await createFixtureCorpus();\n38:   context.after(fixture.cleanup);\n39:   const databasePath = path.join(fixture.base, 'manifest-style.sqlite');\n40:   const built = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n41: \n42:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n43:   const manifest = await readManifest(pointerPath);\n44:   assert.equal(manifest.document.manifestVersion, 1);\n45:   assert.equal(manifest.generationHash, built.generationHash);\n46:   assert.equal(manifest.document.artifacts.sqlite.file, path.basename(built.generationDatabasePath));\n47:   assert.ok(manifest.document.artifacts.sqlite.sha256.startsWith('sha256:'));\n48:   assert.ok(Number.isInteger(manifest.document.artifacts.sqlite.bytes));\n49: \n50:   const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n51:   assert.equal(resolved.generationHash, built.generationHash);\n52:   assert.equal(resolved.legacy, false);\n53:   assert.ok(resolved.artifacts.sqlite.path.endsWith(path.basename(built.generationDatabasePath)));\n54: });\n55: \n56: test('an interrupted publish leaves the prior manifest fully readable', async (context) => {\n57:   const fixture = await createFixtureCorpus();\n58:   context.after(fixture.cleanup);\n59:   const databasePath = path.join(fixture.base, 'interrupted-style.sqlite');\n60:   const first = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n61: \n62:   const { appendDesignText } = await import('../../_engine/__tests__/fixtures.mjs');\n63:   await appendDesignText(fixture.root, 'alpha', 'An interrupted second generation.');\n64:   await assert.rejects(buildStyleDatabase({\n65:     corpusRoot: fixture.root,\n66:     databasePath,\n67:     failureInjector: ({ phase }) => {\n68:       if (phase === 'PUBLISH') throw new Error('simulated-pre-pointer-failure');\n69:     },\n70:   }), /simulated-pre-pointer-failure/);\n71: \n72:   assert.equal(resolvePublishedDatabasePath(databasePath), first.generationDatabasePath);\n73:   const resolved = await resolveManifestArtifacts(\n74:     `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`,\n75:     { verifyDigests: true },\n76:   );\n77:   assert.equal(resolved.generationHash, first.generationHash);\n78: });\n79: \n80: test('a multi-artifact manifest publishes and validates every artifact', async (context) => {\n81:   const directory = await scratchDir();\n82:   context.after(() => rm(directory, { recursive: true, force: true }));\n83:   const pointerPath = path.join(directory, 'style.sqlite.current.json');\n84: \n85:   const artifacts = {\n86:     sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'sqlite-gen1-bytes'),\n87:     screenshotFeatures: await writeArtifact(directory, 'style.features.gen1.bin', 'feature-gen1-bytes'),\n88:     modelProfiles: await writeArtifact(directory, 'style.models.gen1.json', '{\"profile\":\"gen1\"}'),\n89:   };\n90:   const manifest = buildManifest({\n91:     generationHash: 'sha256:gen1',\n92:     createdAt: '2026-01-01T00:00:00.000Z',\n93:     artifacts,\n94:   });\n95:   await writeManifestPointer(pointerPath, manifest);\n96: \n97:   const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n98:   assert.deepEqual(Object.keys(resolved.artifacts).sort(), ['modelProfiles', 'screenshotFeatures', 'sqlite']);\n99:   assert.equal(resolved.generationHash, 'sha256:gen1');\n100: });\n101: \n102: test('a tampered artifact fails digest verification', async (context) => {\n103:   const directory = await scratchDir();\n104:   context.after(() => rm(directory, { recursive: true, force: true }));\n105:   const pointerPath = path.join(directory, 'style.sqlite.current.json');\n106:   const artifacts = {\n107:     sqlite: await writeArtifact(directory, 'style.sqlite.sha256-genT.sqlite', 'original-bytes'),\n108:   };\n109:   await writeManifestPointer(pointerPath, buildManifest({\n110:     generationHash: 'sha256:genT',\n111:     createdAt: '2026-01-01T00:00:00.000Z',\n112:     artifacts,\n113:   }));\n114:   await writeFile(path.join(directory, 'style.sqlite.sha256-genT.sqlite'), 'tampered-bytes');\n115:   await assert.rejects(\n116:     resolveManifestArtifacts(pointerPath, { verifyDigests: true }),\n117:     (error) => error.code === 'generation-artifact-tampered',\n118:   );\n119: });\n120: \n121: test('an interrupted pointer flip is atomic and never leaves a temp file', async (context) => {\n122:   const directory = await scratchDir();\n123:   context.after(() => rm(directory, { recursive: true, force: true }));\n124:   const pointerPath = path.join(directory, 'style.sqlite.current.json');\n125: \n126:   const genOne = buildManifest({\n127:     generationHash: 'sha256:gen1',\n128:     createdAt: '2026-01-01T00:00:00.000Z',\n129:     artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'gen1') },\n130:   });\n131:   await writeManifestPointer(pointerPath, genOne);\n132: \n133:   const genTwo = buildManifest({\n134:     generationHash: 'sha256:gen2',\n135:     createdAt: '2026-01-02T00:00:00.000Z',\n136:     parentGenerationHash: 'sha256:gen1',\n137:     artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen2.sqlite', 'gen2') },\n138:   });\n139:   await assert.rejects(writeManifestPointer(pointerPath, genTwo, {\n140:     afterRename: () => { throw new Error('simulated-post-rename-failure'); },\n141:   }), /simulated-post-rename-failure/);\n142: \n143:   const manifest = await readManifest(pointerPath);\n144:   assert.ok(['sha256:gen1', 'sha256:gen2'].includes(manifest.generationHash));\n145:   assert.ok(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')));\n146:   const leftovers = (await readdir(directory)).filter((name) => name.includes('.tmp-'));\n147:   assert.deepEqual(leftovers, []);\n148: });\n149: \n150: test('retention prunes whole generations while keeping the retained set intact', async (context) => {\n151:   const directory = await scratchDir();\n152:   context.after(() => rm(directory, { recursive: true, force: true }));\n153: \n154:   const manifestFor = async (generation) => buildManifest({\n155:     generationHash: `sha256:${generation}`,\n156:     createdAt: '2026-01-01T00:00:00.000Z',\n157:     artifacts: {\n158:       sqlite: await writeArtifact(directory, `style.sqlite.sha256-${generation}.sqlite`, `${generation}-db`),\n159:       screenshotFeatures: await writeArtifact(directory, `style.features.${generation}.bin`, `${generation}-feat`),\n160:     },\n161:   });\n162:   const genOne = await manifestFor('gen1');\n163:   const genTwo = await manifestFor('gen2');\n164:   const genThree = await manifestFor('gen3');\n165: \n166:   const outcome = await pruneManifestGenerations({\n167:     directory,\n168:     retain: [genThree, genTwo],\n169:     prune: [genOne],\n170:   });\n171:   assert.deepEqual(outcome.removed.sort(), ['style.features.gen1.bin', 'style.sqlite.sha256-gen1.sqlite']);\n172:   assert.equal(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')), false);\n173:   assert.equal(existsSync(path.join(directory, 'style.features.gen1.bin')), false);\n174:   for (const generation of ['gen2', 'gen3']) {\n175:     assert.ok(existsSync(path.join(directory, `style.sqlite.sha256-${generation}.sqlite`)));\n176:     assert.ok(existsSync(path.join(directory, `style.features.${generation}.bin`)));\n177:   }\n178: });\n179: \n180: test('retention never removes an artifact shared with a retained manifest', async (context) => {\n181:   const directory = await scratchDir();\n182:   context.after(() => rm(directory, { recursive: true, force: true }));\n183:   const shared = await writeArtifact(directory, 'style.models.shared.json', '{\"shared\":true}');\n184:   const retained = buildManifest({\n185:     generationHash: 'sha256:keep',\n186:     createdAt: '2026-01-01T00:00:00.000Z',\n187:     artifacts: {\n188:       sqlite: await writeArtifact(directory, 'style.sqlite.sha256-keep.sqlite', 'keep'),\n189:       modelProfiles: shared,\n190:     },\n191:   });\n192:   const pruned = buildManifest({\n193:     generationHash: 'sha256:drop',\n194:     createdAt: '2026-01-01T00:00:00.000Z',\n195:     artifacts: {\n196:       sqlite: await writeArtifact(directory, 'style.sqlite.sha256-drop.sqlite', 'drop'),\n197:       modelProfiles: shared,\n198:     },\n199:   });\n200:   const outcome = await pruneManifestGenerations({ directory, retain: [retained], prune: [pruned] });\n201:   assert.deepEqual(outcome.removed, ['style.sqlite.sha256-drop.sqlite']);\n202:   assert.ok(existsSync(path.join(directory, 'style.models.shared.json')));\n203: });\n204: \n205: test('a legacy single-file pointer still resolves', async (context) => {\n206:   const directory = await scratchDir();\n207:   context.after(() => rm(directory, { recursive: true, force: true }));\n208:   const databasePath = path.join(directory, 'legacy.sqlite');\n209:   const generationFile = 'legacy.sqlite.sha256-legacy.sqlite';\n210:   await writeFile(path.join(directory, generationFile), 'legacy-db-bytes');\n211:   await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n212:     schemaVersion: 1,\n213:     generationHash: 'sha256:legacy',\n214:     databaseFile: generationFile,\n215:   }, null, 2)}\\n`);\n216: \n217:   const target = resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n218:   assert.equal(target.generationHash, 'sha256:legacy');\n219:   assert.equal(path.basename(target.databasePath), generationFile);\n220: \n221:   const manifest = await readManifest(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`);\n222:   assert.equal(manifest.legacy, true);\n223:   assert.equal(manifest.artifacts.sqlite.file, generationFile);\n224: });\n225: \n226: test('an invalid pointer shape is rejected', async (context) => {\n227:   const directory = await scratchDir();\n228:   context.after(() => rm(directory, { recursive: true, force: true }));\n229:   const databasePath = path.join(directory, 'broken.sqlite');\n230:   await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n231:     manifestVersion: 1,\n232:     generationHash: 'sha256:broken',\n233:     artifacts: { sqlite: { file: '../escape.sqlite' } },\n234:   })}\\n`);\n235:   assert.throws(\n236:     () => resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX),\n237:     (error) => error.code === 'generation-pointer-invalid',\n238:   );\n239: });\n\n(End of file - total 239 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation Manifest Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { existsSync } from 'node:fs';\nimport { mkdtemp, readdir, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { buildStyleDatabase } from '../indexer.mjs';\nimport { resolvePublishedDatabasePath, STYLE_DATABASE_POINTER_SUFFIX } from '../schema.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  pruneManifestGenerations,\n  readManifest,\n  resolveManifestArtifacts,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation Manifest Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { existsSync } from 'node:fs';\nimport { mkdtemp, readdir, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { buildStyleDatabase } from '../indexer.mjs';\nimport { resolvePublishedDatabasePath, STYLE_DATABASE_POINTER_SUFFIX } from '../schema.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  pruneManifestGenerations,\n  readManifest,\n  resolveManifestArtifacts,\n  resolvePublishedTarget,\n  writeManifestPointer,\n} from '../generation-manifest.mjs';\n\nasync function scratchDir() {\n  const base = await mkdtemp(path.join(os.tmpdir(), 'style-manifest-'));\n  return base;\n}\n\nasync function writeArtifact(directory, file, bytes) {\n  await writeFile(path.join(directory, file), bytes);\n  const { sha256, bytes: byteLength } = await hashArtifactFile(path.join(directory, file));\n  return { role: file, file, sha256, bytes: byteLength };\n}\n\ntest('a build publishes a manifest pointer that resolves every artifact', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const databasePath = path.join(fixture.base, 'manifest-style.sqlite');\n  const built = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const manifest = await readManifest(pointerPath);\n  assert.equal(manifest.document.manifestVersion, 1);\n  assert.equal(manifest.generationHash, built.generationHash);\n  assert.equal(manifest.document.artifacts.sqlite.file, path.basename(built.generationDatabasePath));\n  assert.ok(manifest.document.artifacts.sqlite.sha256.startsWith('sha256:'));\n  assert.ok(Number.isInteger(manifest.document.artifacts.sqlite.bytes));\n\n  const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n  assert.equal(resolved.generationHash, built.generationHash);\n  assert.equal(resolved.legacy, false);\n  assert.ok(resolved.artifacts.sqlite.path.endsWith(path.basename(built.generationDatabasePath)));\n});\n\ntest('an interrupted publish leaves the prior manifest fully readable', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const databasePath = path.join(fixture.base, 'interrupted-style.sqlite');\n  const first = await buildStyleDatabase({ corpusRoot: fixture.root, databasePath });\n\n  const { appendDesignText } = await import('../../_engine/__tests__/fixtures.mjs');\n  await appendDesignText(fixture.root, 'alpha', 'An interrupted second generation.');\n  await assert.rejects(buildStyleDatabase({\n    corpusRoot: fixture.root,\n    databasePath,\n    failureInjector: ({ phase }) => {\n      if (phase === 'PUBLISH') throw new Error('simulated-pre-pointer-failure');\n    },\n  }), /simulated-pre-pointer-failure/);\n\n  assert.equal(resolvePublishedDatabasePath(databasePath), first.generationDatabasePath);\n  const resolved = await resolveManifestArtifacts(\n    `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`,\n    { verifyDigests: true },\n  );\n  assert.equal(resolved.generationHash, first.generationHash);\n});\n\ntest('a multi-artifact manifest publishes and validates every artifact', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const pointerPath = path.join(directory, 'style.sqlite.current.json');\n\n  const artifacts = {\n    sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'sqlite-gen1-bytes'),\n    screenshotFeatures: await writeArtifact(directory, 'style.features.gen1.bin', 'feature-gen1-bytes'),\n    modelProfiles: await writeArtifact(directory, 'style.models.gen1.json', '{\"profile\":\"gen1\"}'),\n  };\n  const manifest = buildManifest({\n    generationHash: 'sha256:gen1',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts,\n  });\n  await writeManifestPointer(pointerPath, manifest);\n\n  const resolved = await resolveManifestArtifacts(pointerPath, { verifyDigests: true });\n  assert.deepEqual(Object.keys(resolved.artifacts).sort(), ['modelProfiles', 'screenshotFeatures', 'sqlite']);\n  assert.equal(resolved.generationHash, 'sha256:gen1');\n});\n\ntest('a tampered artifact fails digest verification', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const pointerPath = path.join(directory, 'style.sqlite.current.json');\n  const artifacts = {\n    sqlite: await writeArtifact(directory, 'style.sqlite.sha256-genT.sqlite', 'original-bytes'),\n  };\n  await writeManifestPointer(pointerPath, buildManifest({\n    generationHash: 'sha256:genT',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts,\n  }));\n  await writeFile(path.join(directory, 'style.sqlite.sha256-genT.sqlite'), 'tampered-bytes');\n  await assert.rejects(\n    resolveManifestArtifacts(pointerPath, { verifyDigests: true }),\n    (error) => error.code === 'generation-artifact-tampered',\n  );\n});\n\ntest('an interrupted pointer flip is atomic and never leaves a temp file', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const pointerPath = path.join(directory, 'style.sqlite.current.json');\n\n  const genOne = buildManifest({\n    generationHash: 'sha256:gen1',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen1.sqlite', 'gen1') },\n  });\n  await writeManifestPointer(pointerPath, genOne);\n\n  const genTwo = buildManifest({\n    generationHash: 'sha256:gen2',\n    createdAt: '2026-01-02T00:00:00.000Z',\n    parentGenerationHash: 'sha256:gen1',\n    artifacts: { sqlite: await writeArtifact(directory, 'style.sqlite.sha256-gen2.sqlite', 'gen2') },\n  });\n  await assert.rejects(writeManifestPointer(pointerPath, genTwo, {\n    afterRename: () => { throw new Error('simulated-post-rename-failure'); },\n  }), /simulated-post-rename-failure/);\n\n  const manifest = await readManifest(pointerPath);\n  assert.ok(['sha256:gen1', 'sha256:gen2'].includes(manifest.generationHash));\n  assert.ok(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')));\n  const leftovers = (await readdir(directory)).filter((name) => name.includes('.tmp-'));\n  assert.deepEqual(leftovers, []);\n});\n\ntest('retention prunes whole generations while keeping the retained set intact', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n\n  const manifestFor = async (generation) => buildManifest({\n    generationHash: `sha256:${generation}`,\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: {\n      sqlite: await writeArtifact(directory, `style.sqlite.sha256-${generation}.sqlite`, `${generation}-db`),\n      screenshotFeatures: await writeArtifact(directory, `style.features.${generation}.bin`, `${generation}-feat`),\n    },\n  });\n  const genOne = await manifestFor('gen1');\n  const genTwo = await manifestFor('gen2');\n  const genThree = await manifestFor('gen3');\n\n  const outcome = await pruneManifestGenerations({\n    directory,\n    retain: [genThree, genTwo],\n    prune: [genOne],\n  });\n  assert.deepEqual(outcome.removed.sort(), ['style.features.gen1.bin', 'style.sqlite.sha256-gen1.sqlite']);\n  assert.equal(existsSync(path.join(directory, 'style.sqlite.sha256-gen1.sqlite')), false);\n  assert.equal(existsSync(path.join(directory, 'style.features.gen1.bin')), false);\n  for (const generation of ['gen2', 'gen3']) {\n    assert.ok(existsSync(path.join(directory, `style.sqlite.sha256-${generation}.sqlite`)));\n    assert.ok(existsSync(path.join(directory, `style.features.${generation}.bin`)));\n  }\n});\n\ntest('retention never removes an artifact shared with a retained manifest', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const shared = await writeArtifact(directory, 'style.models.shared.json', '{\"shared\":true}');\n  const retained = buildManifest({\n    generationHash: 'sha256:keep',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: {\n      sqlite: await writeArtifact(directory, 'style.sqlite.sha256-keep.sqlite', 'keep'),\n      modelProfiles: shared,\n    },\n  });\n  const pruned = buildManifest({\n    generationHash: 'sha256:drop',\n    createdAt: '2026-01-01T00:00:00.000Z',\n    artifacts: {\n      sqlite: await writeArtifact(directory, 'style.sqlite.sha256-drop.sqlite', 'drop'),\n      modelProfiles: shared,\n    },\n  });\n  const outcome = await pruneManifestGenerations({ directory, retain: [retained], prune: [pruned] });\n  assert.deepEqual(outcome.removed, ['style.sqlite.sha256-drop.sqlite']);\n  assert.ok(existsSync(path.join(directory, 'style.models.shared.json')));\n});\n\ntest('a legacy single-file pointer still resolves', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const databasePath = path.join(directory, 'legacy.sqlite');\n  const generationFile = 'legacy.sqlite.sha256-legacy.sqlite';\n  await writeFile(path.join(directory, generationFile), 'legacy-db-bytes');\n  await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n    schemaVersion: 1,\n    generationHash: 'sha256:legacy',\n    databaseFile: generationFile,\n  }, null, 2)}\\n`);\n\n  const target = resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n  assert.equal(target.generationHash, 'sha256:legacy');\n  assert.equal(path.basename(target.databasePath), generationFile);\n\n  const manifest = await readManifest(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`);\n  assert.equal(manifest.legacy, true);\n  assert.equal(manifest.artifacts.sqlite.file, generationFile);\n});\n\ntest('an invalid pointer shape is rejected', async (context) => {\n  const directory = await scratchDir();\n  context.after(() => rm(directory, { recursive: true, force: true }));\n  const databasePath = path.join(directory, 'broken.sqlite');\n  await writeFile(`${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`, `${JSON.stringify({\n    manifestVersion: 1,\n    generationHash: 'sha256:broken',\n    artifacts: { sqlite: { file: '../escape.sqlite' } },\n  })}\\n`);\n  assert.throws(\n    () => resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX),\n    (error) => error.code === 'generation-pointer-invalid',\n  );\n});","lineStart":1,"lineEnd":239,"totalLines":239,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/__tests__/manifest.test.mjs","time":{"start":1784606365987,"end":1784606365994}},"id":"prt_f82d416190013p9lSSQz1roLEi","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d408a6001ziYd5JSdTvS6bC"}}
{"type":"tool_use","timestamp":1784606366532,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_01_JuT0PeiwsfWdNywJSf2t9577","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Stage Telemetry Tests                                                    ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import assert from 'node:assert/strict';\n6: import { readFile } from 'node:fs/promises';\n7: import path from 'node:path';\n8: import test from 'node:test';\n9: \n10: import { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\n11: import { stableJson } from '../canonical.mjs';\n12: import { indexStyleCorpus } from '../indexer.mjs';\n13: import { queryPersistentStyles } from '../retrieval.mjs';\n14: import { openStyleDatabase } from '../schema.mjs';\n15: import { RESIDENCY, createStageRecorder } from '../stage-telemetry.mjs';\n16: import {\n17:   DEFAULT_GOLDEN_DIR,\n18:   buildOracleDatabase,\n19: } from '../oracle/differential-oracle.mjs';\n20: import { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\n21: import { createIndexedFixture } from './fixtures.mjs';\n22: \n23: const RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n24: \n25: function deterministicRecorder() {\n26:   let clock = 0;\n27:   let rss = 1_000;\n28:   return createStageRecorder({\n29:     now: () => { const value = clock; clock += 5; return value; },\n30:     memory: () => { const value = rss; rss += 32; return value; },\n31:   });\n32: }\n33: \n34: function assertResidencyHonest(recorder) {\n35:   const records = recorder.records();\n36:   assert.ok(records.length > 0, 'expected at least one stage record');\n37:   for (const record of records) {\n38:     assert.ok(RESIDENCY_VALUES.has(record.residency), `unattributed residency: ${record.residency}`);\n39:     assert.equal(typeof record.latencyMs, 'number');\n40:     assert.equal(typeof record.rssDeltaBytes, 'number');\n41:     assert.ok(record.throughputPerSecond === null || typeof record.throughputPerSecond === 'number');\n42:   }\n43:   const summary = recorder.summary();\n44:   assert.equal(summary.native + summary.jsResident, summary.total);\n45:   assert.ok(summary.unattributedMs >= 0, 'unattributed cost must never be negative');\n46:   assert.ok(summary.elapsedMs + 1e-9 >= summary.total, 'elapsed must cover attributed span cost');\n47:   assert.equal(summary.unattributedMs, Math.max(0, summary.elapsedMs - summary.total));\n48:   assert.equal(summary.stageCount, records.length);\n49:   return { records, summary };\n50: }\n51: \n52: test('the recorder attributes every span to one residency bucket', () => {\n53:   const recorder = deterministicRecorder();\n54:   recorder.span('a', RESIDENCY.NATIVE).end(10);\n55:   recorder.span('b', RESIDENCY.JS_RESIDENT).end(20);\n56:   const [first, second] = recorder.records();\n57:   assert.equal(first.latencyMs, 5);\n58:   assert.equal(first.throughputPerSecond, (10 / 5) * 1_000);\n59:   assert.equal(first.rssDeltaBytes, 32);\n60:   assert.equal(second.residency, RESIDENCY.JS_RESIDENT);\n61:   const summary = recorder.summary();\n62:   assert.equal(summary.native, 5);\n63:   assert.equal(summary.jsResident, 5);\n64:   assert.equal(summary.total, 10);\n65:   // The two spans start five ticks apart, so the wall window is 15 while only\n66:   // 10 was bracketed: the recorder must surface the 5-tick gap, not hide it.\n67:   assert.equal(summary.elapsedMs, 15);\n68:   assert.equal(summary.unattributedMs, 5);\n69: });\n70: \n71: test('summary measures wall time an explicit overall timer leaves outside every span', () => {\n72:   let clock = 0;\n73:   const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n74:   const overall = recorder.overall();\n75:   clock = 100; // 100 ticks of work run before any span opens\n76:   const span = recorder.span('native-read', RESIDENCY.NATIVE);\n77:   clock = 130; // the span itself accounts for 30 ticks\n78:   span.end(1);\n79:   clock = 150; // 20 more ticks run after the span closes\n80:   overall.end();\n81:   const summary = recorder.summary();\n82:   assert.equal(summary.total, 30);\n83:   assert.equal(summary.native, 30);\n84:   assert.equal(summary.elapsedMs, 150);\n85:   assert.equal(summary.unattributedMs, 120);\n86: });\n87: \n88: test('summary attributes inter-span gaps to the unattributed bucket', () => {\n89:   let clock = 0;\n90:   const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n91:   const first = recorder.span('a', RESIDENCY.NATIVE);\n92:   clock = 10;\n93:   first.end(1);\n94:   clock = 40; // a 30-tick gap runs outside any span\n95:   const second = recorder.span('b', RESIDENCY.JS_RESIDENT);\n96:   clock = 55;\n97:   second.end(1);\n98:   const summary = recorder.summary();\n99:   assert.equal(summary.total, 25);\n100:   assert.equal(summary.elapsedMs, 55);\n101:   assert.equal(summary.unattributedMs, 30);\n102: });\n103: \n104: test('an unknown residency cannot be recorded', () => {\n105:   const recorder = createStageRecorder();\n106:   assert.throws(() => recorder.span('x', 'blended'), /Unknown telemetry residency/);\n107: });\n108: \n109: test('query telemetry brackets each native SQL and JS-resident step in its true bucket', async (context) => {\n110:   const { database } = await createIndexedFixture(context);\n111:   const recorder = createStageRecorder();\n112:   const withTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database, telemetry: recorder });\n113:   const { records, summary } = assertResidencyHonest(recorder);\n114:   const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n115: \n116:   // Steps the faked instrumentation ran outside every span (fingerprint digest,\n117:   // BEGIN/COMMIT, opaque encoding) are now bracketed with their real residency.\n118:   assert.equal(residencyByStage.get('request.fingerprint'), RESIDENCY.JS_RESIDENT);\n119:   assert.equal(residencyByStage.get('transaction.begin'), RESIDENCY.NATIVE);\n120:   assert.equal(residencyByStage.get('transaction.commit'), RESIDENCY.NATIVE);\n121:   assert.equal(residencyByStage.get('cards.attribution.encode'), RESIDENCY.JS_RESIDENT);\n122:   // Steps that used to bracket both SQL and JS under one label are split honestly.\n123:   assert.equal(residencyByStage.get('generation.read'), RESIDENCY.NATIVE);\n124:   assert.equal(residencyByStage.get('generation.verify'), RESIDENCY.JS_RESIDENT);\n125:   assert.equal(residencyByStage.get('eligibility.load'), RESIDENCY.NATIVE);\n126:   assert.equal(residencyByStage.get('eligibility.facets.load'), RESIDENCY.NATIVE);\n127:   assert.equal(residencyByStage.get('eligibility.facets.assemble'), RESIDENCY.JS_RESIDENT);\n128:   assert.ok(records.map((record) => record.stage).includes('lane.fts'));\n129:   assert.ok(summary.native >= 0 && summary.jsResident >= 0);\n130: \n131:   // Telemetry is a pure side-channel: the returned DTO must be byte-identical.\n132:   const withoutTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database });\n133:   assert.deepEqual(withTelemetry, withoutTelemetry);\n134:   assert.equal(stableJson(withTelemetry), stableJson(withoutTelemetry));\n135: });\n136: \n137: test('the vector lane splits its native fetch from JS-resident cosine work', async (context) => {\n138:   const { database } = await createIndexedFixture(context);\n139:   const { drainVectorQueue } = await import('../vectors.mjs');\n140:   await drainVectorQueue(database, {\n141:     profileId: 'style-default-v1',\n142:     embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n143:   });\n144:   const recorder = createStageRecorder();\n145:   queryPersistentStyles({\n146:     queryVector: [1, 0],\n147:     vectorProfile: 'style-default-v1',\n148:     disableFts: true,\n149:   }, { database, telemetry: recorder });\n150:   const stages = recorder.records().map((record) => record.stage);\n151:   assert.ok(stages.includes('lane.vector.fetch'));\n152:   assert.ok(stages.includes('lane.vector.cosine'));\n153:   const fetch = recorder.records().find((record) => record.stage === 'lane.vector.fetch');\n154:   const cosine = recorder.records().find((record) => record.stage === 'lane.vector.cosine');\n155:   assert.equal(fetch.residency, RESIDENCY.NATIVE);\n156:   assert.equal(cosine.residency, RESIDENCY.JS_RESIDENT);\n157: });\n158: \n159: test('telemetry-off leaves the retrieval DTO byte-identical to the oracle golden', async (context) => {\n160:   const fixture = await createFixtureCorpus();\n161:   context.after(fixture.cleanup);\n162:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n163:   context.after(() => database.close());\n164:   const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'fts-text');\n165:   const golden = (await readFile(path.join(DEFAULT_GOLDEN_DIR, 'fts-text.canonical.json'), 'utf8'))\n166:     .replace(/\\n$/, '');\n167: \n168:   const withoutTelemetry = queryPersistentStyles(scenario.request, { database });\n169:   assert.equal(\n170:     stableJson({ name: scenario.name, request: scenario.request, result: withoutTelemetry }),\n171:     golden,\n172:   );\n173: \n174:   const recorder = createStageRecorder();\n175:   const withTelemetry = queryPersistentStyles(scenario.request, { database, telemetry: recorder });\n176:   assert.equal(\n177:     stableJson({ name: scenario.name, request: scenario.request, result: withTelemetry }),\n178:     golden,\n179:   );\n180:   assert.ok(recorder.records().length > 0);\n181: });\n182: \n183: test('indexer telemetry brackets each stage over the work it names', async (context) => {\n184:   const fixture = await createFixtureCorpus();\n185:   context.after(fixture.cleanup);\n186:   const database = openStyleDatabase();\n187:   context.after(() => database.close());\n188:   const recorder = createStageRecorder();\n189:   const result = await indexStyleCorpus({\n190:     corpusRoot: fixture.root,\n191:     database,\n192:     corpusWalkMode: 'migration',\n193:     telemetry: recorder,\n194:   });\n195:   assert.equal(result.published, true);\n196:   const { records, summary } = assertResidencyHonest(recorder);\n197:   const stages = records.map((record) => record.stage);\n198:   assert.deepEqual(stages, [\n199:     'discover', 'snapshot.load', 'verify.parse', 'plan.hash', 'plan.load',\n200:     'commit.write', 'publish.missing', 'publish.write',\n201:   ]);\n202:   const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n203:   // Discovery, artifact verification/parse, and hashing run on the JS heap.\n204:   assert.equal(residencyByStage.get('discover'), RESIDENCY.JS_RESIDENT);\n205:   assert.equal(residencyByStage.get('verify.parse'), RESIDENCY.JS_RESIDENT);\n206:   assert.equal(residencyByStage.get('plan.hash'), RESIDENCY.JS_RESIDENT);\n207:   // The SQL snapshot, planning reads, and transaction writes stay native.\n208:   assert.equal(residencyByStage.get('snapshot.load'), RESIDENCY.NATIVE);\n209:   assert.equal(residencyByStage.get('plan.load'), RESIDENCY.NATIVE);\n210:   assert.equal(residencyByStage.get('commit.write'), RESIDENCY.NATIVE);\n211:   assert.equal(residencyByStage.get('publish.write'), RESIDENCY.NATIVE);\n212:   assert.equal(summary.native + summary.jsResident, summary.total);\n213: });\n214: \n215: test('indexer telemetry books the JS-heavy embedder drain as js-resident', async (context) => {\n216:   const fixture = await createFixtureCorpus();\n217:   context.after(fixture.cleanup);\n218:   const database = openStyleDatabase();\n219:   context.after(() => database.close());\n220:   const recorder = createStageRecorder();\n221:   const result = await indexStyleCorpus({\n222:     corpusRoot: fixture.root,\n223:     database,\n224:     corpusWalkMode: 'migration',\n225:     telemetry: recorder,\n226:     embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n227:   });\n228:   assert.equal(result.published, true);\n229:   const drain = recorder.records().find((record) => record.stage === 'vector.drain');\n230:   assert.ok(drain, 'expected a vector.drain span for the embedder drain');\n231:   assert.equal(drain.residency, RESIDENCY.JS_RESIDENT);\n232:   const publishWrite = recorder.records().find((record) => record.stage === 'publish.write');\n233:   assert.equal(publishWrite.residency, RESIDENCY.NATIVE);\n234: });\n\n(End of file - total 234 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Stage Telemetry Tests                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { readFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { RESIDENCY, createStageRecorder } from '../stage-telemetry.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n} from '../oracle/differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Stage Telemetry Tests                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { readFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { RESIDENCY, createStageRecorder } from '../stage-telemetry.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n} from '../oracle/differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\nimport { createIndexedFixture } from './fixtures.mjs';\n\nconst RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n\nfunction deterministicRecorder() {\n  let clock = 0;\n  let rss = 1_000;\n  return createStageRecorder({\n    now: () => { const value = clock; clock += 5; return value; },\n    memory: () => { const value = rss; rss += 32; return value; },\n  });\n}\n\nfunction assertResidencyHonest(recorder) {\n  const records = recorder.records();\n  assert.ok(records.length > 0, 'expected at least one stage record');\n  for (const record of records) {\n    assert.ok(RESIDENCY_VALUES.has(record.residency), `unattributed residency: ${record.residency}`);\n    assert.equal(typeof record.latencyMs, 'number');\n    assert.equal(typeof record.rssDeltaBytes, 'number');\n    assert.ok(record.throughputPerSecond === null || typeof record.throughputPerSecond === 'number');\n  }\n  const summary = recorder.summary();\n  assert.equal(summary.native + summary.jsResident, summary.total);\n  assert.ok(summary.unattributedMs >= 0, 'unattributed cost must never be negative');\n  assert.ok(summary.elapsedMs + 1e-9 >= summary.total, 'elapsed must cover attributed span cost');\n  assert.equal(summary.unattributedMs, Math.max(0, summary.elapsedMs - summary.total));\n  assert.equal(summary.stageCount, records.length);\n  return { records, summary };\n}\n\ntest('the recorder attributes every span to one residency bucket', () => {\n  const recorder = deterministicRecorder();\n  recorder.span('a', RESIDENCY.NATIVE).end(10);\n  recorder.span('b', RESIDENCY.JS_RESIDENT).end(20);\n  const [first, second] = recorder.records();\n  assert.equal(first.latencyMs, 5);\n  assert.equal(first.throughputPerSecond, (10 / 5) * 1_000);\n  assert.equal(first.rssDeltaBytes, 32);\n  assert.equal(second.residency, RESIDENCY.JS_RESIDENT);\n  const summary = recorder.summary();\n  assert.equal(summary.native, 5);\n  assert.equal(summary.jsResident, 5);\n  assert.equal(summary.total, 10);\n  // The two spans start five ticks apart, so the wall window is 15 while only\n  // 10 was bracketed: the recorder must surface the 5-tick gap, not hide it.\n  assert.equal(summary.elapsedMs, 15);\n  assert.equal(summary.unattributedMs, 5);\n});\n\ntest('summary measures wall time an explicit overall timer leaves outside every span', () => {\n  let clock = 0;\n  const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n  const overall = recorder.overall();\n  clock = 100; // 100 ticks of work run before any span opens\n  const span = recorder.span('native-read', RESIDENCY.NATIVE);\n  clock = 130; // the span itself accounts for 30 ticks\n  span.end(1);\n  clock = 150; // 20 more ticks run after the span closes\n  overall.end();\n  const summary = recorder.summary();\n  assert.equal(summary.total, 30);\n  assert.equal(summary.native, 30);\n  assert.equal(summary.elapsedMs, 150);\n  assert.equal(summary.unattributedMs, 120);\n});\n\ntest('summary attributes inter-span gaps to the unattributed bucket', () => {\n  let clock = 0;\n  const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n  const first = recorder.span('a', RESIDENCY.NATIVE);\n  clock = 10;\n  first.end(1);\n  clock = 40; // a 30-tick gap runs outside any span\n  const second = recorder.span('b', RESIDENCY.JS_RESIDENT);\n  clock = 55;\n  second.end(1);\n  const summary = recorder.summary();\n  assert.equal(summary.total, 25);\n  assert.equal(summary.elapsedMs, 55);\n  assert.equal(summary.unattributedMs, 30);\n});\n\ntest('an unknown residency cannot be recorded', () => {\n  const recorder = createStageRecorder();\n  assert.throws(() => recorder.span('x', 'blended'), /Unknown telemetry residency/);\n});\n\ntest('query telemetry brackets each native SQL and JS-resident step in its true bucket', async (context) => {\n  const { database } = await createIndexedFixture(context);\n  const recorder = createStageRecorder();\n  const withTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database, telemetry: recorder });\n  const { records, summary } = assertResidencyHonest(recorder);\n  const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n\n  // Steps the faked instrumentation ran outside every span (fingerprint digest,\n  // BEGIN/COMMIT, opaque encoding) are now bracketed with their real residency.\n  assert.equal(residencyByStage.get('request.fingerprint'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('transaction.begin'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('transaction.commit'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('cards.attribution.encode'), RESIDENCY.JS_RESIDENT);\n  // Steps that used to bracket both SQL and JS under one label are split honestly.\n  assert.equal(residencyByStage.get('generation.read'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('generation.verify'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('eligibility.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('eligibility.facets.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('eligibility.facets.assemble'), RESIDENCY.JS_RESIDENT);\n  assert.ok(records.map((record) => record.stage).includes('lane.fts'));\n  assert.ok(summary.native >= 0 && summary.jsResident >= 0);\n\n  // Telemetry is a pure side-channel: the returned DTO must be byte-identical.\n  const withoutTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database });\n  assert.deepEqual(withTelemetry, withoutTelemetry);\n  assert.equal(stableJson(withTelemetry), stableJson(withoutTelemetry));\n});\n\ntest('the vector lane splits its native fetch from JS-resident cosine work', async (context) => {\n  const { database } = await createIndexedFixture(context);\n  const { drainVectorQueue } = await import('../vectors.mjs');\n  await drainVectorQueue(database, {\n    profileId: 'style-default-v1',\n    embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n  });\n  const recorder = createStageRecorder();\n  queryPersistentStyles({\n    queryVector: [1, 0],\n    vectorProfile: 'style-default-v1',\n    disableFts: true,\n  }, { database, telemetry: recorder });\n  const stages = recorder.records().map((record) => record.stage);\n  assert.ok(stages.includes('lane.vector.fetch'));\n  assert.ok(stages.includes('lane.vector.cosine'));\n  const fetch = recorder.records().find((record) => record.stage === 'lane.vector.fetch');\n  const cosine = recorder.records().find((record) => record.stage === 'lane.vector.cosine');\n  assert.equal(fetch.residency, RESIDENCY.NATIVE);\n  assert.equal(cosine.residency, RESIDENCY.JS_RESIDENT);\n});\n\ntest('telemetry-off leaves the retrieval DTO byte-identical to the oracle golden', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'fts-text');\n  const golden = (await readFile(path.join(DEFAULT_GOLDEN_DIR, 'fts-text.canonical.json'), 'utf8'))\n    .replace(/\\n$/, '');\n\n  const withoutTelemetry = queryPersistentStyles(scenario.request, { database });\n  assert.equal(\n    stableJson({ name: scenario.name, request: scenario.request, result: withoutTelemetry }),\n    golden,\n  );\n\n  const recorder = createStageRecorder();\n  const withTelemetry = queryPersistentStyles(scenario.request, { database, telemetry: recorder });\n  assert.equal(\n    stableJson({ name: scenario.name, request: scenario.request, result: withTelemetry }),\n    golden,\n  );\n  assert.ok(recorder.records().length > 0);\n});\n\ntest('indexer telemetry brackets each stage over the work it names', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = openStyleDatabase();\n  context.after(() => database.close());\n  const recorder = createStageRecorder();\n  const result = await indexStyleCorpus({\n    corpusRoot: fixture.root,\n    database,\n    corpusWalkMode: 'migration',\n    telemetry: recorder,\n  });\n  assert.equal(result.published, true);\n  const { records, summary } = assertResidencyHonest(recorder);\n  const stages = records.map((record) => record.stage);\n  assert.deepEqual(stages, [\n    'discover', 'snapshot.load', 'verify.parse', 'plan.hash', 'plan.load',\n    'commit.write', 'publish.missing', 'publish.write',\n  ]);\n  const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n  // Discovery, artifact verification/parse, and hashing run on the JS heap.\n  assert.equal(residencyByStage.get('discover'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('verify.parse'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('plan.hash'), RESIDENCY.JS_RESIDENT);\n  // The SQL snapshot, planning reads, and transaction writes stay native.\n  assert.equal(residencyByStage.get('snapshot.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('plan.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('commit.write'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('publish.write'), RESIDENCY.NATIVE);\n  assert.equal(summary.native + summary.jsResident, summary.total);\n});\n\ntest('indexer telemetry books the JS-heavy embedder drain as js-resident', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = openStyleDatabase();\n  context.after(() => database.close());\n  const recorder = createStageRecorder();\n  const result = await indexStyleCorpus({\n    corpusRoot: fixture.root,\n    database,\n    corpusWalkMode: 'migration',\n    telemetry: recorder,\n    embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n  });\n  assert.equal(result.published, true);\n  const drain = recorder.records().find((record) => record.stage === 'vector.drain');\n  assert.ok(drain, 'expected a vector.drain span for the embedder drain');\n  assert.equal(drain.residency, RESIDENCY.JS_RESIDENT);\n  const publishWrite = recorder.records().find((record) => record.stage === 'publish.write');\n  assert.equal(publishWrite.residency, RESIDENCY.NATIVE);\n});","lineStart":1,"lineEnd":234,"totalLines":234,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs","time":{"start":1784606366524,"end":1784606366530}},"id":"prt_f82d41932001tC73rvB2PVfpA9","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d408a6001ziYd5JSdTvS6bC"}}
{"type":"tool_use","timestamp":1784606367437,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"bash","callID":"call_02_0N6AHceHBXKbk7kylHE28242","state":{"status":"completed","input":{"command":"ls \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/commands/design/\" 2>&1 || echo \"DIRECTORY_NOT_FOUND\"","description":"Check if commands/design/ still exists"},"output":"ls: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/commands/design/: No such file or directory\nDIRECTORY_NOT_FOUND\n","metadata":{"output":"ls: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/commands/design/: No such file or directory\nDIRECTORY_NOT_FOUND\n","exit":0,"truncated":false},"title":"ls \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/commands/design/\" 2>&1 || echo \"DIRECTORY_NOT_FOUND\"","time":{"start":1784606367433,"end":1784606367435}},"id":"prt_f82d41b940014SOnbKysdWQQ4a","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d408a6001ziYd5JSdTvS6bC"}}
{"type":"tool_use","timestamp":1784606368199,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_03_onxo53xXFGjtj9EhGY5C9290","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs","limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Differential Oracle Tests                                                ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import assert from 'node:assert/strict';\n6: import { mkdtemp, readFile, rm, writeFile } from 'node:fs/promises';\n7: import os from 'node:os';\n8: import path from 'node:path';\n9: import test from 'node:test';\n10: \n11: import { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\n12: import { stableJson } from '../canonical.mjs';\n13: import {\n14:   DEFAULT_GOLDEN_DIR,\n15:   buildOracleDatabase,\n16:   canonicalizeSnapshot,\n17:   captureOracle,\n18:   freezeOracle,\n19:   listGoldenScenarios,\n20:   replayOracle,\n21:   snapshotScenario,\n22: } from '../oracle/differential-oracle.mjs';\n23: import { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\n24: import {\n25:   REPLAY_SCALES,\n26:   buildScaledOracleDatabase,\n27:   captureScaleOracle,\n28:   materializeReplayCorpus,\n29: } from '../oracle/replay-fixtures.mjs';\n30: import { queryPersistentStyles } from '../retrieval.mjs';\n31: \n32: async function goldenScratch() {\n33:   return mkdtemp(path.join(os.tmpdir(), 'style-oracle-golden-'));\n34: }\n35: \n36: async function loadScaleGolden() {\n37:   return JSON.parse(await readFile(path.join(DEFAULT_GOLDEN_DIR, 'scales.json'), 'utf8'));\n38: }\n39: \n40: function scenarioRequest(name) {\n41:   return ORACLE_QUERY_SET.find((scenario) => scenario.name === name).request;\n42: }\n43: \n44: test('replay reproduces the committed golden bytes for every scenario', async (context) => {\n45:   const fixture = await createFixtureCorpus();\n46:   context.after(fixture.cleanup);\n47:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n48:   context.after(() => database.close());\n49:   const outcome = await replayOracle({ database });\n50:   assert.equal(outcome.ok, true, JSON.stringify(outcome.mismatches));\n51:   assert.equal(outcome.captures.length, ORACLE_QUERY_SET.length);\n52: });\n53: \n54: test('freeze then replay round-trips in an isolated golden directory', async (context) => {\n55:   const fixture = await createFixtureCorpus();\n56:   context.after(fixture.cleanup);\n57:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n58:   context.after(() => database.close());\n59:   const goldenDir = await goldenScratch();\n60:   context.after(() => rm(goldenDir, { recursive: true, force: true }));\n61: \n62:   const frozen = await freezeOracle({ database, goldenDir });\n63:   assert.equal(frozen.length, ORACLE_QUERY_SET.length);\n64:   assert.deepEqual(await listGoldenScenarios(goldenDir), ORACLE_QUERY_SET.map((s) => s.name).sort());\n65: \n66:   const replay = await replayOracle({ database, goldenDir });\n67:   assert.equal(replay.ok, true, JSON.stringify(replay.mismatches));\n68: });\n69: \n70: test('a byte perturbation in a golden file fails the oracle', async (context) => {\n71:   const fixture = await createFixtureCorpus();\n72:   context.after(fixture.cleanup);\n73:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n74:   context.after(() => database.close());\n75:   const goldenDir = await goldenScratch();\n76:   context.after(() => rm(goldenDir, { recursive: true, force: true }));\n77: \n78:   await freezeOracle({ database, goldenDir });\n79:   const targetPath = path.join(goldenDir, 'fts-text.canonical.json');\n80:   const original = await readFile(targetPath, 'utf8');\n81:   await writeFile(targetPath, original.replace('\"ok\":true', '\"ok\":false'));\n82: \n83:   const replay = await replayOracle({ database, goldenDir });\n84:   assert.equal(replay.ok, false);\n85:   assert.deepEqual(replay.mismatches, [{ name: 'fts-text', reason: 'byte-mismatch', sha256: replay.captures.find((c) => c.name === 'fts-text').sha256 }]);\n86: });\n87: \n88: test('a missing golden file is reported rather than silently passing', async (context) => {\n89:   const fixture = await createFixtureCorpus();\n90:   context.after(fixture.cleanup);\n91:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n92:   context.after(() => database.close());\n93:   const goldenDir = await goldenScratch();\n94:   context.after(() => rm(goldenDir, { recursive: true, force: true }));\n95: \n96:   const replay = await replayOracle({ database, goldenDir });\n97:   assert.equal(replay.ok, false);\n98:   assert.equal(replay.mismatches.length, ORACLE_QUERY_SET.length);\n99:   assert.ok(replay.mismatches.every((mismatch) => mismatch.reason === 'missing-golden'));\n100: });\n101: \n102: test('an ordering or tie-break change alters the canonical bytes', async (context) => {\n103:   const fixture = await createFixtureCorpus();\n104:   context.after(fixture.cleanup);\n105:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n106:   context.after(() => database.close());\n107:   const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'structured-only');\n108:   const snapshot = snapshotScenario(database, scenario);\n109:   const canonical = canonicalizeSnapshot(snapshot);\n110:   const perturbed = {\n111:     ...snapshot,\n112:     result: { ...snapshot.result, cards: [...snapshot.result.cards].reverse() },\n113:   };\n114:   assert.notEqual(stableJson(perturbed), canonical.canonical);\n115:   assert.ok(snapshot.result.cards.length >= 2, 'perturbation requires at least two cards');\n116: });\n117: \n118: test('every capture reuses the shared canonicalizer for a stable digest', async (context) => {\n119:   const fixture = await createFixtureCorpus();\n120:   context.after(fixture.cleanup);\n\n(Showing lines 1-120 of 157. Use offset=121 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Differential Oracle Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { mkdtemp, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n  canonicalizeSnapshot,\n  captureOracle,\n  freezeOracle,\n  listGoldenScenarios,\n  replayOracle,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Differential Oracle Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { mkdtemp, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n  canonicalizeSnapshot,\n  captureOracle,\n  freezeOracle,\n  listGoldenScenarios,\n  replayOracle,\n  snapshotScenario,\n} from '../oracle/differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\nimport {\n  REPLAY_SCALES,\n  buildScaledOracleDatabase,\n  captureScaleOracle,\n  materializeReplayCorpus,\n} from '../oracle/replay-fixtures.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\n\nasync function goldenScratch() {\n  return mkdtemp(path.join(os.tmpdir(), 'style-oracle-golden-'));\n}\n\nasync function loadScaleGolden() {\n  return JSON.parse(await readFile(path.join(DEFAULT_GOLDEN_DIR, 'scales.json'), 'utf8'));\n}\n\nfunction scenarioRequest(name) {\n  return ORACLE_QUERY_SET.find((scenario) => scenario.name === name).request;\n}\n\ntest('replay reproduces the committed golden bytes for every scenario', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const outcome = await replayOracle({ database });\n  assert.equal(outcome.ok, true, JSON.stringify(outcome.mismatches));\n  assert.equal(outcome.captures.length, ORACLE_QUERY_SET.length);\n});\n\ntest('freeze then replay round-trips in an isolated golden directory', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const goldenDir = await goldenScratch();\n  context.after(() => rm(goldenDir, { recursive: true, force: true }));\n\n  const frozen = await freezeOracle({ database, goldenDir });\n  assert.equal(frozen.length, ORACLE_QUERY_SET.length);\n  assert.deepEqual(await listGoldenScenarios(goldenDir), ORACLE_QUERY_SET.map((s) => s.name).sort());\n\n  const replay = await replayOracle({ database, goldenDir });\n  assert.equal(replay.ok, true, JSON.stringify(replay.mismatches));\n});\n\ntest('a byte perturbation in a golden file fails the oracle', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const goldenDir = await goldenScratch();\n  context.after(() => rm(goldenDir, { recursive: true, force: true }));\n\n  await freezeOracle({ database, goldenDir });\n  const targetPath = path.join(goldenDir, 'fts-text.canonical.json');\n  const original = await readFile(targetPath, 'utf8');\n  await writeFile(targetPath, original.replace('\"ok\":true', '\"ok\":false'));\n\n  const replay = await replayOracle({ database, goldenDir });\n  assert.equal(replay.ok, false);\n  assert.deepEqual(replay.mismatches, [{ name: 'fts-text', reason: 'byte-mismatch', sha256: replay.captures.find((c) => c.name === 'fts-text').sha256 }]);\n});\n\ntest('a missing golden file is reported rather than silently passing', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const goldenDir = await goldenScratch();\n  context.after(() => rm(goldenDir, { recursive: true, force: true }));\n\n  const replay = await replayOracle({ database, goldenDir });\n  assert.equal(replay.ok, false);\n  assert.equal(replay.mismatches.length, ORACLE_QUERY_SET.length);\n  assert.ok(replay.mismatches.every((mismatch) => mismatch.reason === 'missing-golden'));\n});\n\ntest('an ordering or tie-break change alters the canonical bytes', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'structured-only');\n  const snapshot = snapshotScenario(database, scenario);\n  const canonical = canonicalizeSnapshot(snapshot);\n  const perturbed = {\n    ...snapshot,\n    result: { ...snapshot.result, cards: [...snapshot.result.cards].reverse() },\n  };\n  assert.notEqual(stableJson(perturbed), canonical.canonical);\n  assert.ok(snapshot.result.cards.length >= 2, 'perturbation requires at least two cards');\n});\n\ntest('every capture reuses the shared canonicalizer for a stable digest', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);","lineStart":1,"lineEnd":120,"totalLines":157,"truncated":true}},"title":".opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs","time":{"start":1784606368193,"end":1784606368197}},"id":"prt_f82d41f18001etFDusc98sZcGN","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d408a6001ziYd5JSdTvS6bC"}}
