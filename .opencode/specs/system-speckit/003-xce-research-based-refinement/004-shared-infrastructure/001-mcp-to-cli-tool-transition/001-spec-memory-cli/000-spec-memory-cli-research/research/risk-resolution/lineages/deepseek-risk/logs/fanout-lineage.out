:   writeOwnerLeaseFile(lease);\n393:   const reread = readOwnerLeaseFile(currentOwnerLeasePath);\n394:   if (!reread || reread.ownerPid !== process.pid) {\n395:     return {\n396:       acquired: false,\n397:       holder: reread || lease,\n398:       classification: reread ? classifyOwnerLease(reread) : 'live-owner',\n399:     };\n400:   }\n401:   ownerLeasePid = process.pid;\n402:   return { acquired: true, lease, reclaimed: existing };\n403: }\n404: \n405: function refreshOwnerLeaseFile(ownerPid, patch = {}) {\n406:   const lease = readOwnerLeaseFile();\n407:   if (!lease || lease.ownerPid !== ownerPid) return false;\n408:   const nextOwnerPid = patch.ownerPid ?? ownerPid;\n409:   writeOwnerLeaseFile({\n410:     ...lease,\n411:     ...patch,\n412:     lastHeartbeatIso: new Date().toISOString(),\n413:   });\n414:   const reread = readOwnerLeaseFile();\n415:   if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n416:   ownerLeasePid = nextOwnerPid;\n417:   return true;\n418: }\n419: \n420: function clearOwnerLeaseHeartbeat() {\n421:   if (ownerLeaseHeartbeatTimer) {\n422:     clearInterval(ownerLeaseHeartbeatTimer);\n423:     ownerLeaseHeartbeatTimer = null;\n424:   }\n425: }\n426: \n427: function startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n428:   clearOwnerLeaseHeartbeat();\n429:   const lease = readOwnerLeaseFile();\n430:   const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n431:   const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n432:   ownerLeaseHeartbeatTimer = setInterval(() => {\n433:     if (refreshOwnerLeaseFile(ownerPid)) return;\n434:     log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n435:     clearOwnerLeaseHeartbeat();\n436:     void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n437:       log(error.stack || error.message);\n438:       clearAllLeaseFiles();\n439:       process.exit(128);\n440:     });\n441:   }, intervalMs);\n442:   ownerLeaseHeartbeatTimer.unref?.();\n443: }\n444: \n445: function ownsOwnerLeaseFile(ownerPid = process.pid) {\n446:   const lease = readOwnerLeaseFile();\n447:   return lease?.ownerPid === ownerPid;\n448: }\n449: \n450: function clearOwnerLeaseFile() {\n451:   if (!Number.isInteger(ownerLeasePid)) return;\n452:   try {\n453:     const lease = readOwnerLeaseFile();\n454:     if (lease && lease.ownerPid === ownerLeasePid\n455:         && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n456:       fs.unlinkSync(ownerLeasePath());\n457:     }\n458:   } catch {\n459:     // Idempotent cleanup.\n460:   } finally {\n461:     clearOwnerLeaseHeartbeat();\n462:     ownerLeasePid = null;\n463:   }\n464: }\n465: \n466: function clearOwnerLeaseFileIfOwner(ownerPid) {\n467:   try {\n468:     const lease = readOwnerLeaseFile();\n469:     if (lease && lease.ownerPid === ownerPid\n470:         && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n471:       fs.unlinkSync(ownerLeasePath());\n472:     }\n473:   } catch {\n474:     // Idempotent cleanup.\n475:   }\n476: }\n477: \n478: function leaseHeldFromFile(filePath, legacyPath = null) {\n479:   const lease = readLeaseFile(filePath);\n480:   if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };\n481:   const startedAt = lease.startedAt ?? new Date(0).toISOString();\n482:   // Surface the owner-recorded socket path so the bridge can prefer it over recomputing one that\n483:   // may diverge under a different SPECKIT_IPC_SOCKET_DIR. Null when the lease predates this field.\n484:   const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;\n485:   try {\n486:     process.kill(lease.pid, 0);\n487:     return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n488:   } catch (error) {\n489:     if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };\n490:     // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n491:     if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n492:     throw error;\n493:   }\n494: }\n495: \n496: function isLeaseHeld() {\n497:   const primary = leaseHeldFromFile(leasePath());\n498:   if (primary.held) return primary;\n499: \n500:   for (const legacyPath of legacyLeasePaths()) {\n501:     if (legacyPath === leasePath()) continue;\n502:     const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n503:     if (legacy.held || legacy.staleReclaimable) return legacy;\n504:   }\n505: \n506:   return primary;\n507: }\n508: \n509: function writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n510:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n511:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n512:   process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n513: }\n514: \n515: function writeLeaseHeldJsonRpcError(leaseResult, reason) {\n516:   process.stdout.write(`${JSON.stringify({\n517:     jsonrpc: '2.0',\n518:     id: null,\n519:     error: {\n520:       code: -32001,\n521:       message: `mk-spec-memory: lease held by pid ${leaseResult.ownerPid} but session bridge unavailable (${reason}); reconnect`,\n522:       data: { retryable: true },\n523:     },\n524:   })}\\n`);\n525: }\n526: \n527: function bridgeReadiness(leaseResult) {\n528:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n529:     return { ready: false, reason: 'bridge-disabled' };\n530:   }\n531:   const storedSocketPath = leaseResult.socketPath;\n532:   if (\n533:     typeof storedSocketPath === 'string' &&\n534:     storedSocketPath.length > 0 &&\n535:     (storedSocketPath.startsWith('tcp