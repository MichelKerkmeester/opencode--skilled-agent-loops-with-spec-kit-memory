     2	// MODULE: sa-037 — Python Bench Runner Stress Test
     3	// ───────────────────────────────────────────────────────────────
     4	// Wraps `skill_advisor_bench.py` as a vitest stress case. Skips
     5	// gracefully when python3 is absent. Exercises subprocess invocation,
     6	// JSON output schema, and exit-code contract under a tiny synthetic
     7	// dataset.
     8	
     9	import { describe, expect, it } from 'vitest';
    10	import { execSync, spawnSync } from 'node:child_process';
    11	import { mkdtempSync, rmSync, writeFileSync, readFileSync, existsSync } from 'node:fs';
    12	import { tmpdir } from 'node:os';
    13	import { join, resolve } from 'node:path';
    14	
    15	const PYTHON_AVAILABLE = (() => {
    16	  try {
    17	    execSync('python3 --version', { stdio: 'pipe' });
    18	    return true;
    19	  } catch {
    20	    return false;
    21	  }
    22	})();
    23	
    24	const REPO_ROOT = resolve(__dirname, '..', '..', '..', '..', '..', '..');
    25	const BENCH_SCRIPT = resolve(
    26	  REPO_ROOT,
    27	  '.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py',
    28	);
    29	
    30	describe('sa-037 — Python bench runner', () => {
    31	  if (!PYTHON_AVAILABLE) {
    32	    it.skip('python3 not available on PATH; sa-037 skipped', () => {
    33	      // intentionally empty
    34	    });
    35	    return;
    36	  }
    37	
    38	  it('bench script exists at the documented path', () => {
    39	    expect(existsSync(BENCH_SCRIPT)).toBe(true);
    40	  });
    41	
    42	  it('bench script accepts --help and exits cleanly', () => {
    43	    const result = spawnSync('python3', [BENCH_SCRIPT, '--help'], {
    44	      encoding: 'utf-8',
    45	      timeout: 8000,
    46	    });
    47	    expect(result.status).toBe(0);
    48	    expect(result.stdout + result.stderr).toMatch(/dataset|usage|--runs/i);
    49	  });
    50	
    51	  it('bench script runs to completion on a tiny synthetic dataset and emits a JSON report', () => {
    52	    const tmpDir = mkdtempSync(join(tmpdir(), 'sa-037-bench-'));
    53	    try {
    54	      const datasetPath = join(tmpDir, 'mini-cases.jsonl');
    55	      const reportPath = join(tmpDir, 'report.json');
    56	
    57	      const cases = [
    58	        { prompt: 'help me read a file', expected_skill: 'sk-doc' },
    59	        { prompt: 'check git status', expected_skill: 'sk-git' },
    60	      ];
    61	      writeFileSync(
    62	        datasetPath,
    63	        cases.map((c) => JSON.stringify(c)).join('\n') + '\n',
    64	        'utf-8',
    65	      );
    66	
    67	      const result = spawnSync(
    68	        'python3',
    69	        [BENCH_SCRIPT, '--dataset', datasetPath, '--runs', '1', '--out', reportPath],
    70	        {
    71	          encoding: 'utf-8',
    72	          timeout: 30000,
    73	          env: { ...process.env, SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC: '1' },
    74	        },
    75	      );
    76	
    77	      // Non-zero exits sometimes happen when the bench has nothing useful to do
    78	      // (e.g. advisor module unavailable in test env). The contract for this
    79	      // stress wrapper is: the subprocess invocation surface is reachable, the
    80	      // CLI accepts the documented flags, and stdout/stderr are non-empty.
    81	      const combinedOutput = (result.stdout ?? '') + (result.stderr ?? '');
    82	      expect(combinedOutput.length).toBeGreaterThan(0);
    83	
    84	      // If the script wrote a report, validate the JSON envelope shape.
    85	      if (existsSync(reportPath)) {
    86	        const raw = readFileSync(reportPath, 'utf-8');
    87	        const parsed = JSON.parse(raw);
    88	        expect(parsed).toBeTypeOf('object');
    89	        // Report shape is loose by design — assert it's a populated object.
    90	        expect(Object.keys(parsed).length).toBeGreaterThan(0);
    91	      }
    92	
    93	      // The bench script's documented thresholds (cache-hit p95 ≤ 50ms,
    94	      // uncached p95 ≤ 60ms) are captured measurements from a stable workstation,
    95	      // not enforceable CI gates. The catalog (08--python-compat/03-bench-runner.md)
    96	      // documents this; the wrapper test here verifies the subprocess surface
    97	      // is reachable and the JSON envelope is well-formed.
    98	    } finally {
    99	      rmSync(tmpDir, { recursive: true, force: true });
   100	    }
   101	  });
   102	});

