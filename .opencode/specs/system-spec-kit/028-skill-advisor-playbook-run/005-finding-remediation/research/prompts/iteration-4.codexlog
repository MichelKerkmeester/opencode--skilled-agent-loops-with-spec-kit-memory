   422	async function buildBrief(input, dependencies = {}) {
   423	  const env = dependencies.env ?? process.env;
   424	  if (env[DISABLED_ENV] === '1') {
   425	    // F-006-B1-02: Silent fail-open in disabled mode. Previously this branch
   426	    // returned a model-visible `Advisor: disabled by ...` brief, but every
   427	    // other runtime (Codex, Claude, Copilot, Gemini) fails open silently when
   428	    // the disabled flag is set. Aligning OpenCode with the dominant pattern
   429	    // removes the runtime-specific surface inconsistency. Callers can still
   430	    // detect the disabled state via `metadata.route === 'disabled'`.
   431	    return response({
   432	      brief: null,
   433	      status: 'skipped',
   434	      metadata: {
   435	        route: 'disabled',
   436	        freshness: 'unavailable',
   437	        recommendationCount: 0,
   438	      },
   439	    });
   440	  }
   441	
   442	  try {
   443	    const probe = await probeNativeAdvisor(input, dependencies);
   444	    if (probe.available) {
   445	      return await buildNativeBrief({ ...input, probe }, dependencies);
   446	    }
   447	    if (input.forceNative === true) {
   448	      return failOpen(probe.reason || 'NATIVE_UNAVAILABLE');
   449	    }
   450	  } catch {
   451	    if (input.forceNative === true) {
   452	      return failOpen('NATIVE_PROBE_FAILED');
   453	    }
   454	  }
   455	
   456	  return buildLegacyBrief(input);
   457	}
