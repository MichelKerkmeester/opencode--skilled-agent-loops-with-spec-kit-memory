and effective","ruledOutReason":"pattern-length and input-length caps both enforced"},{"id":"SL-6-5","dimension":"security","targetRefs":[".opencode/skills/deep-agent-improvement/scripts/model-benchmark/dispatch-model.cjs"],"bugClass":"privilege_escalation_write_default","invariant":"executors default to read-only mode unless DEEP_AGENT_DISPATCH_WRITE=1","searchActions":[{"method":"direct_read","queryOrPath":"dispatch-model.cjs:54-57,189-230","result":"writeCapableOptIn gates write-capable mode; codex read-only sandbox, claude plan, gemini omits -y, devin auto, opencode no write-grant by default","evidenceRefs":[".opencode/skills/deep-agent-improvement/scripts/model-benchmark/dispatch-model.cjs:189"]}],"disposition":"ruled_out","rationale":"F-P1-1 read-only default holds across all executors","ruledOutReason":"verified read-only flags on every branch plus cwd-for-all at line 265"}]}
