: args.jobId },\n89:       recovery: {\n90:         hint: 'Verify the jobId and retry.',\n91:         actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   return createMCPSuccessResponse({\n98:     tool: 'memory_index_scan_status',\n99:     summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n100:     data: mapScanJobForResponse(job),\n101:   });\n102: }\n103: \n104: async function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n105:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n106:   await checkDatabaseUpdated();\n107: \n108:   if (!args.jobId || typeof args.jobId !== 'string') {\n109:     throw new Error('jobId is required and must be a string');\n110:   }\n111: \n112:   const job = getScanJob(args.jobId);\n113:   if (!job) {\n114:     return createMCPErrorResponse({\n115:       tool: 'memory_index_scan_cancel',\n116:       error: `Index scan job not found: ${args.jobId}`,\n117:       code: 'E404',\n118:       details: { jobId: args.jobId },\n119:       recovery: {\n120:         hint: 'Verify the jobId and retry.',\n121:         actions: ['Call memory_index_scan_status with a known jobId'],\n122:         severity: 'warning',\n123:       },\n124:     });\n125:   }\n126: \n127:   if (isTerminalJobState(job.state)) {\n128:     return createMCPSuccessResponse({\n129:       tool: 'memory_index_scan_cancel',\n130:       summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n131:       data: mapScanJobForResponse(job),\n132:     });\n133:   }\n134: \n135:   await requestCancel(args.jobId);\n136:   const updated = getScanJob(args.jobId) ?? job;\n137: \n138:   return createMCPSuccessResponse({\n139:     tool: 'memory_index_scan_cancel',\n140:     summary: `Cancellation requested for index scan job ${updated.id}`,\n141:     data: mapScanJobForResponse(updated),\n142:   });\n143: }\n144: \n145: /* ───────────────────────────────────────────────────────────────\n146:    5. EXPORTS\n147: ──────────────────────────────────────────────────────────────── */\n148: \n149: const handle_memory_index_scan_status = handleMemoryIndexScanStatus;\n150: const handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n151: \n152: export {\n153:   handleMemoryIndexScanStatus,\n154:   handleMemoryIndexScanCancel,\n155:   mapScanJobForResponse,\n156:   handle_memory_index_scan_status,\n157:   handle_memory_index_scan_cancel,\n158: };\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index Scan Job Handlers\n// ───────────────────────────────────────────────────────────────\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index Scan Job Handlers\n// ───────────────────────────────────────────────────────────────\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface MemoryIndexScanStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIndexScanCancelArgs {\n  jobId: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction progressPercent(job: MaintenanceJob): number {\n  if (job.progressTotal <= 0) return 0;\n  const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n  return {\n    jobId: job.id,\n    kind: job.kind,\n    state: job.state,\n    phase: job.phase,\n    progress: { processed: job.progressProcessed, total: job.progressTotal },\n    progressPercent: progressPercent(job),\n    cancelRequested: job.cancelRequested,\n    errors: job.errors,\n    result: job.result,\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n  };\n}\n\n// Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\nfunction getScanJob(jobId: string): MaintenanceJob | null {\n  const job = getMaintenanceJob(jobId);\n  if (!job || job.kind !== 'index_scan') return null;\n  return job;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HANDLERS\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_status',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_status',\n    summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n    data: mapScanJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_cancel',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (isTerminalJobState(job.state)) {\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan_cancel',\n      summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n      data: mapScanJobForResponse(job),\n    });\n  }\n\n  await requestCancel(args.jobId);\n  const updated = getScanJob(args.jobId) ?? job;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_cancel',\n    summary: `Cancellation requested for index scan job ${updated.id}`,\n    data: mapScanJobForResponse(updated),\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nconst handle_memory_index_scan_status = handleMemoryIndexScanStatus;\nconst handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n\nexport {\n  handleMemoryIndexScanStatus,\n  handleMemoryIndexScanCancel,\n  mapScanJobForResponse,\n  handle_memory_index_scan_status,\n  handle_memory_index_scan_cancel,\n};","lineStart":1,"lineEnd":158,"totalLines":158,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","time":{"start":1781756820319,"end":1781756820322}},"metadata":{"openai":{"itemId":"fc_0a81a13940fa42b4016a337394325481919d1deca44e345dbf"}},"id":"prt_ed8fb7b47001I1GqbQChy520hv","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fb1ccc001L1KkZL6nqvRMbR"}}
