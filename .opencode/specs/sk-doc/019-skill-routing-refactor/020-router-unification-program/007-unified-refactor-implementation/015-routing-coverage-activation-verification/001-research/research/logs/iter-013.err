.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:90:      "confidence": 45,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:91:      "readiness": "Needs research"
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:92:    },
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:93:    "postflight": {
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:94:      "knowledgeScore": 75,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:95:      "uncertaintyScore": 25,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:96:      "contextScore": 80,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:97:      "gapsClosed": ["gap1"],
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:98:      "newGaps": ["new-gap"]
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:99:    }
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:100:  }
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:101:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:102:  Tool/Exchange enrichment fields (all optional — JSON-mode only):
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:103:  - toolCalls[]: AI-summarized tool calls with tool name, input/output summaries, status, duration
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:104:  - exchanges[]: Key user-assistant exchanges with timestamps
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:105:  - These provide richer context than DB extraction since the AI filters noise at source
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:106:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:107:  Structured JSON compatibility hints (JSON-mode only):
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:108:  - Top-level routeAs / mergeModeHint are accepted for compatibility with routed save workflows
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:109:  - Top-level specDrift / reviewerFocus are accepted as optional advisory context; absence means none
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:110:  - Explicit CLI spec-folder targets remain authoritative over payload specFolder values
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:111:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:112:  Learning Delta Calculation:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:113:  - Knowledge Delta = postflight.knowledgeScore - preflight.knowledgeScore
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:114:  - Uncertainty Reduction = preflight.uncertaintyScore - postflight.uncertaintyScore
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:115:  - Context Delta = postflight.contextScore - preflight.contextScore
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:116:  - Learning Index = (Know x 0.4) + (Uncert x 0.35) + (Context x 0.25)
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:117:`;
