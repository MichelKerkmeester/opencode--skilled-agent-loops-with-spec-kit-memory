yWalk(state, 'spec document discovery')) {\n\n  Line 326:         if (shouldAbortDiscoveryWalk(state, 'graph metadata discovery')) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts:\n  Line 1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/reconsolidation.vitest.ts:\n  Line 689:     it('MP6: Aborts merge when predecessor changes during embedding generation', async () => {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts:\n  Line 18:   shouldAbort?: () => boolean;\n\n  Line 123: export async function processBatches<T, R>(\n\n  Line 150:     if (retryOptions.shouldAbort?.()) break;\n\n  Line 174:     if (i + effectiveBatchSize < items.length && delayMs > 0 && !retryOptions.shouldAbort?.()) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/exhaustiveness.vitest.ts:\n  Line 59:     type ConflictAbortStatus = 'conflict_stale_predecessor' | 'scope_retagged';\n\n  Line 60:     const normalize = (status: ConflictAbortStatus): ConflictAbortStatus => {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/file-watcher-queue-cap-049-005.vitest.ts:\n  Line 2: // MODULE: File Watcher Queue Cap & Close-Abort Tests\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/model-server-respawn-lock-atomic.vitest.ts:\n  Line 10: // Also asserts shouldAbortRelaunchOnFire — the guard wired into the db-lock-held\n\n  Line 26:   shouldAbortRelaunchOnFire: (input: { shuttingDown: boolean; currentPpid: number; initialPpid: number }) => boolean;\n\n 