{"type":"tool_use","timestamp":1784377926939,"sessionID":"ses_08acc7a6affeS35KntG0P1wx2Z","part":{"type":"tool","tool":"read","callID":"call_9yNNhKUSGQwUDrln9ykp9Yi1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":980,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n980:     remainingDelayMs: checkpoint.remainingDelayMs,\n981:   });\n982: \n983:   await waitUntilCheckpointExpires({\n984:     checkpointPath,\n985:     checkpoint,\n986:     context: { runId, loopType, specFolder },\n987:   });\n988: \n989:   appendFanoutStatusLedger(ledgerPath, {\n990:     event: 'wait_checkpoint_cleared',\n991:     at: new Date().toISOString(),\n992:     run_id: runId,\n993:     loop_type: loopType,\n994:     spec_folder: specFolder,\n995:   });\n996: \n997:   return { didWait: true };\n998: }\n999: \n1000: /**\n1001:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1002:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1003:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1004:  */\n1005: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1006:   assertActiveFanoutLoopType(loopType);\n1007:   const skillFile =\n1008:     loopType === 'review'\n1009:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1010:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1011:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1012:   const detachedIntro = lineage.kind === 'cli-opencode'\n1013:     ? [\n1014:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1015:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1016:         ``,\n1017:       ]\n1018:     : lineage.kind === 'native'\n1019:       ? [\n1020:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1021:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1022:           ``,\n1023:         ]\n1024:       : [];\n1025:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1026:   const stopPolicy = options.stopPolicy || 'convergence';\n1027:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1028:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1029:     : hasIterationCap\n1030:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1031:       : 'to legal convergence';\n1032:   const params = [\n1033:     `  spec_folder: ${specFolder}`,\n1034:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1035:     `  session_id: ${sessionId}`,\n1036:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1037:     `  loop_type: ${loopType}`,\n1038:     `  config.stopPolicy: ${stopPolicy}`,\n1039:   ];\n1040:   if (researchTopic) {\n1041:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1042:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1043:     // Review loops scope by spec_folder and intentionally pass no topic.\n1044:     params.push(`  research_topic: ${researchTopic}`);\n1045:   }\n1046:   if (hasIterationCap) {\n1047:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1048:   }\n1049:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1050:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1051:   }\n1052:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1053:   // still requires the same review setup bindings the native command path pre-binds.\n1054:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1055:   // different setup contract than native lineages.\n1056:   const setupBindings =\n1057:     loopType === 'review'\n1058:       ? [\n1059:           ``,\n1060:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1061:           `review_target: ${specFolder}`,\n1062:           `review_target_type: spec-folder`,\n1063:           `review_dimensions: all`,\n1064:           `spec_folder: ${specFolder}`,\n1065:           `execution_mode: AUTONOMOUS`,\n1066:           `lineage_mode: auto`,\n1067:           ``,\n1068:         ]\n1069:       : [];\n1070:   return [\n1071:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1072:     ...detachedIntro,\n1073:     ``,\n1074:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1075:     ...params,\n1076:     ...setupBindings,\n1077:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1078:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1079:     `command; bind artifact_dir directly to the override value.`,\n1080:     ``,\n1081:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1082:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1083:     ``,\n1084:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1085:   ].join('\\n');\n1086: }\n1087: \n1088: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1089:   assertActiveFanoutLoopType(loopType);\n1090:   const maxIterations = lineage.iterations || 12;\n1091:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1092:   const stopPolicy = options.stopPolicy || 'convergence';\n1093:   const sessionId = options.sessionId || '';\n1094:   const args = [\n1095:     ':auto',\n1096:     JSON.stringify(specFolder),\n1097:     `--spec-folder=${specFolder}`,\n1098:     `--max-iterations=${maxIterations}`,\n1099:     `--convergence=${convergenceThreshold}`,\n1100:     `--stop-policy=${stopPolicy}`,\n1101:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1102:     '--lineage-mode=auto',\n1103:   ];\n1104:   if (loopType === 'research' && options.researchTopic) {\n1105:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1106:   }\n1107: \n1108:   return [\n1109:     args.join(' '),\n1110:     '',\n1111:     'PRE-BOUND SETUP ANSWERS:',\n1112:     `review_target: ${specFolder}`,\n1113:     'review_target_type: spec-folder',\n1114:     'review_dimensions: all',\n1115:     `spec_folder: ${specFolder}`,\n1116:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1117:     'execution_mode: AUTONOMOUS',\n1118:     'lineage_mode: auto',\n1119:     `maxIterations: ${maxIterations}`,\n1120:     `convergenceThreshold: ${convergenceThreshold}`,\n1121:     `stop_policy: ${stopPolicy}`,\n1122:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1123:   ].join('\\n');\n1124: }\n1125: \n1126: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1127: // ceiling and a positive override may only narrow it, never widen past it.\n1128: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1129: \n1130: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1131:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1132:     throw inputError(\n1133:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1134:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1135:     );\n1136:   }\n1137: }\n1138: \n1139: /**\n1140:  * Compute a generous timeout for a full lineage loop run.\n1141:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1142:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1143:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1144:  */\n1145: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1146:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1147:   const iters = lineage.iterations || 12;\n1148:   const perIterSecs = lineage.timeoutSeconds || 900;\n1149:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1150:     ? ceilingHoursOverride * 60 * 60 * 1000\n1151:     : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n1152:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1153: }\n1154: \n1155: function normalizeProgressHeartbeatMs(seconds) {\n1156:   const value = Number(seconds);\n1157:   if (!Number.isFinite(value) || value <= 0) return 0;\n1158:   return Math.max(1, Math.floor(value * 1000));\n1159: }\n\n(Showing lines 980-1159 of 2021. Use offset=1160 to continue.)\n</content>","metadata":{"preview":"    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n      : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n// Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n// ceiling and a positive override may only narrow it, never widen past it.\nconst LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n\nfunction assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n  if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n    throw inputError(\n      `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n        + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n    );\n  }\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}","lineStart":980,"lineEnd":1159,"totalLines":2021,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784377926930,"end":1784377926938}},"metadata":{"openai":{"itemId":"fc_0a81daa3e07133d1016a5b7246b844819193d99e6de9466112"}},"id":"prt_f7536649b001qHutly1is6CY0z","sessionID":"ses_08acc7a6affeS35KntG0P1wx2Z","messageID":"msg_f75362e79001lnsHyfw5uCC7ez"}}
{"type":"tool_use","timestamp":1784377926987,"sessionID":"ses_08acc7a6affeS35KntG0P1wx2Z","part":{"type":"tool","tool":"read","callID":"call_H8sWXh1JgWDXkrinwfk9oow0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":1680,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1680:     onEvent: (event) => {\n1681:       const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n1682:       updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n1683:       if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n1684:       appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n1685:     },\n1686:     worker: async (lineage, context) => {\n1687:       const slotWindowStartIso = new Date().toISOString();\n1688:       const hrStart = process.hrtime();\n1689:       const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n1690:       const livenessKey = `${lineage.label}:${attempt}`;\n1691:       const lineageDir = path.join(lineagesDir, lineage.label);\n1692:       const stateDir = path.join(lineageDir, '.executor-state');\n1693:       fs.mkdirSync(lineageDir, { recursive: true });\n1694:       fs.mkdirSync(stateDir, { recursive: true });\n1695: \n1696:       const budgetDecision = evaluateLineageBudgetCap({\n1697:         lineage,\n1698:         guards: lineageBudgetGuards,\n1699:         maxRetries: fanoutConfig.maxRetries,\n1700:       });\n1701:       if (!budgetDecision.continue_allowed) {\n1702:         appendFanoutStatusLedger(ledgerPath, {\n1703:           event: 'budget_cap_exceeded',\n1704:           label: lineage.label,\n1705:           at: new Date().toISOString(),\n1706:           severity: 'error',\n1707:           stop_reasons: budgetDecision.stop_reasons,\n1708:           upper_bound: budgetDecision.upper_bound,\n1709:           gauges: latestGauges,\n1710:         });\n1711:         const failure = new Error(\n1712:           `lineage ${lineage.label} exceeds configured budget cap: `\n1713:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1714:         );\n1715:         failure.label = lineage.label;\n1716:         failure.exitCode = null;\n1717:         failure.timedOut = false;\n1718:         failure.budgetCap = budgetDecision;\n1719:         throw failure;\n1720:       }\n1721: \n1722:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1723:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1724:         convergenceThreshold,\n1725:         stopPolicy,\n1726:       });\n1727: \n1728:       // Sandbox resolution stays write-capable by default even for review lineages:\n1729:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1730:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1731:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1732:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1733:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1734:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1735:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1736:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1737: \n1738:       const effectiveSandbox = resolvedSandbox;\n1739:       const effectivePermission = resolvedPermission;\n1740: \n1741:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1742:         lineage,\n1743:         prompt,\n1744:         effectiveSandbox,\n1745:         effectivePermission,\n1746:         {\n1747:           loopType,\n1748:           specFolder,\n1749:           lineageDir,\n1750:           sessionId,\n1751:           convergenceThreshold,\n1752:           stopPolicy,\n1753:           researchTopic,\n1754:         },\n1755:       );\n1756: \n1757:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1758:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1759:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1760:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1761:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1762:       // is deliberately avoided here because relocating the home breaks credential/auth\n1763:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1764:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1765:       const extraEnv = {\n1766:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1767:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1768:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1769:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1770:           : {}),\n1771:       };\n1772: \n1773:       // Recursion guard (fail closed): the executor stack can already name the hosting\n1774:       // runtime before the first detached fan-out spawn. The lineage marker is added only\n1775:       // to a spawned seat, so both signals are required to prove that a seat is trying to\n1776:       // fan out its own executor kind again.\n1777:       const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n1778:       const isInsideFanoutLineage = typeof inheritedLineageId 