tring>[] {\n301:   const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n302:   const edges: DirectedTraversalEdge<string>[] = [];\n303:   if (parents.length === 0) {\n304:     return edges;\n305:   }\n306: \n307:   for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n308:     const chunkPlaceholders = placeholders(parentChunk.length);\n309:     const rows = database.prepare(`\n310:       SELECT parent_path, child_path\n311:       FROM dependency_edges\n312:       WHERE parent_path IN (${chunkPlaceholders})\n313:     `).all(...parentChunk) as DependencyEdgeRow[];\n314: \n315:     for (const row of rows) {\n316:       edges.push({ from: row.parent_path, to: row.child_path });\n317:     }\n318:   }\n319: \n320:   return edges;\n321: }\n322: \n323: /** Traverse memo dependency edges from parent paths to all transitive children. */\n324: export function collectDependencyReachability(\n325:   database: Database.Database,\n326:   roots: readonly string[],\n327: ): string[] {\n328:   return collectDirectedReachability({\n329:     roots,\n330:     readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n331:   });\n332: }\n\n(End of file - total 332 lines)\n</content>","metadata":{"preview":"        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n    for (const row of incomingRows) {\n      const from = Number.parseInt(row.target_id, 10);\n      const to = Number.parseInt(row.source_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n  }\n\n  return edges;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","text":"        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n    for (const row of incomingRows) {\n      const from = Number.parseInt(row.target_id, 10);\n      const to = Number.parseInt(row.source_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse causal edges with the production weighted-walk reader. */\nexport function collectCausalWeightedNeighbors(\n  database: Database.Database,\n  seeds: readonly number[],\n  maxHops: number,\n  relationWeights: Readonly<Record<string, number>>,\n): Map<number, WeightedWalkResult<number>> {\n  return collectWeightedWalk({\n    seeds,\n    maxHops,\n    readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n  });\n}\n\n/** Read memo dependency edges in parent-to-child direction. */\nexport function readDependencyChildren(\n  database: Database.Database,\n  parentPaths: readonly string[],\n): DirectedTraversalEdge<string>[] {\n  const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n  const edges: DirectedTraversalEdge<string>[] = [];\n  if (parents.length === 0) {\n    return edges;\n  }\n\n  for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(parentChunk.length);\n    const rows = database.prepare(`\n      SELECT parent_path, child_path\n      FROM dependency_edges\n      WHERE parent_path IN (${chunkPlaceholders})\n    `).all(...parentChunk) as DependencyEdgeRow[];\n\n    for (const row of rows) {\n      edges.push({ from: row.parent_path, to: row.child_path });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse memo dependency edges from parent paths to all transitive children. */\nexport function collectDependencyReachability(\n  database: Database.Database,\n  roots: readonly string[],\n): string[] {\n  return collectDirectedReachability({\n    roots,\n    readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n  });\n}","lineStart":261,"lineEnd":332,"totalLines":332,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","time":{"start":1781150602181,"end":1781150602187}},"metadata":{"openai":{"itemId":"fc_0712198c1a9d2124016a2a338a1644819181c63c003b48c4f3"}},"id":"prt_eb4d953b6001IuI5C0Qcx2iBHM","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d92c39001gL8QeM0hLAASci"}}
{"type":"tool_use","timestamp":1781150602221,"sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","part":{"type":"tool","tool":"read","callID":"call_b0j1lOgVuacgZ5j99usHTjDd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","offset":621,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts</path>\n<type>file</type>\n<content>\n621:   return { results: merged, metadata };\n622: }\n623: \n624: // ───────────────────────────────────────────────────────────────\n625: // ALWAYS-ON GRAPH CONTEXT INJECTION\n626: // ───────────────────────────────────────────────────────────────\n627: \n628: /**\n629:  * Graph context metadata returned by injectGraphContext.\n630:  * Contains related memory IDs and edge types discovered from the graph\n631:  * even when the causal boost has no seed results.\n632:  */\n633: interface GraphContextResult {\n634:   /** Whether graph context injection was active and produced results. */\n635:   activated: boolean;\n636:   /** Canonical concept names matched from the query. */\n637:   matchedConcepts: string[];\n638:   /** Memory IDs of graph neighbors related to matched concepts. */\n639:   relatedMemoryIds: number[];\n640:   /** Edge relation types connecting seeds to neighbors. */\n641:   edgeTypes: string[];\n642: }\n643: \n644: /**\n645:  * Always-on graph context injection.\n646:  *\n647:  * Runs concept routing on the query and finds graph neighbors for matched\n648:  * concepts, returning graph context metadata (related memory IDs, edge types).\n649:  * Unlike applyCausalBoost, this runs even when there are no seed results,\n650:  * enabling proactive graph-guided context discovery.\n651:  *\n652:  * Feature-gated by SPECKIT_GRAPH_CONTEXT_INJECTION (default ON).\n653:  * Fail-open: returns empty result on any error.\n654:  *\n655:  * @param query - The search query string.\n656:  * @param database - SQLite database instance for graph lookups.\n657:  * @returns GraphContextResult with related memory IDs and edge types.\n658:  */\n659: function injectGraphContext(\n660:   query: string,\n661:   database: Database.Database,\n662: ): GraphContextResult {\n663:   const empty: GraphContextResult = {\n664:     activated: false,\n665:     matchedConcepts: [],\n666:     relatedMemoryIds: [],\n667:     edgeTypes: [],\n668:   };\n669: \n670:   if (!isGraphContextInjectionEnabled()) return empty;\n671: \n672:   try {\n673:     const routing = routeQueryConcepts(query, database);\n674:     if (!routing.graphActivated || routing.concepts.length === 0) return empty;\n675: \n676:     // Find seed memory IDs whose titles contain matched concept keywords\n677:     const likeClauses = routing.concepts.map(() => 'LOWER(title) LIKE ?').join(' OR ');\n678:     const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n679: \n680:     const seedRows = (database.prepare(`\n681:       SELECT id FROM memory_index WHERE (${likeClauses}) LIMIT 10\n682:     `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n683: \n684:     if (seedRows.length === 0) {\n685:       return { ...empty, activated: true, matchedConcepts: routing.concepts };\n686:     }\n687: \n688:     const seedIds = seedRows.map((r) => String(r.id));\n689:     const seedPlaceholders = seedIds.map(() => '?').join(', ');\n690: \n691:     // Walk 1-hop causal edges to find neighbor nodes and edge types\n692:     const neighborRows = (database.prepare(`\n693:       SELECT DISTINCT\n694:         CASE\n695:           WHEN ce.source_id IN (${seedPlaceholders}) THEN CAST(ce.target_id AS INTEGER)\n696:           ELSE CAST(ce.source_id AS INTEGER)\n697:         END AS neighbor_id,\n698:         ce.relation\n699:       FROM causal_edges ce\n700:       WHERE ce.source_id IN (${seedPlaceholders}) OR ce.target_id IN (${seedPlaceholders})\n701:       LIMIT 20\n702:     `) as Database.Statement).all(\n703:       ...seedIds,\n704:       ...seedIds,\n705:       ...seedIds,\n706:     ) as Array<{ neighbor_id: number; relation: string }>;\n707: \n708:     const relatedMemoryIds: number[] = [];\n709:     const edgeTypes = new Set<string>();\n710:     const seedIdSet = new Set(seedRows.map((r) => r.id));\n711: \n712:     for (const row of neighborRows) {\n713:       if (!seedIdSet.has(row.neighbor_id) && Number.isFinite(row.neighbor_id)) {\n714:         relatedMemoryIds.push(row.neighbor_id);\n715:       }\n716:       if (row.relation) {\n717:         edgeTypes.add(row.relation);\n718:       }\n719:     }\n720: \n721:     return {\n722:       activated: true,\n723:       matchedConcepts: routing.concepts,\n724:       relatedMemoryIds: [...new Set(relatedMemoryIds)].slice(0, 10),\n725:       edgeTypes: Array.from(edgeTypes),\n726:     };\n727:   } catch (error: unknown) {\n728:     const message = error instanceof Error ? error.message : String(error);\n729:     console.warn(`[causal-boost] injectGraphContext failed (fail-open): ${message}`);\n730:     return empty;\n731:   }\n732: }\n733: \n734: export {\n735:   MAX_HOPS,\n736:   MAX_BOOST_PER_HOP,\n737:   RELATION_WEIGHT_MULTIPLIERS,\n738:   // D3 Phase A exports\n739:   SPARSE_DENSITY_THRESHOLD,\n740:   SPARSE_MAX_HOPS,\n741:   DEFAULT_TYPED_TRAVERSAL_DEPTH,\n742:   INTENT_EDGE_PRIORITY,\n743:   DEFAULT_EDGE_PRIORITY,\n744:   DEFAULT_EDGE_PRIOR,\n745:   EDGE_PRIOR_TIERS,\n746:   EDGE_LABEL_ALIASES,\n747:   init,\n748:   isEnabled,\n749:   isTypedTraversalEnabled,\n750:   isSparseMode,\n751:   resolveSparseFirstTraversalPolicy,\n752:   resolveTraversalDepth,\n753:   resolveEdgePrior,\n754:   computeHopDecay,\n755:   computeIntentTraversalScore,\n756:   getIntentEdgePriorities,\n757:   computeIntentEdgePrior,\n758:   computeTraversalHopDecay,\n759:   computeTraversalFreshnessFactor,\n760:   computeIntentAwareTraversalScore,\n761:   getNeighborBoosts,\n762:   applyCausalBoost,\n763:   // Always-on graph context injection\n764:   injectGraphContext,\n765: };\n766: \n767: export type {\n768:   RankedSearchResult,\n769:   CausalBoostMetadata,\n770:   CausalBoostOptions,\n771:   SparseFirstTraversalPolicy,\n772:   GraphContextResult,\n773: };\n\n(End of file - total 773 lines)\n</content>","metadata":{"preview":"  return { results: merged, metadata };\n}\n\n// ───────────────────────────────────────────────────────────────\n// ALWAYS-ON GRAPH CONTEXT INJECTION\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Graph context metadata returned by injectGraphContext.\n * Contains related memory IDs and edge types discovered from the graph\n * even when the causal boost has no seed results.\n */\ninterface GraphContextResult {\n  /** Whether graph context injection was active and produced results. */\n  activated: boolean;\n  /** Canonical concept names matched from the query. */\n  matchedConcepts: string[];\n  /** Memory IDs of graph neighbors related to matched concepts. */\n  relatedMemoryIds: number[];\n  /** Edge relation types connecting seeds to neighbors. */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","text":"  return { results: merged, metadata };\n}\n\n// ───────────────────────────────────────────────────────────────\n// ALWAYS-ON GRAPH CONTEXT INJECTION\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Graph context metadata returned by injectGraphContext.\n * Contains related memory IDs and edge types discovered from the graph\n * even when the causal boost has no seed results.\n */\ninterface GraphContextResult {\n  /** Whether graph context injection was active and produced results. */\n  activated: boolean;\n  /** Canonical concept names matched from the query. */\n  matchedConcepts: string[];\n  /** Memory IDs of graph neighbors related to matched concepts. */\n  relatedMemoryIds: number[];\n  /** Edge relation types connecting seeds to neighbors. */\n  edgeTypes: string[];\n}\n\n/**\n * Always-on graph context injection.\n *\n * Runs concept routing on the query and finds graph neighbors for matched\n * concepts, returning graph context metadata (related memory IDs, edge types).\n * Unlike applyCausalBoost, this runs even when there are no seed results,\n * enabling proactive graph-guided context discovery.\n *\n * Feature-gated by SPECKIT_GRAPH_CONTEXT_INJECTION (default ON).\n * Fail-open: returns empty result on any error.\n *\n * @param query - The search query string.\n * @param database - SQLite database instance for graph lookups.\n * @returns GraphContextResult with related memory IDs and edge types.\n */\nfunction injectGraphContext(\n  query: string,\n  database: Database.Database,\n): GraphContextResult {\n  const empty: GraphContextResult = {\n    activated: false,\n    matchedConcepts: [],\n    relatedMemoryIds: [],\n    edgeTypes: [],\n  };\n\n  if (!isGraphContextInjectionEnabled()) return empty;\n\n  try {\n    const routing = routeQueryConcepts(query, database);\n    if (!routing.graphActivated || routing.concepts.length === 0) return empty;\n\n    // Find seed memory IDs whose titles contain matched concept keywords\n    const likeClauses = routing.concepts.map(() => 'LOWER(title) LIKE ?').join(' OR ');\n    const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n\n    const seedRows = (database.prepare(`\n      SELECT id FROM memory_index WHERE (${likeClauses}) LIMIT 10\n    `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n\n    if (seedRows.length === 0) {\n      return { ...empty, activated: true, matchedConcepts: routing.concepts };\n    }\n\n    const seedIds = seedRows.map((r) => String(r.id));\n    const seedPlaceholders = seedIds.map(() => '?').join(', ');\n\n    // Walk 1-hop causal edges to find neighbor nodes and edge types\n    const neighborRows = (database.prepare(`\n      SELECT DISTINCT\n        CASE\n          WHEN ce.source_id IN (${seedPlaceholders}) THEN CAST(ce.target_id AS INTEGER)\n          ELSE CAST(ce.source_id AS INTEGER)\n        END AS neighbor_id,\n        ce.relation\n      FROM causal_edges ce\n      WHERE ce.source_id IN (${seedPlaceholders}) OR ce.target_id IN (${seedPlaceholders})\n      LIMIT 20\n    `) as Database.Statement).all(\n      ...seedIds,\n      ...seedIds,\n      ...seedIds,\n    ) as Array<{ neighbor_id: number; relation: string }>;\n\n    const relatedMemoryIds: number[] = [];\n    const edgeTypes = new Set<string>();\n    const seedIdSet = new Set(seedRows.map((r) => r.id));\n\n    for (const row of neighborRows) {\n      if (!seedIdSet.has(row.neighbor_id) && Number.isFinite(row.neighbor_id)) {\n        relatedMemoryIds.push(row.neighbor_id);\n      }\n      if (row.relation) {\n        edgeTypes.add(row.relation);\n      }\n    }\n\n    return {\n      activated: true,\n      matchedConcepts: routing.concepts,\n      relatedMemoryIds: [...new Set(relatedMemoryIds)].slice(0, 10),\n      edgeTypes: Array.from(edgeTypes),\n    };\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-boost] injectGraphContext failed (fail-open): ${message}`);\n    return empty;\n  }\n}\n\nexport {\n  MAX_HOPS,\n  MAX_BOOST_PER_HOP,\n  RELATION_WEIGHT_MULTIPLIERS,\n  // D3 Phase A exports\n  SPARSE_DENSITY_THRESHOLD,\n  SPARSE_MAX_HOPS,\n  DEFAULT_TYPED_TRAVERSAL_DEPTH,\n  INTENT_EDGE_PRIORITY,\n  DEFAULT_EDGE_PRIORITY,\n  DEFAULT_EDGE_PRIOR,\n  EDGE_PRIOR_TIERS,\n  EDGE_LABEL_ALIASES,\n  init,\n  isEnabled,\n  isTypedTraversalEnabled,\n  isSparseMode,\n  resolveSparseFirstTraversalPolicy,\n  resolveTraversalDepth,\n  resolveEdgePrior,\n  computeHopDecay,\n  computeIntentTraversalScore,\n  getIntentEdgePriorities,\n  computeIntentEdgePrior,\n  computeTraversalHopDecay,\n  computeTraversalFreshnessFactor,\n  computeIntentAwareTraversalScore,\n  getNeighborBoosts,\n  applyCausalBoost,\n  // Always-on graph context injection\n  injectGraphContext,\n};\n\nexport type {\n  RankedSearchResult,\n  CausalBoostMetadata,\n  CausalBoostOptions,\n  SparseFirstTraversalPolicy,\n  GraphContextResult,\n};","lineStart":621,"lineEnd":773,"totalLines":773,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","time":{"start":1781150602217,"end":1781150602220}},"metadata":{"openai":{"itemId":"fc_0712198c1a9d2124016a2a338a16548191a23635d2b01d67aa"}},"id":"prt_eb4d953e2001bY4lL9OLoctptH","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d92c39001gL8QeM0hLAASci"}}
{"type":"tool_use","timestamp":1781150602240,"sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","part":{"type":"tool","tool":"read","callID":"call_5aUSFfhh27DHWrpW50wwPs6U","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","offset":1,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Graph Traversal\n3: // -------------------------------------------------------------------\n4: \n5: import type Database from 'better-sqlite3';\n6: import {\n7:   collectCausalWeightedNeighbors,\n8:   collectDependencyReachability,\n9:   collectDirectedReachability,\n10:   collectWeightedWalk,\n11:   type DirectedReachabilityOptions,\n12:   type WeightedWalkOptions,\n13:   type WeightedWalkResult,\n14: } from '../../graph/bfs-traversal.js';\n15: \n16: /** Node identifier accepted by graph traversal ports. */\n17: export type GraphTraversalNode = number | string;\n18: \n19: export type {\n20:   DirectedReachabilityOptions,\n21:   DirectedTraversalEdge,\n22:   WeightedTraversalEdge,\n23:   WeightedWalkOptions,\n24:   WeightedWalkResult,\n25: } from '../../graph/bfs-traversal.js';\n26: \n27: /**\n28:  * Traverses graph-shaped storage data without exposing the caller to the\n29:  * underlying database driver.\n30:  */\n31: export interface GraphTraversal {\n32:   /** Run a generic hop-capped weighted walk. */\n33:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n34:     options: WeightedWalkOptions<TNode>,\n35:   ): Map<TNode, WeightedWalkResult<TNode>>;\n36: \n37:   /** Collect all nodes reachable through directed edges from the roots. */\n38:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n39:     options: DirectedReachabilityOptions<TNode>,\n40:   ): TNode[];\n41: \n42:   /** Traverse causal-neighbor edges from memory IDs. */\n43:   collectCausalWeightedNeighbors(\n44:     seeds: readonly number[],\n45:     maxHops: number,\n46:     relationWeights: Readonly<Record<string, number>>,\n47:   ): Map<number, WeightedWalkResult<number>>;\n48: \n49:   /** Traverse dependency edges from parent paths to transitive children. */\n50:   collectDependencyReachability(roots: readonly string[]): string[];\n51: }\n52: \n53: /** better-sqlite3-backed graph traversal adapter. */\n54: export class BetterSqliteGraphTraversal implements GraphTraversal {\n55:   constructor(private readonly database: Database.Database) {}\n56: \n57:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n58:     options: WeightedWalkOptions<TNode>,\n59:   ): Map<TNode, WeightedWalkResult<TNode>> {\n60:     return collectWeightedWalk(options);\n61:   }\n62: \n63:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n64:     options: DirectedReachabilityOptions<TNode>,\n65:   ): TNode[] {\n66:     return collectDirectedReachability(options);\n67:   }\n68: \n69:   collectCausalWeightedNeighbors(\n70:     seeds: readonly number[],\n71:     maxHops: number,\n72:     relationWeights: Readonly<Record<string, number>>,\n73:   ): Map<number, WeightedWalkResult<number>> {\n74:     return collectCausalWeightedNeighbors(this.database, seeds, maxHops, relationWeights);\n75:   }\n76: \n77:   collectDependencyReachability(roots: readonly string[]): string[] {\n78:     return collectDependencyReachability(this.database, roots);\n79:   }\n80: }\n\n(End of file - total 80 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Graph Traversal\n// -------------------------------------------------------------------\n\nimport type Database from 'better-sqlite3';\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/** Node identifier accepted by graph traversal ports. */\nexport type GraphTraversalNode = number | string;\n\nexport type {\n  DirectedReachabilityOptions,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Graph Traversal\n// -------------------------------------------------------------------\n\nimport type Database from 'better-sqlite3';\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/** Node identifier accepted by graph traversal ports. */\nexport type GraphTraversalNode = number | string;\n\nexport type {\n  DirectedReachabilityOptions,\n  DirectedTraversalEdge,\n  WeightedTraversalEdge,\n  WeightedWalkOptions,\n  WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/**\n * Traverses graph-shaped storage data without exposing the caller to the\n * underlying database driver.\n */\nexport interface GraphTraversal {\n  /** Run a generic hop-capped weighted walk. */\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>>;\n\n  /** Collect all nodes reachable through directed edges from the roots. */\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[];\n\n  /** Traverse causal-neighbor edges from memory IDs. */\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>>;\n\n  /** Traverse dependency edges from parent paths to transitive children. */\n  collectDependencyReachability(roots: readonly string[]): string[];\n}\n\n/** better-sqlite3-backed graph traversal adapter. */\nexport class BetterSqliteGraphTraversal implements GraphTraversal {\n  constructor(private readonly database: Database.Database) {}\n\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>> {\n    return collectWeightedWalk(options);\n  }\n\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[] {\n    return collectDirectedReachability(options);\n  }\n\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>> {\n    return collectCausalWeightedNeighbors(this.database, seeds, maxHops, relationWeights);\n  }\n\n  collectDependencyReachability(roots: readonly string[]): string[] {\n    return collectDependencyReachability(this.database, roots);\n  }\n}","lineStart":1,"lineEnd":80,"totalLines":80,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","time":{"start":1781150602236,"end":1781150602239}},"metadata":{"openai":{"itemId":"fc_0712198c1a9d2124016a2a338a190c8191aeba1b04bc6e6017"}},"id":"prt_eb4d953f7001ZRpfwvy4ySg8i3","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d92c39001gL8QeM0hLAASci"}}
{"type":"tool_use","timestamp":1781150602254,"sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","part":{"type":"tool","tool":"read","callID":"call_Szb3ZzTYMWqGDpjKY1qYFSBR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // TEST: STORAGE PORT CONTRACTS\n3: // -------------------------------------------------------------------\n4: \n5: import * as fs from 'fs';\n6: import * as os from 'os';\n7: import * as path from 'path';\n8: \n9: import Database from 'better-sqlite3';\n10: import { describe, expect, it } from 'vitest';\n11: \n12: import {\n13:   BetterSqliteContentionPolicy,\n14:   BetterSqliteGraphTraversal,\n15:   BetterSqliteMaintenance,\n16:   BetterSqliteVectorStore,\n17:   PackedBm25LexicalSearch,\n18:   type ContentionPolicy,\n19:   type GraphTraversal,\n20:   type LexicalSearch,\n21:   type Maintenance,\n22:   type VectorMetadata,\n23:   type VectorStore,\n24: } from '../lib/storage/ports';\n25: import {\n26:   FakeContentionPolicy,\n27:   FakeGraphTraversal,\n28:   FakeLexicalSearch,\n29:   FakeMaintenance,\n30:   FakeVectorStore,\n31: } from './fakes/storage-ports';\n32: \n33: interface ContractSubject<TPort> {\n34:   readonly port: TPort;\n35:   readonly cleanup: () => void;\n36: }\n37: \n38: interface EnvSnapshot {\n39:   readonly EMBEDDING_DIM: string | undefined;\n40:   readonly MEMORY_ALLOWED_PATHS: string | undefined;\n41: }\n42: \n43: type VectorFixtureMetadata = VectorMetadata & {\n44:   readonly spec_folder: string;\n45:   readonly file_path: string;\n46:   readonly title: string;\n47: };\n48: \n49: function snapshotEnv(): EnvSnapshot {\n50:   return {\n51:     EMBEDDING_DIM: process.env.EMBEDDING_DIM,\n52:     MEMORY_ALLOWED_PATHS: process.env.MEMORY_ALLOWED_PATHS,\n53:   };\n54: }\n55: \n56: function restoreEnv(snapshot: EnvSnapshot): void {\n57:   if (snapshot.EMBEDDING_DIM === undefined) {\n58:     delete process.env.EMBEDDING_DIM;\n59:   } else {\n60:     process.env.EMBEDDING_DIM = snapshot.EMBEDDING_DIM;\n61:   }\n62:   if (snapshot.MEMORY_ALLOWED_PATHS === undefined) {\n63:     delete process.env.MEMORY_ALLOWED_PATHS;\n64:   } else {\n65:     process.env.MEMORY_ALLOWED_PATHS = snapshot.MEMORY_ALLOWED_PATHS;\n66:   }\n67: }\n68: \n69: function createGraphFixtureDb(): Database.Database {\n70:   const database = new Database(':memory:');\n71:   database.exec(`\n72:     CREATE TABLE causal_edges (\n73:       source_id TEXT NOT NULL,\n74:       target_id TEXT NOT NULL,\n75:       relation TEXT NOT NULL,\n76:       strength REAL\n77:     );\n78:     CREATE TABLE dependency_edges (\n79:       parent_path TEXT NOT NULL,\n80:       child_path TEXT NOT NULL\n81:     );\n82:   `);\n83: \n84:   const insertCausal = database.prepare(`\n85:     INSERT INTO causal_edges (source_id, target_id, relation, strength)\n86:     VALUES (?, ?, ?, ?)\n87:   `);\n88:   insertCausal.run('1', '2', 'supports', 0.5);\n89:   insertCausal.run('2', '3', 'enabled', 0.25);\n90: \n91:   const insertDependency = database.prepare(`\n92:     INSERT INTO dependency_edges (parent_path, child_path)\n93:     VALUES (?, ?)\n94:   `);\n95:   insertDependency.run('root', 'child');\n96:   insertDependency.run('child', 'grandchild');\n97: \n98:   return database;\n99: }\n100: \n101: function createFakeGraphTraversal(): FakeGraphTraversal {\n102:   return new FakeGraphTraversal({\n103:     causalEdges: [\n104:       { sourceId: 1, targetId: 2, relation: 'supports', strength: 0.5 },\n105:       { sourceId: 2, targetId: 3, relation: 'enabled', strength: 0.25 },\n106:     ],\n107:     dependencyEdges: [\n108:       { parentPath: 'root', childPath: 'child' },\n109:       { parentPath: 'child', childPath: 'grandchild' },\n110:     ],\n111:   });\n112: }\n113: \n114: function createBetterSqliteVectorSubject(): ContractSubject<VectorStore<VectorFixtureMetadata>> {\n115:   const env = snapshotEnv();\n116:   const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-store-port-'));\n117:   process.env.EMBEDDING_DIM = '4';\n118:   process.env.MEMORY_ALLOWED_PATHS = tempDir;\n119:   const store = new BetterSqliteVectorStore({ dbPath: path.join(tempDir, 'context-index.sqlite') });\n120:   return {\n121:     port: store,\n122:     cleanup: () => {\n123:       void store.close();\n124:       restoreEnv(env);\n125:       fs.rmSync(tempDir, { recursive: true, force: true });\n126:     },\n127:   };\n128: }\n129: \n130: function createBetterSqliteMaintenanceSubject(): ContractSubject<Maintenance> {\n131:   const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintenance-port-'));\n132:   const database = new Database(path.join(tempDir, 'maintenance.sqlite'));\n133:   database.pragma('auto_vacuum = INCREMENTAL');\n134:   database.exec('VACUUM');\n135:   database.pragma('journal_mode = WAL');\n136:   database.exec(`\n137:     CREATE TABLE records (id INTEGER PRIMARY KEY, value TEXT NOT NULL);\n138:     INSERT INTO records (value) VALUES ('kept'), ('deleted');\n139:     DELETE FROM records WHERE value = 'deleted';\n140:   `);\n141: \n142:   return {\n143:     port: new BetterSqliteMaintenance(database),\n144:     cleanup: () => {\n145:       database.close();\n146:       fs.rmSync(tempDir, { recursive: true, force: true });\n147:     },\n148:   };\n149: }\n150: \n151: function createBetterSqliteContentionSubject(): ContractSubject<ContentionPolicy> & { database: Database.Database } {\n152:   const database = new Database(':memory:');\n153:   database.exec('CREATE TABLE writes (id INTEGER PRIMARY KEY, value TEXT NOT NULL)');\n154:   return {\n155:     database,\n156:     port: new BetterSqliteContentionPolicy({\n157:       database,\n158:       sleep: async () => undefined,\n159:       sleepSync: () => undefined,\n160:     }),\n161:     cleanup: () => database.close(),\n162:   };\n163: }\n164: \n165: function runGraphTraversalContract(\n166:   label: string,\n167:   createSubject: () => ContractSubject<GraphTraversal>,\n168: ): void {\n169:   describe(label, () => {\n170:     it('collects weighted causal neighbors with hop and score aggregation', () => {\n171:       const subject = createSubject();\n172:       try {\n173:         const results = subject.port.collectCausalWeightedNeighbors(\n174:           [1],\n175:           2,\n176:           { supports: 2, enabled: 4 },\n177:         );\n178: \n179:         expect(results.get(2)).toEqual({ nodeId: 2, minHop: 1, maxWalkScore: 1 });\n180:         expect(results.get(3)).toEqual({ nodeId: 3, minHop: 2, maxWalkScore: 1 });\n181:         expect(results.has(1)).toBe(false);\n182:       } finally {\n183:         subject.cleanup();\n184:       }\n185:     });\n186: \n187:     it('collects dependency children through directed reachability', () => {\n188:       const subject = createSubject();\n189:       try {\n190:         expect(subject.port.collectDependencyReachability(['root'])).toEqual(['child', 'grandchild']);\n191:       } finally {\n192:         subject.cleanup();\n193:       }\n194:     });\n195: \n196:     it('exposes generic directed reachability for caller-supplied readers', () => {\n197:       const subject = createSubject();\n198:       try {\n199:         const reached = subject.port.collectDirectedReachability({\n200:           roots: ['a'],\n201:           readEdges: (nodeIds) => nodeIds.includes('a')\n202:             ? [{ from: 'a', to: 'b' }, { from: 'a', to: 'c' }]\n203:             : [],\n204:         });\n205: \n206:         expect(reached).toEqual(['b', 'c']);\n207:       } finally {\n208:         subject.cleanup();\n209:       }\n210:     });\n211:   });\n212: }\n213: \n214: function runLexicalSearchContract(\n215:   label: string,\n216:   createSubject: () => ContractSubject<LexicalSearch>,\n217: ): void {\n218:   describe(label, () => {\n219:     it('indexes fielded documents and returns ranked query matches', () => {\n220:       const subject = createSubject();\n221:       try {\n222:         subject.port.addDocumentFields('auth', {\n223:           title: 'Auth guard',\n224:           trigger_phrases: ['authentication', 'login'],\n225:           content_generic: 'auth/module.md',\n226:           body: 'Guarded login access for memory search',\n227:         });\n228:         subject.port.addDocumentFields('cache', {\n229:           title: 'Cache invalidation',\n230:           trigger_phrases: ['cache'],\n231:           content_generic: 'cache/module.md',\n232:           body: 'Background cache refresh notes',\n233:         });\n234: \n235:         const results = subject.port.search('auth guard', { limit: 1 });\n236: \n237:         expect(results).toHaveLength(1);\n238:         expect(results[0]?.id).toBe('auth');\n239:         expect(results[0]?.score).toBeGreaterThan(0);\n240:       } finally {\n\n(Showing lines 1-240 of 599. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// TEST: STORAGE PORT CONTRACTS\n// -------------------------------------------------------------------\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport { describe, expect, it } from 'vitest';\n\nimport {\n  BetterSqliteContentionPolicy,\n  BetterSqliteGraphTraversal,\n  BetterSqliteMaintenance,\n  BetterSqliteVectorStore,\n  PackedBm25LexicalSearch,\n  type ContentionPolicy,\n  type GraphTraversal,\n  type LexicalSearch,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","text":"// -------------------------------------------------------------------\n// TEST: STORAGE PORT CONTRACTS\n// -------------------------------------------------------------------\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport { describe, expect, it } from 'vitest';\n\nimport {\n  BetterSqliteContentionPolicy,\n  BetterSqliteGraphTraversal,\n  BetterSqliteMaintenance,\n  BetterSqliteVectorStore,\n  PackedBm25LexicalSearch,\n  type ContentionPolicy,\n  type GraphTraversal,\n  type LexicalSearch,\n  type Maintenance,\n  type VectorMetadata,\n  type VectorStore,\n} from '../lib/storage/ports';\nimport {\n  FakeContentionPolicy,\n  FakeGraphTraversal,\n  FakeLexicalSearch,\n  FakeMaintenance,\n  FakeVectorStore,\n} from './fakes/storage-ports';\n\ninterface ContractSubject<TPort> {\n  readonly port: TPort;\n  readonly cleanup: () => void;\n}\n\ninterface EnvSnapshot {\n  readonly EMBEDDING_DIM: string | undefined;\n  readonly MEMORY_ALLOWED_PATHS: string | undefined;\n}\n\ntype VectorFixtureMetadata = VectorMetadata & {\n  readonly spec_folder: string;\n  readonly file_path: string;\n  readonly title: string;\n};\n\nfunction snapshotEnv(): EnvSnapshot {\n  return {\n    EMBEDDING_DIM: process.env.EMBEDDING_DIM,\n    MEMORY_ALLOWED_PATHS: process.env.MEMORY_ALLOWED_PATHS,\n  };\n}\n\nfunction restoreEnv(snapshot: EnvSnapshot): void {\n  if (snapshot.EMBEDDING_DIM === undefined) {\n    delete process.env.EMBEDDING_DIM;\n  } else {\n    process.env.EMBEDDING_DIM = snapshot.EMBEDDING_DIM;\n  }\n  if (snapshot.MEMORY_ALLOWED_PATHS === undefined) {\n    delete process.env.MEMORY_ALLOWED_PATHS;\n  } else {\n    process.env.MEMORY_ALLOWED_PATHS = snapshot.MEMORY_ALLOWED_PATHS;\n  }\n}\n\nfunction createGraphFixtureDb(): Database.Database {\n  const database = new Database(':memory:');\n  database.exec(`\n    CREATE TABLE causal_edges (\n      source_id TEXT NOT NULL,\n      target_id TEXT NOT NULL,\n      relation TEXT NOT NULL,\n      strength REAL\n    );\n    CREATE TABLE dependency_edges (\n      parent_path TEXT NOT NULL,\n      child_path TEXT NOT NULL\n    );\n  `);\n\n  const insertCausal = database.prepare(`\n    INSERT INTO causal_edges (source_id, target_id, relation, strength)\n    VALUES (?, ?, ?, ?)\n  `);\n  insertCausal.run('1', '2', 'supports', 0.5);\n  insertCausal.run('2', '3', 'enabled', 0.25);\n\n  const insertDependency = database.prepare(`\n    INSERT INTO dependency_edges (parent_path, child_path)\n    VALUES (?, ?)\n  `);\n  insertDependency.run('root', 'child');\n  insertDependency.run('child', 'grandchild');\n\n  return database;\n}\n\nfunction createFakeGraphTraversal(): FakeGraphTraversal {\n  return new FakeGraphTraversal({\n    causalEdges: [\n      { sourceId: 1, targetId: 2, relation: 'supports', strength: 0.5 },\n      { sourceId: 2, targetId: 3, relation: 'enabled', strength: 0.25 },\n    ],\n    dependencyEdges: [\n      { parentPath: 'root', childPath: 'child' },\n      { parentPath: 'child', childPath: 'grandchild' },\n    ],\n  });\n}\n\nfunction createBetterSqliteVectorSubject(): ContractSubject<VectorStore<VectorFixtureMetadata>> {\n  const env = snapshotEnv();\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-store-port-'));\n  process.env.EMBEDDING_DIM = '4';\n  process.env.MEMORY_ALLOWED_PATHS = tempDir;\n  const store = new BetterSqliteVectorStore({ dbPath: path.join(tempDir, 'context-index.sqlite') });\n  return {\n    port: store,\n    cleanup: () => {\n      void store.close();\n      restoreEnv(env);\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    },\n  };\n}\n\nfunction createBetterSqliteMaintenanceSubject(): ContractSubject<Maintenance> {\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintenance-port-'));\n  const database = new Database(path.join(tempDir, 'maintenance.sqlite'));\n  database.pragma('auto_vacuum = INCREMENTAL');\n  database.exec('VACUUM');\n  database.pragma('journal_mode = WAL');\n  database.exec(`\n    CREATE TABLE records (id INTEGER PRIMARY KEY, value TEXT NOT NULL);\n    INSERT INTO records (value) VALUES ('kept'), ('deleted');\n    DELETE FROM records WHERE value = 'deleted';\n  `);\n\n  return {\n    port: new BetterSqliteMaintenance(database),\n    cleanup: () => {\n      database.close();\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    },\n  };\n}\n\nfunction createBetterSqliteContentionSubject(): ContractSubject<ContentionPolicy> & { database: Database.Database } {\n  const database = new Database(':memory:');\n  database.exec('CREATE TABLE writes (id INTEGER PRIMARY KEY, value TEXT NOT NULL)');\n  return {\n    database,\n    port: new BetterSqliteContentionPolicy({\n      database,\n      sleep: async () => undefined,\n      sleepSync: () => undefined,\n    }),\n    cleanup: () => database.close(),\n  };\n}\n\nfunction runGraphTraversalContract(\n  label: string,\n  createSubject: () => ContractSubject<GraphTraversal>,\n): void {\n  describe(label, () => {\n    it('collects weighted causal neighbors with hop and score aggregation', () => {\n      const subject = createSubject();\n      try {\n        const results = subject.port.collectCausalWeightedNeighbors(\n          [1],\n          2,\n          { supports: 2, enabled: 4 },\n        );\n\n        expect(results.get(2)).toEqual({ nodeId: 2, minHop: 1, maxWalkScore: 1 });\n        expect(results.get(3)).toEqual({ nodeId: 3, minHop: 2, maxWalkScore: 1 });\n        expect(results.has(1)).toBe(false);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('collects dependency children through directed reachability', () => {\n      const subject = createSubject();\n      try {\n        expect(subject.port.collectDependencyReachability(['root'])).toEqual(['child', 'grandchild']);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('exposes generic directed reachability for caller-supplied readers', () => {\n      const subject = createSubject();\n      try {\n        const reached = subject.port.collectDirectedReachability({\n          roots: ['a'],\n          readEdges: (nodeIds) => nodeIds.includes('a')\n            ? [{ from: 'a', to: 'b' }, { from: 'a', to: 'c' }]\n            : [],\n        });\n\n        expect(reached).toEqual(['b', 'c']);\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nfunction runLexicalSearchContract(\n  label: string,\n  createSubject: () => ContractSubject<LexicalSearch>,\n): void {\n  describe(label, () => {\n    it('indexes fielded documents and returns ranked query matches', () => {\n      const subject = createSubject();\n      try {\n        subject.port.addDocumentFields('auth', {\n          title: 'Auth guard',\n          trigger_phrases: ['authentication', 'login'],\n          content_generic: 'auth/module.md',\n          body: 'Guarded login access for memory search',\n        });\n        subject.port.addDocumentFields('cache', {\n          title: 'Cache invalidation',\n          trigger_phrases: ['cache'],\n          content_generic: 'cache/module.md',\n          body: 'Background cache refresh notes',\n        });\n\n        const results = subject.port.search('auth guard', { limit: 1 });\n\n        expect(results).toHaveLength(1);\n        expect(results[0]?.id).toBe('auth');\n        expect(results[0]?.score).toBeGreaterThan(0);\n      } finally {","lineStart":1,"lineEnd":240,"totalLines":599,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","time":{"start":1781150602246,"end":1781150602252}},"metadata":{"openai":{"itemId":"fc_0712198c1a9d2124016a2a338a191c8191b6e9c025c973f3f1"}},"id":"prt_eb4d95405001ZKKDzS5B5scUzQ","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d92c39001gL8QeM0hLAASci"}}
{"type":"tool_use","timestamp":1781150602254,"sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","part":{"type":"tool","tool":"read","callID":"call_6fU7ImhMq5FPPpZYaf6M7iuF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-boost.vitest.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-boost.vitest.ts</path>\n<type>file</type>\n<content>\n1: // TEST: CAUSAL BOOST\n2: import { afterEach, beforeEach, describe, expect, it } from 'vitest';\n3: import Database from 'better-sqlite3';\n4: import * as causalBoost from '../lib/search/causal-boost';\n5: import type { RankedSearchResult } from '../lib/search/causal-boost';\n6: \n7: function createDb() {\n8:   const db = new Database(':memory:');\n9:   db.exec(`\n10:     CREATE TABLE causal_edges (\n11:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n12:       source_id TEXT NOT NULL,\n13:       target_id TEXT NOT NULL,\n14:       relation TEXT NOT NULL,\n15:       strength REAL DEFAULT 1.0,\n16:       evidence TEXT,\n17:       extracted_at TEXT DEFAULT CURRENT_TIMESTAMP,\n18:       created_by TEXT DEFAULT 'manual',\n19:       last_accessed TEXT\n20:     );\n21: \n22:     CREATE TABLE IF NOT EXISTS weight_history (\n23:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n24:       edge_id INTEGER NOT NULL REFERENCES causal_edges(id) ON DELETE CASCADE,\n25:       old_strength REAL NOT NULL,\n26:       new_strength REAL NOT NULL,\n27:       changed_by TEXT DEFAULT 'manual',\n28:       changed_at TEXT DEFAULT (datetime('now')),\n29:       reason TEXT\n30:     );\n31: \n32:     CREATE TABLE memory_index (\n33:       id INTEGER PRIMARY KEY,\n34:       spec_folder TEXT,\n35:       file_path TEXT,\n36:       title TEXT,\n37:       importance_tier TEXT,\n38:       trigger_phrases TEXT,\n39:       created_at TEXT DEFAULT CURRENT_TIMESTAMP\n40:     );\n41:   `);\n42:   causalBoost.init(db);\n43:   return db;\n44: }\n45: \n46: describe('T038-T044 causal boost', () => {\n47:   let db: Database.Database | null = null;\n48:   const previousFlag = process.env.SPECKIT_CAUSAL_BOOST;\n49: \n50:   beforeEach(() => {\n51:     process.env.SPECKIT_CAUSAL_BOOST = 'true';\n52:     db = createDb();\n53:     db.prepare(`\n54:       INSERT INTO memory_index (id, spec_folder, file_path, title, importance_tier, trigger_phrases)\n55:       VALUES\n56:       (1, 'spec', '/tmp/a.md', 'A', 'important', '[]'),\n57:       (2, 'spec', '/tmp/b.md', 'B', 'important', '[]'),\n58:       (3, 'spec', '/tmp/c.md', 'C', 'important', '[]'),\n59:       (4, 'spec', '/tmp/d.md', 'D', 'important', '[]')\n60:     `).run();\n61:   });\n62: \n63:   afterEach(() => {\n64:     if (db) db.close();\n65:     if (previousFlag === undefined) {\n66:       delete process.env.SPECKIT_CAUSAL_BOOST;\n67:     } else {\n68:       process.env.SPECKIT_CAUSAL_BOOST = previousFlag;\n69:     }\n70:   });\n71: \n72:   it('T039/T043: computes 1-hop and 2-hop neighbors from causal_edges', () => {\n73:     db?.prepare(`\n74:       INSERT INTO causal_edges (source_id, target_id, relation)\n75:       VALUES ('1', '2', 'caused'), ('2', '3', 'supports')\n76:     `).run();\n77: \n78:     const boosts = causalBoost.getNeighborBoosts([1]);\n79:     expect(boosts.get(2)?.boost).toBeCloseTo(0.05, 6);\n80:     expect(boosts.get(2)?.hopCount).toBe(1);\n81:     expect(boosts.get(3)?.boost).toBeCloseTo(0.025, 6);\n82:     expect(boosts.get(3)?.hopCount).toBe(2);\n83:   });\n84: \n85:   it('T040/T044: applies bounded boost and deduplicates existing semantic results', () => {\n86:     db?.prepare(`\n87:       INSERT INTO causal_edges (source_id, target_id, relation)\n88:       VALUES ('1', '2', 'caused'), ('1', '3', 'supports')\n89:     `).run();\n90: \n91:     const baseResults = [\n92:       { id: 1, score: 0.9 },\n93:       { id: 2, score: 0.6, sessionBoost: 0.1 },\n94:     ];\n95: \n96:     const { results, metadata } = causalBoost.applyCausalBoost(baseResults as unknown as RankedSearchResult[]);\n97:     const idList = results.map((item) => item.id);\n98: \n99:     expect(metadata.applied).toBe(true);\n100:     expect(metadata.boostedCount).toBeGreaterThanOrEqual(1);\n101:     expect(idList.filter((id) => id === 2)).toHaveLength(1);\n102:     expect(idList.includes(3)).toBe(true);\n103:   });\n104: \n105:   it('T043: handles no edges and cyclic edges without duplication', () => {\n106:     const empty = causalBoost.getNeighborBoosts([4]);\n107:     expect(empty.size).toBe(0);\n108: \n109:     db?.prepare(`\n110:       INSERT INTO causal_edges (source_id, target_id, relation)\n111:       VALUES ('1', '2', 'caused'), ('2', '1', 'supports')\n112:     `).run();\n113: \n114:     const cycle = causalBoost.getNeighborBoosts([1]);\n115:     expect(cycle.get(2)?.boost).toBeCloseTo(0.05, 6);\n116:   });\n117: });\n118: \n119: describe('T008 — Seed cap and multiplier precedence', () => {\n120:   it('RELATION_WEIGHT_MULTIPLIERS covers all relation types from causal-edges', () => {\n121:     const boostRelations = Object.keys(causalBoost.RELATION_WEIGHT_MULTIPLIERS);\n122:     const expectedRelations = ['supersedes', 'contradicts', 'caused', 'enabled', 'derived_from', 'supports'];\n123:     expect(boostRelations).toEqual(expect.arrayContaining(expectedRelations));\n124:   });\n125: \n126:   it('seed cap limits number of seed nodes used for graph walk', () => {\n127:     const localDb = createDb();\n128:     process.env.SPECKIT_CAUSAL_BOOST = 'true';\n129:     // Disable typed traversal to test classic boost values (SPECKIT_TYPED_TRAVERSAL now defaults ON)\n130:     const prevTyped = process.env.SPECKIT_TYPED_TRAVERSAL;\n131:     process.env.SPECKIT_TYPED_TRAVERSAL = 'false';\n132:     localDb.prepare(`\n133:       INSERT INTO memory_index (id, spec_folder, file_path, title, importance_tier, trigger_phrases)\n134:       VALUES\n135:       (1, 'spec', '/tmp/1.md', '1', 'important', '[]'),\n136:       (2, 'spec', '/tmp/2.md', '2', 'important', '[]'),\n137:       (3, 'spec', '/tmp/3.md', '3', 'important', '[]'),\n138:       (4, 'spec', '/tmp/4.md', '4', 'important', '[]'),\n139:       (5, 'spec', '/tmp/5.md', '5', 'important', '[]'),\n140:       (6, 'spec', '/tmp/6.md', '6', 'important', '[]'),\n141:       (7, 'spec', '/tmp/7.md', '7', 'important', '[]'),\n142:       (30, 'spec', '/tmp/30.md', '30', 'important', '[]'),\n143:       (31, 'spec', '/tmp/31.md', '31', 'important', '[]')\n144:     `).run();\n145:     localDb.prepare(`\n146:       INSERT INTO causal_edges (source_id, target_id, relation, strength)\n147:       VALUES\n148:       ('5', '31', 'caused', 1.0),\n149:       ('6', '30', 'caused', 1.0)\n150:     `).run();\n151:     causalBoost.init(localDb);\n152: \n153:     const baseResults = Array.from({ length: 24 }, (_, index) => ({\n154:       id: index + 1,\n155:       score: 1 - index * 0.01,\n156:     }));\n157: \n158:     const { results } = causalBoost.applyCausalBoost(baseResults as RankedSearchResult[]);\n159:     const injectedIds = results.filter((item) => item.injectedByCausalBoost).map((item) => item.id);\n160: \n161:     expect(injectedIds).toContain(31);\n162:     expect(injectedIds).not.toContain(30);\n163: \n164:     const injectedResult = results.find((item) => item.id === 31);\n165:     expect(injectedResult?.causalBoost).toBeCloseTo(0.05, 6);\n166: \n167:     // Restore SPECKIT_TYPED_TRAVERSAL\n168:     if (prevTyped === undefined) delete process.env.SPECKIT_TYPED_TRAVERSAL;\n169:     else process.env.SPECKIT_TYPED_TRAVERSAL = prevTyped;\n170:   });\n171: \n172:   it('relation multipliers change boost precedence behavior', () => {\n173:     const localDb = createDb();\n174:     process.env.SPECKIT_CAUSAL_BOOST = 'true';\n175:     localDb.prepare(`\n176:       INSERT INTO causal_edges (source_id, target_id, relation, strength)\n177:       VALUES ('1', '2', 'supersedes', 1.0), ('1', '3', 'contradicts', 1.0)\n178:     `).run();\n179:     causalBoost.init(localDb);\n180: \n181:     const boosts = causalBoost.getNeighborBoosts([1]);\n182: \n183:     expect(boosts.get(2)?.boost).toBeCloseTo(0.05 * 1.5, 6);\n184:     expect(boosts.get(3)?.boost).toBeCloseTo(0.05 * 0.8, 6);\n185:     expect((boosts.get(2)?.boost ?? 0)).toBeGreaterThan(boosts.get(3)?.boost ?? 0);\n186:   });\n187: });\n\n(End of file - total 187 lines)\n</content>","metadata":{"preview":"// TEST: CAUSAL BOOST\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\nimport Database from 'better-sqlite3';\nimport * as causalBoost from '../lib/search/causal-boost';\nimport type { RankedSearchResult } from '../lib/search/causal-boost';\n\nfunction createDb() {\n  const db = new Database(':memory:');\n  db.exec(`\n    CREATE TABLE causal_edges (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      source_id TEXT NOT NULL,\n      target_id TEXT NOT NULL,\n      relation TEXT NOT NULL,\n      strength REAL DEFAULT 1.0,\n      evidence TEXT,\n      extracted_at TEXT DEFAULT CURRENT_TIMESTAMP,\n      created_by TEXT DEFAULT 'manual',\n      last_accessed TEXT\n    );","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-boost.vitest.ts","text":"// TEST: CAUSAL BOOST\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\nimport Database from 'better-sqlite3';\nimport * as causalBoost from '../lib/search/causal-boost';\nimport type { RankedSearchResult } from '../lib/search/causal-boost';\n\nfunction createDb() {\n  const db = new Database(':memory:');\n  db.exec(`\n    CREATE TABLE causal_edges (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      source_id TEXT NOT NULL,\n      target_id TEXT NOT NULL,\n      relation TEXT NOT NULL,\n      strength REAL DEFAULT 1.0,\n      evidence TEXT,\n      extracted_at TEXT DEFAULT CURRENT_TIMESTAMP,\n      created_by TEXT DEFAULT 'manual',\n      last_accessed TEXT\n    );\n\n    CREATE TABLE IF NOT EXISTS weight_history (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      edge_id INTEGER NOT NULL REFERENCES causal_edges(id) ON DELETE CASCADE,\n      old_strength REAL NOT NULL,\n      new_strength REAL NOT NULL,\n      changed_by TEXT DEFAULT 'manual',\n      changed_at TEXT DEFAULT (datetime('now')),\n      reason TEXT\n    );\n\n    CREATE TABLE memory_index (\n      id INTEGER PRIMARY KEY,\n      spec_folder TEXT,\n      file_path TEXT,\n      title TEXT,\n      importance_tier TEXT,\n      trigger_phrases TEXT,\n      created_at TEXT DEFAULT CURRENT_TIMESTAMP\n    );\n  `);\n  causalBoost.init(db);\n  return db;\n}\n\ndescribe('T038-T044 causal boost', () => {\n  let db: Database.Database | null = null;\n  const previousFlag = process.env.SPECKIT_CAUSAL_BOOST;\n\n  beforeEach(() => {\n    process.env.SPECKIT_CAUSAL_BOOST = 'true';\n    db = createDb();\n    db.prepare(`\n      INSERT INTO memory_index (id, spec_folder, file_path, title, importance_tier, trigger_phrases)\n      VALUES\n      (1, 'spec', '/tmp/a.md', 'A', 'important', '[]'),\n      (2, 'spec', '/tmp/b.md', 'B', 'important', '[]'),\n      (3, 'spec', '/tmp/c.md', 'C', 'important', '[]'),\n      (4, 'spec', '/tmp/d.md', 'D', 'important', '[]')\n    `).run();\n  });\n\n  afterEach(() => {\n    if (db) db.close();\n    if (previousFlag === undefined) {\n      delete process.env.SPECKIT_CAUSAL_BOOST;\n    } else {\n      process.env.SPECKIT_CAUSAL_BOOST = previousFlag;\n    }\n  });\n\n  it('T039/T043: computes 1-hop and 2-hop neighbors from causal_edges', () => {\n    db?.prepare(`\n      INSERT INTO causal_edges (source_id, target_id, relation)\n      VALUES ('1', '2', 'caused'), ('2', '3', 'supports')\n    `).run();\n\n    const boosts = causalBoost.getNeighborBoosts([1]);\n    expect(boosts.get(2)?.boost).toBeCloseTo(0.05, 6);\n    expect(boosts.get(2)?.hopCount).toBe(1);\n    expect(boosts.get(3)?.boost).toBeCloseTo(0.025, 6);\n    expect(boosts.get(3)?.hopCount).toBe(2);\n  });\n\n  it('T040/T044: applies bounded boost and deduplicates existing semantic results', () => {\n    db?.prepare(`\n      INSERT INTO causal_edges (source_id, target_id, relation)\n      VALUES ('1', '2', 'caused'), ('1', '3', 'supports')\n    `).run();\n\n    const baseResults = [\n      { id: 1, score: 0.9 },\n      { id: 2, score: 0.6, sessionBoost: 0.1 },\n    ];\n\n    const { results, metadata } = causalBoost.applyCausalBoost(baseResults as unknown as RankedSearchResult[]);\n    const idList = results.map((item) => item.id);\n\n    expect(metadata.applied).toBe(true);\n    expect(metadata.boostedCount).toBeGreaterThanOrEqual(1);\n    expect(idList.filter((id) => id === 2)).toHaveLength(1);\n    expect(idList.includes(3)).toBe(true);\n  });\n\n  it('T043: handles no edges and cyclic edges without duplication', () => {\n    const empty = causalBoost.getNeighborBoosts([4]);\n    expect(empty.size).toBe(0);\n\n    db?.prepare(`\n      INSERT INTO causal_edges (source_id, target_id, relation)\n      VALUES ('1', '2', 'caused'), ('2', '1', 'supports')\n    `).run();\n\n    const cycle = causalBoost.getNeighborBoosts([1]);\n    expect(cycle.get(2)?.boost).toBeCloseTo(0.05, 6);\n  });\n});\n\ndescribe('T008 — Seed cap and multiplier precedence', () => {\n  it('RELATION_WEIGHT_MULTIPLIERS covers all relation types from causal-edges', () => {\n    const boostRelations = Object.keys(causalBoost.RELATION_WEIGHT_MULTIPLIERS);\n    const expectedRelations = ['supersedes', 'contradicts', 'caused', 'enabled', 'derived_from', 'supports'];\n    expect(boostRelations).toEqual(expect.arrayContaining(expectedRelations));\n  });\n\n  it('seed cap limits number of seed nodes used for graph walk', () => {\n    const localDb = createDb();\n    process.env.SPECKIT_CAUSAL_BOOST = 'true';\n    // Disable typed traversal to test classic boost values (SPECKIT_TYPED_TRAVERSAL now defaults ON)\n    const prevTyped = process.env.SPECKIT_TYPED_TRAVERSAL;\n    process.env.SPECKIT_TYPED_TRAVERSAL = 'false';\n    localDb.prepare(`\n      INSERT INTO memory_index (id, spec_folder, file_path, title, importance_tier, trigger_phrases)\n      VALUES\n      (1, 'spec', '/tmp/1.md', '1', 'important', '[]'),\n      (2, 'spec', '/tmp/2.md', '2', 'important', '[]'),\n      (3, 'spec', '/tmp/3.md', '3', 'important', '[]'),\n      (4, 'spec', '/tmp/4.md', '4', 'important', '[]'),\n      (5, 'spec', '/tmp/5.md', '5', 'important', '[]'),\n      (6, 'spec', '/tmp/6.md', '6', 'important', '[]'),\n      (7, 'spec', '/tmp/7.md', '7', 'important', '[]'),\n      (30, 'spec', '/tmp/30.md', '30', 'important', '[]'),\n      (31, 'spec', '/tmp/31.md', '31', 'important', '[]')\n    `).run();\n    localDb.prepare(`\n      INSERT INTO causal_edges (source_id, target_id, relation, strength)\n      VALUES\n      ('5', '31', 'caused', 1.0),\n      ('6', '30', 'caused', 1.0)\n    `).run();\n    causalBoost.init(localDb);\n\n    const baseResults = Array.from({ length: 24 }, (_, index) => ({\n      id: index + 1,\n      score: 1 - index * 0.01,\n    }));\n\n    const { results } = causalBoost.applyCausalBoost(baseResults as RankedSearchResult[]);\n    const injectedIds = results.filter((item) => item.injectedByCausalBoost).map((item) => item.id);\n\n    expect(injectedIds).toContain(31);\n    expect(injectedIds).not.toContain(30);\n\n    const injectedResult = results.find((item) => item.id === 31);\n    expect(injectedResult?.causalBoost).toBeCloseTo(0.05, 6);\n\n    // Restore SPECKIT_TYPED_TRAVERSAL\n    if (prevTyped === undefined) delete process.env.SPECKIT_TYPED_TRAVERSAL;\n    else process.env.SPECKIT_TYPED_TRAVERSAL = prevTyped;\n  });\n\n  it('relation multipliers change boost precedence behavior', () => {\n    const localDb = createDb();\n    process.env.SPECKIT_CAUSAL_BOOST = 'true';\n    localDb.prepare(`\n      INSERT INTO causal_edges (source_id, target_id, relation, strength)\n      VALUES ('1', '2', 'supersedes', 1.0), ('1', '3', 'contradicts', 1.0)\n    `).run();\n    causalBoost.init(localDb);\n\n    const boosts = causalBoost.getNeighborBoosts([1]);\n\n    expect(boosts.get(2)?.boost).toBeCloseTo(0.05 * 1.5, 6);\n    expect(boosts.get(3)?.boost).toBeCloseTo(0.05 * 0.8, 6);\n    expect((boosts.get(2)?.boost ?? 0)).toBeGreaterThan(boosts.get(3)?.boost ?? 0);\n  });\n});","lineStart":1,"lineEnd":187,"totalLines":187,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/causal-boost.vitest.ts","time":{"start":1781150602248,"end":1781150602253}},"metadata":{"openai":{"itemId":"fc_0712198c1a9d2124016a2a338a19288191a42849f11c0e05b9"}},"id":"prt_eb4d95407001O4gPFdf15EgCc5","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d92c39001gL8QeM0hLAASci"}}
{"type":"tool_use","timestamp":1781150602254,"sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","part":{"type":"tool","tool":"read","callID":"call_hdk3d59i9T5EKAzyoys8Qd04","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { describe, expect, it } from 'vitest';\n2: import Database from 'better-sqlite3';\n3: \n4: import { createMemoStore, MemoStore } from '../lib/storage/memo';\n5: import { FakeGraphTraversal } from './fakes/storage-ports';\n6: \n7: describe('memo storage foundation', () => {\n8:   it('upserts memo records and reads them by input and code hash', () => {\n9:     const db = new Database(':memory:');\n10:     try {\n11:       const store = createMemoStore(db);\n12:       store.upsertMemoRecord({\n13:         componentPath: '/workspace/spec.md',\n14:         inputFingerprint: 'input-a',\n15:         codeHash: 'code-a',\n16:         outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n17:       });\n18: \n19:       expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-a')).toMatchObject({\n20:         componentPath: '/workspace/spec.md',\n21:         inputFingerprint: 'input-a',\n22:         codeHash: 'code-a',\n23:         outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n24:       });\n25:       expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-b')).toBeNull();\n26:     } finally {\n27:       db.close();\n28:     }\n29:   });\n30: \n31:   it('walks dependency edges transitively and invalidates dependent memo rows only', () => {\n32:     const db = new Database(':memory:');\n33:     try {\n34:       const store = createMemoStore(db);\n35:       store.addDependencyEdge({ parentPath: 'source', childPath: 'child-a', kind: 'derived' });\n36:       store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n37:       store.upsertMemoRecord({ componentPath: 'source', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n38:       store.upsertMemoRecord({ componentPath: 'child-a', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n39:       store.upsertMemoRecord({ componentPath: 'child-b', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n40:       store.upsertMemoRecord({ componentPath: 'unrelated', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n41: \n42:       const result = store.invalidateDependents(['source']);\n43: \n44:       expect(result.invalidatedPaths).toEqual(['child-a', 'child-b']);\n45:       expect(result.deletedMemoRecords).toBe(2);\n46:       expect(store.getMemoRecord('source', 'i', 'c')).not.toBeNull();\n47:       expect(store.getMemoRecord('child-a', 'i', 'c')).toBeNull();\n48:       expect(store.getMemoRecord('child-b', 'i', 'c')).toBeNull();\n49:       expect(store.getMemoRecord('unrelated', 'i', 'c')).not.toBeNull();\n50:     } finally {\n51:       db.close();\n52:     }\n53:   });\n54: \n55:   it('rejects dependency cycles', () => {\n56:     const db = new Database(':memory:');\n57:     try {\n58:       const store = createMemoStore(db);\n59:       store.addDependencyEdge({ parentPath: 'a', childPath: 'b', kind: 'derived' });\n60:       store.addDependencyEdge({ parentPath: 'b', childPath: 'c', kind: 'derived' });\n61: \n62:       expect(() => store.addDependencyEdge({ parentPath: 'c', childPath: 'a', kind: 'derived' }))\n63:         .toThrow(/cycle/);\n64:     } finally {\n65:       db.close();\n66:     }\n67:   });\n68: \n69:   it('uses an injected graph traversal port without opening SQLite', () => {\n70:     const fakeDatabase = {\n71:       exec: () => undefined,\n72:       prepare: () => ({\n73:         get: () => ({ edge_count: 1 }),\n74:       }),\n75:     } as unknown as Database.Database;\n76:     const graphTraversal = new FakeGraphTraversal({\n77:       dependencyEdges: [\n78:         { parentPath: 'root', childPath: 'child' },\n79:         { parentPath: 'child', childPath: 'grandchild' },\n80:       ],\n81:     });\n82: \n83:     const store = new MemoStore(fakeDatabase, graphTraversal);\n84: \n85:     expect(store.collectDependents(['root'])).toEqual(['child', 'grandchild']);\n86:   });\n87: });\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"import { describe, expect, it } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport { createMemoStore, MemoStore } from '../lib/storage/memo';\nimport { FakeGraphTraversal } from './fakes/storage-ports';\n\ndescribe('memo storage foundation', () => {\n  it('upserts memo records and reads them by input and code hash', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.upsertMemoRecord({\n        componentPath: '/workspace/spec.md',\n        inputFingerprint: 'input-a',\n        codeHash: 'code-a',\n        outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n      });\n\n      expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-a')).toMatchObject({\n        componentPath: '/workspace/spec.md',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts","text":"import { describe, expect, it } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport { createMemoStore, MemoStore } from '../lib/storage/memo';\nimport { FakeGraphTraversal } from './fakes/storage-ports';\n\ndescribe('memo storage foundation', () => {\n  it('upserts memo records and reads them by input and code hash', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.upsertMemoRecord({\n        componentPath: '/workspace/spec.md',\n        inputFingerprint: 'input-a',\n        codeHash: 'code-a',\n        outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n      });\n\n      expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-a')).toMatchObject({\n        componentPath: '/workspace/spec.md',\n        inputFingerprint: 'input-a',\n        codeHash: 'code-a',\n        outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n      });\n      expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-b')).toBeNull();\n    } finally {\n      db.close();\n    }\n  });\n\n  it('walks dependency edges transitively and invalidates dependent memo rows only', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.addDependencyEdge({ parentPath: 'source', childPath: 'child-a', kind: 'derived' });\n      store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n      store.upsertMemoRecord({ componentPath: 'source', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n      store.upsertMemoRecord({ componentPath: 'child-a', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n      store.upsertMemoRecord({ componentPath: 'child-b', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n      store.upsertMemoRecord({ componentPath: 'unrelated', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n\n      const result = store.invalidateDependents(['source']);\n\n      expect(result.invalidatedPaths).toEqual(['child-a', 'child-b']);\n      expect(result.deletedMemoRecords).toBe(2);\n      expect(store.getMemoRecord('source', 'i', 'c')).not.toBeNull();\n      expect(store.getMemoRecord('child-a', 'i', 'c')).toBeNull();\n      expect(store.getMemoRecord('child-b', 'i', 'c')).toBeNull();\n      expect(store.getMemoRecord('unrelated', 'i', 'c')).not.toBeNull();\n    } finally {\n      db.close();\n    }\n  });\n\n  it('rejects dependency cycles', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.addDependencyEdge({ parentPath: 'a', childPath: 'b', kind: 'derived' });\n      store.addDependencyEdge({ parentPath: 'b', childPath: 'c', kind: 'derived' });\n\n      expect(() => store.addDependencyEdge({ parentPath: 'c', childPath: 'a', kind: 'derived' }))\n        .toThrow(/cycle/);\n    } finally {\n      db.close();\n    }\n  });\n\n  it('uses an injected graph traversal port without opening SQLite', () => {\n    const fakeDatabase = {\n      exec: () => undefined,\n      prepare: () => ({\n        get: () => ({ edge_count: 1 }),\n      }),\n    } as unknown as Database.Database;\n    const graphTraversal = new FakeGraphTraversal({\n      dependencyEdges: [\n        { parentPath: 'root', childPath: 'child' },\n        { parentPath: 'child', childPath: 'grandchild' },\n      ],\n    });\n\n    const store = new MemoStore(fakeDatabase, graphTraversal);\n\n    expect(store.collectDependents(['root'])).toEqual(['child', 'grandchild']);\n  });\n});","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts","time":{"start":1781150602249,"end":1781150602254}},"metadata":{"openai":{"itemId":"fc_0712198c1a9d2124016a2a338a1dc881918e6a03bdc9fc0833"}},"id":"prt_eb4d95408001xri9HFww9B5f57","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d92c39001gL8QeM0hLAASci"}}
