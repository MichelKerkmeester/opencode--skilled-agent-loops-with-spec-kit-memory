tests/check-graph-metadata-child-drift.sh\n.opencode/skills/system-spec-kit/scripts/tests/check-graph-metadata-shape-last-active-child.sh\n.opencode/skills/system-spec-kit/scripts/tests/test-dist-freshness.sh\n.opencode/skills/system-spec-kit/scripts/tests/test-phase-system.sh\n.opencode/skills/system-spec-kit/scripts/tests/test-upgrade-level.sh\n.opencode/skills/system-spec-kit/scripts/tests/test-validation-extended.sh\n.opencode/skills/system-spec-kit/scripts/tests/test-validation.sh\n.opencode/skills/system-spec-kit/scripts/validate-command-tree-parity.sh\n","exit":0,"truncated":false},"title":"echo \"=== ALL SKILL DIRECTORIES ===\" && ls -d .opencode/skills/*/ && echo \"=== NESTED SKILLS ===\" && find .opencode/skills -name \"SKILL.md\" -maxdepth 3 | sort && echo \"=== ANY MISSED SCRIPTS? ===\" && find .opencode/skills -name \"*.sh\" -not -path \"*/node_modules/*\" -not -path \"*/benchmark/*\" | sort","time":{"start":1783744547189,"end":1783744547191}},"id":"prt_f4f75c6bb001nDwJ68qEU3mi1B","sessionID":"ses_0b0929e35ffeiPmK0rQRK8nw1B","messageID":"msg_f4f758dbe001o3RXzqTWfyt6qU"}}
