(explicitTrustBadgePartial, derivedTrustBadges);\n882: \n883:     if (includeTrace) {\n884:       const anchorsInfo = extractAnchorDetails(rawResult);\n885:       formattedResult.scores = {\n886:         semantic: toNullableNumber(rawResult.similarity ?? rawResult.averageSimilarity),\n887:         lexical: toNullableNumber(rawResult.fts_score ?? rawResult.bm25_score ?? (rawResult.sourceScores as Record<string, number> | undefined)?.keyword ?? (rawResult.sourceScores as Record<string, number> | undefined)?.fts ?? (rawResult.sourceScores as Record<string, number> | undefined)?.bm25),\n888:         fusion: toNullableNumber(rawResult.rrfScore),\n889:         intentAdjusted: toNullableNumber(rawResult.intentAdjustedScore),\n\n(Showing lines 820-889 of 1169. Use offset=890 to continue.)\n</content>","metadata":{"preview":"      tool: 'memory_search',\n      summary: 'No matching memories found',\n      data: {\n        searchType: searchType,\n        constitutionalCount: 0,\n        ...(requestQualityData ?? {}),\n        // Preserve caller metadata, but keep trace-only fields opt-in.\n        ...safeExtraData,\n        // Attach recovery payload (additive, only when flag enabled)\n        ...(recoveryPayload !== null ? { recovery: recoveryPayload } : {}),\n        citationPolicy,\n        ...(responsePolicy !== null ? { responsePolicy } : {}),\n      },\n      hints: [\n        'Try broadening your search query',\n        'Use memory_list() to browse available memories',\n        'Check if specFolder filter is too restrictive'\n      ],\n      startTime: startMs\n    });","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","text":"      tool: 'memory_search',\n      summary: 'No matching memories found',\n      data: {\n        searchType: searchType,\n        constitutionalCount: 0,\n        ...(requestQualityData ?? {}),