def _apply_deep_skill_routing_layer(\n\n  Line 2832:     payload = deep_skill_routing_payload(prompt, packet_context or {})\n\n  Line 2862:         note = f\" [Candidate-3 deep routing: {payload['skill']} {mode} {payload['confidence_band']}]\"\n\n  Line 4009:     _apply_deep_skill_routing_layer(recommendations, prompt)\n\n  Line 4317:                         help='Read {\"prompt\": str, \"packet_context\": object} from stdin and emit Candidate-3 deep routing.')\n\n  Line 4366:     if args.deep_skill_routing_json:\n\n  Line 4380:         print(json.dumps(deep_skill_routing_payload(prompt, packet_context), indent=2))\n","metadata":{"matches":21,"truncated":false},"title":"deep.{0,3}routing|deep_skill_routing|def recommend|recommend_skill|def score_deep|return \\[?\\{.*skill","time":{"start":1784313863563,"end":1784313863601}},"id":"prt_f7164dd890014AuxeAKRDrAycI","sessionID":"ses_08ea082cdffeOdjcwgjfes92M1","messageID":"msg_f716496ff001maq3PwMJMe5mHq"}}
