    43	def load_advisor_module() -> Any:
    44	    """Load the advisor module from disk for in-process benchmarks."""
    45	    spec = importlib.util.spec_from_file_location("skill_advisor", ADVISOR_PATH)
    46	    if spec is None or spec.loader is None:
    47	        raise RuntimeError(f"Failed to load advisor module from {ADVISOR_PATH}")
    48	
    49	    module = importlib.util.module_from_spec(spec)
    50	    spec.loader.exec_module(module)
    51	    return module
    52	
    53	
    54	def load_prompts_from_dataset(path: str) -> List[str]:
    55	    """Read prompt strings from a JSONL benchmark dataset.
    56	
    57	    Raises ValueError when any row is malformed or missing a non-empty
    58	    ``prompt`` field so that bench and regression scripts share the same
    59	    validation contract.
    60	    """
    61	    prompts: List[str] = []
    62	    with open(path, "r", encoding="utf-8") as handle:
    63	        for line_number, raw in enumerate(handle, start=1):
    64	            stripped = raw.strip()
    65	            if not stripped:
    66	                continue
    67	            try:
    68	                row = json.loads(stripped)
    69	            except (ValueError, json.JSONDecodeError) as exc:
    70	                raise ValueError(f"Invalid JSONL at line {line_number}: {exc}") from exc
    71	            if not isinstance(row, dict):
    72	                raise ValueError(f"JSONL line {line_number}: expected object, got {type(row).__name__}")
    73	            prompt = row.get("prompt", "").strip()
    74	            if not prompt:
    75	                raise ValueError(f"JSONL line {line_number}: missing or empty 'prompt' field")
    76	            prompts.append(prompt)
    77	    return prompts
    78	
    79	
    80	# ───────────────────────────────────────────────────────────────
    81	# 4. METRICS
