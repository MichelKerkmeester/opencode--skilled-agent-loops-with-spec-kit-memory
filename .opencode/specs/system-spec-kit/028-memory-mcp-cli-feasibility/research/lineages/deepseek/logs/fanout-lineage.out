nProxySocketPath());\n805:   return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n806: }\n807: \n808: function sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n809:   const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n810:   return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n811: }\n812: \n813: function writeSharedModelServerPid(pid) {\n814:   const socketPath = resolveModelServerSocketPath();\n815:   const pidPath = sharedModelServerPidPath(socketPath);\n816:   if (!Number.isInteger(pid) || pid <= 0) {\n817:     try {\n818:       fs.unlinkSync(pidPath);\n819:     } catch (error) {\n820:       if (error.code === 'ENOENT') return true;\n821:       if (isDurableWriteUnavailable(error)) {\n822:         logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n823:         return false;\n824:       }\n825:       throw error;\n826:     }\n827:     return true;\n828:   }\n829: \n830:   return writeAtomicJsonFile(pidPath, {\n831:     pid,\n832:     startedAt: new Date().toISOString(),\n833:     ownerLauncher: 'mk-spec-memory',\n834:     socketPath,\n835:   }, 'shared model-server pid write');\n836: }\n837: \n838: function readSharedModelServerPid() {\n839:   const pidPath = sharedModelServerPidPath();\n840:   try {\n841:     const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n842:     if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n843:   } catch (error) {\n844:     if (error.code !== 'ENOENT') {\n845:       // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n846:     }\n847:   }\n848: \n849:   const lease = readLeaseFile();\n850:   return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n851: }\n852: \n853: const hfControl = mss.createModelServerControl({\n854:   log,\n855:   env: process.env,\n856:   rootDir: root,\n857:   opencodeDir,\n858:   dbDir: resolvedDbDir,\n859:   getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n860:   onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n861:   bridge: loadBridgeModule(),\n862:   writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n863:   readModelServerPid: () => readSharedModelServerPid(),\n864:   writeLease: () => writeLeaseFile(),\n865: });\n866: \n867: function clearLeaseFile() {\n868:   try {\n869:     const lease = readLeaseFile();\n870:     if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n871:       try {\n872:         hfControl.reapProcessTree(lease.modelServerPid);\n873:       } catch {\n874:         // Lease cleanup must remain best-effort even if a final process-tree read fails.\n875:       }\n876:     }\n877:     if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n878:   } catch {\n879:     // Idempotent cleanup.\n880:   }\n881: }\n882: \n883: function clearAllLeaseFiles() {\n884:   clearLeaseFile();\n885:   clearOwnerLeaseFile();\n886: }\n887: \n888: function isInside(parent, child) {\n889:   const relative = path.relative(parent, child);\n890:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n891: }\n892: \n893: function enforceStandaloneCodeGraphDb(actions) {\n894:   const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n895:   const resolvedCurrent = current ? path.resolve(current) : null;\n896:   const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n897:   const specKitRoot = path.resolve(kitDir);\n898: \n899:   if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n900:     process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n901:     actions.push(\n902:       `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n903:     );\n904:   }\n905: }\n906: \n907: function run(command, args, options = {}) {\n908:   const 