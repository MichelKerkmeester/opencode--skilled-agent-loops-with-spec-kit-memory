erPid: null, staleReclaimable: false, startedAt: null, legacyPath };\n506:       }\n507:     } catch {\n508:       return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath };\n509:     }\n510:   }\n511:   const startedAt = lease.startedAt ?? new Date(0).toISOString();\n512:   try {\n513:     process.kill(lease.pid, 0);\n514:     return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath };\n515:   } catch (error) {\n516:     if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath };\n517:     // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n518:     if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath };\n519:     throw error;\n520:   }\n521: }\n522: \n523: function isLeaseHeld() {\n524:   const primary = leaseHeldFromFile(leasePath());\n525:   if (primary.held) return primary;\n526: \n527:   for (const legacyPath of legacyLeasePaths()) {\n528:     if (legacyPath === leasePath()) continue;\n529:     const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n530:     if (legacy.held || legacy.staleReclaimable) return legacy;\n531:   }\n532: \n533:   return primary;\n534: }\n535: \n536: function writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n537:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n538:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n539:   process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n\n(Showing lines 480-539 of 1022. Use offset=540 to continue.)\n</content>","metadata":{"preview":"  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    const pid = parsed[pidField];\n    if (!Number.isInteger(pid)) return false;\n    try { process.kill(pid, 0); return true; } // live\n    catch (error) { return error.code === 'EPERM'; } // EPERM = exists but no perm → treat live; ESRCH = dead\n  } catch { return false; } // missing/unreadable → not live\n}\n\n// A former-location DB is still \"owned\" if EITHER the launcher PID lease\n// (.mk-code-index-launcher.json) or the owner lease (.code-graph-owner.json) names a live process.\nfunction formerLocationOwnerLive(dir) {\n  return pidLiveAt(path.join(dir, '.mk-code-index-launcher.json'), 'pid')\n      || pidLiveAt(path.join(dir, '.code-graph-owner.json'), 'ownerPid');\n}\n\nfunction leaseHeldFromFile(filePath, legacyPath = null) {\n  const lease = readLeaseFile(filePath);\n  if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath };\n  // Do not bridge to a LEGACY-location lease unless its lease file is owned by the","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","text":"  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    const pid = parsed[pidField];\n    if (!Number.isInteger(pid)) return false;\n    try { process.kill(pid, 0); return true; } // live\n    catch (error) { return error.code === 'EPERM'; } // EPERM = exists but no perm → treat live; ESRCH = dead\n  } catch { return false; } // missing/unreadable → not live\n}\n\n// A former-location DB is still \"owned\" if EITHER the launcher PID lease\n// (.mk-code-index-launcher.json) or the owner lease (.code-graph-owner.json) names a live process.\nfunction formerLocationOwnerLive(dir) {\n  return pidLiveAt(path.join(dir, '.mk-code-index-launcher.json'), 'pid')\n      || pidLiveAt(path.join(dir, '.code-graph-owner.json'), 'ownerPid');\n}\n\nfunction leaseHeldFromFile(filePath, legacyPath = null) {\n  const lease = readLeaseFile(filePath);\n  if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath };\n  // Do not bridge to a LEGACY-location lease unless its lease file is owned by the\n  // current user. A foreign-owned lease in a shared/former path could otherwise point this\n  // client at a spoofed IPC socket.\n  if (legacyPath && typeof process.getuid === 'function') {\n    try {\n      if (fs.statSync(filePath).uid !== process.getuid()) {\n        return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath };\n      }\n    } catch {\n      return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath };\n    }\n  }\n  const startedAt = lease.startedAt ?? new Date(0).toISOString();\n  try {\n    process.kill(lease.pid, 0);\n    return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath };\n  } catch (error) {\n    if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath };\n    // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n    if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath };\n    throw error;\n  }\n}\n\nfunction isLeaseHeld() {\n  const primary = leaseHeldFromFile(leasePath());\n  if (primary.held) return primary;\n\n  for (const legacyPath of legacyLeasePaths()) {\n    if (legacyPath === leasePath()) continue;\n    const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n    if (legacy.held || legacy.staleReclaimable) return legacy;\n  }\n\n  return primary;\n}\n\nfunction writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);","lineStart":480,"lineEnd":539,"totalLines":1022,"truncated":true}},"title":".opencode/bin/mk-code-index-launcher.cjs","time":{"start":1780906553167,"end":1780906553173}},"metadata":{"openai":{"itemId":"fc_0d776cc5d0694b36016a267a38ee1c8191ad4215e3a10584ab"}},"id":"prt_ea64d6ede0016wsd062tDK86Z9","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64d4111001YBFZsI6XxDNsNO"}}
{"type":"tool_use","timestamp":1780906553188,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_e8vYLW1MYeaGRh6WDiZ4xSeX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/session-cleanup.sh","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/session-cleanup.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Clean up MCP helper descendants owned by the current Claude Code session.\n3: #\n4: # This script is intentionally session-scoped: it only ever kills processes it\n5: # can prove are descendants of CLAUDE_SESSION_PID, and it re-proves that\n6: # ancestry immediately before each kill. There is deliberately NO fallback to\n7: # the hook's PPID — under a shared terminal that PPID can resolve to an\n8: # ancestor common to MANY live sessions, turning \"this session's descendants\"\n9: # into \"every session's MCP helpers\" and killing sibling sessions' transports\n10: # mid-flight. Missing session identity means we do nothing.\n11: \n12: set -euo pipefail\n13: \n14: SESSION_PID=\"${CLAUDE_SESSION_PID:-}\"\n15: LOG_PATH=\"${CLAUDE_SESSION_CLEANUP_LOG_PATH:-${HOME:-/tmp}/.local/share/claude-stop-hook.log}\"\n16: EXIT_CODE=0\n17: descendants=()\n18: \n19: # Orphan-sweep fallback for the no-session-pid case. Default off. \"dry-run\" logs candidate reaps\n20: # without mutating; \"1\"/\"on\"/\"live\" reaps. It delegates to the ORPHAN-ONLY sweeper, which reaps only\n21: # ownerless (reparented) MCP processes and so can never touch a live sibling session — unlike a PPID\n22: # guess, which this script deliberately refuses (see header). The sweeper path is overridable for tests.\n23: SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n24: ORPHAN_SWEEP_MODE=\"${SPECKIT_STOP_HOOK_ORPHAN_SWEEP:-off}\"\n25: ORPHAN_SWEEPER_BIN=\"${SPECKIT_ORPHAN_SWEEPER_BIN:-$SCRIPT_DIR/orphan-mcp-sweeper.sh}\"\n26: \n27: emit() {\n28:   local line\n29:   line=\"$(date '+%Y-%m-%dT%H:%M:%S%z') $*\"\n30:   printf '%s\\n' \"$line\"\n31:   if [ -n \"$LOG_PATH\" ]; then\n32:     mkdir -p \"$(dirname \"$LOG_PATH\")\" 2>/dev/null || true\n33:     printf '%s\\n' \"$line\" >> \"$LOG_PATH\" 2>/dev/null || true\n34:   fi\n35: }\n36: \n37: pid_in_descendants() {\n38:   local needle=\"$1\"\n39:   local item\n40:   [ \"${#descendants[@]}\" -gt 0 ] || return 1\n41:   for item in \"${descendants[@]}\"; do\n42:     [ \"$item\" = \"$needle\" ] && return 0\n43:   done\n44:   return 1\n45: }\n46: \n47: append_descendants() {\n48:   local parent=\"$1\"\n49:   local child\n50:   while read -r child; do\n51:     [ -n \"$child\" ] || continue\n52:     if ! pid_in_descendants \"$child\"; then\n53:       descendants+=(\"$child\")\n54:       append_descendants \"$child\"\n55:     fi\n56:   done <<EOF\n57: $(pgrep -P \"$parent\" 2>/dev/null || true)\n58: EOF\n59: }\n60: \n61: is_target_command() {\n62:   local cmd=\"$1\"\n63:   case \"$cmd\" in\n64:     *\"mk-spec-memory-launcher.cjs\"*|\\\n65:     *\"mk-skill-advisor-launcher.cjs\"*|\\\n66:     *\"mk-code-index-launcher.cjs\"*|\\\n67:     *\"system-spec-kit/mcp_server/dist/context-server.js\"*|\\\n68:     *\"system-skill-advisor/mcp_server/dist/\"*\"advisor-server.js\"*|\\\n69:     *\"system-code-graph/mcp_server/dist/index.js\"*|\\\n70:     *\"mcp-code-mode/mcp_server/dist/index.js\"*|\\\n71:     *\"@modelcontextprotocol/server-sequential-thinking\"*|\\\n72:     *\"server-sequential-thinking\"*|\\\n73:     *\"clickup-mcp-server\"*)\n74:       return 0\n75:       ;;\n76:   esac\n77:   return 1\n78: }\n79: \n80: # Re-prove, at kill time, that a candidate is still a descendant of the\n81: # session. The pgrep walk above is a snapshot; a process can be re-parented\n82: # (orphan adoption by launchd/init) between the walk and the kill, and a pid\n83: # can in principle be recycled. Walking the live ppid chain upward closes\n84: # that race: a process belonging to a sibling session can never have OUR\n85: # session pid in its ancestor chain.\n86: is_descendant_of_session() {\n87:   local pid=\"$1\"\n88:   local depth=0\n89:   local current=\"$pid\"\n90:   while [ \"$depth\" -lt 15 ]; do\n91:     current=\"$(ps -o ppid= -p \"$current\" 2>/dev/null | tr -d ' ' || true)\"\n92:     [ -n \"$current\" ] || return 1\n93:     [ \"$current\" = \"0\" ] && return 1\n94:     [ \"$current\" = \"1\" ] && return 1\n95:     if [ \"$current\" = \"$SESSION_PID\" ]; then\n96:       return 0\n97:     fi\n98:     depth=$((depth + 1))\n99:   done\n100:   return 1\n101: }\n102: \n103: # Without a session pid the session-scoped kill below is impossible, and guessing is unsafe. Fall\n104: # back to the orphan-only sweeper when explicitly enabled; otherwise keep the historical no-op.\n105: run_orphan_sweep_fallback() {\n106:   case \"$ORPHAN_SWEEP_MODE\" in\n107:     1|on|live)\n108:       emit \"action=orphan-sweep mode=live reason=no-session-pid\"\n109:       bash \"$ORPHAN_SWEEPER_BIN\" || true\n110:       ;;\n111:     dry-run|dryrun|dry)\n112:       emit \"action=orphan-sweep mode=dry-run reason=no-session-pid\"\n113:       bash \"$ORPHAN_SWEEPER_BIN\" --dry-run || true\n114:       ;;\n115:     *)\n116:       emit \"action=skip reason=no-session-pid\"\n117:       ;;\n118:   esac\n119: }\n120: \n121: if [ -z \"$SESSION_PID\" ]; then\n122:   run_orphan_sweep_fallback\n123:   exit 0\n124: fi\n125: if ! kill -0 \"$SESSION_PID\" 2>/dev/null; then\n126:   emit \"action=skip reason=session-pid-not-alive session_pid=$SESSION_PID\"\n127:   exit 0\n128: fi\n129: \n130: append_descendants \"$SESSION_PID\"\n131: emit \"action=start session_pid=$SESSION_PID descendants=${#descendants[@]}\"\n132: \n133: if [ \"${#descendants[@]}\" -gt 0 ]; then\n134:   for pid in \"${descendants[@]}\"; do\n135:     cmd=\"$(ps -p \"$pid\" -o command= 2>/dev/null || true)\"\n136:     [ -n \"$cmd\" ] || continue\n137:     if is_target_command \"$cmd\"; then\n138:       if ! is_descendant_of_session \"$pid\"; then\n139:         emit \"action=skip-kill reason=ancestry-not-confirmed pid=$pid matched_by=name ancestor_ok=no command=$cmd\"\n140:         continue\n141:       fi\n142:       emit \"action=kill signal=TERM pid=$pid matched_by=name ancestor_ok=yes command=$cmd\"\n143:       if ! kill -15 \"$pid\" 2>/dev/null; then\n144:         emit \"action=kill-failed signal=TERM pid=$pid\"\n145:         EXIT_CODE=1\n146:       fi\n147:     fi\n148:   done\n149: fi\n150: \n151: emit \"action=summary session_pid=$SESSION_PID exit_code=$EXIT_CODE\"\n152: exit \"$EXIT_CODE\"\n\n(End of file - total 152 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Clean up MCP helper descendants owned by the current Claude Code session.\n#\n# This script is intentionally session-scoped: it only ever kills processes it\n# can prove are descendants of CLAUDE_SESSION_PID, and it re-proves that\n# ancestry immediately before each kill. There is deliberately NO fallback to\n# the hook's PPID — under a shared terminal that PPID can resolve to an\n# ancestor common to MANY live sessions, turning \"this session's descendants\"\n# into \"every session's MCP helpers\" and killing sibling sessions' transports\n# mid-flight. Missing session identity means we do nothing.\n\nset -euo pipefail\n\nSESSION_PID=\"${CLAUDE_SESSION_PID:-}\"\nLOG_PATH=\"${CLAUDE_SESSION_CLEANUP_LOG_PATH:-${HOME:-/tmp}/.local/share/claude-stop-hook.log}\"\nEXIT_CODE=0\ndescendants=()\n\n# Orphan-sweep fallback for the no-session-pid case. Default off. \"dry-run\" logs candidate reaps\n# without mutating; \"1\"/\"on\"/\"live\" reaps. It delegates to the ORPHAN-ONLY sweeper, which reaps only","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/session-cleanup.sh","text":"#!/usr/bin/env bash\n# Clean up MCP helper descendants owned by the current Claude Code session.\n#\n# This script is intentionally session-scoped: it only ever kills processes it\n# can prove are descendants of CLAUDE_SESSION_PID, and it re-proves that\n# ancestry immediately before each kill. There is deliberately NO fallback to\n# the hook's PPID — under a shared terminal that PPID can resolve to an\n# ancestor common to MANY live sessions, turning \"this session's descendants\"\n# into \"every session's MCP helpers\" and killing sibling sessions' transports\n# mid-flight. Missing session identity means we do nothing.\n\nset -euo pipefail\n\nSESSION_PID=\"${CLAUDE_SESSION_PID:-}\"\nLOG_PATH=\"${CLAUDE_SESSION_CLEANUP_LOG_PATH:-${HOME:-/tmp}/.local/share/claude-stop-hook.log}\"\nEXIT_CODE=0\ndescendants=()\n\n# Orphan-sweep fallback for the no-session-pid case. Default off. \"dry-run\" logs candidate reaps\n# without mutating; \"1\"/\"on\"/\"live\" reaps. It delegates to the ORPHAN-ONLY sweeper, which reaps only\n# ownerless (reparented) MCP processes and so can never touch a live sibling session — unlike a PPID\n# guess, which this script deliberately refuses (see header). The sweeper path is overridable for tests.\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nORPHAN_SWEEP_MODE=\"${SPECKIT_STOP_HOOK_ORPHAN_SWEEP:-off}\"\nORPHAN_SWEEPER_BIN=\"${SPECKIT_ORPHAN_SWEEPER_BIN:-$SCRIPT_DIR/orphan-mcp-sweeper.sh}\"\n\nemit() {\n  local line\n  line=\"$(date '+%Y-%m-%dT%H:%M:%S%z') $*\"\n  printf '%s\\n' \"$line\"\n  if [ -n \"$LOG_PATH\" ]; then\n    mkdir -p \"$(dirname \"$LOG_PATH\")\" 2>/dev/null || true\n    printf '%s\\n' \"$line\" >> \"$LOG_PATH\" 2>/dev/null || true\n  fi\n}\n\npid_in_descendants() {\n  local needle=\"$1\"\n  local item\n  [ \"${#descendants[@]}\" -gt 0 ] || return 1\n  for item in \"${descendants[@]}\"; do\n    [ \"$item\" = \"$needle\" ] && return 0\n  done\n  return 1\n}\n\nappend_descendants() {\n  local parent=\"$1\"\n  local child\n  while read -r child; do\n    [ -n \"$child\" ] || continue\n    if ! pid_in_descendants \"$child\"; then\n      descendants+=(\"$child\")\n      append_descendants \"$child\"\n    fi\n  done <<EOF\n$(pgrep -P \"$parent\" 2>/dev/null || true)\nEOF\n}\n\nis_target_command() {\n  local cmd=\"$1\"\n  case \"$cmd\" in\n    *\"mk-spec-memory-launcher.cjs\"*|\\\n    *\"mk-skill-advisor-launcher.cjs\"*|\\\n    *\"mk-code-index-launcher.cjs\"*|\\\n    *\"system-spec-kit/mcp_server/dist/context-server.js\"*|\\\n    *\"system-skill-advisor/mcp_server/dist/\"*\"advisor-server.js\"*|\\\n    *\"system-code-graph/mcp_server/dist/index.js\"*|\\\n    *\"mcp-code-mode/mcp_server/dist/index.js\"*|\\\n    *\"@modelcontextprotocol/server-sequential-thinking\"*|\\\n    *\"server-sequential-thinking\"*|\\\n    *\"clickup-mcp-server\"*)\n      return 0\n      ;;\n  esac\n  return 1\n}\n\n# Re-prove, at kill time, that a candidate is still a descendant of the\n# session. The pgrep walk above is a snapshot; a process can be re-parented\n# (orphan adoption by launchd/init) between the walk and the kill, and a pid\n# can in principle be recycled. Walking the live ppid chain upward closes\n# that race: a process belonging to a sibling session can never have OUR\n# session pid in its ancestor chain.\nis_descendant_of_session() {\n  local pid=\"$1\"\n  local depth=0\n  local current=\"$pid\"\n  while [ \"$depth\" -lt 15 ]; do\n    current=\"$(ps -o ppid= -p \"$current\" 2>/dev/null | tr -d ' ' || true)\"\n    [ -n \"$current\" ] || return 1\n    [ \"$current\" = \"0\" ] && return 1\n    [ \"$current\" = \"1\" ] && return 1\n    if [ \"$current\" = \"$SESSION_PID\" ]; then\n      return 0\n    fi\n    depth=$((depth + 1))\n  done\n  return 1\n}\n\n# Without a session pid the session-scoped kill below is impossible, and guessing is unsafe. Fall\n# back to the orphan-only sweeper when explicitly enabled; otherwise keep the historical no-op.\nrun_orphan_sweep_fallback() {\n  case \"$ORPHAN_SWEEP_MODE\" in\n    1|on|live)\n      emit \"action=orphan-sweep mode=live reason=no-session-pid\"\n      bash \"$ORPHAN_SWEEPER_BIN\" || true\n      ;;\n    dry-run|dryrun|dry)\n      emit \"action=orphan-sweep mode=dry-run reason=no-session-pid\"\n      bash \"$ORPHAN_SWEEPER_BIN\" --dry-run || true\n      ;;\n    *)\n      emit \"action=skip reason=no-session-pid\"\n      ;;\n  esac\n}\n\nif [ -z \"$SESSION_PID\" ]; then\n  run_orphan_sweep_fallback\n  exit 0\nfi\nif ! kill -0 \"$SESSION_PID\" 2>/dev/null; then\n  emit \"action=skip reason=session-pid-not-alive session_pid=$SESSION_PID\"\n  exit 0\nfi\n\nappend_descendants \"$SESSION_PID\"\nemit \"action=start session_pid=$SESSION_PID descendants=${#descendants[@]}\"\n\nif [ \"${#descendants[@]}\" -gt 0 ]; then\n  for pid in \"${descendants[@]}\"; do\n    cmd=\"$(ps -p \"$pid\" -o command= 2>/dev/null || true)\"\n    [ -n \"$cmd\" ] || continue\n    if is_target_command \"$cmd\"; then\n      if ! is_descendant_of_session \"$pid\"; then\n        emit \"action=skip-kill reason=ancestry-not-confirmed pid=$pid matched_by=name ancestor_ok=no command=$cmd\"\n        continue\n      fi\n      emit \"action=kill signal=TERM pid=$pid matched_by=name ancestor_ok=yes command=$cmd\"\n      if ! kill -15 \"$pid\" 2>/dev/null; then\n        emit \"action=kill-failed signal=TERM pid=$pid\"\n        EXIT_CODE=1\n      fi\n    fi\n  done\nfi\n\nemit \"action=summary session_pid=$SESSION_PID exit_code=$EXIT_CODE\"\nexit \"$EXIT_CODE\"","lineStart":1,"lineEnd":152,"totalLines":152,"truncated":false}},"title":".opencode/scripts/session-cleanup.sh","time":{"start":1780906553182,"end":1780906553186}},"metadata":{"openai":{"itemId":"fc_0d776cc5d0694b36016a267a38ee2081918ca8d5b2cba05a7c"}},"id":"prt_ea64d6f57001ExXAunJLdCyUYu","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64d4111001YBFZsI6XxDNsNO"}}
{"type":"tool_use","timestamp":1780906553197,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_4kmBIjUowxHlcN2FAR3QfppZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"\n3: Comment hygiene checker — detects ephemeral-artifact pointers in code comment lines.\n4: \n5: Usage: check-comment-hygiene.sh <file>\n6: \n7: Exit codes:\n8:   0 — file is clean (no violations found)\n9:   1 — violations found (reported to stdout as FILEPATH:LINE: excerpt)\n10:   2 — file skipped (binary, unknown extension, or in excluded dir)\n11: \n12: Escape: add \"hygiene-ok\" anywhere on a comment line to suppress it.\n13: \n14: See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n15: \"\"\"\n16: import sys\n17: import os\n18: import re\n19: \n20: def main():\n21:     if len(sys.argv) < 2:\n22:         print(\"Usage: check-comment-hygiene.sh <file>\", file=sys.stderr)\n23:         sys.exit(2)\n24: \n25:     filepath = sys.argv[1]\n26: \n27:     # --- Excluded directories and file patterns ---\n28:     abs_path = os.path.abspath(filepath)\n29:     excluded_dirs = [\"/dist/\", \"/node_modules/\", \"/.git/\"]\n30:     for excl in excluded_dirs:\n31:         if excl in abs_path:\n32:             sys.exit(2)\n33: \n34:     basename = os.path.basename(filepath)\n35:     if basename.endswith(\".vitest.js\"):\n36:         sys.exit(2)\n37: \n38:     # --- Language detection from extension ---\n39:     _, ext = os.path.splitext(basename)\n40:     ext = ext.lower()\n41: \n42:     if ext in (\".ts\", \".tsx\", \".js\", \".mjs\", \".cjs\"):\n43:         lang = \"js\"\n44:     elif ext == \".py\":\n45:         lang = \"py\"\n46:     elif ext in (\".sh\", \".bash\"):\n47:         lang = \"sh\"\n48:     elif ext == \".jsonc\":\n49:         lang = \"jsonc\"\n50:     else:\n51:         # Unknown extension — skip silently\n52:         sys.exit(2)\n53: \n54:     # --- Read file ---\n55:     try:\n56:         with open(filepath, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n57:             lines = f.readlines()\n58:     except (OSError, IOError) as e:\n59:         print(f\"WARNING: cannot read {filepath}: {e}\", file=sys.stderr)\n60:         sys.exit(0)\n61: \n62:     # --- Comment detection ---\n63:     def find_unquoted_js_line_comment(line: str) -> int:\n64:         in_string = False\n65:         quote = \"\"\n66:         escaping = False\n67: \n68:         index = 0\n69:         while index < len(line):\n70:             char = line[index]\n71:             next_char = line[index + 1] if index + 1 < len(line) else \"\"\n72: \n73:             if in_string:\n74:                 if escaping:\n75:                     escaping = False\n76:                 elif char == \"\\\\\":\n77:                     escaping = True\n78:                 elif char == quote:\n79:                     in_string = False\n80:                 index += 1\n81:                 continue\n82: \n83:             if char in (\"'\", '\"', \"`\"):\n84:                 in_string = True\n85:                 quote = char\n86:                 index += 1\n87:                 continue\n88: \n89:             if char == \"/\" and next_char == \"/\":\n90:                 return index\n91: \n92:             index += 1\n93: \n94:         return -1\n95: \n96:     def find_unquoted_hash_comment(line: str) -> int:\n97:         in_string = False\n98:         quote = \"\"\n99:         escaping = False\n100: \n101:         for index, char in enumerate(line):\n102:             if in_string:\n103:                 if escaping:\n104:                     escaping = False\n105:                 elif char == \"\\\\\" and quote != \"'\":\n106:                     escaping = True\n107:                 elif char == quote:\n108:                     in_string = False\n109:                 continue\n110: \n111:             if char in (\"'\", '\"'):\n112:                 in_string = True\n113:                 quote = char\n114:                 continue\n115: \n116:             if char == \"#\" and (index == 0 or line[index - 1].isspace()):\n117:                 return index\n118: \n119:         return -1\n120: \n121:     def is_comment_line(stripped: str, lang: str) -> bool:\n122:         if lang in (\"js\", \"jsonc\"):\n123:             return stripped.startswith(\"//\") or stripped.startswith(\"*\") or stripped.startswith(\"/*\")\n124:         elif lang in (\"py\", \"sh\"):\n125:             return stripped.startswith(\"#\")\n126:         return False\n127: \n128:     def extract_comment_text(raw_line: str, lang: str) -> str:\n129:         stripped = raw_line.strip()\n130:         if is_comment_line(stripped, lang):\n131:             return stripped\n132: \n133:         if lang in (\"js\", \"jsonc\"):\n134:             comment_index = find_unquoted_js_line_comment(raw_line)\n135:             if comment_index >= 0:\n136:                 return raw_line[comment_index:].strip()\n137: \n138:         if lang in (\"py\", \"sh\"):\n139:             comment_index = find_unquoted_hash_comment(raw_line)\n140:             if comment_index >= 0:\n141:                 return raw_line[comment_index:].strip()\n142: \n143:         return \"\"\n144: \n145:     # --- Allowed-class patterns (these suppress violation detection) ---\n146:     # Order: check these BEFORE violation patterns.\n147:     ALLOWED_PATTERNS = [\n148:         re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n149:         re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n150:         re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n151:         re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n152:         re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n153:         re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n154:         re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n155:         re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n156:     ]\n157: \n158:     # --- Violation patterns ---\n159:     # Each is (pattern, description) for clear reporting.\n160:     # F-notation is intentionally excluded: repo comments use it heavily for function keys,\n161:     # figures, and field references, so genuine finding labels stay review-owned.\n162:     VIOLATION_PATTERNS = [\n163:         (re.compile(r'\\b\\d{3}/\\d{3}\\b'),                            \"packet/phase reference\"),\n164:         (re.compile(r'\\bRC-\\d+\\b'),                                  \"RC reference\"),\n165:         (re.compile(r'\\bADR-\\d+\\b'),                                \"ADR reference\"),\n166:         (re.compile(r'\\bREQ-\\d+\\b'),                                \"REQ reference\"),\n167:         (re.compile(r'\\bCHK-\\d+\\b'),                                \"CHK reference\"),\n168:         (re.compile(r'\\bT\\d{3,4}\\b'),                               \"task ID reference\"),\n169:         (re.compile(r'\\bpacket\\s+\\d+\\b', re.IGNORECASE),            \"packet number reference\"),\n170:         (re.compile(r'\\bphase[\\s-]\\d{3}\\b', re.IGNORECASE),          \"3-digit phase reference\"),\n171:         (re.compile(r'specs/[a-z0-9]+-[a-z0-9-]*/'),               \"spec path reference\"),\n172:         (re.compile(r'\\bWS-\\d+-\\d+\\b'),                             \"worktree session reference\"),\n173:         (re.compile(r'\\bDR-\\d+(?:-\\d+)?\\b'),                        \"deep review reference\"),\n174:         (re.compile(r'\\bP\\d+-Seat\\d+\\b'),                           \"council seat reference\"),\n175:         (re.compile(r'\\breview\\s+finding\\b', re.IGNORECASE),        \"review finding reference\"),\n176:         (re.compile(r'\\bchecklist\\s+item\\s+\\d+\\b', re.IGNORECASE), \"checklist item reference\"),\n177:         (re.compile(r'\\b[Pp]\\d-finding[-\\s]\\d+\\b'),                 \"finding id reference\"),\n178:         (re.compile(r'\\bfinding\\s+#\\d+\\b', re.IGNORECASE),         \"finding id reference\"),\n179:     ]\n180: \n181:     violations = []\n182: \n183:     for lineno, raw_line in enumerate(lines, start=1):\n184:         comment_text = extract_comment_text(raw_line, lang)\n185: \n186:         if not comment_text:\n187:             continue\n188: \n189:         # Hygiene-ok escape: skip this line entirely\n190:         if \"hygiene-ok\" in comment_text:\n191:             continue\n192: \n193:         # Check allowed-class patterns first — if any match, skip violation check\n194:         if any(pat.search(comment_text) for pat in ALLOWED_PATTERNS):\n195:             continue\n196: \n197:         # Check violation patterns\n198:         for vpat, _desc in VIOLATION_PATTERNS:\n199:             m = vpat.search(comment_text)\n200:             if m:\n201:                 excerpt = raw_line.rstrip()\n202:                 violations.append(f\"{filepath}:{lineno}: {excerpt}\")\n203:                 break  # One violation per line is enough\n204: \n205:     if violations:\n206:         for v in violations:\n207:             print(v)\n208:         sys.exit(1)\n209: \n210:     sys.exit(0)\n211: \n212: \n213: if __name__ == \"__main__\":\n214:     main()\n\n(End of file - total 214 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"\nComment hygiene checker — detects ephemeral-artifact pointers in code comment lines.\n\nUsage: check-comment-hygiene.sh <file>\n\nExit codes:\n  0 — file is clean (no violations found)\n  1 — violations found (reported to stdout as FILEPATH:LINE: excerpt)\n  2 — file skipped (binary, unknown extension, or in excluded dir)\n\nEscape: add \"hygiene-ok\" anywhere on a comment line to suppress it.\n\nSee: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n\"\"\"\nimport sys\nimport os\nimport re\n\ndef main():","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh","text":"#!/usr/bin/env python3\n\"\"\"\nComment hygiene checker — detects ephemeral-artifact pointers in code comment lines.\n\nUsage: check-comment-hygiene.sh <file>\n\nExit codes:\n  0 — file is clean (no violations found)\n  1 — violations found (reported to stdout as FILEPATH:LINE: excerpt)\n  2 — file skipped (binary, unknown extension, or in excluded dir)\n\nEscape: add \"hygiene-ok\" anywhere on a comment line to suppress it.\n\nSee: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n\"\"\"\nimport sys\nimport os\nimport re\n\ndef main():\n    if len(sys.argv) < 2:\n        print(\"Usage: check-comment-hygiene.sh <file>\", file=sys.stderr)\n        sys.exit(2)\n\n    filepath = sys.argv[1]\n\n    # --- Excluded directories and file patterns ---\n    abs_path = os.path.abspath(filepath)\n    excluded_dirs = [\"/dist/\", \"/node_modules/\", \"/.git/\"]\n    for excl in excluded_dirs:\n        if excl in abs_path:\n            sys.exit(2)\n\n    basename = os.path.basename(filepath)\n    if basename.endswith(\".vitest.js\"):\n        sys.exit(2)\n\n    # --- Language detection from extension ---\n    _, ext = os.path.splitext(basename)\n    ext = ext.lower()\n\n    if ext in (\".ts\", \".tsx\", \".js\", \".mjs\", \".cjs\"):\n        lang = \"js\"\n    elif ext == \".py\":\n        lang = \"py\"\n    elif ext in (\".sh\", \".bash\"):\n        lang = \"sh\"\n    elif ext == \".jsonc\":\n        lang = \"jsonc\"\n    else:\n        # Unknown extension — skip silently\n        sys.exit(2)\n\n    # --- Read file ---\n    try:\n        with open(filepath, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n            lines = f.readlines()\n    except (OSError, IOError) as e:\n        print(f\"WARNING: cannot read {filepath}: {e}\", file=sys.stderr)\n        sys.exit(0)\n\n    # --- Comment detection ---\n    def find_unquoted_js_line_comment(line: str) -> int:\n        in_string = False\n        quote = \"\"\n        escaping = False\n\n        index = 0\n        while index < len(line):\n            char = line[index]\n            next_char = line[index + 1] if index + 1 < len(line) else \"\"\n\n            if in_string:\n                if escaping:\n                    escaping = False\n                elif char == \"\\\\\":\n                    escaping = True\n                elif char == quote:\n                    in_string = False\n                index += 1\n                continue\n\n            if char in (\"'\", '\"', \"`\"):\n                in_string = True\n                quote = char\n                index += 1\n                continue\n\n            if char == \"/\" and next_char == \"/\":\n                return index\n\n            index += 1\n\n        return -1\n\n    def find_unquoted_hash_comment(line: str) -> int:\n        in_string = False\n        quote = \"\"\n        escaping = False\n\n        for index, char in enumerate(line):\n            if in_string:\n                if escaping:\n                    escaping = False\n                elif char == \"\\\\\" and quote != \"'\":\n                    escaping = True\n                elif char == quote:\n                    in_string = False\n                continue\n\n            if char in (\"'\", '\"'):\n                in_string = True\n                quote = char\n                continue\n\n            if char == \"#\" and (index == 0 or line[index - 1].isspace()):\n                return index\n\n        return -1\n\n    def is_comment_line(stripped: str, lang: str) -> bool:\n        if lang in (\"js\", \"jsonc\"):\n            return stripped.startswith(\"//\") or stripped.startswith(\"*\") or stripped.startswith(\"/*\")\n        elif lang in (\"py\", \"sh\"):\n            return stripped.startswith(\"#\")\n        return False\n\n    def extract_comment_text(raw_line: str, lang: str) -> str:\n        stripped = raw_line.strip()\n        if is_comment_line(stripped, lang):\n            return stripped\n\n        if lang in (\"js\", \"jsonc\"):\n            comment_index = find_unquoted_js_line_comment(raw_line)\n            if comment_index >= 0:\n                return raw_line[comment_index:].strip()\n\n        if lang in (\"py\", \"sh\"):\n            comment_index = find_unquoted_hash_comment(raw_line)\n            if comment_index >= 0:\n                return raw_line[comment_index:].strip()\n\n        return \"\"\n\n    # --- Allowed-class patterns (these suppress violation detection) ---\n    # Order: check these BEFORE violation patterns.\n    ALLOWED_PATTERNS = [\n        re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n        re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n        re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n        re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n        re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n        re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n        re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n        re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n    ]\n\n    # --- Violation patterns ---\n    # Each is (pattern, description) for clear reporting.\n    # F-notation is intentionally excluded: repo comments use it heavily for function keys,\n    # figures, and field references, so genuine finding labels stay review-owned.\n    VIOLATION_PATTERNS = [\n        (re.compile(r'\\b\\d{3}/\\d{3}\\b'),                            \"packet/phase reference\"),\n        (re.compile(r'\\bRC-\\d+\\b'),                                  \"RC reference\"),\n        (re.compile(r'\\bADR-\\d+\\b'),                                \"ADR reference\"),\n        (re.compile(r'\\bREQ-\\d+\\b'),                                \"REQ reference\"),\n        (re.compile(r'\\bCHK-\\d+\\b'),                                \"CHK reference\"),\n        (re.compile(r'\\bT\\d{3,4}\\b'),                               \"task ID reference\"),\n        (re.compile(r'\\bpacket\\s+\\d+\\b', re.IGNORECASE),            \"packet number reference\"),\n        (re.compile(r'\\bphase[\\s-]\\d{3}\\b', re.IGNORECASE),          \"3-digit phase reference\"),\n        (re.compile(r'specs/[a-z0-9]+-[a-z0-9-]*/'),               \"spec path reference\"),\n        (re.compile(r'\\bWS-\\d+-\\d+\\b'),                             \"worktree session reference\"),\n        (re.compile(r'\\bDR-\\d+(?:-\\d+)?\\b'),                        \"deep review reference\"),\n        (re.compile(r'\\bP\\d+-Seat\\d+\\b'),                           \"council seat reference\"),\n        (re.compile(r'\\breview\\s+finding\\b', re.IGNORECASE),        \"review finding reference\"),\n        (re.compile(r'\\bchecklist\\s+item\\s+\\d+\\b', re.IGNORECASE), \"checklist item reference\"),\n        (re.compile(r'\\b[Pp]\\d-finding[-\\s]\\d+\\b'),                 \"finding id reference\"),\n        (re.compile(r'\\bfinding\\s+#\\d+\\b', re.IGNORECASE),         \"finding id reference\"),\n    ]\n\n    violations = []\n\n    for lineno, raw_line in enumerate(lines, start=1):\n        comment_text = extract_comment_text(raw_line, lang)\n\n        if not comment_text:\n            continue\n\n        # Hygiene-ok escape: skip this line entirely\n        if \"hygiene-ok\" in comment_text:\n            continue\n\n        # Check allowed-class patterns first — if any match, skip violation check\n        if any(pat.search(comment_text) for pat in ALLOWED_PATTERNS):\n            continue\n\n        # Check violation patterns\n        for vpat, _desc in VIOLATION_PATTERNS:\n            m = vpat.search(comment_text)\n            if m:\n                excerpt = raw_line.rstrip()\n                violations.append(f\"{filepath}:{lineno}: {excerpt}\")\n                break  # One violation per line is enough\n\n    if violations:\n        for v in violations:\n            print(v)\n        sys.exit(1)\n\n    sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()","lineStart":1,"lineEnd":214,"totalLines":214,"truncated":false}},"title":".opencode/skills/sk-code/scripts/check-comment-hygiene.sh","time":{"start":1780906553195,"end":1780906553197}},"metadata":{"openai":{"itemId":"fc_0d776cc5d0694b36016a267a38ee2481918e2efa4a43f17676"}},"id":"prt_ea64d6f5f001qjUHmKxxmC2a09","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64d4111001YBFZsI6XxDNsNO"}}
