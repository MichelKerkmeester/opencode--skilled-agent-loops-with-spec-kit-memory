{"type":"step_start","timestamp":1783437244823,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"id":"prt_f3d24b996001BeBaYWs7X3UHZr","messageID":"msg_f3d24b3a0001g77zq5uk2J434C","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","snapshot":"ba1173841046708b3fd5484fc52175710034c0a3","type":"step-start"}}
{"type":"text","timestamp":1783437254298,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"id":"prt_f3d24bdc9001uTHjaSBjJbQxau","messageID":"msg_f3d24b3a0001g77zq5uk2J434C","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","type":"text","text":"The existing vocab sync guard already reads registry aliases, hub keywords, graph derived trigger phrases, and packet intent signals for one hub. Its current shape does not compare ownership across hubs, which matches the charter’s collision-gap angle.","time":{"start":1783437245897,"end":1783437254297},"metadata":{"openai":{"itemId":"msg_05d3cf1f77bc4662016a4d17bde02c81919964e0a41e344f62","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1783437254354,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_fcrZDrl43tR2y0tVnQDyPDCC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs","offset":321,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs</path>\n<type>file</type>\n<content>\n321:   if (!hub || !registry || !projectionParsed) {\n322:     if (!projectionParsed) {\n323:       findings.push({\n324:         class: 'unparseable-input',\n325:         severity: 'P0',\n326:         locus: 'hub-router.json',\n327:         detail: 'vocabularyClasses is missing or not an object',\n328:       });\n329:     }\n330:     return emptyResult({\n331:       familyPresent: true,\n332:       projectionParsed,\n333:       findings,\n334:       score: scoreFromFindings(findings),\n335:     });\n336:   }\n337: \n338:   const skillMdPath = path.join(skillRoot, 'SKILL.md');\n339:   const hubSkillMd = fs.existsSync(skillMdPath) ? fs.readFileSync(skillMdPath, 'utf8') : '';\n340:   const hubKeywords = extractHubKeywords(hubSkillMd);\n341:   const triggerPhrases = graphTriggerPhrases(graph);\n342:   const modePrefixes = buildModePrefixes(registry);\n343:   const { projection, typedKeywordRaw, typedAliasKeys } = buildProjection(hub.vocabularyClasses, modePrefixes);\n344:   const { aliases: registryAliases, ownerMap: registryAliasOwners } = buildRegistryAliases(registry);\n345:   const intentSignalOwners = buildIntentSignalOwners(skillRoot, registry, findings);\n346: \n347:   const orphanAliases = [];\n348:   const ownershipDrift = [];\n349:   for (const alias of registryAliases) {\n350:     const typed = projection.get(alias.normalized);\n351:     const typedModes = typed ? typed.modes : new Set();\n352:     if (!typed || typedModes.size === 0) {\n353:       orphanAliases.push(alias);\n354:     } else if (!typedModes.has(alias.mode)) {\n355:       ownershipDrift.push({\n356:         ...alias,\n357:         typedModes: sortedValues(typedModes),\n358:         classes: sortedValues(typed.classes),\n359:       });\n360:     }\n361:   }\n362: \n363:   const aliasCollisions = [];\n364:   const collisionKeys = new Set([...typedAliasKeys, ...registryAliasOwners.keys()]);\n365: \n366:   for (const key of collisionKeys) {\n367:     const modes = new Set();\n368:     const sources = new Set();\n369:     if (registryAliasOwners.has(key)) {\n370:       for (const mode of registryAliasOwners.get(key)) modes.add(mode);\n371:       sources.add('mode-registry');\n372:     }\n373:     const typed = projection.get(key);\n374:     if (typed) {\n375:       for (const mode of typed.modes) modes.add(mode);\n376:       sources.add('hub-router');\n377:     }\n378:     if (modes.size > 1) aliasCollisions.push(formatCollision(key, modes, sources));\n379:   }\n380: \n381:   const hubKeywordKeys = hubKeywords.map(normalizePhrase).filter(Boolean);\n382:   const untypedKeywords = hubKeywords.filter((keyword) => !projection.has(normalizePhrase(keyword)));\n383:   const untypedKeywordRate = hubKeywordKeys.length\n384:     ? untypedKeywords.length / hubKeywordKeys.length\n385:     : null;\n386: \n387:   const allSourceKeys = sourceKeys({ registryAliases, hubKeywords, triggerPhrases, intentSignalOwners });\n388:   const phantomTypedKeywords = [...typedKeywordRaw.entries()]\n389:     .filter(([key]) => {\n390:       const typed = projection.get(key);\n391:       if (typed && typed.classes.has('hub-identity')) return false;\n392:       return !allSourceKeys.has(key);\n393:     })\n394:     .map(([, raw]) => sortedValues(raw)[0])\n395:     .sort();\n396: \n397:   const coveredTriggerCount = triggerPhrases.filter((phrase) => {\n398:     const normalized = normalizePhrase(phrase);\n399:     return normalized && (projection.has(normalized) || registryAliasOwners.has(normalized));\n400:   }).length;\n401:   const triggerPhraseCoverage = triggerPhrases.length\n402:     ? coveredTriggerCount / triggerPhrases.length\n403:     : null;\n404: \n405:   for (const item of orphanAliases) {\n406:     findings.push(makeFinding(item, 'orphan-alias', `${item.mode} alias is not typed by the hub vocabulary`));\n407:   }\n408:   for (const item of aliasCollisions) {\n409:     findings.push(makeFinding(item, 'alias-collision', `phrase belongs to multiple modes: ${item.modes.join(', ')}`));\n410:   }\n411:   for (const item of ownershipDrift) {\n412:     findings.push(makeFinding(item, 'ownership-drift', `${item.mode} alias is typed as ${item.typedModes.join(', ')}`));\n413:   }\n414: \n415:   const driftDetected = orphanAliases.length > 0 || aliasCollisions.length > 0 || ownershipDrift.length > 0;\n416: \n417:   return {\n418:     familyPresent: true,\n419:     projectionParsed: true,\n420:     typedKeywordCount: projection.size,\n421:     score: scoreFromFindings(findings),\n422:     driftDetected,\n423:     verdict: driftDetected ? HARD_VERDICT : null,\n424:     findings,\n425:     orphanAliases,\n426:     aliasCollisions,\n427:     ownershipDrift,\n428:     untypedKeywords,\n429:     untypedKeywordRate,\n430:     phantomTypedKeywords,\n431:     triggerPhraseCoverage,\n432:   };\n433: }\n434: \n435: // ─────────────────────────────────────────────────────────────────────────────\n436: // 5. EXPORTS\n437: // ─────────────────────────────────────────────────────────────────────────────\n438: \n439: module.exports = {\n440:   checkVocabSync,\n441:   normalizePhrase,\n442:   ownerModeForClass,\n443: };\n444: \n445: if (require.main === module) {\n446:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n447:   if (!args.skill) {\n448:     process.stderr.write('usage: parent-hub-vocab-sync.cjs --skill <skill-root>\\n');\n449:     process.exit(2);\n450:   }\n451: \n452:   try {\n453:     const result = checkVocabSync({ skillRoot: args.skill });\n454:     process.stdout.write(JSON.stringify(result, null, 2) + '\\n');\n455:     const structuralClasses = new Set([\n456:       'unparseable-input',\n457:       'invalid-input',\n458:       'missing-hub-router',\n459:       'missing-mode-registry',\n460:     ]);\n461:     if (result.findings.some((finding) => structuralClasses.has(finding.class))) {\n462:       process.exit(2);\n463:     }\n464:     process.exit(result.driftDetected ? 1 : 0);\n465:   } catch (err) {\n466:     process.stderr.write(`[parent-hub-vocab-sync] ${err.message}\\n`);\n467:     process.exit(2);\n468:   }\n469: }\n\n(End of file - total 469 lines)\n</content>","metadata":{"preview":"  if (!hub || !registry || !projectionParsed) {\n    if (!projectionParsed) {\n      findings.push({\n        class: 'unparseable-input',\n        severity: 'P0',\n        locus: 'hub-router.json',\n        detail: 'vocabularyClasses is missing or not an object',\n      });\n    }\n    return emptyResult({\n      familyPresent: true,\n      projectionParsed,\n      findings,\n      score: scoreFromFindings(findings),\n    });\n  }\n\n  const skillMdPath = path.join(skillRoot, 'SKILL.md');\n  const hubSkillMd = fs.existsSync(skillMdPath) ? fs.readFileSync(skillMdPath, 'utf8') : '';\n  const hubKeywords = extractHubKeywords(hubSkillMd);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs","text":"  if (!hub || !registry || !projectionParsed) {\n    if (!projectionParsed) {\n      findings.push({\n        class: 'unparseable-input',\n        severity: 'P0',\n        locus: 'hub-router.json',\n        detail: 'vocabularyClasses is missing or not an object',\n      });\n    }\n    return emptyResult({\n      familyPresent: true,\n      projectionParsed,\n      findings,\n      score: scoreFromFindings(findings),\n    });\n  }\n\n  const skillMdPath = path.join(skillRoot, 'SKILL.md');\n  const hubSkillMd = fs.existsSync(skillMdPath) ? fs.readFileSync(skillMdPath, 'utf8') : '';\n  const hubKeywords = extractHubKeywords(hubSkillMd);\n  const triggerPhrases = graphTriggerPhrases(graph);\n  const modePrefixes = buildModePrefixes(registry);\n  const { projection, typedKeywordRaw, typedAliasKeys } = buildProjection(hub.vocabularyClasses, modePrefixes);\n  const { aliases: registryAliases, ownerMap: registryAliasOwners } = buildRegistryAliases(registry);\n  const intentSignalOwners = buildIntentSignalOwners(skillRoot, registry, findings);\n\n  const orphanAliases = [];\n  const ownershipDrift = [];\n  for (const alias of registryAliases) {\n    const typed = projection.get(alias.normalized);\n    const typedModes = typed ? typed.modes : new Set();\n    if (!typed || typedModes.size === 0) {\n      orphanAliases.push(alias);\n    } else if (!typedModes.has(alias.mode)) {\n      ownershipDrift.push({\n        ...alias,\n        typedModes: sortedValues(typedModes),\n        classes: sortedValues(typed.classes),\n      });\n    }\n  }\n\n  const aliasCollisions = [];\n  const collisionKeys = new Set([...typedAliasKeys, ...registryAliasOwners.keys()]);\n\n  for (const key of collisionKeys) {\n    const modes = new Set();\n    const sources = new Set();\n    if (registryAliasOwners.has(key)) {\n      for (const mode of registryAliasOwners.get(key)) modes.add(mode);\n      sources.add('mode-registry');\n    }\n    const typed = projection.get(key);\n    if (typed) {\n      for (const mode of typed.modes) modes.add(mode);\n      sources.add('hub-router');\n    }\n    if (modes.size > 1) aliasCollisions.push(formatCollision(key, modes, sources));\n  }\n\n  const hubKeywordKeys = hubKeywords.map(normalizePhrase).filter(Boolean);\n  const untypedKeywords = hubKeywords.filter((keyword) => !projection.has(normalizePhrase(keyword)));\n  const untypedKeywordRate = hubKeywordKeys.length\n    ? untypedKeywords.length / hubKeywordKeys.length\n    : null;\n\n  const allSourceKeys = sourceKeys({ registryAliases, hubKeywords, triggerPhrases, intentSignalOwners });\n  const phantomTypedKeywords = [...typedKeywordRaw.entries()]\n    .filter(([key]) => {\n      const typed = projection.get(key);\n      if (typed && typed.classes.has('hub-identity')) return false;\n      return !allSourceKeys.has(key);\n    })\n    .map(([, raw]) => sortedValues(raw)[0])\n    .sort();\n\n  const coveredTriggerCount = triggerPhrases.filter((phrase) => {\n    const normalized = normalizePhrase(phrase);\n    return normalized && (projection.has(normalized) || registryAliasOwners.has(normalized));\n  }).length;\n  const triggerPhraseCoverage = triggerPhrases.length\n    ? coveredTriggerCount / triggerPhrases.length\n    : null;\n\n  for (const item of orphanAliases) {\n    findings.push(makeFinding(item, 'orphan-alias', `${item.mode} alias is not typed by the hub vocabulary`));\n  }\n  for (const item of aliasCollisions) {\n    findings.push(makeFinding(item, 'alias-collision', `phrase belongs to multiple modes: ${item.modes.join(', ')}`));\n  }\n  for (const item of ownershipDrift) {\n    findings.push(makeFinding(item, 'ownership-drift', `${item.mode} alias is typed as ${item.typedModes.join(', ')}`));\n  }\n\n  const driftDetected = orphanAliases.length > 0 || aliasCollisions.length > 0 || ownershipDrift.length > 0;\n\n  return {\n    familyPresent: true,\n    projectionParsed: true,\n    typedKeywordCount: projection.size,\n    score: scoreFromFindings(findings),\n    driftDetected,\n    verdict: driftDetected ? HARD_VERDICT : null,\n    findings,\n    orphanAliases,\n    aliasCollisions,\n    ownershipDrift,\n    untypedKeywords,\n    untypedKeywordRate,\n    phantomTypedKeywords,\n    triggerPhraseCoverage,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  checkVocabSync,\n  normalizePhrase,\n  ownerModeForClass,\n};\n\nif (require.main === module) {\n  const args = require('./_args.cjs').parse(process.argv.slice(2));\n  if (!args.skill) {\n    process.stderr.write('usage: parent-hub-vocab-sync.cjs --skill <skill-root>\\n');\n    process.exit(2);\n  }\n\n  try {\n    const result = checkVocabSync({ skillRoot: args.skill });\n    process.stdout.write(JSON.stringify(result, null, 2) + '\\n');\n    const structuralClasses = new Set([\n      'unparseable-input',\n      'invalid-input',\n      'missing-hub-router',\n      'missing-mode-registry',\n    ]);\n    if (result.findings.some((finding) => structuralClasses.has(finding.class))) {\n      process.exit(2);\n    }\n    process.exit(result.driftDetected ? 1 : 0);\n  } catch (err) {\n    process.stderr.write(`[parent-hub-vocab-sync] ${err.message}\\n`);\n    process.exit(2);\n  }\n}","lineStart":321,"lineEnd":469,"totalLines":469,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs","time":{"start":1783437254344,"end":1783437254353}},"metadata":{"openai":{"itemId":"fc_05d3cf1f77bc4662016a4d17c63eac8191b53418bbaaff2f44"}},"id":"prt_f3d24de9a001TL99Dc3dw5Kc2b","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24b3a0001g77zq5uk2J434C"}}
{"type":"tool_use","timestamp":1783437254407,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_psrUpjseBGjHEHPjot5D7AJG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/executor-delegation.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/executor-delegation.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Executor Delegation Resolver\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: // Resolves prompts that explicitly delegate to a CLI executor (an OpenCode /\n6: // Claude Code orchestrator, or one of the small-model executors that dispatch\n7: // through one) and forces that executor to the top of the ranking.\n8: //\n9: // Two durable design choices:\n10: //   1. The override is applied POST-FUSION. A pre-clamp explicit-lane penalty\n11: //      cannot carry the negative evidence this needs: the explicit lane clamps\n12: //      each skill at 1, so a delegation framing that saturates the code hub\n13: //      (repeated \"opencode\" tokens + author matches) hides any small penalty\n14: //      under the clamp. Re-lifting the executor and capping the code hub AFTER\n15: //      confidence/uncertainty are settled is the only place the decision can be\n16: //      expressed cleanly and reversibly.\n17: //   2. The alias table is derived from METADATA, not hardcoded. Active executor\n18: //      aliases come from the cli-family projection (each executor's intent\n19: //      signals + derived trigger phrases + name variants); model aliases come\n20: //      from the shared model-profile registry; a retired executor's aliases\n21: //      come from its archived graph metadata. Adding a new executor, a new\n22: //      small model, or retiring one needs no change here.\n23: \n24: import { existsSync, readFileSync, readdirSync } from 'node:fs';\n25: import { join } from 'node:path';\n26: \n27: import { matchesPhraseBoundary, phraseVariants, skillNameVariants } from './text.js';\n28: import type {\n29:   AdvisorProjection,\n30:   AdvisorScoredRecommendation,\n31:   SkillLifecycleStatus,\n32: } from './types.js';\n33: \n34: // The code hub is the fallback a bare executor framing otherwise saturates; it\n35: // is the one skill this resolver deliberately demotes so the executor wins.\n36: const CODE_HUB_SKILL_ID = 'sk-code';\n37: \n38: // A route lift must clear the strict dual threshold and sit clearly above the\n39: // capped code hub so the executor is the unambiguous top.\n40: const ROUTE_CONFIDENCE = 0.95;\n41: const ROUTE_UNCERTAINTY = 0.2;\n42: const CODE_HUB_CONFIDENCE_CAP = 0.88;\n43: \n44: // Generic single tokens that appear in executor metadata as domain/topic labels\n45: // rather than delegation cues. They would over-match general prompts, so they\n46: // are never treated as executor aliases.\n47: const ALIAS_STOPLIST: ReadonlySet<string> = new Set([\n48:   'cli',\n49:   'delegation',\n50:   'cross-ai',\n51:   'cross ai',\n52:   'reasoning',\n53:   'code-editing',\n54:   'code editing',\n55:   'code-generation',\n56:   'code generation',\n57:   'web-research',\n58:   'web research',\n59:   'parallel-sessions',\n60:   'parallel sessions',\n61: ]);\n62: \n63: // Delegation cues pair with an orchestrator noun to catch non-literal framings\n64: // (\"ask OpenCode …\", \"an OpenCode second opinion\", \"a small-model executor\").\n65: const DELEGATION_CUES = /\\b(use|delegate to|ask|run|invoke|dispatch|hand off to|second opinion|small[- ]model)\\b/;\n66: \n67: // The negative guard forces NON-delegation. \"opencode {standards|route|…}\" and a\n68: // bare \".opencode/\" path are the code hub's own opencode surface, not an\n69: // executor handoff, so they must never lift an executor.\n70: const NEGATIVE_GUARD = /\\bopencode[-\\s]?(standards|route|skill|agent|plugin|command|convention)\\b|\\.opencode\\//;\n71: \n72: /** One resolved delegation decision. */\n73: export interface ExecutorDelegation {\n74:   /** The executor skill id, e.g. 'cli-opencode' | 'cli-claude-code'. Null when suppressed-only. */\n75:   readonly executorSkillId: string | null;\n76:   /** 'route'   -> lift executorSkillId to the top and suppress code-hub re-saturation.\n77:    *  'abstain' -> archived/retired executor named: suppress the code-hub fallback, lift nothing. */\n78:   readonly action: 'route' | 'abstain';\n79:   /** The matched alias + the delegation cue, for evidence/reason strings. */\n80:   readonly evidence: string;\n81: }\n82: \n83: /** Alias tables built once from metadata. */\n84: export interface ExecutorAliasTable {\n85:   /** alias phrase -> active executor skill id. */\n86:   readonly activeAliases: ReadonlyMap<string, string>;\n87:   /** alias phrases of retired/archived executors (suppress, never route). */\n88:   readonly suppressedAliases: ReadonlySet<string>;\n89:   /** orchestrator noun -> active executor skill id (used only with a delegation cue). */\n90:   readonly orchestratorNouns: ReadonlyMap<string, string>;\n91:   readonly delegationCues: RegExp;\n92:   readonly negativeGuard: RegExp;\n93: }\n94: \n95: /** Context for the fusion-tail override helper. */\n96: export interface ExecutorDelegationContext {\n97:   readonly promptLower: string;\n98:   readonly projection: AdvisorProjection;\n99:   readonly workspaceRoot: string | undefined;\n100:   readonly confidenceThreshold: number;\n101:   readonly uncertaintyThreshold: number;\n102: }\n103: \n104: interface ModelExecutorEntry {\n105:   readonly executor?: unknown;\n106:   readonly status?: unknown;\n107: }\n108: \n109: interface ModelProfileEntry {\n110:   readonly id?: unknown;\n111:   readonly executors?: unknown;\n112:   readonly capability?: { readonly model_slug?: unknown } | unknown;\n113: }\n114: \n115: interface ArchivedGraphMetadata {\n116:   readonly family?: unknown;\n117:   readonly intent_signals?: unknown;\n118:   readonly derived?: { readonly trigger_phrases?: unknown } | unknown;\n119: }\n120: \n121: /** Filesystem-derived alias data (model registry + archived executors). */\n122: interface FilesystemAliasData {\n123:   readonly modelAliases: ReadonlyMap<string, string>;\n124:   readonly suppressedAliases: ReadonlySet<string>;\n125: }\n126: \n127: // The filesystem read (model registry + archived metadata) is workspace-derived\n128: // and projection-independent, so it is memoized by workspace root. The\n129: // projection-derived active aliases are cheap (a handful of cli-family skills)\n130: // and are recomputed per call so a fixture projection never contaminates the\n131: // real one under a shared workspace root.\n132: const filesystemAliasCache = new Map<string, FilesystemAliasData>();\n133: \n134: function isAliasShaped(alias: string): boolean {\n135:   if (!alias) return false;\n136:   if (ALIAS_STOPLIST.has(alias)) return false;\n137:   // Drop file-path-shaped and doc-name entities that leak in as metadata.\n138:   if (alias.includes('/') && alias.includes('.')) return false;\n139:   return true;\n140: }\n141: \n142: function aliasVariantsOf(phrase: string): string[] {\n143:   return phraseVariants(phrase).filter((variant) => isAliasShaped(variant));\n144: }\n145: \n146: function stringArray(value: unknown): string[] {\n147:   return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n148: }\n149: \n150: function loadFilesystemAliasData(workspaceRoot: string | undefined): FilesystemAliasData {\n151:   const cacheKey = workspaceRoot ?? '';\n152:   const cached = filesystemAliasCache.get(cacheKey);\n153:   if (cached) return cached;\n154: \n155:   const skillsRoot = join(workspaceRoot ?? process.cwd(), '.opencode', 'skills');\n156:   const modelAliases = new Map<string, string>();\n157:   const suppressedAliases = new Set<string>();\n158: \n159:   // Model -> executor aliases from the shared small-model profile registry.\n160:   // Only active executor paths lift; an optional/unverified path is recorded\n161:   // nowhere so a bare model mention never auto-routes to it.\n162:   const modelProfilesPath = join(skillsRoot, 'sk-prompt-models', 'assets', 'model_profiles.json');\n163:   try {\n164:     if (existsSync(modelProfilesPath)) {\n165:       const parsed = JSON.parse(readFileSync(modelProfilesPath, 'utf8')) as { models?: unknown };\n166:       const models = Array.isArray(parsed.models) ? (parsed.models as ModelProfileEntry[]) : [];\n167:       for (const model of models) {\n168:         const executors = Array.isArray(model.executors) ? (model.executors as ModelExecutorEntry[]) : [];\n169:         const activeExecutor = executors.find((entry) => entry.status === 'active');\n170:         if (!activeExecutor || typeof activeExecutor.executor !== 'string') continue;\n171:         const executorId = activeExecutor.executor;\n172:         const modelPhrases: string[] = [];\n173:         if (typeof model.id === 'string') modelPhrases.push(model.id);\n174:         const capability = model.capability;\n175:         if (capability && typeof capability === 'object' && 'model_slug' in capability) {\n176:           const slug = (capability as { model_slug?: unknown }).model_slug;\n177:           if (typeof slug === 'string') modelPhrases.push(slug);\n178:         }\n179:         for (const phrase of modelPhrases) {\n180:           for (const variant of aliasVariantsOf(phrase)) {\n181:             if (!modelAliases.has(variant)) modelAliases.set(variant, executorId);\n182:           }\n183:         }\n184:       }\n185:     }\n186:   } catch {\n187:     // A malformed registry degrades to no model aliases, never a hard failure.\n188:   }\n189: \n190:   // Retired/archived executor aliases. Any archived cli-family skill's declared\n191:   // triggers become a suppressed set so \"use codex …\" abstains instead of\n192:   // falling back to the code hub.\n193:   const archiveRoot = join(skillsRoot, 'z_archive');\n194:   try {\n195:     if (existsSync(archiveRoot)) {\n196:       for (const entry of readdirSync(archiveRoot, { withFileTypes: true })) {\n197:         if (!entry.isDirectory()) continue;\n198:         const metadataPath = join(archiveRoot, entry.name, 'graph-metadata.json');\n199:         if (!existsSync(metadataPath)) continue;\n200:         let metadata: ArchivedGraphMetadata;\n201:         try {\n202:           metadata = JSON.parse(readFileSync(metadataPath, 'utf8')) as ArchivedGraphMetadata;\n203:         } catch {\n204:           continue;\n205:         }\n206:         if (metadata.family !== 'cli') continue;\n207:         const derived = metadata.derived && typeof metadata.derived === 'object'\n208:           ? (metadata.derived as { trigger_phrases?: unknown })\n209:           : {};\n210:         const phrases = [\n211:           ...stringArray(metadata.intent_signals),\n212:           ...stringArray(derived.trigger_phrases),\n213:         ];\n214:         for (const phrase of phrases) {\n215:           for (const variant of aliasVariantsOf(phrase)) {\n216:             suppressedAliases.add(variant);\n217:           }\n218:         }\n219:       }\n220:     }\n221:   } catch {\n222:     // No archive (or unreadable) simply means an empty suppressed set.\n223:   }\n224: \n225:   const data: FilesystemAliasData = { modelAliases, suppressedAliases };\n226:   filesystemAliasCache.set(cacheKey, data);\n227:   return data;\n228: }\n229: \n230: /** Build (memoized filesystem part) the alias tables from metadata. */\n231: export function buildExecutorAliasTable(\n232:   projection: AdvisorProjection,\n233:   workspaceRoot: string | undefined,\n234: ): ExecutorAliasTable {\n235:   const filesystem = loadFilesystemAliasData(workspaceRoot);\n236:   const activeAliases = new Map<string, string>();\n237:   const orchestratorNouns = new Map<string, string>();\n238: \n239:   const activeCliSkills = projection.skills.filter(\n240:     (skill) => skill.family === 'cli' && skill.lifecycleStatus === 'active',\n241:   );\n242:   const activeExecutorIds = new Set(activeCliSkills.map((skill) => skill.id));\n243: \n244:   for (const skill of activeCliSkills) {\n245:     // Author-declared delegation vocabulary only: name variants + intent\n246:     // signals + derived trigger phrases. Derived KEYWORDS (key_topics/entities/\n247:     // key_files/source_docs) carry file paths and doc names that would\n248:     // over-match general prompts, so they are intentionally excluded.\n249:     const phrases = [\n250:       ...skillNameVariants(skill.id),\n251:       ...skill.intentSignals,\n252:       ...skill.derivedTriggers,\n253:     ];\n254:     for (const phrase of phrases) {\n255:       for (const variant of aliasVariantsOf(phrase)) {\n256:         if (!activeAliases.has(variant)) activeAliases.set(variant, skill.id);\n257:       }\n258:     }\n259:     // Orchestrator noun derived from the executor id (\"cli-opencode\" ->\n260:     // \"opencode\", \"cli-claude-code\" -> \"claude-code\"/\"claude code\").\n261:     const noun = skill.id.replace(/^cli-/, '');\n262:     if (noun && noun !== skill.id) {\n263:       orchestratorNouns.set(noun, skill.id);\n264:       const spaced = noun.replace(/-/g, ' ');\n265:       if (spaced !== noun) orchestratorNouns.set(spaced, skill.id);\n266:     }\n267:   }\n268: \n269:   // Model aliases back-stop the projection: any active model whose executor is\n270:   // a routable cli skill contributes its aliases even if the executor's derived\n271:   // block has not yet been re-synced with that model.\n272:   for (const [alias, executorId] of filesystem.modelAliases) {\n273:     if (!activeExecutorIds.has(executorId)) continue;\n274:     if (!activeAliases.has(alias)) activeAliases.set(alias, executorId);\n275:   }\n276: \n277:   return {\n278:     activeAliases,\n279:     suppressedAliases: filesystem.suppressedAliases,\n280:     orchestratorNouns,\n281:     delegationCues: DELEGATION_CUES,\n282:     negativeGuard: NEGATIVE_GUARD,\n283:   };\n284: }\n285: \n286: function longestPhraseMatch(promptLower: string, phrases: Iterable<[string, string]>): { phrase: string; value: string } | null {\n287:   let best: { phrase: string; value: string } | null = null;\n288:   for (const [phrase, value] of phrases) {\n289:     if (!matchesPhraseBoundary(promptLower, phrase)) continue;\n290:     if (!best || phrase.length > best.phrase.length) best = { phrase, value };\n291:   }\n292:   return best;\n293: }\n294: \n295: /** Pure detector: returns a delegation decision or null (no delegation present). */\n296: export function resolveExecutorDelegation(\n297:   promptLower: string,\n298:   table: ExecutorAliasTable,\n299: ): ExecutorDelegation | null {\n300:   // Highest precedence: the code hub's opencode surface is not a handoff.\n301:   if (table.negativeGuard.test(promptLower)) return null;\n302: \n303:   // A retired executor named explicitly must abstain, never fall back.\n304:   for (const alias of table.suppressedAliases) {\n305:     if (matchesPhraseBoundary(promptLower, alias)) {\n306:       return { executorSkillId: null, action: 'abstain', evidence: `suppressed-executor:${alias}` };\n307:     }\n308:   }\n309: \n310:   // A direct, unambiguous alias routes without needing a separate cue.\n311:   const directMatch = longestPhraseMatch(promptLower, table.activeAliases.entries());\n312:   if (directMatch) {\n313:     return { executorSkillId: directMatch.value, action: 'route', evidence: `executor-alias:${directMatch.phrase}` };\n314:   }\n315: \n316:   // Otherwise an orchestrator noun co-occurring with a delegation cue routes.\n317:   if (table.delegationCues.test(promptLower)) {\n318:     const orchestratorMatch = longestPhraseMatch(promptLower, table.orchestratorNouns.entries());\n319:     if (orchestratorMatch) {\n320:       return {\n321:         executorSkillId: orchestratorMatch.value,\n322:         action: 'route',\n323:         evidence: `executor-orchestrator:${orchestratorMatch.phrase}`,\n324:       };\n325:     }\n326:   }\n327: \n328:   return null;\n329: }\n330: \n331: function appendEvidence(reason: string, evidence: string): string {\n332:   const note = `[delegation: ${evidence}]`;\n333:   return reason.includes(note) ? reason : `${reason} ${note}`.trim();\n334: }\n335: \n336: function synthesizeExecutorRecommendation(\n337:   executorId: string,\n338:   projection: AdvisorProjection,\n339:   ranked: readonly AdvisorScoredRecommendation[],\n340:   evidence: string,\n341: ): AdvisorScoredRecommendation {\n342:   const projectionSkill = projection.skills.find((skill) => skill.id === executorId);\n343:   const kind: AdvisorScoredRecommendation['kind'] = projectionSkill?.kind ?? 'skill';\n344:   const lifecycleStatus: SkillLifecycleStatus = projectionSkill?.lifecycleStatus ?? 'active';\n345:   const topScore = ranked.reduce((max, rec) => Math.max(max, rec.score), 0);\n346:   return {\n347:     skill: executorId,\n348:     kind,\n349:     confidence: ROUTE_CONFIDENCE,\n350:     uncertainty: ROUTE_UNCERTAINTY,\n351:     passes_threshold: true,\n352:     reason: appendEvidence('Executor delegation resolved', evidence),\n353:     score: topScore,\n354:     laneContributions: [],\n355:     dominantLane: null,\n356:     lifecycleStatus,\n357:   };\n358: }\n359: \n360: /**\n\n(Showing lines 1-360 of 423. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Executor Delegation Resolver\n// ───────────────────────────────────────────────────────────────\n\n// Resolves prompts that explicitly delegate to a CLI executor (an OpenCode /\n// Claude Code orchestrator, or one of the small-model executors that dispatch\n// through one) and forces that executor to the top of the ranking.\n//\n// Two durable design choices:\n//   1. The override is applied POST-FUSION. A pre-clamp explicit-lane penalty\n//      cannot carry the negative evidence this needs: the explicit lane clamps\n//      each skill at 1, so a delegation framing that saturates the code hub\n//      (repeated \"opencode\" tokens + author matches) hides any small penalty\n//      under the clamp. Re-lifting the executor and capping the code hub AFTER\n//      confidence/uncertainty are settled is the only place the decision can be\n//      expressed cleanly and reversibly.\n//   2. The alias table is derived from METADATA, not hardcoded. Active executor\n//      aliases come from the cli-family projection (each executor's intent\n//      signals + derived trigger phrases + name variants); model aliases come\n//      from the shared model-profile registry; a retired executor's aliases","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/executor-delegation.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Executor Delegation Resolver\n// ───────────────────────────────────────────────────────────────\n\n// Resolves prompts that explicitly delegate to a CLI executor (an OpenCode /\n// Claude Code orchestrator, or one of the small-model executors that dispatch\n// through one) and forces that executor to the top of the ranking.\n//\n// Two durable design choices:\n//   1. The override is applied POST-FUSION. A pre-clamp explicit-lane penalty\n//      cannot carry the negative evidence this needs: the explicit lane clamps\n//      each skill at 1, so a delegation framing that saturates the code hub\n//      (repeated \"opencode\" tokens + author matches) hides any small penalty\n//      under the clamp. Re-lifting the executor and capping the code hub AFTER\n//      confidence/uncertainty are settled is the only place the decision can be\n//      expressed cleanly and reversibly.\n//   2. The alias table is derived from METADATA, not hardcoded. Active executor\n//      aliases come from the cli-family projection (each executor's intent\n//      signals + derived trigger phrases + name variants); model aliases come\n//      from the shared model-profile registry; a retired executor's aliases\n//      come from its archived graph metadata. Adding a new executor, a new\n//      small model, or retiring one needs no change here.\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { join } from 'node:path';\n\nimport { matchesPhraseBoundary, phraseVariants, skillNameVariants } from './text.js';\nimport type {\n  AdvisorProjection,\n  AdvisorScoredRecommendation,\n  SkillLifecycleStatus,\n} from './types.js';\n\n// The code hub is the fallback a bare executor framing otherwise saturates; it\n// is the one skill this resolver deliberately demotes so the executor wins.\nconst CODE_HUB_SKILL_ID = 'sk-code';\n\n// A route lift must clear the strict dual threshold and sit clearly above the\n// capped code hub so the executor is the unambiguous top.\nconst ROUTE_CONFIDENCE = 0.95;\nconst ROUTE_UNCERTAINTY = 0.2;\nconst CODE_HUB_CONFIDENCE_CAP = 0.88;\n\n// Generic single tokens that appear in executor metadata as domain/topic labels\n// rather than delegation cues. They would over-match general prompts, so they\n// are never treated as executor aliases.\nconst ALIAS_STOPLIST: ReadonlySet<string> = new Set([\n  'cli',\n  'delegation',\n  'cross-ai',\n  'cross ai',\n  'reasoning',\n  'code-editing',\n  'code editing',\n  'code-generation',\n  'code generation',\n  'web-research',\n  'web research',\n  'parallel-sessions',\n  'parallel sessions',\n]);\n\n// Delegation cues pair with an orchestrator noun to catch non-literal framings\n// (\"ask OpenCode …\", \"an OpenCode second opinion\", \"a small-model executor\").\nconst DELEGATION_CUES = /\\b(use|delegate to|ask|run|invoke|dispatch|hand off to|second opinion|small[- ]model)\\b/;\n\n// The negative guard forces NON-delegation. \"opencode {standards|route|…}\" and a\n// bare \".opencode/\" path are the code hub's own opencode surface, not an\n// executor handoff, so they must never lift an executor.\nconst NEGATIVE_GUARD = /\\bopencode[-\\s]?(standards|route|skill|agent|plugin|command|convention)\\b|\\.opencode\\//;\n\n/** One resolved delegation decision. */\nexport interface ExecutorDelegation {\n  /** The executor skill id, e.g. 'cli-opencode' | 'cli-claude-code'. Null when suppressed-only. */\n  readonly executorSkillId: string | null;\n  /** 'route'   -> lift executorSkillId to the top and suppress code-hub re-saturation.\n   *  'abstain' -> archived/retired executor named: suppress the code-hub fallback, lift nothing. */\n  readonly action: 'route' | 'abstain';\n  /** The matched alias + the delegation cue, for evidence/reason strings. */\n  readonly evidence: string;\n}\n\n/** Alias tables built once from metadata. */\nexport interface ExecutorAliasTable {\n  /** alias phrase -> active executor skill id. */\n  readonly activeAliases: ReadonlyMap<string, string>;\n  /** alias phrases of retired/archived executors (suppress, never route). */\n  readonly suppressedAliases: ReadonlySet<string>;\n  /** orchestrator noun -> active executor skill id (used only with a delegation cue). */\n  readonly orchestratorNouns: ReadonlyMap<string, string>;\n  readonly delegationCues: RegExp;\n  readonly negativeGuard: RegExp;\n}\n\n/** Context for the fusion-tail override helper. */\nexport interface ExecutorDelegationContext {\n  readonly promptLower: string;\n  readonly projection: AdvisorProjection;\n  readonly workspaceRoot: string | undefined;\n  readonly confidenceThreshold: number;\n  readonly uncertaintyThreshold: number;\n}\n\ninterface ModelExecutorEntry {\n  readonly executor?: unknown;\n  readonly status?: unknown;\n}\n\ninterface ModelProfileEntry {\n  readonly id?: unknown;\n  readonly executors?: unknown;\n  readonly capability?: { readonly model_slug?: unknown } | unknown;\n}\n\ninterface ArchivedGraphMetadata {\n  readonly family?: unknown;\n  readonly intent_signals?: unknown;\n  readonly derived?: { readonly trigger_phrases?: unknown } | unknown;\n}\n\n/** Filesystem-derived alias data (model registry + archived executors). */\ninterface FilesystemAliasData {\n  readonly modelAliases: ReadonlyMap<string, string>;\n  readonly suppressedAliases: ReadonlySet<string>;\n}\n\n// The filesystem read (model registry + archived metadata) is workspace-derived\n// and projection-independent, so it is memoized by workspace root. The\n// projection-derived active aliases are cheap (a handful of cli-family skills)\n// and are recomputed per call so a fixture projection never contaminates the\n// real one under a shared workspace root.\nconst filesystemAliasCache = new Map<string, FilesystemAliasData>();\n\nfunction isAliasShaped(alias: string): boolean {\n  if (!alias) return false;\n  if (ALIAS_STOPLIST.has(alias)) return false;\n  // Drop file-path-shaped and doc-name entities that leak in as metadata.\n  if (alias.includes('/') && alias.includes('.')) return false;\n  return true;\n}\n\nfunction aliasVariantsOf(phrase: string): string[] {\n  return phraseVariants(phrase).filter((variant) => isAliasShaped(variant));\n}\n\nfunction stringArray(value: unknown): string[] {\n  return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n}\n\nfunction loadFilesystemAliasData(workspaceRoot: string | undefined): FilesystemAliasData {\n  const cacheKey = workspaceRoot ?? '';\n  const cached = filesystemAliasCache.get(cacheKey);\n  if (cached) return cached;\n\n  const skillsRoot = join(workspaceRoot ?? process.cwd(), '.opencode', 'skills');\n  const modelAliases = new Map<string, string>();\n  const suppressedAliases = new Set<string>();\n\n  // Model -> executor aliases from the shared small-model profile registry.\n  // Only active executor paths lift; an optional/unverified path is recorded\n  // nowhere so a bare model mention never auto-routes to it.\n  const modelProfilesPath = join(skillsRoot, 'sk-prompt-models', 'assets', 'model_profiles.json');\n  try {\n    if (existsSync(modelProfilesPath)) {\n      const parsed = JSON.parse(readFileSync(modelProfilesPath, 'utf8')) as { models?: unknown };\n      const models = Array.isArray(parsed.models) ? (parsed.models as ModelProfileEntry[]) : [];\n      for (const model of models) {\n        const executors = Array.isArray(model.executors) ? (model.executors as ModelExecutorEntry[]) : [];\n        const activeExecutor = executors.find((entry) => entry.status === 'active');\n        if (!activeExecutor || typeof activeExecutor.executor !== 'string') continue;\n        const executorId = activeExecutor.executor;\n        const modelPhrases: string[] = [];\n        if (typeof model.id === 'string') modelPhrases.push(model.id);\n        const capability = model.capability;\n        if (capability && typeof capability === 'object' && 'model_slug' in capability) {\n          const slug = (capability as { model_slug?: unknown }).model_slug;\n          if (typeof slug === 'string') modelPhrases.push(slug);\n        }\n        for (const phrase of modelPhrases) {\n          for (const variant of aliasVariantsOf(phrase)) {\n            if (!modelAliases.has(variant)) modelAliases.set(variant, executorId);\n          }\n        }\n      }\n    }\n  } catch {\n    // A malformed registry degrades to no model aliases, never a hard failure.\n  }\n\n  // Retired/archived executor aliases. Any archived cli-family skill's declared\n  // triggers become a suppressed set so \"use codex …\" abstains instead of\n  // falling back to the code hub.\n  const archiveRoot = join(skillsRoot, 'z_archive');\n  try {\n    if (existsSync(archiveRoot)) {\n      for (const entry of readdirSync(archiveRoot, { withFileTypes: true })) {\n        if (!entry.isDirectory()) continue;\n        const metadataPath = join(archiveRoot, entry.name, 'graph-metadata.json');\n        if (!existsSync(metadataPath)) continue;\n        let metadata: ArchivedGraphMetadata;\n        try {\n          metadata = JSON.parse(readFileSync(metadataPath, 'utf8')) as ArchivedGraphMetadata;\n        } catch {\n          continue;\n        }\n        if (metadata.family !== 'cli') continue;\n        const derived = metadata.derived && typeof metadata.derived === 'object'\n          ? (metadata.derived as { trigger_phrases?: unknown })\n          : {};\n        const phrases = [\n          ...stringArray(metadata.intent_signals),\n          ...stringArray(derived.trigger_phrases),\n        ];\n        for (const phrase of phrases) {\n          for (const variant of aliasVariantsOf(phrase)) {\n            suppressedAliases.add(variant);\n          }\n        }\n      }\n    }\n  } catch {\n    // No archive (or unreadable) simply means an empty suppressed set.\n  }\n\n  const data: FilesystemAliasData = { modelAliases, suppressedAliases };\n  filesystemAliasCache.set(cacheKey, data);\n  return data;\n}\n\n/** Build (memoized filesystem part) the alias tables from metadata. */\nexport function buildExecutorAliasTable(\n  projection: AdvisorProjection,\n  workspaceRoot: string | undefined,\n): ExecutorAliasTable {\n  const filesystem = loadFilesystemAliasData(workspaceRoot);\n  const activeAliases = new Map<string, string>();\n  const orchestratorNouns = new Map<string, string>();\n\n  const activeCliSkills = projection.skills.filter(\n    (skill) => skill.family === 'cli' && skill.lifecycleStatus === 'active',\n  );\n  const activeExecutorIds = new Set(activeCliSkills.map((skill) => skill.id));\n\n  for (const skill of activeCliSkills) {\n    // Author-declared delegation vocabulary only: name variants + intent\n    // signals + derived trigger phrases. Derived KEYWORDS (key_topics/entities/\n    // key_files/source_docs) carry file paths and doc names that would\n    // over-match general prompts, so they are intentionally excluded.\n    const phrases = [\n      ...skillNameVariants(skill.id),\n      ...skill.intentSignals,\n      ...skill.derivedTriggers,\n    ];\n    for (const phrase of phrases) {\n      for (const variant of aliasVariantsOf(phrase)) {\n        if (!activeAliases.has(variant)) activeAliases.set(variant, skill.id);\n      }\n    }\n    // Orchestrator noun derived from the executor id (\"cli-opencode\" ->\n    // \"opencode\", \"cli-claude-code\" -> \"claude-code\"/\"claude code\").\n    const noun = skill.id.replace(/^cli-/, '');\n    if (noun && noun !== skill.id) {\n      orchestratorNouns.set(noun, skill.id);\n      const spaced = noun.replace(/-/g, ' ');\n      if (spaced !== noun) orchestratorNouns.set(spaced, skill.id);\n    }\n  }\n\n  // Model aliases back-stop the projection: any active model whose executor is\n  // a routable cli skill contributes its aliases even if the executor's derived\n  // block has not yet been re-synced with that model.\n  for (const [alias, executorId] of filesystem.modelAliases) {\n    if (!activeExecutorIds.has(executorId)) continue;\n    if (!activeAliases.has(alias)) activeAliases.set(alias, executorId);\n  }\n\n  return {\n    activeAliases,\n    suppressedAliases: filesystem.suppressedAliases,\n    orchestratorNouns,\n    delegationCues: DELEGATION_CUES,\n    negativeGuard: NEGATIVE_GUARD,\n  };\n}\n\nfunction longestPhraseMatch(promptLower: string, phrases: Iterable<[string, string]>): { phrase: string; value: string } | null {\n  let best: { phrase: string; value: string } | null = null;\n  for (const [phrase, value] of phrases) {\n    if (!matchesPhraseBoundary(promptLower, phrase)) continue;\n    if (!best || phrase.length > best.phrase.length) best = { phrase, value };\n  }\n  return best;\n}\n\n/** Pure detector: returns a delegation decision or null (no delegation present). */\nexport function resolveExecutorDelegation(\n  promptLower: string,\n  table: ExecutorAliasTable,\n): ExecutorDelegation | null {\n  // Highest precedence: the code hub's opencode surface is not a handoff.\n  if (table.negativeGuard.test(promptLower)) return null;\n\n  // A retired executor named explicitly must abstain, never fall back.\n  for (const alias of table.suppressedAliases) {\n    if (matchesPhraseBoundary(promptLower, alias)) {\n      return { executorSkillId: null, action: 'abstain', evidence: `suppressed-executor:${alias}` };\n    }\n  }\n\n  // A direct, unambiguous alias routes without needing a separate cue.\n  const directMatch = longestPhraseMatch(promptLower, table.activeAliases.entries());\n  if (directMatch) {\n    return { executorSkillId: directMatch.value, action: 'route', evidence: `executor-alias:${directMatch.phrase}` };\n  }\n\n  // Otherwise an orchestrator noun co-occurring with a delegation cue routes.\n  if (table.delegationCues.test(promptLower)) {\n    const orchestratorMatch = longestPhraseMatch(promptLower, table.orchestratorNouns.entries());\n    if (orchestratorMatch) {\n      return {\n        executorSkillId: orchestratorMatch.value,\n        action: 'route',\n        evidence: `executor-orchestrator:${orchestratorMatch.phrase}`,\n      };\n    }\n  }\n\n  return null;\n}\n\nfunction appendEvidence(reason: string, evidence: string): string {\n  const note = `[delegation: ${evidence}]`;\n  return reason.includes(note) ? reason : `${reason} ${note}`.trim();\n}\n\nfunction synthesizeExecutorRecommendation(\n  executorId: string,\n  projection: AdvisorProjection,\n  ranked: readonly AdvisorScoredRecommendation[],\n  evidence: string,\n): AdvisorScoredRecommendation {\n  const projectionSkill = projection.skills.find((skill) => skill.id === executorId);\n  const kind: AdvisorScoredRecommendation['kind'] = projectionSkill?.kind ?? 'skill';\n  const lifecycleStatus: SkillLifecycleStatus = projectionSkill?.lifecycleStatus ?? 'active';\n  const topScore = ranked.reduce((max, rec) => Math.max(max, rec.score), 0);\n  return {\n    skill: executorId,\n    kind,\n    confidence: ROUTE_CONFIDENCE,\n    uncertainty: ROUTE_UNCERTAINTY,\n    passes_threshold: true,\n    reason: appendEvidence('Executor delegation resolved', evidence),\n    score: topScore,\n    laneContributions: [],\n    dominantLane: null,\n    lifecycleStatus,\n  };\n}\n\n/**","lineStart":1,"lineEnd":360,"totalLines":423,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/executor-delegation.ts","time":{"start":1783437254349,"end":1783437254378}},"metadata":{"openai":{"itemId":"fc_05d3cf1f77bc4662016a4d17c63ec0819180bba740e1d4c94c"}},"id":"prt_f3d24deca001bKyYIgWoxukbeF","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24b3a0001g77zq5uk2J434C"}}
{"type":"tool_use","timestamp":1783437254487,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_iecGfApctf8iueN3YL8P3zKC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/003-advisor-rrf-fusion/benchmark-results.md","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/003-advisor-rrf-fusion/benchmark-results.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Benchmark Results: Advisor RRF Fusion\"\n3: description: \"Benchmarks the advisor RRF-fusion cluster against the weighted-sum baseline on routing top-1 correctness through the production scoreAdvisorPrompt path against a read-only projection copy, on a widened 42-prompt set with two bands that target the guard seams directly. RRF lifts top-1 from 37 of 42 to 38 of 42 with zero regressions and 0.976 agreement. The self-recommendation guard moves zero top-1 even on prompts built to trigger it and is behaviorally redundant with existing logic. The conflict-rerank seam, fed real conflicts_with mass through a benchmark overlay, corrects one top-1 (4 of 5 to 5 of 5) and repairs a regression RRF itself introduces, since plain RRF drops the signed conflict suppression the weighted-sum keeps natively. Default-off byte-identical, deterministic. Verdict GRADUATE for the RRF core paired with the conflict-rerank seam, CUT for the self-recommendation guard.\"\n4: trigger_phrases:\n5:   - \"advisor rrf fusion benchmark\"\n6:   - \"SPECKIT_ADVISOR_RRF_FUSION verdict\"\n7:   - \"advisor routing top-1 correctness\"\n8:   - \"advisor conflict rerank seam signal\"\n9: importance_tier: \"important\"\n10: contextType: \"general\"\n11: ---\n12: # Benchmark Results: Advisor RRF Fusion\n13: \n14: ## Question\n15: The skill advisor ships an RRF-fusion path (`SPECKIT_ADVISOR_RRF_FUSION`, `ADVISOR_RRF_K=8`, RRF rank order as the post-bonus tiebreak), a conflict-rerank seam that preserves graph conflict mass as a deterministic post-fusion demotion, and a self-recommendation guard (`SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD`). All three are default-off and byte-identical when off. Does RRF fusion beat the weighted-sum baseline on routing top-1 correctness, and do the two guard seams show signal on a set built to trigger them?\n16: \n17: ## Method\n18: - **Production path.** The harness imports the compiled production scorer `scoreAdvisorPrompt` and the production projection loader `loadAdvisorProjection`, the exact pair the `advisor_recommend` handler calls, and toggles only the real flag readers through the environment.\n19: - **Read-only corpus.** The live `skill-graph.sqlite` is copied once into `results/skill-graph.backup.sqlite` and the loader opens a read-only scratch copy. The source hash is unchanged after the run. The projection loads from `sqlite` with 27 entries (21 corpus skills plus 6 command bridges).\n20: - **Conflict overlay, not a corpus write.** The live corpus carries zero `conflicts_with` edges, so the conflict seam is dormant against it. Rather than write the live corpus, five `conflicts_with` edges modeling real routing conflicts are merged into the in-memory projection for the conflict band only. The production `scoreGraphCausalLaneSplit` conflict path runs against real mass without mutating production data.\n21: - **Neutral embedder lane.** The semantic_shadow lane is left neutral so both arms share an identical live lane set and the comparison isolates the fusion change.\n22: - **Widened labeled set.** 42 prompts paired with the correct skill, each gold answer grounded in the corpus trigger phrases, across five bands: 15 exact, 12 paraphrase, 6 hard, 4 self_guard (advisor-self-leaning audit prompts where a real task skill is gold), 5 conflict (near-tie prompts whose runner-up is a `conflicts_with` target of the gold skill).\n23: - **Arms.** `baseline` (all flags off, the weighted-sum scorer), `rrf` (`SPECKIT_ADVISOR_RRF_FUSION` on), `rrf_guard` (RRF plus `SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD` on). The conflict band is scored against the overlay for the RRF arms and against the live projection for the baseline, since the conflict comparator demotion is RRF-gated.\n24: - **Two differentials** isolate the seams: the self-guard differential compares RRF guard-off against RRF guard-on over the self_guard band, and the conflict differential compares RRF over the live projection against RRF over the overlay projection over the conflict band.\n25: - **Determinism.** The scorer is deterministic, so run-to-run variance is zero and the graduate margin is exact.\n26: \n27: ## Results: RRF lifts top-1 by one prompt with zero regressions\n28: \n29: | Metric | baseline (weighted-sum) | rrf | rrf_guard |\n30: |--------|--------------------------|-----|-----------|\n31: | top-1 correct | 37 / 42 | **38 / 42** | 38 / 42 |\n32: | top-1 accuracy | 0.8810 | **0.9048** | 0.9048 |\n33: | exact band | 0.8667 | **0.9333** | 0.9333 |\n34: | paraphrase band | 0.75 | 0.75 | 0.75 |\n35: | hard band | 1.00 | 1.00 | 1.00 |\n36: | self_guard band | 1.00 | 1.00 | 1.00 |\n37: | conflict band | 1.00 | 1.00 | 1.00 |\n38: | agreement vs baseline | n/a | **0.9762** | 0.9762 |\n39: | top-1 moved vs baseline | n/a | 1 (`q02`) | 1 (`q02`) |\n40: \n41: RRF corrects one prompt and regresses none. The exact band rises from 0.8667 to 0.9333. The other four bands are unchanged. The RRF-plus-guard arm is identical to the RRF arm.\n42: \n43: ### The moved prompt: rank fusion beats lane magnitude\n44: | id | band | prompt | gold | baseline top-1 | rrf top-1 |\n45: |----|------|--------|------|----------------|-----------|\n46: | q02 | exact | `codex pr review` | cli-codex | sk-code-review | **cli-codex** |\n47: \n48: The weighted-sum baseline picked `sk-code-review` because the lexical tokens `pr` and `review` outweighed the explicit-author `codex` signal. RRF rank fusion put `cli-codex`'s explicit-author rank first and the dominant intent won. Rank fusion resists a single lane's magnitude swamping the correct dominant rank.\n49: \n50: ## The self-recommendation guard shows no signal and is behaviorally redundant\n51: \n52: The self_guard band is four audit-recommendation-quality prompts that make `system-skill-advisor` a strong candidate, where the correct route is `sk-code-review`. If the guard had any distinct effect it would demote the advisor self-recommendation on exactly these prompts.\n53: \n54: | differential | result |\n55: |--------------|--------|\n56: | top-1 moved by the guard | **0 of 4** |\n57: | correct with guard off | 4 of 4 |\n58: | correct with guard on | 4 of 4 |\n59: | shows signal | **false** |\n60: \n61: The guard changes nothing. The root cause is structural, confirmed by reading the production scorer:\n62: - On any read-only-explainer prompt, the generic floor `if (readOnlyExplainer && !readOnlyRouteAllowed) return readOnlyExplainerFloor` pins every skill to the same floor. `system-skill-advisor` is never in the `readOnlyRouteAllowed` allowlist, so it always hits that floor with or without the guard. The guard's confidence-floor branch is unreachable as distinct behavior.\n63: - On audit-recommendation prompts, the `auditRecsAdvisorPenalty` already fires for `system-skill-advisor` in the guard-off path via `if (!selfRecommendationGuardEnabled && recommendation.skill === 'system-skill-advisor')`. The guard only generalizes a penalty that was already applied.\n64: \n65: So the guard is not merely inert on a thin set. It duplicates logic that already runs for the advisor corpus id on every realistic prompt shape, and adds no demotion the scorer was not already making.\n66: \n67: ## The conflict-rerank seam shows signal and repairs an RRF regression\n68: \n69: The conflict band is five near-tie prompts whose runner-up under plain RRF is a `conflicts_with` target of the gold skill. The conflict differential compares RRF against the live projection (no conflict edges) with RRF against the overlay projection (five `conflicts_with` edges).\n70: \n71: | differential | result |\n72: |--------------|--------|\n73: | top-1 moved by conflict mass | **1 of 5** |\n74: | correct without overlay | 4 of 5 |\n75: | correct with overlay | **5 of 5** |\n76: | shows signal | **true** |\n77: \n78: ### The corrected prompt and the regression it repairs\n79: | config | structural-impact prompt top-1 |\n80: |--------|--------------------------------|\n81: | baseline weighted-sum, no overlay | system-code-graph (correct) |\n82: | RRF, no overlay | **sk-code (wrong)** |\n83: | RRF, conflict overlay | system-code-graph (correct) |\n84: \n85: On `find the structural impact of this code change across callers` the weighted-sum baseline already routes correctly to `system-code-graph`, because the graph-causal lane folds the signed conflict mass into the weighted sum natively. Plain RRF regresses it to `sk-code`, because RRF rank fusion discards the signed conflict suppression and `sk-code` wins on raw lexical rank. The conflict-rerank seam re-injects that suppression as a post-fusion comparator demotion and restores `system-code-graph`.\n86: \n87: This is the key finding of the refinement. The conflict-rerank seam is not a luxury. It repairs a regression that RRF itself introduces on conflict-bearing prompts. On the live corpus the point is moot because no conflict edges exist, but on any corpus that carries conflict edges, RRF without the conflict seam is a regression and the seam is required to make RRF safe there. The conflict-band aggregate of 5 of 5 for both arms in the main table reflects the baseline reading conflict mass natively and the RRF arm reading it through the seam, so neither arm is worse, and the differential shows the seam is load-bearing for RRF specifically.\n88: \n89: ## Safety\n90: - **Flag-off byte-identical.** The baseline arm is byte-identical across repeated runs over all 42 prompts. With both flags off the scorer is the unchanged weighted-sum path.\n91: - **The conflict overlay does not change the default-off top-1.** With flags off, the overlay perturbs only lower-rank scores through the native weighted-sum graph-causal handling and changes no routed answer. This is expected native behavior, not a flag leak, since the RRF-specific conflict comparator demotion is flag-gated.\n92: - **Deterministic.** Every arm is run-to-run top-1 stable, so the lifts exceed the zero run-to-run variance.\n93: - **Read-only.** The source `skill-graph.sqlite` hash is unchanged after the run and git shows no change to it. No production code was edited and no flag default was flipped.\n94: \n95: ## Verdicts\n96: \n97: **RRF core plus the conflict-rerank seam: GRADUATE.** RRF lifts top-1 from 0.8810 to 0.9048 with zero regressions on the widened set, and the conflict-rerank seam corrects the one near-tie where plain RRF regresses, taking the conflict band from 4 of 5 to 5 of 5. The two belong together. RRF rank fusion drops the signed conflict suppression that weighted-sum holds natively, and the conflict seam re-injects it, so graduating RRF without the conflict seam would ship a known regression on any corpus that grows conflict edges. Both are deterministic and byte-identical when off. The recommendation is to graduate `SPECKIT_ADVISOR_RRF_FUSION` and the conflict-rerank seam together, with the live-corpus caveat below.\n98: \n99: **Self-recommendation guard: CUT.** The guard moves zero top-1 even on prompts purpose-built to trigger it, and reading the scorer shows why: its confidence-floor branch is unreachable behind the generic explainer floor, and its audit penalty duplicates a demotion the scorer already applies to `system-skill-advisor` without the flag. It is dead weight behind a flag, the same verdict that retired the other cut experiments. The recommendation is to delete `SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD` and the guard code, keeping the existing un-flagged advisor demotion that already does the job.\n100: \n101: ### Live-corpus caveat on the conflict graduation\n102: The conflict-rerank seam was measured against a benchmark overlay because the live corpus carries no `conflicts_with` edges. Graduating the seam is safe and correct as a property of RRF (it prevents an RRF regression), and it is inert on the current corpus exactly because there are no conflict edges to demote. The seam earns its graduation as RRF's safety net, and it begins to add routing value the moment the corpus grows its first `conflicts_with` edge. Seeding those edges into the live corpus is a separate corpus-authoring decision outside this read-only benchmark.\n103: \n104: ## Reproduce\n105: `node scripts/advisor-rrf-benchmark.mjs` rebuilds `results/metrics.json` from the read-only projection copy and the in-memory conflict overlay, exit 0.\n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Benchmark Results: Advisor RRF Fusion\"\ndescription: \"Benchmarks the advisor RRF-fusion cluster against the weighted-sum baseline on routing top-1 correctness through the production scoreAdvisorPrompt path against a read-only projection copy, on a widened 42-prompt set with two bands that target the guard seams directly. RRF lifts top-1 from 37 of 42 to 38 of 42 with zero regressions and 0.976 agreement. The self-recommendation guard moves zero top-1 even on prompts built to trigger it and is behaviorally redundant with existing logic. The conflict-rerank seam, fed real conflicts_with mass through a benchmark overlay, corrects one top-1 (4 of 5 to 5 of 5) and repairs a regression RRF itself introduces, since plain RRF drops the signed conflict suppression the weighted-sum keeps natively. Default-off byte-identical, deterministic. Verdict GRADUATE for the RRF core paired with the conflict-rerank seam, CUT for the self-recommendation guard.\"\ntrigger_phrases:\n  - \"advisor rrf fusion benchmark\"\n  - \"SPECKIT_ADVISOR_RRF_FUSION verdict\"\n  - \"advisor routing top-1 correctness\"\n  - \"advisor conflict rerank seam signal\"\nimportance_tier: \"important\"\ncontextType: \"general\"\n---\n# Benchmark Results: Advisor RRF Fusion\n\n## Question\nThe skill advisor ships an RRF-fusion path (`SPECKIT_ADVISOR_RRF_FUSION`, `ADVISOR_RRF_K=8`, RRF rank order as the post-bonus tiebreak), a conflict-rerank seam that preserves graph conflict mass as a deterministic post-fusion demotion, and a self-recommendation guard (`SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD`). All three are default-off and byte-identical when off. Does RRF fusion beat the weighted-sum baseline on routing top-1 correctness, and do the two guard seams show signal on a set built to trigger them?\n\n## Method\n- **Production path.** The harness imports the compiled production scorer `scoreAdvisorPrompt` and the production projection loader `loadAdvisorProjection`, the exact pair the `advisor_recommend` handler calls, and toggles only the real flag readers through the environment.\n- **Read-only corpus.** The live `skill-graph.sqlite` is copied once into `results/skill-graph.backup.sqlite` and the loader opens a read-only scratch copy. The source hash is unchanged after the run. The projection loads from `sqlite` with 27 entries (21 corpus skills plus 6 command bridges).\n- **Conflict overlay, not a corpus write.** The live corpus carries zero `conflicts_with` edges, so the conflict seam is dormant against it. Rather than write the live corpus, five `conflicts_with` edges modeling real routing conflicts are merged into the in-memory projection for the conflict band only. The production `scoreGraphCausalLaneSplit` conflict path runs against real mass without mutating production data.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/003-advisor-rrf-fusion/benchmark-results.md","text":"---\ntitle: \"Benchmark Results: Advisor RRF Fusion\"\ndescription: \"Benchmarks the advisor RRF-fusion cluster against the weighted-sum baseline on routing top-1 correctness through the production scoreAdvisorPrompt path against a read-only projection copy, on a widened 42-prompt set with two bands that target the guard seams directly. RRF lifts top-1 from 37 of 42 to 38 of 42 with zero regressions and 0.976 agreement. The self-recommendation guard moves zero top-1 even on prompts built to trigger it and is behaviorally redundant with existing logic. The conflict-rerank seam, fed real conflicts_with mass through a benchmark overlay, corrects one top-1 (4 of 5 to 5 of 5) and repairs a regression RRF itself introduces, since plain RRF drops the signed conflict suppression the weighted-sum keeps natively. Default-off byte-identical, deterministic. Verdict GRADUATE for the RRF core paired with the conflict-rerank seam, CUT for the self-recommendation guard.\"\ntrigger_phrases:\n  - \"advisor rrf fusion benchmark\"\n  - \"SPECKIT_ADVISOR_RRF_FUSION verdict\"\n  - \"advisor routing top-1 correctness\"\n  - \"advisor conflict rerank seam signal\"\nimportance_tier: \"important\"\ncontextType: \"general\"\n---\n# Benchmark Results: Advisor RRF Fusion\n\n## Question\nThe skill advisor ships an RRF-fusion path (`SPECKIT_ADVISOR_RRF_FUSION`, `ADVISOR_RRF_K=8`, RRF rank order as the post-bonus tiebreak), a conflict-rerank seam that preserves graph conflict mass as a deterministic post-fusion demotion, and a self-recommendation guard (`SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD`). All three are default-off and byte-identical when off. Does RRF fusion beat the weighted-sum baseline on routing top-1 correctness, and do the two guard seams show signal on a set built to trigger them?\n\n## Method\n- **Production path.** The harness imports the compiled production scorer `scoreAdvisorPrompt` and the production projection loader `loadAdvisorProjection`, the exact pair the `advisor_recommend` handler calls, and toggles only the real flag readers through the environment.\n- **Read-only corpus.** The live `skill-graph.sqlite` is copied once into `results/skill-graph.backup.sqlite` and the loader opens a read-only scratch copy. The source hash is unchanged after the run. The projection loads from `sqlite` with 27 entries (21 corpus skills plus 6 command bridges).\n- **Conflict overlay, not a corpus write.** The live corpus carries zero `conflicts_with` edges, so the conflict seam is dormant against it. Rather than write the live corpus, five `conflicts_with` edges modeling real routing conflicts are merged into the in-memory projection for the conflict band only. The production `scoreGraphCausalLaneSplit` conflict path runs against real mass without mutating production data.\n- **Neutral embedder lane.** The semantic_shadow lane is left neutral so both arms share an identical live lane set and the comparison isolates the fusion change.\n- **Widened labeled set.** 42 prompts paired with the correct skill, each gold answer grounded in the corpus trigger phrases, across five bands: 15 exact, 12 paraphrase, 6 hard, 4 self_guard (advisor-self-leaning audit prompts where a real task skill is gold), 5 conflict (near-tie prompts whose runner-up is a `conflicts_with` target of the gold skill).\n- **Arms.** `baseline` (all flags off, the weighted-sum scorer), `rrf` (`SPECKIT_ADVISOR_RRF_FUSION` on), `rrf_guard` (RRF plus `SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD` on). The conflict band is scored against the overlay for the RRF arms and against the live projection for the baseline, since the conflict comparator demotion is RRF-gated.\n- **Two differentials** isolate the seams: the self-guard differential compares RRF guard-off against RRF guard-on over the self_guard band, and the conflict differential compares RRF over the live projection against RRF over the overlay projection over the conflict band.\n- **Determinism.** The scorer is deterministic, so run-to-run variance is zero and the graduate margin is exact.\n\n## Results: RRF lifts top-1 by one prompt with zero regressions\n\n| Metric | baseline (weighted-sum) | rrf | rrf_guard |\n|--------|--------------------------|-----|-----------|\n| top-1 correct | 37 / 42 | **38 / 42** | 38 / 42 |\n| top-1 accuracy | 0.8810 | **0.9048** | 0.9048 |\n| exact band | 0.8667 | **0.9333** | 0.9333 |\n| paraphrase band | 0.75 | 0.75 | 0.75 |\n| hard band | 1.00 | 1.00 | 1.00 |\n| self_guard band | 1.00 | 1.00 | 1.00 |\n| conflict band | 1.00 | 1.00 | 1.00 |\n| agreement vs baseline | n/a | **0.9762** | 0.9762 |\n| top-1 moved vs baseline | n/a | 1 (`q02`) | 1 (`q02`) |\n\nRRF corrects one prompt and regresses none. The exact band rises from 0.8667 to 0.9333. The other four bands are unchanged. The RRF-plus-guard arm is identical to the RRF arm.\n\n### The moved prompt: rank fusion beats lane magnitude\n| id | band | prompt | gold | baseline top-1 | rrf top-1 |\n|----|------|--------|------|----------------|-----------|\n| q02 | exact | `codex pr review` | cli-codex | sk-code-review | **cli-codex** |\n\nThe weighted-sum baseline picked `sk-code-review` because the lexical tokens `pr` and `review` outweighed the explicit-author `codex` signal. RRF rank fusion put `cli-codex`'s explicit-author rank first and the dominant intent won. Rank fusion resists a single lane's magnitude swamping the correct dominant rank.\n\n## The self-recommendation guard shows no signal and is behaviorally redundant\n\nThe self_guard band is four audit-recommendation-quality prompts that make `system-skill-advisor` a strong candidate, where the correct route is `sk-code-review`. If the guard had any distinct effect it would demote the advisor self-recommendation on exactly these prompts.\n\n| differential | result |\n|--------------|--------|\n| top-1 moved by the guard | **0 of 4** |\n| correct with guard off | 4 of 4 |\n| correct with guard on | 4 of 4 |\n| shows signal | **false** |\n\nThe guard changes nothing. The root cause is structural, confirmed by reading the production scorer:\n- On any read-only-explainer prompt, the generic floor `if (readOnlyExplainer && !readOnlyRouteAllowed) return readOnlyExplainerFloor` pins every skill to the same floor. `system-skill-advisor` is never in the `readOnlyRouteAllowed` allowlist, so it always hits that floor with or without the guard. The guard's confidence-floor branch is unreachable as distinct behavior.\n- On audit-recommendation prompts, the `auditRecsAdvisorPenalty` already fires for `system-skill-advisor` in the guard-off path via `if (!selfRecommendationGuardEnabled && recommendation.skill === 'system-skill-advisor')`. The guard only generalizes a penalty that was already applied.\n\nSo the guard is not merely inert on a thin set. It duplicates logic that already runs for the advisor corpus id on every realistic prompt shape, and adds no demotion the scorer was not already making.\n\n## The conflict-rerank seam shows signal and repairs an RRF regression\n\nThe conflict band is five near-tie prompts whose runner-up under plain RRF is a `conflicts_with` target of the gold skill. The conflict differential compares RRF against the live projection (no conflict edges) with RRF against the overlay projection (five `conflicts_with` edges).\n\n| differential | result |\n|--------------|--------|\n| top-1 moved by conflict mass | **1 of 5** |\n| correct without overlay | 4 of 5 |\n| correct with overlay | **5 of 5** |\n| shows signal | **true** |\n\n### The corrected prompt and the regression it repairs\n| config | structural-impact prompt top-1 |\n|--------|--------------------------------|\n| baseline weighted-sum, no overlay | system-code-graph (correct) |\n| RRF, no overlay | **sk-code (wrong)** |\n| RRF, conflict overlay | system-code-graph (correct) |\n\nOn `find the structural impact of this code change across callers` the weighted-sum baseline already routes correctly to `system-code-graph`, because the graph-causal lane folds the signed conflict mass into the weighted sum natively. Plain RRF regresses it to `sk-code`, because RRF rank fusion discards the signed conflict suppression and `sk-code` wins on raw lexical rank. The conflict-rerank seam re-injects that suppression as a post-fusion comparator demotion and restores `system-code-graph`.\n\nThis is the key finding of the refinement. The conflict-rerank seam is not a luxury. It repairs a regression that RRF itself introduces on conflict-bearing prompts. On the live corpus the point is moot because no conflict edges exist, but on any corpus that carries conflict edges, RRF without the conflict seam is a regression and the seam is required to make RRF safe there. The conflict-band aggregate of 5 of 5 for both arms in the main table reflects the baseline reading conflict mass natively and the RRF arm reading it through the seam, so neither arm is worse, and the differential shows the seam is load-bearing for RRF specifically.\n\n## Safety\n- **Flag-off byte-identical.** The baseline arm is byte-identical across repeated runs over all 42 prompts. With both flags off the scorer is the unchanged weighted-sum path.\n- **The conflict overlay does not change the default-off top-1.** With flags off, the overlay perturbs only lower-rank scores through the native weighted-sum graph-causal handling and changes no routed answer. This is expected native behavior, not a flag leak, since the RRF-specific conflict comparator demotion is flag-gated.\n- **Deterministic.** Every arm is run-to-run top-1 stable, so the lifts exceed the zero run-to-run variance.\n- **Read-only.** The source `skill-graph.sqlite` hash is unchanged after the run and git shows no change to it. No production code was edited and no flag default was flipped.\n\n## Verdicts\n\n**RRF core plus the conflict-rerank seam: GRADUATE.** RRF lifts top-1 from 0.8810 to 0.9048 with zero regressions on the widened set, and the conflict-rerank seam corrects the one near-tie where plain RRF regresses, taking the conflict band from 4 of 5 to 5 of 5. The two belong together. RRF rank fusion drops the signed conflict suppression that weighted-sum holds natively, and the conflict seam re-injects it, so graduating RRF without the conflict seam would ship a known regression on any corpus that grows conflict edges. Both are deterministic and byte-identical when off. The recommendation is to graduate `SPECKIT_ADVISOR_RRF_FUSION` and the conflict-rerank seam together, with the live-corpus caveat below.\n\n**Self-recommendation guard: CUT.** The guard moves zero top-1 even on prompts purpose-built to trigger it, and reading the scorer shows why: its confidence-floor branch is unreachable behind the generic explainer floor, and its audit penalty duplicates a demotion the scorer already applies to `system-skill-advisor` without the flag. It is dead weight behind a flag, the same verdict that retired the other cut experiments. The recommendation is to delete `SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD` and the guard code, keeping the existing un-flagged advisor demotion that already does the job.\n\n### Live-corpus caveat on the conflict graduation\nThe conflict-rerank seam was measured against a benchmark overlay because the live corpus carries no `conflicts_with` edges. Graduating the seam is safe and correct as a property of RRF (it prevents an RRF regression), and it is inert on the current corpus exactly because there are no conflict edges to demote. The seam earns its graduation as RRF's safety net, and it begins to add routing value the moment the corpus grows its first `conflicts_with` edge. Seeding those edges into the live corpus is a separate corpus-authoring decision outside this read-only benchmark.\n\n## Reproduce\n`node scripts/advisor-rrf-benchmark.mjs` rebuilds `results/metrics.json` from the read-only projection copy and the in-memory conflict overlay, exit 0.","lineStart":1,"lineEnd":105,"totalLines":105,"truncated":false}},"title":".opencode/specs/system-skill-advisor/012-skill-advisor-tuning/003-advisor-rrf-fusion/benchmark-results.md","time":{"start":1783437254468,"end":1783437254485}},"metadata":{"openai":{"itemId":"fc_05d3cf1f77bc4662016a4d17c63ed08191bcd8f0a129b34576"}},"id":"prt_f3d24df06001JLeN67f35CNSMH","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24b3a0001g77zq5uk2J434C"}}
{"type":"tool_use","timestamp":1783437254492,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_OhHeDBVYYjTMZ19r5FT70aZg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening/implementation-summary.md","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening/implementation-summary.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Implementation Summary: Advisor Scorer Eval Hardening\"\n3: description: \"Shipped: eval-hardening infrastructure for the advisor scorer. An empirical ambiguity slice, bucket/source_type enum enforcement plus named intent-bucket accuracy slices, a ratcheted accuracy baseline with an exact-match non-regression gate, and an honest independent 78-row holdout from three disjoint labeled fixtures. Corpus-neutral (105/101/4 held byte-identical), additive output plus stricter input validation only, no routing change.\"\n4: trigger_phrases:\n5:   - \"advisor eval hardening summary\"\n6:   - \"ratcheted baseline implementation summary\"\n7:   - \"independent holdout shipped\"\n8: importance_tier: \"high\"\n9: contextType: \"implementation\"\n10: status: \"Complete\"\n11: _memory:\n12:   continuity:\n13:     packet_pointer: \"system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening\"\n14:     last_updated_at: \"2026-07-07T07:15:00.000Z\"\n15:     last_updated_by: \"opus-4.8\"\n16:     recent_action: \"Eval-hardening infrastructure implemented and verified corpus-neutral; all scorer gates green\"\n17:     next_safe_action: \"Orchestrator pushes the working tree to the shared branch (no commit/push done here)\"\n18:     blockers: []\n19:     key_files:\n20:       - \".opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-validate.ts\"\n21:       - \".opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts\"\n22:       - \".opencode/skills/system-skill-advisor/mcp_server/scripts/routing-accuracy/scorer-eval-baseline.json\"\n23:       - \".opencode/skills/system-skill-advisor/mcp_server/tests/parity/scorer-eval-baseline-ratchet.vitest.ts\"\n24:       - \".opencode/skills/system-skill-advisor/mcp_server/tests/parity/holdout-independent.vitest.ts\"\n25:       - \".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/ambiguity-slice.vitest.ts\"\n26:     completion_pct: 100\n27: ---\n28: # Implementation Summary\n29: \n30: <!-- SPECKIT_LEVEL: 3 -->\n31: <!-- SPECKIT_TEMPLATE_SOURCE: impl-summary-core + level3 | v2.2 -->\n32: <!-- HVR_REFERENCE: .opencode/skills/sk-doc/shared/references/global/hvr_rules.md -->\n33: \n34: ---\n35: \n36: <!-- ANCHOR:metadata -->\n37: ## Metadata\n38: \n39: | Field | Value |\n40: |-------|-------|\n41: | **Spec Folder** | 007-eval-hardening |\n42: | **Completed** | 2026-07-07 |\n43: | **Level** | 3 |\n44: <!-- /ANCHOR:metadata -->\n45: \n46: ---\n47: \n48: <!-- ANCHOR:exec-summary -->\n49: ## Executive Summary\n50: \n51: The advisor scorer's evaluation now catches regressions that the aggregate accuracy gate hid. Four measures are frozen from the current scorer state and guarded: an empirical ambiguity slice over the lowest-margin prompts, named intent buckets (review, memory_save, delegation), an independent 78-row holdout disjoint from the training corpus, and a ratcheted baseline whose gate forbids silent drift in either direction. No routing behavior changed — the scorer is read-only in every new path, and the handler edits are additive output plus enum-tightened input validation only.\n52: <!-- /ANCHOR:exec-summary -->\n53: \n54: ---\n55: \n56: <!-- ANCHOR:what-built -->\n57: ## What Was Built\n58: \n59: ### The gap\n60: The release gate measured only aggregate top-1 accuracy plus a synthetic dead-tie check and an every-fifth-row holdout carved from the same 193-row training corpus. Regressions confined to contested prompts, to a single intent class, or masked by memorization were invisible. The corpus already carried `bucket` and `source_type` on every row, but they were unenforced and unused for slicing.\n61: \n62: ### What was added\n63: - **Empirical ambiguity slice**: the top-2 fused-score margin is derived for every corpus row under the reproducible projection; the 25 lowest-margin rows (at a frozen `tau=0.03`) are frozen with their existing gold labels, and a gate holds their top-1 at or above the baseline.\n64: - **Bucket enforcement + slices**: `CorpusRowSchema` now validates `bucket` and `source_type` as enums (passthrough retained); the validate output gains `slices.buckets.{review, memory_save, delegation}`, each with a `minN` floor. review and memory_save slice the corpus by bucket; delegation scores the shared executor-delegation fixture (the training corpus carries no honest executor-delegation signal).\n65: - **Ratcheted baseline + gate**: `scorer-eval-baseline.json` records the top-1 count for every measure with sha256 fixture pins. The gate re-scores live and holds each metric exactly, failing directionally on any drift (regression vs unrecaptured improvement), with the fixed release floors retained as an absolute minimum.\n66: - **Independent holdout**: 78 rows assembled from three disjoint labeled fixtures (harder-intent 22, regression 50, delegation 11 -> dedup -> 78), with a gate that re-proves disjointness from the training corpus and holds top-1 at or above the baseline.\n67: \n68: ### Files Changed\n69: \n70: | File | Action | Purpose |\n71: |------|--------|---------|\n72: | `handlers/advisor-validate.ts` | Modified | Enum-enforce bucket/source_type; delegation loader + `evaluateDelegationCases`; `bucketSlice`; compute + output `slices.buckets` over the full corpus |\n73: | `schemas/advisor-tool-schemas.ts` | Modified | `bucketSliceSchema` (adds `minN` + `top1`); `slices.buckets` block |\n74: | `scripts/routing-accuracy/build-holdout.mjs` | Created | Assemble + dedup the 78-row independent holdout |\n75: | `scripts/routing-accuracy/derive-ambiguity-slice.mjs` | Created | Offline-derive + freeze the ambiguity slice at `tau` |\n76: | `scripts/routing-accuracy/capture-scorer-eval-baseline.mjs` | Created | Capture the baseline with sha256 fixture pins |\n77: | `scripts/routing-accuracy/holdout-prompts.jsonl` | Created | Frozen 78-row independent holdout |\n78: | `scripts/routing-accuracy/ambiguity-prompts.jsonl` | Created | Frozen 25-row ambiguity slice |\n79: | `scripts/routing-accuracy/scorer-eval-baseline.json` | Created | Frozen accuracy baseline |\n80: | `tests/parity/scorer-eval-baseline-ratchet.vitest.ts` | Created | Non-regression + fixture-pin + floor gate |\n81: | `tests/parity/holdout-independent.vitest.ts` | Created | Independent holdout gate |\n82: | `tests/scorer/ambiguity-slice.vitest.ts` | Created | Ambiguity-slice gate |\n83: | `tests/handlers/advisor-validate.vitest.ts` | Modified | Assert the new buckets, minN, full-corpus scope, and enum enforcement |\n84: | `tests/handlers/advisor-validate-shapes.vitest.ts` | Modified | Update the valid-corpus-row fixtures for the now-required enum fields |\n85: <!-- /ANCHOR:what-built -->\n86: \n87: ---\n88: \n89: <!-- ANCHOR:how-delivered -->\n90: ## How It Was Delivered\n91: \n92: Numbers were measured, not assumed. The additive handler and schema edits were made and typechecked (exit 0) before dist was rebuilt. The holdout dedup was verified to reproduce 78 rows exactly (83 raw, 4 intra-pool duplicates, 1 training collision — the CommonJS-helper delegation prompt — removed) with disjointness confirmed. The ambiguity slice was derived from live margins. The baseline was captured under the deterministic filesystem projection.\n93: \n94: A discrepancy surfaced during verification: the node-captured baseline disagreed with the vitest gate on the near-tie rows. Root cause was found empirically — the semantic-shadow lane substitutes deterministic fixture vectors under the test-harness flag, which every existing scorer gate runs with, but a plain node capture does not. The capture scripts were corrected to set the harness flag (recorded as ADR-003), after which the baseline reproduces the gate numbers exactly. No commit or push was performed; the changes are left in the working tree for the orchestrator.\n95: <!-- /ANCHOR:how-delivered -->\n96: \n97: ---\n98: \n99: <!-- ANCHOR:decisions -->\n100: ## Key Decisions\n101: \n102: | Decision | Why |\n103: |----------|-----|\n104: | Fixed floor + exact-match ratchet (ADR-001) | A fixed floor is blind to above-floor drift; the ratchet holds the last-known-good and forces a conscious re-baseline on any legitimate movement, with the floor as a hard backstop |\n105: | Honest holdout from disjoint labeled fixtures (ADR-002) | No never-seen production gold exists in the repo; repurposing three disjoint, separately-authored labeled fixtures measures generalization without fabricating labels |\n106: | Capture under the test-harness regime (ADR-003) | Every scorer gate runs the harness fixture-semantic regime; the baseline must be measured in the same regime that re-scores it, or the ratchet fails against its own baseline |\n107: | Buckets over the full corpus, not the skillSlug scope | The named buckets are a global diagnostic; scoping them would shrink them below `minN` and lose meaning |\n108: | Retain the legacy every-Nth-row holdout | Removing it would churn the live handler and adjacent parity assertions for no measurement gain; it stays as a secondary signal |\n109: <!-- /ANCHOR:decisions -->\n110: \n111: ---\n112: \n113: <!-- ANCHOR:verification -->\n114: ## Verification\n115: \n116: | Check | Result |\n117: |-------|--------|\n118: | `npm run typecheck` | PASS (exit 0) |\n119: | `scorer-eval-baseline-ratchet.vitest.ts` | PASS (6/6) |\n120: | `holdout-independent.vitest.ts` | PASS (3/3) |\n121: | `ambiguity-slice.vitest.ts` | PASS (3/3) |\n122: | `advisor-validate.vitest.ts` (extended) | PASS |\n123: | `advisor-validate-shapes.vitest.ts` (reconciled) | PASS |\n124: | `python-ts-parity.vitest.ts` | PASS (hard-asserts pythonCorrect=105, tsAlsoCorrect=101, regressions=4, ids equal) |\n125: | `local-native-divergence-ratchet.vitest.ts` | PASS (green; no ledger edit) |\n126: | Ratchet mutation proof | PASS (baseline full_corpus 147 -> 148 fails the gate with the exact directional diff; restored) |\n127: | Full advisor vitest suite | 652 passed, 5 skipped, 4 failed (all pre-existing scorer-independent infra flakes) |\n128: \n129: **Baseline (harness regime, filesystem projection)**: full-corpus 147/193 = 0.7617; unknown 10; gold-none-false-fire 8; holdout 60/78 = 0.7692; ambiguity 15/25 = 0.60 (`tau=0.03`); buckets review 22/32 = 0.6875, memory_save 25/32 = 0.7813, delegation 11/11 = 1.0. Floors met: full-corpus >= 0.75, holdout >= 0.725.\n130: <!-- /ANCHOR:verification -->\n131: \n132: ---\n133: \n134: <!-- ANCHOR:deviations -->\n135: ## Deviations From Plan\n136: \n137: 1. **A third generator script was added** (`derive-ambiguity-slice.mjs`) beyond the plan's two. The ambiguity slice needs an offline deriver, mirroring `build-holdout.mjs`; it is a run-once frozen generator, not a CI dependency.\n138: 2. **The baseline is captured under the test-harness regime** (ADR-003). The plan's capture recipe omitted the harness fixture-semantic factor; matching it is required for the baseline and the gate to agree and keeps this gate consistent with every sibling scorer test.\n139: 3. **`advisor-validate-shapes.vitest.ts` was reconciled** (not named in the plan). The enum tightening made its minimal valid-row fixtures invalid; two fixtures gained the now-required `bucket` + `source_type` fields.\n140: <!-- /ANCHOR:deviations -->\n141: \n142: ---\n143: \n144: <!-- ANCHOR:limitations -->\n145: ## Known Limitations\n146: \n147: 1. **The full suite shows 4 failures, all pre-existing and scorer-independent.** `compat/shim` (Python subprocess stdin), `skill-advisor-cli-parity` (Python/native CLI), `advisor-graph-health` (legacy graph health), and `manual-testing-playbook` (doc inventory). None imports the scorer, and the scorer/parity/ratchet gates are all green, so this change introduces no new failures. A fifth infra flake (migration-lineage-identity / launcher-orphan-reaping) is fluid and passed this run.\n148: 2. **The baseline measures the harness regime, not the daemon's real-embedding runtime.** This is the standard reproducible-CI trade-off shared by every scorer gate; the ratchet tracks relative regressions, which is its purpose (ADR-003).\n149: 3. **The holdout rows are repurposed labeled fixtures, not fresh held-out production traffic.** The telemetry-labeled upgrade is deferred, not faked (prompt-safety forbids storing routable prompt content in telemetry) (ADR-002).\n150: 4. **The routing-accuracy `README.md` fixture documentation is deferred.** A concurrent session holds the README dirty; the doc delta is handed off rather than clobbering their edit.\n151: 5. **No commit or push was performed.** The orchestrator owns the push to the shared branch; the changes are in the working tree.\n152: <!-- /ANCHOR:limitations -->\n153: \n154: ---\n155: \n156: <!-- ANCHOR:follow-up -->\n157: ## Follow-Up\n158: \n159: - Document the four routing-accuracy fixtures in the `README.md` once the concurrent session's edit lands.\n160: - When the scorer or skill metadata legitimately changes, re-run `capture-scorer-eval-baseline.mjs --write` to re-baseline (the ratchet's directional message names this step).\n161: <!-- /ANCHOR:follow-up -->\n\n(End of file - total 161 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Implementation Summary: Advisor Scorer Eval Hardening\"\ndescription: \"Shipped: eval-hardening infrastructure for the advisor scorer. An empirical ambiguity slice, bucket/source_type enum enforcement plus named intent-bucket accuracy slices, a ratcheted accuracy baseline with an exact-match non-regression gate, and an honest independent 78-row holdout from three disjoint labeled fixtures. Corpus-neutral (105/101/4 held byte-identical), additive output plus stricter input validation only, no routing change.\"\ntrigger_phrases:\n  - \"advisor eval hardening summary\"\n  - \"ratcheted baseline implementation summary\"\n  - \"independent holdout shipped\"\nimportance_tier: \"high\"\ncontextType: \"implementation\"\nstatus: \"Complete\"\n_memory:\n  continuity:\n    packet_pointer: \"system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening\"\n    last_updated_at: \"2026-07-07T07:15:00.000Z\"\n    last_updated_by: \"opus-4.8\"\n    recent_action: \"Eval-hardening infrastructure implemented and verified corpus-neutral; all scorer gates green\"\n    next_safe_action: \"Orchestrator pushes the working tree to the shared branch (no commit/push done here)\"\n    blockers: []\n    key_files:\n      - \".opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-validate.ts\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening/implementation-summary.md","text":"---\ntitle: \"Implementation Summary: Advisor Scorer Eval Hardening\"\ndescription: \"Shipped: eval-hardening infrastructure for the advisor scorer. An empirical ambiguity slice, bucket/source_type enum enforcement plus named intent-bucket accuracy slices, a ratcheted accuracy baseline with an exact-match non-regression gate, and an honest independent 78-row holdout from three disjoint labeled fixtures. Corpus-neutral (105/101/4 held byte-identical), additive output plus stricter input validation only, no routing change.\"\ntrigger_phrases:\n  - \"advisor eval hardening summary\"\n  - \"ratcheted baseline implementation summary\"\n  - \"independent holdout shipped\"\nimportance_tier: \"high\"\ncontextType: \"implementation\"\nstatus: \"Complete\"\n_memory:\n  continuity:\n    packet_pointer: \"system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening\"\n    last_updated_at: \"2026-07-07T07:15:00.000Z\"\n    last_updated_by: \"opus-4.8\"\n    recent_action: \"Eval-hardening infrastructure implemented and verified corpus-neutral; all scorer gates green\"\n    next_safe_action: \"Orchestrator pushes the working tree to the shared branch (no commit/push done here)\"\n    blockers: []\n    key_files:\n      - \".opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-validate.ts\"\n      - \".opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts\"\n      - \".opencode/skills/system-skill-advisor/mcp_server/scripts/routing-accuracy/scorer-eval-baseline.json\"\n      - \".opencode/skills/system-skill-advisor/mcp_server/tests/parity/scorer-eval-baseline-ratchet.vitest.ts\"\n      - \".opencode/skills/system-skill-advisor/mcp_server/tests/parity/holdout-independent.vitest.ts\"\n      - \".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/ambiguity-slice.vitest.ts\"\n    completion_pct: 100\n---\n# Implementation Summary\n\n<!-- SPECKIT_LEVEL: 3 -->\n<!-- SPECKIT_TEMPLATE_SOURCE: impl-summary-core + level3 | v2.2 -->\n<!-- HVR_REFERENCE: .opencode/skills/sk-doc/shared/references/global/hvr_rules.md -->\n\n---\n\n<!-- ANCHOR:metadata -->\n## Metadata\n\n| Field | Value |\n|-------|-------|\n| **Spec Folder** | 007-eval-hardening |\n| **Completed** | 2026-07-07 |\n| **Level** | 3 |\n<!-- /ANCHOR:metadata -->\n\n---\n\n<!-- ANCHOR:exec-summary -->\n## Executive Summary\n\nThe advisor scorer's evaluation now catches regressions that the aggregate accuracy gate hid. Four measures are frozen from the current scorer state and guarded: an empirical ambiguity slice over the lowest-margin prompts, named intent buckets (review, memory_save, delegation), an independent 78-row holdout disjoint from the training corpus, and a ratcheted baseline whose gate forbids silent drift in either direction. No routing behavior changed — the scorer is read-only in every new path, and the handler edits are additive output plus enum-tightened input validation only.\n<!-- /ANCHOR:exec-summary -->\n\n---\n\n<!-- ANCHOR:what-built -->\n## What Was Built\n\n### The gap\nThe release gate measured only aggregate top-1 accuracy plus a synthetic dead-tie check and an every-fifth-row holdout carved from the same 193-row training corpus. Regressions confined to contested prompts, to a single intent class, or masked by memorization were invisible. The corpus already carried `bucket` and `source_type` on every row, but they were unenforced and unused for slicing.\n\n### What was added\n- **Empirical ambiguity slice**: the top-2 fused-score margin is derived for every corpus row under the reproducible projection; the 25 lowest-margin rows (at a frozen `tau=0.03`) are frozen with their existing gold labels, and a gate holds their top-1 at or above the baseline.\n- **Bucket enforcement + slices**: `CorpusRowSchema` now validates `bucket` and `source_type` as enums (passthrough retained); the validate output gains `slices.buckets.{review, memory_save, delegation}`, each with a `minN` floor. review and memory_save slice the corpus by bucket; delegation scores the shared executor-delegation fixture (the training corpus carries no honest executor-delegation signal).\n- **Ratcheted baseline + gate**: `scorer-eval-baseline.json` records the top-1 count for every measure with sha256 fixture pins. The gate re-scores live and holds each metric exactly, failing directionally on any drift (regression vs unrecaptured improvement), with the fixed release floors retained as an absolute minimum.\n- **Independent holdout**: 78 rows assembled from three disjoint labeled fixtures (harder-intent 22, regression 50, delegation 11 -> dedup -> 78), with a gate that re-proves disjointness from the training corpus and holds top-1 at or above the baseline.\n\n### Files Changed\n\n| File | Action | Purpose |\n|------|--------|---------|\n| `handlers/advisor-validate.ts` | Modified | Enum-enforce bucket/source_type; delegation loader + `evaluateDelegationCases`; `bucketSlice`; compute + output `slices.buckets` over the full corpus |\n| `schemas/advisor-tool-schemas.ts` | Modified | `bucketSliceSchema` (adds `minN` + `top1`); `slices.buckets` block |\n| `scripts/routing-accuracy/build-holdout.mjs` | Created | Assemble + dedup the 78-row independent holdout |\n| `scripts/routing-accuracy/derive-ambiguity-slice.mjs` | Created | Offline-derive + freeze the ambiguity slice at `tau` |\n| `scripts/routing-accuracy/capture-scorer-eval-baseline.mjs` | Created | Capture the baseline with sha256 fixture pins |\n| `scripts/routing-accuracy/holdout-prompts.jsonl` | Created | Frozen 78-row independent holdout |\n| `scripts/routing-accuracy/ambiguity-prompts.jsonl` | Created | Frozen 25-row ambiguity slice |\n| `scripts/routing-accuracy/scorer-eval-baseline.json` | Created | Frozen accuracy baseline |\n| `tests/parity/scorer-eval-baseline-ratchet.vitest.ts` | Created | Non-regression + fixture-pin + floor gate |\n| `tests/parity/holdout-independent.vitest.ts` | Created | Independent holdout gate |\n| `tests/scorer/ambiguity-slice.vitest.ts` | Created | Ambiguity-slice gate |\n| `tests/handlers/advisor-validate.vitest.ts` | Modified | Assert the new buckets, minN, full-corpus scope, and enum enforcement |\n| `tests/handlers/advisor-validate-shapes.vitest.ts` | Modified | Update the valid-corpus-row fixtures for the now-required enum fields |\n<!-- /ANCHOR:what-built -->\n\n---\n\n<!-- ANCHOR:how-delivered -->\n## How It Was Delivered\n\nNumbers were measured, not assumed. The additive handler and schema edits were made and typechecked (exit 0) before dist was rebuilt. The holdout dedup was verified to reproduce 78 rows exactly (83 raw, 4 intra-pool duplicates, 1 training collision — the CommonJS-helper delegation prompt — removed) with disjointness confirmed. The ambiguity slice was derived from live margins. The baseline was captured under the deterministic filesystem projection.\n\nA discrepancy surfaced during verification: the node-captured baseline disagreed with the vitest gate on the near-tie rows. Root cause was found empirically — the semantic-shadow lane substitutes deterministic fixture vectors under the test-harness flag, which every existing scorer gate runs with, but a plain node capture does not. The capture scripts were corrected to set the harness flag (recorded as ADR-003), after which the baseline reproduces the gate numbers exactly. No commit or push was performed; the changes are left in the working tree for the orchestrator.\n<!-- /ANCHOR:how-delivered -->\n\n---\n\n<!-- ANCHOR:decisions -->\n## Key Decisions\n\n| Decision | Why |\n|----------|-----|\n| Fixed floor + exact-match ratchet (ADR-001) | A fixed floor is blind to above-floor drift; the ratchet holds the last-known-good and forces a conscious re-baseline on any legitimate movement, with the floor as a hard backstop |\n| Honest holdout from disjoint labeled fixtures (ADR-002) | No never-seen production gold exists in the repo; repurposing three disjoint, separately-authored labeled fixtures measures generalization without fabricating labels |\n| Capture under the test-harness regime (ADR-003) | Every scorer gate runs the harness fixture-semantic regime; the baseline must be measured in the same regime that re-scores it, or the ratchet fails against its own baseline |\n| Buckets over the full corpus, not the skillSlug scope | The named buckets are a global diagnostic; scoping them would shrink them below `minN` and lose meaning |\n| Retain the legacy every-Nth-row holdout | Removing it would churn the live handler and adjacent parity assertions for no measurement gain; it stays as a secondary signal |\n<!-- /ANCHOR:decisions -->\n\n---\n\n<!-- ANCHOR:verification -->\n## Verification\n\n| Check | Result |\n|-------|--------|\n| `npm run typecheck` | PASS (exit 0) |\n| `scorer-eval-baseline-ratchet.vitest.ts` | PASS (6/6) |\n| `holdout-independent.vitest.ts` | PASS (3/3) |\n| `ambiguity-slice.vitest.ts` | PASS (3/3) |\n| `advisor-validate.vitest.ts` (extended) | PASS |\n| `advisor-validate-shapes.vitest.ts` (reconciled) | PASS |\n| `python-ts-parity.vitest.ts` | PASS (hard-asserts pythonCorrect=105, tsAlsoCorrect=101, regressions=4, ids equal) |\n| `local-native-divergence-ratchet.vitest.ts` | PASS (green; no ledger edit) |\n| Ratchet mutation proof | PASS (baseline full_corpus 147 -> 148 fails the gate with the exact directional diff; restored) |\n| Full advisor vitest suite | 652 passed, 5 skipped, 4 failed (all pre-existing scorer-independent infra flakes) |\n\n**Baseline (harness regime, filesystem projection)**: full-corpus 147/193 = 0.7617; unknown 10; gold-none-false-fire 8; holdout 60/78 = 0.7692; ambiguity 15/25 = 0.60 (`tau=0.03`); buckets review 22/32 = 0.6875, memory_save 25/32 = 0.7813, delegation 11/11 = 1.0. Floors met: full-corpus >= 0.75, holdout >= 0.725.\n<!-- /ANCHOR:verification -->\n\n---\n\n<!-- ANCHOR:deviations -->\n## Deviations From Plan\n\n1. **A third generator script was added** (`derive-ambiguity-slice.mjs`) beyond the plan's two. The ambiguity slice needs an offline deriver, mirroring `build-holdout.mjs`; it is a run-once frozen generator, not a CI dependency.\n2. **The baseline is captured under the test-harness regime** (ADR-003). The plan's capture recipe omitted the harness fixture-semantic factor; matching it is required for the baseline and the gate to agree and keeps this gate consistent with every sibling scorer test.\n3. **`advisor-validate-shapes.vitest.ts` was reconciled** (not named in the plan). The enum tightening made its minimal valid-row fixtures invalid; two fixtures gained the now-required `bucket` + `source_type` fields.\n<!-- /ANCHOR:deviations -->\n\n---\n\n<!-- ANCHOR:limitations -->\n## Known Limitations\n\n1. **The full suite shows 4 failures, all pre-existing and scorer-independent.** `compat/shim` (Python subprocess stdin), `skill-advisor-cli-parity` (Python/native CLI), `advisor-graph-health` (legacy graph health), and `manual-testing-playbook` (doc inventory). None imports the scorer, and the scorer/parity/ratchet gates are all green, so this change introduces no new failures. A fifth infra flake (migration-lineage-identity / launcher-orphan-reaping) is fluid and passed this run.\n2. **The baseline measures the harness regime, not the daemon's real-embedding runtime.** This is the standard reproducible-CI trade-off shared by every scorer gate; the ratchet tracks relative regressions, which is its purpose (ADR-003).\n3. **The holdout rows are repurposed labeled fixtures, not fresh held-out production traffic.** The telemetry-labeled upgrade is deferred, not faked (prompt-safety forbids storing routable prompt content in telemetry) (ADR-002).\n4. **The routing-accuracy `README.md` fixture documentation is deferred.** A concurrent session holds the README dirty; the doc delta is handed off rather than clobbering their edit.\n5. **No commit or push was performed.** The orchestrator owns the push to the shared branch; the changes are in the working tree.\n<!-- /ANCHOR:limitations -->\n\n---\n\n<!-- ANCHOR:follow-up -->\n## Follow-Up\n\n- Document the four routing-accuracy fixtures in the `README.md` once the concurrent session's edit lands.\n- When the scorer or skill metadata legitimately changes, re-run `capture-scorer-eval-baseline.mjs --write` to re-baseline (the ratchet's directional message names this step).\n<!-- /ANCHOR:follow-up -->","lineStart":1,"lineEnd":161,"totalLines":161,"truncated":false}},"title":".opencode/specs/system-skill-advisor/012-skill-advisor-tuning/007-eval-hardening/implementation-summary.md","time":{"start":1783437254479,"end":1783437254488}},"metadata":{"openai":{"itemId":"fc_05d3cf1f77bc4662016a4d17c63ed8819199c69c35516a4b01"}},"id":"prt_f3d24df460013CJwprFZQHojPB","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24b3a0001g77zq5uk2J434C"}}
{"type":"tool_use","timestamp":1783437254501,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_0GdLBi5DBCwHJprqc59x14LC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze/implementation-summary.md","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze/implementation-summary.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Implementation Summary: Semantic Shadow Prove-or-Freeze\"\n3: description: \"Shipped: the FREEZE of the semantic_shadow lane at weight 0.05 is confirmed and locked. A full 193-row paired ablation under a pinned real provider (ollama__nomic-embed-text-v1.5__768, RRF off, rerank off) measured full 149/193 vs semantic-disabled 150/193 — a marginal net-negative of one row. An additive opt-in harness carries the ablation, a fail-on-skip experiment-integrity guard, and a runtime degradation detector. No production scorer code or weight changed; the five scorer files stay git-clean; parity 105/101/4 unchanged.\"\n4: trigger_phrases:\n5:   - \"semantic shadow freeze summary\"\n6:   - \"semantic ablation implementation summary\"\n7:   - \"fail-on-skip guard shipped\"\n8: importance_tier: \"high\"\n9: contextType: \"implementation\"\n10: status: \"Complete\"\n11: _memory:\n12:   continuity:\n13:     packet_pointer: \"system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze\"\n14:     last_updated_at: \"2026-07-07T09:00:00.000Z\"\n15:     last_updated_by: \"opus-4.8\"\n16:     recent_action: \"Confirmed the freeze and shipped the additive guards\"\n17:     next_safe_action: \"Orchestrator pushes the working tree to the shared branch (no commit/push done here)\"\n18:     blockers: []\n19:     key_files:\n20:       - \".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/semantic-shadow-ablation.vitest.ts\"\n21:     completion_pct: 100\n22: ---\n23: # Implementation Summary\n24: \n25: <!-- SPECKIT_LEVEL: 2 -->\n26: <!-- SPECKIT_TEMPLATE_SOURCE: impl-summary-core + level2 | v2.2 -->\n27: \n28: ---\n29: \n30: <!-- ANCHOR:metadata -->\n31: ## Metadata\n32: \n33: | Field | Value |\n34: |-------|-------|\n35: | **Spec Folder** | 008-semantic-shadow-prove-or-freeze |\n36: | **Completed** | 2026-07-07 |\n37: | **Level** | 2 |\n38: | **Verdict** | FREEZE (weight 0.05 unchanged) |\n39: <!-- /ANCHOR:metadata -->\n40: \n41: ---\n42: \n43: <!-- ANCHOR:exec-summary -->\n44: ## Executive Summary\n45: \n46: The `semantic_shadow` lane stays at weight **0.05** with no production scorer change. The mandate — PROVE-or-FREEZE that weight on the full corpus — is answered FREEZE, confirmed by a full 193-row paired ablation under a pinned real provider. The two arms (full 5-lane vs `disabledLanes:['semantic_shadow']`) differ only in the semantic lane, with RRF fusion and the exact-semantic rerank both OFF. Measured, deterministic: full **149/193** top-1 correct, semantic-disabled **150/193**, delta **+1** for the disabled arm, **6** top-1 flips. The lane is a marginal net-negative of one row (0.5% of the corpus). Everything shipped is additive: one vitest harness carrying the ablation, a fail-on-skip guard, and a runtime degradation detector, plus this decision record.\n47: <!-- /ANCHOR:exec-summary -->\n48: \n49: ---\n50: \n51: <!-- ANCHOR:what-built -->\n52: ## What Was Built\n53: \n54: ### The gap\n55: The weight had never been confirmed on the full 193-row corpus with real embeddings. Prior evidence (a 46-prompt sweep, a V0/V1 weight-ablation) showed zero routing change, but every existing scorer gate runs the lane under deterministic FIXTURE vectors, never the daemon's real embedding path — so the live behavior was unmeasured. And when the provider is unavailable the lane silently no-ops, which is indistinguishable from \"semantic is irrelevant.\"\n56: \n57: ### What was added\n58: - **Seeded 193-row paired ablation** (opt-in): loads the full projection, builds a fixture projection of every described skill, seeds each description through the pinned provider (cache-backed), spies `loadSkillEmbeddings`, then scores every corpus row with and without the semantic lane. All described skills are seeded so the cosine lane can pull toward ANY skill — a wrong flip is as observable as a right one.\n59: - **Fail-on-skip experiment integrity**: under the opt-in flag the harness hard-fails on provider-absent, pinned-model mismatch, missing prompt/skill embeddings, or all-zero seeded semantic scores; absent the flag it skip-guards so default CI never needs a provider. A non-zero-semantic probe proves the seeded lane is genuinely active.\n60: - **Runtime degradation detector**: drives the lane's stale-projection path and asserts `getSemanticShadowRuntimeHealth().disabledReason` surfaces the degradation instead of swallowing it into a `console.warn`.\n61: \n62: ### Files Changed\n63: \n64: | File | Action | Purpose |\n65: |------|--------|---------|\n66: | `tests/scorer/semantic-shadow-ablation.vitest.ts` | Created | Opt-in 193-row paired ablation + non-zero-semantic guardrail + fail-on-skip + runtime degradation detector |\n67: | `.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze/**` | Created | This Level 2 decision record + metadata |\n68: | `.opencode/specs/system-skill-advisor/graph-metadata.json` | Modified | Registered the 008 child; repointed `last_active_child_id` |\n69: \n70: ### Files deliberately NOT changed (frozen)\n71: `lib/scorer/fusion.ts`, `lib/scorer/lanes/semantic-shadow.ts`, `lib/scorer/ablation.ts`, `lib/scorer/weights-config.ts`, `lib/scorer/lane-registry.ts` — all git-clean.\n72: <!-- /ANCHOR:what-built -->\n73: \n74: ---\n75: \n76: <!-- ANCHOR:how-delivered -->\n77: ## How It Was Delivered\n78: \n79: Numbers were measured, not assumed. The plan predicted delta-0 / zero flips from the 46-prompt evidence. The full-corpus run with real nomic embeddings instead produced a deterministic **net-negative of one row**: full 149/193, disabled 150/193, 6 flips. The flips break down as 2 helps (`memory:save` correct only with the lane), 3 hurts (gold `none` abstains that the lane false-fires to `mcp-chrome-devtools`), and 1 neutral-wrong. Two flag-on re-runs reproduced the counts and the flip ids exactly.\n80: \n81: This surprise was reported exactly rather than forced to delta-0 — fabricating a null result would defeat the entire experiment-integrity purpose of the packet. It does not change the verdict: a net-negative is direct evidence AGAINST raising the weight (raising it amplifies the abstain false-fires, not the two gains), and a 0.5% swing measured under a seeded fixture-projection harness does not justify dropping the lane (dropping breaks `liveLaneCount === 5` and the weight-sum normalization and forces a full re-baseline of the 105/101/4 parity contract). The harness therefore asserts a small documented freeze band and records the exact counts, rather than asserting zero. No commit or push was performed; the changes are left in the working tree for the orchestrator.\n82: <!-- /ANCHOR:how-delivered -->\n83: \n84: ---\n85: \n86: <!-- ANCHOR:decisions -->\n87: ## Key Decisions\n88: \n89: | Decision | Why |\n90: |----------|-----|\n91: | Keep the weight at 0.05 (retain the lane, do not drop to 0) | A 0.5% seeded-harness net-negative does not justify breaking the live-lane-count / weight-sum invariants or forcing a full 105/101/4 re-baseline; the low-weight hedge is the smaller, reversible choice |\n92: | Report the measured +1, not the plan's predicted delta-0 | Fabricating a null result would defeat the fail-on-skip experiment-integrity purpose; honesty is the deliverable |\n93: | Gate the heavy ablation behind an opt-in flag | The real-embedding run must never make default CI depend on a local provider; absent the flag the suite skip-guards |\n94: | Seed ALL described skills, not just the corpus gold set | So the cosine lane can pull toward any skill and a wrong flip (abstain false-fire) is as observable as a right one |\n95: | Score against a fixture projection | Avoids the sqlite embedding-staleness gate and any live daemon vector DB open (native-ABI / SIGBUS fragility) |\n96: <!-- /ANCHOR:decisions -->\n97: \n98: ---\n99: \n100: <!-- ANCHOR:verification -->\n101: ## Verification\n102: \n103: | Check | Result |\n104: |-------|--------|\n105: | `semantic-shadow-ablation.vitest.ts` — flag OFF | PASS (2 passed / 2 skipped; degradation detector green, ablation skip-guarded) |\n106: | `semantic-shadow-ablation.vitest.ts` — flag ON | PASS (4/4; pinned provider present) |\n107: | `semantic-lane-promotion.vitest.ts` | PASS (6/6; `liveLaneCount === 5`, weight 0.05, `liveWeightTotal ≈ 1`) |\n108: | `lane-weight-sweep.vitest.ts` | PASS (3/3; seeded sweep + non-zero-semantic guardrail) |\n109: | `semantic-shadow-cosine.vitest.ts` | PASS (4/4 via an include override; the file is outside the default `tests/**` include glob — a pre-existing config condition) |\n110: | `python-ts-parity.vitest.ts` | PASS (2/2; hard-asserts pythonCorrect=105, tsAlsoCorrect=101, regressions=4) |\n111: | Five production scorer files git-clean | PASS (`git status --porcelain` empty) |\n112: | `validate.sh --strict` on this folder | Exit 0 |\n113: \n114: **Ablation (pinned real provider, filesystem fixture projection)**: providerModelId `ollama__nomic-embed-text-v1.5__768`; RRF off, exact-semantic rerank off; full 149/193 = 0.7720; semantic-disabled 150/193 = 0.7772; delta +1; 6 flips (2 help `memory:save`, 3 hurt via `mcp-chrome-devtools` abstain false-fire, 1 neutral-wrong); deterministic across re-runs.\n115: <!-- /ANCHOR:verification -->\n116: \n117: ---\n118: \n119: <!-- ANCHOR:deviations -->\n120: ## Deviations From Plan\n121: \n122: 1. **The ablation is a marginal net-negative, not delta-0.** The plan predicted zero flips from the 46-prompt evidence; the full-corpus real-embedding run measured full 149 vs disabled 150 (delta +1, 6 flips). Reported exactly. It strengthens the freeze-vs-raise decision and does not clear the bar to drop the lane. The plan's \"harmless hedge\" framing is refined to \"marginal net-negative hedge retained for structural stability.\"\n123: 2. **The harness asserts a freeze band, not delta-0.** Because the real-embedding lane is a net-negative, a hard `flips === 0` assertion would be a false expectation; the harness asserts the net correctness swing stays within a small documented tolerance and records the exact counts + flip list.\n124: 3. **No `decision-record.md`.** Level 2 is the target; the decision + evidence live in spec.md §5 and here. The confirming ablation did not surprise us into a PROVE branch (it went net-negative, not net-positive), so no Level 3 escalation was warranted.\n125: <!-- /ANCHOR:deviations -->\n126: \n127: ---\n128: \n129: <!-- ANCHOR:limitations -->\n130: ## Known Limitations\n131: \n132: 1. **The ablation measures a seeded fixture-projection harness, not the daemon's live runtime.** This is the standard reproducible-test trade-off; the pinned provider + spied `loadSkillEmbeddings` keep it deterministic and off the fragile daemon vector DB.\n133: 2. **The heavy ablation is opt-in.** It runs only under `SPECKIT_ADVISOR_SEMANTIC_ABLATION=1`; default CI runs the always-on degradation detector and skip-guards the rest.\n134: 3. **The `semantic-shadow-cosine` test is outside the default `tests/**` include glob.** It is confirmed green via an include override; wiring it into the default suite is a pre-existing config matter, out of this packet's scope, and cannot regress from a freeze that touches no production code.\n135: 4. **No commit or push was performed.** The orchestrator owns the push to the shared branch; the changes are in the working tree.\n136: <!-- /ANCHOR:limitations -->\n137: \n138: ---\n139: \n140: <!-- ANCHOR:follow-up -->\n141: ## Follow-Up\n142: \n143: - If the daemon or skill metadata legitimately changes, re-run the opt-in ablation under the pinned provider to re-confirm the freeze band.\n144: - If a future run ever shows a net-POSITIVE correctness gain from the lane clearing the evidence bar, escalate to a PROVE branch (weight change + full 105/101/4 re-baseline, coordinated against the pushed fusion lane) — not expected on current evidence.\n145: - Optional, out of packet: wire `lib/**/__tests__/**/*.vitest.ts` into the default vitest include so the cosine gate runs in the standard suite.\n146: <!-- /ANCHOR:follow-up -->\n\n(End of file - total 146 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Implementation Summary: Semantic Shadow Prove-or-Freeze\"\ndescription: \"Shipped: the FREEZE of the semantic_shadow lane at weight 0.05 is confirmed and locked. A full 193-row paired ablation under a pinned real provider (ollama__nomic-embed-text-v1.5__768, RRF off, rerank off) measured full 149/193 vs semantic-disabled 150/193 — a marginal net-negative of one row. An additive opt-in harness carries the ablation, a fail-on-skip experiment-integrity guard, and a runtime degradation detector. No production scorer code or weight changed; the five scorer files stay git-clean; parity 105/101/4 unchanged.\"\ntrigger_phrases:\n  - \"semantic shadow freeze summary\"\n  - \"semantic ablation implementation summary\"\n  - \"fail-on-skip guard shipped\"\nimportance_tier: \"high\"\ncontextType: \"implementation\"\nstatus: \"Complete\"\n_memory:\n  continuity:\n    packet_pointer: \"system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze\"\n    last_updated_at: \"2026-07-07T09:00:00.000Z\"\n    last_updated_by: \"opus-4.8\"\n    recent_action: \"Confirmed the freeze and shipped the additive guards\"\n    next_safe_action: \"Orchestrator pushes the working tree to the shared branch (no commit/push done here)\"\n    blockers: []\n    key_files:\n      - \".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/semantic-shadow-ablation.vitest.ts\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze/implementation-summary.md","text":"---\ntitle: \"Implementation Summary: Semantic Shadow Prove-or-Freeze\"\ndescription: \"Shipped: the FREEZE of the semantic_shadow lane at weight 0.05 is confirmed and locked. A full 193-row paired ablation under a pinned real provider (ollama__nomic-embed-text-v1.5__768, RRF off, rerank off) measured full 149/193 vs semantic-disabled 150/193 — a marginal net-negative of one row. An additive opt-in harness carries the ablation, a fail-on-skip experiment-integrity guard, and a runtime degradation detector. No production scorer code or weight changed; the five scorer files stay git-clean; parity 105/101/4 unchanged.\"\ntrigger_phrases:\n  - \"semantic shadow freeze summary\"\n  - \"semantic ablation implementation summary\"\n  - \"fail-on-skip guard shipped\"\nimportance_tier: \"high\"\ncontextType: \"implementation\"\nstatus: \"Complete\"\n_memory:\n  continuity:\n    packet_pointer: \"system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze\"\n    last_updated_at: \"2026-07-07T09:00:00.000Z\"\n    last_updated_by: \"opus-4.8\"\n    recent_action: \"Confirmed the freeze and shipped the additive guards\"\n    next_safe_action: \"Orchestrator pushes the working tree to the shared branch (no commit/push done here)\"\n    blockers: []\n    key_files:\n      - \".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/semantic-shadow-ablation.vitest.ts\"\n    completion_pct: 100\n---\n# Implementation Summary\n\n<!-- SPECKIT_LEVEL: 2 -->\n<!-- SPECKIT_TEMPLATE_SOURCE: impl-summary-core + level2 | v2.2 -->\n\n---\n\n<!-- ANCHOR:metadata -->\n## Metadata\n\n| Field | Value |\n|-------|-------|\n| **Spec Folder** | 008-semantic-shadow-prove-or-freeze |\n| **Completed** | 2026-07-07 |\n| **Level** | 2 |\n| **Verdict** | FREEZE (weight 0.05 unchanged) |\n<!-- /ANCHOR:metadata -->\n\n---\n\n<!-- ANCHOR:exec-summary -->\n## Executive Summary\n\nThe `semantic_shadow` lane stays at weight **0.05** with no production scorer change. The mandate — PROVE-or-FREEZE that weight on the full corpus — is answered FREEZE, confirmed by a full 193-row paired ablation under a pinned real provider. The two arms (full 5-lane vs `disabledLanes:['semantic_shadow']`) differ only in the semantic lane, with RRF fusion and the exact-semantic rerank both OFF. Measured, deterministic: full **149/193** top-1 correct, semantic-disabled **150/193**, delta **+1** for the disabled arm, **6** top-1 flips. The lane is a marginal net-negative of one row (0.5% of the corpus). Everything shipped is additive: one vitest harness carrying the ablation, a fail-on-skip guard, and a runtime degradation detector, plus this decision record.\n<!-- /ANCHOR:exec-summary -->\n\n---\n\n<!-- ANCHOR:what-built -->\n## What Was Built\n\n### The gap\nThe weight had never been confirmed on the full 193-row corpus with real embeddings. Prior evidence (a 46-prompt sweep, a V0/V1 weight-ablation) showed zero routing change, but every existing scorer gate runs the lane under deterministic FIXTURE vectors, never the daemon's real embedding path — so the live behavior was unmeasured. And when the provider is unavailable the lane silently no-ops, which is indistinguishable from \"semantic is irrelevant.\"\n\n### What was added\n- **Seeded 193-row paired ablation** (opt-in): loads the full projection, builds a fixture projection of every described skill, seeds each description through the pinned provider (cache-backed), spies `loadSkillEmbeddings`, then scores every corpus row with and without the semantic lane. All described skills are seeded so the cosine lane can pull toward ANY skill — a wrong flip is as observable as a right one.\n- **Fail-on-skip experiment integrity**: under the opt-in flag the harness hard-fails on provider-absent, pinned-model mismatch, missing prompt/skill embeddings, or all-zero seeded semantic scores; absent the flag it skip-guards so default CI never needs a provider. A non-zero-semantic probe proves the seeded lane is genuinely active.\n- **Runtime degradation detector**: drives the lane's stale-projection path and asserts `getSemanticShadowRuntimeHealth().disabledReason` surfaces the degradation instead of swallowing it into a `console.warn`.\n\n### Files Changed\n\n| File | Action | Purpose |\n|------|--------|---------|\n| `tests/scorer/semantic-shadow-ablation.vitest.ts` | Created | Opt-in 193-row paired ablation + non-zero-semantic guardrail + fail-on-skip + runtime degradation detector |\n| `.opencode/specs/system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze/**` | Created | This Level 2 decision record + metadata |\n| `.opencode/specs/system-skill-advisor/graph-metadata.json` | Modified | Registered the 008 child; repointed `last_active_child_id` |\n\n### Files deliberately NOT changed (frozen)\n`lib/scorer/fusion.ts`, `lib/scorer/lanes/semantic-shadow.ts`, `lib/scorer/ablation.ts`, `lib/scorer/weights-config.ts`, `lib/scorer/lane-registry.ts` — all git-clean.\n<!-- /ANCHOR:what-built -->\n\n---\n\n<!-- ANCHOR:how-delivered -->\n## How It Was Delivered\n\nNumbers were measured, not assumed. The plan predicted delta-0 / zero flips from the 46-prompt evidence. The full-corpus run with real nomic embeddings instead produced a deterministic **net-negative of one row**: full 149/193, disabled 150/193, 6 flips. The flips break down as 2 helps (`memory:save` correct only with the lane), 3 hurts (gold `none` abstains that the lane false-fires to `mcp-chrome-devtools`), and 1 neutral-wrong. Two flag-on re-runs reproduced the counts and the flip ids exactly.\n\nThis surprise was reported exactly rather than forced to delta-0 — fabricating a null result would defeat the entire experiment-integrity purpose of the packet. It does not change the verdict: a net-negative is direct evidence AGAINST raising the weight (raising it amplifies the abstain false-fires, not the two gains), and a 0.5% swing measured under a seeded fixture-projection harness does not justify dropping the lane (dropping breaks `liveLaneCount === 5` and the weight-sum normalization and forces a full re-baseline of the 105/101/4 parity contract). The harness therefore asserts a small documented freeze band and records the exact counts, rather than asserting zero. No commit or push was performed; the changes are left in the working tree for the orchestrator.\n<!-- /ANCHOR:how-delivered -->\n\n---\n\n<!-- ANCHOR:decisions -->\n## Key Decisions\n\n| Decision | Why |\n|----------|-----|\n| Keep the weight at 0.05 (retain the lane, do not drop to 0) | A 0.5% seeded-harness net-negative does not justify breaking the live-lane-count / weight-sum invariants or forcing a full 105/101/4 re-baseline; the low-weight hedge is the smaller, reversible choice |\n| Report the measured +1, not the plan's predicted delta-0 | Fabricating a null result would defeat the fail-on-skip experiment-integrity purpose; honesty is the deliverable |\n| Gate the heavy ablation behind an opt-in flag | The real-embedding run must never make default CI depend on a local provider; absent the flag the suite skip-guards |\n| Seed ALL described skills, not just the corpus gold set | So the cosine lane can pull toward any skill and a wrong flip (abstain false-fire) is as observable as a right one |\n| Score against a fixture projection | Avoids the sqlite embedding-staleness gate and any live daemon vector DB open (native-ABI / SIGBUS fragility) |\n<!-- /ANCHOR:decisions -->\n\n---\n\n<!-- ANCHOR:verification -->\n## Verification\n\n| Check | Result |\n|-------|--------|\n| `semantic-shadow-ablation.vitest.ts` — flag OFF | PASS (2 passed / 2 skipped; degradation detector green, ablation skip-guarded) |\n| `semantic-shadow-ablation.vitest.ts` — flag ON | PASS (4/4; pinned provider present) |\n| `semantic-lane-promotion.vitest.ts` | PASS (6/6; `liveLaneCount === 5`, weight 0.05, `liveWeightTotal ≈ 1`) |\n| `lane-weight-sweep.vitest.ts` | PASS (3/3; seeded sweep + non-zero-semantic guardrail) |\n| `semantic-shadow-cosine.vitest.ts` | PASS (4/4 via an include override; the file is outside the default `tests/**` include glob — a pre-existing config condition) |\n| `python-ts-parity.vitest.ts` | PASS (2/2; hard-asserts pythonCorrect=105, tsAlsoCorrect=101, regressions=4) |\n| Five production scorer files git-clean | PASS (`git status --porcelain` empty) |\n| `validate.sh --strict` on this folder | Exit 0 |\n\n**Ablation (pinned real provider, filesystem fixture projection)**: providerModelId `ollama__nomic-embed-text-v1.5__768`; RRF off, exact-semantic rerank off; full 149/193 = 0.7720; semantic-disabled 150/193 = 0.7772; delta +1; 6 flips (2 help `memory:save`, 3 hurt via `mcp-chrome-devtools` abstain false-fire, 1 neutral-wrong); deterministic across re-runs.\n<!-- /ANCHOR:verification -->\n\n---\n\n<!-- ANCHOR:deviations -->\n## Deviations From Plan\n\n1. **The ablation is a marginal net-negative, not delta-0.** The plan predicted zero flips from the 46-prompt evidence; the full-corpus real-embedding run measured full 149 vs disabled 150 (delta +1, 6 flips). Reported exactly. It strengthens the freeze-vs-raise decision and does not clear the bar to drop the lane. The plan's \"harmless hedge\" framing is refined to \"marginal net-negative hedge retained for structural stability.\"\n2. **The harness asserts a freeze band, not delta-0.** Because the real-embedding lane is a net-negative, a hard `flips === 0` assertion would be a false expectation; the harness asserts the net correctness swing stays within a small documented tolerance and records the exact counts + flip list.\n3. **No `decision-record.md`.** Level 2 is the target; the decision + evidence live in spec.md §5 and here. The confirming ablation did not surprise us into a PROVE branch (it went net-negative, not net-positive), so no Level 3 escalation was warranted.\n<!-- /ANCHOR:deviations -->\n\n---\n\n<!-- ANCHOR:limitations -->\n## Known Limitations\n\n1. **The ablation measures a seeded fixture-projection harness, not the daemon's live runtime.** This is the standard reproducible-test trade-off; the pinned provider + spied `loadSkillEmbeddings` keep it deterministic and off the fragile daemon vector DB.\n2. **The heavy ablation is opt-in.** It runs only under `SPECKIT_ADVISOR_SEMANTIC_ABLATION=1`; default CI runs the always-on degradation detector and skip-guards the rest.\n3. **The `semantic-shadow-cosine` test is outside the default `tests/**` include glob.** It is confirmed green via an include override; wiring it into the default suite is a pre-existing config matter, out of this packet's scope, and cannot regress from a freeze that touches no production code.\n4. **No commit or push was performed.** The orchestrator owns the push to the shared branch; the changes are in the working tree.\n<!-- /ANCHOR:limitations -->\n\n---\n\n<!-- ANCHOR:follow-up -->\n## Follow-Up\n\n- If the daemon or skill metadata legitimately changes, re-run the opt-in ablation under the pinned provider to re-confirm the freeze band.\n- If a future run ever shows a net-POSITIVE correctness gain from the lane clearing the evidence bar, escalate to a PROVE branch (weight change + full 105/101/4 re-baseline, coordinated against the pushed fusion lane) — not expected on current evidence.\n- Optional, out of packet: wire `lib/**/__tests__/**/*.vitest.ts` into the default vitest include so the cosine gate runs in the standard suite.\n<!-- /ANCHOR:follow-up -->","lineStart":1,"lineEnd":146,"totalLines":146,"truncated":false}},"title":".opencode/specs/system-skill-advisor/012-skill-advisor-tuning/008-semantic-shadow-prove-or-freeze/implementation-summary.md","time":{"start":1783437254490,"end":1783437254500}},"metadata":{"openai":{"itemId":"fc_05d3cf1f77bc4662016a4d17c63ee081919423de56f50e1603"}},"id":"prt_f3d24df51001bkHTNxSbcjlrYm","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24b3a0001g77zq5uk2J434C"}}
{"type":"tool_use","timestamp":1783437254566,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"grep","callID":"call_0RImcHshg0TcZ9ip9MgWDIut","state":{"status":"completed","input":{"pattern":"buildExecutorAliasTable","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode","include":"*.{ts,cjs,mjs,js}"},"output":"Found 4 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/executor-delegation.ts:\n  Line 231: export function buildExecutorAliasTable(\n\n  Line 370:   const table = buildExecutorAliasTable(ctx.projection, ctx.workspaceRoot);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/executor-delegation.vitest.ts:\n  Line 14:   buildExecutorAliasTable,\n\n  Line 121:   const table = buildExecutorAliasTable(loadAdvisorProjection(WORKSPACE_ROOT), WORKSPACE_ROOT);\n","metadata":{"matches":4,"truncated":false},"title":"buildExecutorAliasTable","time":{"start":1783437254402,"end":1783437254564}},"metadata":{"openai":{"itemId":"fc_05d3cf1f77bc4662016a4d17c63ec88191ba373acb6f763495"}},"id":"prt_f3d24decf001iG3RRIWKdx6xYj","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24b3a0001g77zq5uk2J434C"}}
{"type":"step_finish","timestamp":1783437254924,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"id":"prt_f3d24e109001QH3UKw02f3CF1i","reason":"tool-calls","snapshot":"cc84567d5854c5fc7aa25b8826a78c8760092b59","messageID":"msg_f3d24b3a0001g77zq5uk2J434C","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","type":"step-finish","tokens":{"total":144247,"input":15791,"output":456,"reasoning":0,"cache":{"write":0,"read":128000}},"cost":0}}
{"type":"step_start","timestamp":1783437257269,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"id":"prt_f3d24ea34001GM82c4j7FlKivT","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","snapshot":"cc84567d5854c5fc7aa25b8826a78c8760092b59","type":"step-start"}}
{"type":"text","timestamp":1783437267609,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"id":"prt_f3d24f227001aEQKE7yQNR8Og0","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","type":"text","text":"The prior packets give measured baselines to preserve: 007 fixed the ambiguity slice at 15/25 with weakest measured accuracy 0.60, and 008 confirmed semantic_shadow is net-negative on abstain false-fires to `mcp-chrome-devtools`. I’ll fold those into later iterations rather than proposing lane-weight churn.","time":{"start":1783437259303,"end":1783437267605},"metadata":{"openai":{"itemId":"msg_0318580f82639b15016a4d17cb44c88191aa80560032c8b789","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1783437267672,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_z3Sb01RJhiqGBW1hyVcvCoFA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","offset":600,"limit":150},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts</path>\n<type>file</type>\n<content>\n600:   try {\n601:     const rows = db.prepare(`\n602:       SELECT id, family, category, domains, intent_signals, derived, source_path\n603:       FROM skill_nodes\n604:       ORDER BY id ASC\n605:     `).all() as SkillNodeRow[];\n606:     const edgeRows = db.prepare(`\n607:       SELECT source_id, target_id, edge_type, weight, context\n608:       FROM skill_edges\n609:       ORDER BY source_id ASC, edge_type ASC, target_id ASC\n610:     `).all() as SkillEdgeRow[];\n611:     const docTriggersBySkill = loadDocTriggersBySkill(db);\n612:     const embeddingStaleness = readAdvisorEmbeddingStaleness(db);\n613:     return {\n614:       skills: [\n615:         ...rows.map((row) => {\n616:           const projection = projectionFromRow(row);\n617:           const docTriggers = docTriggersBySkill.get(row.id);\n618:           return docTriggers && docTriggers.length > 0 ? { ...projection, docTriggers } : projection;\n619:         }),\n620:         ...COMMAND_BRIDGES,\n621:       ],\n622:       edges: edgeRows.map((row) => ({\n623:         sourceId: row.source_id,\n624:         targetId: row.target_id,\n625:         edgeType: row.edge_type,\n626:         weight: Math.max(0, Math.min(1, row.weight)),\n627:         context: row.context,\n628:       })),\n629:       generatedAt: new Date().toISOString(),\n630:       source: 'sqlite',\n631:       embeddingSignature: embeddingStaleness.stored,\n632:       embeddingStaleness,\n633:     };\n634:   } finally {\n635:     db.close();\n636:   }\n637: }\n638: \n639: function loadFilesystemProjection(workspaceRoot: string): AdvisorProjection {\n640:   const skillRoot = join(workspaceRoot, '.opencode', 'skills');\n641:   const skills: SkillProjection[] = [];\n642:   const edges: SkillEdgeProjection[] = [];\n643:   if (!existsSync(skillRoot)) {\n644:     return { skills: [...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n645:   }\n646:   for (const entry of readdirSync(skillRoot, { withFileTypes: true })) {\n647:     if (!entry.isDirectory()) continue;\n648:     const skillDir = join(skillRoot, entry.name);\n649:     const metadataPath = join(skillDir, 'graph-metadata.json');\n650:     if (!existsSync(metadataPath)) continue;\n651:     const metadata = readJson(metadataPath);\n652:     const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), entry.name);\n653:     const skillId = typeof metadata.skill_id === 'string' ? metadata.skill_id : entry.name;\n654:     const rawDerived = typeof metadata.derived === 'object' && metadata.derived !== null && !Array.isArray(metadata.derived)\n655:       ? metadata.derived as Record<string, unknown>\n656:       : {};\n657:     const derived = sanitizeDerivedMetadata(rawDerived, metadataPath) ?? {};\n658:     // Same split applied here as in projectionFromRow above —\n659:     // derivedTriggers (from trigger_phrases) and derivedKeywords (from\n660:     // key_topics + entities + key_files + source_docs) are now distinct.\n661:     const derivedTriggers = unique(\n662:       stringArray(derived.trigger_phrases).flatMap((item) => phraseVariants(item)),\n663:     );\n664:     const derivedKeywords = unique([\n665:       ...stringArray(derived.key_topics),\n666:       ...stringArray(derived.entities),\n667:       ...stringArray(derived.key_files),\n668:       ...stringArray(derived.source_docs),\n669:     ].flatMap((item) => phraseVariants(item)));\n670:     skills.push({\n671:       id: skillId,\n672:       kind: 'skill',\n673:       family: typeof metadata.family === 'string' ? metadata.family : 'system',\n674:       category: typeof metadata.category === 'string' ? metadata.category : 'skill',\n675:       name: skillMd.name,\n676:       description: skillMd.description,\n677:       keywords: unique(skillMd.keywords.flatMap((item) => phraseVariants(item))),\n678:       domains: unique(sanitizeMetadataStringArray(stringArray(metadata.domains), metadataPath).flatMap((item) => phraseVariants(item))),\n679:       intentSignals: unique(sanitizeMetadataStringArray(stringArray(metadata.intent_signals), metadataPath).flatMap((item) => phraseVariants(item))),\n680:       derivedTriggers,\n681:       derivedKeywords,\n682:       derivedDemotion: boundedDemotion(derived.demotion),\n683:       // generated_at leads the chain (canonical V2 author/sync time); see the\n684:       // SQLite branch above for why this is author-time, not runtime.\n685:       derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n686:       sourcePath: metadataPath,\n687:       lifecycleStatus: lifecycleStatus(metadata.lifecycle_status ?? derived.lifecycle_status, metadataPath),\n688:       redirectTo: typeof metadata.redirect_to === 'string' ? metadata.redirect_to : undefined,\n689:       redirectFrom: stringArray(metadata.redirect_from),\n690:     });\n691:   }\n692:   return { skills: [...skills, ...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n693: }\n694: \n695: // Previously a bare `catch {}` swallowed every SQLite read error\n696: // and silently fell back to the filesystem projection, hiding corrupt-DB and\n697: // schema-drift failures from operators. We now distinguish three cases:\n698: //   1. SQLite read succeeded → return that projection ('sqlite').\n699: //   2. SQLite DB does not exist yet → loadSqliteProjection returns null and we\n700: //      fall through to a clean 'filesystem' projection (legitimate first run).\n701: //   3. SQLite read THREW → we still degrade to filesystem so the daemon stays\n702: //      up, but the projection is tagged 'filesystem-fallback' with a\n703: //      fallbackReason carrying the underlying error message AND the failure\n704: //      is logged via console.warn so it surfaces in daemon logs.\n705: export function loadAdvisorProjection(workspaceRoot: string): AdvisorProjection {\n706:   const resolvedRoot = resolve(workspaceRoot);\n707:   try {\n708:     const sqliteProjection = loadSqliteProjection(resolvedRoot);\n709:     if (sqliteProjection !== null) return sqliteProjection;\n710:     return loadFilesystemProjection(resolvedRoot);\n711:   } catch (error: unknown) {\n712:     const reason = error instanceof Error ? error.message : String(error);\n713:     console.warn(`[advisor-projection] SQLite projection failed; degraded to filesystem fallback: ${reason}`);\n714:     const fallback = loadFilesystemProjection(resolvedRoot);\n715:     return {\n716:       ...fallback,\n717:       source: 'filesystem-fallback',\n718:       fallbackReason: reason,\n719:     };\n720:   }\n721: }\n722: \n723: export function createFixtureProjection(\n724:   skills: readonly SkillProjection[],\n725:   edges: readonly SkillEdgeProjection[] = [],\n726: ): AdvisorProjection {\n727:   return {\n728:     skills,\n729:     edges,\n730:     generatedAt: new Date().toISOString(),\n731:     source: 'fixture',\n732:   };\n733: }\n\n(End of file - total 733 lines)\n</content>","metadata":{"preview":"  try {\n    const rows = db.prepare(`\n      SELECT id, family, category, domains, intent_signals, derived, source_path\n      FROM skill_nodes\n      ORDER BY id ASC\n    `).all() as SkillNodeRow[];\n    const edgeRows = db.prepare(`\n      SELECT source_id, target_id, edge_type, weight, context\n      FROM skill_edges\n      ORDER BY source_id ASC, edge_type ASC, target_id ASC\n    `).all() as SkillEdgeRow[];\n    const docTriggersBySkill = loadDocTriggersBySkill(db);\n    const embeddingStaleness = readAdvisorEmbeddingStaleness(db);\n    return {\n      skills: [\n        ...rows.map((row) => {\n          const projection = projectionFromRow(row);\n          const docTriggers = docTriggersBySkill.get(row.id);\n          return docTriggers && docTriggers.length > 0 ? { ...projection, docTriggers } : projection;\n        }),","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","text":"  try {\n    const rows = db.prepare(`\n      SELECT id, family, category, domains, intent_signals, derived, source_path\n      FROM skill_nodes\n      ORDER BY id ASC\n    `).all() as SkillNodeRow[];\n    const edgeRows = db.prepare(`\n      SELECT source_id, target_id, edge_type, weight, context\n      FROM skill_edges\n      ORDER BY source_id ASC, edge_type ASC, target_id ASC\n    `).all() as SkillEdgeRow[];\n    const docTriggersBySkill = loadDocTriggersBySkill(db);\n    const embeddingStaleness = readAdvisorEmbeddingStaleness(db);\n    return {\n      skills: [\n        ...rows.map((row) => {\n          const projection = projectionFromRow(row);\n          const docTriggers = docTriggersBySkill.get(row.id);\n          return docTriggers && docTriggers.length > 0 ? { ...projection, docTriggers } : projection;\n        }),\n        ...COMMAND_BRIDGES,\n      ],\n      edges: edgeRows.map((row) => ({\n        sourceId: row.source_id,\n        targetId: row.target_id,\n        edgeType: row.edge_type,\n        weight: Math.max(0, Math.min(1, row.weight)),\n        context: row.context,\n      })),\n      generatedAt: new Date().toISOString(),\n      source: 'sqlite',\n      embeddingSignature: embeddingStaleness.stored,\n      embeddingStaleness,\n    };\n  } finally {\n    db.close();\n  }\n}\n\nfunction loadFilesystemProjection(workspaceRoot: string): AdvisorProjection {\n  const skillRoot = join(workspaceRoot, '.opencode', 'skills');\n  const skills: SkillProjection[] = [];\n  const edges: SkillEdgeProjection[] = [];\n  if (!existsSync(skillRoot)) {\n    return { skills: [...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n  }\n  for (const entry of readdirSync(skillRoot, { withFileTypes: true })) {\n    if (!entry.isDirectory()) continue;\n    const skillDir = join(skillRoot, entry.name);\n    const metadataPath = join(skillDir, 'graph-metadata.json');\n    if (!existsSync(metadataPath)) continue;\n    const metadata = readJson(metadataPath);\n    const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), entry.name);\n    const skillId = typeof metadata.skill_id === 'string' ? metadata.skill_id : entry.name;\n    const rawDerived = typeof metadata.derived === 'object' && metadata.derived !== null && !Array.isArray(metadata.derived)\n      ? metadata.derived as Record<string, unknown>\n      : {};\n    const derived = sanitizeDerivedMetadata(rawDerived, metadataPath) ?? {};\n    // Same split applied here as in projectionFromRow above —\n    // derivedTriggers (from trigger_phrases) and derivedKeywords (from\n    // key_topics + entities + key_files + source_docs) are now distinct.\n    const derivedTriggers = unique(\n      stringArray(derived.trigger_phrases).flatMap((item) => phraseVariants(item)),\n    );\n    const derivedKeywords = unique([\n      ...stringArray(derived.key_topics),\n      ...stringArray(derived.entities),\n      ...stringArray(derived.key_files),\n      ...stringArray(derived.source_docs),\n    ].flatMap((item) => phraseVariants(item)));\n    skills.push({\n      id: skillId,\n      kind: 'skill',\n      family: typeof metadata.family === 'string' ? metadata.family : 'system',\n      category: typeof metadata.category === 'string' ? metadata.category : 'skill',\n      name: skillMd.name,\n      description: skillMd.description,\n      keywords: unique(skillMd.keywords.flatMap((item) => phraseVariants(item))),\n      domains: unique(sanitizeMetadataStringArray(stringArray(metadata.domains), metadataPath).flatMap((item) => phraseVariants(item))),\n      intentSignals: unique(sanitizeMetadataStringArray(stringArray(metadata.intent_signals), metadataPath).flatMap((item) => phraseVariants(item))),\n      derivedTriggers,\n      derivedKeywords,\n      derivedDemotion: boundedDemotion(derived.demotion),\n      // generated_at leads the chain (canonical V2 author/sync time); see the\n      // SQLite branch above for why this is author-time, not runtime.\n      derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n      sourcePath: metadataPath,\n      lifecycleStatus: lifecycleStatus(metadata.lifecycle_status ?? derived.lifecycle_status, metadataPath),\n      redirectTo: typeof metadata.redirect_to === 'string' ? metadata.redirect_to : undefined,\n      redirectFrom: stringArray(metadata.redirect_from),\n    });\n  }\n  return { skills: [...skills, ...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n}\n\n// Previously a bare `catch {}` swallowed every SQLite read error\n// and silently fell back to the filesystem projection, hiding corrupt-DB and\n// schema-drift failures from operators. We now distinguish three cases:\n//   1. SQLite read succeeded → return that projection ('sqlite').\n//   2. SQLite DB does not exist yet → loadSqliteProjection returns null and we\n//      fall through to a clean 'filesystem' projection (legitimate first run).\n//   3. SQLite read THREW → we still degrade to filesystem so the daemon stays\n//      up, but the projection is tagged 'filesystem-fallback' with a\n//      fallbackReason carrying the underlying error message AND the failure\n//      is logged via console.warn so it surfaces in daemon logs.\nexport function loadAdvisorProjection(workspaceRoot: string): AdvisorProjection {\n  const resolvedRoot = resolve(workspaceRoot);\n  try {\n    const sqliteProjection = loadSqliteProjection(resolvedRoot);\n    if (sqliteProjection !== null) return sqliteProjection;\n    return loadFilesystemProjection(resolvedRoot);\n  } catch (error: unknown) {\n    const reason = error instanceof Error ? error.message : String(error);\n    console.warn(`[advisor-projection] SQLite projection failed; degraded to filesystem fallback: ${reason}`);\n    const fallback = loadFilesystemProjection(resolvedRoot);\n    return {\n      ...fallback,\n      source: 'filesystem-fallback',\n      fallbackReason: reason,\n    };\n  }\n}\n\nexport function createFixtureProjection(\n  skills: readonly SkillProjection[],\n  edges: readonly SkillEdgeProjection[] = [],\n): AdvisorProjection {\n  return {\n    skills,\n    edges,\n    generatedAt: new Date().toISOString(),\n    source: 'fixture',\n  };\n}","lineStart":600,"lineEnd":733,"totalLines":733,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","time":{"start":1783437267651,"end":1783437267660}},"metadata":{"openai":{"itemId":"fc_0318580f82639b15016a4d17d387188191af4a4f8ff3d47334"}},"id":"prt_f3d251297001WhvNIEXlT5vaDj","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9"}}
{"type":"tool_use","timestamp":1783437267721,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_3u8vPi9DHZHFTVBef9o6bFYJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Registry ↔ Advisor Routing Drift Guard\n3: // ───────────────────────────────────────────────────────────────────\n4: //\n5: import { createHash } from 'node:crypto';\n6: import { execFileSync } from 'node:child_process';\n7: import { readFileSync } from 'node:fs';\n8: import { dirname, resolve } from 'node:path';\n9: import { fileURLToPath } from 'node:url';\n10: \n11: import { describe, expect, it } from 'vitest';\n12: \n13: import { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';\n14: import {\n15:   DEEP_MODE_BY_CANONICAL,\n16:   DEEP_ROUTING_PROJECTION_HASH,\n17:   SKILL_ALIAS_GROUPS,\n18: } from '../lib/scorer/aliases.js';\n19: \n20: const here = dirname(fileURLToPath(import.meta.url));\n21: const repoRoot = findAdvisorWorkspaceRoot(here);\n22: const advisorScript = resolve(\n23:   repoRoot,\n24:   '.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py',\n25: );\n26: const registryPath = resolve(repoRoot, '.opencode/skills/deep-loop-workflows/mode-registry.json');\n27: \n28: type RoutingClass = 'lexical' | 'alias-fold' | 'metadata' | 'command-bridge';\n29: \n30: interface AdvisorRouting {\n31:   readonly routingClass: RoutingClass;\n32:   readonly legacyAdvisorId?: string;\n33:   readonly advisorDefaultMode?: boolean;\n34:   readonly legacyAliases?: readonly string[];\n35:   readonly packetSkillName: string;\n36: }\n37: interface Mode {\n38:   readonly workflowMode: string;\n39:   readonly packet: string;\n40:   readonly advisorRouting: AdvisorRouting;\n41: }\n42: interface ProjectionEntry {\n43:   readonly legacyAdvisorId: string;\n44:   readonly workflowMode: string;\n45:   readonly routingClass: 'lexical' | 'alias-fold';\n46:   readonly advisorDefaultMode: boolean;\n47:   readonly legacyAliases: readonly string[];\n48: }\n49: interface RoutingDump {\n50:   readonly DEEP_ROUTING_PROJECTION_HASH: string;\n51:   readonly DEEP_ROUTING_SKILLS: string[];\n52:   readonly DEEP_ROUTING_MODE_BY_KEY: Record<string, string>;\n53:   readonly PY_ALIAS_GROUP_KEYS: string[];\n54: }\n55: const registry = JSON.parse(readFileSync(registryPath, 'utf8')) as { modes: readonly Mode[] };\n56: \n57: function registryProjectionEntries(classes: readonly RoutingClass[]): ProjectionEntry[] {\n58:   const entries: ProjectionEntry[] = [];\n59:   for (const mode of registry.modes) {\n60:     const ar = mode.advisorRouting;\n61:     if ((ar.routingClass === 'lexical' || ar.routingClass === 'alias-fold') && classes.includes(ar.routingClass)) {\n62:       entries.push({\n63:         legacyAdvisorId: ar.legacyAdvisorId as string,\n64:         workflowMode: mode.workflowMode,\n65:         routingClass: ar.routingClass,\n66:         advisorDefaultMode: ar.advisorDefaultMode === true,\n67:         legacyAliases: [...(ar.legacyAliases ?? [])],\n68:       });\n69:     }\n70:   }\n71:   return entries.sort((left, right) => left.legacyAdvisorId.localeCompare(right.legacyAdvisorId));\n72: }\n73: \n74: function projectionHash(entries: readonly ProjectionEntry[]): string {\n75:   const canonical = JSON.stringify({\n76:     skill: 'deep-loop-workflows',\n77:     entries: entries.map((entry) => ({\n78:       legacyAdvisorId: entry.legacyAdvisorId,\n79:       workflowMode: entry.workflowMode,\n80:       routingClass: entry.routingClass,\n81:       advisorDefaultMode: entry.advisorDefaultMode,\n82:       legacyAliases: [...entry.legacyAliases],\n83:     })),\n84:   });\n85:   return `sha256:${createHash('sha256').update(canonical).digest('hex')}`;\n86: }\n87: \n88: function generatedTypeScriptProjectionEntries(): ProjectionEntry[] {\n89:   const registryById = new Map(\n90:     registryProjectionEntries(['lexical', 'alias-fold'])\n91:       .map((entry) => [entry.legacyAdvisorId, entry] as const),\n92:   );\n93:   return Object.entries(DEEP_MODE_BY_CANONICAL)\n94:     .map(([legacyAdvisorId, workflowMode]) => {\n95:       const registryEntry = registryById.get(legacyAdvisorId);\n96:       expect(registryEntry, `registry entry missing for ${legacyAdvisorId}`).toBeDefined();\n97:       return {\n98:         legacyAdvisorId,\n99:         workflowMode,\n100:         routingClass: registryEntry!.routingClass,\n101:         advisorDefaultMode: registryEntry!.advisorDefaultMode,\n102:         legacyAliases: [...(SKILL_ALIAS_GROUPS[legacyAdvisorId] ?? [])],\n103:       };\n104:     })\n105:     .sort((left, right) => left.legacyAdvisorId.localeCompare(right.legacyAdvisorId));\n106: }\n107: \n108: function generatedPythonProjectionEntries(dump: RoutingDump): ProjectionEntry[] {\n109:   const registryById = new Map(\n110:     registryProjectionEntries(['lexical'])\n111:       .map((entry) => [entry.legacyAdvisorId, entry] as const),\n112:   );\n113:   return Object.entries(dump.DEEP_ROUTING_MODE_BY_KEY)\n114:     .map(([legacyAdvisorId, workflowMode]) => {\n115:       const registryEntry = registryById.get(legacyAdvisorId);\n116:       expect(registryEntry, `registry lexical entry missing for ${legacyAdvisorId}`).toBeDefined();\n117:       return {\n118:         legacyAdvisorId,\n119:         workflowMode,\n120:         routingClass: registryEntry!.routingClass,\n121:         advisorDefaultMode: registryEntry!.advisorDefaultMode,\n122:         legacyAliases: [...registryEntry!.legacyAliases],\n123:       };\n124:     })\n125:     .sort((left, right) => left.legacyAdvisorId.localeCompare(right.legacyAdvisorId));\n126: }\n127: \n128: function dumpPythonMaps(): RoutingDump {\n129:   const stdout = execFileSync('python3', [advisorScript, '--dump-routing-maps'], {\n130:     cwd: repoRoot,\n131:     encoding: 'utf8',\n132:   });\n133:   return JSON.parse(stdout) as RoutingDump;\n134: }\n135: \n136: function checkProjectionGenerator(): { readonly status: string; readonly projectionHash: string; readonly changed: readonly string[] } {\n137:   const stdout = execFileSync('python3', [advisorScript, '--check-routing-projection'], {\n138:     cwd: repoRoot,\n139:     encoding: 'utf8',\n140:   });\n141:   return JSON.parse(stdout) as { readonly status: string; readonly projectionHash: string; readonly changed: readonly string[] };\n142: }\n143: \n144: describe('routing-registry-drift-guard', () => {\n145:   it('every mode carries an advisorRouting block with a valid routingClass + packetSkillName', () => {\n146:     const valid = new Set(['lexical', 'alias-fold', 'metadata', 'command-bridge']);\n147:     for (const mode of registry.modes) {\n148:       expect(mode.advisorRouting, `mode ${mode.workflowMode} missing advisorRouting`).toBeDefined();\n149:       expect(valid.has(mode.advisorRouting.routingClass), `mode ${mode.workflowMode} bad routingClass`).toBe(true);\n150:       expect(mode.advisorRouting.packetSkillName, `mode ${mode.workflowMode} missing packetSkillName`).toBeTruthy();\n151:       expect(mode.advisorRouting.packetSkillName, `mode ${mode.workflowMode} packetSkillName drift`).toBe(mode.packet);\n152:       // lexical + alias-fold modes must name a legacyAdvisorId (the projection-map key)\n153:       if (mode.advisorRouting.routingClass === 'lexical' || mode.advisorRouting.routingClass === 'alias-fold') {\n154:         expect(mode.advisorRouting.legacyAdvisorId, `mode ${mode.workflowMode} missing legacyAdvisorId`).toBeTruthy();\n155:       }\n156:     }\n157:   });\n158: \n159:   it('generated projection hash matches the registry projection', () => {\n160:     const registryHash = projectionHash(registryProjectionEntries(['lexical', 'alias-fold']));\n161:     const py = dumpPythonMaps();\n162: \n163:     expect(DEEP_ROUTING_PROJECTION_HASH).toBe(registryHash);\n164:     expect(py.DEEP_ROUTING_PROJECTION_HASH).toBe(registryHash);\n165:   });\n166: \n167:   it('projection generator reports fresh generated blocks', () => {\n168:     const registryHash = projectionHash(registryProjectionEntries(['lexical', 'alias-fold']));\n169:     const generator = checkProjectionGenerator();\n170: \n171:     expect(generator.status).toBe('fresh');\n172:     expect(generator.changed).toEqual([]);\n173:     expect(generator.projectionHash).toBe(registryHash);\n174:   });\n175: \n176:   it('TypeScript generated projection stays hash-fresh', () => {\n177:     const registryHash = projectionHash(registryProjectionEntries(['lexical', 'alias-fold']));\n178:     const generatedHash = projectionHash(generatedTypeScriptProjectionEntries());\n179: \n180:     expect(generatedHash).toBe(registryHash);\n181:   });\n182: \n183:   it('Python lexical projection stays hash-fresh', () => {\n184:     const py = dumpPythonMaps();\n185:     const registryHash = projectionHash(registryProjectionEntries(['lexical']));\n186:     const generatedHash = projectionHash(generatedPythonProjectionEntries(py));\n187: \n188:     expect(generatedHash).toBe(registryHash);\n189:     expect(new Set(py.DEEP_ROUTING_SKILLS)).toEqual(new Set(Object.keys(py.DEEP_ROUTING_MODE_BY_KEY)));\n190:   });\n191: \n192:   it('exactly one mode is flagged advisorDefaultMode, and it is agent-improvement', () => {\n193:     const defaults = registry.modes.filter((m) => m.advisorRouting.advisorDefaultMode === true);\n194:     expect(defaults.map((m) => m.workflowMode)).toEqual(['agent-improvement']);\n195:   });\n196: \n197:   it('legacyAdvisorId keys exist on both TS and Python alias surfaces', () => {\n198:     const pyKeys = new Set(dumpPythonMaps().PY_ALIAS_GROUP_KEYS);\n199:     for (const mode of registry.modes) {\n200:       const ar = mode.advisorRouting;\n201:       if (ar.routingClass === 'lexical' || ar.routingClass === 'alias-fold') {\n202:         const id = ar.legacyAdvisorId as string;\n203:         expect(SKILL_ALIAS_GROUPS[id], `no TS SKILL_ALIAS_GROUPS entry for ${id}`).toBeDefined();\n204:         expect(pyKeys.has(id), `legacyAdvisorId ${id} missing from Python SKILL_ALIAS_GROUPS`).toBe(true);\n205:       }\n206:     }\n207:   });\n208: });\n\n(End of file - total 208 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Registry ↔ Advisor Routing Drift Guard\n// ───────────────────────────────────────────────────────────────────\n//\nimport { createHash } from 'node:crypto';\nimport { execFileSync } from 'node:child_process';\nimport { readFileSync } from 'node:fs';\nimport { dirname, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { describe, expect, it } from 'vitest';\n\nimport { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';\nimport {\n  DEEP_MODE_BY_CANONICAL,\n  DEEP_ROUTING_PROJECTION_HASH,\n  SKILL_ALIAS_GROUPS,\n} from '../lib/scorer/aliases.js';\n\nconst here = dirname(fileURLToPath(import.meta.url));","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Registry ↔ Advisor Routing Drift Guard\n// ───────────────────────────────────────────────────────────────────\n//\nimport { createHash } from 'node:crypto';\nimport { execFileSync } from 'node:child_process';\nimport { readFileSync } from 'node:fs';\nimport { dirname, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { describe, expect, it } from 'vitest';\n\nimport { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';\nimport {\n  DEEP_MODE_BY_CANONICAL,\n  DEEP_ROUTING_PROJECTION_HASH,\n  SKILL_ALIAS_GROUPS,\n} from '../lib/scorer/aliases.js';\n\nconst here = dirname(fileURLToPath(import.meta.url));\nconst repoRoot = findAdvisorWorkspaceRoot(here);\nconst advisorScript = resolve(\n  repoRoot,\n  '.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py',\n);\nconst registryPath = resolve(repoRoot, '.opencode/skills/deep-loop-workflows/mode-registry.json');\n\ntype RoutingClass = 'lexical' | 'alias-fold' | 'metadata' | 'command-bridge';\n\ninterface AdvisorRouting {\n  readonly routingClass: RoutingClass;\n  readonly legacyAdvisorId?: string;\n  readonly advisorDefaultMode?: boolean;\n  readonly legacyAliases?: readonly string[];\n  readonly packetSkillName: string;\n}\ninterface Mode {\n  readonly workflowMode: string;\n  readonly packet: string;\n  readonly advisorRouting: AdvisorRouting;\n}\ninterface ProjectionEntry {\n  readonly legacyAdvisorId: string;\n  readonly workflowMode: string;\n  readonly routingClass: 'lexical' | 'alias-fold';\n  readonly advisorDefaultMode: boolean;\n  readonly legacyAliases: readonly string[];\n}\ninterface RoutingDump {\n  readonly DEEP_ROUTING_PROJECTION_HASH: string;\n  readonly DEEP_ROUTING_SKILLS: string[];\n  readonly DEEP_ROUTING_MODE_BY_KEY: Record<string, string>;\n  readonly PY_ALIAS_GROUP_KEYS: string[];\n}\nconst registry = JSON.parse(readFileSync(registryPath, 'utf8')) as { modes: readonly Mode[] };\n\nfunction registryProjectionEntries(classes: readonly RoutingClass[]): ProjectionEntry[] {\n  const entries: ProjectionEntry[] = [];\n  for (const mode of registry.modes) {\n    const ar = mode.advisorRouting;\n    if ((ar.routingClass === 'lexical' || ar.routingClass === 'alias-fold') && classes.includes(ar.routingClass)) {\n      entries.push({\n        legacyAdvisorId: ar.legacyAdvisorId as string,\n        workflowMode: mode.workflowMode,\n        routingClass: ar.routingClass,\n        advisorDefaultMode: ar.advisorDefaultMode === true,\n        legacyAliases: [...(ar.legacyAliases ?? [])],\n      });\n    }\n  }\n  return entries.sort((left, right) => left.legacyAdvisorId.localeCompare(right.legacyAdvisorId));\n}\n\nfunction projectionHash(entries: readonly ProjectionEntry[]): string {\n  const canonical = JSON.stringify({\n    skill: 'deep-loop-workflows',\n    entries: entries.map((entry) => ({\n      legacyAdvisorId: entry.legacyAdvisorId,\n      workflowMode: entry.workflowMode,\n      routingClass: entry.routingClass,\n      advisorDefaultMode: entry.advisorDefaultMode,\n      legacyAliases: [...entry.legacyAliases],\n    })),\n  });\n  return `sha256:${createHash('sha256').update(canonical).digest('hex')}`;\n}\n\nfunction generatedTypeScriptProjectionEntries(): ProjectionEntry[] {\n  const registryById = new Map(\n    registryProjectionEntries(['lexical', 'alias-fold'])\n      .map((entry) => [entry.legacyAdvisorId, entry] as const),\n  );\n  return Object.entries(DEEP_MODE_BY_CANONICAL)\n    .map(([legacyAdvisorId, workflowMode]) => {\n      const registryEntry = registryById.get(legacyAdvisorId);\n      expect(registryEntry, `registry entry missing for ${legacyAdvisorId}`).toBeDefined();\n      return {\n        legacyAdvisorId,\n        workflowMode,\n        routingClass: registryEntry!.routingClass,\n        advisorDefaultMode: registryEntry!.advisorDefaultMode,\n        legacyAliases: [...(SKILL_ALIAS_GROUPS[legacyAdvisorId] ?? [])],\n      };\n    })\n    .sort((left, right) => left.legacyAdvisorId.localeCompare(right.legacyAdvisorId));\n}\n\nfunction generatedPythonProjectionEntries(dump: RoutingDump): ProjectionEntry[] {\n  const registryById = new Map(\n    registryProjectionEntries(['lexical'])\n      .map((entry) => [entry.legacyAdvisorId, entry] as const),\n  );\n  return Object.entries(dump.DEEP_ROUTING_MODE_BY_KEY)\n    .map(([legacyAdvisorId, workflowMode]) => {\n      const registryEntry = registryById.get(legacyAdvisorId);\n      expect(registryEntry, `registry lexical entry missing for ${legacyAdvisorId}`).toBeDefined();\n      return {\n        legacyAdvisorId,\n        workflowMode,\n        routingClass: registryEntry!.routingClass,\n        advisorDefaultMode: registryEntry!.advisorDefaultMode,\n        legacyAliases: [...registryEntry!.legacyAliases],\n      };\n    })\n    .sort((left, right) => left.legacyAdvisorId.localeCompare(right.legacyAdvisorId));\n}\n\nfunction dumpPythonMaps(): RoutingDump {\n  const stdout = execFileSync('python3', [advisorScript, '--dump-routing-maps'], {\n    cwd: repoRoot,\n    encoding: 'utf8',\n  });\n  return JSON.parse(stdout) as RoutingDump;\n}\n\nfunction checkProjectionGenerator(): { readonly status: string; readonly projectionHash: string; readonly changed: readonly string[] } {\n  const stdout = execFileSync('python3', [advisorScript, '--check-routing-projection'], {\n    cwd: repoRoot,\n    encoding: 'utf8',\n  });\n  return JSON.parse(stdout) as { readonly status: string; readonly projectionHash: string; readonly changed: readonly string[] };\n}\n\ndescribe('routing-registry-drift-guard', () => {\n  it('every mode carries an advisorRouting block with a valid routingClass + packetSkillName', () => {\n    const valid = new Set(['lexical', 'alias-fold', 'metadata', 'command-bridge']);\n    for (const mode of registry.modes) {\n      expect(mode.advisorRouting, `mode ${mode.workflowMode} missing advisorRouting`).toBeDefined();\n      expect(valid.has(mode.advisorRouting.routingClass), `mode ${mode.workflowMode} bad routingClass`).toBe(true);\n      expect(mode.advisorRouting.packetSkillName, `mode ${mode.workflowMode} missing packetSkillName`).toBeTruthy();\n      expect(mode.advisorRouting.packetSkillName, `mode ${mode.workflowMode} packetSkillName drift`).toBe(mode.packet);\n      // lexical + alias-fold modes must name a legacyAdvisorId (the projection-map key)\n      if (mode.advisorRouting.routingClass === 'lexical' || mode.advisorRouting.routingClass === 'alias-fold') {\n        expect(mode.advisorRouting.legacyAdvisorId, `mode ${mode.workflowMode} missing legacyAdvisorId`).toBeTruthy();\n      }\n    }\n  });\n\n  it('generated projection hash matches the registry projection', () => {\n    const registryHash = projectionHash(registryProjectionEntries(['lexical', 'alias-fold']));\n    const py = dumpPythonMaps();\n\n    expect(DEEP_ROUTING_PROJECTION_HASH).toBe(registryHash);\n    expect(py.DEEP_ROUTING_PROJECTION_HASH).toBe(registryHash);\n  });\n\n  it('projection generator reports fresh generated blocks', () => {\n    const registryHash = projectionHash(registryProjectionEntries(['lexical', 'alias-fold']));\n    const generator = checkProjectionGenerator();\n\n    expect(generator.status).toBe('fresh');\n    expect(generator.changed).toEqual([]);\n    expect(generator.projectionHash).toBe(registryHash);\n  });\n\n  it('TypeScript generated projection stays hash-fresh', () => {\n    const registryHash = projectionHash(registryProjectionEntries(['lexical', 'alias-fold']));\n    const generatedHash = projectionHash(generatedTypeScriptProjectionEntries());\n\n    expect(generatedHash).toBe(registryHash);\n  });\n\n  it('Python lexical projection stays hash-fresh', () => {\n    const py = dumpPythonMaps();\n    const registryHash = projectionHash(registryProjectionEntries(['lexical']));\n    const generatedHash = projectionHash(generatedPythonProjectionEntries(py));\n\n    expect(generatedHash).toBe(registryHash);\n    expect(new Set(py.DEEP_ROUTING_SKILLS)).toEqual(new Set(Object.keys(py.DEEP_ROUTING_MODE_BY_KEY)));\n  });\n\n  it('exactly one mode is flagged advisorDefaultMode, and it is agent-improvement', () => {\n    const defaults = registry.modes.filter((m) => m.advisorRouting.advisorDefaultMode === true);\n    expect(defaults.map((m) => m.workflowMode)).toEqual(['agent-improvement']);\n  });\n\n  it('legacyAdvisorId keys exist on both TS and Python alias surfaces', () => {\n    const pyKeys = new Set(dumpPythonMaps().PY_ALIAS_GROUP_KEYS);\n    for (const mode of registry.modes) {\n      const ar = mode.advisorRouting;\n      if (ar.routingClass === 'lexical' || ar.routingClass === 'alias-fold') {\n        const id = ar.legacyAdvisorId as string;\n        expect(SKILL_ALIAS_GROUPS[id], `no TS SKILL_ALIAS_GROUPS entry for ${id}`).toBeDefined();\n        expect(pyKeys.has(id), `legacyAdvisorId ${id} missing from Python SKILL_ALIAS_GROUPS`).toBe(true);\n      }\n    }\n  });\n});","lineStart":1,"lineEnd":208,"totalLines":208,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts","time":{"start":1783437267709,"end":1783437267717}},"metadata":{"openai":{"itemId":"fc_0318580f82639b15016a4d17d387448191b38ae23a64003c1c"}},"id":"prt_f3d2512fb0014mFs6nXolsx5Jx","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9"}}
{"type":"tool_use","timestamp":1783437267721,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_avhZzpop2IymHkfEBIVGGGPO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/conflict-query-rerank.vitest.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/conflict-query-rerank.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Conflict Query Rerank Tests\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { afterEach, describe, expect, it, vi } from 'vitest';\n6: \n7: import { speckitMetrics } from '../../lib/metrics.js';\n8: import {\n9:   ADVISOR_EXACT_SEMANTIC_RERANK_FLAG,\n10:   ADVISOR_QUERY_CLASS_ROUTING_FLAG,\n11:   ADVISOR_RRF_FUSION_FLAG,\n12:   applyQueryClassLaneMultipliers,\n13:   classifyAdvisorQuery,\n14:   scoreAdvisorPrompt,\n15: } from '../../lib/scorer/fusion.js';\n16: import {\n17:   _semanticShadowTest,\n18:   clearSemanticShadowPromptEmbedding,\n19:   scoreSemanticShadowExactSubset,\n20:   scoreSemanticShadowLane,\n21:   setSemanticShadowPromptEmbedding,\n22: } from '../../lib/scorer/lanes/semantic-shadow.js';\n23: import { createFixtureProjection } from '../../lib/scorer/projection.js';\n24: import { DEFAULT_SCORER_WEIGHTS } from '../../lib/scorer/weights-config.js';\n25: import type { SkillEdgeProjection, SkillProjection } from '../../lib/scorer/types.js';\n26: \n27: function skill(overrides: Partial<SkillProjection> & Pick<SkillProjection, 'id'>): SkillProjection {\n28:   return {\n29:     id: overrides.id,\n30:     kind: 'skill',\n31:     family: 'system',\n32:     category: 'test',\n33:     name: overrides.id,\n34:     description: '',\n35:     keywords: [],\n36:     domains: [],\n37:     intentSignals: [],\n38:     derivedTriggers: [],\n39:     derivedKeywords: [],\n40:     sourcePath: `.opencode/skills/${overrides.id}/graph-metadata.json`,\n41:     lifecycleStatus: 'active',\n42:     ...Object.fromEntries(Object.entries(overrides).filter(([key]) => key !== 'id')),\n43:   };\n44: }\n45: \n46: function recommendationSnapshot(prompt: string, projection: ReturnType<typeof createFixtureProjection>): string {\n47:   const result = scoreAdvisorPrompt(prompt, {\n48:     workspaceRoot: process.cwd(),\n49:     projection,\n50:     includeAllCandidates: true,\n51:     confidenceThreshold: 0,\n52:     uncertaintyThreshold: 1,\n53:   });\n54:   return JSON.stringify(result.recommendations.map((recommendation) => ({\n55:     skill: recommendation.skill,\n56:     score: recommendation.score,\n57:     confidence: recommendation.confidence,\n58:     uncertainty: recommendation.uncertainty,\n59:     laneContributions: recommendation.laneContributions.map((contribution) => ({\n60:       lane: contribution.lane,\n61:       rawScore: contribution.rawScore,\n62:       weightedScore: contribution.weightedScore,\n63:       weight: contribution.weight,\n64:     })),\n65:   })));\n66: }\n67: \n68: function cosineText(prompt: string, text: string): number {\n69:   return _semanticShadowTest.cosineSimilarity(\n70:     _semanticShadowTest.fixtureVector(prompt),\n71:     _semanticShadowTest.fixtureVector(text),\n72:   );\n73: }\n74: \n75: function findTextForScore(\n76:   prompt: string,\n77:   predicate: (score: number) => boolean,\n78:   vectorText: (text: string) => string = (text) => text,\n79: ): string {\n80:   const tokens = Array.from({ length: 360 }, (_, index) => `reranktoken${index}`);\n81:   for (let start = 0; start <= tokens.length - 6; start++) {\n82:     const text = tokens.slice(start, start + 6).join(' ');\n83:     if (predicate(cosineText(prompt, vectorText(text)))) {\n84:       return text;\n85:     }\n86:   }\n87:   throw new Error('Could not build deterministic vector fixture');\n88: }\n89: \n90: afterEach(() => {\n91:   vi.unstubAllEnvs();\n92:   clearSemanticShadowPromptEmbedding();\n93:   speckitMetrics.reset();\n94: });\n95: \n96: describe('advisor conflict, query class, and exact rerank seams', () => {\n97:   it('counts opt-in graph conflict demotions when metrics are enabled', () => {\n98:     vi.stubEnv(ADVISOR_RRF_FUSION_FLAG, 'true');\n99:     vi.stubEnv('SPECKIT_METRICS_ENABLED', 'true');\n100:     const edges: SkillEdgeProjection[] = [\n101:       { sourceId: 'seed', targetId: 'conflicted', edgeType: 'conflicts_with', weight: 1 },\n102:     ];\n103:     const projection = createFixtureProjection([\n104:       skill({ id: 'seed', keywords: ['seed route'], intentSignals: ['seed route'] }),\n105:       skill({ id: 'conflicted', keywords: ['shared route'] }),\n106:       skill({ id: 'safe', keywords: ['shared route'] }),\n107:     ], edges);\n108: \n109:     scoreAdvisorPrompt('seed route shared route', {\n110:       workspaceRoot: process.cwd(),\n111:       projection,\n112:       includeAllCandidates: true,\n113:       confidenceThreshold: 0,\n114:       uncertaintyThreshold: 1,\n115:     });\n116: \n117:     const counterKeys = [...speckitMetrics.snapshot().counters.keys()];\n118:     expect(counterKeys.some((key) => (\n119:       key.includes('spec_kit.scorer.graph_conflict_demote_applied_total')\n120:       && key.includes('skill_id=conflicted')\n121:     ))).toBe(true);\n122:   });\n123: \n124:   it('keeps query-class routing default-off and explicit-author dominant when enabled', () => {\n125:     const projection = createFixtureProjection([\n126:       skill({ id: 'alpha', intentSignals: ['fix typescript handler'], description: 'TypeScript handler work' }),\n127:       skill({ id: 'beta', derivedTriggers: ['fix typescript handler'], description: 'Generated helper notes' }),\n128:     ]);\n129:     const prompt = 'fix typescript handler';\n130: \n131:     vi.stubEnv(ADVISOR_QUERY_CLASS_ROUTING_FLAG, undefined);\n132:     const unset = recommendationSnapshot(prompt, projection);\n133:     vi.stubEnv(ADVISOR_QUERY_CLASS_ROUTING_FLAG, 'false');\n134:     const disabled = recommendationSnapshot(prompt, projection);\n135:     expect(disabled).toBe(unset);\n136: \n137:     expect(classifyAdvisorQuery(prompt)).toBe('implementation');\n138:     const adjusted = applyQueryClassLaneMultipliers(DEFAULT_SCORER_WEIGHTS, 'implementation');\n139:     const strongestOther = Math.max(\n140:       adjusted.lexical,\n141:       adjusted.graph_causal,\n142:       adjusted.derived_generated,\n143:       adjusted.semantic_shadow,\n144:     );\n145:     expect(adjusted.explicit_author).toBeGreaterThanOrEqual(strongestOther);\n146: \n147:     vi.stubEnv(ADVISOR_QUERY_CLASS_ROUTING_FLAG, 'true');\n148:     const enabled = scoreAdvisorPrompt(prompt, {\n149:       workspaceRoot: process.cwd(),\n150:       projection,\n151:       includeAllCandidates: true,\n152:       confidenceThreshold: 0,\n153:       uncertaintyThreshold: 1,\n154:     });\n155:     const alpha = enabled.recommendations.find((recommendation) => recommendation.skill === 'alpha');\n156:     expect(alpha?.laneContributions.find((contribution) => contribution.lane === 'explicit_author')?.weight)\n157:       .toBeCloseTo(DEFAULT_SCORER_WEIGHTS.explicit_author * 1.04, 6);\n158:   });\n159: \n160:   it('bypasses the semantic cutoff only for the requested exact subset', () => {\n161:     const prompt = 'semantic cutoff pivot one two three four five';\n162:     const belowCutoffText = findTextForScore(prompt, (score) => score > 0 && score <= 0.2, (text) => `candidate ${text}`);\n163:     const projection = createFixtureProjection([\n164:       skill({ id: 'below-cutoff', name: 'candidate', description: belowCutoffText }),\n165:       skill({ id: 'outside-subset', name: 'candidate', description: belowCutoffText }),\n166:     ]);\n167: \n168:     setSemanticShadowPromptEmbedding(prompt, _semanticShadowTest.fixtureVector(prompt));\n169:     const normal = scoreSemanticShadowLane(prompt, projection);\n170:     expect(normal.some((match) => match.skillId === 'below-cutoff')).toBe(false);\n171: \n172:     const exact = scoreSemanticShadowExactSubset(prompt, projection, ['below-cutoff']);\n173:     expect(exact).toHaveLength(1);\n174:     expect(exact[0].skillId).toBe('below-cutoff');\n175:     expect(exact[0].score).toBeGreaterThan(0);\n176:     expect(exact[0].score).toBeLessThanOrEqual(0.2);\n177:   });\n178: \n179:   it('uses exact semantic scores as an opt-in deterministic top-set tiebreak', () => {\n180:     vi.stubEnv(ADVISOR_RRF_FUSION_FLAG, 'true');\n181:     const prompt = 'seed route semantic pivot one two three four five';\n182:     const betaText = findTextForScore(prompt, (score) => score > 0.18 && score <= 0.2, (text) => `candidate ${text}`);\n183:     const alphaText = findTextForScore(prompt, (score) => score === 0, (text) => `candidate ${text}`);\n184:     const edges: SkillEdgeProjection[] = [\n185:       { sourceId: 'seed', targetId: 'alpha', edgeType: 'enhances', weight: 1 },\n186:       { sourceId: 'seed', targetId: 'beta', edgeType: 'enhances', weight: 1 },\n187:     ];\n188:     const projection = createFixtureProjection([\n189:       skill({ id: 'seed', intentSignals: ['seed route'] }),\n190:       skill({ id: 'alpha', name: 'candidate', description: alphaText }),\n191:       skill({ id: 'beta', name: 'candidate', description: betaText }),\n192:     ], edges);\n193: \n194:     setSemanticShadowPromptEmbedding(prompt, _semanticShadowTest.fixtureVector(prompt));\n195:     const off = scoreAdvisorPrompt(prompt, {\n196:       workspaceRoot: process.cwd(),\n197:       projection,\n198:       includeAllCandidates: true,\n199:       confidenceThreshold: 0,\n200:       uncertaintyThreshold: 1,\n201:       disabledLanes: ['lexical', 'derived_generated'],\n202:     });\n203:     const offAlphaIndex = off.recommendations.findIndex((recommendation) => recommendation.skill === 'alpha');\n204:     const offBetaIndex = off.recommendations.findIndex((recommendation) => recommendation.skill === 'beta');\n205:     expect(offAlphaIndex).toBeLessThan(offBetaIndex);\n206: \n207:     vi.stubEnv(ADVISOR_EXACT_SEMANTIC_RERANK_FLAG, 'true');\n208:     const on = scoreAdvisorPrompt(prompt, {\n209:       workspaceRoot: process.cwd(),\n210:       projection,\n211:       includeAllCandidates: true,\n212:       confidenceThreshold: 0,\n213:       uncertaintyThreshold: 1,\n214:       disabledLanes: ['lexical', 'derived_generated'],\n215:     });\n216:     const onAlphaIndex = on.recommendations.findIndex((recommendation) => recommendation.skill === 'alpha');\n217:     const onBetaIndex = on.recommendations.findIndex((recommendation) => recommendation.skill === 'beta');\n218:     expect(onBetaIndex).toBeLessThan(onAlphaIndex);\n219:   });\n220: });\n\n(End of file - total 220 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Conflict Query Rerank Tests\n// ───────────────────────────────────────────────────────────────\n\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { speckitMetrics } from '../../lib/metrics.js';\nimport {\n  ADVISOR_EXACT_SEMANTIC_RERANK_FLAG,\n  ADVISOR_QUERY_CLASS_ROUTING_FLAG,\n  ADVISOR_RRF_FUSION_FLAG,\n  applyQueryClassLaneMultipliers,\n  classifyAdvisorQuery,\n  scoreAdvisorPrompt,\n} from '../../lib/scorer/fusion.js';\nimport {\n  _semanticShadowTest,\n  clearSemanticShadowPromptEmbedding,\n  scoreSemanticShadowExactSubset,\n  scoreSemanticShadowLane,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/conflict-query-rerank.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Conflict Query Rerank Tests\n// ───────────────────────────────────────────────────────────────\n\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { speckitMetrics } from '../../lib/metrics.js';\nimport {\n  ADVISOR_EXACT_SEMANTIC_RERANK_FLAG,\n  ADVISOR_QUERY_CLASS_ROUTING_FLAG,\n  ADVISOR_RRF_FUSION_FLAG,\n  applyQueryClassLaneMultipliers,\n  classifyAdvisorQuery,\n  scoreAdvisorPrompt,\n} from '../../lib/scorer/fusion.js';\nimport {\n  _semanticShadowTest,\n  clearSemanticShadowPromptEmbedding,\n  scoreSemanticShadowExactSubset,\n  scoreSemanticShadowLane,\n  setSemanticShadowPromptEmbedding,\n} from '../../lib/scorer/lanes/semantic-shadow.js';\nimport { createFixtureProjection } from '../../lib/scorer/projection.js';\nimport { DEFAULT_SCORER_WEIGHTS } from '../../lib/scorer/weights-config.js';\nimport type { SkillEdgeProjection, SkillProjection } from '../../lib/scorer/types.js';\n\nfunction skill(overrides: Partial<SkillProjection> & Pick<SkillProjection, 'id'>): SkillProjection {\n  return {\n    id: overrides.id,\n    kind: 'skill',\n    family: 'system',\n    category: 'test',\n    name: overrides.id,\n    description: '',\n    keywords: [],\n    domains: [],\n    intentSignals: [],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: `.opencode/skills/${overrides.id}/graph-metadata.json`,\n    lifecycleStatus: 'active',\n    ...Object.fromEntries(Object.entries(overrides).filter(([key]) => key !== 'id')),\n  };\n}\n\nfunction recommendationSnapshot(prompt: string, projection: ReturnType<typeof createFixtureProjection>): string {\n  const result = scoreAdvisorPrompt(prompt, {\n    workspaceRoot: process.cwd(),\n    projection,\n    includeAllCandidates: true,\n    confidenceThreshold: 0,\n    uncertaintyThreshold: 1,\n  });\n  return JSON.stringify(result.recommendations.map((recommendation) => ({\n    skill: recommendation.skill,\n    score: recommendation.score,\n    confidence: recommendation.confidence,\n    uncertainty: recommendation.uncertainty,\n    laneContributions: recommendation.laneContributions.map((contribution) => ({\n      lane: contribution.lane,\n      rawScore: contribution.rawScore,\n      weightedScore: contribution.weightedScore,\n      weight: contribution.weight,\n    })),\n  })));\n}\n\nfunction cosineText(prompt: string, text: string): number {\n  return _semanticShadowTest.cosineSimilarity(\n    _semanticShadowTest.fixtureVector(prompt),\n    _semanticShadowTest.fixtureVector(text),\n  );\n}\n\nfunction findTextForScore(\n  prompt: string,\n  predicate: (score: number) => boolean,\n  vectorText: (text: string) => string = (text) => text,\n): string {\n  const tokens = Array.from({ length: 360 }, (_, index) => `reranktoken${index}`);\n  for (let start = 0; start <= tokens.length - 6; start++) {\n    const text = tokens.slice(start, start + 6).join(' ');\n    if (predicate(cosineText(prompt, vectorText(text)))) {\n      return text;\n    }\n  }\n  throw new Error('Could not build deterministic vector fixture');\n}\n\nafterEach(() => {\n  vi.unstubAllEnvs();\n  clearSemanticShadowPromptEmbedding();\n  speckitMetrics.reset();\n});\n\ndescribe('advisor conflict, query class, and exact rerank seams', () => {\n  it('counts opt-in graph conflict demotions when metrics are enabled', () => {\n    vi.stubEnv(ADVISOR_RRF_FUSION_FLAG, 'true');\n    vi.stubEnv('SPECKIT_METRICS_ENABLED', 'true');\n    const edges: SkillEdgeProjection[] = [\n      { sourceId: 'seed', targetId: 'conflicted', edgeType: 'conflicts_with', weight: 1 },\n    ];\n    const projection = createFixtureProjection([\n      skill({ id: 'seed', keywords: ['seed route'], intentSignals: ['seed route'] }),\n      skill({ id: 'conflicted', keywords: ['shared route'] }),\n      skill({ id: 'safe', keywords: ['shared route'] }),\n    ], edges);\n\n    scoreAdvisorPrompt('seed route shared route', {\n      workspaceRoot: process.cwd(),\n      projection,\n      includeAllCandidates: true,\n      confidenceThreshold: 0,\n      uncertaintyThreshold: 1,\n    });\n\n    const counterKeys = [...speckitMetrics.snapshot().counters.keys()];\n    expect(counterKeys.some((key) => (\n      key.includes('spec_kit.scorer.graph_conflict_demote_applied_total')\n      && key.includes('skill_id=conflicted')\n    ))).toBe(true);\n  });\n\n  it('keeps query-class routing default-off and explicit-author dominant when enabled', () => {\n    const projection = createFixtureProjection([\n      skill({ id: 'alpha', intentSignals: ['fix typescript handler'], description: 'TypeScript handler work' }),\n      skill({ id: 'beta', derivedTriggers: ['fix typescript handler'], description: 'Generated helper notes' }),\n    ]);\n    const prompt = 'fix typescript handler';\n\n    vi.stubEnv(ADVISOR_QUERY_CLASS_ROUTING_FLAG, undefined);\n    const unset = recommendationSnapshot(prompt, projection);\n    vi.stubEnv(ADVISOR_QUERY_CLASS_ROUTING_FLAG, 'false');\n    const disabled = recommendationSnapshot(prompt, projection);\n    expect(disabled).toBe(unset);\n\n    expect(classifyAdvisorQuery(prompt)).toBe('implementation');\n    const adjusted = applyQueryClassLaneMultipliers(DEFAULT_SCORER_WEIGHTS, 'implementation');\n    const strongestOther = Math.max(\n      adjusted.lexical,\n      adjusted.graph_causal,\n      adjusted.derived_generated,\n      adjusted.semantic_shadow,\n    );\n    expect(adjusted.explicit_author).toBeGreaterThanOrEqual(strongestOther);\n\n    vi.stubEnv(ADVISOR_QUERY_CLASS_ROUTING_FLAG, 'true');\n    const enabled = scoreAdvisorPrompt(prompt, {\n      workspaceRoot: process.cwd(),\n      projection,\n      includeAllCandidates: true,\n      confidenceThreshold: 0,\n      uncertaintyThreshold: 1,\n    });\n    const alpha = enabled.recommendations.find((recommendation) => recommendation.skill === 'alpha');\n    expect(alpha?.laneContributions.find((contribution) => contribution.lane === 'explicit_author')?.weight)\n      .toBeCloseTo(DEFAULT_SCORER_WEIGHTS.explicit_author * 1.04, 6);\n  });\n\n  it('bypasses the semantic cutoff only for the requested exact subset', () => {\n    const prompt = 'semantic cutoff pivot one two three four five';\n    const belowCutoffText = findTextForScore(prompt, (score) => score > 0 && score <= 0.2, (text) => `candidate ${text}`);\n    const projection = createFixtureProjection([\n      skill({ id: 'below-cutoff', name: 'candidate', description: belowCutoffText }),\n      skill({ id: 'outside-subset', name: 'candidate', description: belowCutoffText }),\n    ]);\n\n    setSemanticShadowPromptEmbedding(prompt, _semanticShadowTest.fixtureVector(prompt));\n    const normal = scoreSemanticShadowLane(prompt, projection);\n    expect(normal.some((match) => match.skillId === 'below-cutoff')).toBe(false);\n\n    const exact = scoreSemanticShadowExactSubset(prompt, projection, ['below-cutoff']);\n    expect(exact).toHaveLength(1);\n    expect(exact[0].skillId).toBe('below-cutoff');\n    expect(exact[0].score).toBeGreaterThan(0);\n    expect(exact[0].score).toBeLessThanOrEqual(0.2);\n  });\n\n  it('uses exact semantic scores as an opt-in deterministic top-set tiebreak', () => {\n    vi.stubEnv(ADVISOR_RRF_FUSION_FLAG, 'true');\n    const prompt = 'seed route semantic pivot one two three four five';\n    const betaText = findTextForScore(prompt, (score) => score > 0.18 && score <= 0.2, (text) => `candidate ${text}`);\n    const alphaText = findTextForScore(prompt, (score) => score === 0, (text) => `candidate ${text}`);\n    const edges: SkillEdgeProjection[] = [\n      { sourceId: 'seed', targetId: 'alpha', edgeType: 'enhances', weight: 1 },\n      { sourceId: 'seed', targetId: 'beta', edgeType: 'enhances', weight: 1 },\n    ];\n    const projection = createFixtureProjection([\n      skill({ id: 'seed', intentSignals: ['seed route'] }),\n      skill({ id: 'alpha', name: 'candidate', description: alphaText }),\n      skill({ id: 'beta', name: 'candidate', description: betaText }),\n    ], edges);\n\n    setSemanticShadowPromptEmbedding(prompt, _semanticShadowTest.fixtureVector(prompt));\n    const off = scoreAdvisorPrompt(prompt, {\n      workspaceRoot: process.cwd(),\n      projection,\n      includeAllCandidates: true,\n      confidenceThreshold: 0,\n      uncertaintyThreshold: 1,\n      disabledLanes: ['lexical', 'derived_generated'],\n    });\n    const offAlphaIndex = off.recommendations.findIndex((recommendation) => recommendation.skill === 'alpha');\n    const offBetaIndex = off.recommendations.findIndex((recommendation) => recommendation.skill === 'beta');\n    expect(offAlphaIndex).toBeLessThan(offBetaIndex);\n\n    vi.stubEnv(ADVISOR_EXACT_SEMANTIC_RERANK_FLAG, 'true');\n    const on = scoreAdvisorPrompt(prompt, {\n      workspaceRoot: process.cwd(),\n      projection,\n      includeAllCandidates: true,\n      confidenceThreshold: 0,\n      uncertaintyThreshold: 1,\n      disabledLanes: ['lexical', 'derived_generated'],\n    });\n    const onAlphaIndex = on.recommendations.findIndex((recommendation) => recommendation.skill === 'alpha');\n    const onBetaIndex = on.recommendations.findIndex((recommendation) => recommendation.skill === 'beta');\n    expect(onBetaIndex).toBeLessThan(onAlphaIndex);\n  });\n});","lineStart":1,"lineEnd":220,"totalLines":220,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/conflict-query-rerank.vitest.ts","time":{"start":1783437267706,"end":1783437267719}},"metadata":{"openai":{"itemId":"fc_0318580f82639b15016a4d17d3873c8191957983eb88f8ba41"}},"id":"prt_f3d2512f8001tBP57zH0rTDi9i","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9"}}
{"type":"tool_use","timestamp":1783437267734,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_cFq2lxZqUkUj5pMfd0b6oMCE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","offset":260,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts</path>\n<type>file</type>\n<content>\n260:   options: ExplicitLaneOptions = {},\n261: ): LaneMatch[] {\n262:   const lower = prompt.toLowerCase();\n263:   const tokens = tokenize(prompt, true);\n264:   const scores = new Map<string, ExplicitScoreEntry>();\n265: \n266:   for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {\n267:     if (!lower.includes(phrase)) continue;\n268:     for (const [skillId, amount] of boosts) {\n269:       push(scores, skillId, amount, `phrase:${phrase}`);\n270:     }\n271:   }\n272: \n273:   for (const token of tokens) {\n274:     for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {\n275:       push(scores, skillId, amount, `token:${token}`);\n276:     }\n277:   }\n278: \n279:   if (WRITE_VERBS.test(lower) && /\\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\\b/.test(lower)) {\n280:     push(scores, 'sk-doc', 0.7, 'write-doc-surface');\n281:   }\n282:   if (WRITE_VERBS.test(lower) && /\\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\\.py|mcp\\.json|commonjs)\\b/.test(lower)) {\n283:     push(scores, 'sk-code', 0.7, 'write-system-code-surface');\n284:   }\n285:   if (WRITE_VERBS.test(lower) && /\\b(error classes|trigger gap|reporter|mismatches?|bucket|gate 3)\\b/.test(lower)) {\n286:     push(scores, 'sk-code', 0.6, 'write-routing-tool-surface');\n287:   }\n288:   if (MEMORY_PRESERVATION_SESSION_INTENT.test(lower)) {\n289:     push(scores, 'memory:save', 1.2, 'memory-preservation-session-intent');\n290:     push(scores, 'command-memory-save', 0.8, 'memory-preservation-session-intent');\n291:     push(scores, 'system-spec-kit', 0.3, 'memory-preservation-session-intent');\n292:   }\n293:   if (lower.includes('/speckit:resume')) {\n294:     push(scores, 'system-spec-kit', 0.4, 'speckit-resume-skill-disambiguation');\n295:     push(scores, 'command-spec-kit', -1.0, 'speckit-resume-skill-disambiguation');\n296:   }\n297:   // Review-plus-write intent. When the prompt contains the word `review`\n298:   // AND an explicit write/edit verb (`update|edit|fix|modify`), the request\n299:   // is implementation work; anchor the explicit lane firmly on `sk-code` so\n300:   // the code hub wins the skill selection (its router then selects the\n301:   // implement mode rather than the code-review mode). The lane's emit clamps\n302:   // with `Math.min(value.score, 1)`, so the wide magnitude only guarantees\n303:   // the anchor; it cannot overshoot.\n304:   if (/\\breview\\b/.test(lower) && /\\b(update|edit|fix|modify)\\b/.test(lower)) {\n305:     push(scores, 'sk-code', 3.0, 'review-plus-write-disambiguation');\n306:   }\n307:   if (/\\b(continue|resume|launch|kick off|overnight|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\bresearch\\b/.test(lower)) {\n308:     push(scores, 'deep-loop-workflows', 0.85, 'research-loop');\n309:   }\n310:   if (/\\b(continue|resume|launch|start|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\breview\\b/.test(lower)) {\n311:     push(scores, 'deep-loop-workflows', 0.85, 'review-loop');\n312:     if (/\\b(audit|spec folder|packet|convergence)\\b/.test(lower)) {\n313:       push(scores, 'sk-code', -0.6, 'iterative-review-vs-pr-disambiguation');\n314:     }\n315:   }\n316:   if (/\\b(figure out|find|diagnose|debug)\\b.{0,40}\\b(wrong|broken|failing|bug|issue)\\b.{0,40}\\bcode\\b|\\b(wrong|broken|failing)\\b.{0,30}\\bcode\\b/.test(lower)) {\n317:     push(scores, 'sk-code', 0.9, 'ambiguous-code-problem');\n318:     push(scores, 'deep-loop-workflows', 0.45, 'ambiguous-code-problem');\n319:   }\n320: \n321:   for (const skill of projection.skills) {\n322:     for (const variant of skillNameVariants(skill.id)) {\n323:       if (matchesPhraseBoundary(lower, variant)) {\n324:         push(scores, skill.id, 1, `explicit:${variant}`);\n325:       }\n326:     }\n327:     for (const phrase of [...skill.intentSignals, ...skill.keywords]) {\n328:       if (matchesPhraseBoundary(lower, phrase)) {\n329:         push(\n330:           scores,\n331:           skill.id,\n332:           phraseSpecificity(phrase),\n333:           `author:${phrase}`,\n334:           options.includeProducerIdentity ? skill.id : undefined,\n335:         );\n336:       }\n337:     }\n338:   }\n339: \n340:   return [...scores.entries()].map(([skillId, value]) => {\n341:     const producerSkillIds = [...value.producerSkillIds].sort();\n342:     return {\n343:       skillId,\n344:       lane: 'explicit_author' as const,\n345:       score: Math.min(value.score, 1),\n346:       evidence: value.evidence.slice(0, 6),\n347:       ...(producerSkillIds.length > 0 ? { producerSkillIds } : {}),\n348:     };\n349:   });\n350: }\n\n(End of file - total 350 lines)\n</content>","metadata":{"preview":"  options: ExplicitLaneOptions = {},\n): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = tokenize(prompt, true);\n  const scores = new Map<string, ExplicitScoreEntry>();\n\n  for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {\n    if (!lower.includes(phrase)) continue;\n    for (const [skillId, amount] of boosts) {\n      push(scores, skillId, amount, `phrase:${phrase}`);\n    }\n  }\n\n  for (const token of tokens) {\n    for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {\n      push(scores, skillId, amount, `token:${token}`);\n    }\n  }\n\n  if (WRITE_VERBS.test(lower) && /\\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\\b/.test(lower)) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","text":"  options: ExplicitLaneOptions = {},\n): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = tokenize(prompt, true);\n  const scores = new Map<string, ExplicitScoreEntry>();\n\n  for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {\n    if (!lower.includes(phrase)) continue;\n    for (const [skillId, amount] of boosts) {\n      push(scores, skillId, amount, `phrase:${phrase}`);\n    }\n  }\n\n  for (const token of tokens) {\n    for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {\n      push(scores, skillId, amount, `token:${token}`);\n    }\n  }\n\n  if (WRITE_VERBS.test(lower) && /\\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\\b/.test(lower)) {\n    push(scores, 'sk-doc', 0.7, 'write-doc-surface');\n  }\n  if (WRITE_VERBS.test(lower) && /\\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\\.py|mcp\\.json|commonjs)\\b/.test(lower)) {\n    push(scores, 'sk-code', 0.7, 'write-system-code-surface');\n  }\n  if (WRITE_VERBS.test(lower) && /\\b(error classes|trigger gap|reporter|mismatches?|bucket|gate 3)\\b/.test(lower)) {\n    push(scores, 'sk-code', 0.6, 'write-routing-tool-surface');\n  }\n  if (MEMORY_PRESERVATION_SESSION_INTENT.test(lower)) {\n    push(scores, 'memory:save', 1.2, 'memory-preservation-session-intent');\n    push(scores, 'command-memory-save', 0.8, 'memory-preservation-session-intent');\n    push(scores, 'system-spec-kit', 0.3, 'memory-preservation-session-intent');\n  }\n  if (lower.includes('/speckit:resume')) {\n    push(scores, 'system-spec-kit', 0.4, 'speckit-resume-skill-disambiguation');\n    push(scores, 'command-spec-kit', -1.0, 'speckit-resume-skill-disambiguation');\n  }\n  // Review-plus-write intent. When the prompt contains the word `review`\n  // AND an explicit write/edit verb (`update|edit|fix|modify`), the request\n  // is implementation work; anchor the explicit lane firmly on `sk-code` so\n  // the code hub wins the skill selection (its router then selects the\n  // implement mode rather than the code-review mode). The lane's emit clamps\n  // with `Math.min(value.score, 1)`, so the wide magnitude only guarantees\n  // the anchor; it cannot overshoot.\n  if (/\\breview\\b/.test(lower) && /\\b(update|edit|fix|modify)\\b/.test(lower)) {\n    push(scores, 'sk-code', 3.0, 'review-plus-write-disambiguation');\n  }\n  if (/\\b(continue|resume|launch|kick off|overnight|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\bresearch\\b/.test(lower)) {\n    push(scores, 'deep-loop-workflows', 0.85, 'research-loop');\n  }\n  if (/\\b(continue|resume|launch|start|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\breview\\b/.test(lower)) {\n    push(scores, 'deep-loop-workflows', 0.85, 'review-loop');\n    if (/\\b(audit|spec folder|packet|convergence)\\b/.test(lower)) {\n      push(scores, 'sk-code', -0.6, 'iterative-review-vs-pr-disambiguation');\n    }\n  }\n  if (/\\b(figure out|find|diagnose|debug)\\b.{0,40}\\b(wrong|broken|failing|bug|issue)\\b.{0,40}\\bcode\\b|\\b(wrong|broken|failing)\\b.{0,30}\\bcode\\b/.test(lower)) {\n    push(scores, 'sk-code', 0.9, 'ambiguous-code-problem');\n    push(scores, 'deep-loop-workflows', 0.45, 'ambiguous-code-problem');\n  }\n\n  for (const skill of projection.skills) {\n    for (const variant of skillNameVariants(skill.id)) {\n      if (matchesPhraseBoundary(lower, variant)) {\n        push(scores, skill.id, 1, `explicit:${variant}`);\n      }\n    }\n    for (const phrase of [...skill.intentSignals, ...skill.keywords]) {\n      if (matchesPhraseBoundary(lower, phrase)) {\n        push(\n          scores,\n          skill.id,\n          phraseSpecificity(phrase),\n          `author:${phrase}`,\n          options.includeProducerIdentity ? skill.id : undefined,\n        );\n      }\n    }\n  }\n\n  return [...scores.entries()].map(([skillId, value]) => {\n    const producerSkillIds = [...value.producerSkillIds].sort();\n    return {\n      skillId,\n      lane: 'explicit_author' as const,\n      score: Math.min(value.score, 1),\n      evidence: value.evidence.slice(0, 6),\n      ...(producerSkillIds.length > 0 ? { producerSkillIds } : {}),\n    };\n  });\n}","lineStart":260,"lineEnd":350,"totalLines":350,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","time":{"start":1783437267695,"end":1783437267728}},"metadata":{"openai":{"itemId":"fc_0318580f82639b15016a4d17d387288191828b93ef0922a382"}},"id":"prt_f3d2512c6001CV1bTFEd8qa0ej","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9"}}
{"type":"tool_use","timestamp":1783437267735,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_sLDQWzWGihf5TBXyLZsu2ifL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts","offset":1,"limit":190},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Graph Causal Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { NormalizedAffordance } from '../../affordance-normalizer.js';\n6: import type { AdvisorProjection, LaneMatch } from '../types.js';\n7: \n8: export interface GraphCausalOptions {\n9:   readonly maxDepth?: number;\n10:   readonly maxBreadth?: number;\n11: }\n12: \n13: export interface GraphCausalLaneSplit {\n14:   readonly combinedMatches: LaneMatch[];\n15:   readonly positiveMatches: LaneMatch[];\n16:   readonly conflictMatches: LaneMatch[];\n17: }\n18: \n19: interface GraphCausalScoreEntry {\n20:   readonly combinedScore: number;\n21:   readonly positiveScore: number;\n22:   readonly conflictScore: number;\n23:   readonly evidence: readonly string[];\n24:   readonly positiveEvidence: readonly string[];\n25:   readonly conflictEvidence: readonly string[];\n26: }\n27: \n28: const EDGE_MULTIPLIER: Readonly<Record<string, number>> = {\n29:   enhances: 0.55,\n30:   siblings: 0.35,\n31:   depends_on: 0.35,\n32:   prerequisite_for: 0.30,\n33:   conflicts_with: -0.35,\n34: };\n35: \n36: function buildGraphCausalScores(\n37:   seedMatches: readonly LaneMatch[],\n38:   projection: AdvisorProjection,\n39:   options: GraphCausalOptions = {},\n40:   affordances: readonly NormalizedAffordance[] = [],\n41: ): Map<string, GraphCausalScoreEntry> {\n42:   const maxDepth = options.maxDepth ?? 2;\n43:   const maxBreadth = options.maxBreadth ?? 4;\n44:   const adjacency = new Map<string, typeof projection.edges>();\n45:   for (const edge of projection.edges) {\n46:     const current = adjacency.get(edge.sourceId) ?? [];\n47:     adjacency.set(edge.sourceId, [...current, edge]);\n48:   }\n49:   for (const affordance of affordances) {\n50:     const current = adjacency.get(affordance.skillId) ?? [];\n51:     adjacency.set(affordance.skillId, [\n52:       ...current,\n53:       ...affordance.edges.map((edge) => ({\n54:         sourceId: affordance.skillId,\n55:         targetId: edge.targetSkillId,\n56:         edgeType: edge.edgeType,\n57:         weight: edge.weight,\n58:         context: affordance.evidenceLabel,\n59:       })),\n60:     ]);\n61:   }\n62: \n63:   const seedScores = new Map<string, number>();\n64:   for (const match of seedMatches) {\n65:     if (match.lane === 'semantic_shadow') continue;\n66:     seedScores.set(match.skillId, Math.max(seedScores.get(match.skillId) ?? 0, match.score));\n67:   }\n68: \n69:   const scores = new Map<string, {\n70:     combinedScore: number;\n71:     positiveScore: number;\n72:     conflictScore: number;\n73:     evidence: string[];\n74:     positiveEvidence: string[];\n75:     conflictEvidence: string[];\n76:   }>();\n77:   for (const [seedId, seedScore] of seedScores) {\n78:     // Best positive strength discovered per target; also the visited/expansion ledger.\n79:     // Seeded with the origin so a back-edge to the seed can never re-expand it.\n80:     const bestPositiveStrengthByTarget = new Map<string, number>([[seedId, seedScore]]);\n81:     const queue: Array<{ id: string; depth: number }> = [{ id: seedId, depth: 0 }];\n82:     while (queue.length > 0) {\n83:       // queue.length was checked immediately before shifting the next item.\n84:       const current = queue.shift()!;\n85:       if (current.depth >= maxDepth) continue;\n86:       const currentStrength = bestPositiveStrengthByTarget.get(current.id) ?? 0;\n87:       if (currentStrength <= 0) continue;\n88:       const outgoing = [...(adjacency.get(current.id) ?? [])]\n89:         .sort((left, right) => right.weight - left.weight)\n90:         .slice(0, maxBreadth);\n91:       for (const edge of outgoing) {\n92:         const multiplier = EDGE_MULTIPLIER[edge.edgeType];\n93:         if (multiplier === undefined) continue;\n94:         const propagated = currentStrength * edge.weight * Math.abs(multiplier) * (1 / (current.depth + 1));\n95:         if (propagated < 0.05) continue;\n96:         const signed = multiplier < 0 ? -propagated : propagated;\n97:         // Score every qualifying edge before deciding expansion, so a weaker or earlier\n98:         // edge can no longer suppress a stronger later edge to the same target.\n99:         const entry = scores.get(edge.targetId) ?? {\n100:           combinedScore: 0,\n101:           positiveScore: 0,\n102:           conflictScore: 0,\n103:           evidence: [],\n104:           positiveEvidence: [],\n105:           conflictEvidence: [],\n106:         };\n107:         const evidence = `edge:${current.id}->${edge.targetId}:${edge.edgeType}`;\n108:         entry.combinedScore += signed;\n109:         entry.evidence.push(evidence);\n110:         if (signed > 0) {\n111:           entry.positiveScore += signed;\n112:           entry.positiveEvidence.push(evidence);\n113:         } else {\n114:           entry.conflictScore += signed;\n115:           entry.conflictEvidence.push(evidence);\n116:         }\n117:         scores.set(edge.targetId, entry);\n118:         // Expand a target once, on its first positive reach, tracking its best positive\n119:         // strength for onward propagation. Negative edges score but never expand, so no\n120:         // positive graph-causal support propagates through a negative edge.\n121:         if (signed > 0) {\n122:           const prevBest = bestPositiveStrengthByTarget.get(edge.targetId);\n123:           if (prevBest === undefined) {\n124:             bestPositiveStrengthByTarget.set(edge.targetId, signed);\n125:             queue.push({ id: edge.targetId, depth: current.depth + 1 });\n126:           } else if (signed > prevBest) {\n127:             bestPositiveStrengthByTarget.set(edge.targetId, signed);\n128:           }\n129:         }\n130:       }\n131:     }\n132:   }\n133: \n134:   return scores;\n135: }\n136: \n137: function toLaneMatches(\n138:   scores: Map<string, GraphCausalScoreEntry>,\n139:   scoreKey: 'combinedScore' | 'positiveScore' | 'conflictScore',\n140:   evidenceKey: 'evidence' | 'positiveEvidence' | 'conflictEvidence',\n141: ): LaneMatch[] {\n142:   return [...scores.entries()]\n143:     .filter(([, value]) => value[scoreKey] !== 0)\n144:     .map(([skillId, value]) => ({\n145:       skillId,\n146:       lane: 'graph_causal' as const,\n147:       score: Math.max(-1, Math.min(value[scoreKey], 1)),\n148:       evidence: value[evidenceKey].slice(0, 6),\n149:     }));\n150: }\n151: \n152: export function scoreGraphCausalLaneSplit(\n153:   seedMatches: readonly LaneMatch[],\n154:   projection: AdvisorProjection,\n155:   options: GraphCausalOptions = {},\n156:   affordances: readonly NormalizedAffordance[] = [],\n157: ): GraphCausalLaneSplit {\n158:   const scores = buildGraphCausalScores(seedMatches, projection, options, affordances);\n159:   return {\n160:     combinedMatches: toLaneMatches(scores, 'combinedScore', 'evidence'),\n161:     positiveMatches: toLaneMatches(scores, 'positiveScore', 'positiveEvidence'),\n162:     conflictMatches: toLaneMatches(scores, 'conflictScore', 'conflictEvidence'),\n163:   };\n164: }\n165: \n166: export function scoreGraphCausalLane(\n167:   seedMatches: readonly LaneMatch[],\n168:   projection: AdvisorProjection,\n169:   options: GraphCausalOptions = {},\n170:   affordances: readonly NormalizedAffordance[] = [],\n171: ): LaneMatch[] {\n172:   return scoreGraphCausalLaneSplit(seedMatches, projection, options, affordances).combinedMatches;\n173: }\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Graph Causal Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nexport interface GraphCausalOptions {\n  readonly maxDepth?: number;\n  readonly maxBreadth?: number;\n}\n\nexport interface GraphCausalLaneSplit {\n  readonly combinedMatches: LaneMatch[];\n  readonly positiveMatches: LaneMatch[];\n  readonly conflictMatches: LaneMatch[];\n}\n\ninterface GraphCausalScoreEntry {\n  readonly combinedScore: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Graph Causal Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nexport interface GraphCausalOptions {\n  readonly maxDepth?: number;\n  readonly maxBreadth?: number;\n}\n\nexport interface GraphCausalLaneSplit {\n  readonly combinedMatches: LaneMatch[];\n  readonly positiveMatches: LaneMatch[];\n  readonly conflictMatches: LaneMatch[];\n}\n\ninterface GraphCausalScoreEntry {\n  readonly combinedScore: number;\n  readonly positiveScore: number;\n  readonly conflictScore: number;\n  readonly evidence: readonly string[];\n  readonly positiveEvidence: readonly string[];\n  readonly conflictEvidence: readonly string[];\n}\n\nconst EDGE_MULTIPLIER: Readonly<Record<string, number>> = {\n  enhances: 0.55,\n  siblings: 0.35,\n  depends_on: 0.35,\n  prerequisite_for: 0.30,\n  conflicts_with: -0.35,\n};\n\nfunction buildGraphCausalScores(\n  seedMatches: readonly LaneMatch[],\n  projection: AdvisorProjection,\n  options: GraphCausalOptions = {},\n  affordances: readonly NormalizedAffordance[] = [],\n): Map<string, GraphCausalScoreEntry> {\n  const maxDepth = options.maxDepth ?? 2;\n  const maxBreadth = options.maxBreadth ?? 4;\n  const adjacency = new Map<string, typeof projection.edges>();\n  for (const edge of projection.edges) {\n    const current = adjacency.get(edge.sourceId) ?? [];\n    adjacency.set(edge.sourceId, [...current, edge]);\n  }\n  for (const affordance of affordances) {\n    const current = adjacency.get(affordance.skillId) ?? [];\n    adjacency.set(affordance.skillId, [\n      ...current,\n      ...affordance.edges.map((edge) => ({\n        sourceId: affordance.skillId,\n        targetId: edge.targetSkillId,\n        edgeType: edge.edgeType,\n        weight: edge.weight,\n        context: affordance.evidenceLabel,\n      })),\n    ]);\n  }\n\n  const seedScores = new Map<string, number>();\n  for (const match of seedMatches) {\n    if (match.lane === 'semantic_shadow') continue;\n    seedScores.set(match.skillId, Math.max(seedScores.get(match.skillId) ?? 0, match.score));\n  }\n\n  const scores = new Map<string, {\n    combinedScore: number;\n    positiveScore: number;\n    conflictScore: number;\n    evidence: string[];\n    positiveEvidence: string[];\n    conflictEvidence: string[];\n  }>();\n  for (const [seedId, seedScore] of seedScores) {\n    // Best positive strength discovered per target; also the visited/expansion ledger.\n    // Seeded with the origin so a back-edge to the seed can never re-expand it.\n    const bestPositiveStrengthByTarget = new Map<string, number>([[seedId, seedScore]]);\n    const queue: Array<{ id: string; depth: number }> = [{ id: seedId, depth: 0 }];\n    while (queue.length > 0) {\n      // queue.length was checked immediately before shifting the next item.\n      const current = queue.shift()!;\n      if (current.depth >= maxDepth) continue;\n      const currentStrength = bestPositiveStrengthByTarget.get(current.id) ?? 0;\n      if (currentStrength <= 0) continue;\n      const outgoing = [...(adjacency.get(current.id) ?? [])]\n        .sort((left, right) => right.weight - left.weight)\n        .slice(0, maxBreadth);\n      for (const edge of outgoing) {\n        const multiplier = EDGE_MULTIPLIER[edge.edgeType];\n        if (multiplier === undefined) continue;\n        const propagated = currentStrength * edge.weight * Math.abs(multiplier) * (1 / (current.depth + 1));\n        if (propagated < 0.05) continue;\n        const signed = multiplier < 0 ? -propagated : propagated;\n        // Score every qualifying edge before deciding expansion, so a weaker or earlier\n        // edge can no longer suppress a stronger later edge to the same target.\n        const entry = scores.get(edge.targetId) ?? {\n          combinedScore: 0,\n          positiveScore: 0,\n          conflictScore: 0,\n          evidence: [],\n          positiveEvidence: [],\n          conflictEvidence: [],\n        };\n        const evidence = `edge:${current.id}->${edge.targetId}:${edge.edgeType}`;\n        entry.combinedScore += signed;\n        entry.evidence.push(evidence);\n        if (signed > 0) {\n          entry.positiveScore += signed;\n          entry.positiveEvidence.push(evidence);\n        } else {\n          entry.conflictScore += signed;\n          entry.conflictEvidence.push(evidence);\n        }\n        scores.set(edge.targetId, entry);\n        // Expand a target once, on its first positive reach, tracking its best positive\n        // strength for onward propagation. Negative edges score but never expand, so no\n        // positive graph-causal support propagates through a negative edge.\n        if (signed > 0) {\n          const prevBest = bestPositiveStrengthByTarget.get(edge.targetId);\n          if (prevBest === undefined) {\n            bestPositiveStrengthByTarget.set(edge.targetId, signed);\n            queue.push({ id: edge.targetId, depth: current.depth + 1 });\n          } else if (signed > prevBest) {\n            bestPositiveStrengthByTarget.set(edge.targetId, signed);\n          }\n        }\n      }\n    }\n  }\n\n  return scores;\n}\n\nfunction toLaneMatches(\n  scores: Map<string, GraphCausalScoreEntry>,\n  scoreKey: 'combinedScore' | 'positiveScore' | 'conflictScore',\n  evidenceKey: 'evidence' | 'positiveEvidence' | 'conflictEvidence',\n): LaneMatch[] {\n  return [...scores.entries()]\n    .filter(([, value]) => value[scoreKey] !== 0)\n    .map(([skillId, value]) => ({\n      skillId,\n      lane: 'graph_causal' as const,\n      score: Math.max(-1, Math.min(value[scoreKey], 1)),\n      evidence: value[evidenceKey].slice(0, 6),\n    }));\n}\n\nexport function scoreGraphCausalLaneSplit(\n  seedMatches: readonly LaneMatch[],\n  projection: AdvisorProjection,\n  options: GraphCausalOptions = {},\n  affordances: readonly NormalizedAffordance[] = [],\n): GraphCausalLaneSplit {\n  const scores = buildGraphCausalScores(seedMatches, projection, options, affordances);\n  return {\n    combinedMatches: toLaneMatches(scores, 'combinedScore', 'evidence'),\n    positiveMatches: toLaneMatches(scores, 'positiveScore', 'positiveEvidence'),\n    conflictMatches: toLaneMatches(scores, 'conflictScore', 'conflictEvidence'),\n  };\n}\n\nexport function scoreGraphCausalLane(\n  seedMatches: readonly LaneMatch[],\n  projection: AdvisorProjection,\n  options: GraphCausalOptions = {},\n  affordances: readonly NormalizedAffordance[] = [],\n): LaneMatch[] {\n  return scoreGraphCausalLaneSplit(seedMatches, projection, options, affordances).combinedMatches;\n}","lineStart":1,"lineEnd":173,"totalLines":173,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts","time":{"start":1783437267703,"end":1783437267730}},"metadata":{"openai":{"itemId":"fc_0318580f82639b15016a4d17d387348191afde2aec5fcc00a3"}},"id":"prt_f3d2512f5001hh6n2ubyn7WOIR","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24e2dd001fFa7Ar4odxWNO9"}}
{"type":"tool_use","timestamp":1783437267735,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_1A0jIMmhueKTRVCFt0X6n8Q1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":760,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n760:     }\n761:   }\n762:   const exactSemanticRerankIndex = useExactSemanticRerank\n763:     ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n764:     : new Map<string, ExactSemanticRerankEntry>();\n765:   let ranked = recommendations.sort((left, right) => {\n766:     const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n767:     const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n768:     const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n769:     const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n770:     const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n771:     const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n772:     const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n773:       - (left.score + leftCommandBonus + leftIntent + leftConflict);\n774:     if (useRrfFusion) {\n775:       const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n776:       const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n777:       if (leftExactSemantic !== null\n778:         && rightExactSemantic !== null\n779:         && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {\n780:         const exactSemanticDiff = rightExactSemantic - leftExactSemantic;\n781:         if (exactSemanticDiff !== 0) {\n782:           return exactSemanticDiff;\n783:         }\n784:       }\n785:       return adjustedScoreDiff\n786:         || rrfRankFor(rrfFusion, left) - rrfRankFor(rrfFusion, right)\n787:         || left.skill.localeCompare(right.skill);\n788:     }\n789:     return adjustedScoreDiff\n790:       || right.confidence - left.confidence\n791:       || left.skill.localeCompare(right.skill);\n792:   });\n793: \n794:   ranked = ranked.map((recommendation, index) => {\n795:     const next = ranked[index + 1];\n796:     const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n797:     const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n798:     return {\n799:       ...recommendation,\n800:       uncertainty,\n801:       passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n802:         && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n803:     };\n804:   });\n805:   ranked = applyAmbiguity(ranked);\n806: \n807:   // Low-information ambiguity abstention: a short, intent-less prompt that lands\n808:   // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n809:   // every cluster member's uncertainty above the strict threshold so strict\n810:   // callers abstain, while confidence-only callers still surface the best guess\n811:   // (the disambiguated top-ranked candidate).\n812:   const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n813:   const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n814:   if (lowInfoPrompt) {\n815:     const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n816:     // Only abstain when the cluster's lead is built from diffuse, shared\n817:     // single-word keyword matches rather than a distinctive multi-word phrase\n818:     // anchor (an explicit-author/derived phrase match such as \"code audit\").\n819:     // A multi-word anchor means the prompt does pin a specific skill, so it\n820:     // should route instead of abstaining.\n821:     const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (\n822:       recommendation.laneContributions.some((contribution) => (\n823:         (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')\n824:         && contribution.evidence.some((entry) => entry.includes(' '))\n825:       ))\n826:     ));\n827:     if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {\n828:       const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n829:       const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n830:       const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n831:       ranked = ranked.map((recommendation) => {\n832:         if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;\n833:         const uncertainty = Math.max(recommendation.uncertainty, floor);\n834:         return {\n835:           ...recommendation,\n836:           uncertainty,\n837:           passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n838:         };\n839:       });\n840:     }\n841:   }\n842: \n843:   // Class C: breadth / multi-concern abstention. A broad greenfield build\n844:   // (\"build full stack typescript service\") or a multi-concern optimization\n845:   // (\"optimize X execution speed and recommendation quality\") is under-specified\n846:   // for single-skill routing. When the top code-like candidate carries that\n847:   // shape, floor every passing candidate's uncertainty so strict callers abstain.\n848:   // Narrow anchors (a file, failing test, named component/route, benchmark, or\n849:   // review intent) bypass the broad-build branch; the multi-concern branch\n850:   // requires two distinct concern classes, so a file + single concern still routes.\n851:   if (!promptLower.includes('/')) {\n852:     const concernClasses = (CONCERN_PERF.test(promptLower) ? 1 : 0) + (CONCERN_QUALITY.test(promptLower) ? 1 : 0);\n853:     const broadBuild = BREADTH_BUILD_VERB.test(promptLower) && BREADTH_NOUN.test(promptLower) && !BREADTH_NARROW_ANCHOR.test(promptLower);\n854:     const multiConcern = MULTI_CONCERN_VERB.test(promptLower) && concernClasses >= 2;\n855:     if (broadBuild || multiConcern) {\n856:       const topRec = ranked.find((recommendation) => recommendation.passes_threshold) ?? null;\n857:       if (topRec && (topRec.skill === 'sk-code' || topRec.skill === 'system-skill-advisor')) {\n858:         const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n859:         const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n860:         const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n861:         ranked = ranked.map((recommendation) => {\n862:           if (!recommendation.passes_threshold) return recommendation;\n863:           const uncertainty = Math.max(recommendation.uncertainty, floor);\n864:           return {\n865:             ...recommendation,\n866:             uncertainty,\n867:             passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n868:           };\n869:         });\n870:       }\n871:     }\n872:   }\n873: \n874:   // Post-fusion so a resolved executor delegation can carry negative evidence\n875:   // the pre-clamp explicit lane cannot express, and so it runs after every\n876:   // abstention gate. The alias table is metadata-derived, so new executors or\n877:   // small models need no change here. It is a no-op on non-delegation prompts.\n878:   ranked = applyExecutorDelegationOverride(ranked, {\n879:     promptLower,\n880:     projection,\n881:     workspaceRoot: options.workspaceRoot,\n882:     confidenceThreshold: options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD,\n883:     uncertaintyThreshold: options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD,\n884:   });\n885: \n886:   const passing = ranked.filter((recommendation) => recommendation.passes_threshold);\n887:   const visible = options.includeAllCandidates ? ranked : passing;\n888:   const top = passing[0] ?? null;\n889:   const laneHealthReason = degradedLaneReason(degradedLanes);\n890:   const abstainReasons = laneHealthReason ? [laneHealthReason] : [];\n891:   if (isSpeckitMetricsEnabled() && top) {\n892:     const runtimeLabel = normalizeRuntimeLabel(process.env.SPECKIT_RUNTIME);\n893:     const freshnessLabel = normalizeFreshnessLabel(process.env.SPECKIT_ADVISOR_FRESHNESS);\n894:     if (runtimeLabel && freshnessLabel) {\n895:       speckitMetrics.incrementCounter('spec_kit.advisor.recommendation_emitted_total', { runtime: runtimeLabel, freshness_state: freshnessLabel });\n896:     }\n897:     speckitMetrics.recordConfidenceBracket(top.confidence);\n898:   }\n899:   return {\n900:     recommendations: visible,\n901:     topSkill: top?.skill ?? null,\n902:     unknown: !top,\n903:     ambiguous: isAmbiguousTopTwo(ranked),\n904:     metrics: {\n905:       candidateCount: ranked.length,\n906:       liveLaneCount: runtimeLiveLaneCount,\n907:       ...(degradedLanes.length > 0 ? { degradedLanes, laneHealth } : {}),\n908:     },\n909:     ...(abstainReasons.length > 0 ? { abstainReasons } : {}),\n910:   };\n911: }\n\n(End of file - total 911 lines)\n</content>","metadata":{"preview":"    }\n  }\n  const exactSemanticRerankIndex = useExactSemanticRerank\n    ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n    : new Map<string, ExactSemanticRerankEntry>();\n  let ranked = recommendations.sort((left, right) => {\n    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n    const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n    const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n    const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n    const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n      - (left.score + leftCommandBonus + leftIntent + leftConflict);\n    if (useRrfFusion) {\n      const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n      const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n      if (leftExactSemantic !== null\n        && rightExactSemantic !== null\n        && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"    }\n  }\n  const exactSemanticRerankIndex = useExactSemanticRerank\n    ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n    : new Map<string, ExactSemanticRerankEntry>();\n  let ranked = recommendations.sort((left, right) => {\n    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n    const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n    const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n    const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n    const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n      - (left.score + leftCommandBonus + leftIntent + leftConflict);\n    if (useRrfFusion) {\n      const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n      const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n      if (leftExactSemantic !== null\n        && rightExactSemantic !== null\n        && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {\n        const exactSemanticDiff = rightExactSemantic - leftExactSemantic;\n        if (exactSemanticDiff !== 0) {\n          return exactSemanticDiff;\n        }\n      }\n      return adjustedScoreDiff\n        || rrfRankFor(rrfFusion, left) - rrfRankFor(rrfFusion, right)\n        || left.skill.localeCompare(right.skill);\n    }\n    return adjustedScoreDiff\n      || right.confidence - left.confidence\n      || left.skill.localeCompare(right.skill);\n  });\n\n  ranked = ranked.map((recommendation, index) => {\n    const next = ranked[index + 1];\n    const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n    const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n    return {\n      ...recommendation,\n      uncertainty,\n      passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n        && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n    };\n  });\n  ranked = applyAmbiguity(ranked);\n\n  // Low-information ambiguity abstention: a short, intent-less prompt that lands\n  // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n  // every cluster member's uncertainty above the strict threshold so strict\n  // callers abstain, while confidence-only callers still surface the best guess\n  // (the disambiguated top-ranked candidate).\n  const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n  const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n  if (lowInfoPrompt) {\n    const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n    // Only abstain when the cluster's lead is built from diffuse, shared\n    // single-word keyword matches rather than a distinctive multi-word phrase\n    // anchor (an explicit-author/derived phrase match such as \"code audit\").\n    // A multi-word anchor means the prompt does pin a specific skill, so it\n    // should route instead of abstaining.\n    const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (\n      recommendation.laneContributions.some((contribution) => (\n        (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')\n        && contribution.evidence.some((entry) => entry.includes(' '))\n      ))\n    ));\n    if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {\n      const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n      const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n      const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n      ranked = ranked.map((recommendation) => {\n        if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;\n        const uncertainty = Math.max(recommendation.uncertainty, floor);\n        return {\n          ...recommendation,\n          uncertainty,\n          passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n        };\n      });\n    }\n  }\n\n  // Class C: breadth / multi-concern abstention. A broad greenfield build\n  // (\"build full stack typescript service\") or a multi-concern optimization\n  // (\"optimize X execution speed and recommendation quality\") is under-specified\n  // for single-skill routing. When the top code-like candidate carries that\n  // shape, floor every passing candidate's uncertainty so strict callers abstain.\n  // Narrow anchors (a file, failing test, named component/route, benchmark, or\n  // review intent) bypass the broad-build branch; the multi-concern branch\n  // requires two distinct concern classes, so a file + single concern still routes.\n  if (!promptLower.includes('/')) {\n    const concernClasses = (CONCERN_PERF.test(promptLower) ? 1 : 0) + (CONCERN_QUALITY.test(promptLower) ? 1 : 0);\n    const broadBuild = BREADTH_BUILD_VERB.test(promptLower) && BREADTH_NOUN.test(promptLower) && !BREADTH_NARROW_ANCHOR.test(promptLower);\n    const multiConcern = MULTI_CONCERN_VERB.test(promptLower) && concernClasses >= 2;\n    if (broadBuild || multiConcern) {\n      const topRec = ranked.find((recommendation) => recommendation.passes_threshold) ?? null;\n      if (topRec && (topRec.skill === 'sk-code' || topRec.skill === 'system-skill-advisor')) {\n        const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n        const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n        const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n        ranked = ranked.map((recommendation) => {\n          if (!recommendation.passes_threshold) return recommendation;\n          const uncertainty = Math.max(recommendation.uncertainty, floor);\n          return {\n            ...recommendation,\n            uncertainty,\n            passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n          };\n        });\n      }\n    }\n  }\n\n  // Post-fusion so a resolved executor delegation can carry negative evidence\n  // the pre-clamp explicit lane cannot express, and so it runs after every\n  // abstention gate. The alias table is metadata-derived, so new executors or\n  // small models need no change here. It is a no-op on non-delegation prompts.\n  ranked = applyExecutorDelegationOverride(ranked, {\n    promptLower,\n    projection,\n    workspaceRoot: options.workspaceRoot,\n    confidenceThreshold: options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD,\n    uncertaintyThreshold: options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD,\n  });\n\n  const passing = ranked.filter((recommendation) => recommendation.passes_threshold);\n  const visible = options.includeAllCandidates ? ranked : passing;\n  const top = passing[0] ?? null;\n  const laneHealthReason = degradedLaneReason(degradedLanes);\n  const abstainReasons = laneHealthReason ? [laneHealthReason] : [];\n  if (isSpeckitMetricsEnabled() && top) {\n    const runtimeLabel = normalizeRuntimeLabel(process.env.SPECKIT_RUNTIME);\n    const freshnessLabel = normalizeFreshnessLabel(process.env.SPECKIT_ADVISOR_FRESHNESS);\n    if (runtimeLabel && freshnessLabel) {\n      speckitMetrics.incrementCounter('spec_kit.advisor.recommendation_emitted_total', { runtime: runtimeLabel, freshness_state: freshnessLabel });\n    }\n    speckitMetrics.recordConfidenceBracket(top.confidence);\n  }\n  return {\n    recommendations: visible,\n    topSkill: top?.skill ?? null,\n    unknown: !top,\n    ambiguous: isAmbiguousTopTwo(ranked),\n    metrics: {\n      candidateCount: ranked.length,\n      liveLaneCount: runtimeLiveLaneCount,\n      ...(degradedLanes.length > 0 ? { degradedLanes, laneHealth } : {}),\n    },\n    ...(abstainReasons.length > 0 ? { abstainReasons } : {}),\n  };\n}","lineStart":760,"lineEnd":911,"totalLines":911,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":178343726