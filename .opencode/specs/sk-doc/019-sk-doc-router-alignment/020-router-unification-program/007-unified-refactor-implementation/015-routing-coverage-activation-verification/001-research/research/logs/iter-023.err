   105	];
   106	
   107	// ─────────────────────────────────────────────────────────────────────────────
   108	// 3. HELPERS
   109	// ─────────────────────────────────────────────────────────────────────────────
   110	
   111	/**
   112	 * Map a bare lane script name to its on-disk path at spawn time.
   113	 *
   114	 * @param {string} scriptName - Bare script name (e.g. 'score-candidate.cjs')
   115	 * @returns {string} Absolute path to the resolved lane script
   116	 */
   117	function resolveScriptPath(scriptName) {
   118	  if (LANE_A.has(scriptName)) {
   119	    return path.join(SCRIPTS_ROOT, '..', 'agent-improvement', scriptName);
   120	  }
   121	  if (LANE_MODEL_BENCHMARK.has(scriptName)) {
   122	    return path.join(SCRIPTS_ROOT, '..', 'model-benchmark', scriptName);
   123	  }
   124	  if (LANE_SKILL_BENCHMARK.has(scriptName)) {
   125	    return path.join(SCRIPTS_ROOT, '..', 'skill-benchmark', scriptName);
   126	  }
   127	  // Other shared scripts (materialize-benchmark-fixtures, promote-candidate,
   128	  // reduce-state, improvement-journal, mutation-coverage) live alongside this file.
   129	  return path.join(SCRIPTS_ROOT, scriptName);
   130	}
   131	
   132	/**
   133	 * Resolve a raw --mode value to a valid mode, defaulting unknown values.
   134	 *
   135	 * @param {string|undefined} rawMode - Raw --mode flag value
   136	 * @returns {string} A valid mode, falling back to 'agent-improvement'
   137	 */
   138	function resolveMode(rawMode) {
   139	  if (rawMode === undefined) return 'agent-improvement';
   140	  if (VALID_MODES.has(rawMode)) return rawMode;
   141	  process.stderr.write(`loop-host: unknown mode '${rawMode}', defaulting to 'agent-improvement'\n`);
   142	  return 'agent-improvement';
   143	}
   144	
   145	// ─────────────────────────────────────────────────────────────────────────────
   146	// 4. CORE LOGIC
   147	// ─────────────────────────────────────────────────────────────────────────────
   148	
   149	/**
   150	 * Pure planner: map (mode, args) -> the ordered script invocations to run.
   151	 * Planning is separated from execution so the backward-compat identity gate
   152	 * the identity gate can assert byte-identical plans for the default and explicit
   153	 * agent-improvement routes without spawning anything.
   154	 *
   155	 * @param {string} mode - Resolved run mode (agent-improvement, model-benchmark, skill-benchmark)
   156	 * @param {object} args - Parsed CLI args keyed by flag name
   157	 * @returns {{ ok: true, steps: Array<{script: string, args: string[]}> } | { ok: false, error: string }}
   158	 */
   159	function planInvocation(mode, args) {
   160	  if (mode === 'model-benchmark') {
   161	    if (!args.profile || !args['outputs-dir']) {
   162	      return { ok: false, error: 'model-benchmark: missing required --profile=<path-or-id> and --outputs-dir=<path>' };
   163	    }
   164	    // materialize MUST run (and succeed) before run-benchmark, else scoring
   165	    // silently produces all-zero "missing-output" results. These scripts use
   166	    // space-separated args.
   167	    //
   168	    // Both steps share one option schema (BENCHMARK_* lists) so forwarding stays
   169	    // in sync with run-benchmark.cjs and the materializer, instead of a hand-rolled
   170	    // per-flag chain that silently drifts.
   171	    // run-benchmark.cjs forwards scorer/grader/integration-report so the journal
   172	    // and report.json agree on the requested method; the materializer forwards
   173	    // --profiles-dir so a profile-by-ID resolves identically in both steps.
   174	    const materializeArgs = ['--profile', args.profile, '--outputs-dir', args['outputs-dir']];
   175	    for (const opt of BENCHMARK_MATERIALIZE_OPTIONS) {
   176	      if (args[opt] !== undefined) materializeArgs.push(`--${opt}`, String(args[opt]));
   177	    }
   178	    const benchArgs = ['--profile', args.profile, '--outputs-dir', args['outputs-dir']];
   179	    for (const opt of BENCHMARK_RUN_OPTIONS) {
   180	      if (args[opt] !== undefined) benchArgs.push(`--${opt}`, String(args[opt]));
   181	    }
   182	    return {
   183	      ok: true,
   184	      steps: [
   185	        { script: 'materialize-benchmark-fixtures.cjs', args: materializeArgs },
   186	        { script: 'run-benchmark.cjs', args: benchArgs },
   187	      ],
   188	    };
   189	  }
   190	  if (mode === 'skill-benchmark') {
   191	    if (!args.skill || !args['outputs-dir']) {
   192	      return { ok: false, error: 'skill-benchmark: missing required --skill=<skill-root-or-id> and --outputs-dir=<path>' };
   193	    }
   194	    // Single orchestrator step: run-skill-benchmark.cjs internally sequences
   195	    // D5-gate -> router-replay -> (optional live) -> trace-parse -> score ->
   196	    // report, so the plan stays one step (unlike Lane B's materialize+run pair).
   197	    // Lane C scripts use space-separated args.
   198	    const skillArgs = ['--skill', args.skill, '--outputs-dir', args['outputs-dir']];
   199	    for (const opt of SKILL_BENCHMARK_RUN_OPTIONS) {
   200	      if (args[opt] !== undefined) skillArgs.push(`--${opt}`, String(args[opt]));
   201	    }
   202	    return { ok: true, steps: [{ script: 'run-skill-benchmark.cjs', args: skillArgs }] };
   203	  }
   204	  // agent-improvement (default). score-candidate.cjs uses key=value args.
   205	  if (!args.candidate) {
   206	    return { ok: false, error: 'agent-improvement: missing required --candidate=<path>' };
   207	  }
   208	  const scoreArgs = [`--candidate=${args.candidate}`];
   209	  if (args.baseline) scoreArgs.push(`--baseline=${args.baseline}`);
   210	  if (args.output) scoreArgs.push(`--output=${args.output}`);

