eester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_alignment_confirm.yaml:\n  Line 188:           skip_to: phase_synthesis\n\n  Line 350:       step_dispatch_alignment_iteration:\n\n  Line 396:         if_converged: { proceed_to: phase_synthesis }\n\n  Line 397:         if_stop_max_iterations: { log: \"Max iterations ({max_iterations}) reached without full convergence; proceeding to synthesis with current coverage/stability as recorded evidence.\", proceed_to: phase_synthesis }\n\n  Line 398:         if_nothing_to_converge: { log: \"Zero applicable lanes -- nothing to converge. Proceeding to synthesis.\", proceed_to: phase_synthesis }\n\n  Line 404:   phase_synthesis:\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_model-benchmark_confirm.yaml:\n  Line 105:     reducer: .opencode/skills/system-deep-loop/deep-improvement/scripts/shared/reduce-state.cjs\n\n  Line 200:         command: \"node .opencode/skills/system-deep-loop/deep-improvement/scripts/shared/reduce-state.cjs {spec_folder}/improvement\"\n\n  Line 219:   phase_synthesis:\n\n  Line 223:         description: \"Render the final dashboard via reduce-state and present benchmark trends and stop reason\"\n\n  Line 224:         command: \"node .opencode/skills/system-deep-loop/deep-improvement/scripts/shared/reduce-state.cjs {spec_folder}/improvement\"\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_model-benchmark_presentation.txt:\n  Line 40:   executor: cli-opencode  # required only when grader = llm; one of cli-opencode | cli-claude-code\n\n  Line 41:   model: gpt-5.5  # required only when grader = llm; model id for the chosen executor (cli-opencode e.g. xiaomi-token-plan-ams/mimo-v2.5-pro, minimax-coding-plan/MiniMax-M2.7-highspeed)\n\n  Line