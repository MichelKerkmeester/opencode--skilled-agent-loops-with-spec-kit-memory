{"type":"tool_use","timestamp":1784210764435,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_5Q14MLfsRMuEU8TeFAe65zUG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs","limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: // After-dispatch leaf-reliability check for the deep-loop iteration loop.\n5: //\n6: // A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n7: // (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n8: // per-iteration delta file. The state-log record must also carry route-proof\n9: // fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n10: // resolved_route). A model-driven loop is trusted to self-check today, which lets a\n11: // silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n12: // non-zero with a single machine reason so the workflow can re-dispatch the same\n13: // iteration once before recording an error and continuing.\n14: \n15: const fs = require('node:fs');\n16: const path = require('node:path');\n17: \n18: const LEAF_BY_LOOP = {\n19:   review: 'deep-review',\n20:   research: 'deep-research',\n21:   alignment: 'deep-alignment',\n22: };\n23: \n24: const STATE_LOG_BY_LOOP = {\n25:   review: 'deep-review-state.jsonl',\n26:   research: 'deep-research-state.jsonl',\n27:   alignment: 'deep-alignment-state.jsonl',\n28: };\n29: \n30: const REASONS = {\n31:   ITERATION_FILE_MISSING: 'iteration_file_missing',\n32:   ITERATION_VERDICT_MISSING: 'iteration_verdict_missing',\n33:   STATE_RECORD_MISSING: 'state_record_missing',\n34:   ROUTE_PROOF_MISSING: 'route_proof_missing',\n35:   ROUTE_PROOF_MISMATCH: 'route_proof_mismatch',\n36:   DELTA_FILE_MISSING: 'delta_file_missing',\n37: };\n38: \n39: function pad3(n) {\n40:   return String(n).padStart(3, '0');\n41: }\n42: \n43: function parseArgs(argv) {\n44:   const out = { json: false };\n45:   for (let i = 0; i < argv.length; i += 1) {\n46:     const a = argv[i];\n47:     if (a === '--loop-type') { out.loopType = argv[i + 1]; i += 1; }\n48:     else if (a === '--artifact-dir') { out.artifactDir = argv[i + 1]; i += 1; }\n49:     else if (a === '--iteration') { out.iteration = parseInt(argv[i + 1], 10); i += 1; }\n50:     else if (a === '--json') { out.json = true; }\n51:     else if (a === '--help' || a === '-h') { out.help = true; }\n52:     else { out.error = `unknown flag: ${a}`; }\n53:   }\n54:   return out;\n55: }\n56: \n57: // Read a JSONL file and return parsed objects, skipping blank/malformed lines so a\n58: // single corrupt append never crashes the gate.\n59: function readJsonlRecords(filePath) {\n60:   let raw;\n61:   try {\n62:     raw = fs.readFileSync(filePath, 'utf8');\n63:   } catch (_) {\n64:     return null; // file absent/unreadable\n65:   }\n66:   const records = [];\n67:   for (const line of raw.split('\\n')) {\n68:     const trimmed = line.trim();\n69:     if (!trimmed) continue;\n70:     try {\n71:       records.push(JSON.parse(trimmed));\n72:     } catch (_) {\n73:       // skip malformed line\n74:     }\n75:   }\n76:   return records;\n77: }\n78: \n79: // The narrative file is written as iteration-NNN.md but the leaf may append a\n80: // descriptive suffix (iteration-NNN-some-focus.md), so match the padded number as a\n81: // prefix bounded by \".\" or \"-\" to avoid confusing 002 with 020.\n82: function findIterationNarrative(iterationsDir, iteration) {\n83:   const nnn = pad3(iteration);\n84:   let entries;\n85:   try {\n86:     entries = fs.readdirSync(iterationsDir);\n87:   } catch (_) {\n88:     return null;\n89:   }\n90:   const re = new RegExp(`^iteration-${nnn}(?:\\\\.md$|-.*\\\\.md$)`);\n91:   for (const name of entries) {\n92:     if (re.test(name)) return path.join(iterationsDir, name);\n93:   }\n94:   return null;\n95: }\n96: \n97: function isNonEmptyString(value) {\n98:   return typeof value === 'string' && value.trim().length > 0;\n99: }\n100: \n101: // Route-proof lives on the canonical iteration record. Absent fields => the leaf did\n102: // not emit route-proof at all; present-but-wrong => it ran as something other than\n103: // its own leaf identity or in the wrong mode.\n104: function checkRouteProof(record, loopType, leaf) {\n105:   const hasMode = 'mode' in record;\n106:   const hasTarget = 'target_agent' in record;\n107:   const hasLoaded = 'agent_definition_loaded' in record;\n108:   const hasRoute = 'resolved_route' in record;\n109:   if (!hasMode || !hasTarget || !hasLoaded || !hasRoute) {\n110:     return REASONS.ROUTE_PROOF_MISSING;\n111:   }\n112:   if (\n113:     record.mode !== loopType ||\n114:     record.target_agent !== leaf ||\n115:     record.agent_definition_loaded !== true ||\n116:     !isNonEmptyString(record.resolved_route)\n117:   ) {\n118:     return REASONS.ROUTE_PROOF_MISMATCH;\n119:   }\n120:   return null;\n121: }\n122: \n123: function verify(loopType, artifactDir, iteration) {\n124:   const leaf = LEAF_BY_LOOP[loopType];\n125:   const stateLogName = STATE_LOG_BY_LOOP[loopType];\n126: \n127:   // 1. Iteration narrative markdown.\n128:   const narrativePath = findIterationNarrative(path.join(artifactDir, 'iterations'), iteration);\n129:   if (!narrativePath) {\n130:     return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `no iterations/iteration-${pad3(iteration)}*.md under ${artifactDir}` };\n131:   }\n132:   const narrative = fs.readFileSync(narrativePath, 'utf8');\n133:   if (!narrative.trim()) {\n134:     return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `${narrativePath} is empty` };\n135:   }\n136:   // Review narratives must end on exactly one machine-readable verdict; research/context\n137:   // use a different closing shape, so only review enforces the verdict line here.\n138:   if (loopType === 'review') {\n139:     const verdictPattern = /^Review verdict:\\s*(PASS|CONDITIONAL|FAIL)\\s*$/i;\n140:     const verdictLines = narrative.split(/\\r?\\n/).filter((line) => verdictPattern.test(line));\n141:     const finalLine = narrative.trimEnd().split(/\\r?\\n/).at(-1) ?? '';\n142:     if (verdictLines.length !== 1 || !verdictPattern.test(finalLine)) {\n143:       return { ok: false, reason: REASONS.ITERATION_VERDICT_MISSING, detail: `${narrativePath} must end with exactly one \"Review verdict: PASS|CONDITIONAL|FAIL\" line` };\n144:     }\n145:   }\n146: \n147:   // 2. Canonical state-log record for this iteration + route-proof.\n148:   const stateRecords = readJsonlRecords(path.join(artifactDir, stateLogName));\n149:   // Review/research key the iteration number as `iteration`; context keys it as `run`.\n150:   // Match either so one shim covers all three modes (a non-numeric run-id yields NaN\n151:   // and never false-matches). Take the LAST matching record, not the first: the state\n152:   // log is append-only, so a re-dispatched iteration appends a corrected record after\n153:   // the bad one -- matching the first would keep reporting the stale failure and defeat\n154:   // the bounded retry. The state reducer applies the same latest-record-wins rule.\n155:   const iterationRecord = (stateRecords || []).findLast(\n156:     (r) => r && r.type === 'iteration' && (Number(r.iteration) === iteration || Number(r.run) === iteration),\n157:   );\n158:   if (!iterationRecord) {\n159:     return { ok: false, reason: REASONS.STATE_RECORD_MISSING, detail: `no type=iteration record with iteration=${iteration} in ${stateLogName}` };\n160:   }\n161:   const routeReason = checkRouteProof(iterationRecord, loopType, leaf);\n162:   if (routeReason) {\n163:     return { ok: false, reason: routeReason, detail: `iteration ${iteration} state record failed route-proof (expected mode=${loopType} target_agent=${leaf})` };\n164:   }\n165: \n166:   // 3. Per-iteration delta file with at least one iteration record.\n167:   const deltaRecords = readJsonlRecords(path.join(artifactDir, 'deltas', `iter-${pad3(iteration)}.jsonl`));\n168:   if (!deltaRecords || !deltaRecords.some((r) => r && r.type === 'iteration')) {\n169:     return { ok: false, reason: REASONS.DELTA_FILE_MISSING, detail: `deltas/iter-${pad3(iteration)}.jsonl missing or has no type=iteration record` };\n170:   }\n171: \n172:   return { ok: true, reason: null, detail: `iteration ${iteration} complete: narrative + route-proof + delta` };\n173: }\n174: \n175: function main(argv = process.argv.slice(2)) {\n176:   const args = parseArgs(argv);\n177:   if (args.help) {\n178:     process.stdout.write('Usage: verify-iteration.cjs --loop-type review|research|context|alignment --artifact-dir <dir> --iteration <N> [--json]\\n');\n179:     return 0;\n180:   }\n181:   if (args.error) { process.stderr.write(`${args.error}\\n`); return 2; }\n182:   if (!args.loopType || !LEAF_BY_LOOP[args.loopType]) { process.stderr.write(`--loop-type must be one of ${Object.keys(LEAF_BY_LOOP).join('|')}\\n`); return 2; }\n183:   if (!args.artifactDir) { process.stderr.write('--artifact-dir is required\\n'); return 2; }\n184:   if (!Number.isInteger(args.iteration) || args.iteration < 1) { process.stderr.write('--iteration must be a positive integer\\n'); return 2; }\n185: \n186:   const result = verify(args.loopType, args.artifactDir, args.iteration);\n187:   if (args.json) {\n188:     process.stdout.write(`${JSON.stringify(result)}\\n`);\n189:   } else if (result.ok) {\n190:     process.stdout.write(`OK ${result.detail}\\n`);\n191:   } else {\n192:     process.stderr.write(`${result.reason} ${result.detail}\\n`);\n193:   }\n194:   return result.ok ? 0 : 1;\n195: }\n196: \n197: if (require.main === module) {\n198:   process.exit(main());\n199: }\n200: \n201: module.exports = { verify, checkRouteProof, findIterationNarrative, readJsonlRecords, pad3, REASONS, LEAF_BY_LOOP, STATE_LOG_BY_LOOP };\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n// After-dispatch leaf-reliability check for the deep-loop iteration loop.\n//\n// A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n// (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n// per-iteration delta file. The state-log record must also carry route-proof\n// fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n// resolved_route). A model-driven loop is trusted to self-check today, which lets a\n// silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n// non-zero with a single machine reason so the workflow can re-dispatch the same\n// iteration once before recording an error and continuing.\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst LEAF_BY_LOOP = {\n  review: 'deep-review',\n  research: 'deep-research',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs","text":"#!/usr/bin/env node\n'use strict';\n\n// After-dispatch leaf-reliability check for the deep-loop iteration loop.\n//\n// A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n// (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n// per-iteration delta file. The state-log record must also carry route-proof\n// fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n// resolved_route). A model-driven loop is trusted to self-check today, which lets a\n// silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n// non-zero with a single machine reason so the workflow can re-dispatch the same\n// iteration once before recording an error and continuing.\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst LEAF_BY_LOOP = {\n  review: 'deep-review',\n  research: 'deep-research',\n  alignment: 'deep-alignment',\n};\n\nconst STATE_LOG_BY_LOOP = {\n  review: 'deep-review-state.jsonl',\n  research: 'deep-research-state.jsonl',\n  alignment: 'deep-alignment-state.jsonl',\n};\n\nconst REASONS = {\n  ITERATION_FILE_MISSING: 'iteration_file_missing',\n  ITERATION_VERDICT_MISSING: 'iteration_verdict_missing',\n  STATE_RECORD_MISSING: 'state_record_missing',\n  ROUTE_PROOF_MISSING: 'route_proof_missing',\n  ROUTE_PROOF_MISMATCH: 'route_proof_mismatch',\n  DELTA_FILE_MISSING: 'delta_file_missing',\n};\n\nfunction pad3(n) {\n  return String(n).padStart(3, '0');\n}\n\nfunction parseArgs(argv) {\n  const out = { json: false };\n  for (let i = 0; i < argv.length; i += 1) {\n    const a = argv[i];\n    if (a === '--loop-type') { out.loopType = argv[i + 1]; i += 1; }\n    else if (a === '--artifact-dir') { out.artifactDir = argv[i + 1]; i += 1; }\n    else if (a === '--iteration') { out.iteration = parseInt(argv[i + 1], 10); i += 1; }\n    else if (a === '--json') { out.json = true; }\n    else if (a === '--help' || a === '-h') { out.help = true; }\n    else { out.error = `unknown flag: ${a}`; }\n  }\n  return out;\n}\n\n// Read a JSONL file and return parsed objects, skipping blank/malformed lines so a\n// single corrupt append never crashes the gate.\nfunction readJsonlRecords(filePath) {\n  let raw;\n  try {\n    raw = fs.readFileSync(filePath, 'utf8');\n  } catch (_) {\n    return null; // file absent/unreadable\n  }\n  const records = [];\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) continue;\n    try {\n      records.push(JSON.parse(trimmed));\n    } catch (_) {\n      // skip malformed line\n    }\n  }\n  return records;\n}\n\n// The narrative file is written as iteration-NNN.md but the leaf may append a\n// descriptive suffix (iteration-NNN-some-focus.md), so match the padded number as a\n// prefix bounded by \".\" or \"-\" to avoid confusing 002 with 020.\nfunction findIterationNarrative(iterationsDir, iteration) {\n  const nnn = pad3(iteration);\n  let entries;\n  try {\n    entries = fs.readdirSync(iterationsDir);\n  } catch (_) {\n    return null;\n  }\n  const re = new RegExp(`^iteration-${nnn}(?:\\\\.md$|-.*\\\\.md$)`);\n  for (const name of entries) {\n    if (re.test(name)) return path.join(iterationsDir, name);\n  }\n  return null;\n}\n\nfunction isNonEmptyString(value) {\n  return typeof value === 'string' && value.trim().length > 0;\n}\n\n// Route-proof lives on the canonical iteration record. Absent fields => the leaf did\n// not emit route-proof at all; present-but-wrong => it ran as something other than\n// its own leaf identity or in the wrong mode.\nfunction checkRouteProof(record, loopType, leaf) {\n  const hasMode = 'mode' in record;\n  const hasTarget = 'target_agent' in record;\n  const hasLoaded = 'agent_definition_loaded' in record;\n  const hasRoute = 'resolved_route' in record;\n  if (!hasMode || !hasTarget || !hasLoaded || !hasRoute) {\n    return REASONS.ROUTE_PROOF_MISSING;\n  }\n  if (\n    record.mode !== loopType ||\n    record.target_agent !== leaf ||\n    record.agent_definition_loaded !== true ||\n    !isNonEmptyString(record.resolved_route)\n  ) {\n    return REASONS.ROUTE_PROOF_MISMATCH;\n  }\n  return null;\n}\n\nfunction verify(loopType, artifactDir, iteration) {\n  const leaf = LEAF_BY_LOOP[loopType];\n  const stateLogName = STATE_LOG_BY_LOOP[loopType];\n\n  // 1. Iteration narrative markdown.\n  const narrativePath = findIterationNarrative(path.join(artifactDir, 'iterations'), iteration);\n  if (!narrativePath) {\n    return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `no iterations/iteration-${pad3(iteration)}*.md under ${artifactDir}` };\n  }\n  const narrative = fs.readFileSync(narrativePath, 'utf8');\n  if (!narrative.trim()) {\n    return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `${narrativePath} is empty` };\n  }\n  // Review narratives must end on exactly one machine-readable verdict; research/context\n  // use a different closing shape, so only review enforces the verdict line here.\n  if (loopType === 'review') {\n    const verdictPattern = /^Review verdict:\\s*(PASS|CONDITIONAL|FAIL)\\s*$/i;\n    const verdictLines = narrative.split(/\\r?\\n/).filter((line) => verdictPattern.test(line));\n    const finalLine = narrative.trimEnd().split(/\\r?\\n/).at(-1) ?? '';\n    if (verdictLines.length !== 1 || !verdictPattern.test(finalLine)) {\n      return { ok: false, reason: REASONS.ITERATION_VERDICT_MISSING, detail: `${narrativePath} must end with exactly one \"Review verdict: PASS|CONDITIONAL|FAIL\" line` };\n    }\n  }\n\n  // 2. Canonical state-log record for this iteration + route-proof.\n  const stateRecords = readJsonlRecords(path.join(artifactDir, stateLogName));\n  // Review/research key the iteration number as `iteration`; context keys it as `run`.\n  // Match either so one shim covers all three modes (a non-numeric run-id yields NaN\n  // and never false-matches). Take the LAST matching record, not the first: the state\n  // log is append-only, so a re-dispatched iteration appends a corrected record after\n  // the bad one -- matching the first would keep reporting the stale failure and defeat\n  // the bounded retry. The state reducer applies the same latest-record-wins rule.\n  const iterationRecord = (stateRecords || []).findLast(\n    (r) => r && r.type === 'iteration' && (Number(r.iteration) === iteration || Number(r.run) === iteration),\n  );\n  if (!iterationRecord) {\n    return { ok: false, reason: REASONS.STATE_RECORD_MISSING, detail: `no type=iteration record with iteration=${iteration} in ${stateLogName}` };\n  }\n  const routeReason = checkRouteProof(iterationRecord, loopType, leaf);\n  if (routeReason) {\n    return { ok: false, reason: routeReason, detail: `iteration ${iteration} state record failed route-proof (expected mode=${loopType} target_agent=${leaf})` };\n  }\n\n  // 3. Per-iteration delta file with at least one iteration record.\n  const deltaRecords = readJsonlRecords(path.join(artifactDir, 'deltas', `iter-${pad3(iteration)}.jsonl`));\n  if (!deltaRecords || !deltaRecords.some((r) => r && r.type === 'iteration')) {\n    return { ok: false, reason: REASONS.DELTA_FILE_MISSING, detail: `deltas/iter-${pad3(iteration)}.jsonl missing or has no type=iteration record` };\n  }\n\n  return { ok: true, reason: null, detail: `iteration ${iteration} complete: narrative + route-proof + delta` };\n}\n\nfunction main(argv = process.argv.slice(2)) {\n  const args = parseArgs(argv);\n  if (args.help) {\n    process.stdout.write('Usage: verify-iteration.cjs --loop-type review|research|context|alignment --artifact-dir <dir> --iteration <N> [--json]\\n');\n    return 0;\n  }\n  if (args.error) { process.stderr.write(`${args.error}\\n`); return 2; }\n  if (!args.loopType || !LEAF_BY_LOOP[args.loopType]) { process.stderr.write(`--loop-type must be one of ${Object.keys(LEAF_BY_LOOP).join('|')}\\n`); return 2; }\n  if (!args.artifactDir) { process.stderr.write('--artifact-dir is required\\n'); return 2; }\n  if (!Number.isInteger(args.iteration) || args.iteration < 1) { process.stderr.write('--iteration must be a positive integer\\n'); return 2; }\n\n  const result = verify(args.loopType, args.artifactDir, args.iteration);\n  if (args.json) {\n    process.stdout.write(`${JSON.stringify(result)}\\n`);\n  } else if (result.ok) {\n    process.stdout.write(`OK ${result.detail}\\n`);\n  } else {\n    process.stderr.write(`${result.reason} ${result.detail}\\n`);\n  }\n  return result.ok ? 0 : 1;\n}\n\nif (require.main === module) {\n  process.exit(main());\n}\n\nmodule.exports = { verify, checkRouteProof, findIterationNarrative, readJsonlRecords, pad3, REASONS, LEAF_BY_LOOP, STATE_LOG_BY_LOOP };","lineStart":1,"lineEnd":201,"totalLines":201,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs","time":{"start":1784210764426,"end":1784210764433}},"metadata":{"openai":{"itemId":"fc_0c02ec28285e3b78016a58e54c3294819b8f12cbc83afca5b4"}},"id":"prt_f6b3fb22d0010yldbuBk8cKOqe","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3f8c39001RSF6WtTQz3aLy2"}}
{"type":"tool_use","timestamp":1784210764530,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_SbCDhP3LJq3y8sN9lRJ15cqE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","limit":250},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep Review State Reducer                                                ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: const { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\n14: const { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\n15: const { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n16: \n17: // ─────────────────────────────────────────────────────────────────────────────\n18: // 2. CONSTANTS\n19: // ─────────────────────────────────────────────────────────────────────────────\n20: \n21: const REQUIRED_DIMENSIONS = ['correctness', 'security', 'traceability', 'maintainability'];\n22: const SEVERITY_KEYS = ['P0', 'P1', 'P2'];\n23: const SEVERITY_WEIGHTS = { P0: 10.0, P1: 5.0, P2: 1.0 };\n24: const LIVE_LINEAGE_MODES = new Set(['new', 'resume', 'restart']);\n25: \n26: // ─────────────────────────────────────────────────────────────────────────────\n27: // 3. HELPERS\n28: // ─────────────────────────────────────────────────────────────────────────────\n29: \n30: function readUtf8(filePath) {\n31:   return fs.readFileSync(filePath, 'utf8');\n32: }\n33: \n34: function writeUtf8(filePath, content) {\n35:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n36:   fs.writeFileSync(filePath, content, 'utf8');\n37: }\n38: \n39: function readJson(filePath) {\n40:   return JSON.parse(readUtf8(filePath));\n41: }\n42: \n43: function getResourceMapEmitSetting(config) {\n44:   const nested = config && typeof config === 'object'\n45:     ? (config.resource_map || config.resourceMap || null)\n46:     : null;\n47:   if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n48:     return nested.emit;\n49:   }\n50:   return true;\n51: }\n52: \n53: function slugify(value) {\n54:   return value\n55:     .toLowerCase()\n56:     .replace(/[^a-z0-9]+/g, '-')\n57:     .replace(/^-+|-+$/g, '')\n58:     .slice(0, 80) || 'entry';\n59: }\n60: \n61: function normalizeText(value) {\n62:   if (value === null || value === undefined) return '';\n63:   if (typeof value !== 'string') {\n64:     try { return String(value).replace(/\\s+/g, ' ').trim(); }\n65:     catch { return ''; }\n66:   }\n67:   return value.replace(/\\s+/g, ' ').trim();\n68: }\n69: \n70: function escapeRegExp(value) {\n71:   return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n72: }\n73: \n74: function zeroSeverityMap() {\n75:   return { P0: 0, P1: 0, P2: 0 };\n76: }\n77: \n78: function isFiniteNumber(value) {\n79:   return typeof value === 'number' && Number.isFinite(value);\n80: }\n81: \n82: function normalizeSeverity(value) {\n83:   return SEVERITY_KEYS.includes(value) ? value : null;\n84: }\n85: \n86: function normalizeLineageMode(value) {\n87:   const normalized = normalizeText(value).toLowerCase();\n88:   return LIVE_LINEAGE_MODES.has(normalized) ? normalized : null;\n89: }\n90: \n91: function getNestedField(record, fieldName) {\n92:   if (!record || typeof record !== 'object') {\n93:     return undefined;\n94:   }\n95:   if (record[fieldName] !== undefined) {\n96:     return record[fieldName];\n97:   }\n98:   if (record.details && typeof record.details === 'object' && record.details[fieldName] !== undefined) {\n99:     return record.details[fieldName];\n100:   }\n101:   return undefined;\n102: }\n103: \n104: // ─────────────────────────────────────────────────────────────────────────────\n105: // 4. PARSERS\n106: // ─────────────────────────────────────────────────────────────────────────────\n107: \n108: /**\n109:  * Parse JSONL content into an array of records, preserving both iteration and\n110:  * event rows. Backward-compatible array return.\n111:  *\n112:  * @param {string} jsonlContent - Newline-delimited JSON string\n113:  * @returns {Array<Object>} Parsed records (corrupt lines silently dropped — use parseJsonlDetailed for fail-closed behavior)\n114:  */\n115: function parseJsonl(jsonlContent) {\n116:   return parseJsonlDetailed(jsonlContent).records;\n117: }\n118: \n119: /**\n120:  * Parse JSONL content and report malformed lines (fail-closed pathway).\n121:  *\n122:  * Returns both the parsed records and a corruption warning list. The reducer\n123:  * exit code is non-zero when warnings are present unless `--lenient` is passed.\n124:  *\n125:  * @param {string} jsonlContent - Newline-delimited JSON string\n126:  * @returns {{records: Array<Object>, corruptionWarnings: Array<{line: number, raw: string, error: string}>}}\n127:  */\n128: function parseJsonlDetailed(jsonlContent) {\n129:   const records = [];\n130:   const corruptionWarnings = [];\n131:   let lineNumber = 0;\n132: \n133:   for (const rawLine of jsonlContent.split('\\n')) {\n134:     lineNumber += 1;\n135:     const line = rawLine.trim();\n136:     if (!line) {\n137:       continue;\n138:     }\n139: \n140:     try {\n141:       records.push(JSON.parse(line));\n142:     } catch (error) {\n143:       corruptionWarnings.push({\n144:         line: lineNumber,\n145:         raw: rawLine.length > 200 ? `${rawLine.slice(0, 200)}...` : rawLine,\n146:         error: error instanceof Error ? error.message : String(error),\n147:       });\n148:     }\n149:   }\n150: \n151:   return { records, corruptionWarnings };\n152: }\n153: \n154: function loadDeltaPayloads(deltaDir) {\n155:   if (!fs.existsSync(deltaDir)) {\n156:     return [];\n157:   }\n158: \n159:   return fs.readdirSync(deltaDir)\n160:     .filter((fileName) => /^iter-\\d+\\.jsonl$/.test(fileName))\n161:     .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }))\n162:     .map((fileName) => {\n163:       const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(path.join(deltaDir, fileName)));\n164:       if (!corruptionWarnings.length) {\n165:         return records;\n166:       }\n167:       console.warn(\n168:         `[deep-review] resource-map extractor skipped ${corruptionWarnings.length} malformed delta row(s) from ${fileName}`,\n169:       );\n170:       return records.concat(new Array(corruptionWarnings.length).fill(null));\n171:     });\n172: }\n173: \n174: function extractSection(markdown, heading) {\n175:   const pattern = new RegExp(`(?:^|\\\\n)##\\\\s+${escapeRegExp(heading)}\\\\s*\\\\n([\\\\s\\\\S]*?)(?=\\\\n##\\\\s|$)`, 'i');\n176:   const match = markdown.match(pattern);\n177:   return match ? match[1].trim() : '';\n178: }\n179: \n180: function extractSubsection(sectionText, subheading) {\n181:   const pattern = new RegExp(`(?:^|\\\\n)###\\\\s+${escapeRegExp(subheading)}[^\\\\n]*\\\\n([\\\\s\\\\S]*?)(?=\\\\n###\\\\s|\\\\n##\\\\s|$)`, 'i');\n182:   const match = sectionText.match(pattern);\n183:   return match ? match[1].trim() : '';\n184: }\n185: \n186: function extractListItems(sectionText) {\n187:   return sectionText\n188:     .split('\\n')\n189:     .map((line) => line.trim())\n190:     .filter((line) => /^([-*]|\\d+\\.)\\s+/.test(line))\n191:     .map((line) => normalizeText(line.replace(/^([-*]|\\d+\\.)\\s+/, '')))\n192:     .filter(Boolean);\n193: }\n194: \n195: /**\n196:  * Parse a finding line of the form: `- **F001**: Title — file:line — Description`\n197:  *\n198:  * @param {string} line - Raw finding bullet\n199:  * @param {string} severity - P0, P1, or P2 context\n200:  * @returns {Object|null} Structured finding or null when the line is not a finding\n201:  */\n202: function parseFindingLine(line, severity) {\n203:   const match = line.match(/^\\*\\*(F\\d+)\\*\\*\\s*:\\s*(.+?)(?:\\s+[—-]\\s+`?([^`]+?)`?)?(?:\\s+[—-]\\s+(.+))?$/);\n204:   if (!match) {\n205:     return null;\n206:   }\n207: \n208:   const [, findingId, title, evidenceRaw, description] = match;\n209:   let file = null;\n210:   let lineNumber = null;\n211: \n212:   if (evidenceRaw) {\n213:     const evidenceMatch = evidenceRaw.trim().match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n214:     if (evidenceMatch) {\n215:       file = evidenceMatch[1];\n216:       lineNumber = Number(evidenceMatch[2]);\n217:     } else {\n218:       file = evidenceRaw.trim();\n219:     }\n220:   }\n221: \n222:   return {\n223:     findingId,\n224:     severity,\n225:     title: normalizeText(title),\n226:     file,\n227:     line: lineNumber,\n228:     description: normalizeText(description || ''),\n229:   };\n230: }\n231: \n232: function parseFindingsBlock(sectionText, severity) {\n233:   if (!sectionText) {\n234:     return [];\n235:   }\n236: \n237:   return sectionText\n238:     .split('\\n')\n239:     .map((line) => line.trim())\n240:     .filter((line) => /^-\\s+\\*\\*F\\d+\\*\\*/.test(line))\n241:     .map((line) => parseFindingLine(line.replace(/^-\\s+/, ''), severity))\n242:     .filter(Boolean);\n243: }\n244: \n245: /**\n246:  * Parse a single iteration markdown file into a structured review record.\n247:  *\n248:  * @param {string} iterationPath - Absolute path to an iteration-NNN.md file\n249:  * @returns {Object} Parsed iteration with focus, findings, cross-reference, and reflection fields\n250:  */\n\n(Showing lines 1-250 of 2235. Use offset=251 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Review State Reducer                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Review State Reducer                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst REQUIRED_DIMENSIONS = ['correctness', 'security', 'traceability', 'maintainability'];\nconst SEVERITY_KEYS = ['P0', 'P1', 'P2'];\nconst SEVERITY_WEIGHTS = { P0: 10.0, P1: 5.0, P2: 1.0 };\nconst LIVE_LINEAGE_MODES = new Set(['new', 'resume', 'restart']);\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction readUtf8(filePath) {\n  return fs.readFileSync(filePath, 'utf8');\n}\n\nfunction writeUtf8(filePath, content) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.writeFileSync(filePath, content, 'utf8');\n}\n\nfunction readJson(filePath) {\n  return JSON.parse(readUtf8(filePath));\n}\n\nfunction getResourceMapEmitSetting(config) {\n  const nested = config && typeof config === 'object'\n    ? (config.resource_map || config.resourceMap || null)\n    : null;\n  if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n    return nested.emit;\n  }\n  return true;\n}\n\nfunction slugify(value) {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 80) || 'entry';\n}\n\nfunction normalizeText(value) {\n  if (value === null || value === undefined) return '';\n  if (typeof value !== 'string') {\n    try { return String(value).replace(/\\s+/g, ' ').trim(); }\n    catch { return ''; }\n  }\n  return value.replace(/\\s+/g, ' ').trim();\n}\n\nfunction escapeRegExp(value) {\n  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\nfunction zeroSeverityMap() {\n  return { P0: 0, P1: 0, P2: 0 };\n}\n\nfunction isFiniteNumber(value) {\n  return typeof value === 'number' && Number.isFinite(value);\n}\n\nfunction normalizeSeverity(value) {\n  return SEVERITY_KEYS.includes(value) ? value : null;\n}\n\nfunction normalizeLineageMode(value) {\n  const normalized = normalizeText(value).toLowerCase();\n  return LIVE_LINEAGE_MODES.has(normalized) ? normalized : null;\n}\n\nfunction getNestedField(record, fieldName) {\n  if (!record || typeof record !== 'object') {\n    return undefined;\n  }\n  if (record[fieldName] !== undefined) {\n    return record[fieldName];\n  }\n  if (record.details && typeof record.details === 'object' && record.details[fieldName] !== undefined) {\n    return record.details[fieldName];\n  }\n  return undefined;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. PARSERS\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Parse JSONL content into an array of records, preserving both iteration and\n * event rows. Backward-compatible array return.\n *\n * @param {string} jsonlContent - Newline-delimited JSON string\n * @returns {Array<Object>} Parsed records (corrupt lines silently dropped — use parseJsonlDetailed for fail-closed behavior)\n */\nfunction parseJsonl(jsonlContent) {\n  return parseJsonlDetailed(jsonlContent).records;\n}\n\n/**\n * Parse JSONL content and report malformed lines (fail-closed pathway).\n *\n * Returns both the parsed records and a corruption warning list. The reducer\n * exit code is non-zero when warnings are present unless `--lenient` is passed.\n *\n * @param {string} jsonlContent - Newline-delimited JSON string\n * @returns {{records: Array<Object>, corruptionWarnings: Array<{line: number, raw: string, error: string}>}}\n */\nfunction parseJsonlDetailed(jsonlContent) {\n  const records = [];\n  const corruptionWarnings = [];\n  let lineNumber = 0;\n\n  for (const rawLine of jsonlContent.split('\\n')) {\n    lineNumber += 1;\n    const line = rawLine.trim();\n    if (!line) {\n      continue;\n    }\n\n    try {\n      records.push(JSON.parse(line));\n    } catch (error) {\n      corruptionWarnings.push({\n        line: lineNumber,\n        raw: rawLine.length > 200 ? `${rawLine.slice(0, 200)}...` : rawLine,\n        error: error instanceof Error ? error.message : String(error),\n      });\n    }\n  }\n\n  return { records, corruptionWarnings };\n}\n\nfunction loadDeltaPayloads(deltaDir) {\n  if (!fs.existsSync(deltaDir)) {\n    return [];\n  }\n\n  return fs.readdirSync(deltaDir)\n    .filter((fileName) => /^iter-\\d+\\.jsonl$/.test(fileName))\n    .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }))\n    .map((fileName) => {\n      const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(path.join(deltaDir, fileName)));\n      if (!corruptionWarnings.length) {\n        return records;\n      }\n      console.warn(\n        `[deep-review] resource-map extractor skipped ${corruptionWarnings.length} malformed delta row(s) from ${fileName}`,\n      );\n      return records.concat(new Array(corruptionWarnings.length).fill(null));\n    });\n}\n\nfunction extractSection(markdown, heading) {\n  const pattern = new RegExp(`(?:^|\\\\n)##\\\\s+${escapeRegExp(heading)}\\\\s*\\\\n([\\\\s\\\\S]*?)(?=\\\\n##\\\\s|$)`, 'i');\n  const match = markdown.match(pattern);\n  return match ? match[1].trim() : '';\n}\n\nfunction extractSubsection(sectionText, subheading) {\n  const pattern = new RegExp(`(?:^|\\\\n)###\\\\s+${escapeRegExp(subheading)}[^\\\\n]*\\\\n([\\\\s\\\\S]*?)(?=\\\\n###\\\\s|\\\\n##\\\\s|$)`, 'i');\n  const match = sectionText.match(pattern);\n  return match ? match[1].trim() : '';\n}\n\nfunction extractListItems(sectionText) {\n  return sectionText\n    .split('\\n')\n    .map((line) => line.trim())\n    .filter((line) => /^([-*]|\\d+\\.)\\s+/.test(line))\n    .map((line) => normalizeText(line.replace(/^([-*]|\\d+\\.)\\s+/, '')))\n    .filter(Boolean);\n}\n\n/**\n * Parse a finding line of the form: `- **F001**: Title — file:line — Description`\n *\n * @param {string} line - Raw finding bullet\n * @param {string} severity - P0, P1, or P2 context\n * @returns {Object|null} Structured finding or null when the line is not a finding\n */\nfunction parseFindingLine(line, severity) {\n  const match = line.match(/^\\*\\*(F\\d+)\\*\\*\\s*:\\s*(.+?)(?:\\s+[—-]\\s+`?([^`]+?)`?)?(?:\\s+[—-]\\s+(.+))?$/);\n  if (!match) {\n    return null;\n  }\n\n  const [, findingId, title, evidenceRaw, description] = match;\n  let file = null;\n  let lineNumber = null;\n\n  if (evidenceRaw) {\n    const evidenceMatch = evidenceRaw.trim().match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n    if (evidenceMatch) {\n      file = evidenceMatch[1];\n      lineNumber = Number(evidenceMatch[2]);\n    } else {\n      file = evidenceRaw.trim();\n    }\n  }\n\n  return {\n    findingId,\n    severity,\n    title: normalizeText(title),\n    file,\n    line: lineNumber,\n    description: normalizeText(description || ''),\n  };\n}\n\nfunction parseFindingsBlock(sectionText, severity) {\n  if (!sectionText) {\n    return [];\n  }\n\n  return sectionText\n    .split('\\n')\n    .map((line) => line.trim())\n    .filter((line) => /^-\\s+\\*\\*F\\d+\\*\\*/.test(line))\n    .map((line) => parseFindingLine(line.replace(/^-\\s+/, ''), severity))\n    .filter(Boolean);\n}\n\n/**\n * Parse a single iteration markdown file into a structured review record.\n *\n * @param {string} iterationPath - Absolute path to an iteration-NNN.md file\n * @returns {Object} Parsed iteration with focus, findings, cross-reference, and reflection fields\n */","lineStart":1,"lineEnd":250,"totalLines":2235,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","time":{"start":1784210764517,"end":1784210764528}},"metadata":{"openai":{"itemId":"fc_0c02ec28285e3b78016a58e54c32bc819b83f4ba4cc53f4302"}},"id":"prt_f6b3fb28e001lpuL48aPD6hog4","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3f8c39001RSF6WtTQz3aLy2"}}
