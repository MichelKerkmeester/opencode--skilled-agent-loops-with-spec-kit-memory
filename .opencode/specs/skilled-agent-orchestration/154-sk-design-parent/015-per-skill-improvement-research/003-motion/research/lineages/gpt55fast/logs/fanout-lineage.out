 \"score\": 54\n    },\n    \"D2\": {\n      \"points\": 20,\n      \"score\": 91\n    },\n    \"D3\": {\n      \"points\": 15,\n      \"score\": 57\n    },\n    \"D4\": {\n      \"points\": 25,\n      \"score\": null,\n      \"status\": \"unscored-mode-a\"\n    },\n    \"D5\": {\n      \"points\": 15,\n      \"score\": 100,\n      \"hardGate\": true\n    }\n  },\n  \"unscoredDimensions\": [\n    \"D1inter\",\n    \"D4\"\n  ],\n  \"advisorySignals\": {\n    \"D4_task_outcome\": {\n      \"score\": null,\n      \"status\": \"unscored (run --d4 in live mode)\",\n      \"note\": \"task-outcome usefulness delta; separate from D4 hallucination, never summed into it\"\n    },\n    \"assetRecall\": {\n      \"score\": null,\n      \"status\": \"deferred (router) or no asset gold\",\n      \"note\": \"deferred-asset support recall; advisory, not weighted\"\n    },\n    \"modePrecision\": {\n      \"score\": null,\n      \"status\": \"unscored (no mode-routing probe or no expected.mode)\",\n      \"note\": \"advisor deep-loop mode match vs fixture expected.mode; advisory, gate stays skill-id\"\n    }\n  },\n  \"funnel\": {\n    \"passed\": 12,\n    \"routed-intra\": 2\n  },\n  \"headlineBottleneck\": \"routed-intra\",\n  \"bottlenecks\": [\n    {\n      \"class\": \"funnel_attrition\",\n      \"severity\": \"P1\",\n      \"stage\": \"routed-intra\",\n      \"detail\": \"2 scenario(s) first fail at stage 'routed-intra'\"\n    }\n  ],\n  \"coverage\": {\n    \"routing\": 14,\n    \"advisor\": 0,\n    \"browser\": 0,\n    \"routedOut\": 0,\n    \"scored\": 14\n  },\n  \"divergence\": [],\n  \"lintFindings\": [],\n  \"scenarioRows\": [\n    {\n      \"scenarioId\": \"ID-014\",\n      \"tier\": \"live\",\n      \"dims\": {\n        \"d1intra\": {\n          \"score\": 0.6,\n          \"intentRecall\": 0,\n          \"resourceRecall\": 1,\n          \"negative\": false\n        },\n        \"d2\": {\n          \"score\": 1,\n          \"proxy\": \"router-replay-recall\",\n        