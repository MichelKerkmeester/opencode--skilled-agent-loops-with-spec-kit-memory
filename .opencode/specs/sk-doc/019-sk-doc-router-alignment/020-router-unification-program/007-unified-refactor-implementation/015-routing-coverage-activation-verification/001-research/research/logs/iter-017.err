    56	  if (!report.topologyDigest) {
    57	    problems.push('missing provenance: topologyDigest (manifest digest)');
    58	  }
    59	  for (const row of [...excluded, ...gatedRows]) {
    60	    if (!row.scenarioId) problems.push('missing provenance: a gated/excluded row has no scenarioId');
    61	  }
    62	  return problems;
    63	}
