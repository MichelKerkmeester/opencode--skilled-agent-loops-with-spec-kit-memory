{"type":"tool_use","timestamp":1783486629349,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_WUk9SifcbdXEzf3l6mO1jrCX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":421,"limit":450},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n421:       event: 'assignment_model_rejected',\n422:       severity: 'warning',\n423:       at: new Date().toISOString(),\n424:       run_id: runId,\n425:       loop_type: loopType,\n426:       spec_folder: specFolder,\n427:       planner_status: wavePlanner.status,\n428:       fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n429:       ...rejection,\n430:     });\n431:   }\n432: }\n433: \n434: // Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\n435: const SPECKIT_STATE_ENV_BY_KIND = {\n436:   'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n437:   'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n438: };\n439: \n440: const activeLineageProcesses = new Set();\n441: const WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\n442: const WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\n443: const WAIT_SLEEP_CHUNK_MS = 200;\n444: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n445: const DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n446: \n447: function stopActiveLineageProcesses(signal) {\n448:   for (const child of activeLineageProcesses) {\n449:     terminateLineageProcess(child, signal);\n450:   }\n451: }\n452: \n453: function expandHomeDir(inputPath) {\n454:   if (inputPath === '~') {\n455:     return os.homedir();\n456:   }\n457:   if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n458:     return path.join(os.homedir(), inputPath.slice(2));\n459:   }\n460:   return inputPath;\n461: }\n462: \n463: function isPathInside(childPath, parentPath) {\n464:   const relative = path.relative(parentPath, childPath);\n465:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n466: }\n467: \n468: function physicalPathForValidation(targetPath) {\n469:   try {\n470:     return fs.realpathSync.native(targetPath);\n471:   } catch {\n472:     const parentPath = path.dirname(targetPath);\n473:     try {\n474:       return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n475:     } catch {\n476:       return targetPath;\n477:     }\n478:   }\n479: }\n480: \n481: function validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n482:   if (baseArtifactDir.includes('\\0')) {\n483:     throw inputError('baseArtifactDir must not contain null bytes');\n484:   }\n485:   if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n486:     throw inputError('baseArtifactDir must not contain \"..\" path segments');\n487:   }\n488:   const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n489:   const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n490:   const expectedRoot = path.join(resolvedSpecFolder, loopType);\n491:   if (!isPathInside(resolvedBase, expectedRoot)) {\n492:     throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n493:   }\n494:   return baseArtifactDir;\n495: }\n496: \n497: function validateClaudeConfigDir(configDir) {\n498:   if (typeof configDir !== 'string' || configDir.trim() === '') {\n499:     throw inputError('configDir must be a non-empty string when set');\n500:   }\n501:   validateNamespaceValue(configDir, 'configDir', inputError);\n502: \n503:   const expanded = expandHomeDir(configDir);\n504:   const resolved = path.resolve(process.cwd(), expanded);\n505:   const homeDir = path.resolve(os.homedir());\n506:   const cwd = path.resolve(process.cwd());\n507:   const homeRelative = path.relative(homeDir, resolved);\n508:   const cwdRelative = path.relative(cwd, resolved);\n509:   const homeTop = homeRelative.split(path.sep)[0] || '';\n510:   const cwdTop = cwdRelative.split(path.sep)[0] || '';\n511:   const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n512: \n513:   if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n514:     return resolved;\n515:   }\n516:   if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n517:     return resolved;\n518:   }\n519:   throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n520: }\n521: \n522: function terminateLineageProcess(child, signal) {\n523:   if (!child || child.killed) return;\n524:   if (process.platform !== 'win32' && child.pid) {\n525:     try {\n526:       process.kill(-child.pid, signal);\n527:       return;\n528:     } catch (error) {\n529:       if (error && error.code !== 'ESRCH') {\n530:         try {\n531:           child.kill(signal);\n532:         } catch {\n533:           // The process may have already exited between the group and direct kill attempts.\n534:         }\n535:       }\n536:       return;\n537:     }\n538:   }\n539:   try {\n540:     child.kill(signal);\n541:   } catch {\n542:     // The process may have already exited.\n543:   }\n544: }\n545: \n546: function expectedLineageArtifactPaths(loopType, lineageDir) {\n547:   assertActiveFanoutLoopType(loopType);\n548:   if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n549:   return [path.join(lineageDir, 'research.md')];\n550: }\n551: \n552: function hasNonEmptyFile(filePath) {\n553:   try {\n554:     return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n555:   } catch {\n556:     return false;\n557:   }\n558: }\n559: \n560: function findMissingLineageArtifacts(loopType, lineageDir) {\n561:   return expectedLineageArtifactPaths(loopType, lineageDir)\n562:     .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n563: }\n564: \n565: function parseJsonlRecords(filePath) {\n566:   const text = fs.readFileSync(filePath, 'utf8');\n567:   return text\n568:     .split(/\\r?\\n/)\n569:     .filter((line) => line.trim() !== '')\n570:     .map((line) => JSON.parse(line));\n571: }\n572: \n573: function lineageStateLogName(loopType) {\n574:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n575: }\n576: \n577: function readLineageStateRecords(loopType, lineageDir) {\n578:   const stateLogName = lineageStateLogName(loopType);\n579:   if (!stateLogName) {\n580:     return { statePath: null, records: [], missing: true, parseError: null };\n581:   }\n582:   const statePath = path.join(lineageDir, stateLogName);\n583:   if (!hasNonEmptyFile(statePath)) {\n584:     return { statePath, records: [], missing: true, parseError: null };\n585:   }\n586:   try {\n587:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n588:   } catch (error) {\n589:     return {\n590:       statePath,\n591:       records: [],\n592:       missing: false,\n593:       parseError: error instanceof Error ? error.message : String(error),\n594:     };\n595:   }\n596: }\n597: \n598: // A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n599: // spelling. The iteration-count check above already proves the lineage ran every iteration,\n600: // so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n601: // \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n602: // such as convergence, a manual stop, or an error.\n603: function isMaxIterationsStopReason(stopReason) {\n604:   if (typeof stopReason !== 'string') return false;\n605:   return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n606: }\n607: \n608: function findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n609:   if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n610:   if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n611:     return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n612:   }\n613: \n614:   if (!stateRead || stateRead.missing) {\n615:     return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n616:   }\n617:   if (stateRead.parseError) {\n618:     return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n619:   }\n620: \n621:   const records = stateRead.records;\n622:   const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n623:   const synthesis = [...records]\n624:     .reverse()\n625:     .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n626:   if (!synthesis) {\n627:     return 'missing synthesis_complete event for max-iterations stop-policy validation';\n628:   }\n629: \n630:   const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n631:     ? Number(synthesis.totalIterations)\n632:     : iterationCount;\n633:   if (totalIterations !== lineage.iterations) {\n634:     return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n635:   }\n636:   if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n637:     return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n638:   }\n639:   return null;\n640: }\n641: \n642: function isRecord(value) {\n643:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n644: }\n645: \n646: function normalizeStallWatchdogMs(rawConfig) {\n647:   // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n648:   // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n649:   // because this knob is intentionally outside fanoutConfigSchema. Set 0 to opt out.\n650:   return readRawConfigNumber(rawConfig, [\n651:     'stallWatchdogMs',\n652:     'stall_watchdog_ms',\n653:     'stallWatchdogMillis',\n654:     'stall_watchdog_millis',\n655:   ], 'stallWatchdogMs') ?? 300000;\n656: }\n657: \n658: function normalizeLineageBudgetGuards(rawConfig = {}) {\n659:   return {\n660:     max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n661:       'maxCostUnitsPerLineage',\n662:       'max_cost_units_per_lineage',\n663:       'maxLineageCostUnits',\n664:       'max_lineage_cost_units',\n665:       'maxTokensPerLineage',\n666:       'max_tokens_per_lineage',\n667:       'maxTokenBudget',\n668:       'max_token_budget',\n669:       'maxTokenBudgetPerLineage',\n670:       'max_token_budget_per_lineage',\n671:     ], 'maxCostUnitsPerLineage') ?? 0,\n672:     cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n673:       'costUnitsPerIteration',\n674:       'cost_units_per_iteration',\n675:       'estimatedTokensPerIteration',\n676:       'estimated_tokens_per_iteration',\n677:     ], 'costUnitsPerIteration', 1),\n678:   };\n679: }\n680: \n681: function computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n682:   const guards = normalizeLineageBudgetGuards(guardsInput);\n683:   const rawIterations = Number(lineage && lineage.iterations);\n684:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n685:   return {\n686:     ...guards,\n687:     iterations,\n688:     estimated_cost_units: iterations * guards.cost_units_per_iteration,\n689:   };\n690: }\n691: \n692: function evaluateLineageBudgetCap(input = {}) {\n693:   const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n694:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n695:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n696:   return {\n697:     continue_allowed: !exceeded,\n698:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n699:     upper_bound: upperBound,\n700:   };\n701: }\n702: \n703: function buildTimestampAnomalyCounts(check) {\n704:   return {\n705:     anomalous: check.anomalous,\n706:     untimestamped: check.untimestamped,\n707:     unparseable: check.unparseable,\n708:     total: check.total,\n709:   };\n710: }\n711: \n712: function buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n713:   return {\n714:     label: lineage.label,\n715:     state_log: statePath,\n716:     window: {\n717:       start_at_iso: check.windowStart,\n718:       end_at_iso: check.windowEnd,\n719:       tolerance_ms: check.toleranceMs,\n720:     },\n721:     counts: buildTimestampAnomalyCounts(check),\n722:     sample: check.sample,\n723:   };\n724: }\n725: \n726: function collectTimestampAnomalies(results) {\n727:   return results\n728:     .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n729:     .map((result) => result.output.timestamp_anomaly);\n730: }\n731: \n732: function normalizeNonNegativeDelayMs(value) {\n733:   if (value === undefined || value === null) return null;\n734:   const n = Number(value);\n735:   if (!Number.isFinite(n) || n < 0) return null;\n736:   return Math.floor(n);\n737: }\n738: \n739: function normalizeWaitDurationMs(value) {\n740:   return normalizeNonNegativeDelayMs(value) ?? 0;\n741: }\n742: \n743: function waitCheckpointPath(baseArtifactDir) {\n744:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n745: }\n746: \n747: function atomicWriteJson(filePath, payload) {\n748:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n749:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n750:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n751:   fs.renameSync(tmpPath, filePath);\n752: }\n753: \n754: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n755:   const durationMs = normalizeWaitDurationMs(waitMs);\n756:   const updatedAt = new Date(nowMs).toISOString();\n757:   if (durationMs <= 0) {\n758:     return {\n759:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n760:       status: 'idle',\n761:       nextRunAt: null,\n762:       remainingDelayMs: null,\n763:       updatedAt,\n764:       runId,\n765:       loopType,\n766:       specFolder,\n767:     };\n768:   }\n769: \n770:   return {\n771:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n772:     status: 'waiting',\n773:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n774:     remainingDelayMs: durationMs,\n775:     updatedAt,\n776:     runId,\n777:     loopType,\n778:     specFolder,\n779:   };\n780: }\n781: \n782: function normalizeWaitCheckpoint(raw, context) {\n783:   if (!isRecord(raw)) {\n784:     throw inputError('wait checkpoint must be a JSON object');\n785:   }\n786: \n787:   const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n788:   const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n789:   const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n790:   const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n791:     ? raw.nextRunAt\n792:     : null;\n793:   const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n794:   const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n795:   const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n796:   const base = {\n797:     runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n798:     loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n799:     specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n800:   };\n801: \n802:   const checkpoint = waiting\n803:     ? {\n804:         schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n805:         status: 'waiting',\n806:         nextRunAt,\n807:         remainingDelayMs,\n808:         updatedAt: new Date(nowMs).toISOString(),\n809:         ...base,\n810:       }\n811:     : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n812:   const staleWaitingFields = !waiting\n813:     && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n814:   const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n815: \n816:   return {\n817:     checkpoint,\n818:     migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n819:   };\n820: }\n821: \n822: function readWaitCheckpoint(checkpointPath, context) {\n823:   if (!fs.existsSync(checkpointPath)) {\n824:     return { exists: false, checkpoint: null, migrated: false };\n825:   }\n826: \n827:   let raw;\n828:   try {\n829:     raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n830:   } catch (error) {\n831:     throw inputError(\n832:       `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n833:     );\n834:   }\n835: \n836:   const normalized = normalizeWaitCheckpoint(raw, context);\n837:   if (normalized.migrated) {\n838:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n839:   }\n840:   return { exists: true, ...normalized };\n841: }\n842: \n843: function sleepWaitChunk(ms) {\n844:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n845: }\n846: \n847: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n848:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n849:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n850: \n851:   while (remainingDelayMs > 0) {\n852:     atomicWriteJson(checkpointPath, {\n853:       ...checkpoint,\n854:       remainingDelayMs,\n855:       updatedAt: new Date().toISOString(),\n856:     });\n857:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n858:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n859:   }\n860: \n861:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n862: }\n863: \n864: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n865:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n866:   const loaded = readWaitCheckpoint(checkpointPath, context);\n867:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n868:     return { didWait: false, migrated: loaded.migrated };\n869:   }\n870: \n\n(Showing lines 421-870 of 1871. Use offset=871 to continue.)\n</content>","metadata":{"preview":"      event: 'assignment_model_rejected',\n      severity: 'warning',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      planner_status: wavePlanner.status,\n      fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      ...rejection,\n    });\n  }\n}\n\n// Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\nconst SPECKIT_STATE_ENV_BY_KIND = {\n  'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n  'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n};\n\nconst activeLineageProcesses = new Set();","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"      event: 'assignment_model_rejected',\n      severity: 'warning',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      planner_status: wavePlanner.status,\n      fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      ...rejection,\n    });\n  }\n}\n\n// Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\nconst SPECKIT_STATE_ENV_BY_KIND = {\n  'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n  'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n};\n\nconst activeLineageProcesses = new Set();\nconst WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\nconst WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\nconst WAIT_SLEEP_CHUNK_MS = 200;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\nconst DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n\nfunction stopActiveLineageProcesses(signal) {\n  for (const child of activeLineageProcesses) {\n    terminateLineageProcess(child, signal);\n  }\n}\n\nfunction expandHomeDir(inputPath) {\n  if (inputPath === '~') {\n    return os.homedir();\n  }\n  if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n    return path.join(os.homedir(), inputPath.slice(2));\n  }\n  return inputPath;\n}\n\nfunction isPathInside(childPath, parentPath) {\n  const relative = path.relative(parentPath, childPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction physicalPathForValidation(targetPath) {\n  try {\n    return fs.realpathSync.native(targetPath);\n  } catch {\n    const parentPath = path.dirname(targetPath);\n    try {\n      return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n    } catch {\n      return targetPath;\n    }\n  }\n}\n\nfunction validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n  if (baseArtifactDir.includes('\\0')) {\n    throw inputError('baseArtifactDir must not contain null bytes');\n  }\n  if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n    throw inputError('baseArtifactDir must not contain \"..\" path segments');\n  }\n  const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n  const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n  const expectedRoot = path.join(resolvedSpecFolder, loopType);\n  if (!isPathInside(resolvedBase, expectedRoot)) {\n    throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n  }\n  return baseArtifactDir;\n}\n\nfunction validateClaudeConfigDir(configDir) {\n  if (typeof configDir !== 'string' || configDir.trim() === '') {\n    throw inputError('configDir must be a non-empty string when set');\n  }\n  validateNamespaceValue(configDir, 'configDir', inputError);\n\n  const expanded = expandHomeDir(configDir);\n  const resolved = path.resolve(process.cwd(), expanded);\n  const homeDir = path.resolve(os.homedir());\n  const cwd = path.resolve(process.cwd());\n  const homeRelative = path.relative(homeDir, resolved);\n  const cwdRelative = path.relative(cwd, resolved);\n  const homeTop = homeRelative.split(path.sep)[0] || '';\n  const cwdTop = cwdRelative.split(path.sep)[0] || '';\n  const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n\n  if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n    return resolved;\n  }\n  if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n    return resolved;\n  }\n  throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {\n    child.kill(signal);\n  } catch {\n    // The process may have already exited.\n  }\n}\n\nfunction expectedLineageArtifactPaths(loopType, lineageDir) {\n  assertActiveFanoutLoopType(loopType);\n  if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n  return [path.join(lineageDir, 'research.md')];\n}\n\nfunction hasNonEmptyFile(filePath) {\n  try {\n    return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n  } catch {\n    return false;\n  }\n}\n\nfunction findMissingLineageArtifacts(loopType, lineageDir) {\n  return expectedLineageArtifactPaths(loopType, lineageDir)\n    .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n}\n\nfunction parseJsonlRecords(filePath) {\n  const text = fs.readFileSync(filePath, 'utf8');\n  return text\n    .split(/\\r?\\n/)\n    .filter((line) => line.trim() !== '')\n    .map((line) => JSON.parse(line));\n}\n\nfunction lineageStateLogName(loopType) {\n  return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n}\n\nfunction readLineageStateRecords(loopType, lineageDir) {\n  const stateLogName = lineageStateLogName(loopType);\n  if (!stateLogName) {\n    return { statePath: null, records: [], missing: true, parseError: null };\n  }\n  const statePath = path.join(lineageDir, stateLogName);\n  if (!hasNonEmptyFile(statePath)) {\n    return { statePath, records: [], missing: true, parseError: null };\n  }\n  try {\n    return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n  } catch (error) {\n    return {\n      statePath,\n      records: [],\n      missing: false,\n      parseError: error instanceof Error ? error.message : String(error),\n    };\n  }\n}\n\n// A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n// spelling. The iteration-count check above already proves the lineage ran every iteration,\n// so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n// \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n// such as convergence, a manual stop, or an error.\nfunction isMaxIterationsStopReason(stopReason) {\n  if (typeof stopReason !== 'string') return false;\n  return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n}\n\nfunction findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n  if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n  if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n    return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n  }\n\n  if (!stateRead || stateRead.missing) {\n    return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n  }\n  if (stateRead.parseError) {\n    return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n  }\n\n  const records = stateRead.records;\n  const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n  const synthesis = [...records]\n    .reverse()\n    .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n  if (!synthesis) {\n    return 'missing synthesis_complete event for max-iterations stop-policy validation';\n  }\n\n  const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n    ? Number(synthesis.totalIterations)\n    : iterationCount;\n  if (totalIterations !== lineage.iterations) {\n    return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n  }\n  if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n    return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n  }\n  return null;\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n  // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n  // because this knob is intentionally outside fanoutConfigSchema. Set 0 to opt out.\n  return readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs') ?? 300000;\n}\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? 0,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  return {\n    ...guards,\n    iterations,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction buildTimestampAnomalyCounts(check) {\n  return {\n    anomalous: check.anomalous,\n    untimestamped: check.untimestamped,\n    unparseable: check.unparseable,\n    total: check.total,\n  };\n}\n\nfunction buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n  return {\n    label: lineage.label,\n    state_log: statePath,\n    window: {\n      start_at_iso: check.windowStart,\n      end_at_iso: check.windowEnd,\n      tolerance_ms: check.toleranceMs,\n    },\n    counts: buildTimestampAnomalyCounts(check),\n    sample: check.sample,\n  };\n}\n\nfunction collectTimestampAnomalies(results) {\n  return results\n    .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n    .map((result) => result.output.timestamp_anomaly);\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };\n}\n\nfunction normalizeWaitCheckpoint(raw, context) {\n  if (!isRecord(raw)) {\n    throw inputError('wait checkpoint must be a JSON object');\n  }\n\n  const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n  const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n  const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n  const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n    ? raw.nextRunAt\n    : null;\n  const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n  const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n  const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n  const base = {\n    runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n    loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n    specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n  };\n\n  const checkpoint = waiting\n    ? {\n        schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n        status: 'waiting',\n        nextRunAt,\n        remainingDelayMs,\n        updatedAt: new Date(nowMs).toISOString(),\n        ...base,\n      }\n    : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n  const staleWaitingFields = !waiting\n    && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n  const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n\n  return {\n    checkpoint,\n    migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n  };\n}\n\nfunction readWaitCheckpoint(checkpointPath, context) {\n  if (!fs.existsSync(checkpointPath)) {\n    return { exists: false, checkpoint: null, migrated: false };\n  }\n\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n  } catch (error) {\n    throw inputError(\n      `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n\n  const normalized = normalizeWaitCheckpoint(raw, context);\n  if (normalized.migrated) {\n    atomicWriteJson(checkpointPath, normalized.checkpoint);\n  }\n  return { exists: true, ...normalized };\n}\n\nfunction sleepWaitChunk(ms) {\n  return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n}\n\nasync function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n  const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n  let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n\n  while (remainingDelayMs > 0) {\n    atomicWriteJson(checkpointPath, {\n      ...checkpoint,\n      remainingDelayMs,\n      updatedAt: new Date().toISOString(),\n    });\n    await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n    remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n  }\n\n  atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n}\n\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n","lineStart":421,"lineEnd":870,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783486629332,"end":1783486629348}},"metadata":{"openai":{"itemId":"fc_096bb8aa26ac5d84016a4dd8a546e48191a5062aa911aaacbd"}},"id":"prt_f401645c2001dLn7O22aw06SBb","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f401627ad001C87wmULd5RnCr1"}}
{"type":"tool_use","timestamp":1783486629355,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_6huCRNfq5oVeRau1kszz9Tok","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":871,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n871:   appendFanoutStatusLedger(ledgerPath, {\n872:     event: 'resume_waiting',\n873:     at: new Date().toISOString(),\n874:     run_id: runId,\n875:     loop_type: loopType,\n876:     spec_folder: specFolder,\n877:     nextRunAt: loaded.checkpoint.nextRunAt,\n878:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n879:   });\n880: \n881:   await waitUntilCheckpointExpires({\n882:     checkpointPath,\n883:     checkpoint: loaded.checkpoint,\n884:     context: { runId, loopType, specFolder },\n885:   });\n886: \n887:   appendFanoutStatusLedger(ledgerPath, {\n888:     event: 'resume_waiting_complete',\n889:     at: new Date().toISOString(),\n890:     run_id: runId,\n891:     loop_type: loopType,\n892:     spec_folder: specFolder,\n893:   });\n894: \n895:   return { didWait: true, migrated: loaded.migrated };\n896: }\n897: \n898: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n899:   const durationMs = normalizeWaitDurationMs(waitMs);\n900:   if (durationMs <= 0) {\n901:     return { didWait: false };\n902:   }\n903: \n904:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n905:   atomicWriteJson(checkpointPath, checkpoint);\n906:   appendFanoutStatusLedger(ledgerPath, {\n907:     event: 'wait_checkpoint_persisted',\n908:     at: checkpoint.updatedAt,\n909:     run_id: runId,\n910:     loop_type: loopType,\n911:     spec_folder: specFolder,\n912:     nextRunAt: checkpoint.nextRunAt,\n913:     remainingDelayMs: checkpoint.remainingDelayMs,\n914:   });\n915: \n916:   await waitUntilCheckpointExpires({\n917:     checkpointPath,\n918:     checkpoint,\n919:     context: { runId, loopType, specFolder },\n920:   });\n921: \n922:   appendFanoutStatusLedger(ledgerPath, {\n923:     event: 'wait_checkpoint_cleared',\n924:     at: new Date().toISOString(),\n925:     run_id: runId,\n926:     loop_type: loopType,\n927:     spec_folder: specFolder,\n928:   });\n929: \n930:   return { didWait: true };\n931: }\n932: \n933: /**\n934:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n935:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n936:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n937:  */\n938: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n939:   assertActiveFanoutLoopType(loopType);\n940:   const skillFile =\n941:     loopType === 'review'\n942:       ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n943:       : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n944:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n945:   const detachedIntro = lineage.kind === 'cli-opencode'\n946:     ? [\n947:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n948:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n949:         ``,\n950:       ]\n951:     : lineage.kind === 'native'\n952:       ? [\n953:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n954:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n955:           ``,\n956:         ]\n957:       : [];\n958:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n959:   const stopPolicy = options.stopPolicy || 'convergence';\n960:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n961:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n962:     : hasIterationCap\n963:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n964:       : 'to legal convergence';\n965:   const params = [\n966:     `  spec_folder: ${specFolder}`,\n967:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n968:     `  session_id: ${sessionId}`,\n969:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n970:     `  loop_type: ${loopType}`,\n971:     `  config.stopPolicy: ${stopPolicy}`,\n972:   ];\n973:   if (researchTopic) {\n974:     // A research lineage's phase_init binds research_topic from this line. Without it a\n975:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n976:     // Review loops scope by spec_folder and intentionally pass no topic.\n977:     params.push(`  research_topic: ${researchTopic}`);\n978:   }\n979:   if (hasIterationCap) {\n980:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n981:   }\n982:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n983:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n984:   }\n985:   // Review lineages scope by spec_folder but the auto-workflow preflight\n986:   // still requires the same review setup bindings the native command path pre-binds.\n987:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n988:   // different setup contract than native lineages.\n989:   const setupBindings =\n990:     loopType === 'review'\n991:       ? [\n992:           ``,\n993:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n994:           `review_target: ${specFolder}`,\n995:           `review_target_type: spec-folder`,\n996:           `review_dimensions: all`,\n997:           `spec_folder: ${specFolder}`,\n998:           `execution_mode: AUTONOMOUS`,\n999:           `lineage_mode: auto`,\n1000:           ``,\n1001:         ]\n1002:       : [];\n1003:   return [\n1004:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1005:     ...detachedIntro,\n1006:     ``,\n1007:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1008:     ...params,\n1009:     ...setupBindings,\n1010:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1011:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1012:     `command; bind artifact_dir directly to the override value.`,\n1013:     ``,\n1014:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1015:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1016:     ``,\n1017:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1018:   ].join('\\n');\n1019: }\n1020: \n1021: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1022:   assertActiveFanoutLoopType(loopType);\n1023:   const maxIterations = lineage.iterations || 12;\n1024:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1025:   const stopPolicy = options.stopPolicy || 'convergence';\n1026:   const sessionId = options.sessionId || '';\n1027:   const args = [\n1028:     ':auto',\n1029:     JSON.stringify(specFolder),\n1030:     `--spec-folder=${specFolder}`,\n1031:     `--max-iterations=${maxIterations}`,\n1032:     `--convergence=${convergenceThreshold}`,\n1033:     `--stop-policy=${stopPolicy}`,\n1034:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1035:     '--lineage-mode=auto',\n1036:   ];\n1037:   if (loopType === 'research' && options.researchTopic) {\n1038:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1039:   }\n1040: \n1041:   return [\n1042:     args.join(' '),\n1043:     '',\n1044:     'PRE-BOUND SETUP ANSWERS:',\n1045:     `review_target: ${specFolder}`,\n1046:     'review_target_type: spec-folder',\n1047:     'review_dimensions: all',\n1048:     `spec_folder: ${specFolder}`,\n1049:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1050:     'execution_mode: AUTONOMOUS',\n1051:     'lineage_mode: auto',\n1052:     `maxIterations: ${maxIterations}`,\n1053:     `convergenceThreshold: ${convergenceThreshold}`,\n1054:     `stop_policy: ${stopPolicy}`,\n1055:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1056:   ].join('\\n');\n1057: }\n1058: \n1059: /**\n1060:  * Compute a generous timeout for a full lineage loop run.\n1061:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1062:  * We double it for safety and cap at 4 hours.\n1063:  */\n1064: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1065:   const iters = lineage.iterations || 12;\n1066:   const perIterSecs = lineage.timeoutSeconds || 900;\n1067:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1068:     ? ceilingHoursOverride * 60 * 60 * 1000\n1069:     : 4 * 60 * 60 * 1000;\n1070:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1071: }\n1072: \n1073: function normalizeProgressHeartbeatMs(seconds) {\n1074:   const value = Number(seconds);\n1075:   if (!Number.isFinite(value) || value <= 0) return 0;\n1076:   return Math.max(1, Math.floor(value * 1000));\n1077: }\n1078: \n1079: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1080:   const explicit = readRawConfigNumber(rawConfig, [\n1081:     'postExitGraceMs',\n1082:     'post_exit_grace_ms',\n1083:     'postSubprocessExitGraceMs',\n1084:     'post_subprocess_exit_grace_ms',\n1085:     'orchestratorPostExitGraceMs',\n1086:     'orchestrator_post_exit_grace_ms',\n1087:   ], 'postExitGraceMs');\n1088:   if (explicit !== null) return explicit;\n1089: \n1090:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1091:     ? progressHeartbeatMs * 2\n1092:     : 0;\n1093:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1094: }\n1095: \n1096: function slotDurationMsFromHrtime(hrStart) {\n1097:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1098:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1099: }\n1100: \n1101: function computeSkippedCount(slotDurationMs, intervalMs) {\n1102:   const elapsed = Number(slotDurationMs);\n1103:   const interval = Number(intervalMs);\n1104:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1105:     return 0;\n1106:   }\n1107:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1108: }\n1109: \n1110: function buildSlotAccounting(hrStart, intervalMs) {\n1111:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1112:   return {\n1113:     slotDurationMs,\n1114:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1115:   };\n1116: }\n1117: \n1118: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1119:   if (!event || typeof event.label !== 'string') return event;\n1120:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1121: \n1122:   const accounting = accountingByLabel.get(event.label);\n1123:   if (!accounting) return event;\n1124:   return {\n1125:     ...event,\n1126:     skippedCount: accounting.skippedCount,\n1127:     slotDurationMs: accounting.slotDurationMs,\n1128:   };\n1129: }\n1130: \n1131: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1132:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1133:     return () => {};\n1134:   }\n1135:   const startedAtMs = Date.now();\n1136:   const timer = setInterval(() => {\n1137:     appendFanoutStatusLedger(ledgerPath, {\n1138:       event: 'progress',\n1139:       label,\n1140:       at: new Date().toISOString(),\n1141:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1142:         gauges: getGauges(),\n1143:       });\n1144:       if (typeof onProgress === 'function') onProgress();\n1145:     }, cadenceMs);\n1146:   timer.unref?.();\n1147:   return () => clearInterval(timer);\n1148: }\n1149: \n1150: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1151:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1152:     return () => {};\n1153:   }\n1154: \n1155:   let timer = null;\n1156:   let fired = false;\n1157:   const schedule = () => {\n1158:     if (fired) return;\n1159:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1160:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1161:     timer = setTimeout(() => {\n1162:       timer = null;\n1163:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1164:       if (latestQuietMs >= thresholdMs) {\n1165:         fired = true;\n1166:         appendFanoutStatusLedger(ledgerPath, {\n1167:           event: 'stall_detected',\n1168:           label,\n1169:           at: new Date().toISOString(),\n1170:           severity: 'warning',\n1171:           metric: 'time_since_last_lineage_event',\n1172:           stall_watchdog_ms: thresholdMs,\n1173:           quiet_ms: Math.floor(latestQuietMs),\n1174:           gauges: getGauges(),\n1175:         });\n1176:         return;\n1177:       }\n1178:       schedule();\n1179:     }, delayMs);\n1180:     timer.unref?.();\n1181:   };\n1182: \n1183:   schedule();\n1184:   return () => {\n1185:     fired = true;\n1186:     if (timer) clearTimeout(timer);\n1187:   };\n1188: }\n1189: \n1190: /**\n1191:  * Run a lineage subprocess without blocking the Node event loop.\n1192:  *\n1193:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1194:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1195:  * thread until each child exited, serializing every lineage regardless of the\n1196:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1197:  *\n1198:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1199:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1200:  *\n1201:  * @param {string} command - Executable to run.\n1202:  * @param {string[]} cmdArgs - Arguments for the executable.\n1203:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1204:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1205:  */\n1206: function runLineageProcess(command, cmdArgs, opts) {\n1207:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1208:   const hasInput = typeof opts.input === 'string';\n1209: \n1210:   return new Promise((resolvePromise) => {\n1211:     let child;\n1212:     try {\n1213:       child = spawn(command, cmdArgs, {\n1214:         cwd,\n1215:         env,\n1216:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1217:         detached: process.platform !== 'win32',\n1218:       });\n1219:     } catch (error) {\n1220:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1221:       return;\n1222:     }\n1223:     activeLineageProcesses.add(child);\n1224:     if (typeof opts.onSpawn === 'function') {\n1225:       opts.onSpawn({ pid: child.pid });\n1226:     }\n1227: \n1228:     let stdout = '';\n1229:     let stdoutBytes = 0;\n1230:     let truncated = false;\n1231:     let timedOut = false;\n1232:     let settled = false;\n1233:     let spawnError;\n1234: \n1235:     const timer = setTimeout(() => {\n1236:       timedOut = true;\n1237:       terminateLineageProcess(child, 'SIGTERM');\n1238:     }, timeoutMs);\n1239:     timer.unref?.();\n1240: \n1241:     const abortHandler = () => {\n1242:       terminateLineageProcess(child, 'SIGTERM');\n1243:     };\n1244:     if (opts.abortSignal) {\n1245:       if (opts.abortSignal.aborted) {\n1246:         abortHandler();\n1247:       } else {\n1248:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1249:       }\n1250:     }\n1251: \n1252:     child.stdout?.setEncoding('utf8');\n1253:     child.stdout?.on('data', (chunk) => {\n1254:       if (truncated) return;\n1255:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1256:       if (stdoutBytes > maxBuffer) {\n1257:         truncated = true;\n1258:         terminateLineageProcess(child, 'SIGTERM');\n1259:         return;\n1260:       }\n1261:       stdout += chunk;\n1262:     });\n1263:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1264:     child.stderr?.resume();\n1265: \n1266:     child.on('error', (error) => {\n1267:       spawnError = error;\n1268:     });\n1269: \n1270:     child.on('close', (code, signal) => {\n1271:       if (settled) return;\n1272:       settled = true;\n1273:       activeLineageProcesses.delete(child);\n1274:       clearTimeout(timer);\n1275:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1276:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1277:       if (typeof opts.onExit === 'function') {\n1278:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1279:       }\n1280:       resolvePromise({\n1281:         status: timedOut ? null : code,\n1282:         signal: effectiveSignal,\n1283:         stdout,\n1284:         ...(spawnError ? { error: spawnError } : {}),\n1285:       });\n1286:     });\n1287: \n1288:     if (hasInput) {\n1289:       child.stdin?.on('error', () => {});\n1290:       child.stdin?.end(opts.input);\n1291:     }\n1292:   });\n1293: }\n1294: \n1295: /**\n1296:  * Build the subprocess command for a fan-out lineage.\n1297:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1298:  */\n1299: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1300:   const kind = lineage.kind;\n1301: \n1302:   if (kind === 'cli-claude-code') {\n1303:     const args = [\n1304:       '-p',\n1305:       prompt,\n1306:       '--model',\n1307:       lineage.model || 'claude-opus-4-8',\n1308:       '--permission-mode',\n1309:       resolvedPermission,\n1310:       '--output-format',\n1311:       'text',\n1312:     ];\n1313:     if (lineage.reasoningEffort) {\n1314:       args.push('--effort', lineage.reasoningEffort);\n1315:     }\n1316:     return { command: 'claude', args };\n1317:   }\n1318: \n1319:   if (kind === 'native') {\n1320:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1321:     // For review runs this is the real deep/review command surface with a lineage\n1322:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1323:     const args = [\n1324:       'run',\n1325:       '--format',\n1326:       'json',\n1327:       '--dangerously-skip-permissions',\n1328:       '--dir',\n1329:       process.cwd(),\n1330:       '--command',\n1331:       `deep/${options.loopType || 'review'}`,\n1332:     ];\n1333:     args.push(buildNativeCommandInput(\n1334:       options.loopType || 'review',\n1335:       options.specFolder || '',\n1336:       options.lineageDir || '',\n1337:       lineage,\n1338:       options,\n1339:     ));\n1340:     return { command: 'opencode', args, input: '' };\n1341:   }\n1342: \n1343:   if (kind === 'cli-opencode') {\n1344:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1345:     // on a top-level `run`. The default agent runs when none is named, and a\n1346:     // specific agent profile can be requested in the prompt body instead.\n1347:     const args = [\n1348:       'run',\n1349:       '--model',\n1350:       lineage.model || 'anthropic/claude-opus-4-8',\n1351:       '--format',\n1352:       'json',\n1353:       '--pure',\n1354:       '--dir',\n1355:       process.cwd(),\n1356:     ];\n1357:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1358:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1359:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1360:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1361:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n1362:     // must now opt into full bypass rather than getting it silently by default.\n1363:     const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n1364:     if (useDangerousBypass) {\n1365:       args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n1366:       process.stderr.write(\n1367:         `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n1368:           + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n1369:       );\n1370:     }\n1371:     if (lineage.reasoningEffort) {\n1372:       args.push('--variant', lineage.reasoningEffort);\n1373:     }\n1374:     args.push(prompt);\n1375:     return { command: 'opencode', args, input: '' };\n1376:   }\n1377: \n1378:   throw inputError(`Unknown fan-out executor kind: ${kind}`);\n1379: }\n1380: \n1381: // ─────────────────────────────────────────────────────────────────────────────\n1382: // 4. CORE LOGIC\n1383: // ─────────────────────────────────────────────────────────────────────────────\n1384: \n1385: async function main() {\n1386:   const args = parseArgs();\n1387:   const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n1388:   const loopType = ensureString(args, 'loopType');\n1389:   assertActiveFanoutLoopType(loopType);\n1390:   // Optional shared research question, threaded into each lineage prompt so a research\n\n(Showing lines 871-1390 of 1871. Use offset=1391 to continue.)\n</content>","metadata":{"preview":"  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : 4 * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n    // --dangerously-skip-permissions so their writes are subject to the CLI permission\n    // boundary. opencode has no path-scoped write flag, so a workspace-write review\n    // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n    // must now opt into full bypass rather than getting it silently by default.\n    const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n    if (useDangerousBypass) {\n      args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n      process.stderr.write(\n        `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n          + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n      );\n    }\n    if (lineage.reasoningEffort) {\n      args.push('--variant', lineage.reasoningEffort);\n    }\n    args.push(prompt);\n    return { command: 'opencode', args, input: '' };\n  }\n\n  throw inputError(`Unknown fan-out executor kind: ${kind}`);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const args = parseArgs();\n  const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n  const loopType = ensureString(args, 'loopType');\n  assertActiveFanoutLoopType(loopType);\n  // Optional shared research question, threaded into each lineage prompt so a research","lineStart":871,"lineEnd":1390,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783486629337,"end":1783486629353}},"metadata":{"openai":{"itemId":"fc_096bb8aa26ac5d84016a4dd8a546ec8191a9601fbb41559680"}},"id":"prt_f401645d600102JIgEFbjJgGuh","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f401627ad001C87wmULd5RnCr1"}}
{"type":"tool_use","timestamp":1783486629356,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_wKOlMfqBpL6TrKnxhlz5gzVT","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":1391,"limit":481},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1391:   // fan-out can bind research_topic. Absent for review, which scopes by folder.\n1392:   const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n1393:     ? args.researchTopic.trim()\n1394:     : null;\n1395:   const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n1396:   const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n1397:   const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n1398:   const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n1399:   const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n1400: \n1401:   const {\n1402:     parseFanoutConfig,\n1403:     expandLineages,\n1404:     resolveSandboxMode,\n1405:     resolveClaudePermissionMode,\n1406:   } = await import('../lib/deep-loop/executor-config.ts');\n1407:   const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n1408:   const {\n1409:     DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1410:     checkLineageTimestampWindow,\n1411:   } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n1412: \n1413:   maybeThrowTestFault();\n1414: \n1415:   let rawConfig;\n1416:   try {\n1417:     rawConfig = JSON.parse(fanoutConfigJson);\n1418:   } catch {\n1419:     throw inputError('fanoutConfigJson is not valid JSON');\n1420:   }\n1421: \n1422:   const lineagesDir = path.join(baseArtifactDir, 'lineages');\n1423:   const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n1424:   const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n1425:   const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n1426:   const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n1427:   const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n1428:   const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n1429:   const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n1430:   const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n1431:   const fanoutConfig = guardedAssignment.config;\n1432:   const allLineages = expandLineages(fanoutConfig);\n1433:   const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n1434:   const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n1435:   const slotIntervalMs = progressHeartbeatMs;\n1436: \n1437:   logFlatPoolGuardRejections({\n1438:     rejections: guardedAssignment.rejections,\n1439:     ledgerPath,\n1440:     runId,\n1441:     loopType,\n1442:     specFolder,\n1443:   });\n1444: \n1445:   // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n1446:   // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n1447:   // ownership here so all lineages share the same retries and artifact validation.\n1448:   const cliLineages = allLineages;\n1449:   const checkpointPath = waitCheckpointPath(baseArtifactDir);\n1450:   const resumeWaiting = await resumeWaitingCheckpoint({\n1451:     checkpointPath,\n1452:     ledgerPath,\n1453:     runId,\n1454:     loopType,\n1455:     specFolder,\n1456:   });\n1457:   if (!resumeWaiting.didWait) {\n1458:     await persistPreDispatchWait({\n1459:       checkpointPath,\n1460:       ledgerPath,\n1461:       runId,\n1462:       loopType,\n1463:       specFolder,\n1464:       waitMs: args.preDispatchWaitMs,\n1465:     });\n1466:   }\n1467: \n1468:   if (cliLineages.length === 0) {\n1469:     const summary = {\n1470:       total: 0,\n1471:       succeeded: 0,\n1472:       failed: 0,\n1473:       all_failed: false,\n1474:       gauges: { lag: 0, pending: 0, failed: 0 },\n1475:       convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n1476:     };\n1477:     writeOrchestrationSummary(summaryPath, {\n1478:       run_id: runId,\n1479:       loop_type: loopType,\n1480:       spec_folder: specFolder,\n1481:       base_artifact_dir: baseArtifactDir,\n1482:       total_cli_lineages: 0,\n1483:       ...summary,\n1484:     });\n1485:     jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n1486:     return;\n1487:   }\n1488: \n1489:   fs.mkdirSync(lineagesDir, { recursive: true });\n1490:   const orphanedLineages = markOrphanedLineages(ledgerPath);\n1491:   const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n1492: \n1493:   const lineageSnapshots = new Map();\n1494:   const lineageSlotAccounting = new Map();\n1495:   const lineageProcessLiveness = new Map();\n1496:   let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n1497:   let stoppedSummaryWritten = false;\n1498: \n1499:   const writeStoppedSummary = (signal) => {\n1500:     if (stoppedSummaryWritten) return;\n1501:     stoppedSummaryWritten = true;\n1502:     stopActiveLineageProcesses(signal);\n1503:     const stoppedAtIso = new Date().toISOString();\n1504:     const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n1505:     const gauges = {\n1506:       lag: latestGauges.lag,\n1507:       pending: latestGauges.pending,\n1508:       failed: Math.max(latestGauges.failed, partial.summary.failed),\n1509:     };\n1510:     appendFanoutStatusLedger(ledgerPath, {\n1511:       event: 'stopped',\n1512:       signal,\n1513:       at: stoppedAtIso,\n1514:       gauges,\n1515:     });\n1516:     writeOrchestrationSummary(summaryPath, {\n1517:       run_id: runId,\n1518:       loop_type: loopType,\n1519:       spec_folder: specFolder,\n1520:       base_artifact_dir: baseArtifactDir,\n1521:       total_cli_lineages: cliLineages.length,\n1522:       stopped: true,\n1523:       stopped_signal: signal,\n1524:       stopped_at_iso: stoppedAtIso,\n1525:       status: 'partial',\n1526:       ...partial.summary,\n1527:       gauges,\n1528:       results: partial.results,\n1529:     });\n1530:   };\n1531: \n1532:   installFanoutSignalHandlers(writeStoppedSummary);\n1533: \n1534:   const { results, summary } = await runCappedPool({\n1535:     items: cliLineages,\n1536:     concurrency: fanoutConfig.concurrency,\n1537:     maxRetries: fanoutConfig.maxRetries,\n1538:     lagCeilingMs: fanoutConfig.lagCeilingMs,\n1539:     postExitGraceMs,\n1540:     initialRetryCounts,\n1541:     getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n1542:     onEvent: (event) => {\n1543:       const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n1544:       updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n1545:       if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n1546:       appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n1547:     },\n1548:     worker: async (lineage, context) => {\n1549:       const slotWindowStartIso = new Date().toISOString();\n1550:       const hrStart = process.hrtime();\n1551:       const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n1552:       const livenessKey = `${lineage.label}:${attempt}`;\n1553:       const lineageDir = path.join(lineagesDir, lineage.label);\n1554:       const stateDir = path.join(lineageDir, '.executor-state');\n1555:       fs.mkdirSync(lineageDir, { recursive: true });\n1556:       fs.mkdirSync(stateDir, { recursive: true });\n1557: \n1558:       const budgetDecision = evaluateLineageBudgetCap({ lineage, guards: lineageBudgetGuards });\n1559:       if (!budgetDecision.continue_allowed) {\n1560:         appendFanoutStatusLedger(ledgerPath, {\n1561:           event: 'budget_cap_exceeded',\n1562:           label: lineage.label,\n1563:           at: new Date().toISOString(),\n1564:           severity: 'error',\n1565:           stop_reasons: budgetDecision.stop_reasons,\n1566:           upper_bound: budgetDecision.upper_bound,\n1567:           gauges: latestGauges,\n1568:         });\n1569:         const failure = new Error(\n1570:           `lineage ${lineage.label} exceeds configured budget cap: `\n1571:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1572:         );\n1573:         failure.label = lineage.label;\n1574:         failure.exitCode = null;\n1575:         failure.timedOut = false;\n1576:         failure.budgetCap = budgetDecision;\n1577:         throw failure;\n1578:       }\n1579: \n1580:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1581:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1582:         convergenceThreshold,\n1583:         stopPolicy,\n1584:       });\n1585: \n1586:       // Sandbox resolution stays write-capable by default even for review lineages:\n1587:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1588:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1589:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1590:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1591:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1592:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1593:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1594:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1595: \n1596:       const effectiveSandbox = resolvedSandbox;\n1597:       const effectivePermission = resolvedPermission;\n1598: \n1599:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1600:         lineage,\n1601:         prompt,\n1602:         effectiveSandbox,\n1603:         effectivePermission,\n1604:         {\n1605:           loopType,\n1606:           specFolder,\n1607:           lineageDir,\n1608:           sessionId,\n1609:           convergenceThreshold,\n1610:           stopPolicy,\n1611:           researchTopic,\n1612:         },\n1613:       );\n1614: \n1615:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1616:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1617:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1618:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1619:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1620:       // is deliberately avoided here because relocating the home breaks credential/auth\n1621:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1622:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1623:       const extraEnv = {\n1624:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1625:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1626:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1627:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1628:           : {}),\n1629:       };\n1630: \n1631:       // Recursion guard (fail closed): refuse to spawn when this executor kind is\n1632:       // already on the INHERITED dispatch stack — i.e. a seat that itself runs the loop\n1633:       // tried to fan out the SAME kind again. Only the stack layer is checked here: the\n1634:       // orchestrator legitimately runs inside one of these runtimes, so the runtime-env\n1635:       // (e.g. OPENCODE_SESSION_ID) and ancestry layers would false-positive on the\n1636:       // first-level dispatch. The stack is empty at top level and only carries a kind\n1637:       // once a parent fanout stamped it via buildExecutorDispatchEnv for its child.\n1638:       if (detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)) {\n1639:         throw new Error(\n1640:           `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n1641:         );\n1642:       }\n1643: \n1644:       // Stamp the dispatch stack with this lineage's executor kind so a seat that\n1645:       // tries to recursively launch the same kind is detectable by the runtime\n1646:       // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n1647:       // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n1648:       // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n1649:       // preserve the per-replica lockfile isolation they provide.\n1650:       const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n1651: \n1652:       const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n1653:       let lastLineageEventAtMs = Date.now();\n1654:       const markLineageEvent = () => {\n1655:         lastLineageEventAtMs = Date.now();\n1656:       };\n1657:       const stopStallWatchdog = startLineageStallWatchdog({\n1658:         thresholdMs: stallWatchdogMs,\n1659:         label: lineage.label,\n1660:         ledgerPath,\n1661:         getLastEventAtMs: () => lastLineageEventAtMs,\n1662:         getGauges: () => latestGauges,\n1663:       });\n1664: \n1665:       const stopProgressHeartbeat = startLineageProgressHeartbeat({\n1666:         cadenceMs: progressHeartbeatMs,\n1667:         label: lineage.label,\n1668:         ledgerPath,\n1669:         getGauges: () => latestGauges,\n1670:         onProgress: markLineageEvent,\n1671:       });\n1672:       let result;\n1673:       try {\n1674:         result = await runLineageProcess(command, cmdArgs, {\n1675:           cwd: process.cwd(),\n1676:           timeoutMs,\n1677:           env: dispatchEnv,\n1678:           maxBuffer: 20 * 1024 * 1024,\n1679:           abortSignal: context.signal,\n1680:           onSpawn: ({ pid }) => {\n1681:             lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n1682:           },\n1683:           onExit: ({ pid, exitedAtMs }) => {\n1684:             lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n1685:           },\n1686:           ...(typeof input === 'string' ? { input } : {}),\n1687:         });\n1688:       } finally {\n1689:         stopProgressHeartbeat();\n1690:         stopStallWatchdog();\n1691:       }\n1692: \n1693:       // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n1694:       const logsDir = path.join(lineageDir, 'logs');\n1695:       fs.mkdirSync(logsDir, { recursive: true });\n1696:       const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n1697:       fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n1698: \n1699:       // Recover missing iteration files from captured stdout when possible. Runs\n1700:       // BEFORE the failure throw below so iteration recovery is never lost.\n1701:       const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n1702:       const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n1703:       lineageSlotAccounting.set(lineage.label, slotAccounting);\n1704: \n1705:       const exitCode = result.status ?? (result.error ? 1 : 0);\n1706:       const timedOut = result.signal === 'SIGTERM';\n1707:       // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n1708:       // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n1709:       // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n1710:       const killedBySignal = result.signal != null;\n1711:       const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n1712:       const stateRead = readLineageStateRecords(loopType, lineageDir);\n1713:       const stopPolicyViolation = findMaxIterationsPolicyViolation({\n1714:         loopType,\n1715:         stateRead,\n1716:         lineage,\n1717:         stopPolicy,\n1718:       });\n1719: \n1720:       // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n1721:       // not a success. Throw so the pool settles this item as rejected and counts it\n1722:       // in summary.failed/all_failed, which drives the process exit code. Returning a\n1723:       // plain object here would let the pool record any completed worker as fulfilled\n1724:       // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n1725:       if (timedOut || killedBySignal || exitCode !== 0) {\n1726:         const reason = timedOut\n1727:           ? 'timed out'\n1728:           : killedBySignal\n1729:             ? `killed by signal ${result.signal}`\n1730:             : `exited with code ${exitCode}`;\n1731:         const failure = new Error(`lineage ${lineage.label} ${reason}`);\n1732:         failure.label = lineage.label;\n1733:         failure.exitCode = exitCode;\n1734:         failure.timedOut = timedOut;\n1735:         failure.killedBySignal = killedBySignal;\n1736:         failure.salvage = salvage;\n1737:         throw failure;\n1738:       }\n1739: \n1740:       if (missingArtifacts.length > 0) {\n1741:         const failure = new Error(\n1742:           `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n1743:         );\n1744:         failure.label = lineage.label;\n1745:         failure.exitCode = exitCode;\n1746:         failure.timedOut = false;\n1747:         failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n1748:         failure.missingArtifacts = missingArtifacts;\n1749:         throw failure;\n1750:       }\n1751: \n1752:       if (stopPolicyViolation) {\n1753:         const failure = new Error(\n1754:           `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n1755:         );\n1756:         failure.label = lineage.label;\n1757:         failure.exitCode = exitCode;\n1758:         failure.timedOut = false;\n1759:         failure.salvage = salvage;\n1760:         failure.stopPolicyViolation = stopPolicyViolation;\n1761:         throw failure;\n1762:       }\n1763: \n1764:       // An exit-0 lineage whose salvage sweep could not recover every iteration\n1765:       // markdown is NOT fulfilled, even when the top-level report exists. Returning\n1766:       // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n1767:       // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n1768:       // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n1769:       if (salvage && salvage.failed > 0) {\n1770:         const failure = new Error(\n1771:           `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n1772:         );\n1773:         failure.label = lineage.label;\n1774:         failure.exitCode = exitCode;\n1775:         failure.timedOut = false;\n1776:         failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n1777:         failure.missingArtifacts = [];\n1778:         throw failure;\n1779:       }\n1780: \n1781:       const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n1782:       if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n1783:         const slotWindowEndIso = new Date().toISOString();\n1784:         try {\n1785:           const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n1786:             windowStart: slotWindowStartIso,\n1787:             windowEnd: slotWindowEndIso,\n1788:             toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1789:           });\n1790:           if (timestampCheck.anomalous > 0) {\n1791:             const timestampAnomaly = buildTimestampAnomalyPayload({\n1792:               lineage,\n1793:               statePath: stateRead.statePath,\n1794:               check: timestampCheck,\n1795:             });\n1796:             appendFanoutStatusLedger(ledgerPath, {\n1797:               event: 'timestamp_anomaly',\n1798:               status: 'warning',\n1799:               severity: 'warning',\n1800:               label: lineage.label,\n1801:               at: new Date().toISOString(),\n1802:               ...timestampAnomaly,\n1803:             });\n1804:             output.timestamp_anomaly = timestampAnomaly;\n1805:           }\n1806:         } catch {\n1807:           // Timestamp telemetry is advisory and cannot affect lineage fulfillment.\n1808:         }\n1809:       }\n1810: \n1811:       return output;\n1812:     },\n1813:   });\n1814: \n1815:   const timestampAnomalies = collectTimestampAnomalies(results);\n1816:   const finalSummary = timestampAnomalies.length > 0\n1817:     ? { ...summary, timestamp_anomalies: timestampAnomalies }\n1818:     : summary;\n1819: \n1820:   writeOrchestrationSummary(summaryPath, {\n1821:     run_id: runId,\n1822:     loop_type: loopType,\n1823:     spec_folder: specFolder,\n1824:     base_artifact_dir: baseArtifactDir,\n1825:     total_cli_lineages: cliLineages.length,\n1826:     orphaned_lineages: orphanedLineages,\n1827:     ...finalSummary,\n1828:   });\n1829: \n1830:   const exitCode = finalSummary.all_failed ? 3 : finalSummary.failed > 0 ? 2 : 0;\n1831:   jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary: finalSummary });\n1832:   process.exit(exitCode);\n1833: }\n1834: \n1835: if (require.main === module && isTsxLoaded) {\n1836:   main().catch((err) => {\n1837:     const code = classifyExitCode(err);\n1838:     jsonOut({\n1839:       status: 'error',\n1840:       error: err instanceof Error ? err.message : String(err),\n1841:       code: err && err.code ? err.code : 'SCRIPT_ERROR',\n1842:     });\n1843:     if (code === 1) {\n1844:       process.stderr.write(\n1845:         JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n1846:       );\n1847:     }\n1848:     process.exit(code);\n1849:   });\n1850: }\n1851: \n1852: module.exports = {\n1853:   buildLineageCommand,\n1854:   buildLoopPrompt,\n1855:   findMaxIterationsPolicyViolation,\n1856:   isMaxIterationsStopReason,\n1857:   computeLineageTimeoutMs,\n1858:   computeLineageBudgetUpperBound,\n1859:   evaluateLineageBudgetCap,\n1860:   normalizeProgressHeartbeatMs,\n1861:   normalizePostExitGraceMs,\n1862:   normalizeLineageBudgetGuards,\n1863:   normalizeStallWatchdogMs,\n1864:   computeSkippedCount,\n1865:   decorateSlotAccountingEvent,\n1866:   startLineageProgressHeartbeat,\n1867:   startLineageStallWatchdog,\n1868:   statusForLedgerEvent,\n1869:   updateLineageSnapshot,\n1870:   applyFlatPoolAssignmentGuard,\n1871: };\n\n(End of file - total 1871 lines)\n</content>","metadata":{"preview":"  // fan-out can bind research_topic. Absent for review, which scopes by folder.\n  const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n    ? args.researchTopic.trim()\n    : null;\n  const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n  const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n  const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n  const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n  const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n\n  const {\n    parseFanoutConfig,\n    expandLineages,\n    resolveSandboxMode,\n    resolveClaudePermissionMode,\n  } = await import('../lib/deep-loop/executor-config.ts');\n  const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n  const {\n    DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n    checkLineageTimestampWindow,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"  // fan-out can bind research_topic. Absent for review, which scopes by folder.\n  const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n    ? args.researchTopic.trim()\n    : null;\n  const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n  const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n  const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n  const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n  const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n\n  const {\n    parseFanoutConfig,\n    expandLineages,\n    resolveSandboxMode,\n    resolveClaudePermissionMode,\n  } = await import('../lib/deep-loop/executor-config.ts');\n  const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n  const {\n    DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n    checkLineageTimestampWindow,\n  } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n\n  maybeThrowTestFault();\n\n  let rawConfig;\n  try {\n    rawConfig = JSON.parse(fanoutConfigJson);\n  } catch {\n    throw inputError('fanoutConfigJson is not valid JSON');\n  }\n\n  const lineagesDir = path.join(baseArtifactDir, 'lineages');\n  const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n  const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n  const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n  const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n  const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n  const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n  const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n  const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n  const fanoutConfig = guardedAssignment.config;\n  const allLineages = expandLineages(fanoutConfig);\n  const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n  const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n  const slotIntervalMs = progressHeartbeatMs;\n\n  logFlatPoolGuardRejections({\n    rejections: guardedAssignment.rejections,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n\n  // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n  // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n  // ownership here so all lineages share the same retries and artifact validation.\n  const cliLineages = allLineages;\n  const checkpointPath = waitCheckpointPath(baseArtifactDir);\n  const resumeWaiting = await resumeWaitingCheckpoint({\n    checkpointPath,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n  if (!resumeWaiting.didWait) {\n    await persistPreDispatchWait({\n      checkpointPath,\n      ledgerPath,\n      runId,\n      loopType,\n      specFolder,\n      waitMs: args.preDispatchWaitMs,\n    });\n  }\n\n  if (cliLineages.length === 0) {\n    const summary = {\n      total: 0,\n      succeeded: 0,\n      failed: 0,\n      all_failed: false,\n      gauges: { lag: 0, pending: 0, failed: 0 },\n      convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n    };\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: 0,\n      ...summary,\n    });\n    jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n    return;\n  }\n\n  fs.mkdirSync(lineagesDir, { recursive: true });\n  const orphanedLineages = markOrphanedLineages(ledgerPath);\n  const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n\n  const lineageSnapshots = new Map();\n  const lineageSlotAccounting = new Map();\n  const lineageProcessLiveness = new Map();\n  let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n  let stoppedSummaryWritten = false;\n\n  const writeStoppedSummary = (signal) => {\n    if (stoppedSummaryWritten) return;\n    stoppedSummaryWritten = true;\n    stopActiveLineageProcesses(signal);\n    const stoppedAtIso = new Date().toISOString();\n    const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n    const gauges = {\n      lag: latestGauges.lag,\n      pending: latestGauges.pending,\n      failed: Math.max(latestGauges.failed, partial.summary.failed),\n    };\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'stopped',\n      signal,\n      at: stoppedAtIso,\n      gauges,\n    });\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: cliLineages.length,\n      stopped: true,\n      stopped_signal: signal,\n      stopped_at_iso: stoppedAtIso,\n      status: 'partial',\n      ...partial.summary,\n      gauges,\n      results: partial.results,\n    });\n  };\n\n  installFanoutSignalHandlers(writeStoppedSummary);\n\n  const { results, summary } = await runCappedPool({\n    items: cliLineages,\n    concurrency: fanoutConfig.concurrency,\n    maxRetries: fanoutConfig.maxRetries,\n    lagCeilingMs: fanoutConfig.lagCeilingMs,\n    postExitGraceMs,\n    initialRetryCounts,\n    getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n    onEvent: (event) => {\n      const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n      updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n      if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n      appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n    },\n    worker: async (lineage, context) => {\n      const slotWindowStartIso = new Date().toISOString();\n      const hrStart = process.hrtime();\n      const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n      const livenessKey = `${lineage.label}:${attempt}`;\n      const lineageDir = path.join(lineagesDir, lineage.label);\n      const stateDir = path.join(lineageDir, '.executor-state');\n      fs.mkdirSync(lineageDir, { recursive: true });\n      fs.mkdirSync(stateDir, { recursive: true });\n\n      const budgetDecision = evaluateLineageBudgetCap({ lineage, guards: lineageBudgetGuards });\n      if (!budgetDecision.continue_allowed) {\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'budget_cap_exceeded',\n          label: lineage.label,\n          at: new Date().toISOString(),\n          severity: 'error',\n          stop_reasons: budgetDecision.stop_reasons,\n          upper_bound: budgetDecision.upper_bound,\n          gauges: latestGauges,\n        });\n        const failure = new Error(\n          `lineage ${lineage.label} exceeds configured budget cap: `\n            + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = null;\n        failure.timedOut = false;\n        failure.budgetCap = budgetDecision;\n        throw failure;\n      }\n\n      const sessionId = `fanout-${lineage.label}-${runId}`;\n      const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n        convergenceThreshold,\n        stopPolicy,\n      });\n\n      // Sandbox resolution stays write-capable by default even for review lineages:\n      // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n      // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n      // blanket read-only default would break those writes. The lineageDir-only write boundary\n      // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n      // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n      // exposed one. Callers can still pass an explicit sandboxMode to override.\n      const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n      const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n\n      const effectiveSandbox = resolvedSandbox;\n      const effectivePermission = resolvedPermission;\n\n      const { command, args: cmdArgs, input } = buildLineageCommand(\n        lineage,\n        prompt,\n        effectiveSandbox,\n        effectivePermission,\n        {\n          loopType,\n          specFolder,\n          lineageDir,\n          sessionId,\n          convergenceThreshold,\n          stopPolicy,\n          researchTopic,\n        },\n      );\n\n      // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n      // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n      // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n      // native lockfile. Real same-kind-replica isolation comes from each lineage's\n      // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n      // is deliberately avoided here because relocating the home breaks credential/auth\n      // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n      const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n      const extraEnv = {\n        SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n        ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n        ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n          ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n          : {}),\n      };\n\n      // Recursion guard (fail closed): refuse to spawn when this executor kind is\n      // already on the INHERITED dispatch stack — i.e. a seat that itself runs the loop\n      // tried to fan out the SAME kind again. Only the stack layer is checked here: the\n      // orchestrator legitimately runs inside one of these runtimes, so the runtime-env\n      // (e.g. OPENCODE_SESSION_ID) and ancestry layers would false-positive on the\n      // first-level dispatch. The stack is empty at top level and only carries a kind\n      // once a parent fanout stamped it via buildExecutorDispatchEnv for its child.\n      if (detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)) {\n        throw new Error(\n          `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n        );\n      }\n\n      // Stamp the dispatch stack with this lineage's executor kind so a seat that\n      // tries to recursively launch the same kind is detectable by the runtime\n      // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n      // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n      // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n      // preserve the per-replica lockfile isolation they provide.\n      const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n\n      const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n      let lastLineageEventAtMs = Date.now();\n      const markLineageEvent = () => {\n        lastLineageEventAtMs = Date.now();\n      };\n      const stopStallWatchdog = startLineageStallWatchdog({\n        thresholdMs: stallWatchdogMs,\n        label: lineage.label,\n        ledgerPath,\n        getLastEventAtMs: () => lastLineageEventAtMs,\n        getGauges: () => latestGauges,\n      });\n\n      const stopProgressHeartbeat = startLineageProgressHeartbeat({\n        cadenceMs: progressHeartbeatMs,\n        label: lineage.label,\n        ledgerPath,\n        getGauges: () => latestGauges,\n        onProgress: markLineageEvent,\n      });\n      let result;\n      try {\n        result = await runLineageProcess(command, cmdArgs, {\n          cwd: process.cwd(),\n          timeoutMs,\n          env: dispatchEnv,\n          maxBuffer: 20 * 1024 * 1024,\n          abortSignal: context.signal,\n          onSpawn: ({ pid }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n          },\n          onExit: ({ pid, exitedAtMs }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n          },\n          ...(typeof input === 'string' ? { input } : {}),\n        });\n      } finally {\n        stopProgressHeartbeat();\n        stopStallWatchdog();\n      }\n\n      // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n      const logsDir = path.join(lineageDir, 'logs');\n      fs.mkdirSync(logsDir, { recursive: true });\n      const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n      fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n\n      // Recover missing iteration files from captured stdout when possible. Runs\n      // BEFORE the failure throw below so iteration recovery is never lost.\n      const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n      const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n      lineageSlotAccounting.set(lineage.label, slotAccounting);\n\n      const exitCode = result.status ?? (result.error ? 1 : 0);\n      const timedOut = result.signal === 'SIGTERM';\n      // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n      // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n      // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n      const killedBySignal = result.signal != null;\n      const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n      const stateRead = readLineageStateRecords(loopType, lineageDir);\n      const stopPolicyViolation = findMaxIterationsPolicyViolation({\n        loopType,\n        stateRead,\n        lineage,\n        stopPolicy,\n      });\n\n      // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n      // not a success. Throw so the pool settles this item as rejected and counts it\n      // in summary.failed/all_failed, which drives the process exit code. Returning a\n      // plain object here would let the pool record any completed worker as fulfilled\n      // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n      if (timedOut || killedBySignal || exitCode !== 0) {\n        const reason = timedOut\n          ? 'timed out'\n          : killedBySignal\n            ? `killed by signal ${result.signal}`\n            : `exited with code ${exitCode}`;\n        const failure = new Error(`lineage ${lineage.label} ${reason}`);\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = timedOut;\n        failure.killedBySignal = killedBySignal;\n        failure.salvage = salvage;\n        throw failure;\n      }\n\n      if (missingArtifacts.length > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n        failure.missingArtifacts = missingArtifacts;\n        throw failure;\n      }\n\n      if (stopPolicyViolation) {\n        const failure = new Error(\n          `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = salvage;\n        failure.stopPolicyViolation = stopPolicyViolation;\n        throw failure;\n      }\n\n      // An exit-0 lineage whose salvage sweep could not recover every iteration\n      // markdown is NOT fulfilled, even when the top-level report exists. Returning\n      // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n      // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n      // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n      if (salvage && salvage.failed > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n        failure.missingArtifacts = [];\n        throw failure;\n      }\n\n      const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n      if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n        const slotWindowEndIso = new Date().toISOString();\n        try {\n          const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n            windowStart: slotWindowStartIso,\n            windowEnd: slotWindowEndIso,\n            toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n          });\n          if (timestampCheck.anomalous > 0) {\n            const timestampAnomaly = buildTimestampAnomalyPayload({\n              lineage,\n              statePath: stateRead.statePath,\n              check: timestampCheck,\n            });\n            appendFanoutStatusLedger(ledgerPath, {\n              event: 'timestamp_anomaly',\n              status: 'warning',\n              severity: 'warning',\n              label: lineage.label,\n              at: new Date().toISOString(),\n              ...timestampAnomaly,\n            });\n            output.timestamp_anomaly = timestampAnomaly;\n          }\n        } catch {\n          // Timestamp telemetry is advisory and cannot affect lineage fulfillment.\n        }\n      }\n\n      return output;\n    },\n  });\n\n  const timestampAnomalies = collectTimestampAnomalies(results);\n  const finalSummary = timestampAnomalies.length > 0\n    ? { ...summary, timestamp_anomalies: timestampAnomalies }\n    : summary;\n\n  writeOrchestrationSummary(summaryPath, {\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    base_artifact_dir: baseArtifactDir,\n    total_cli_lineages: cliLineages.length,\n    orphaned_lineages: orphanedLineages,\n    ...finalSummary,\n  });\n\n  const exitCode = finalSummary.all_failed ? 3 : finalSummary.failed > 0 ? 2 : 0;\n  jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary: finalSummary });\n  process.exit(exitCode);\n}\n\nif (require.main === module && isTsxLoaded) {\n  main().catch((err) => {\n    const code = classifyExitCode(err);\n    jsonOut({\n      status: 'error',\n      error: err instanceof Error ? err.message : String(err),\n      code: err && err.code ? err.code : 'SCRIPT_ERROR',\n    });\n    if (code === 1) {\n      process.stderr.write(\n        JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n      );\n    }\n    process.exit(code);\n  });\n}\n\nmodule.exports = {\n  buildLineageCommand,\n  buildLoopPrompt,\n  findMaxIterationsPolicyViolation,\n  isMaxIterationsStopReason,\n  computeLineageTimeoutMs,\n  computeLineageBudgetUpperBound,\n  evaluateLineageBudgetCap,\n  normalizeProgressHeartbeatMs,\n  normalizePostExitGraceMs,\n  normalizeLineageBudgetGuards,\n  normalizeStallWatchdogMs,\n  computeSkippedCount,\n  decorateSlotAccountingEvent,\n  startLineageProgressHeartbeat,\n  startLineageStallWatchdog,\n  statusForLedgerEvent,\n  updateLineageSnapshot,\n  applyFlatPoolAssignmentGuard,\n};","lineStart":1391,"lineEnd":1871,"totalLines":1871,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783486629342,"end":1783486629354}},"metadata":{"openai":{"itemId":"fc_096bb8aa26ac5d84016a4dd8a546f48191a08684eecae97990"}},"id":"prt_f401645dd0017blr1ZJD4mK3kj","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f401627ad001C87wmULd5RnCr1"}}
