{
  "schemaVersion": "deep-ai-council.runtime-capabilities.v1",
  "skill": "deep-ai-council",
  "stopPolicy": "fail-closed",
  "defaultMode": "in-cli",
  "invariants": {
    "planningOnly": true,
    "oneCliPerRound": true,
    "packetLocalArtifactsAuthoritative": true,
    "derivedGraphProjectionOnly": true
  },
  "runtimes": {
    "opencode": {
      "agentPath": ".opencode/agents/ai-council.md",
      "supportsInCliSeats": true,
      "supportsExternalCliCapture": true,
      "notes": "OpenCode supplies in-runtime model diversity when available."
    },
    "claude": {
      "agentPath": ".claude/agents/ai-council.md",
      "supportsInCliSeats": true,
      "supportsExternalCliCapture": true,
      "notes": "Claude Code seats must stay within one CLI per round."
    }
  },
  "validation": {
    "quickValidate": "python3 .opencode/skills/sk-doc/scripts/quick_validate.py .opencode/skills/deep-loop-workflows/deep-ai-council --json",
    "completionAdvisory": "node .opencode/skills/deep-loop-workflows/deep-ai-council/scripts/advise-council-completion.cjs <packet>"
  }
}
