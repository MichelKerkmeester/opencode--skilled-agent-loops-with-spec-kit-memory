\n\n  Line 767:     ) -> list[DedupReview]:\n\n  Line 773:                 select(DedupReview)\n\n  Line 775:                     DedupReview.tenant_id == tenant_id,\n\n  Line 776:                     DedupReview.status == status,\n\n  Line 778:                 .order_by(DedupReview.created_at.desc())\n\n  Line 786:     ) -> DedupReview | None:\n\n  Line 797:             row = await session.get(DedupReview, review_id)\n\n  Line 806:     async def memory_bulk_find_by_content_hashes(\n\n  Line 813:         \"\"\"Map ``content_hash → {id, client_request_id}`` for existing rows.\n\n  Line 815:         ``client_request_id`` is included so the upstream bulk-write\n\n  Line 817:         a content match whose stored ``client_request_id`` equals the\n\n  Line 827:             stmt = select(Memory.content_hash, Memory.id, Memory.client_request_id).where(\n\n  Line 839:             return {row[0]: {\"id\": row[1], \"client_request_id\": row[2]} for row in rows}\n\n  Line 1018:             (Memory.status.in_((\"outdated\", \"conflicted\")), 0.5),\n\n  Line 1151:             # path) or ``conflicted`` (semantic path) and points the newer\n\n  Line 1156:             scored_stmt = scored_stmt.where(Memory.status.notin_((\"outdated\", \"conflicted\")))\n\n  Line 1316:                 stmt = stmt.where(Memory.status.notin_((\"outdated\", \"conflicted\")))\n\n  Line 1425:         ``conflicted`` row that ``memory_id``'s chain points at — i.e.\n\n  Line 1430:         ``M.status == 'conflicted'`` AND\n\n  Line 1433:         ``supersedes_id`` pointing back at the *older/conflicted* row;\n\n  Line 1434:         the conflicted row itself has ``supersedes_id=NULL``.\n\n  Line 1438:         looked for \"conflicted rows pointing at me\" but Path A leaves\n\n  Line 1439:         the conflicted row's ``supersedes_id`` as NULL. That filter\n\n  Line 1465:                 # marked conflicted on this memory's behalf.\n\n  Line 1472:                         Memory.status == \"conflicted\",\n\n  Line