   249	// ─────────────────────────────────────────────────────────────────────────────
   250	// 3b. 5-DIM SCORING (opt-in, --scorer=5dim) — 121/005
   251	// ─────────────────────────────────────────────────────────────────────────────
   252	// Routes the materialized fixture output through the ported 120/003 5-dim scorer
   253	// (deterministic checks + grader factory) instead of the default heading/pattern
   254	// matcher. Opt-in so the default `pattern` path stays byte-identical; the scorer
   255	// module is lazily required only on this path. graderKind defaults to 'noop'
   256	// (deterministic, no LLM dispatch) so a benchmark run stays hermetic unless the
   257	// operator explicitly asks for the 'llm' grader.
   258	
   259	async function scoreFixture5dim(fixture, outputPath, cwdAbs, graderKind, scorerModule) {
   260	  if (!fs.existsSync(outputPath)) {
   261	    return {
   262	      id: fixture.id,
   263	      outputPath,
   264	      score: 0,
   265	      maxScore: 100,
   266	      passed: false,
   267	      scoringMethod: '5dim',
   268	      dimensions: {},
   269	      hard_gate_failed: false,
   270	      failureModes: ['missing-output'],
   271	    };
   272	  }
   273	  const outputText = fs.readFileSync(outputPath, 'utf8');
   274	  const result = await scorerModule.score({
   275	    candidateId: fixture.id,
   276	    outputText,
   277	    criteria: {
   278	      acceptance: fixture.acceptance || [],
   279	      requiredHeadings: fixture.requiredHeadings || [],
   280	      requiredPatterns: fixture.requiredPatterns || [],
   281	    },
   282	    cwd: cwdAbs,
   283	    graderKind,
   284	  });
   285	  const score = Math.round((result.weightedScore || 0) * 100);
   286	  const failureModes = [];
   287	  if (result.hard_gate_failed) {
   288	    failureModes.push('hard-gate-failed');
   289	  }
   290	  for (const [dim, value] of Object.entries(result.dimensions || {})) {
   291	    if (typeof value === 'number' && value < 0.5) {
   292	      failureModes.push(`low-${dim}`);
   293	    }
   294	  }
   295	  return {
   296	    id: fixture.id,
   297	    outputPath,
   298	    score,
   299	    maxScore: 100,
   300	    passed: !result.hard_gate_failed && failureModes.length === 0,
   301	    scoringMethod: '5dim',
   302	    dimensions: result.dimensions || {},
   303	    hard_gate_failed: Boolean(result.hard_gate_failed),
   304	    failureModes,
   305	  };
   306	}
   307	
   308	// ─────────────────────────────────────────────────────────────────────────────
   309	// 4. INTEGRATION SCORING
   310	// ─────────────────────────────────────────────────────────────────────────────
   311	
   312	// P2 (014 review): every sub-score below is on a normalized 0..100 scale and
   313	// combined with the weights defined here. Earlier comments described a "10 pt"
   314	// scale that did not match the code; these named constants are now the single
   315	// source of truth for the integration score composition.
   316	const INTEGRATION_FULL_SCORE = 100;
   317	const MIRROR_MISSING_PENALTY = 30;
   318	const MIRROR_DIVERGED_PENALTY = 20;
   319	const COVERAGE_PRESENT_SCORE = 100; // binary: >=1 reference => full normalized score
   320	const INTEGRATION_WEIGHTS = { mirror: 0.6, command: 0.2, skill: 0.2 };
   321	
   322	function scoreIntegration(integrationReportPath) {
   323	  const data = readJson(integrationReportPath);
   324	
   325	  // Normalize scanner output: scan-integration.cjs emits surfaces.mirrors/commands/skills
   326	  // while this function historically expects top-level mirrors/commandReferences/skillReferences.
   327	  const mirrors = data.mirrors || (data.surfaces && data.surfaces.mirrors) || [];
   328	  const commandRefs = data.commandReferences || (data.surfaces && data.surfaces.commands) || [];
   329	  const skillRefs = data.skillReferences || (data.surfaces && data.surfaces.skills) || [];
   330	
   331	  // --- Mirror sync score (0..100, start full and penalize diverged/missing) ---
   332	  let mirrorScore = INTEGRATION_FULL_SCORE;
   333	  for (const mirror of mirrors) {
   334	    const mStatus = mirror.status || mirror.syncStatus;
   335	    if (mStatus === 'missing') {
   336	      mirrorScore -= MIRROR_MISSING_PENALTY;
   337	    } else if (mStatus === 'diverged') {
   338	      mirrorScore -= MIRROR_DIVERGED_PENALTY;
   339	    }
   340	  }
   341	  mirrorScore = Math.max(0, mirrorScore);
   342	  const mirrorStatus =
   343	    mirrorScore === INTEGRATION_FULL_SCORE
   344	      ? 'all-aligned'
   345	      : mirrors.some((entry) => (entry.status || entry.syncStatus) === 'missing')
   346	        ? 'has-missing'
   347	        : 'has-divergence';
   348	
   349	  // --- Command coverage (binary: >=1 reference => COVERAGE_PRESENT_SCORE, else 0) ---
   350	  const commandCount = commandRefs.length;
   351	  const commandScore = commandCount >= 1 ? COVERAGE_PRESENT_SCORE : 0;
   352	
   353	  // --- Skill coverage (binary: >=1 reference => COVERAGE_PRESENT_SCORE, else 0) ---
   354	  const skillCount = skillRefs.length;
   355	  const skillScore = skillCount >= 1 ? COVERAGE_PRESENT_SCORE : 0;
   356	
   357	  // --- Weighted average on the 0..100 scale (mirror 60%, command 20%, skill 20%) ---
   358	  const integrationScore = Math.round(
   359	    mirrorScore * INTEGRATION_WEIGHTS.mirror
   360	    + commandScore * INTEGRATION_WEIGHTS.command

