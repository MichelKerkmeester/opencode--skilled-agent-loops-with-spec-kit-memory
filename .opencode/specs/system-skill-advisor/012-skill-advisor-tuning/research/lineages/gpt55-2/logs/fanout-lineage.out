{"type":"tool_use","timestamp":1783437217134,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_ttvj2drbsgg2sPatntHFwBK4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":500,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n500: \n501: function hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n502:   const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n503:   if (!explicit || explicit.rawScore < 0.55) return false;\n504:   return explicit.evidence.some((entry) => (\n505:     entry.startsWith('phrase:')\n506:     || entry.startsWith('explicit:')\n507:     || entry.startsWith('author:')\n508:     || entry.includes(skillId)\n509:     || entry.includes('loop')\n510:     || entry.includes('write-')\n511:   ));\n512: }\n513: \n514: function readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n515:   if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n516:     return false;\n517:   }\n518:   if (skillId === 'sk-code' && /\\b(compare|audit|review)\\b/.test(promptLower)\n519:     && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n520:     return true;\n521:   }\n522:   if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n523:     return true;\n524:   }\n525:   if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n526:     return true;\n527:   }\n528:   if (skillId === 'deep-loop-workflows' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n529:     return true;\n530:   }\n531:   if (skillId === 'mcp-chrome-devtools' && /\\b(\\.opencode\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n532:     return true;\n533:   }\n534:   // Browser/devtools inspection is a genuine chrome-devtools task even though\n535:   // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n536:   // explainer floor when the prompt carries devtools-specific vocabulary.\n537:   if (skillId === 'mcp-chrome-devtools'\n538:     && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n539:     return true;\n540:   }\n541:   if (skillId === 'sk-code' && /\\bgate-3-classifier\\.ts\\b/.test(promptLower)) {\n542:     return true;\n543:   }\n544:   return false;\n545: }\n546: \n547: function isPlainFileSavePrompt(promptLower: string): boolean {\n548:   return FILE_SAVE_OPERATION.test(promptLower) && !MEMORY_SAVE_CONTEXT_ANCHOR.test(promptLower.replace(/\\bfile(s)?\\b/g, ''));\n549: }\n550: \n551: function primaryIntentBonus(\n552:   promptLower: string,\n553:   recommendation: AdvisorScoredRecommendation,\n554:   selfRecommendationGuardEnabled: boolean,\n555: ): number {\n556:   const R = SCORING_CALIBRATION.routing;\n557:   if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n558:     if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n559:   }\n560:   if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n561:     if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n562:   }\n563:   if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n564:     if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchOtherSkillsPenalty;\n565:   }\n566:   if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n567:     if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n568:   }\n569:   if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n570:     if (recommendation.skill === 'sk-code') return R.compareAuditCodeReviewBonus;\n571:   }\n572:   if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n573:     if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n574:     if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;\n575:   }\n576:   if (promptLower.includes('/speckit:resume')) {\n577:     if (recommendation.skill === 'system-spec-kit') return R.speckitResumeSpecKitBonus;\n578:     if (recommendation.skill === 'command-spec-kit') return R.speckitResumeCommandPenalty;\n579:   }\n580:   if (promptLower.includes('/speckit:plan')) {\n581:     if (recommendation.skill === 'command-spec-kit') return R.speckitPlanCommandBonus;\n582:     if (recommendation.skill === 'sk-doc') return R.speckitPlanSkDocPenalty;\n583:   }\n584:   // External-tool-chain (\"call_tool_chain\") vocabulary belongs to mcp-code-mode,\n585:   // not the generic code skill. Disambiguate so the best guess for these\n586:   // toolchain-shaped prompts is mcp-code-mode.\n587:   // Toolchain + external-data-source vocabulary (webflow CMS, cms collection)\n588:   // is mcp-code-mode territory, not the generic code skill.\n589:   if (/\\b(call_tool_chain|code mode|tool ?chain|api chain|webflow cms|cms collection)\\b/.test(promptLower)) {\n590:     if (recommendation.skill === 'mcp-code-mode') return R.mcpToolchainCodeModeBonus;\n591:     if (recommendation.skill === 'sk-code') return R.mcpToolchainSkCodePenalty;\n592:   }\n593:   // A \"code audit\" is a code-review task, not a deep-review loop. On the\n594:   // near-tie this phrase produces, prefer sk-code over deep-review.\n595:   if (/\\bcode audit\\b/.test(promptLower)) {\n596:     if (recommendation.skill === 'sk-code') return R.codeAuditCodeReviewBonus;\n597:     if (recommendation.skill === 'deep-review' || recommendation.skill === 'deep-loop-workflows') return R.codeAuditDeepReviewPenalty;\n598:   }\n599:   // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n600:   // loop; rank it above single-pass code review.\n601:   if (/:review:(auto|confirm)\\b/.test(promptLower)) {\n602:     if (recommendation.skill === 'deep-loop-workflows') return R.reviewLoopDeepReviewBonus;\n603:     if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n604:   }\n605:   // Auditing recommendation quality is a review task, not an advisor-self task.\n606:   if (/\\baudit\\b/.test(promptLower) && /\\b(recommendation|recommendations|recommendation quality|routing quality)\\b/.test(promptLower)) {\n607:     if (recommendation.skill === 'sk-code') return R.auditRecsCodeReviewBonus;\n608:     if (!selfRecommendationGuardEnabled && isAdvisorSelfRecommendationSkill(recommendation.skill)) return R.auditRecsAdvisorPenalty;\n609:     if (shouldApplyAdvisorSelfRecommendationGuard({\n610:       skillId: recommendation.skill,\n611:       guardEnabled: selfRecommendationGuardEnabled,\n612:     })) {\n613:       return R.auditRecsAdvisorPenalty;\n614:     }\n615:   }\n616:   if (/\\b(save context|save memory)\\b/.test(promptLower)) {\n617:     if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;\n618:     if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;\n619:   }\n620:   if (/\\b(create (a )?new agent|create agent)\\b/.test(promptLower) || promptLower.includes('/create:agent')) {\n621:     if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;\n622:     if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;\n623:   }\n624:   if (/\\bcreate (a )?(test|testing) playbook\\b/.test(promptLower) || promptLower.includes('/create:manual-testing-playbook')) {\n625:     if (recommendation.skill === 'create:manual-testing-playbook' || recommendation.skill === 'command-create-manual-testing-playbook') return R.createTestingPlaybookBonus;\n626:     if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;\n627:     if (recommendation.skill === 'deep-loop-workflows') return R.createTestingPlaybookOtherSkillsPenalty;\n628:   }\n629:   if (/\\bphase folder\\b/.test(promptLower)) {\n630:     if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n631:   }\n632:   return 0;\n633: }\n634: \n635: export function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n636:   const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n637:   const promptLower = prompt.toLowerCase();\n638:   const queryClass = classifyAdvisorQuery(promptLower);\n639:   const weights = effectiveScorerWeights(\n640:     options.laneWeightsOverride,\n641:     isAdvisorQueryClassRoutingEnabled() ? queryClass : 'unknown',\n642:   );\n643:   const disabled = new Set(options.disabledLanes ?? []);\n644:   const affordances = normalize(options.affordances ?? []);\n645:   const useRrfFusion = isAdvisorRrfFusionEnabled();\n646:   const useExactSemanticRerank = useRrfFusion && isAdvisorExactSemanticRerankEnabled();\n647:   const selfRecommendationGuardEnabled = isAdvisorSelfRecommendationGuardEnabled();\n648:   const { laneScores, graphConflictMatches } = buildLaneScores(\n649:     prompt,\n650:     projection,\n651:     disabled,\n652:     affordances,\n653:     useRrfFusion,\n654:     selfRecommendationGuardEnabled,\n655:   );\n656:   const runtimeLaneHealth = projectionRuntimeLaneHealth(projection, options.runtimeLaneHealth);\n657:   const laneHealth = buildLaneRuntimeHealth(laneScores, disabled, runtimeLaneHealth);\n658:   const degradedLanes = laneHealth\n659:     .filter((lane) => lane.status === 'runtime_degraded')\n660:     .map((lane) => lane.lane);\n661:   const runtimeDegradedLanes = new Set(degradedLanes);\n662:   const graphConflictIndex = buildConflictMatchIndex(graphConflictMatches);\n663:   const rrfFusion = useRrfFusion\n664:     ? fuseAdvisorLaneRanks(laneScores, weights, disabled, runtimeDegradedLanes)\n665:     : null;\n666:   const laneScoreIndexes = Object.fromEntries(\n667:     SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n668:   ) as Record<ScorerLane, LaneMatchIndex>;\n669:   const liveTotal = SCORER_LANES\n670:     .filter((lane) => !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n671:     .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n672:   const runtimeLiveLaneCount = SCORER_LANES\n673:     .filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n674:     .length;\n675:   if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n676:     for (const lane of SCORER_LANES) {\n677:       if (!isLiveScorerLane(lane) || disabled.has(lane) || runtimeDegradedLanes.has(lane)) continue;\n678:       speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n679:     }\n680:   }\n681:   const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n682:   const hasTaskIntent = TASK_INTENT.test(promptLower);\n683:   const recommendations: AdvisorScoredRecommendation[] = [];\n684: \n685:   for (const skill of projection.skills) {\n686:     if (!isDefaultRoutable(promptLower, skill)) continue;\n687:     const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n688:       const laneMatch = laneScoreIndexes[lane].get(skill.id);\n689:       const rawScore = laneMatch?.rawScore ?? 0;\n690:       const shadowOnly = !isLiveScorerLane(lane);\n691:       const runtimeDegraded = runtimeDegradedLanes.has(lane);\n692:       return {\n693:         lane,\n694:         rawScore,\n695:         weightedScore: shadowOnly || disabled.has(lane) || runtimeDegraded ? 0 : rawScore * weights[lane],\n696:         weight: disabled.has(lane) || runtimeDegraded ? 0 : weights[lane],\n697:         evidence: laneMatch?.evidence ?? [],\n698:         shadowOnly,\n699:       };\n700:     });\n701:     const weightedScore = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n702:     const rrfScore = rrfFusion?.scoreBySkill.get(skill.id);\n703:     const score = useRrfFusion ? rrfScore ?? 0 : weightedScore;\n704:     if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n705:     if (isSpeckitMetricsEnabled()) {\n706:       for (const contribution of contributions) {\n707:         if (contribution.weightedScore !== 0) {\n708:           speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n709:         }\n710:       }\n711:     }\n712: \n713:     const directScore = Math.max(\n714:       contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n715:       contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n716:     );\n717:     const derivedDominant = isDerivedDominant(contributions);\n718:     const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n719:     const explicitMatch = laneScoreIndexes.explicit_author.get(skill.id);\n720:     const liveNormalized = score / liveTotal;\n721:     let confidence = confidenceFor({\n722:       liveNormalized,\n723:       directScore,\n724:       readOnlyExplainer,\n725:       hasExplicitWorkflowSignal: explicitSignal,\n726:       hasTaskIntent,\n727:       readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n728:       derivedDominant,\n729:       skillId: skill.id,\n730:       selfRecommendationGuardEnabled,\n731:       hasAdvisorSelfAuthoredSignal: hasAdvisorSelfAuthoredSignal(skill.id, explicitMatch),\n732:     });\n733:     if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n734:       confidence = Math.min(confidence, 0.49);\n735:     }\n736:     recommendations.push({\n737:       skill: skill.id,\n738:       kind: skill.kind,\n739:       confidence,\n740:       uncertainty: uncertaintyFor(contributions, confidence, 0),\n741:       passes_threshold: false,\n742:       reason: attributionReason(contributions),\n743:       score: useRrfFusion ? score : Number(score.toFixed(6)),\n744:       laneContributions: contributions,\n745:       dominantLane: dominantLane(contributions),\n746:       redirectTo: skill.redirectTo ?? undefined,\n747:       redirectFrom: skill.redirectFrom,\n748:       lifecycleStatus: skill.lifecycleStatus,\n749:     });\n750:   }\n751: \n752:   if (isSpeckitMetricsEnabled()) {\n753:     for (const recommendation of recommendations) {\n754:       if (primaryIntentBonus(promptLower, recommendation, selfRecommendationGuardEnabled) !== 0) {\n755:         speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n756:       }\n757:       if (useRrfFusion && graphConflictAdjustment(graphConflictIndex, recommendation) !== 0) {\n758:         speckitMetrics.incrementCounter('spec_kit.scorer.graph_conflict_demote_applied_total', { skill_id: recommendation.skill });\n759:       }\n\n(Showing lines 500-759 of 911. Use offset=760 to continue.)\n</content>","metadata":{"preview":"\nfunction hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n  const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n  if (!explicit || explicit.rawScore < 0.55) return false;\n  return explicit.evidence.some((entry) => (\n    entry.startsWith('phrase:')\n    || entry.startsWith('explicit:')\n    || entry.startsWith('author:')\n    || entry.includes(skillId)\n    || entry.includes('loop')\n    || entry.includes('write-')\n  ));\n}\n\nfunction readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n  if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n    return false;\n  }\n  if (skillId === 'sk-code' && /\\b(compare|audit|review)\\b/.test(promptLower)\n    && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"\nfunction hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {\n  const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');\n  if (!explicit || explicit.rawScore < 0.55) return false;\n  return explicit.evidence.some((entry) => (\n    entry.startsWith('phrase:')\n    || entry.startsWith('explicit:')\n    || entry.startsWith('author:')\n    || entry.includes(skillId)\n    || entry.includes('loop')\n    || entry.includes('write-')\n  ));\n}\n\nfunction readOnlyRouteAllowed(promptLower: string, skillId: string): boolean {\n  if (/\\b(no edits?|without making changes|do not (change|edit|modify|touch)|read-only only|no edits yet|only; do not|just show|just list)\\b/.test(promptLower)) {\n    return false;\n  }\n  if (skillId === 'sk-code' && /\\b(compare|audit|review)\\b/.test(promptLower)\n    && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'deep-loop-workflows' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'mcp-chrome-devtools' && /\\b(\\.opencode\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n    return true;\n  }\n  // Browser/devtools inspection is a genuine chrome-devtools task even though\n  // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n  // explainer floor when the prompt carries devtools-specific vocabulary.\n  if (skillId === 'mcp-chrome-devtools'\n    && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'sk-code' && /\\bgate-3-classifier\\.ts\\b/.test(promptLower)) {\n    return true;\n  }\n  return false;\n}\n\nfunction isPlainFileSavePrompt(promptLower: string): boolean {\n  return FILE_SAVE_OPERATION.test(promptLower) && !MEMORY_SAVE_CONTEXT_ANCHOR.test(promptLower.replace(/\\bfile(s)?\\b/g, ''));\n}\n\nfunction primaryIntentBonus(\n  promptLower: string,\n  recommendation: AdvisorScoredRecommendation,\n  selfRecommendationGuardEnabled: boolean,\n): number {\n  const R = SCORING_CALIBRATION.routing;\n  if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n  }\n  if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n  }\n  if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchOtherSkillsPenalty;\n  }\n  if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n  }\n  if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.compareAuditCodeReviewBonus;\n  }\n  if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n    if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;\n  }\n  if (promptLower.includes('/speckit:resume')) {\n    if (recommendation.skill === 'system-spec-kit') return R.speckitResumeSpecKitBonus;\n    if (recommendation.skill === 'command-spec-kit') return R.speckitResumeCommandPenalty;\n  }\n  if (promptLower.includes('/speckit:plan')) {\n    if (recommendation.skill === 'command-spec-kit') return R.speckitPlanCommandBonus;\n    if (recommendation.skill === 'sk-doc') return R.speckitPlanSkDocPenalty;\n  }\n  // External-tool-chain (\"call_tool_chain\") vocabulary belongs to mcp-code-mode,\n  // not the generic code skill. Disambiguate so the best guess for these\n  // toolchain-shaped prompts is mcp-code-mode.\n  // Toolchain + external-data-source vocabulary (webflow CMS, cms collection)\n  // is mcp-code-mode territory, not the generic code skill.\n  if (/\\b(call_tool_chain|code mode|tool ?chain|api chain|webflow cms|cms collection)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'mcp-code-mode') return R.mcpToolchainCodeModeBonus;\n    if (recommendation.skill === 'sk-code') return R.mcpToolchainSkCodePenalty;\n  }\n  // A \"code audit\" is a code-review task, not a deep-review loop. On the\n  // near-tie this phrase produces, prefer sk-code over deep-review.\n  if (/\\bcode audit\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.codeAuditCodeReviewBonus;\n    if (recommendation.skill === 'deep-review' || recommendation.skill === 'deep-loop-workflows') return R.codeAuditDeepReviewPenalty;\n  }\n  // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n  // loop; rank it above single-pass code review.\n  if (/:review:(auto|confirm)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'deep-loop-workflows') return R.reviewLoopDeepReviewBonus;\n    if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n  }\n  // Auditing recommendation quality is a review task, not an advisor-self task.\n  if (/\\baudit\\b/.test(promptLower) && /\\b(recommendation|recommendations|recommendation quality|routing quality)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.auditRecsCodeReviewBonus;\n    if (!selfRecommendationGuardEnabled && isAdvisorSelfRecommendationSkill(recommendation.skill)) return R.auditRecsAdvisorPenalty;\n    if (shouldApplyAdvisorSelfRecommendationGuard({\n      skillId: recommendation.skill,\n      guardEnabled: selfRecommendationGuardEnabled,\n    })) {\n      return R.auditRecsAdvisorPenalty;\n    }\n  }\n  if (/\\b(save context|save memory)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;\n    if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;\n  }\n  if (/\\b(create (a )?new agent|create agent)\\b/.test(promptLower) || promptLower.includes('/create:agent')) {\n    if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;\n    if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;\n  }\n  if (/\\bcreate (a )?(test|testing) playbook\\b/.test(promptLower) || promptLower.includes('/create:manual-testing-playbook')) {\n    if (recommendation.skill === 'create:manual-testing-playbook' || recommendation.skill === 'command-create-manual-testing-playbook') return R.createTestingPlaybookBonus;\n    if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;\n    if (recommendation.skill === 'deep-loop-workflows') return R.createTestingPlaybookOtherSkillsPenalty;\n  }\n  if (/\\bphase folder\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n  }\n  return 0;\n}\n\nexport function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n  const promptLower = prompt.toLowerCase();\n  const queryClass = classifyAdvisorQuery(promptLower);\n  const weights = effectiveScorerWeights(\n    options.laneWeightsOverride,\n    isAdvisorQueryClassRoutingEnabled() ? queryClass : 'unknown',\n  );\n  const disabled = new Set(options.disabledLanes ?? []);\n  const affordances = normalize(options.affordances ?? []);\n  const useRrfFusion = isAdvisorRrfFusionEnabled();\n  const useExactSemanticRerank = useRrfFusion && isAdvisorExactSemanticRerankEnabled();\n  const selfRecommendationGuardEnabled = isAdvisorSelfRecommendationGuardEnabled();\n  const { laneScores, graphConflictMatches } = buildLaneScores(\n    prompt,\n    projection,\n    disabled,\n    affordances,\n    useRrfFusion,\n    selfRecommendationGuardEnabled,\n  );\n  const runtimeLaneHealth = projectionRuntimeLaneHealth(projection, options.runtimeLaneHealth);\n  const laneHealth = buildLaneRuntimeHealth(laneScores, disabled, runtimeLaneHealth);\n  const degradedLanes = laneHealth\n    .filter((lane) => lane.status === 'runtime_degraded')\n    .map((lane) => lane.lane);\n  const runtimeDegradedLanes = new Set(degradedLanes);\n  const graphConflictIndex = buildConflictMatchIndex(graphConflictMatches);\n  const rrfFusion = useRrfFusion\n    ? fuseAdvisorLaneRanks(laneScores, weights, disabled, runtimeDegradedLanes)\n    : null;\n  const laneScoreIndexes = Object.fromEntries(\n    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n  ) as Record<ScorerLane, LaneMatchIndex>;\n  const liveTotal = SCORER_LANES\n    .filter((lane) => !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n  const runtimeLiveLaneCount = SCORER_LANES\n    .filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n    .length;\n  if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n    for (const lane of SCORER_LANES) {\n      if (!isLiveScorerLane(lane) || disabled.has(lane) || runtimeDegradedLanes.has(lane)) continue;\n      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n    }\n  }\n  const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n  const hasTaskIntent = TASK_INTENT.test(promptLower);\n  const recommendations: AdvisorScoredRecommendation[] = [];\n\n  for (const skill of projection.skills) {\n    if (!isDefaultRoutable(promptLower, skill)) continue;\n    const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n      const laneMatch = laneScoreIndexes[lane].get(skill.id);\n      const rawScore = laneMatch?.rawScore ?? 0;\n      const shadowOnly = !isLiveScorerLane(lane);\n      const runtimeDegraded = runtimeDegradedLanes.has(lane);\n      return {\n        lane,\n        rawScore,\n        weightedScore: shadowOnly || disabled.has(lane) || runtimeDegraded ? 0 : rawScore * weights[lane],\n        weight: disabled.has(lane) || runtimeDegraded ? 0 : weights[lane],\n        evidence: laneMatch?.evidence ?? [],\n        shadowOnly,\n      };\n    });\n    const weightedScore = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n    const rrfScore = rrfFusion?.scoreBySkill.get(skill.id);\n    const score = useRrfFusion ? rrfScore ?? 0 : weightedScore;\n    if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n    if (isSpeckitMetricsEnabled()) {\n      for (const contribution of contributions) {\n        if (contribution.weightedScore !== 0) {\n          speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n        }\n      }\n    }\n\n    const directScore = Math.max(\n      contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n      contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n    );\n    const derivedDominant = isDerivedDominant(contributions);\n    const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n    const explicitMatch = laneScoreIndexes.explicit_author.get(skill.id);\n    const liveNormalized = score / liveTotal;\n    let confidence = confidenceFor({\n      liveNormalized,\n      directScore,\n      readOnlyExplainer,\n      hasExplicitWorkflowSignal: explicitSignal,\n      hasTaskIntent,\n      readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n      derivedDominant,\n      skillId: skill.id,\n      selfRecommendationGuardEnabled,\n      hasAdvisorSelfAuthoredSignal: hasAdvisorSelfAuthoredSignal(skill.id, explicitMatch),\n    });\n    if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n      confidence = Math.min(confidence, 0.49);\n    }\n    recommendations.push({\n      skill: skill.id,\n      kind: skill.kind,\n      confidence,\n      uncertainty: uncertaintyFor(contributions, confidence, 0),\n      passes_threshold: false,\n      reason: attributionReason(contributions),\n      score: useRrfFusion ? score : Number(score.toFixed(6)),\n      laneContributions: contributions,\n      dominantLane: dominantLane(contributions),\n      redirectTo: skill.redirectTo ?? undefined,\n      redirectFrom: skill.redirectFrom,\n      lifecycleStatus: skill.lifecycleStatus,\n    });\n  }\n\n  if (isSpeckitMetricsEnabled()) {\n    for (const recommendation of recommendations) {\n      if (primaryIntentBonus(promptLower, recommendation, selfRecommendationGuardEnabled) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n      }\n      if (useRrfFusion && graphConflictAdjustment(graphConflictIndex, recommendation) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.graph_conflict_demote_applied_total', { skill_id: recommendation.skill });\n      }","lineStart":500,"lineEnd":759,"totalLines":911,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437217125,"end":1783437217132}},"metadata":{"openai":{"itemId":"fc_0e0fa9cb0d2f105e016a4d17a0ea9c8199bb7b741c68db3c72"}},"id":"prt_f3d244d3e00116TtS0xWD6cDLz","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24212e001kD5KCskpnWietg"}}
{"type":"tool_use","timestamp":1783437217190,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_5n4LkYrcXuMLFpwdHz6SRP7H","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Derived Generated Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: // Pull the age-haircut policy from the scorer-local seam\n6: // instead of reaching into the lifecycle subsystem directly. The lifecycle\n7: // implementation stays the source of truth; the seam keeps the scorer's\n8: // dependency direction inward.\n9: import { applyAgeHaircutToLane } from '../age-policy.js';\n10: import type { NormalizedAffordance } from '../../affordance-normalizer.js';\n11: import type { AdvisorProjection, LaneMatch } from '../types.js';\n12: import { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n13: \n14: function affordancesForSkill(\n15:   affordances: readonly NormalizedAffordance[],\n16:   skillId: string,\n17: ): NormalizedAffordance[] {\n18:   return affordances.filter((affordance) => affordance.skillId === skillId);\n19: }\n20: \n21: // Doc-level harvest contribution is bounded twice: only the strongest\n22: // few docs count (so doc-heavy skills cannot outscore lean skills on\n23: // volume alone) and the summed contribution is capped below the level a\n24: // skill's own curated triggers can reach.\n25: const DOC_TOP_N = 3;\n26: const DOC_PHRASE_FACTOR = 0.5;\n27: const DOC_CONTRIBUTION_CAP = 0.45;\n28: \n29: interface DocMatch {\n30:   readonly docPath: string;\n31:   readonly score: number;\n32: }\n33: \n34: function scoreDocTriggers(\n35:   lower: string,\n36:   skill: AdvisorProjection['skills'][number],\n37: ): DocMatch[] {\n38:   const matches: DocMatch[] = [];\n39:   for (const doc of skill.docTriggers ?? []) {\n40:     let best = 0;\n41:     for (const phrase of doc.phrases) {\n42:       if (!matchesPhraseBoundary(lower, phrase)) continue;\n43:       best = Math.max(best, phraseSpecificity(phrase));\n44:     }\n45:     if (best <= 0) continue;\n46:     matches.push({ docPath: doc.docPath, score: best * doc.tierWeight });\n47:   }\n48:   return matches.sort((left, right) => right.score - left.score).slice(0, DOC_TOP_N);\n49: }\n50: \n51: export function scoreDerivedLane(\n52:   prompt: string,\n53:   projection: AdvisorProjection,\n54:   now: Date = new Date(),\n55:   affordances: readonly NormalizedAffordance[] = [],\n56: ): LaneMatch[] {\n57:   const lower = prompt.toLowerCase();\n58:   const tokens = tokenize(prompt);\n59:   const matches: LaneMatch[] = [];\n60: \n61:   for (const skill of projection.skills) {\n62:     const phrases = [...skill.derivedTriggers, ...skill.derivedKeywords];\n63:     const skillAffordances = affordancesForSkill(affordances, skill.id);\n64:     const affordancePhrases = skillAffordances.flatMap((affordance) => [...affordance.derivedTriggers]);\n65:     const docMatches = scoreDocTriggers(lower, skill);\n66:     if (phrases.length === 0 && affordancePhrases.length === 0 && docMatches.length === 0) continue;\n67:     const evidence: string[] = docMatches.map((doc) => `doc:${doc.docPath}`);\n68:     let score = Math.min(\n69:       docMatches.reduce((total, doc) => total + doc.score, 0) * DOC_PHRASE_FACTOR,\n70:       DOC_CONTRIBUTION_CAP,\n71:     );\n72:     for (const phrase of phrases) {\n73:       if (!matchesPhraseBoundary(lower, phrase)) continue;\n74:       score += phraseSpecificity(phrase) * 0.7;\n75:       evidence.push(`derived:${phrase}`);\n76:     }\n77:     for (const affordance of skillAffordances) {\n78:       let matched = false;\n79:       for (const phrase of affordance.derivedTriggers) {\n80:         if (!matchesPhraseBoundary(lower, phrase)) continue;\n81:         matched = true;\n82:         score += phraseSpecificity(phrase) * 0.45;\n83:       }\n84:       if (matched) evidence.push(affordance.evidenceLabel);\n85:     }\n86:     score += scoreTokenOverlap(tokens, phrases) * 0.45;\n87:     score += scoreTokenOverlap(tokens, affordancePhrases) * 0.25;\n88:     // Decay by the skill's own derived-content age — derivedGeneratedAt is the\n89:     // author/sync time of the derived block (author-time, not refreshed by\n90:     // rebuild; see SkillProjection.derivedGeneratedAt). The projection.generatedAt\n91:     // fallback is a last-resort, timestamp-less value (near-now on every run, so\n92:     // it exempts the skill from the haircut), used ONLY when a skill has no\n93:     // derived.generated_at — it is not a runtime freshness signal.\n94:     const adjusted = applyAgeHaircutToLane(\n95:       { trustLane: 'derived_generated', score: Math.min(score, 1) },\n96:       {\n97:         generatedAt: skill.derivedGeneratedAt ?? projection.generatedAt,\n98:         now,\n99:         lifecycleStatus: skill.lifecycleStatus,\n100:       },\n101:     );\n102:     if (adjusted.score <= 0.05) continue;\n103:     matches.push({\n104:       skillId: skill.id,\n105:       lane: 'derived_generated',\n106:       score: Number((adjusted.score * (skill.derivedDemotion ?? 1)).toFixed(6)),\n107:       evidence: evidence.slice(0, 6),\n108:     });\n109:   }\n110: \n111:   return matches;\n112: }\n\n(End of file - total 112 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Generated Lane\n// ───────────────────────────────────────────────────────────────\n\n// Pull the age-haircut policy from the scorer-local seam\n// instead of reaching into the lifecycle subsystem directly. The lifecycle\n// implementation stays the source of truth; the seam keeps the scorer's\n// dependency direction inward.\nimport { applyAgeHaircutToLane } from '../age-policy.js';\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n\nfunction affordancesForSkill(\n  affordances: readonly NormalizedAffordance[],\n  skillId: string,\n): NormalizedAffordance[] {\n  return affordances.filter((affordance) => affordance.skillId === skillId);\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Generated Lane\n// ───────────────────────────────────────────────────────────────\n\n// Pull the age-haircut policy from the scorer-local seam\n// instead of reaching into the lifecycle subsystem directly. The lifecycle\n// implementation stays the source of truth; the seam keeps the scorer's\n// dependency direction inward.\nimport { applyAgeHaircutToLane } from '../age-policy.js';\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n\nfunction affordancesForSkill(\n  affordances: readonly NormalizedAffordance[],\n  skillId: string,\n): NormalizedAffordance[] {\n  return affordances.filter((affordance) => affordance.skillId === skillId);\n}\n\n// Doc-level harvest contribution is bounded twice: only the strongest\n// few docs count (so doc-heavy skills cannot outscore lean skills on\n// volume alone) and the summed contribution is capped below the level a\n// skill's own curated triggers can reach.\nconst DOC_TOP_N = 3;\nconst DOC_PHRASE_FACTOR = 0.5;\nconst DOC_CONTRIBUTION_CAP = 0.45;\n\ninterface DocMatch {\n  readonly docPath: string;\n  readonly score: number;\n}\n\nfunction scoreDocTriggers(\n  lower: string,\n  skill: AdvisorProjection['skills'][number],\n): DocMatch[] {\n  const matches: DocMatch[] = [];\n  for (const doc of skill.docTriggers ?? []) {\n    let best = 0;\n    for (const phrase of doc.phrases) {\n      if (!matchesPhraseBoundary(lower, phrase)) continue;\n      best = Math.max(best, phraseSpecificity(phrase));\n    }\n    if (best <= 0) continue;\n    matches.push({ docPath: doc.docPath, score: best * doc.tierWeight });\n  }\n  return matches.sort((left, right) => right.score - left.score).slice(0, DOC_TOP_N);\n}\n\nexport function scoreDerivedLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  now: Date = new Date(),\n  affordances: readonly NormalizedAffordance[] = [],\n): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = tokenize(prompt);\n  const matches: LaneMatch[] = [];\n\n  for (const skill of projection.skills) {\n    const phrases = [...skill.derivedTriggers, ...skill.derivedKeywords];\n    const skillAffordances = affordancesForSkill(affordances, skill.id);\n    const affordancePhrases = skillAffordances.flatMap((affordance) => [...affordance.derivedTriggers]);\n    const docMatches = scoreDocTriggers(lower, skill);\n    if (phrases.length === 0 && affordancePhrases.length === 0 && docMatches.length === 0) continue;\n    const evidence: string[] = docMatches.map((doc) => `doc:${doc.docPath}`);\n    let score = Math.min(\n      docMatches.reduce((total, doc) => total + doc.score, 0) * DOC_PHRASE_FACTOR,\n      DOC_CONTRIBUTION_CAP,\n    );\n    for (const phrase of phrases) {\n      if (!matchesPhraseBoundary(lower, phrase)) continue;\n      score += phraseSpecificity(phrase) * 0.7;\n      evidence.push(`derived:${phrase}`);\n    }\n    for (const affordance of skillAffordances) {\n      let matched = false;\n      for (const phrase of affordance.derivedTriggers) {\n        if (!matchesPhraseBoundary(lower, phrase)) continue;\n        matched = true;\n        score += phraseSpecificity(phrase) * 0.45;\n      }\n      if (matched) evidence.push(affordance.evidenceLabel);\n    }\n    score += scoreTokenOverlap(tokens, phrases) * 0.45;\n    score += scoreTokenOverlap(tokens, affordancePhrases) * 0.25;\n    // Decay by the skill's own derived-content age — derivedGeneratedAt is the\n    // author/sync time of the derived block (author-time, not refreshed by\n    // rebuild; see SkillProjection.derivedGeneratedAt). The projection.generatedAt\n    // fallback is a last-resort, timestamp-less value (near-now on every run, so\n    // it exempts the skill from the haircut), used ONLY when a skill has no\n    // derived.generated_at — it is not a runtime freshness signal.\n    const adjusted = applyAgeHaircutToLane(\n      { trustLane: 'derived_generated', score: Math.min(score, 1) },\n      {\n        generatedAt: skill.derivedGeneratedAt ?? projection.generatedAt,\n        now,\n        lifecycleStatus: skill.lifecycleStatus,\n      },\n    );\n    if (adjusted.score <= 0.05) continue;\n    matches.push({\n      skillId: skill.id,\n      lane: 'derived_generated',\n      score: Number((adjusted.score * (skill.derivedDemotion ?? 1)).toFixed(6)),\n      evidence: evidence.slice(0, 6),\n    });\n  }\n\n  return matches;\n}","lineStart":1,"lineEnd":112,"totalLines":112,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","time":{"start":1783437217182,"end":1783437217189}},"metadata":{"openai":{"itemId":"fc_0e0fa9cb0d2f105e016a4d17a0eaa48199afae24ad74eebb7a"}},"id":"prt_f3d244d67001K1NFpZ3UqsgnLr","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24212e001kD5KCskpnWietg"}}
{"type":"tool_use","timestamp":1783437217191,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_uwvbpjrMC6I43vamePqn9qDe","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Semantic Shadow Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { getAdapter } from '../../embedders/registry.js';\n6: import { getActiveEmbedder } from '../../embedders/schema.js';\n7: import { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\n8: import { scoreTokenOverlap, tokenize } from '../text.js';\n9: import type { AdvisorProjection, LaneMatch } from '../types.js';\n10: \n11: const COSINE_THRESHOLD = 0.2;\n12: \n13: let activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n14: \n15: export interface SemanticShadowRuntimeHealth {\n16:   readonly checkedAt: string;\n17:   readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n18:   readonly dimMismatch: boolean;\n19:   readonly disabledReason: string | null;\n20:   readonly lastPromptEmbeddingAt: string | null;\n21: }\n22: \n23: let runtimeHealth: SemanticShadowRuntimeHealth = {\n24:   checkedAt: new Date(0).toISOString(),\n25:   activeEmbedder: null,\n26:   dimMismatch: false,\n27:   disabledReason: null,\n28:   lastPromptEmbeddingAt: null,\n29: };\n30: \n31: function setRuntimeHealth(update: Partial<SemanticShadowRuntimeHealth>): void {\n32:   runtimeHealth = {\n33:     ...runtimeHealth,\n34:     ...update,\n35:     checkedAt: new Date().toISOString(),\n36:   };\n37: }\n38: \n39: export function getSemanticShadowRuntimeHealth(): SemanticShadowRuntimeHealth {\n40:   return runtimeHealth;\n41: }\n42: \n43: function toFloat32Array(vector: Float32Array | readonly number[]): Float32Array {\n44:   return vector instanceof Float32Array ? vector : Float32Array.from(vector);\n45: }\n46: \n47: function cosineSimilarity(left: Float32Array, right: Float32Array): number {\n48:   const length = Math.min(left.length, right.length);\n49:   if (length === 0) {\n50:     return 0;\n51:   }\n52: \n53:   let dot = 0;\n54:   let leftNorm = 0;\n55:   let rightNorm = 0;\n56:   for (let index = 0; index < length; index++) {\n57:     const leftValue = left[index];\n58:     const rightValue = right[index];\n59:     dot += leftValue * rightValue;\n60:     leftNorm += leftValue * leftValue;\n61:     rightNorm += rightValue * rightValue;\n62:   }\n63: \n64:   if (leftNorm === 0 || rightNorm === 0) {\n65:     return 0;\n66:   }\n67: \n68:   return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n69: }\n70: \n71: function fixtureVector(text: string): Float32Array {\n72:   const normalized = text.toLowerCase().split(/\\W+/).filter(Boolean);\n73:   const vector = new Float32Array(32);\n74:   for (const token of normalized) {\n75:     let hash = 0;\n76:     for (let index = 0; index < token.length; index++) {\n77:       hash = ((hash << 5) - hash + token.charCodeAt(index)) | 0;\n78:     }\n79:     vector[Math.abs(hash) % vector.length] += 1;\n80:   }\n81:   return vector;\n82: }\n83: \n84: export function setSemanticShadowPromptEmbedding(prompt: string, vector: Float32Array | readonly number[] | null | undefined): void {\n85:   activePromptEmbedding = vector ? { prompt, vector: toFloat32Array(vector) } : null;\n86: }\n87: \n88: export function clearSemanticShadowPromptEmbedding(): void {\n89:   activePromptEmbedding = null;\n90: }\n91: \n92: export async function withSemanticShadowPromptEmbedding<T>(prompt: string, run: () => T): Promise<T> {\n93:   if (process.env.VITEST === 'true') {\n94:     return run();\n95:   }\n96: \n97:   try {\n98:     // Read-only access: recommend calls must never open the daemon-owned\n99:     // database read-write (dual-writer hazard) or create it when absent.\n100:     const database = getDbReadOnly();\n101:     if (!database) {\n102:       setRuntimeHealth({\n103:         activeEmbedder: null,\n104:         dimMismatch: false,\n105:         disabledReason: 'database_absent',\n106:       });\n107:       throw new Error('skill graph database is absent; shadow scoring disabled');\n108:     }\n109:     const active = getActiveEmbedder(database);\n110:     const adapter = getAdapter(active.name);\n111:     if (!adapter) {\n112:       setRuntimeHealth({\n113:         activeEmbedder: { name: active.name, dim: active.dim, adapterDim: null },\n114:         dimMismatch: false,\n115:         disabledReason: 'adapter_unavailable',\n116:       });\n117:       throw new Error(`active embedder is not registered: ${active.name}`);\n118:     }\n119:     if (adapter.dim !== active.dim) {\n120:       setRuntimeHealth({\n121:         activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n122:         dimMismatch: true,\n123:         disabledReason: 'dim_mismatch',\n124:       });\n125:       throw new Error(`active embedder dimension mismatch: ${active.name} reports ${adapter.dim}, pointer expects ${active.dim}`);\n126:     }\n127: \n128:     const [vector] = await adapter.embed([prompt], { inputType: 'query' });\n129:     setSemanticShadowPromptEmbedding(prompt, vector ?? null);\n130:     setRuntimeHealth({\n131:       activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n132:       dimMismatch: false,\n133:       disabledReason: vector ? null : 'prompt_embedding_empty',\n134:       lastPromptEmbeddingAt: vector ? new Date().toISOString() : runtimeHealth.lastPromptEmbeddingAt,\n135:     });\n136:   } catch (error: unknown) {\n137:     setSemanticShadowPromptEmbedding(prompt, null);\n138:     const message = error instanceof Error ? error.message : String(error);\n139:     if (!runtimeHealth.disabledReason) {\n140:       setRuntimeHealth({ disabledReason: 'prompt_embedding_failed' });\n141:     }\n142:     console.warn(`[semantic-shadow] Prompt embedding failed; cosine lane disabled for this call (${message})`);\n143:   }\n144: \n145:   try {\n146:     return run();\n147:   } finally {\n148:     clearSemanticShadowPromptEmbedding();\n149:   }\n150: }\n151: \n152: export const _semanticShadowTest = {\n153:   cosineSimilarity,\n154:   fixtureVector,\n155: };\n156: \n157: export function scoreSemanticShadowExactSubset(\n158:   prompt: string,\n159:   projection: AdvisorProjection,\n160:   skillIds: readonly string[],\n161: ): LaneMatch[] {\n162:   if (projection.embeddingStaleness?.stale) {\n163:     setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n164:     return [];\n165:   }\n166: \n167:   const orderedSkillIds = [...new Set(skillIds)];\n168:   if (orderedSkillIds.length === 0) return [];\n169: \n170:   const promptVector = activePromptEmbedding?.prompt === prompt\n171:     ? activePromptEmbedding.vector\n172:     : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n173:   if (!promptVector) {\n174:     return [];\n175:   }\n176: \n177:   const requested = new Set(orderedSkillIds);\n178:   const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n179:     ? new Map(projection.skills\n180:         .filter((skill) => requested.has(skill.id))\n181:         .map((skill) => [skill.id, fixtureVector([\n182:           skill.name,\n183:           skill.description,\n184:           ...skill.domains,\n185:           ...skill.intentSignals,\n186:           ...skill.derivedTriggers,\n187:         ].join(' '))]))\n188:     : new Map<string, Float32Array>();\n189: \n190:   let cachedVectors = new Map<string, Float32Array>();\n191:   if (projection.source !== 'fixture' && process.env.VITEST !== 'true') {\n192:     try {\n193:       cachedVectors = new Map(\n194:         loadSkillEmbeddings(orderedSkillIds)\n195:           .map((row) => [row.skillId, row.embedding]),\n196:       );\n197:     } catch (error: unknown) {\n198:       const message = error instanceof Error ? error.message : String(error);\n199:       setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n200:       console.warn(`[semantic-shadow] Exact skill embedding load failed; rerank disabled (${message})`);\n201:       return [];\n202:     }\n203:   }\n204: \n205:   return orderedSkillIds\n206:     .map((skillId): LaneMatch | null => {\n207:       const skillVector = cachedVectors.get(skillId) ?? fixtureVectors.get(skillId);\n208:       if (!skillVector) {\n209:         return null;\n210:       }\n211:       const score = cosineSimilarity(promptVector, skillVector);\n212:       const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n213:       return {\n214:         skillId,\n215:         lane: 'semantic_shadow' as const,\n216:         score: roundedScore,\n217:         evidence: [`cosine-exact:${score.toFixed(4)}`],\n218:         shadowOnly: false,\n219:       };\n220:     })\n221:     .filter((match): match is LaneMatch => match !== null);\n222: }\n223: \n224: export function scoreSemanticShadowLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n225:   if (projection.embeddingStaleness?.stale) {\n226:     setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n227:     return [];\n228:   }\n229: \n230:   if (!activePromptEmbedding && process.env.VITEST === 'true') {\n231:     const tokens = tokenize(prompt);\n232:     return projection.skills\n233:       .map((skill) => ({\n234:         skillId: skill.id,\n235:         lane: 'semantic_shadow' as const,\n236:         score: Math.min(scoreTokenOverlap(tokens, [\n237:           skill.name,\n238:           skill.description,\n239:           ...skill.domains,\n240:           ...skill.intentSignals,\n241:           ...skill.derivedTriggers,\n242:         ]) * 0.8, 1),\n243:         evidence: ['shadow:test-fallback'],\n244:         shadowOnly: false,\n245:       }))\n246:       .filter((match) => match.score > 0.08);\n247:   }\n248: \n249:   const promptVector = activePromptEmbedding?.prompt === prompt\n250:     ? activePromptEmbedding.vector\n251:     : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n252:   if (!promptVector) {\n253:     return [];\n254:   }\n255: \n256:   const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n257:     ? new Map(projection.skills.map((skill) => [skill.id, fixtureVector([\n258:         skill.name,\n259:         skill.description,\n260:         ...skill.domains,\n\n(Showing lines 1-260 of 311. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport { getAdapter } from '../../embedders/registry.js';\nimport { getActiveEmbedder } from '../../embedders/schema.js';\nimport { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\nimport { scoreTokenOverlap, tokenize } from '../text.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nconst COSINE_THRESHOLD = 0.2;\n\nlet activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n\nexport interface SemanticShadowRuntimeHealth {\n  readonly checkedAt: string;\n  readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n  readonly dimMismatch: boolean;\n  readonly disabledReason: string | null;\n  readonly lastPromptEmbeddingAt: string | null;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport { getAdapter } from '../../embedders/registry.js';\nimport { getActiveEmbedder } from '../../embedders/schema.js';\nimport { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\nimport { scoreTokenOverlap, tokenize } from '../text.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nconst COSINE_THRESHOLD = 0.2;\n\nlet activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n\nexport interface SemanticShadowRuntimeHealth {\n  readonly checkedAt: string;\n  readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n  readonly dimMismatch: boolean;\n  readonly disabledReason: string | null;\n  readonly lastPromptEmbeddingAt: string | null;\n}\n\nlet runtimeHealth: SemanticShadowRuntimeHealth = {\n  checkedAt: new Date(0).toISOString(),\n  activeEmbedder: null,\n  dimMismatch: false,\n  disabledReason: null,\n  lastPromptEmbeddingAt: null,\n};\n\nfunction setRuntimeHealth(update: Partial<SemanticShadowRuntimeHealth>): void {\n  runtimeHealth = {\n    ...runtimeHealth,\n    ...update,\n    checkedAt: new Date().toISOString(),\n  };\n}\n\nexport function getSemanticShadowRuntimeHealth(): SemanticShadowRuntimeHealth {\n  return runtimeHealth;\n}\n\nfunction toFloat32Array(vector: Float32Array | readonly number[]): Float32Array {\n  return vector instanceof Float32Array ? vector : Float32Array.from(vector);\n}\n\nfunction cosineSimilarity(left: Float32Array, right: Float32Array): number {\n  const length = Math.min(left.length, right.length);\n  if (length === 0) {\n    return 0;\n  }\n\n  let dot = 0;\n  let leftNorm = 0;\n  let rightNorm = 0;\n  for (let index = 0; index < length; index++) {\n    const leftValue = left[index];\n    const rightValue = right[index];\n    dot += leftValue * rightValue;\n    leftNorm += leftValue * leftValue;\n    rightNorm += rightValue * rightValue;\n  }\n\n  if (leftNorm === 0 || rightNorm === 0) {\n    return 0;\n  }\n\n  return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n}\n\nfunction fixtureVector(text: string): Float32Array {\n  const normalized = text.toLowerCase().split(/\\W+/).filter(Boolean);\n  const vector = new Float32Array(32);\n  for (const token of normalized) {\n    let hash = 0;\n    for (let index = 0; index < token.length; index++) {\n      hash = ((hash << 5) - hash + token.charCodeAt(index)) | 0;\n    }\n    vector[Math.abs(hash) % vector.length] += 1;\n  }\n  return vector;\n}\n\nexport function setSemanticShadowPromptEmbedding(prompt: string, vector: Float32Array | readonly number[] | null | undefined): void {\n  activePromptEmbedding = vector ? { prompt, vector: toFloat32Array(vector) } : null;\n}\n\nexport function clearSemanticShadowPromptEmbedding(): void {\n  activePromptEmbedding = null;\n}\n\nexport async function withSemanticShadowPromptEmbedding<T>(prompt: string, run: () => T): Promise<T> {\n  if (process.env.VITEST === 'true') {\n    return run();\n  }\n\n  try {\n    // Read-only access: recommend calls must never open the daemon-owned\n    // database read-write (dual-writer hazard) or create it when absent.\n    const database = getDbReadOnly();\n    if (!database) {\n      setRuntimeHealth({\n        activeEmbedder: null,\n        dimMismatch: false,\n        disabledReason: 'database_absent',\n      });\n      throw new Error('skill graph database is absent; shadow scoring disabled');\n    }\n    const active = getActiveEmbedder(database);\n    const adapter = getAdapter(active.name);\n    if (!adapter) {\n      setRuntimeHealth({\n        activeEmbedder: { name: active.name, dim: active.dim, adapterDim: null },\n        dimMismatch: false,\n        disabledReason: 'adapter_unavailable',\n      });\n      throw new Error(`active embedder is not registered: ${active.name}`);\n    }\n    if (adapter.dim !== active.dim) {\n      setRuntimeHealth({\n        activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n        dimMismatch: true,\n        disabledReason: 'dim_mismatch',\n      });\n      throw new Error(`active embedder dimension mismatch: ${active.name} reports ${adapter.dim}, pointer expects ${active.dim}`);\n    }\n\n    const [vector] = await adapter.embed([prompt], { inputType: 'query' });\n    setSemanticShadowPromptEmbedding(prompt, vector ?? null);\n    setRuntimeHealth({\n      activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n      dimMismatch: false,\n      disabledReason: vector ? null : 'prompt_embedding_empty',\n      lastPromptEmbeddingAt: vector ? new Date().toISOString() : runtimeHealth.lastPromptEmbeddingAt,\n    });\n  } catch (error: unknown) {\n    setSemanticShadowPromptEmbedding(prompt, null);\n    const message = error instanceof Error ? error.message : String(error);\n    if (!runtimeHealth.disabledReason) {\n      setRuntimeHealth({ disabledReason: 'prompt_embedding_failed' });\n    }\n    console.warn(`[semantic-shadow] Prompt embedding failed; cosine lane disabled for this call (${message})`);\n  }\n\n  try {\n    return run();\n  } finally {\n    clearSemanticShadowPromptEmbedding();\n  }\n}\n\nexport const _semanticShadowTest = {\n  cosineSimilarity,\n  fixtureVector,\n};\n\nexport function scoreSemanticShadowExactSubset(\n  prompt: string,\n  projection: AdvisorProjection,\n  skillIds: readonly string[],\n): LaneMatch[] {\n  if (projection.embeddingStaleness?.stale) {\n    setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n    return [];\n  }\n\n  const orderedSkillIds = [...new Set(skillIds)];\n  if (orderedSkillIds.length === 0) return [];\n\n  const promptVector = activePromptEmbedding?.prompt === prompt\n    ? activePromptEmbedding.vector\n    : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n  if (!promptVector) {\n    return [];\n  }\n\n  const requested = new Set(orderedSkillIds);\n  const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n    ? new Map(projection.skills\n        .filter((skill) => requested.has(skill.id))\n        .map((skill) => [skill.id, fixtureVector([\n          skill.name,\n          skill.description,\n          ...skill.domains,\n          ...skill.intentSignals,\n          ...skill.derivedTriggers,\n        ].join(' '))]))\n    : new Map<string, Float32Array>();\n\n  let cachedVectors = new Map<string, Float32Array>();\n  if (projection.source !== 'fixture' && process.env.VITEST !== 'true') {\n    try {\n      cachedVectors = new Map(\n        loadSkillEmbeddings(orderedSkillIds)\n          .map((row) => [row.skillId, row.embedding]),\n      );\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n      console.warn(`[semantic-shadow] Exact skill embedding load failed; rerank disabled (${message})`);\n      return [];\n    }\n  }\n\n  return orderedSkillIds\n    .map((skillId): LaneMatch | null => {\n      const skillVector = cachedVectors.get(skillId) ?? fixtureVectors.get(skillId);\n      if (!skillVector) {\n        return null;\n      }\n      const score = cosineSimilarity(promptVector, skillVector);\n      const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n      return {\n        skillId,\n        lane: 'semantic_shadow' as const,\n        score: roundedScore,\n        evidence: [`cosine-exact:${score.toFixed(4)}`],\n        shadowOnly: false,\n      };\n    })\n    .filter((match): match is LaneMatch => match !== null);\n}\n\nexport function scoreSemanticShadowLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n  if (projection.embeddingStaleness?.stale) {\n    setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n    return [];\n  }\n\n  if (!activePromptEmbedding && process.env.VITEST === 'true') {\n    const tokens = tokenize(prompt);\n    return projection.skills\n      .map((skill) => ({\n        skillId: skill.id,\n        lane: 'semantic_shadow' as const,\n        score: Math.min(scoreTokenOverlap(tokens, [\n          skill.name,\n          skill.description,\n          ...skill.domains,\n          ...skill.intentSignals,\n          ...skill.derivedTriggers,\n        ]) * 0.8, 1),\n        evidence: ['shadow:test-fallback'],\n        shadowOnly: false,\n      }))\n      .filter((match) => match.score > 0.08);\n  }\n\n  const promptVector = activePromptEmbedding?.prompt === prompt\n    ? activePromptEmbedding.vector\n    : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n  if (!promptVector) {\n    return [];\n  }\n\n  const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n    ? new Map(projection.skills.map((skill) => [skill.id, fixtureVector([\n        skill.name,\n        skill.description,\n        ...skill.domains,","lineStart":1,"lineEnd":260,"totalLines":311,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","time":{"start":1783437217184,"end":1783437217190}},"metadata":{"openai":{"itemId":"fc_0e0fa9cb0d2f105e016a4d17a0eaac8199af2e295f50e18d65"}},"id":"prt_f3d244d9e0013xKOUmlW58Jt86","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d24212e001kD5KCskpnWietg"}}
