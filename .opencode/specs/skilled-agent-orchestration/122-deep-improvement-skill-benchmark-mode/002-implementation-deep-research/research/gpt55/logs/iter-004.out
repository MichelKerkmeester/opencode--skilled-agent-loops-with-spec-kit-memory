     1	// ╔══════════════════════════════════════════════════════════════════════════╗
     2	// ║ Integration Surface Scanner for deep-agent-improvement                      ║
     3	// ╚══════════════════════════════════════════════════════════════════════════╝
     4	'use strict';
     5	
     6	// ─────────────────────────────────────────────────────────────────────────────
     7	// 1. IMPORTS
     8	// ─────────────────────────────────────────────────────────────────────────────
     9	const fs = require('node:fs');
    10	const path = require('node:path');
    11	
    12	// ─────────────────────────────────────────────────────────────────────────────
    13	// 2. CONSTANTS
    14	// ─────────────────────────────────────────────────────────────────────────────
    15	const MIRROR_TEMPLATES = [
    16	  '.opencode/agents/{name}.md',
    17	  '.claude/agents/{name}.md',
    18	  '.codex/agents/{name}.toml',
    19	  '.gemini/agents/{name}.md',
    20	];
    21	const GLOBAL_DOC_PATHS = ['CLAUDE.md', '.claude/CLAUDE.md'];
    22	const SKILL_ADVISOR_PATH = '.opencode/skills/scripts/skill_advisor.py';
    23	
    24	// ─────────────────────────────────────────────────────────────────────────────
    25	// 3. UTILITIES
    26	// ─────────────────────────────────────────────────────────────────────────────
    27	function parseArgs(argv) {
    28	  const args = {};
    29	  for (const entry of argv) {
    30	    if (!entry.startsWith('--')) continue;
    31	    const [key, ...rest] = entry.slice(2).split('=');
    32	    args[key] = rest.length > 0 ? rest.join('=') : true;
    33	  }
    34	  return args;
    35	}
    36	
    37	function readOptional(filePath) {
    38	  try { return fs.readFileSync(filePath, 'utf8'); } catch (_e) { return null; }
    39	}
    40	
    41	function walk(dir, acc) {
    42	  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    43	    if (entry.name === 'node_modules' || entry.name === '.git') continue;
    44	    const full = path.join(dir, entry.name);
    45	    if (entry.isDirectory()) walk(full, acc);
    46	    else acc.push(full);
    47	  }
    48	}
    49	
    50	function stripFrontmatter(content) {
    51	  return content.replace(/^---[\s\S]*?---\n/, '');
    52	}
    53	
    54	function parseFrontmatter(content) {
    55	  const match = content.match(/^---\n([\s\S]*?)\n---/);
    56	  if (!match) return null;
    57	  const fm = {};
    58	  for (const line of match[1].split('\n')) {
    59	    const idx = line.indexOf(':');
    60	    if (idx < 0) continue;
    61	    const key = line.slice(0, idx).trim();
    62	    const val = line.slice(idx + 1).trim().replace(/^["']|["']$/g, '');
    63	    if (key) fm[key] = val;
    64	  }
    65	  return fm;
    66	}
    67	
    68	function collectFiles(rootDir) {
    69	  if (!fs.existsSync(rootDir)) return [];
    70	  const files = [];
    71	  walk(rootDir, files);
    72	  return files;
    73	}
    74	
    75	// ─────────────────────────────────────────────────────────────────────────────
    76	// 4. SIGNAL-BASED MIRROR SYNC CHECK
    77	// ─────────────────────────────────────────────────────────────────────────────
    78	function extractSignals(body) {
    79	  const signals = [];
    80	  const re = /\*\*(.+?)\*\*/g;
    81	  let m;
    82	  while ((m = re.exec(body)) !== null) {
    83	    if (m[1].length > 20 && signals.length < 3) signals.push(m[1]);
    84	  }
    85	  return signals;
    86	}
    87	
    88	function checkMirrorSync(canonicalBody, mirrorContent) {
    89	  if (mirrorContent === null) return 'missing';
    90	  const signals = extractSignals(canonicalBody);
    91	  if (signals.length === 0) return 'aligned';
    92	  const mirrorBody = stripFrontmatter(mirrorContent);
    93	  const hits = signals.filter((s) => mirrorBody.includes(s)).length;
    94	  return hits >= 2 ? 'aligned' : 'diverged';
    95	}
    96	
    97	// ─────────────────────────────────────────────────────────────────────────────
    98	// 5. SURFACE SCANNERS
    99	// ─────────────────────────────────────────────────────────────────────────────
   100	function scanCanonical(repoRoot, agentName) {
   101	  const relPath = `.opencode/agents/${agentName}.md`;
   102	  const content = readOptional(path.join(repoRoot, relPath));
   103	  return { path: relPath, exists: content !== null, frontmatter: content ? parseFrontmatter(content) : null };
   104	}
   105	
   106	function scanMirrors(repoRoot, agentName, canonicalBody) {
   107	  return MIRROR_TEMPLATES.map((tpl) => {
   108	    const relPath = tpl.replace('{name}', agentName);
   109	    const content = readOptional(path.join(repoRoot, relPath));
   110	    return { path: relPath, exists: content !== null, syncStatus: checkMirrorSync(canonicalBody, content) };
   111	  });
   112	}
   113	
   114	function scanFilesByExt(repoRoot, agentName, ext, patternFn) {
   115	  const files = collectFiles(path.join(repoRoot, '.opencode/commands'));
   116	  const pattern = patternFn(agentName);
   117	  const results = [];
   118	  for (const file of files) {
   119	    if (!file.endsWith(ext)) continue;
   120	    const content = readOptional(file);
   121	    if (!content) continue;
   122	    const matches = content.match(pattern);
   123	    if (matches && matches.length > 0) {
   124	      results.push({ path: path.relative(repoRoot, file), references: [...new Set(matches)] });
   125	    }
   126	  }
   127	  return results;
   128	}
   129	
   130	function scanCommands(repoRoot, agentName) {
   131	  return scanFilesByExt(repoRoot, agentName, '.md', (n) => new RegExp(`@${n}\\b`, 'g'));
   132	}
   133	
   134	function scanYamlWorkflows(repoRoot, agentName) {
   135	  const yamlFiles = collectFiles(path.join(repoRoot, '.opencode/commands'));
   136	  const pattern = new RegExp(`(?:@${agentName}|\\b${agentName}\\b)`, 'g');
   137	  const results = [];
   138	  for (const file of yamlFiles) {
   139	    if (!file.endsWith('.yaml') && !file.endsWith('.yml')) continue;
   140	    const content = readOptional(file);
   141	    if (!content) continue;
   142	    const matches = content.match(pattern);
   143	    if (matches && matches.length > 0) {
   144	      results.push({ path: path.relative(repoRoot, file), references: [...new Set(matches)] });
   145	    }
   146	  }
   147	  return results;
   148	}
   149	
   150	function scanSkills(repoRoot, agentName) {
   151	  const skillDir = path.join(repoRoot, '.opencode/skills');
   152	  if (!fs.existsSync(skillDir)) return [];
   153	  const pattern = new RegExp(`\\b${agentName}\\b`, 'gi');
   154	  const results = [];
   155	  for (const entry of fs.readdirSync(skillDir, { withFileTypes: true })) {
   156	    if (!entry.isDirectory()) continue;
   157	    const skillMd = path.join(skillDir, entry.name, 'SKILL.md');
   158	    const content = readOptional(skillMd);
   159	    if (!content) continue;
   160	    const matches = content.match(pattern);
   161	    if (matches) results.push({ path: path.relative(repoRoot, skillMd), referenceCount: matches.length });
   162	  }
   163	  return results;
   164	}
   165	
   166	function scanGlobalDocs(repoRoot, agentName) {
   167	  const pattern = new RegExp(`\\b${agentName}\\b`, 'gi');
   168	  const results = [];
   169	  for (const relPath of GLOBAL_DOC_PATHS) {
   170	    const content = readOptional(path.join(repoRoot, relPath));
   171	    if (!content) continue;
   172	    const matches = content.match(pattern);
   173	    if (matches) results.push({ path: relPath, referenceCount: matches.length });
   174	  }
   175	  return results;
   176	}
   177	
   178	function scanSkillAdvisor(repoRoot, agentName) {
   179	  const content = readOptional(path.join(repoRoot, SKILL_ADVISOR_PATH));
   180	  return { path: SKILL_ADVISOR_PATH, matched: content !== null && new RegExp(`\\b${agentName}\\b`, 'i').test(content) };
   181	}
   182	
   183	// ─────────────────────────────────────────────────────────────────────────────
   184	// 6. MAIN
   185	// ─────────────────────────────────────────────────────────────────────────────
   186	function main() {
   187	  const args = parseArgs(process.argv.slice(2));
   188	  const agentName = args.agent;
   189	  const repoRoot = path.resolve(args['repo-root'] || '.');
   190	  const outputPath = args.output;
   191	
   192	  if (!agentName) {
   193	    process.stderr.write('Usage: node scan-integration.cjs --agent=<name> [--repo-root=.] [--output=path.json]\n');
   194	    process.exit(2);
   195	  }
   196	
   197	  const canonical = scanCanonical(repoRoot, agentName);
   198	  const canonicalContent = readOptional(path.join(repoRoot, canonical.path));
   199	  const canonicalBody = canonicalContent ? stripFrontmatter(canonicalContent) : '';
   200	  const mirrors = scanMirrors(repoRoot, agentName, canonicalBody);
   201	  const commands = scanCommands(repoRoot, agentName);
   202	  const yamlWorkflows = scanYamlWorkflows(repoRoot, agentName);
   203	  const skills = scanSkills(repoRoot, agentName);
   204	  const globalDocs = scanGlobalDocs(repoRoot, agentName);
   205	  const skillAdvisor = scanSkillAdvisor(repoRoot, agentName);
   206	
   207	  const existingMirrors = mirrors.filter((m) => m.exists).length;
   208	  const missingMirrors = mirrors.filter((m) => m.syncStatus === 'missing').length;
   209	  const divergedMirrors = mirrors.filter((m) => m.syncStatus === 'diverged').length;
   210	  const totalSurfaces = (canonical.exists ? 1 : 0) + existingMirrors
   211	    + commands.length + yamlWorkflows.length + skills.length
   212	    + globalDocs.length + (skillAdvisor.matched ? 1 : 0);
   213	
   214	  let mirrorSyncStatus = 'all-aligned';
   215	  if (missingMirrors > 0) mirrorSyncStatus = 'has-missing';
   216	  else if (divergedMirrors > 0) mirrorSyncStatus = 'has-divergence';
   217	
   218	  const result = {
   219	    status: 'complete',
   220	    agent: agentName,
   221	    timestamp: new Date().toISOString(),
   222	    surfaces: { canonical, mirrors, commands, yamlWorkflows, skills, globalDocs, skillAdvisor },
   223	    summary: {
   224	      totalSurfaces,
   225	      existingCount: totalSurfaces,
   226	      missingCount: missingMirrors + (canonical.exists ? 0 : 1),
   227	      mirrorSyncStatus,
   228	      commandCount: commands.length,
   229	      skillCount: skills.length,
   230	    },
   231	  };
   232	
   233	  const json = JSON.stringify(result, null, 2) + '\n';
   234	  process.stdout.write(json);
   235	  if (outputPath) {
   236	    fs.mkdirSync(path.dirname(path.resolve(outputPath)), { recursive: true });
   237	    fs.writeFileSync(path.resolve(outputPath), json, 'utf8');
   238	  }
   239	}
   240	
   241	main();

