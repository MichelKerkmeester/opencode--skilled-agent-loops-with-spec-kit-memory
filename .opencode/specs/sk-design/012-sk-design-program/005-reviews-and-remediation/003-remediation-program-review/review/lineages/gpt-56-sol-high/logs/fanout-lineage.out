      \"claim\": \"All four corpus consumers suppress their modeled requery-required state by classifying post-query generation drift as no-fit.\",\n      \"evidenceRefs\": [\n        \".opencode/skills/sk-design/design-audit/corpus/comparison-lane.mjs:374-403\",\n        \".opencode/skills/sk-design/design-audit/corpus/comparison-lane.mjs:503-508\",\n        \".opencode/skills/sk-design/design-foundations/corpus/relationship-blueprint.mjs:681-710\",\n        \".opencode/skills/sk-design/design-foundations/corpus/relationship-blueprint.mjs:854-855\",\n        \".opencode/skills/sk-design/design-interface/corpus/relational-exemplar.mjs:471-500\",\n        \".opencode/skills/sk-design/design-interface/corpus/relational-exemplar.mjs:622-628\",\n        \".opencode/skills/sk-design/design-motion/corpus/motion-evidence.mjs:509-538\",\n        \".opencode/skills/sk-design/design-motion/corpus/motion-evidence.mjs:808-815\"\n      ],\n      \"counterevidenceSought\": \"Mismatch warnings, no-source-influence containment, and concurrent-generation tests were reviewed; they prevent P0 stale-source use but do not emit requery-required.\",\n      \"alternativeExplanation\": \"No-fit may be intended as a safe target-derived continuation.\",\n      \"finalSeverity\": \"P1\",\n      \"confidence\": \"high\",\n      \"downgradeTrigger\": \"An explicit governing contract defines post-query mismatch as no-fit and proves no caller relies on requery-required.\"\n    }\n  }\n]\n","metadata":{"output":"[\n  {\n    \"id\": \"P1-006\",\n    \"findingId\": \"P1-006\",\n    \"severity\": \"P1\",\n    \"category\": \"security\",\n    \"title\": \"Post-query generation drift is mislabeled as no-fit in every corpus consumer\",\n    \"file\": \".opencode/skills/sk-design/design-audit/corpus/comparison-lane.mjs:503\",\n    \"evidence\": \"All four consumers detect a post-query generation mismatch but pass no-fit into builders that already model generation-mismatch as requery-required.\",\n    \"fi