acquired) {\n1200:       return { allowed: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n1201:     }\n1202:     try {\n1203:       const modelServerPid = readModelServerPid();\n1204:       if (!Number.isInteger(modelServerPid) || modelServerPid <= 0) {\n1205:         return { allowed: true, reaped: false, reason: 'missing-model-server-pid' };\n1206:       }\n1207:       return await getSupervisor().reapBeforeRespawn(modelServerPid);\n1208:     } finally {\n1209:       if (!options.lock) releaseRespawnLockFile(lock);\n1210:     }\n1211:   }\n1212: \n1213:   async function prepareModelServerDemandTarget(socketPath) {\n1214:     if (socketPath.startsWith('tcp://')) {\n1215:       const lock = acquireDemandRespawnLock(socketPath);\n1216:       if (!lock.acquired) return { shouldListen: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n1217:       return { shouldListen: true };\n1218:     }\n1219:     assertSunPathLimit(socketPath);\n1220:     // Keep SPECKIT_IPC_SOCKET_DIR fail-closed: never mkdir/unlink through a symlinked or foreign-owned perimeter.\n1221:     assertSocketDirOwnership(socketPath, { statApi, getuid, logger });\n1222:     fs.mkdirSync(path.dirname(socketPath), { recursive: true, mode: 0o700 });\n1223:     let deadProbeReason = null;\n1224:     if (fs.existsSync(socketPath)) {\n1225:       const probeModelServer = deps.bridge && deps.bridge.probeModelServer;\n1226:       if (typeof probeModelServer === 'function') {\n1227:         const probe = await probeModelServer(socketPath, { timeoutMs: 1000 });\n1228:         if (probe.status === 'alive') {\n1229:           if (probe.reason === 'health-ready') clearRecoveredGiveUpCooldown();\n1230:           return { shouldListen: false, reason: 'model-server-alive' };\n1231:         }\n1232:         deadProbeReason = probe.reason;\n1233:       }\n1234:     }\n1235: \n1236:     // The respawn lock is intentionally held across the bind + idle-listener window (released only on\n1237:     // demand-driven spawn, shutdown, or listen failure) so a second launcher sharing this socket loses\n1238:     // cleanly with 'model-server-respawn-lock-held' instead of racing the bind. (Lock LIFETIME differs\n1239:     // from the single-launcher path by design; the wx-open + UDS-bind primitives are unchanged.)\n1240:     const lock = acquireDemandRespawnLock(socketPath);\n1241:     if (!lock.acquired) return { shouldListen: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n1242:     let reapResult;\n1243:     if (fs.existsSync(socketPath)) {\n1244:       reapResult = await reapRecordedModelServerBeforeRespawn(socketPath, { lock });\n1245:     } else {\n1246:       // No socket file yet — but a sibling launcher may have JUST spawned the server: launch() writes the\n1247:       // shared hf-embed.pid synchronously before the child binds, so during the spawn->bind window the pid\n1248:       // is live while the socket is absent. Respect a live recorded pid so we do not clobber a booting\n1249:       // resident (the demand lock can be momentarily free right after a sibling's spawn).\n1250:       const recordedPid = readModelServerPid();\n1251:       if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n1252:         releaseDemandRespawnLock();\n1253:         return { shouldListen: false, reason: 'model-server-booting' };\n1254:       }\n1255:       reapResult = { allowed: true, reaped: false, reason: 'missing-model-server-pid' };\n1256:     }\n1257:     if (!reapResult.allowed) {\n1258:       releaseDemandRespawnLock();\n1259:       return { shouldListen: false, reason: reapResult.reason, lockPath: reapResult.lockPath };\n1260:     }\n1261:     if (reapResult.reaped && (deadProbeReason === 'loading-wedged' || deadProbeReason === 'health-error')) {\n1262:       armGiveUpCooldown();\n1263:     }\n1264:     unlinkModelServerSocket(socketPath);\n1265:     return { shouldListen: true, reason: reapResult.reason };\n1266:   }\n1267: \n1268:   function handleModelServerDemand(request, response) {\n1269:     const routePath = new URL(request.url || '/', 'http://127.0.0.1').pathname;\n1270:     // A launcher liveness probe must never be treated as embed demand. A sibling launcher's\n1271:     // boot-time health check would otherwise wake — and on a host where the local model is\n1272:     // unsupported, crash-loop — a model server that no consumer actually needs. Genuine consumers\n1273:     // never send this marker, so their lazy wake-on-demand path is unaffected.\n1274:     const probeMarker = request.headers && request.headers['x-speckit-probe'];\n1275:     if (typeof probeMarker === 'string' && probeMarker.toLowerCase() === 'liveness') {\n1276:       writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1277:         state: 'no-resident',\n1278:         reason: 'liveness-probe',\n1279:       });\n1280:       return;\n1281:     }\n1282:     const cooldown = activeGiveUpCooldown(state.demandTarget || resolveSocketPath());\n1283:     if (cooldown) {\n1284:       logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; crash-loop cooldown active for ${cooldown.retryAfterMs}ms`);\n1285:       writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1286:         state: 'error',\n1287:         reason: 'crash-loop-cooldown',\n1288:         retryAfterMs: cooldown.retryAfterMs,\n1289:       });\n1290:       return;\n1291:     }\n1292:     logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; spawning launcher-owned sibling`);\n1293:     releaseModelServerDemandListenerForSpawn({ keepRespawnLock: true });\n1294:     const launched = getSupervisor().launch();\n1295:     releaseDemandRespawnLock();\n1296:     if (!launched) {\n1297:       // launch() returned false (spawn produced no pid, or a child is already running). The\n1298:       // demand server was already torn down above and the respawn lock released, so without re-arming\n1299:       // the launcher is stranded — no listener, no resident, and no scheduled relaunch (the child\n1300:       // 'exit' handler is never wired when there is no valid child). Re-arm the lazy demand listener so\n1301:       // a later demand can retry. Fire-and-forget with a .catch: the interval/HTTP context has no\n1302:       // awaiter, and startModelServerDemandListener() self-guards via already-owned / lock-held when a\n1303:       // sibling won the race.\n1304:       logger('hf-model-server demand-driven launch produced no resident; re-arming lazy demand listener');\n1305:       void startModelServerDemandListener().catch((error) => {\n1306:         logger(`hf-model-server demand listener re-arm after spawn failure failed (will retry on next demand): ${error && error.message ? error.message : error}`);\n1307:       });\n1308:     }\n1309:     writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1310:       state: 'loading',\n1311:       modelServerLaunchRequested: true,\n1312:       launched,\n1313:     });\n1314:   }\n1315: \n1316:   async function startModelServerDemandListener(options = {}) {\n1317:     if (state.demandServer || getPid()) {\n1318:       return { started: false, reason: 'already-owned' };\n1319:     }\n1320: \n1321:     const socketPath = options.socketPath || resolveSocketPath();\n1322:     const prepared = options.skipPrepare ? { shouldListen: true } : await prepareModelServerDemandTarget(socketPath);\n1323:     if (!prepared.shouldListen) {\n1324:       logger(`hf-model-server demand listener skipped: ${prepared.reason}`);\n1325:       return { started: false, reason: prepared.reason, socketPath, lockPath: prepared.lockPath };\n1326:     }\n1327: \n1328:     const server = (deps.httpCreateServer || http.createServer)(handleModelServerDemand);\n1329:     try {\n1330:       await new Promise((resolve, reject) => {\n1331:         let reclaimedStaleSocket = false;\n1332:         const onError = (error) => {\n1333:           if (error && error.code === 'EADDRINUSE' && !socketPath.startsWith('tcp://') && !reclaimedStaleSocket) {\n1334:             // Only reclaim a CONFIRMED-STALE socket. If the shared pid still records a live resident,\n1335:             // a sibling launcher's server bound first — do not unlink its live socket (it serves embeds\n1336:             // for everyone). Reject so this launcher backs off rather than clobbering a working server.\n1337:             const recordedPid = readModelServerPid();\n1338:             if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n1339:               server.off('listening', onListening);\n1340:               reject(new Error(`hf-model-server socket ${socketPath} owned by a live resident (pid ${recordedPid}); not reclaiming`));\n1341:               return;\n1342:             }\n1343:             reclaimedStaleSocket = true;\n1344:             // The re-assert + reclaim runs inside this 'error' handler, which fires in a\n1345:             // microtask — a synchronous throw here would ESCAPE the Promise executor instead of\n1346:             // rejecting it. Wrap so a perimeter violation (symlinked node, etc.) or unlink failure\n1347:             // fails the listener closed (rejects → outer catch releases the lock and rethrows).\n1348:             try {\n1349:               assertSocketDirOwnership(socketPath, { statApi, getuid, logger });\n1350:               unlinkModelServerSocket(socketPath);\n1351:               server.listen(socketPath);\n1352:             } catch (reclaimError) {\n1353:               server.off('listening', onListening);\n1354:               reject(reclaimError);\n1355:             }\n1356:             return;\n1357:           }\n1358:           server.off('listening', onListening);\n1359:           reject(error);\n1360:         };\n1361:         const onListening = () => {\n1362:           server.off('error', onError);\n1363:           resolve();\n1364:         };\n1365:         server.on('error', onError);\n1366:         server.once('listening', onListening);\n1367:         if (socketPath.startsWith('tcp://')) {\n1368:           const url = new URL(socketPath);\n1369:           server.listen(Number.parseInt(url.port, 10), url.hostname || '127.0.0.1');\n1370:         } else {\n1371:           server.listen(socketPath);\n1372:         }\n1373:       });\n1374:     } catch (error) {\n1375:       releaseDemandRespawnLock();\n1376:       throw error;\n1377:     }\n1378: \n1379:     if (!socketPath.startsWith('tcp://')) {\n1380:       fs.chmodSync(socketPath, 0o600);\n1381:     }\n1382:     state.demandServer = server;\n1383:     state.demandTarget = socketPath;\n1384:     armIdleMonitor();\n1385:     logger(`hf-model-server lazy demand listener ready at ${socketPath}`);\n1386:     return { started: true, socketPath };\n1387:   }\n1388: \n1389:   return {\n1390:     start: startModelServerDemandListener,\n1391:     startDemandListener: startModelServerDemandListener,\n1392:     stopDemandListener: stopModelServerDemandListener,\n1393:     releaseDemandListenerForSpawn: releaseModelServerDemandListenerForSpawn,\n1394:     launch: () => getSupervisor().launch(),\n1395:     getPid,\n1396:     getChild: () => (state.supervisor ? state.supervisor.getChild() : null),\n1397:     getSnapshotPids: () => (state.supervisor ? state.supervisor.getSnapshotPids() : [...state.lastKnownDescendantPids]),\n1398:     clearTimers: () => {\n1399:       disarmIdleMonitor();\n1400:       if (state.supervisor) state.supervisor.clearTimers();\n1401:     },\n1402:     reapProcessTree: (childPid) => getSupervisor().reapProcessTree(childPid),\n1403:     reapBeforeRespawn: (childPid) => getSupervisor().reapBeforeRespawn(childPid),\n1404:     reapRecordedBeforeRespawn: reapRecordedModelServerBeforeRespawn,\n1405:     resolveSocketPath,\n1406:   };\n1407: }\n1408: \n1409: module.exports = {\n1410:   SHUTDOWN_DEADLINE_MS,\n1411:   RESPAWN_REAP_GRACE_MS,\n1412:   RESPAWN_LOCK_STALE_MS,\n1413:   DEFAULT_WATCHDOG_GRACE_MS,\n1414:   DEFAULT_WATCHDOG_INTERVAL_MS,\n1415:   DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES,\n1416:   DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS,\n1417:   DEFAULT_CRASH_LOOP_MAX_DEATHS,\n1418:   DEFAULT_CRASH_LOOP_WINDOW_MS,\n1419:   DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS,\n\n(Showing lines 1160-1419 of 1474. Use offset=1420 to continue.)\n</content>","metadata":{"preview":"      void tickIdleMonitor();\n    }, intervalMs);\n    state.idleTimer.unref?.();\n  }\n\n  function releaseModelServerDemandListenerForSpawn(options = {}) {\n    const server = state.demandServer;\n    const target = state.demandTarget;\n    state.demandServer = null;\n    state.demandTarget = null;\n    if (target) unlinkModelServerSocket(target);\n    if (server) {\n      server.close(() => undefined);\n    }\n    if (!options.keepRespawnLock) releaseDemandRespawnLock();\n  }\n\n  async function stopModelServerDemandListener() {\n    disarmIdleMonitor();\n    const server = state.demandServer;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"      void tickIdleMonitor();\n    }, intervalMs);\n    state.idleTimer.unref?.();\n  }\n\n  function releaseModelServerDemandListenerForSpawn(options = {}) {\n    const server = state.demandServer;\n    const target = state.demandTarget;\n    state.demandServer = null;\n    state.demandTarget = null;\n    if (target) unlinkModelServerSocket(target);\n    if (server) {\n      server.close(() => undefined);\n    }\n    if (!options.keepRespawnLock) releaseDemandRespawnLock();\n  }\n\n  async function stopModelServerDemandListener() {\n    disarmIdleMonitor();\n    const server = state.demandServer;\n    const target = state.demandTarget;\n    state.demandServer = null;\n    state.demandTarget = null;\n    try {\n      if (!server) {\n        if (target) unlinkModelServerSocket(target);\n        return;\n      }\n      await new Promise((resolve) => {\n        server.close(() => resolve());\n      });\n      if (target) unlinkModelServerSocket(target);\n    } finally {\n      releaseDemandRespawnLock();\n    }\n  }\n\n  async function reapRecordedModelServerBeforeRespawn(socketPath, options = {}) {\n    const lock = options.lock || acquireModelServerRespawnLockFile(socketPath, { dbDir, log: logger });\n    if (!lock.acquired) {\n      return { allowed: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n    }\n    try {\n      const modelServerPid = readModelServerPid();\n      if (!Number.isInteger(modelServerPid) || modelServerPid <= 0) {\n        return { allowed: true, reaped: false, reason: 'missing-model-server-pid' };\n      }\n      return await getSupervisor().reapBeforeRespawn(modelServerPid);\n    } finally {\n      if (!options.lock) releaseRespawnLockFile(lock);\n    }\n  }\n\n  async function prepareModelServerDemandTarget(socketPath) {\n    if (socketPath.startsWith('tcp://')) {\n      const lock = acquireDemandRespawnLock(socketPath);\n      if (!lock.acquired) return { shouldListen: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n      return { shouldListen: true };\n    }\n    assertSunPathLimit(socketPath);\n    // Keep SPECKIT_IPC_SOCKET_DIR fail-closed: never mkdir/unlink through a symlinked or foreign-owned perimeter.\n    assertSocketDirOwnership(socketPath, { statApi, getuid, logger });\n    fs.mkdirSync(path.dirname(socketPath), { recursive: true, mode: 0o700 });\n    let deadProbeReason = null;\n    if (fs.existsSync(socketPath)) {\n      const probeModelServer = deps.bridge && deps.bridge.probeModelServer;\n      if (typeof probeModelServer === 'function') {\n        const probe = await probeModelServer(socketPath, { timeoutMs: 1000 });\n        if (probe.status === 'alive') {\n          if (probe.reason === 'health-ready') clearRecoveredGiveUpCooldown();\n          return { shouldListen: false, reason: 'model-server-alive' };\n        }\n        deadProbeReason = probe.reason;\n      }\n    }\n\n    // The respawn lock is intentionally held across the bind + idle-listener window (released only on\n    // demand-driven spawn, shutdown, or listen failure) so a second launcher sharing this socket loses\n    // cleanly with 'model-server-respawn-lock-held' instead of racing the bind. (Lock LIFETIME differs\n    // from the single-launcher path by design; the wx-open + UDS-bind primitives are unchanged.)\n    const lock = acquireDemandRespawnLock(socketPath);\n    if (!lock.acquired) return { shouldListen: false, reason: respawnLockBlockedReason(lock), lockPath: lock.path };\n    let reapResult;\n    if (fs.existsSync(socketPath)) {\n      reapResult = await reapRecordedModelServerBeforeRespawn(socketPath, { lock });\n    } else {\n      // No socket file yet — but a sibling launcher may have JUST spawned the server: launch() writes the\n      // shared hf-embed.pid synchronously before the child binds, so during the spawn->bind window the pid\n      // is live while the socket is absent. Respect a live recorded pid so we do not clobber a booting\n      // resident (the demand lock can be momentarily free right after a sibling's spawn).\n      const recordedPid = readModelServerPid();\n      if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n        releaseDemandRespawnLock();\n        return { shouldListen: false, reason: 'model-server-booting' };\n      }\n      reapResult = { allowed: true, reaped: false, reason: 'missing-model-server-pid' };\n    }\n    if (!reapResult.allowed) {\n      releaseDemandRespawnLock();\n      return { shouldListen: false, reason: reapResult.reason, lockPath: reapResult.lockPath };\n    }\n    if (reapResult.reaped && (deadProbeReason === 'loading-wedged' || deadProbeReason === 'health-error')) {\n      armGiveUpCooldown();\n    }\n    unlinkModelServerSocket(socketPath);\n    return { shouldListen: true, reason: reapResult.reason };\n  }\n\n  function handleModelServerDemand(request, response) {\n    const routePath = new URL(request.url || '/', 'http://127.0.0.1').pathname;\n    // A launcher liveness probe must never be treated as embed demand. A sibling launcher's\n    // boot-time health check would otherwise wake — and on a host where the local model is\n    // unsupported, crash-loop — a model server that no consumer actually needs. Genuine consumers\n    // never send this marker, so their lazy wake-on-demand path is unaffected.\n    const probeMarker = request.headers && request.headers['x-speckit-probe'];\n    if (typeof probeMarker === 'string' && probeMarker.toLowerCase() === 'liveness') {\n      writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n        state: 'no-resident',\n        reason: 'liveness-probe',\n      });\n      return;\n    }\n    const cooldown = activeGiveUpCooldown(state.demandTarget || resolveSocketPath());\n    if (cooldown) {\n      logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; crash-loop cooldown active for ${cooldown.retryAfterMs}ms`);\n      writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n        state: 'error',\n        reason: 'crash-loop-cooldown',\n        retryAfterMs: cooldown.retryAfterMs,\n      });\n      return;\n    }\n    logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; spawning launcher-owned sibling`);\n    releaseModelServerDemandListenerForSpawn({ keepRespawnLock: true });\n    const launched = getSupervisor().launch();\n    releaseDemandRespawnLock();\n    if (!launched) {\n      // launch() returned false (spawn produced no pid, or a child is already running). The\n      // demand server was already torn down above and the respawn lock released, so without re-arming\n      // the launcher is stranded — no listener, no resident, and no scheduled relaunch (the child\n      // 'exit' handler is never wired when there is no valid child). Re-arm the lazy demand listener so\n      // a later demand can retry. Fire-and-forget with a .catch: the interval/HTTP context has no\n      // awaiter, and startModelServerDemandListener() self-guards via already-owned / lock-held when a\n      // sibling won the race.\n      logger('hf-model-server demand-driven launch produced no resident; re-arming lazy demand listener');\n      void startModelServerDemandListener().catch((error) => {\n        logger(`hf-model-server demand listener re-arm after spawn failure failed (will retry on next demand): ${error && error.message ? error.message : error}`);\n      });\n    }\n    writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n      state: 'loading',\n      modelServerLaunchRequested: true,\n      launched,\n    });\n  }\n\n  async function startModelServerDemandListener(options = {}) {\n    if (state.demandServer || getPid()) {\n      return { started: false, reason: 'already-owned' };\n    }\n\n    const socketPath = options.socketPath || resolveSocketPath();\n    const prepared = options.skipPrepare ? { shouldListen: true } : await prepareModelServerDemandTarget(socketPath);\n    if (!prepared.shouldListen) {\n      logger(`hf-model-server demand listener skipped: ${prepared.reason}`);\n      return { started: false, reason: prepared.reason, socketPath, lockPath: prepared.lockPath };\n    }\n\n    const server = (deps.httpCreateServer || http.createServer)(handleModelServerDemand);\n    try {\n      await new Promise((resolve, reject) => {\n        let reclaimedStaleSocket = false;\n        const onError = (error) => {\n          if (error && error.code === 'EADDRINUSE' && !socketPath.startsWith('tcp://') && !reclaimedStaleSocket) {\n            // Only reclaim a CONFIRMED-STALE socket. If the shared pid still records a live resident,\n            // a sibling launcher's server bound first — do not unlink its live socket (it serves embeds\n            // for everyone). Reject so this launcher backs off rather than clobbering a working server.\n            const recordedPid = readModelServerPid();\n            if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n              server.off('listening', onListening);\n              reject(new Error(`hf-model-server socket ${socketPath} owned by a live resident (pid ${recordedPid}); not reclaiming`));\n              return;\n            }\n            reclaimedStaleSocket = true;\n            // The re-assert + reclaim runs inside this 'error' handler, which fires in a\n            // microtask — a synchronous throw here would ESCAPE the Promise executor instead of\n            // rejecting it. Wrap so a perimeter violation (symlinked node, etc.) or unlink failure\n            // fails the listener closed (rejects → outer catch releases the lock and rethrows).\n            try {\n              assertSocketDirOwnership(socketPath, { statApi, getuid, logger });\n              unlinkModelServerSocket(socketPath);\n              server.listen(socketPath);\n            } catch (reclaimError) {\n              server.off('listening', onListening);\n              reject(reclaimError);\n            }\n            return;\n          }\n          server.off('listening', onListening);\n          reject(error);\n        };\n        const onListening = () => {\n          server.off('error', onError);\n          resolve();\n        };\n        server.on('error', onError);\n        server.once('listening', onListening);\n        if (socketPath.startsWith('tcp://')) {\n          const url = new URL(socketPath);\n          server.listen(Number.parseInt(url.port, 10), url.hostname || '127.0.0.1');\n        } else {\n          server.listen(socketPath);\n        }\n      });\n    } catch (error) {\n      releaseDemandRespawnLock();\n      throw error;\n    }\n\n    if (!socketPath.startsWith('tcp://')) {\n      fs.chmodSync(socketPath, 0o600);\n    }\n    state.demandServer = server;\n    state.demandTarget = socketPath;\n    armIdleMonitor();\n    logger(`hf-model-server lazy demand listener ready at ${socketPath}`);\n    return { started: true, socketPath };\n  }\n\n  return {\n    start: startModelServerDemandListener,\n    startDemandListener: startModelServerDemandListener,\n    stopDemandListener: stopModelServerDemandListener,\n    releaseDemandListenerForSpawn: releaseModelServerDemandListenerForSpawn,\n    launch: () => getSupervisor().launch(),\n    getPid,\n    getChild: () => (state.supervisor ? state.supervisor.getChild() : null),\n    getSnapshotPids: () => (state.supervisor ? state.supervisor.getSnapshotPids() : [...state.lastKnownDescendantPids]),\n    clearTimers: () => {\n      disarmIdleMonitor();\n      if (state.supervisor) state.supervisor.clearTimers();\n    },\n    reapProcessTree: (childPid) => getSupervisor().reapProcessTree(childPid),\n    reapBeforeRespawn: (childPid) => getSupervisor().reapBeforeRespawn(childPid),\n    reapRecordedBeforeRespawn: reapRecordedModelServerBeforeRespawn,\n    resolveSocketPath,\n  };\n}\n\nmodule.exports = {\n  SHUTDOWN_DEADLINE_MS,\n  RESPAWN_REAP_GRACE_MS,\n  RESPAWN_LOCK_STALE_MS,\n  DEFAULT_WATCHDOG_GRACE_MS,\n  DEFAULT_WATCHDOG_INTERVAL_MS,\n  DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES,\n  DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS,\n  DEFAULT_CRASH_LOOP_MAX_DEATHS,\n  DEFAULT_CRASH_LOOP_WINDOW_MS,\n  DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS,","lineStart":1160,"lineEnd":1419,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781764062936,"end":1781764062942}},"metadata":{"openai":{"itemId":"fc_0e5479c4caf315c9016a338fde987c819184811c946363bbef"}},"id":"prt_ed969fec9001oVcitqm4yHbdgU","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed969b927001sCY1VSSjMBR9bQ"}}
{"type":"tool_use","timestamp":1781764062959,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_GYCWmEPzVFUatIFrZ2Pq38vu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":900,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n900:     startRssWatchdog(childPid, {\n901:       config: watchdogConfig(),\n902:       label: 'hf-model-server',\n903:       runner: processRowsRunner,\n904:       log: logger,\n905:       timerState: {\n906:         get: () => state.rssWatchdogTimer,\n907:         set: (timer) => {\n908:           state.rssWatchdogTimer = timer;\n909:         },\n910:       },\n911:       snapshot: {\n912:         set: (pids) => {\n913:           state.lastKnownDescendantPids = pids;\n914:         },\n915:       },\n916:       onBreach: onRssBreach,\n917:     });\n918: \n919:     state.child.on('exit', (code, signalCode) => {\n920:       if (shouldExitLauncher()) {\n921:         return;\n922:       }\n923:       const result = superviseChildExit(\n924:         { code, signal: signalCode, childPid, intentional: false },\n925:         {\n926:           crashLoopGuard: state.crashLoopGuard,\n927:           clearLease: () => {\n928:             state.child = null;\n929:             writeLease(null);\n930:           },\n931:           reapProcessGroup: reapProcessTree,\n932:           mirrorSignal: (exitSignal) => logger(`hf-model-server crash loop exhausted after signal ${exitSignal}; daemon remains running`),\n933:           exit: (exitCode) => logger(`hf-model-server crash loop exhausted with exit ${exitCode}; daemon remains running`),\n934:           scheduleRelaunch: (backoffMs) => {\n935:             logger(`hf-model-server child exited code=${code ?? 'null'} signal=${signalCode ?? 'null'}; relaunching in ${backoffMs}ms`);\n936:             state.relaunchTimer = setTimer(() => launch(), backoffMs);\n937:             state.relaunchTimer.unref?.();\n938:           },\n939:         },\n940:       );\n941:       if (result.action === 'give-up') {\n942:         writeGiveUpUntil(nowMs() + giveUpCooldownMs);\n943:         logger(`hf-model-server crash loop detected after ${result.deathsInWindow} deaths; modelServerPid removed from lease`);\n944:         scheduleDemandListener();\n945:       }\n946:     });\n947: \n948:     state.child.on('error', (error) => {\n949:       logger(error.stack || error.message);\n950:     });\n951:     return true;\n952:   }\n953: \n954:   return {\n955:     clearTimers,\n956:     getChild: () => state.child,\n957:     getPid,\n958:     getSnapshotPids: () => [...state.lastKnownDescendantPids],\n959:     launch,\n960:     reapBeforeRespawn,\n961:     reapProcessTree,\n962:   };\n963: }\n964: \n965: function createModelServerControl(deps = {}) {\n966:   const logger = deps.log || defaultLog;\n967:   const env = deps.env || process.env;\n968:   const rootDir = deps.rootDir || defaultRoot;\n969:   const opencodeDir = deps.opencodeDir || path.join(rootDir, '.opencode');\n970:   const dbDir = deps.dbDir || (() => path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'));\n971:   const modelServerPath = deps.modelServerPath || path.join(opencodeDir, 'bin', 'hf-model-server.cjs');\n972:   const signal = deps.signal || signalProcess;\n973:   const processRowsRunner = deps.processRowsRunner || defaultProcessRowsRunner;\n974:   const liveness = deps.liveness || processLiveness;\n975:   const nowMs = typeof deps.nowMs === 'function' ? deps.nowMs : () => Date.now();\n976:   const giveUpCooldownMs = parsePositiveInteger(deps.giveUpCooldownMs, getModelServerGiveUpCooldownMs(env));\n977:   const idleConfig = deps.idleConfig || getModelServerIdleConfig(env);\n978:   const setIntervalFn = deps.setInterval || setInterval;\n979:   const clearIntervalFn = deps.clearInterval || clearInterval;\n980:   const statApi = deps.statApi || fs;\n981:   const getuid = typeof deps.getuid === 'function' ? deps.getuid : () => process.getuid?.();\n982:   const state = {\n983:     demandServer: null,\n984:     demandTarget: null,\n985:     demandRespawnLock: null,\n986:     supervisor: null,\n987:     lastKnownDescendantPids: [],\n988:     idleTimer: null,\n989:     idleTickInFlight: false,\n990:   };\n991: \n992:   const resolveSocketPath = (options = {}) => {\n993:     if (typeof deps.resolveSocketPath === 'function') return deps.resolveSocketPath(options);\n994:     return resolveModelServerSocketPath(env, {\n995:       ...options,\n996:       dbDir,\n997:     });\n998:   };\n999: \n1000:   function writeModelServerPid(pid) {\n1001:     if (typeof deps.writeModelServerPid === 'function') deps.writeModelServerPid(pid);\n1002:     if (typeof deps.writeLease === 'function') deps.writeLease(pid);\n1003:   }\n1004: \n1005:   function readModelServerPid() {\n1006:     if (typeof deps.readModelServerPid === 'function') return deps.readModelServerPid();\n1007:     return null;\n1008:   }\n1009: \n1010:   function writeGiveUpUntil(giveUpUntilMs) {\n1011:     const socketPath = resolveSocketPath();\n1012:     if (typeof deps.writeGiveUpUntil === 'function') {\n1013:       return deps.writeGiveUpUntil(giveUpUntilMs, socketPath);\n1014:     }\n1015:     return writeModelServerGiveUpUntil(socketPath, giveUpUntilMs, { dbDir, log: logger });\n1016:   }\n1017: \n1018:   function readGiveUpUntil(socketPath = resolveSocketPath()) {\n1019:     if (typeof deps.readGiveUpUntil === 'function') return deps.readGiveUpUntil(socketPath);\n1020:     return readModelServerGiveUpUntil(socketPath, {\n1021:       dbDir,\n1022:       env,\n1023:       giveUpCooldownMs,\n1024:       liveness,\n1025:       nowMs,\n1026:     });\n1027:   }\n1028: \n1029:   function activeGiveUpCooldown(socketPath = resolveSocketPath()) {\n1030:     const giveUpUntil = readGiveUpUntil(socketPath);\n1031:     const current = nowMs();\n1032:     if (!Number.isFinite(giveUpUntil) || giveUpUntil <= current) return null;\n1033:     return {\n1034:       giveUpUntil,\n1035:       retryAfterMs: Math.max(1, giveUpUntil - current),\n1036:     };\n1037:   }\n1038: \n1039:   function getSupervisor() {\n1040:     if (!state.supervisor) {\n1041:       state.supervisor = createModelServerSupervisor({\n1042:         spawnFn: deps.spawnFn,\n1043:         child: deps.child,\n1044:         crashLoopGuard: deps.crashLoopGuard,\n1045:         env,\n1046:         rootDir,\n1047:         modelServerPath,\n1048:         log: logger,\n1049:         writeLease: writeModelServerPid,\n1050:         writeGiveUpUntil,\n1051:         giveUpCooldownMs,\n1052:         crashLoopConfig: deps.crashLoopConfig || (() => getCrashLoopConfig(env)),\n1053:         watchdogConfig: deps.watchdogConfig || (() => getModelServerWatchdogConfig(env, logger)),\n1054:         processRowsRunner,\n1055:         signal,\n1056:         liveness: deps.liveness || processLiveness,\n1057:         waitForExit: deps.waitForExit || waitForPidExit,\n1058:         setTimeout: deps.setTimeout || setTimeout,\n1059:         clearTimeout: deps.clearTimeout || clearTimeout,\n1060:         nowMs,\n1061:         shouldExitLauncher: deps.getLauncherShutdownInProgress || (() => false),\n1062:         onRssBreach: deps.onRssBreach || (() => undefined),\n1063:         startDemandListener: () => startModelServerDemandListener(),\n1064:       });\n1065:     }\n1066:     return state.supervisor;\n1067:   }\n1068: \n1069:   function getPid() {\n1070:     return state.supervisor ? state.supervisor.getPid() : null;\n1071:   }\n1072: \n1073:   function releaseDemandRespawnLock() {\n1074:     releaseRespawnLockFile(state.demandRespawnLock);\n1075:     state.demandRespawnLock = null;\n1076:   }\n1077: \n1078:   function acquireDemandRespawnLock(socketPath) {\n1079:    