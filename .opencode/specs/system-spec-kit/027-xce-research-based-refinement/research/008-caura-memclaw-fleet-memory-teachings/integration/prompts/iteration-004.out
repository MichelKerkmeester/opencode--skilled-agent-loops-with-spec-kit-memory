dlers/checkpoints.ts:\n  Line 659: async function handleCheckpointDelete(args: CheckpointDeleteArgs): Promise<MCPResponse> {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/chunking-orchestrator.ts:\n  Line 23: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n\n  Line 251:   // Use existingParentUpdated below for mutation ledger (replaces `existing` variable)\n\n  Line 604:   appendMutationLedgerSafe(database, {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/pe-gating.ts:\n  Line 239: /** Mark a memory as superseded (deprecated) when a newer contradicting version is saved */\n\n  Line 246:       SET importance_tier = 'deprecated',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/pe-orchestration.ts:\n  Line 9: import { getMemoryHashSnapshot, appendMutationLedgerSafe } from '../memory-crud-utils.js';\n\n  Line 123:           const ledgerRecorded = appendMutationLedgerSafe(database, {\n\n  Line 175:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/reconsolidation-bridge.ts:\n  Line 26: import { appendMutationLedgerSafe } from '../memory-crud-utils.js';\n\n  Line 698:           const ledgerRecorded = appendMutationLedgerSafe(database, {\n\n  Line 812:             `older=${topId} similarity=${similarity.toFixed(3)}; archived-tier side effects are disabled`\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts:\n  Line 29: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n\n  Line 262:       const ledgerRecorded = appendMutationLedgerSafe(database,