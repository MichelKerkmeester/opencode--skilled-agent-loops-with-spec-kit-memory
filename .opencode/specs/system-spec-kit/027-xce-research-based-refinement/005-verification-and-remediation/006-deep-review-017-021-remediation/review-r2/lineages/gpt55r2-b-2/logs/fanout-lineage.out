        \"matched_phrases\": [\n            \"phase\",\n            \"system\",\n            \"021\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 6626,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/007-system-spec-kit-rename\",\n          \"title\": \"Skill Rename [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/007-system-spec-kit-rename/spec]\",\n          \"matched_phrases\": [\n            \"skill\",\n            \"spec\",\n            \"kit\",\n            \"system\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-06-18T05:43:05.794Z\",\n      \"latencyMs\": 459\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781761385332,"end":1781761385842}},"metadata":{"openai":{"itemId":"fc_05a6767a11c97733016a3385669ee08191ae25182c7a9837e9"}},"id":"prt_ed94118e8001OaqUeRnIGyoTjf","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed94103f5001cGglG1zxBHPqSl"}}
