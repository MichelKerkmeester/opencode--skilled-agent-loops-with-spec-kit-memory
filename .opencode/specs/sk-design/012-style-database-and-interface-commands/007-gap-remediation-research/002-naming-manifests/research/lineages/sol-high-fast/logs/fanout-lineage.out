p\",\"## 7. Canonical Source-of-Truth Design\",\"## 10. Import and Reference Update Plan\",\"## 11. Two-Checkpoint Migration and Verification\",\"## Eliminated Alternatives\",\"## Divergence Map\",\"## 12. Open Questions\",\"## 16. Convergence Report\",\"## 17. Conclusion\"];const missing=required.filter(x=>!synthesis.includes(x));const name=i=>String(i).padStart(3,\"0\");const deltas=[1,2,3,4,5].every(i=>fs.existsSync(p.join(root,\"deltas\",\"iter-\"+name(i)+\".jsonl\")));const narratives=[1,2,3,4,5].every(i=>fs.existsSync(p.join(root,\"iterations\",\"iteration-\"+name(i)+\".md\")));const completeEvent=rows.find(r=>r.event===\"synthesis_complete\");const out={configStatus:config.status,iterations:iterations.length,uniqueRuns:new Set(iterations.map(r=>r.run)).size,resolvedQuestions:registry.metrics.resolvedQuestions,openQuestions:registry.metrics.openQuestions,synthesisComplete:Boolean(completeEvent),stopReason:completeEvent&&completeEvent.stopReason,deltas,narratives,missingSynthesisSections:missing,citations:(synthesis.match(/\\[(SOURCE|INFERENCE):/g)||[]).length,resourceMap:fs.existsSync(p.join(root,\"resource-map.md\"))};console.log(JSON.stringify(out,null,2));if(config.status!==\"complete\"||iterations.length!==5||out.uniqueRuns!==5||registry.metrics.resolvedQuestions!==5||registry.metrics.openQuestions!==0||!out.synthesisComplete||!deltas||!narratives||missing.length||out.citations<10||!out.resourceMap)process.exit(1);' \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/002-naming-manifests/research/lineages/sol-high-fast\"","time":{"start":1784622602592,"end":1784622602597}},"metadata":{"openai":{"itemId":"fc_0b6966efa0231b58016a5f2e00cef48191b1d87bc1c13a0448"}},"id":"prt_f83cbb372001Go5sfcyV7OwerF","sessionID":"ses_07c62e1e5ffemFsnADH4fVqMT5","messageID":"msg_f83cb8d4d001Q203XxpoSde4HZ"}}
