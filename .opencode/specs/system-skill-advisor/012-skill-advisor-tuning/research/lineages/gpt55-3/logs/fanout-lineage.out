cript that counts\",\n125:     \"counts how many\",\n126:     \"build a script that\",\n127:     \"code review\",\n128:     \"pr review\",\n129:     \"security review\",\n130:     \"quality gate\",\n131:     \"findings\",\n132:     \"audit packet docs\",\n133:     \"review packet docs\",\n134:     \"merge readiness\",\n135:     \"quality check\",\n136:     \"check before done\",\n137:     \"author quality gate\",\n138:     \"pre-verification quality check\",\n139:     \"p0 p1 p2 review\"\n140:   ],\n141:   \"derived\": {\n142:     \"trigger_phrases\": [\n143:       \"sk-code\",\n144:       \"code work\",\n145:       \"surface-aware code implementation\",\n146:       \"frontend implementation standards\",\n147:       \"opencode typescript verification\",\n148:       \"motion animation integration\",\n149:       \"stack-specific code quality gate\",\n150:       \"language-specific verification commands\",\n151:       \"surface detection routing\",\n152:       \"webflow frontend workflow\",\n153:       \"opencode system code workflow\",\n154:       \"alignment verifier workflow\",\n155:       \"code quality gate\",\n156:       \"verification commands\",\n157:       \"sk-code hub\",\n158:       \"code mode router\",\n159:       \"workflow doctrine\",\n160:       \"review mode\",\n161:       \"author quality gate\",\n162:       \"quality check\"\n163:     ],\n164:     \"key_topics\": [\n165:       \"code\",\n166:       \"surface-aware-routing\",\n167:       \"webflow\",\n168:       \"motion_dev\",\n169:       \"cross-stack-animation\",\n170:       \"opencode\",\n171:       \"language-sub-detection\",\n172:       \"code-quality\",\n173:       \"verification\",\n174:       \"mode-registry\",\n175:       \"workflowMode\",\n176:       \"backendKind\",\n177:       \"surface-router\",\n178:       \"workflow-doctrine\",\n179:       \"quality-mode\",\n180:       \"review-mode\",\n181:       \"quality-gate\"\n182:     ],\n183:     \"intent_signals\": [\n184:       \"implement code\",\n185:       \"fix bug\",\n186:       \"refactor\",\n187:       \"detect code surface\",\n188:       \"verify after change\"\n189:     ],\n190:     \"source_docs\": [\n191:       \"SKILL.md\",\n192:       \"README.md\",\n193:       \"mode-registry.json\",\n194:       \"hub-router.json\",\n195:       \"shared/references/stack_detection.md\",\n196:       \"shared/references/smart_routing.md\",\n197:       \"shared/references/phase_detection.md\",\n198:       \"code-webflow/references/animation/animate_and_timelines.md\",\n199:       \"code-webflow/references/animation/decision_matrix.md\",\n200:       \"code-webflow/references/animation/integration_patterns.md\",\n201:       \"code-webflow/references/animation/performance_and_pitfalls.md\",\n202:       \"code-webflow/references/animation/quick_start.md\",\n203:       \"code-webflow/references/animation/scroll_and_gestures.md\",\n204:       \"code-webflow/SKILL.md\",\n205:       \"code-opencode/SKILL.md\"\n206:     ],\n207:     \"key_files\": [\n208:       \".opencode/skills/sk-code/SKILL.md\",\n209:       \".opencode/skills/sk-code/README.md\",\n210:       \".opencode/skills/sk-code/mode-registry.json\",\n211:       \".opencode/skills/sk-code/hub-router.json\",\n212:       \".opencode/skills/sk-code/code-quality/SKILL.md\",\n213:       \".opencode/skills/sk-code/code-review/SKILL.md\",\n214:       \".opencode/skills/sk-code/shared/references/stack_detection.md\",\n215:       \".opencode/skills/sk-code/shared/references/smart_routing.md\",\n216:       \".opencode/skills/sk-code/shared/references/phase_detection.md\",\n217:       \".opencode/skills/sk-code/code-webflow/references/animation/quick_start.md\",\n218:       \".opencode/skills/sk-code/code-webflow/references/animation/decision_matrix.md\",\n219:       \".opencode/skills/sk-code/code-webflow/references/animation/integration_patterns.md\",\n220:       \".opencode/skills/sk-code/code-webflow/references/animation/performance_and_pitfalls.md\",\n221:       \".opencode/skills/sk-code/code-webflow/assets/animation/install_card.md\",\n222:       \".opencode/skills/sk-code/code-webflow/assets/animation/playbook_entries.md\",\n223:       \".opencode/skills/sk-code/code-webflow/assets/patterns/wait_patterns.js\",\n224:       \".opencode/skills/sk-code/code-webflow/references/implementation/implementation_workflows.md\",\n225:       \".opencode/skills/sk-code/code-opencode/references/shared/universal_patterns.md\",\n226:       \".opencode/skills/sk-code/code-opencode/assets/scripts/verify_alignment_drift.py\",\n227:       \".opencode/skills/sk-code/code-webflow/SKILL.md\",\n228:       \".opencode/skills/sk-code/code-opencode/SKILL.md\"\n229:     ],\n230:     \"entities\": [\n231:       {\n232:         \"name\": \"sk-code\",\n233:         \"kind\": \"skill\",\n234:         \"path\": \".opencode/skills/sk-code/SKILL.md\",\n235:         \"source\": \"derived\"\n236:       },\n237:       {\n238:         \"name\": \"motion_dev\",\n239:         \"kind\": \"reference\",\n240:         \"path\": \".opencode/skills/sk-code/code-webflow/references/animation/quick_start.md\",\n241:         \"source\": \"derived\"\n242:       },\n243:       {\n244:         \"name\": \"code_surface_detection\",\n245:         \"kind\": \"reference\",\n246:         \"path\": \".opencode/skills/sk-code/shared/references/stack_detection.md\",\n247:         \"source\": \"derived\"\n248:       },\n249:       {\n250:         \"name\": \"verify_alignment_drift\",\n251:         \"kind\": \"script\",\n252:         \"path\": \".opencode/skills/sk-code/code-opencode/assets/scripts/verify_alignment_drift.py\",\n253:         \"source\": \"derived\"\n254:       }\n255:     ],\n256:     \"causal_summary\": \"sk-code is the single public code skill that routes a request through mode-registry.json to two workflow modes (quality, code-review) or bundles one of two read-only surface evidence packets (code-webflow, code-opencode) over a shared surface-detection router. Each surface carries the shared implement/debug/verify workflow doctrine plus its stack knowledge; code-webflow also carries the Motion.dev animation overlay. The shared router centralizes WEBFLOW, OPENCODE, and MOTION_DEV identity and precedence so the advisor sees exactly one code identity.\",\n257:     \"created_at\": \"2026-04-30T08:30:00Z\",\n258:     \"last_updated_at\": \"2026-07-06T00:00:00Z\",\n259:     \"supported_surfaces\": [\n260:       \"WEBFLOW\",\n\n(Showing lines 1-260 of 267. Use offset=261 to continue.)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"sk-code\",\n  \"family\": \"sk-code\",\n  \"category\": \"code-quality\",\n  \"deprecated\": false,\n  \"edges\": {\n    \"depends_on\": [],\n    \"enhances\": [\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.3,\n        \"context\": \"opencode standards and verification for spec-kit system code\"\n      }\n    ],\n    \"siblings\": [\n      {\n        \"target\": \"sk-design\",\n        \"weight\": 0.4,\n        \"context\": \"design-and-build pair: sk-design owns the look, sk-code owns the implementation\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/graph-metadata.json","text":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"sk-code\",\n  \"family\": \"sk-code\",\n  \"category\": \"code-quality\",\n  \"deprecated\": false,\n  \"edges\": {\n    \"depends_on\": [],\n    \"enhances\": [\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.3,\n        \"context\": \"opencode standards and verification for spec-kit system code\"\n      }\n    ],\n    \"siblings\": [\n      {\n        \"target\": \"sk-design\",\n        \"weight\": 0.4,\n        \"context\": \"design-and-build pair: sk-design owns the look, sk-code owns the implementation\"\n      }\n    ],\n    \"conflicts_with\": [],\n    \"prerequisite_for\": [\n      {\n 