{"type":"tool_use","timestamp":1781764062807,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_f7difOZ0dW7v6xEdNX49jWDo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // --------------------------------------------------------------------------\n3: // COMPONENT: Spec Memory CLI Shim\n4: // PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n5: // --------------------------------------------------------------------------\n6: 'use strict';\n7: \n8: const fs = require('fs');\n9: const path = require('path');\n10: const crypto = require('crypto');\n11: const { spawnSync } = require('child_process');\n12: \n13: const opencodeDir = path.resolve(__dirname, '..');\n14: const mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\n15: const cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\n16: const sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\n17: const defaultSocketDir = '/tmp/mk-spec-memory';\n18: const socketFileName = 'daemon-ipc.sock';\n19: const allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n20: \n21: function fail(message) {\n22:   process.stderr.write(`${message}\\n`);\n23:   process.exit(69);\n24: }\n25: \n26: // Recursively collects the CLI's compiled-source surface (entry, local schema\n27: // imports, tsconfig) so new files under candidate directories are watched\n28: // without editing this list. Must stay in lock-step with\n29: // scripts/finalize-dist.mjs, which writes the matching hash at build time.\n30: function sourceCandidates() {\n31:   const candidates = [\n32:     path.join(mcpServerDir, 'spec-memory-cli.ts'),\n33:     path.join(mcpServerDir, 'tool-schemas.ts'),\n34:     path.join(mcpServerDir, 'tsconfig.json'),\n35:     path.join(mcpServerDir, 'schemas'),\n36:   ];\n37:   const files = [];\n38: \n39:   const visit = (candidate) => {\n40:     if (!fs.existsSync(candidate)) return;\n41:     const stat = fs.statSync(candidate);\n42:     if (stat.isDirectory()) {\n43:       for (const entry of fs.readdirSync(candidate)) {\n44:         visit(path.join(candidate, entry));\n45:       }\n46:       return;\n47:     }\n48:     if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n49:       files.push(candidate);\n50:     }\n51:   };\n52: \n53:   for (const candidate of candidates) visit(candidate);\n54:   return files;\n55: }\n56: \n57: function hashSourceFiles(existingSources) {\n58:   const hash = crypto.createHash('sha256');\n59:   for (const filePath of [...existingSources].sort()) {\n60:     hash.update(path.relative(mcpServerDir, filePath));\n61:     hash.update('\\0');\n62:     hash.update(fs.readFileSync(filePath));\n63:     hash.update('\\0');\n64:   }\n65:   return hash.digest('hex');\n66: }\n67: \n68: function readStoredSourceHash() {\n69:   try {\n70:     const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n71:     return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n72:   } catch {\n73:     return null;\n74:   }\n75: }\n76: \n77: function writeStoredSourceHash(sourceHash) {\n78:   try {\n79:     fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n80:     fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n81:   } catch {\n82:     // Freshness metadata is an optimization; stale detection remains conservative.\n83:   }\n84: }\n85: \n86: function ensureFreshDist() {\n87:   if (!fs.existsSync(cliDist)) {\n88:     fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n89:   }\n90:   if (allowStale) return;\n91:   const existingSources = sourceCandidates();\n92:   if (existingSources.length === 0) return;\n93:   const currentSourceHash = hashSourceFiles(existingSources);\n94:   if (readStoredSourceHash() === currentSourceHash) return;\n95:   const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n96:   const distMtime = fs.statSync(cliDist).mtimeMs;\n97:   if (newestSourceMtime > distMtime) {\n98:     fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n99:   }\n100:   writeStoredSourceHash(currentSourceHash);\n101: }\n102: \n103: function ensureSocketDir() {\n104:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n105:     process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n106:   }\n107:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n108:   if (socketDir.startsWith('tcp://')) return;\n109:   fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n110:   const socketPath = path.join(path.resolve(socketDir), socketFileName);\n111:   if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n112:     fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n113:   }\n114: }\n115: \n116: ensureSocketDir();\n117: ensureFreshDist();\n118: \n119: const result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n120:   cwd: path.dirname(opencodeDir),\n121:   env: process.env,\n122:   stdio: 'inherit',\n123: });\n124: \n125: if (result.error) {\n126:   process.stderr.write(`${result.error.message}\\n`);\n127:   process.exit(75);\n128: }\n129: \n130: process.exit(result.status ?? 1);\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","text":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n\nfunction fail(message) {\n  process.stderr.write(`${message}\\n`);\n  process.exit(69);\n}\n\n// Recursively collects the CLI's compiled-source surface (entry, local schema\n// imports, tsconfig) so new files under candidate directories are watched\n// without editing this list. Must stay in lock-step with\n// scripts/finalize-dist.mjs, which writes the matching hash at build time.\nfunction sourceCandidates() {\n  const candidates = [\n    path.join(mcpServerDir, 'spec-memory-cli.ts'),\n    path.join(mcpServerDir, 'tool-schemas.ts'),\n    path.join(mcpServerDir, 'tsconfig.json'),\n    path.join(mcpServerDir, 'schemas'),\n  ];\n  const files = [];\n\n  const visit = (candidate) => {\n    if (!fs.existsSync(candidate)) return;\n    const stat = fs.statSync(candidate);\n    if (stat.isDirectory()) {\n      for (const entry of fs.readdirSync(candidate)) {\n        visit(path.join(candidate, entry));\n      }\n      return;\n    }\n    if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n      files.push(candidate);\n    }\n  };\n\n  for (const candidate of candidates) visit(candidate);\n  return files;\n}\n\nfunction hashSourceFiles(existingSources) {\n  const hash = crypto.createHash('sha256');\n  for (const filePath of [...existingSources].sort()) {\n    hash.update(path.relative(mcpServerDir, filePath));\n    hash.update('\\0');\n    hash.update(fs.readFileSync(filePath));\n    hash.update('\\0');\n  }\n  return hash.digest('hex');\n}\n\nfunction readStoredSourceHash() {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n    return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction writeStoredSourceHash(sourceHash) {\n  try {\n    fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n    fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n  } catch {\n    // Freshness metadata is an optimization; stale detection remains conservative.\n  }\n}\n\nfunction ensureFreshDist() {\n  if (!fs.existsSync(cliDist)) {\n    fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n  }\n  if (allowStale) return;\n  const existingSources = sourceCandidates();\n  if (existingSources.length === 0) return;\n  const currentSourceHash = hashSourceFiles(existingSources);\n  if (readStoredSourceHash() === currentSourceHash) return;\n  const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n  const distMtime = fs.statSync(cliDist).mtimeMs;\n  if (newestSourceMtime > distMtime) {\n    fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n  }\n  writeStoredSourceHash(currentSourceHash);\n}\n\nfunction ensureSocketDir() {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (socketDir.startsWith('tcp://')) return;\n  fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  const socketPath = path.join(path.resolve(socketDir), socketFileName);\n  if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n    fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n  }\n}\n\nensureSocketDir();\nensureFreshDist();\n\nconst result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n  cwd: path.dirname(opencodeDir),\n  env: process.env,\n  stdio: 'inherit',\n});\n\nif (result.error) {\n  process.stderr.write(`${result.error.message}\\n`);\n  process.exit(75);\n}\n\nprocess.exit(result.status ?? 1);","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/bin/spec-memory.cjs","time":{"start":1781764062786,"end":1781764062796}},"metadata":{"openai":{"itemId":"fc_05848926afa0cb86016a338fdeb0308191824436d7ca6f50f0"}},"id":"prt_ed969fe3f001lZfHC2B6nXmXPm","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed969daee001UL2KKwHzsTAUav"}}
{"type":"tool_use","timestamp":1781764062819,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_SRbS72Mj0BaabyTaTw2rB2ka","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   readMaintenanceMarker,\n37:   shouldAdoptDespiteProbe,\n38:   releaseRespawnLockFile,\n39:   sampleProcessTreeRssMb,\n40:   shouldAbortRelaunchOnFire,\n41:   shouldSkipLaunch,\n42:   signalProcess,\n43:   superviseChildExit,\n44:   waitForPidExit,\n45: } = mss;\n46: \n47: const root = path.resolve(__dirname, '..', '..');\n48: const opencodeDir = path.join(root, '.opencode');\n49: \n50: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n51: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n52: // Minimal parser — no external dependency.\n53: function loadEnvFile(filePath) {\n54:   if (!fs.existsSync(filePath)) return 0;\n55:   let count = 0;\n56:   const raw = fs.readFileSync(filePath, 'utf8');\n57:   for (const line of raw.split('\\n')) {\n58:     const trimmed = line.trim();\n59:     if (!trimmed || trimmed.startsWith('#')) continue;\n60:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n61:     if (!m) continue;\n62:     const key = m[1];\n63:     let val = m[2];\n64:     // Strip matching outer quotes (single or double)\n65:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n66:       val = val.slice(1, -1);\n67:     }\n68:     if (!(key in process.env)) {\n69:       process.env[key] = val;\n70:       count++;\n71:     }\n72:   }\n73:   return count;\n74: }\n75: \n76: function isStrictModeDisabled(value) {\n77:   if (value === undefined || value === null) return false;\n78:   const v = String(value).trim().toLowerCase();\n79:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n80: }\n81: \n82: let skillsDir = path.join(opencodeDir, 'skills');\n83: let legacySkillDir = path.join(opencodeDir, 'skill');\n84: let kitDir = path.join(skillsDir, 'system-spec-kit');\n85: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n86: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n87: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n88: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n89: let stateFile = path.join(dbDir, PID_FILE_NAME);\n90: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n91: \n92: const rel = (p) => path.relative(root, p) || '.';\n93: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n94: const now = () => new Date().toISOString();\n95: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n96: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n97: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n98: let childProcess = null;\n99: let ownerLeasePid = null;\n100: let leaseStartedAt = null;\n101: let launcherShutdownInProgress = false;\n102: let rssBreachSelfExitInProgress = false;\n103: let rssWatchdogTimer = null;\n104: let crashLoopGuard = null;\n105: let supervisorRelaunchTimer = null;\n106: // The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n107: // launcher's parent. When the host disposes its session the launcher is orphaned and its\n108: // ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n109: // path can tell \"owning runtime went away\" apart from a genuine daemon crash.\n110: const LAUNCHER_INITIAL_PPID = process.ppid;\n111: let ownerLeaseHeartbeatTimer = null;\n112: let ownerLeaseRequired = true;\n113: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n114: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n115: // orphaned sidecar after the child has already exited.\n116: let lastKnownDescendantPids = [];\n117: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n118: const durableWriteWarnings = new Set();\n119: // Daemon exit code meaning \"another live process holds the database\n120: // single-writer lock\". Never counts toward the crash loop: the right move is\n121: // bridging to the live owner (or a bounded retry while a maintenance script\n122: // finishes), not relaunching a doomed second writer. Mirrored in\n123: // mcp_server context-server (EXIT_DB_LOCK_HELD).\n124: const EXIT_DB_LOCK_HELD = 86;\n125: const DB_LOCK_HELD_MAX_RETRIES = 3;\n126: let dbLockHeldRetries = 0;\n127: \n128: function log(message) {\n129:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n130:   persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n131: }\n132: \n133: function isDurableWriteUnavailable(error) {\n134:   const code = error && typeof error === 'object' ? error.code : undefined;\n135:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n136: }\n137: \n138: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n139:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n140:   const key = `${operation}:${targetPath}:${code}`;\n141:   if (durableWriteWarnings.has(key)) return;\n142:   durableWriteWarnings.add(key);\n143:   const detail = error instanceof Error ? error.message : String(error ?? code);\n144:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n145: }\n146: \n147: // Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n148: // ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n149: // durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n150: // launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n151: // grow without bound.\n152: function launcherLogIsEnabled(env = process.env) {\n153:   return env.SPECKIT_LAUNCHER_LOG !== '0';\n154: }\n155: function launcherLogMaxBytes(env = process.env) {\n156:   return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n157: }\n158: function resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n159:   const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n160:   return typeof override === 'string' && override.trim()\n161:     ? override.trim()\n162:     : path.join(baseDir, '.mk-spec-memory-launcher.log');\n163: }\n164: function shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n165:   return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n166: }\n167: function persistLauncherLogLine(line) {\n168:   if (!launcherLogIsEnabled()) return;\n169:   let target;\n170:   try {\n171:     target = resolveLauncherLogPath();\n172:     try {\n173:       const { size } = fs.statSync(target);\n174:       if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n175:         try {\n176:           // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n177:           // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n178:           // suffix still rotates instead of renaming the file onto itself and growing without bound.\n179:           const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n180:           fs.renameSync(target, rotated);\n181:         } catch {\n182:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n183:         }\n184:       }\n185:     } catch (statErr) {\n186:       if (statErr.code !== 'ENOENT') throw statErr;\n187:     }\n188:     fs.appendFileSync(target, line, { mode: 0o600 });\n189:   } catch (error) {\n190:     if (target && isDurableWriteUnavailable(error)) {\n191:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n192:       return;\n193:     }\n194:     // Logging must never break the launcher.\n195:   }\n196: }\n197: \n198: // Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n199: // When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n200: // (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n201: // not tear the shared backend out from under other sessions. A fresh session that finds the released\n202: // daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n203: // it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n204: // writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n205: // killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n206: // sweeper bounds any leak.\n207: function daemonReelectionEnabled(env = process.env) {\n208:   return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n209: }\n210: function contextServerSpawnIo(reelectionEnabled) {\n211:   return reelectionEnabled\n212:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n213:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n214: }\n215: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n216:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n217: }\n218: \n219: function cleanupTmpFile(tmpPath) {\n220:   try {\n221:     fs.unlinkSync(tmpPath);\n222:   } catch (error) {\n223:     if (error.code !== 'ENOENT') {\n224:       // Best-effort cleanup only; the original durable-write failure is more useful.\n225:     }\n226:   }\n227: }\n228: \n229: function writeAtomicJsonFile(targetPath, payload, operation) {\n230:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n231:   const tmp = `${currentPath}.tmp.${process.pid}`;\n232:   try {\n233:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n234:     fs.renameSync(tmp, currentPath);\n235:     return true;\n236:   } catch (error) {\n237:     cleanupTmpFile(tmp);\n238:     if (isDurableWriteUnavailable(error)) {\n239:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n240:       return false;\n241:     }\n242:     throw error;\n243:   }\n244: }\n245: \n246: function loadProjectEnvFiles() {\n247:   for (const fname of ['.env.local', '.env']) {\n248:     const p = path.join(root, fname);\n249:     if (fs.existsSync(p)) {\n250:       const n = loadEnvFile(p);\n251:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n252:     }\n253:   }\n254: }\n255: \n256: function parsePositiveInteger(value, fallback) {\n257:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n258:   const parsed = Number.parseInt(String(value).trim(), 10);\n259:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n260: }\n261: \n262: function loadBridgeModule() {\n263:   try {\n264:     return require('./lib/launcher-ipc-bridge.cjs');\n265:   } catch (error) {\n266:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n267:     return {\n268:       async maybeBridgeLeaseHolder({ leaseResult }) {\n269:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n270:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n271:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n272:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n273:         return { action: 'report', reason: 'bridge-module-missing' };\n274:       },\n275:     };\n276:   }\n277: }\n278: \n279: function resolveSessionProxySocketPath() {\n280:   const { getIpcSocketPath } = loadBridgeModule();\n281:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n282: }\n283: \n284: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n285: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n286: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n287: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n288: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n289: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n290: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n291: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n292:   const createProxy = options.createProxy ?? createSessionProxy;\n293:   const sessionProxy = createProxy({\n294:     socketPath,\n295:     stdin: options.stdin ?? process.stdin,\n296:     stdout: options.stdout ?? process.stdout,\n297:     log,\n298:   });\n299:   return sessionProxy.start();\n300: }\n\n(Showing lines 1-300 of 1882. Use offset=301 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;\nlet crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\n// The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n// launcher's parent. When the host disposes its session the launcher is orphaned and its\n// ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n// path can tell \"owning runtime went away\" apart from a genuine daemon crash.\nconst LAUNCHER_INITIAL_PPID = process.ppid;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n// Daemon exit code meaning \"another live process holds the database\n// single-writer lock\". Never counts toward the crash loop: the right move is\n// bridging to the live owner (or a bounded retry while a maintenance script\n// finishes), not relaunching a doomed second writer. Mirrored in\n// mcp_server context-server (EXIT_DB_LOCK_HELD).\nconst EXIT_DB_LOCK_HELD = 86;\nconst DB_LOCK_HELD_MAX_RETRIES = 3;\nlet dbLockHeldRetries = 0;\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n  persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\n// Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n// ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n// durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n// launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n// grow without bound.\nfunction launcherLogIsEnabled(env = process.env) {\n  return env.SPECKIT_LAUNCHER_LOG !== '0';\n}\nfunction launcherLogMaxBytes(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n}\nfunction resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n  const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n  return typeof override === 'string' && override.trim()\n    ? override.trim()\n    : path.join(baseDir, '.mk-spec-memory-launcher.log');\n}\nfunction shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n  return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n}\nfunction persistLauncherLogLine(line) {\n  if (!launcherLogIsEnabled()) return;\n  let target;\n  try {\n    target = resolveLauncherLogPath();\n    try {\n      const { size } = fs.statSync(target);\n      if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n        try {\n          // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n          // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n          // suffix still rotates instead of renaming the file onto itself and growing without bound.\n          const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n// (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n// not tear the shared backend out from under other sessions. A fresh session that finds the released\n// daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n// it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n// writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n// killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n// sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}","lineStart":1,"lineEnd":300,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781764062799,"end":1781764062816}},"metadata":{"openai":{"itemId":"fc_05848926afa0cb86016a338fdeb03c81919989b30649855f47"}},"id":"prt_ed969fe42001QNZ42TO6ww0zCq","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed969daee001UL2KKwHzsTAUav"}}
{"type":"tool_use","timestamp":1781764062823,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_pAQesNcuAB0CNB2g4yEBAToQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":1,"limit":400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: Model Server Supervision                                      ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n5: // ╚══════════════════════════════════════════════════════════════════════════╝\n6: \n7: 'use strict';\n8: \n9: const fs = require('fs');\n10: const http = require('http');\n11: const path = require('path');\n12: const { spawn, spawnSync } = require('child_process');\n13: \n14: const defaultRoot = path.resolve(__dirname, '..', '..', '..');\n15: const defaultOpencodeDir = path.join(defaultRoot, '.opencode');\n16: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n17: \n18: const SHUTDOWN_DEADLINE_MS = 5000;\n19: const RESPAWN_REAP_GRACE_MS = 7000;\n20: const RESPAWN_LOCK_STALE_MS = 60000;\n21: const DEFAULT_WATCHDOG_GRACE_MS = 7000;\n22: const DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\n23: const DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\n24: const DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\n25: const DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\n26: const DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\n27: const DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\n28: const DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\n29: const HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\n30: const HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\n31: const HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\n32: const HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\n33: const MODEL_SERVER_DEMAND_STATUS = 503;\n34: const DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\n35: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n36: const durableWriteWarnings = new Set();\n37: \n38: function defaultLog(message) {\n39:   process.stderr.write(`[model-server-supervision] ${message}\\n`);\n40: }\n41: \n42: function parsePositiveInteger(value, fallback) {\n43:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n44:   const parsed = Number.parseInt(String(value).trim(), 10);\n45:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n46: }\n47: \n48: function isPermissionError(error) {\n49:   const code = error && typeof error === 'object' ? error.code : undefined;\n50:   if (code === 'EPERM' || code === 'EACCES') return true;\n51:   const message = error instanceof Error ? error.message : String(error ?? '');\n52:   return /operation not permitted|permission denied/i.test(message);\n53: }\n54: \n55: function isDurableWriteUnavailable(error) {\n56:   const code = error && typeof error === 'object' ? error.code : undefined;\n57:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n58: }\n59: \n60: function logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n61:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n62:   const key = `${operation}:${targetPath}:${code}`;\n63:   if (durableWriteWarnings.has(key)) return;\n64:   durableWriteWarnings.add(key);\n65:   const detail = error instanceof Error ? error.message : String(error ?? code);\n66:   logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n67: }\n68: \n69: function cleanupTmpFile(tmpPath, fsApi = fs) {\n70:   try {\n71:     fsApi.unlinkSync(tmpPath);\n72:   } catch (error) {\n73:     if (error.code !== 'ENOENT') {\n74:       // Best-effort cleanup only; the original durable-write failure is more useful.\n75:     }\n76:   }\n77: }\n78: \n79: function parseProcessRows(input) {\n80:   if (Array.isArray(input)) {\n81:     return input\n82:       .map((row) => ({\n83:         pid: Number(row.pid),\n84:         ppid: Number(row.ppid),\n85:         rss: Number(row.rss),\n86:       }))\n87:       .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n88:   }\n89: \n90:   return String(input ?? '')\n91:     .split(/\\r?\\n/)\n92:     .map((line) => line.trim())\n93:     .filter(Boolean)\n94:     .map((line) => {\n95:       const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n96:       return { pid, ppid, rss };\n97:     })\n98:     .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n99: }\n100: \n101: function defaultProcessRowsRunner() {\n102:   const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n103:     encoding: 'utf8',\n104:     stdio: ['ignore', 'pipe', 'pipe'],\n105:   });\n106:   if (result.error) throw result.error;\n107:   if (result.status !== 0) {\n108:     const error = new Error(result.stderr || `ps exited ${result.status}`);\n109:     error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n110:     throw error;\n111:   }\n112:   return result.stdout;\n113: }\n114: \n115: function resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n116:   if (!Number.isInteger(childPid) || childPid <= 0) return null;\n117: \n118:   let rows;\n119:   try {\n120:     rows = parseProcessRows(runner());\n121:   } catch (error) {\n122:     if (isPermissionError(error)) return null;\n123:     throw error;\n124:   }\n125: \n126:   const byPid = new Map();\n127:   const childrenByPpid = new Map();\n128:   for (const row of rows) {\n129:     byPid.set(row.pid, row);\n130:     const children = childrenByPpid.get(row.ppid) || [];\n131:     children.push(row);\n132:     childrenByPpid.set(row.ppid, children);\n133:   }\n134:   if (!byPid.has(childPid)) return null;\n135: \n136:   const subtree = [];\n137:   const stack = [childPid];\n138:   const seen = new Set();\n139:   while (stack.length > 0) {\n140:     const pid = stack.pop();\n141:     if (seen.has(pid)) continue;\n142:     seen.add(pid);\n143:     const row = byPid.get(pid);\n144:     if (row) subtree.push(row);\n145:     for (const child of childrenByPpid.get(pid) || []) {\n146:       stack.push(child.pid);\n147:     }\n148:   }\n149: \n150:   return subtree;\n151: }\n152: \n153: function sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n154:   const rows = resolveProcessTreeRows(childPid, runner);\n155:   if (!rows) return null;\n156:   const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n157:   return rssKb / 1024;\n158: }\n159: \n160: function normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n161:   const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n162:   if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n163:   warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n164:   return DEFAULT_WATCHDOG_GRACE_MS;\n165: }\n166: \n167: function getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n168:   const envNames = {\n169:     maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n170:     selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n171:     intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n172:     consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n173:     graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n174:   };\n175:   const rawMaxRssMb = env[envNames.maxRssMb];\n176:   const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n177:     ? null\n178:     : Number.parseFloat(String(rawMaxRssMb).trim());\n179:   const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n180:   return {\n181:     enabled,\n182:     maxRssMb,\n183:     intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n184:     consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n185:     graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n186:     maxRssMbEnv: envNames.maxRssMb,\n187:     selfExitEnv: envNames.selfExit,\n188:   };\n189: }\n190: \n191: function getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n192:   return getWatchdogConfig(env, warn, {\n193:     maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n194:     selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n195:   });\n196: }\n197: \n198: function getModelServerIdleConfig(env = process.env) {\n199:   const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n200:   const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n201:     ? 0\n202:     : Number.parseFloat(String(rawIdleMin).trim());\n203:   const enabled = Number.isFinite(idleMin) && idleMin > 0;\n204:   return {\n205:     enabled,\n206:     timeoutMs: enabled ? idleMin * 60000 : 0,\n207:   };\n208: }\n209: \n210: function computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n211:   const exponent = Math.max(0, deathsInWindow - 1);\n212:   return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n213: }\n214: \n215: function createCrashLoopGuard(options = {}) {\n216:   const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_CRASH_LOOP_MAX_DEATHS);\n217:   const windowMs = parsePositiveInteger(options.windowMs, DEFAULT_CRASH_LOOP_WINDOW_MS);\n218:   const initialBackoffMs = parsePositiveInteger(options.initialBackoffMs, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS);\n219:   const maxBackoffMs = parsePositiveInteger(options.maxBackoffMs, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS);\n220:   const nowMs = typeof options.now === 'function' ? options.now : () => Date.now();\n221:   const deaths = [];\n222: \n223:   return {\n224:     recordDeath() {\n225:       const current = nowMs();\n226:       deaths.push(current);\n227:       while (deaths.length > 0 && current - deaths[0] > windowMs) deaths.shift();\n228:       const deathsInWindow = deaths.length;\n229:       return {\n230:         deathsInWindow,\n231:         giveUp: deathsInWindow >= maxDeaths,\n232:         backoffMs: computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs),\n233:       };\n234:     },\n235:   };\n236: }\n237: \n238: function getCrashLoopConfig(env = process.env) {\n239:   return {\n240:     maxDeaths: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_DEATHS, DEFAULT_CRASH_LOOP_MAX_DEATHS),\n241:     windowMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_WINDOW_MS, DEFAULT_CRASH_LOOP_WINDOW_MS),\n242:     initialBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_INITIAL_BACKOFF_MS, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS),\n243:     maxBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_BACKOFF_MS, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS),\n244:   };\n245: }\n246: \n247: function getModelServerGiveUpCooldownMs(env = process.env) {\n248:   return parsePositiveInteger(env.SPECKIT_HF_MODEL_SERVER_GIVEUP_COOLDOWN_MS, DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS);\n249: }\n250: \n251: function superviseChildExit(event, actions) {\n252:   if (event.intentional) {\n253:     actions.clearLease();\n254:     actions.exit(event.code ?? 0);\n255:     return { action: 'intentional-exit' };\n256:   }\n257: \n258:   const decision = actions.crashLoopGuard.recordDeath();\n259:   if (decision.giveUp) {\n260:     actions.clearLease();\n261:     actions.reapProcessGroup(event.childPid);\n262:     if (event.signal) {\n263:       actions.mirrorSignal(event.signal);\n264:     } else {\n265:       actions.exit(event.code ?? 1);\n266:     }\n267:     return { action: 'give-up', deathsInWindow: decision.deathsInWindow };\n268:   }\n269: \n270:   actions.scheduleRelaunch(decision.backoffMs);\n271:   return { action: 'relaunch', deathsInWindow: decision.deathsInWindow, backoffMs: decision.backoffMs };\n272: }\n273: \n274: function processLiveness(pid) {\n275:   if (!Number.isInteger(pid) || pid <= 0) return 'dead';\n276:   try {\n277:     process.kill(pid, 0);\n278:     return 'alive';\n279:   } catch (error) {\n280:     if (error.code === 'ESRCH') return 'dead';\n281:     if (error.code === 'EPERM') return 'unknown-eperm';\n282:     return 'alive';\n283:   }\n284: }\n285: \n286: async function waitForPidExit(pid, timeoutMs) {\n287:   const deadline = Date.now() + timeoutMs;\n288:   while (Date.now() <= deadline) {\n289:     if (processLiveness(pid) === 'dead') return true;\n290:     await sleep(100);\n291:   }\n292:   return processLiveness(pid) === 'dead';\n293: }\n294: \n295: function signalProcess(pid, signal) {\n296:   try {\n297:     process.kill(pid, signal);\n298:     return true;\n299:   } catch (error) {\n300:     if (error.code === 'ESRCH' || error.code === 'EPERM') return false;\n301:     throw error;\n302:   }\n303: }\n304: \n305: function isChildRunning(child) {\n306:   return child && child.exitCode === null && child.signalCode === null;\n307: }\n308: \n309: function shouldSkipLaunch(child) {\n310:   return Boolean(child && isChildRunning(child));\n311: }\n312: \n313: // A scheduled daemon relaunch must be ABORTED when its backoff fires under a dying owner.\n314: // The MCP host spawns the launcher directly, so a parent pid that no longer matches the value\n315: // captured at startup (or has reparented to the init/subreaper pid 1) means the owning session\n316: // disposed; respawning then would only flap the daemon under a runtime that is going away and\n317: // drop every bridged transport. Crash-recovery and RSS-recycle fire with the owner alive and a\n318: // matching ppid, so this stays a no-op for them.\n319: function shouldAbortRelaunchOnFire({ shuttingDown, currentPpid, initialPpid } = {}) {\n320:   return Boolean(shuttingDown) || currentPpid !== initialPpid || currentPpid === 1;\n321: }\n322: \n323: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner, options = {}) {\n324:   const snapshot = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n325:   const rows = resolveProcessTreeRows(childPid, runner);\n326:   if (rows === null) return snapshot;\n327:   const pids = rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1);\n328:   if (options.snapshot && typeof options.snapshot.set === 'function') {\n329:     options.snapshot.set(pids);\n330:   }\n331:   return pids;\n332: }\n333: \n334: function reapProcessTreeGroups(childPid, options = {}) {\n335:   const runner = options.runner || defaultProcessRowsRunner;\n336:   const signal = options.signal || signalProcess;\n337:   const snapshotPids = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n338: \n339:   const liveRows = resolveProcessTreeRows(childPid, runner);\n340:   const liveDescendants = liveRows ? liveRows.map((row) => row.pid).filter((pid) => pid !== childPid) : [];\n341: \n342:   const candidates = [...new Set([...liveDescendants, ...snapshotPids])].filter(\n343:     (pid) => Number.isInteger(pid) && pid > 1 && pid !== childPid && pid !== process.pid && signal(pid, 0),\n344:   );\n345:   if (candidates.length === 0) return;\n346: \n347:   for (const pid of candidates) {\n348:     if (process.platform !== 'win32') signal(-pid, 'SIGTERM');\n349:     signal(pid, 'SIGTERM');\n350:   }\n351:   setTimeout(() => {\n352:     for (const pid of candidates) {\n353:       if (process.platform !== 'win32') signal(-pid, 'SIGKILL');\n354:       signal(pid, 'SIGKILL');\n355:     }\n356:   }, 1000).unref();\n357: }\n358: \n359: function startRssWatchdog(childPid, options = {}) {\n360:   let fallbackTimer = null;\n361:   const timerState = options.timerState || {\n362:     get: () => fallbackTimer,\n363:     set: (timer) => {\n364:       fallbackTimer = timer;\n365:     },\n366:   };\n367:   const existingTimer = timerState.get();\n368:   if (existingTimer) {\n369:     clearInterval(existingTimer);\n370:     timerState.set(null);\n371:   }\n372:   const logger = options.log || defaultLog;\n373:   const label = options.label || 'context-server';\n374:   const runner = options.runner || defaultProcessRowsRunner;\n375:   let fallbackSnapshotPids = [];\n376:   const snapshot = options.snapshot || {\n377:     set: (pids) => {\n378:       fallbackSnapshotPids = pids;\n379:     },\n380:     get: () => fallbackSnapshotPids,\n381:   };\n382:   const config = options.config || getWatchdogConfig(process.env, logger);\n383:   if (!config.enabled && config.maxRssMb !== null && Number.isFinite(config.maxRssMb) && config.maxRssMb > 0) {\n384:     logger(`RSS watchdog ceiling configured but ${config.selfExitEnv}=1 is not set; breach self-exit remains disabled (descendant tracking still active for crash-loop reap)`);\n385:   }\n386: \n387:   const tickMs = config.enabled ? config.intervalMs : DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS;\n388:   let consecutiveBreaches = 0;\n389:   const timer = setInterval(() => {\n390:     const rows = resolveProcessTreeRows(childPid, runner);\n391:     if (rows === null) {\n392:       consecutiveBreaches = 0;\n393:       return;\n394:     }\n395:     snapshot.set(rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1));\n396:     if (!config.enabled) return;\n397:     const rssMb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0) / 1024;\n398:     if (rssMb <= config.maxRssMb) {\n399:       consecutiveBreaches = 0;\n400:       return;\n\n(Showing lines 1-400 of 1474. Use offset=401 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: Model Server Supervision                                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\n\nconst defaultRoot = path.resolve(__dirname, '..', '..', '..');\nconst defaultOpencodeDir = path.join(defaultRoot, '.opencode');\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst SHUTDOWN_DEADLINE_MS = 5000;\nconst RESPAWN_REAP_GRACE_MS = 7000;\nconst RESPAWN_LOCK_STALE_MS = 60000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: Model Server Supervision                                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\n\nconst defaultRoot = path.resolve(__dirname, '..', '..', '..');\nconst defaultOpencodeDir = path.join(defaultRoot, '.opencode');\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst SHUTDOWN_DEADLINE_MS = 5000;\nconst RESPAWN_REAP_GRACE_MS = 7000;\nconst RESPAWN_LOCK_STALE_MS = 60000;\nconst DEFAULT_WATCHDOG_GRACE_MS = 7000;\nconst DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\nconst DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\nconst DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\nconst DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\nconst DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\nconst DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\nconst DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\nconst HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\nconst HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\nconst HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\nconst HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\nconst MODEL_SERVER_DEMAND_STATUS = 503;\nconst DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n\nfunction defaultLog(message) {\n  process.stderr.write(`[model-server-supervision] ${message}\\n`);\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isPermissionError(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  if (code === 'EPERM' || code === 'EACCES') return true;\n  const message = error instanceof Error ? error.message : String(error ?? '');\n  return /operation not permitted|permission denied/i.test(message);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\nfunction cleanupTmpFile(tmpPath, fsApi = fs) {\n  try {\n    fsApi.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction parseProcessRows(input) {\n  if (Array.isArray(input)) {\n    return input\n      .map((row) => ({\n        pid: Number(row.pid),\n        ppid: Number(row.ppid),\n        rss: Number(row.rss),\n      }))\n      .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n  }\n\n  return String(input ?? '')\n    .split(/\\r?\\n/)\n    .map((line) => line.trim())\n    .filter(Boolean)\n    .map((line) => {\n      const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n      return { pid, ppid, rss };\n    })\n    .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n}\n\nfunction defaultProcessRowsRunner() {\n  const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n  if (result.error) throw result.error;\n  if (result.status !== 0) {\n    const error = new Error(result.stderr || `ps exited ${result.status}`);\n    error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n    throw error;\n  }\n  return result.stdout;\n}\n\nfunction resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n  if (!Number.isInteger(childPid) || childPid <= 0) return null;\n\n  let rows;\n  try {\n    rows = parseProcessRows(runner());\n  } catch (error) {\n    if (isPermissionError(error)) return null;\n    throw error;\n  }\n\n  const byPid = new Map();\n  const childrenByPpid = new Map();\n  for (const row of rows) {\n    byPid.set(row.pid, row);\n    const children = childrenByPpid.get(row.ppid) || [];\n    children.push(row);\n    childrenByPpid.set(row.ppid, children);\n  }\n  if (!byPid.has(childPid)) return null;\n\n  const subtree = [];\n  const stack = [childPid];\n  const seen = new Set();\n  while (stack.length > 0) {\n    const pid = stack.pop();\n    if (seen.has(pid)) continue;\n    seen.add(pid);\n    const row = byPid.get(pid);\n    if (row) subtree.push(row);\n    for (const child of childrenByPpid.get(pid) || []) {\n      stack.push(child.pid);\n    }\n  }\n\n  return subtree;\n}\n\nfunction sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n  const rows = resolveProcessTreeRows(childPid, runner);\n  if (!rows) return null;\n  const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n  return rssKb / 1024;\n}\n\nfunction normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n  const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n  if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n  warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n  return DEFAULT_WATCHDOG_GRACE_MS;\n}\n\nfunction getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n  const envNames = {\n    maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n    selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n    intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n    consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n    graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n  };\n  const rawMaxRssMb = env[envNames.maxRssMb];\n  const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n    ? null\n    : Number.parseFloat(String(rawMaxRssMb).trim());\n  const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n  return {\n    enabled,\n    maxRssMb,\n    intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n    consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n    graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n    maxRssMbEnv: envNames.maxRssMb,\n    selfExitEnv: envNames.selfExit,\n  };\n}\n\nfunction getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n  return getWatchdogConfig(env, warn, {\n    maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n    selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n  });\n}\n\nfunction getModelServerIdleConfig(env = process.env) {\n  const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n  const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n    ? 0\n    : Number.parseFloat(String(rawIdleMin).trim());\n  const enabled = Number.isFinite(idleMin) && idleMin > 0;\n  return {\n    enabled,\n    timeoutMs: enabled ? idleMin * 60000 : 0,\n  };\n}\n\nfunction computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n  const exponent = Math.max(0, deathsInWindow - 1);\n  return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n}\n\nfunction createCrashLoopGuard(options = {}) {\n  const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_CRASH_LOOP_MAX_DEATHS);\n  const windowMs = parsePositiveInteger(options.windowMs, DEFAULT_CRASH_LOOP_WINDOW_MS);\n  const initialBackoffMs = parsePositiveInteger(options.initialBackoffMs, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS);\n  const maxBackoffMs = parsePositiveInteger(options.maxBackoffMs, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS);\n  const nowMs = typeof options.now === 'function' ? options.now : () => Date.now();\n  const deaths = [];\n\n  return {\n    recordDeath() {\n      const current = nowMs();\n      deaths.push(current);\n      while (deaths.length > 0 && current - deaths[0] > windowMs) deaths.shift();\n      const deathsInWindow = deaths.length;\n      return {\n        deathsInWindow,\n        giveUp: deathsInWindow >= maxDeaths,\n        backoffMs: computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs),\n      };\n    },\n  };\n}\n\nfunction getCrashLoopConfig(env = process.env) {\n  return {\n    maxDeaths: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_DEATHS, DEFAULT_CRASH_LOOP_MAX_DEATHS),\n    windowMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_WINDOW_MS, DEFAULT_CRASH_LOOP_WINDOW_MS),\n    initialBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_INITIAL_BACKOFF_MS, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS),\n    maxBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_BACKOFF_MS, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS),\n  };\n}\n\nfunction getModelServerGiveUpCooldownMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_HF_MODEL_SERVER_GIVEUP_COOLDOWN_MS, DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS);\n}\n\nfunction superviseChildExit(event, actions) {\n  if (event.intentional) {\n    actions.clearLease();\n    actions.exit(event.code ?? 0);\n    return { action: 'intentional-exit' };\n  }\n\n  const decision = actions.crashLoopGuard.recordDeath();\n  if (decision.giveUp) {\n    actions.clearLease();\n    actions.reapProcessGroup(event.childPid);\n    if (event.signal) {\n      actions.mirrorSignal(event.signal);\n    } else {\n      actions.exit(event.code ?? 1);\n    }\n    return { action: 'give-up', deathsInWindow: decision.deathsInWindow };\n  }\n\n  actions.scheduleRelaunch(decision.backoffMs);\n  return { action: 'relaunch', deathsInWindow: decision.deathsInWindow, backoffMs: decision.backoffMs };\n}\n\nfunction processLiveness(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return 'dead';\n  try {\n    process.kill(pid, 0);\n    return 'alive';\n  } catch (error) {\n    if (error.code === 'ESRCH') return 'dead';\n    if (error.code === 'EPERM') return 'unknown-eperm';\n    return 'alive';\n  }\n}\n\nasync function waitForPidExit(pid, timeoutMs) {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() <= deadline) {\n    if (processLiveness(pid) === 'dead') return true;\n    await sleep(100);\n  }\n  return processLiveness(pid) === 'dead';\n}\n\nfunction signalProcess(pid, signal) {\n  try {\n    process.kill(pid, signal);\n    return true;\n  } catch (error) {\n    if (error.code === 'ESRCH' || error.code === 'EPERM') return false;\n    throw error;\n  }\n}\n\nfunction isChildRunning(child) {\n  return child && child.exitCode === null && child.signalCode === null;\n}\n\nfunction shouldSkipLaunch(child) {\n  return Boolean(child && isChildRunning(child));\n}\n\n// A scheduled daemon relaunch must be ABORTED when its backoff fires under a dying owner.\n// The MCP host spawns the launcher directly, so a parent pid that no longer matches the value\n// captured at startup (or has reparented to the init/subreaper pid 1) means the owning session\n// disposed; respawning then would only flap the daemon under a runtime that is going away and\n// drop every bridged transport. Crash-recovery and RSS-recycle fire with the owner alive and a\n// matching ppid, so this stays a no-op for them.\nfunction shouldAbortRelaunchOnFire({ shuttingDown, currentPpid, initialPpid } = {}) {\n  return Boolean(shuttingDown) || currentPpid !== initialPpid || currentPpid === 1;\n}\n\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner, options = {}) {\n  const snapshot = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n  const rows = resolveProcessTreeRows(childPid, runner);\n  if (rows === null) return snapshot;\n  const pids = rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1);\n  if (options.snapshot && typeof options.snapshot.set === 'function') {\n    options.snapshot.set(pids);\n  }\n  return pids;\n}\n\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  const runner = options.runner || defaultProcessRowsRunner;\n  const signal = options.signal || signalProcess;\n  const snapshotPids = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n\n  const liveRows = resolveProcessTreeRows(childPid, runner);\n  const liveDescendants = liveRows ? liveRows.map((row) => row.pid).filter((pid) => pid !== childPid) : [];\n\n  const candidates = [...new Set([...liveDescendants, ...snapshotPids])].filter(\n    (pid) => Number.isInteger(pid) && pid > 1 && pid !== childPid && pid !== process.pid && signal(pid, 0),\n  );\n  if (candidates.length === 0) return;\n\n  for (const pid of candidates) {\n    if (process.platform !== 'win32') signal(-pid, 'SIGTERM');\n    signal(pid, 'SIGTERM');\n  }\n  setTimeout(() => {\n    for (const pid of candidates) {\n      if (process.platform !== 'win32') signal(-pid, 'SIGKILL');\n      signal(pid, 'SIGKILL');\n    }\n  }, 1000).unref();\n}\n\nfunction startRssWatchdog(childPid, options = {}) {\n  let fallbackTimer = null;\n  const timerState = options.timerState || {\n    get: () => fallbackTimer,\n    set: (timer) => {\n      fallbackTimer = timer;\n    },\n  };\n  const existingTimer = timerState.get();\n  if (existingTimer) {\n    clearInterval(existingTimer);\n    timerState.set(null);\n  }\n  const logger = options.log || defaultLog;\n  const label = options.label || 'context-server';\n  const runner = options.runner || defaultProcessRowsRunner;\n  let fallbackSnapshotPids = [];\n  const snapshot = options.snapshot || {\n    set: (pids) => {\n      fallbackSnapshotPids = pids;\n    },\n    get: () => fallbackSnapshotPids,\n  };\n  const config = options.config || getWatchdogConfig(process.env, logger);\n  if (!config.enabled && config.maxRssMb !== null && Number.isFinite(config.maxRssMb) && config.maxRssMb > 0) {\n    logger(`RSS watchdog ceiling configured but ${config.selfExitEnv}=1 is not set; breach self-exit remains disabled (descendant tracking still active for crash-loop reap)`);\n  }\n\n  const tickMs = config.enabled ? config.intervalMs : DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS;\n  let consecutiveBreaches = 0;\n  const timer = setInterval(() => {\n    const rows = resolveProcessTreeRows(childPid, runner);\n    if (rows === null) {\n      consecutiveBreaches = 0;\n      return;\n    }\n    snapshot.set(rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1));\n    if (!config.enabled) return;\n    const rssMb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0) / 1024;\n    if (rssMb <= config.maxRssMb) {\n      consecutiveBreaches = 0;\n      return;","lineStart":1,"lineEnd":400,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781764062802,"end":1781764062820}},"metadata":{"openai":{"itemId":"fc_05848926afa0cb86016a338fdeb0448191b9b9ee94e06c9118"}},"id":"prt_ed969fe50001pHfQCuIYfqpk54","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed969daee001UL2KKwHzsTAUav"}}
