:   force: boolean;\n\n  Line 285:     force: !!options.force,\n\n  Line 299:   force?: boolean;\n\n  Line 303:   // Opt-in: run the scan as a background job and return a jobId immediately.\n\n  Line 304:   background?: boolean;\n\n  Line 311:   governedAt?: string;\n\n  Line 321: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n\n  Line 327:   force: boolean = false,\n\n  Line 329:     qualityGateMode?: 'enforce' | 'warn-only';\n\n  Line 332:     governance?: GovernanceDecision;\n\n  Line 337:     force,\n\n  Line 341:     governance: options?.governance,\n\n  Line 350: // Hooks let a background runner observe cancellation and report phase/progress.\n\n  Line 370: // Persisted payload for debugging: scan shape only, no governance identifiers.\n\n  Line 374:     force: !!args.force,\n\n  Line 378:     background: true,\n\n  Line 411:     force = false,\n\n  Line 418:     force,\n\n  Line 423:   const governedIngest = requiresGovernedIngest(args);\n\n  Line 424:   const governanceDecision = validateGovernedIngest(args);\n\n  Line 425:   if (!governanceDecision.allowed) {\n\n  Line 426:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n\n  Line 810:     if (incremental && !force) {\n\n  Line 932:       enabled: incremental && !force,\n\n  Line 961:   if (incremental && !force) {\n\n  Line 1043:       // During force reindex, use warn-only for all files — the goal is to index\n\n  Line 1044:       // everything that has valid frontmatter, not to enforce template contracts on\n\n  Line 1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n\n  Line 1047:       const indexResult = await indexSingleFile(filePath, force, {\n\n  Line 1051:         governance: governedIngest ? governanceDecision : undefined,\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"async function handleMemoryIndexScan|background|cre