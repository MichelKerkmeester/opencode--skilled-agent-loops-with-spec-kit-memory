{
  "color": {
    "void-black": {
      "$value": "#040506",
      "$type": "color",
      "$description": "Void Black — Page canvas, dominant background — the near-pure-black base that most of the interface sits on"
    },
    "ink": {
      "$value": "#07080a",
      "$type": "color",
      "$description": "Ink — Card surfaces, elevated panels, image backgrounds — one step up from the canvas for content blocks"
    },
    "obsidian": {
      "$value": "#111214",
      "$type": "color",
      "$description": "Obsidian — Subtle surface tint, pressed states, input wells — used for slight depth on form fields and recessed containers"
    },
    "graphite": {
      "$value": "#1b1c1e",
      "$type": "color",
      "$description": "Graphite — Neutral form states, badge text, and quiet UI feedback where color should stay understated."
    },
    "smoke": {
      "$value": "#6a6b6c",
      "$type": "color",
      "$description": "Smoke — Secondary body text, muted labels — the everyday reading color on dark surfaces"
    },
    "ash": {
      "$value": "#9c9c9d",
      "$type": "color",
      "$description": "Ash — Light text on dark surfaces, inverse labels, and high-contrast captions."
    },
    "mist": {
      "$value": "#e6e6e6",
      "$type": "color",
      "$description": "Mist — Light neutral action fill for buttons on dark surfaces."
    },
    "iron": {
      "$value": "#454647",
      "$type": "color",
      "$description": "Iron — Button text on light fills, mid-gray borders — paired with Mist for filled button labels"
    },
    "slate": {
      "$value": "#2f3031",
      "$type": "color",
      "$description": "Slate — Dark button borders and labels on ghost/dark buttons"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Headings, high-emphasis text, reversed text on light buttons — the loudest text color in the system"
    },
    "coral-pulse": {
      "$value": "#ff6363",
      "$type": "color",
      "$description": "Coral Pulse — Brand accent — logo diamond, AI badge fill, hero artwork saturation, the single warm punctuation in an achromatic system"
    },
    "ember-hush": {
      "$value": "#452324",
      "$type": "color",
      "$description": "Ember Hush — Warm-tinted card backgrounds, accent surface tints — desaturated coral used as a muted backdrop for coral-anchored content"
    },
    "electric-sky": {
      "$value": "#63a1ff",
      "$type": "color",
      "$description": "Electric Sky — Hero illustration mid-tone, decorative gradient — appears only in the dramatic abstract hero artwork, not in interface controls"
    },
    "cobalt-edge": {
      "$value": "#143ca3",
      "$type": "color",
      "$description": "Cobalt Edge — Hero illustration stroke, deep gradient anchor — paired with Electric Sky in the hero's blue geometry"
    },
    "deep-space": {
      "$value": "#02193b",
      "$type": "color",
      "$description": "Deep Space — Hero illustration fill, darkest blue in the artwork gradient — not a UI token"
    },
    "info-blue": {
      "$value": "#56c2ff",
      "$type": "color",
      "$description": "Info Blue — Blue wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    },
    "success-green": {
      "$value": "#59d499",
      "$type": "color",
      "$description": "Success Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary interface typeface — body text at 16px/400, nav and card labels at 13–14px/500, subheadings at 18–22px/400, section headings at 32–56px in the 400–600 range, and display at 64px/600. Inter's neutral geometry carries the developer-tool seriousness; weight 400 at the 56px hero headline is an anti-convention choice — most brands shout with 700, Raycast whispers with regular weight and lets the size do the work"
    },
    "geistmono": {
      "$value": "GeistMono",
      "$type": "fontFamily",
      "$description": "Monospace for version strings, technical micro-labels, terminal-style text — appears in footer metadata (v1.104.21), command-line hints, and 10px uppercase eyebrow tags. Geist Mono's compact, slightly geometric forms make the tiny labels feel engineered rather than decorative"
    },
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "System font used for icon glyphs and numeric stat callouts at 24–32px/500. Falls back to SF Pro on macOS for native feel — reinforces the 'this is a Mac app' identity"
    },
    "sf-pro": {
      "$value": "SF Pro",
      "$type": "fontFamily",
      "$description": "SF Pro — detected in extracted data but not described by AI"
    }
  },
