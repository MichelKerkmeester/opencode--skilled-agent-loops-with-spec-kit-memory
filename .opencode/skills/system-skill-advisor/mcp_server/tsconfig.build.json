{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": false,
    "rootDir": "../..",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo"
  },
  "include": [
    "advisor-server.ts",
    "handlers/**/*.ts",
    "lib/**/*.ts",
    "schemas/**/*.ts",
    "tools/**/*.ts",
    "bench/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "stress_test",
    "**/*.bench.ts",
    "**/*.test.ts",
    "**/*.test-d.ts",
    "**/*.vitest.ts",
    "**/__tests__"
  ]
}
