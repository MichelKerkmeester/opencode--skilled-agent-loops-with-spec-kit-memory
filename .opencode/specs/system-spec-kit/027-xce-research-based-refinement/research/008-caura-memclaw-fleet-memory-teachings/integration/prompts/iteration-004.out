{"type":"tool_use","timestamp":1780738253398,"sessionID":"ses_163bcc50affeyxhkrz48ouVc7l","part":{"type":"tool","tool":"read","callID":"call_YjCNoetoPaDtygal6iN0HObw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n69: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n70:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n71:   await checkDatabaseUpdated();\n72: \n73:   const { id, specFolder, confirm } = args;\n74:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n75:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n76:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n77: \n78:   let numericId: number | null = null;\n79:   if (id !== undefined && id !== null) {\n80:     numericId = parseMemoryId(id);\n81:   }\n82: \n83:   let deletedCount = 0;\n84:   let checkpointName: string | null = null;\n85:   let mutationLedgerWarning: string | null = null;\n86:   const database = vectorIndex.getDb();\n87: \n88:   if (!database) {\n89:     // Unified DB-unavailable contract for single and bulk delete paths.\n90:     return createDatabaseUnavailableDeleteResponse();\n91:   }\n92: \n93:   if (numericId !== null) {\n94:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n95: \n96:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n97:     // Cleanup, ledger append) in a transaction for atomicity on error.\n98:     database.transaction(() => {\n99:       deletedCount = vectorIndex.deleteMemory(numericId) ? 1 : 0;\n100: \n101:       if (deletedCount > 0) {\n102:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n103:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n104:         try {\n105:           recordHistory(\n106:             numericId,\n107:             'DELETE',\n108:             singleSnapshot?.file_path ?? null,\n109:             null,\n110:             'mcp:memory_delete',\n111:             singleSnapshot?.spec_folder ?? null,\n112:           );\n113:         } catch (_histErr: unknown) {\n114:           // History recording is best-effort\n115:         }\n116: \n117:         causalEdges.init(database);\n118:         causalEdges.deleteEdgesForMemory(String(numericId));\n119:         // H1 FIX: Use db-specific invalidation instead of the no-op global version\n120:         clearDegreeCacheForDb(database);\n121: \n122:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n123:           mutationType: 'delete',\n124:           reason: 'memory_delete: single memory delete',\n125:           priorHash: singleSnapshot?.content_hash ?? null,\n126:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n127:           linkedMemoryIds: [numericId],\n128:           decisionMeta: {\n129:             tool: 'memory_delete',\n130:             bulk: false,\n131:             memoryId: numericId,\n132:             specFolder: singleSnapshot?.spec_folder ?? null,\n133:             filePath: singleSnapshot?.file_path ?? null,\n134:           },\n135:           actor: 'mcp:memory_delete',\n136:         });\n137:         if (!ledgerRecorded) {\n138:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n139:         }\n140:       }\n141:     })();\n142:   } else {\n143:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n144:     const deletedIds: number[] = [];\n145:     const hashById = new Map<number, MemoryHashSnapshot>();\n146: \n147:     if (database && 'prepare' in database) {\n148:       try {\n149:         const rows = database.prepare(`\n150:           SELECT id, content_hash, spec_folder, file_path\n151:           FROM memory_index\n152:           WHERE spec_folder = ?\n153:         `).all(specFolder as string) as MemoryHashSnapshot[];\n154: \n155:         for (const row of rows) {\n156:           hashById.set(row.id, row);\n157:         }\n158:       } catch (_err: unknown) {\n159:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n160:       }\n161:     }\n162: \n163:     if (memories.length > 0) {\n164:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n165:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n166:       try {\n167:         const checkpoint = checkpoints.createCheckpoint({\n168:           name: proposedCheckpointName,\n169:           specFolder,\n170:           metadata: {\n171:             reason: 'auto-checkpoint before bulk delete',\n172:             memoryCount: memories.length,\n173:           },\n174:         });\n175: \n176:         if (checkpoint) {\n177:           checkpointName = checkpoint.name;\n178:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n179:         } else {\n180:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n181:           checkpointName = null;\n182:         }\n183:       } catch (cpErr: unknown) {\n184:         const message = toErrorMessage(cpErr);\n185:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n186:         // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n187:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n188:         checkpointName = null;\n189:       }\n190:     }\n191: \n192:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n193:     causalEdges.init(database);\n194:     const bulkDeleteTx = database.transaction(() => {\n195:       for (const memory of memories) {\n196:         if (vectorIndex.deleteMemory(memory.id)) {\n197:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n198:           try {\n199:             const snapshot = hashById.get(memory.id);\n200:             recordHistory(\n201:               memory.id,\n202:               'DELETE',\n203:               snapshot?.file_path ?? null,\n204:               null,\n205:               'mcp:memory_delete',\n206:               snapshot?.spec_folder ?? null,\n207:             );\n208:           } catch (_histErr: unknown) {\n209:             // History recording is best-effort inside bulk delete\n210:           }\n211:           deletedCount++;\n212:           deletedIds.push(memory.id);\n213:           causalEdges.deleteEdgesForMemory(String(memory.id));\n214:         }\n215:       }\n216: \n217:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n218:       for (const deletedId of deletedIds) {\n219:         const snapshot = hashById.get(deletedId) ?? null;\n220:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n221:           mutationType: 'delete',\n222:           reason: 'memory_delete: bulk delete by spec folder',\n223:           priorHash: snapshot?.content_hash ?? null,\n224:           newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n225:           linkedMemoryIds: [deletedId],\n226:           decisionMeta: {\n227:             tool: 'memory_delete',\n228:             bulk: true,\n229:             specFolder,\n230:             checkpoint: checkpointName,\n231:             memoryId: deletedId,\n232:             filePath: snapshot?.file_path ?? null,\n233:           },\n234:           actor: 'mcp:memory_delete',\n235:         });\n236:         if (!ledgerRecorded) {\n237:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n238:         }\n239:       }\n240:     });\n241:     bulkDeleteTx();\n242:   }\n243: \n244:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n245:   if (deletedCount > 0) {\n246:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n247:     try {\n248:       postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n249:     } catch (hookError: unknown) {\n250:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n251:       postMutationHooks = {\n252:         latencyMs: 0, triggerCacheCleared: false,\n253:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n254:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n255:         errors: [msg],\n256:       };\n257:     }\n258:     postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n259:   }\n260: \n261:   const summary = deletedCount > 0\n262:     ? `Deleted ${deletedCount} memory(s)`\n263:     : 'No spec-doc records found to delete';\n264: \n265:   const hints: string[] = [];\n266:   if (checkpointName) {\n267:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n268:   }\n269:   if (deletedCount === 0) {\n270:     hints.push('Use memory_list() to find existing memories');\n271:   }\n272:   if (postMutationFeedback) {\n273:     hints.push(...postMutationFeedback.hints);\n274:   }\n275:   if (mutationLedgerWarning) {\n276:     hints.push(mutationLedgerWarning);\n277:   }\n278: \n279:   const data: Record<string, unknown> = { deleted: deletedCount };\n280:   if (checkpointName) {\n281:     data.checkpoint = checkpointName;\n282:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n283:   }\n284:   if (postMutationFeedback) {\n285:     data.postMutationHooks = postMutationFeedback.data;\n286:   }\n287:   if (mutationLedgerWarning) {\n288:     data.warning = mutationLedgerWarning;\n289:   }\n290: \n291:   return createMCPSuccessResponse({\n292:     tool: 'memory_delete',\n293:     summary,\n294:     data,\n295:     hints,\n296:   });\n297: }\n298: \n299: /* ───────────────────────────────────────────────────────────────\n300:    EXPORTS\n301: ──────────────────────────────────────────────────────────────── */\n302: \n303: export { handleMemoryDelete };\n\n(End of file - total 303 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = vectorIndex.deleteMemory(numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId));\n        // H1 FIX: Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (vectorIndex.deleteMemory(memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id));\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: bulk delete by spec folder',\n          priorHash: snapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n          linkedMemoryIds: [deletedId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: true,\n            specFolder,\n            checkpoint: checkpointName,\n            memoryId: deletedId,\n            filePath: snapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    });\n    bulkDeleteTx();\n  }\n\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n  }\n\n  const summary = deletedCount > 0\n    ? `Deleted ${deletedCount} memory(s)`\n    : 'No spec-doc records found to delete';\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  }\n  if (deletedCount === 0) {\n    hints.push('Use memory_list() to find existing memories');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n\n  const data: Record<string, unknown> = { deleted: deletedCount };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (mutationLedgerWarning) {\n    data.warning = mutationLedgerWarning;\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryDelete };","lineStart":1,"lineEnd":303,"totalLines":303,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1780738253391,"end":1780738253396}},"metadata":{"openai":{"itemId":"fc_06fef252c6ca1472016a23e8cd2d0c8191974152c1ee3f9fde"}},"id":"prt_e9c4561ad001QIyr1D8KYhLeKH","sessionID":"ses_163bcc50affeyxhkrz48ouVc7l","messageID":"msg_e9c453ddd001QL6YKVN6nbPJ50"}}
{"type":"tool_use","timestamp":1780738253704,"sessionID":"ses_163bcc50affeyxhkrz48ouVc7l","part":{"type":"tool","tool":"read","callID":"call_cqzPPhIIVRcOcEqAIqKgKSm6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: \n11: import type { MCPResponse } from './types.js';\n12: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n13: \n14: /** Handle the memory_retention_sweep MCP tool request. */\n15: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n16:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n17:   await checkDatabaseUpdated();\n18: \n19:   const database = vectorIndex.getDb();\n20:   if (!database) {\n21:     return createMCPErrorResponse({\n22:       tool: 'memory_retention_sweep',\n23:       error: 'Retention sweep aborted: database unavailable',\n24:       code: 'E_DB_UNAVAILABLE',\n25:       details: {\n26:         dryRun: args?.dryRun === true,\n27:       },\n28:       recovery: {\n29:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n30:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n31:         severity: 'error',\n32:       },\n33:     });\n34:   }\n35: \n36:   try {\n37:     const result = runMemoryRetentionSweep(database, { dryRun: args?.dryRun === true });\n38:     const summary = result.dryRun\n39:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted`\n40:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}`;\n41: \n42:     const hints: string[] = [];\n43:     if (result.ledgerRecorded === false) {\n44:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n45:     }\n46:     if (result.dryRun && result.candidates.length > 0) {\n47:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n48:     }\n49: \n50:     return createMCPSuccessResponse({\n51:       tool: 'memory_retention_sweep',\n52:       summary,\n53:       data: {\n54:         swept: result.swept,\n55:         retained: result.retained,\n56:         dryRun: result.dryRun,\n57:         durationMs: result.durationMs,\n58:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n59:           id: candidate.id,\n60:           deleteAfter: candidate.deleteAfter,\n61:           specFolder: candidate.specFolder,\n62:           filePath: candidate.filePath,\n63:         })),\n64:         deletedIds: result.deletedIds,\n65:         ledgerRecorded: result.ledgerRecorded,\n66:       },\n67:       hints,\n68:     });\n69:   } catch (error: unknown) {\n70:     return createMCPErrorResponse({\n71:       tool: 'memory_retention_sweep',\n72:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n73:       code: 'E_RETENTION_SWEEP_FAILED',\n74:       details: {\n75:         dryRun: args?.dryRun === true,\n76:       },\n77:       recovery: {\n78:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n79:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n80:         severity: 'error',\n81:       },\n82:     });\n83:   }\n84: }\n85: \n86: export { handleMemoryRetentionSweep };\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, { dryRun: args?.dryRun === true });\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        ledgerRecorded: result.ledgerRecorded,\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":86,"totalLines":86,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1780738253696,"end":1780738253703}},"metadata":{"openai":{"itemId":"fc_06fef252c6ca1472016a23e8cd2d2481919faae1a9c5a5064d"}},"id":"prt_e9c4563680017u5xGCzod1bO96","sessionID":"ses_163bcc50affeyxhkrz48ouVc7l","messageID":"msg_e9c453ddd001QL6YKVN6nbPJ50"}}
