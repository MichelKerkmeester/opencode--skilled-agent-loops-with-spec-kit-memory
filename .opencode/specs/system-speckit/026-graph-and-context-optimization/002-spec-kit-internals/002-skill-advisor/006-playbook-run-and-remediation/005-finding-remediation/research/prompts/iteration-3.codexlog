    71	}[] = LANE_DEFINITIONS.map((lane) => ({
    72	  id: lane.id,
    73	  weight: RESOLVED_WEIGHTS[lane.id],
    74	  shadowWeight: RESOLVED_SHADOW_WEIGHTS[lane.id],
    75	  live: lane.live,
    76	}));
    77	
    78	export const SCORER_LANE_IDS = SCORER_LANE_REGISTRY.map((lane) => lane.id) as [
    79	  ScorerLaneId,
    80	  ...ScorerLaneId[],
    81	];
    82	
    83	export const LIVE_SCORER_LANE_IDS = SCORER_LANE_REGISTRY
    84	  .filter((lane) => lane.live)
    85	  .map((lane) => lane.id) as ScorerLaneId[];
    86	
    87	export const DEFAULT_SCORER_LANE_WEIGHTS = RESOLVED_WEIGHTS;
    88	
    89	export const DEFAULT_SHADOW_SCORER_LANE_WEIGHTS = RESOLVED_SHADOW_WEIGHTS;
    90	
    91	export function isLiveScorerLane(lane: ScorerLaneId): boolean {
    92	  return SCORER_LANE_REGISTRY.some((entry) => entry.id === lane && entry.live);
    93	}

