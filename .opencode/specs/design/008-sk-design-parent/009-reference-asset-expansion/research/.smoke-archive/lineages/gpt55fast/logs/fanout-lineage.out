c]\",\n          \"matched_phrases\": [\n            \"stop\"\n          ]\n        },\n        {\n          \"memory_id\": 8558,\n          \"spec_folder\": \"system-spec-kit/z_archive/024-compact-code-graph/003-stop-hook-tracking\",\n          \"title\": \"Plan: Phase 3 — Stop Hook + Token Tracking [system-spec-kit/024-compact-code-graph/003-stop-hook-tracking/plan]\",\n          \"matched_phrases\": [\n            \"stop\"\n          ]\n        },\n        {\n          \"memory_id\": 8540,\n          \"spec_folder\": \"system-spec-kit/z_archive/024-compact-code-graph/003-stop-hook-tracking\",\n          \"title\": \"Tasks: Stop Hook + Token Tracking [024/003] [system-spec-kit/024-compact-code-graph/003-stop-hook-tracking/tasks]\",\n          \"matched_phrases\": [\n            \"stop\"\n          ]\n        },\n        {\n          \"memory_id\": 8534,\n          \"spec_folder\": \"system-spec-kit/z_archive/024-compact-code-graph/003-stop-hook-tracking\",\n          \"title\": \"Implementation Summary: Stop [system-spec-kit/024-compact-code-graph/003-stop-hook-tracking/implementation-summary]\",\n          \"matched_phrases\": [\n            \"stop\"\n          ]\n        },\n        {\n          \"memory_id\": 8531,\n          \"spec_folder\": \"system-spec-kit/z_archive/024-compact-code-graph/003-stop-hook-tracking\",\n          \"title\": \"Checklist: Phase 3 — Stop Hook + Token [system-spec-kit/024-compact-code-graph/003-stop-hook-tracking/checklist]\",\n          \"matched_phrases\": [\n            \"stop\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-06-26T15:21:12.264Z\",\n      \"latencyMs\": 3696\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1782487268558,"end":1782487272297}},"metadata":{"openai":{"itemId":"fc_0b24b3d7f2c43031016a3e98e467648194b4314bfc6fae38c7"}},"id":"prt_f04853c92001JRSao93mt0pFoN","sessionID":"ses_0fb835c90ffeqUAmvkS8gfEWSy","messageID":"msg_f0484f4db0017GLry33J1wDWtk"}}
