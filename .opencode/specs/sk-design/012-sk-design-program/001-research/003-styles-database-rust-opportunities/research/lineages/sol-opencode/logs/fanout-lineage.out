ity.\\\"},{\\\"approach\\\":\\\"Parallel SQLite publication\\\",\\\"reason\\\":\\\"The single transaction is the correctness boundary; bounded parallelism belongs in verification and parsing.\\\"},{\\\"approach\\\":\\\"Watcher as freshness authority\\\",\\\"reason\\\":\\\"Node, Chokidar, and Rust notify all consume fallible platform events, so authoritative reconciliation remains required.\\\"},{\\\"approach\\\":\\\"Standalone Rust watcher at current scale\\\",\\\"reason\\\":\\\"Chokidar provides normalized atomic and chunked-write handling without a new binary lifecycle.\\\"}],\\\"graphEvents\\\":[{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"q-index-automation-scale\\\",\\\"kind\\\":\\\"QUESTION\\\",\\\"label\\\":\\\"Index automation by scale\\\"},{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"f-projection-cache-gap\\\",\\\"kind\\\":\\\"FINDING\\\",\\\"label\\\":\\\"Parsed projection cache is missing\\\"},{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"f-precommit-worker-seam\\\",\\\"kind\\\":\\\"FINDING\\\",\\\"label\\\":\\\"Parallel seam is pre-transaction\\\"},{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"f-watcher-hints-only-i8\\\",\\\"kind\\\":\\\"FINDING\\\",\\\"label\\\":\\\"Watch events remain hints\\\"},{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"c-manifest-required-external\\\",\\\"kind\\\":\\\"CLAIM\\\",\\\"label\\\":\\\"External projections require manifest\\\"},{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"s-styles-indexer-i8\\\",\\\"kind\\\":\\\"SOURCE\\\",\\\"label\\\":\\\"Styles indexer and publisher\\\"},{\\\"type\\\":\\\"node\\\",\\\"id\\\":\\\"s-watcher-docs-i8\\\",\\\"kind\\\":\\\"SOURCE\\\",\\\"label\\\":\\\"Node Chokidar notify watcher docs\\\"},{\\\"type\\\":\\\"edge\\\",\\\"id\\\":\\\"e-cache-answers-automation-i8\\\",\\\"source\\\":\\\"f-projection-cache-gap\\\",\\\"target\\\":\\\"q-index-automation-scale\\\",\\\"relation\\\":\\\"ANSWERS\\\"},{\\\"type\\\":\\\"edge\\\",\\\"id\\\":\\\"e-worker-answers-automation-i8\\\",\\\"source\\\":\\\"f-precommit-worker-seam\\\"