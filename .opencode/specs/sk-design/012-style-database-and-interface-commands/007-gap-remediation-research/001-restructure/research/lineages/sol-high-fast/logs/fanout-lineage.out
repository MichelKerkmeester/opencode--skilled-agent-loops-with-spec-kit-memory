proaches\",\n60:       \"ruled-out-directions\",\n61:       \"divergence-frontier\",\n62:       \"next-focus\"\n63:     ]\n64:   },\n65:   \"capabilityMatrixPath\": \".opencode/skills/system-deep-loop/deep-research/assets/runtime-capabilities.json\",\n66:   \"reducerScriptPath\": \".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs\",\n67:   \"pauseSentinelPath\": \".deep-research-pause\",\n68:   \"archiveRoot\": \"_archive\",\n69:   \"migrationWindowDays\": 28,\n70:   \"nextRunAt\": null,\n71:   \"remainingDelayMs\": null,\n72:   \"fileProtection\": {\n73:     \"deep-research-config.json\": \"immutable\",\n74:     \"deep-research-state.jsonl\": \"append-only\",\n75:     \"deep-research-strategy.md\": \"mutable\",\n76:     \"deep-research-dashboard.md\": \"auto-generated\",\n77:     \"findings-registry.json\": \"auto-generated\",\n78:     \"iteration-*.md\": \"write-once\",\n79:     \"research.md\": \"mutable\"\n80:   }\n81: }\n\n(End of file - total 81 lines)\n</content>","metadata":{"preview":"{\n  \"topic\": \"Restructure the sk-design styles tree so the 1290 downloaded style data folders are separated from the backend code (database, engine, harness, manifests), aligned to the proven system-deep-loop/runtime architecture (code in lib-style modules, real sqlite under a database directory, kebab-case throughout). Deliver a concrete target folder layout, a migration path from the current flat mixed structure, and the git-mv rename plan.\",\n  \"maxIterations\": 5,\n  \"minIterations\": 3,\n  \"convergenceThreshold\": 0.05,\n  \"stopPolicy\": \"max-iterations\",\n  \"antiConvergence\": {\n    \"minIterations\": 3,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"max-iterations\",\n    \"divergent\": {}\n  },\n  \"stuckThreshold\": 3,\n  \"minIdeaObservations\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,\n  \"specFolder\": \"/Users/mi