const fs = require('fs');
const path = require('path');
const root = process.cwd();
const rel = (...parts) => path.join(...parts);
const modelIds = ['minimax-m3','mimo-v2.5-pro','minimax-2.7','swe-1.6','deepseek-v4-pro','kimi-k2.6','qwen3.6','glm-5.1'];
const cliIds = ['cli-claude-code','cli-codex','cli-devin','cli-gemini','cli-opencode'];
const files = [
  ...modelIds.map(id => rel('.opencode/skills/sk-prompt-small-model/references/models', `${id}.md`)),
  rel('.opencode/skills/sk-prompt-small-model/references/models/_index.md'),
  rel('.opencode/skills/sk-prompt-small-model/references/pattern-index.md'),
  ...cliIds.map(id => rel('.opencode/skills', id, 'assets/prompt_quality_card.md')),
  ...cliIds.map(id => rel('.opencode/skills', id, 'SKILL.md')),
  rel('.opencode/skills/sk-prompt/assets/cli_prompt_quality_card.md'),
];
function stripCode(line, state) {
  if (/^\s*```/.test(line)) state.inFence = !state.inFence;
  return state.inFence ? '' : line;
}
function getScopeLines(file, content) {
  const lines = content.split(/\r?\n/);
  if (!file.endsWith('/SKILL.md')) return lines.map((text, i) => ({ text, n: i + 1 }));
  const start = lines.findIndex(l => l.includes('Prompt construction & model-craft (cli-* family precedence).'));
  if (start < 0) return [];
  let end = lines.length;
  for (let i = start + 1; i < lines.length; i++) {
    if (/^\s*\d+\.\s+\*\*[^*]+\*\*/.test(lines[i]) && !/^\s+\d+\./.test(lines[i])) { end = i; break; }
    if (/^\s*###\s+/.test(lines[i]) || /^\s*##\s+/.test(lines[i])) { end = i; break; }
  }
  return lines.slice(start, end).map((text, i) => ({ text, n: start + i + 1 }));
}
function isRelative(target) {
  if (!target || target.startsWith('#')) return false;
  if (/^[a-z][a-z0-9+.-]*:/i.test(target)) return false;
  if (target.startsWith('/')) return false;
  return true;
}
function decodeLink(raw) {
  return raw.replace(/\\\)/g, ')').trim();
}
function checkTarget(file, target) {
  let clean = target.split('#')[0].split('?')[0];
  clean = decodeURIComponent(clean);
  if (clean === '') return { exists: true, resolved: file };
  const resolved = path.resolve(root, path.dirname(file), clean);
  return { exists: fs.existsSync(resolved), resolved: path.relative(root, resolved) };
}
function extractLinks(file, content) {
  const scoped = getScopeLines(file, content);
  const out = [];
  const state = { inFence: false };
  for (const { text: orig, n } of scoped) {
    const text = stripCode(orig, state);
    if (!text) continue;
    // Inline markdown links/images: [label](target) or ![label](target)
    const inline = /!?\[[^\]\n]*(?:\][^\[]*\[[^\]\n]*)*\]\(([^\s)]+(?:\\\)|[^)])*)\)/g;
    let m;
    while ((m = inline.exec(text))) {
      const target = decodeLink(m[1]);
      if (isRelative(target)) out.push({ line: n, target, syntax: 'inline' });
    }
    // Reference definitions: [label]: target
    const def = /^\s*\[[^\]]+\]:\s*(\S+)/.exec(text);
    if (def) {
      const target = decodeLink(def[1]);
      if (isRelative(target)) out.push({ line: n, target, syntax: 'definition' });
    }
  }
  return out;
}
const all = [];
for (const file of files) {
  const abs = path.join(root, file);
  if (!fs.existsSync(abs)) {
    all.push({ file, missingFile: true });
    continue;
  }
  const content = fs.readFileSync(abs, 'utf8');
  const links = extractLinks(file, content);
  for (const link of links) {
    const result = checkTarget(file, link.target);
    all.push({ file, line: link.line, target: link.target, resolved: result.resolved, exists: result.exists, syntax: link.syntax });
  }
}
const broken = all.filter(x => x.missingFile || x.exists === false);
console.log(JSON.stringify({ checkedFiles: files.length, totalRelativeLinks: all.filter(x => !x.missingFile).length, brokenCount: broken.length, broken, all }, null, 2));
