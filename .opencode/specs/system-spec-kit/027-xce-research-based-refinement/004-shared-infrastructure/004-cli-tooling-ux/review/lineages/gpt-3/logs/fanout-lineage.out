}\n39:   if (exitCode === 0) return 'fresh';\n40:   return 'unknown';\n41: }\n42: \n43: function parseJson(stdout) {\n44:   try {\n45:     return JSON.parse(stdout || '{}');\n46:   } catch {\n47:     return null;\n48:   }\n49: }\n50: \n51: function runCheck(check, timeoutMs) {\n52:   const sandbox = fs.mkdtempSync(path.join(os.tmpdir(), 'cli-offline-smoke-'));\n53:   const socketDir = path.join(sandbox, 'sock');\n54:   try {\n55:     const result = spawnSync(process.execPath, [check.shim, 'list-tools', '--format', 'json'], {\n56:       cwd: repoRoot,\n57:       env: {\n58:         ...process.env,\n59:         SPECKIT_IPC_SOCKET_DIR: socketDir,\n60:         SPECKIT_DAEMON_REELECTION: '0',\n61:       },\n62:       encoding: 'utf8',\n63:       timeout: timeoutMs,\n64:       maxBuffer: 1024 * 1024 * 10,\n65:       stdio: ['ignore', 'pipe', 'pipe'],\n66:     });\n67: \n68:     const payload = parseJson(result.stdout);\n69:     const count = payload?.data?.count;\n70:     const daemonSocket = path.join(socketDir, socketFileName);\n71:     const freshness = classifyFreshness(result.status, result.stderr ?? '');\n72:     const ok = result.status === 0\n73:       && payload?.status === 'ok'\n74:       && count === check.expectedCount\n75:       && !fs.existsSync(daemonSocket);\n76: \n77:     return {\n78:       name: check.name,\n79:       ok,\n80:       status: payload?.status ?? null,\n81:       count: typeof count === 'number' ? count : null,\n82:       expectedCount: check.expectedCount,\n83:       freshness,\n84:       exitCode: result.status,\n85:       signal: result.signal,\n86:       daemonFree: !fs.existsSync(daemonSocket),\n87:       stderr: result.stderr ? '[stderr-present]' : null,\n88:     };\n89:   } finally {\n90:     fs.rmSync(sandbox, { recursive: true, force: true });\n91:   }\n92: }\n93: \n94: function renderText(payload) {\n95:   const lines = [\n96:     `CLI offline smoke: ${payload.status.toUpperCase()}`,\n97:     `scenario=${payload.scenario}`,\n98:   ];\n99:   for (const result of payload.results) {\n100:     lines.push(`${result.name}: ${result.ok ? 'ok' : 'fail'} count=${result.count ?? 'n/a'}/${result.expectedCount} freshness=${result.freshness} daemonFree=${result.daemonFree}`);\n101:   }\n102:   return `${lines.join('\\n')}\\n`;\n103: }\n104: \n105: function main() {\n106:   const options = parseArgs(process.argv.slice(2));\n107:   const results = checks.map((check) => runCheck(check, options.timeoutMs));\n108:   const ok = results.every((result) => result.ok);\n109:   const payload = {\n110:     status: ok ? 'ok' : 'fail',\n111:     scenario: 'cli-list-tools-parity',\n112:     daemonRequired: false,\n113:     buildRequired: false,\n114:     scanRequired: false,\n115:     results,\n116:   };\n117: \n118:   process.stdout.write(options.format === 'json' ? `${JSON.stringify(payload, null, 2)}\\n` : renderText(payload));\n119:   process.exit(ok ? 0 : 1);\n120: }\n121: \n122: main();\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\nconst fs = require('fs');\nconst os = require('os');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\nconst repoRoot = path.resolve(__dirname, '..', '..');\nconst socketFileName = 'daemon-ipc.sock';\nconst checks = [\n  { name: 'spec-memory', shim: path.join(__dirname, 'spec-memory.cjs'), expectedCount: 37 },\n  { name: 'code-index', shim: path.join(__dirname, 'code-index.cjs'), expectedCount: 8 },\n  { name: 'skill-advisor', shim: path.join(__dirname, 'skill-advisor.cjs'), expectedCount: 9 },\n];\n\nfunction parseArgs(argv) {\n  const options = { format: 'text', timeoutMs: 20_000 };\n  for (let index = 0; index < argv.length; index += 1) {\n    const value = argv[index];","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.cjs","text":"#!/usr/bin/env node\n'use strict';\n\nconst fs = require('fs');\nconst os = require('os');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\nconst repoRoot = path.resolve(__dirname, '..', '..');\nconst socketFileName = 'daemon-ipc.sock';\nconst checks = [\n  { name: 'spec-memory', shim: path.join(__dirname, 'spec-memory.cjs'), expectedCount: 37 },\n  { name: 'code-index', shim: path.join(__dirname, 'code-index.cjs'), expectedCount: 8 },\n  { name: 'skill-advisor', shim: path.join(__dirname, 'skill-advisor.cjs'), expectedCount: 9 },\n];\n\nfunction parseArgs(argv) {\n  const options = { format: 'text', timeoutMs: 20_000 };\n  for (let index = 0; index < argv.length; index += 1) {\n    const value = argv[index];\n    if (value === '--format') {\n      options.format = argv[index + 1] === 'json' ? 'json' : 'text';\n      index += 1;\n    } else if (value === '--json') {\n      options.format = 'json';\n    } else if (value === '--timeout-ms') {\n      const parsed = Number.parseInt(argv[index + 1], 10);\n      if (Number.isFinite(parsed) && parsed > 0) options.timeoutMs = parsed;\n      index += 1;\n    }\n  }\n  return options;\n}\n\nfunction classifyFreshness(exitCode, stderr) {\n  if (exitCode === 69 && /dist entrypoint is (stale|missing)/i.test(stderr)) {\n    return 'dist_stale_rebuild_required';\n  }\n  if (exitCode === 0) return 'fresh';\n  return 'unknown';\n}\n\nfunction parseJson(stdout) {\n  try {\n    return JSON.parse(stdout || '{}');\n  } catch {\n    return null;\n  }\n}\n\nfunction runCheck(check, timeoutMs) {\n  const sandbox = fs.mkdtempSync(path.join(os.tmpdir(), 'cli-offline-smoke-'));\n  const socketDir = path.join(sandbox, 'sock');\n  try {\n    const result = spawnSync(process.execPath, [check.shim, 'list-tools', '--format', 'json'], {\n      cwd: repoRoot,\n      env: {\n        ...process.env,\n        SPECKIT_IPC_SOCKET_DIR: socketDir,\n        SPECKIT_DAEMON_REELECTION: '0',\n      },\n      encoding: 'utf8',\n      timeout: timeoutMs,\n      maxBuffer: 1024 * 1024 * 10,\n      stdio: ['ignore', 'pipe', 'pipe'],\n    });\n\n    const payload = parseJson(result.stdout);\n    const count = payload?.data?.count;\n    const daemonSocket = path.join(socketDir, socketFileName);\n    const freshness = classifyFreshness(result.status, result.stderr ?? '');\n    const ok = result.status === 0\n      && payload?.status === 'ok'\n      && count === check.expectedCount\n      && !fs.existsSync(daemonSocket);\n\n    return {\n      name: check.name,\n      ok,\n      status: payload?.status ?? null,\n      count: typeof count === 'number' ? count : null,\n      expectedCount: check.expectedCount,\n      freshness,\n      exitCode: result.status,\n      signal: result.signal,\n      daemonFree: !fs.existsSync(daemonSocket),\n      stderr: result.stderr ? '[stderr-present]' : null,\n    };\n  } finally {\n    fs.rmSync(sandbox, { recursive: true, force: true });\n  }\n}\n\nfunction renderText(payload) {\n  const lines = [\n    `CLI offline smoke: ${payload.status.toUpperCase()}`,\n    `scenario=${payload.scenario}`,\n  ];\n  for (const result of payload.results) {\n    lines.push(`${result.name}: ${result.ok ? 'ok' : 'fail'} count=${result.count ?? 'n/a'}/${result.expectedCount} freshness=${result.freshness} daemonFree=${result.daemonFree}`);\n  }\n  return `${lines.join('\\n')}\\n`;\n}\n\nfunction main() {\n  const options = parseArgs(process.argv.slice(2));\n  const results = checks.map((check) => runCheck(check, options.timeoutMs));\n  const ok = results.every((result) => result.ok);\n  const payload = {\n    status: ok ? 'ok' : 'fail',\n    scenario: 'cli-list-tools-parity',\n    daemonRequired: false,\n    buildRequired: false,\n    scanRequired: false,\n    results,\n  };\n\n  process.stdout.write(options.format === 'json' ? `${JSON.stringify(payload, null, 2)}\\n` : renderText(payload));\n  process.exit(ok ? 0 : 1);\n}\n\nmain();","lineStart":1,"lineEnd":122,"totalLines":122,"truncated":false}},"title":".opencode/bin/cli-offline-smoke.cjs","time":{"start":1781145004526,"end":1781145004532}},"metadata":{"openai":{"itemId":"fc_022207856142141c016a2a1dac6d148191a011f13501703c4c"}},"id":"prt_eb483e9ed001ilWfeu2B5PdMSy","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb483b48f001iw4rp7PWNlbwst"}}
{"type":"tool_use","timestamp":1781145004537,"sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","part":{"type":"tool","tool":"read","callID":"call_0qwoeHPjMDZomtQDYQ1IhBCl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.test.cjs","offset":1,"limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.test.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: const assert = require('assert');\n5: const path = require('path');\n6: const { spawnSync } = require('child_process');\n7: \n8: const repoRoot = path.resolve(__dirname, '..', '..');\n9: const smokeScript = path.join(__dirname, 'cli-offline-smoke.cjs');\n10: \n11: const result = spawnSync(process.execPath, [smokeScript, '--format', 'json'], {\n12:   cwd: repoRoot,\n13:   encoding: 'utf8',\n14:   timeout: 60_000,\n15:   maxBuffer: 1024 * 1024 * 10,\n16:   stdio: ['ignore', 'pipe', 'pipe'],\n17: });\n18: \n19: assert.strictEqual(result.status, 0, result.stderr || result.stdout);\n20: const payload = JSON.parse(result.stdout);\n21: assert.strictEqual(payload.status, 'ok');\n22: assert.strictEqual(payload.daemonRequired, false);\n23: assert.strictEqual(payload.buildRequired, false);\n24: assert.strictEqual(payload.scanRequired, false);\n25: \n26: const expected = new Map([\n27:   ['spec-memory', 37],\n28:   ['code-index', 8],\n29:   ['skill-advisor', 9],\n30: ]);\n31: \n32: for (const row of payload.results) {\n33:   assert.strictEqual(row.ok, true, `${row.name} smoke row failed`);\n34:   assert.strictEqual(row.count, expected.get(row.name), `${row.name} count mismatch`);\n35:   assert.strictEqual(row.freshness, 'fresh', `${row.name} freshness mismatch`);\n36:   assert.strictEqual(row.daemonFree, true, `${row.name} used a daemon socket`);\n37: }\n38: \n39: (async () => {\n40:   const memoryBridge = await import('../skills/system-spec-kit/mcp_server/plugin_bridges/mk-spec-memory-bridge.mjs');\n41:   const codeGraphBridge = await import('../skills/system-code-graph/mcp_server/plugin_bridges/mk-code-graph-bridge.mjs');\n42:   const advisorBridge = await import('../skills/system-skill-advisor/mcp_server/plugin_bridges/mk-skill-advisor-bridge.mjs');\n43: \n44:   for (const classify of [memoryBridge.classifyCliFailure, codeGraphBridge.classifyCliFailure]) {\n45:     const stale = classify(69, 'dist entrypoint is stale. Run a build.', false);\n46:     assert.strictEqual(stale.error, 'dist_stale_rebuild_required');\n47:     assert.strictEqual(stale.metadata.staleDist, true);\n48:     assert.strictEqual(stale.metadata.rebuildRequired, true);\n49:     assert.strictEqual(stale.retryable, false);\n50:   }\n51: \n52:   const advisorStale = advisorBridge.classifyCliStaleDist(69, 'skill-advisor dist entrypoint is stale. Run a build.');\n53:   assert.strictEqual(advisorStale.state, 'dist_stale_rebuild_required');\n54:   assert.strictEqual(advisorStale.stderr, '[stderr-present]');\n55:   assert.strictEqual(advisorStale.rebuildRequired, true);\n56: })().catch((error) => {\n57:   process.stderr.write(`${error?.stack ?? error}\\n`);\n58:   process.exit(1);\n59: });\n\n(End of file - total 59 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\nconst assert = require('assert');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\nconst repoRoot = path.resolve(__dirname, '..', '..');\nconst smokeScript = path.join(__dirname, 'cli-offline-smoke.cjs');\n\nconst result = spawnSync(process.execPath, [smokeScript, '--format', 'json'], {\n  cwd: repoRoot,\n  encoding: 'utf8',\n  timeout: 60_000,\n  maxBuffer: 1024 * 1024 * 10,\n  stdio: ['ignore', 'pipe', 'pipe'],\n});\n\nassert.strictEqual(result.status, 0, result.stderr || result.stdout);\nconst payload = JSON.parse(result.stdout);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.test.cjs","text":"#!/usr/bin/env node\n'use strict';\n\nconst assert = require('assert');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\nconst repoRoot = path.resolve(__dirname, '..', '..');\nconst smokeScript = path.join(__dirname, 'cli-offline-smoke.cjs');\n\nconst result = spawnSync(process.execPath, [smokeScript, '--format', 'json'], {\n  cwd: repoRoot,\n  encoding: 'utf8',\n  timeout: 60_000,\n  maxBuffer: 1024 * 1024 * 10,\n  stdio: ['ignore', 'pipe', 'pipe'],\n});\n\nassert.strictEqual(result.status, 0, result.stderr || result.stdout);\nconst payload = JSON.parse(result.stdout);\nassert.strictEqual(payload.status, 'ok');\nassert.strictEqual(payload.daemonRequired, false);\nassert.strictEqual(payload.buildRequired, false);\nassert.strictEqual(payload.scanRequired, false);\n\nconst expected = new Map([\n  ['spec-memory', 37],\n  ['code-index', 8],\n  ['skill-advisor', 9],\n]);\n\nfor (const row of payload.results) {\n  assert.strictEqual(row.ok, true, `${row.name} smoke row failed`);\n  assert.strictEqual(row.count, expected.get(row.name), `${row.name} count mismatch`);\n  assert.strictEqual(row.freshness, 'fresh', `${row.name} freshness mismatch`);\n  assert.strictEqual(row.daemonFree, true, `${row.name} used a daemon socket`);\n}\n\n(async () => {\n  const memoryBridge = await import('../skills/system-spec-kit/mcp_server/plugin_bridges/mk-spec-memory-bridge.mjs');\n  const codeGraphBridge = await import('../skills/system-code-graph/mcp_server/plugin_bridges/mk-code-graph-bridge.mjs');\n  const advisorBridge = await import('../skills/system-skill-advisor/mcp_server/plugin_bridges/mk-skill-advisor-bridge.mjs');\n\n  for (const classify of [memoryBridge.classifyCliFailure, codeGraphBridge.classifyCliFailure]) {\n    const stale = classify(69, 'dist entrypoint is stale. Run a build.', false);\n    assert.strictEqual(stale.error, 'dist_stale_rebuild_required');\n    assert.strictEqual(stale.metadata.staleDist, true);\n    assert.strictEqual(stale.metadata.rebuildRequired, true);\n    assert.strictEqual(stale.retryable, false);\n  }\n\n  const advisorStale = advisorBridge.classifyCliStaleDist(69, 'skill-advisor dist entrypoint is stale. Run a build.');\n  assert.strictEqual(advisorStale.state, 'dist_stale_rebuild_required');\n  assert.strictEqual(advisorStale.stderr, '[stderr-present]');\n  assert.strictEqual(advisorStale.rebuildRequired, true);\n})().catch((error) => {\n  process.stderr.write(`${error?.stack ?? error}\\n`);\n  process.exit(1);\n});","lineStart":1,"lineEnd":59,"totalLines":59,"truncated":false}},"title":".opencode/bin/cli-offline-smoke.test.cjs","time":{"start":1781145004528,"end":1781145004536}},"metadata":{"openai":{"itemId":"fc_022207856142141c016a2a1dac6d1c8191ace4c85bf17bbf82"}},"id":"prt_eb483e9ef001Ji7IEuuxivf6nI","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb483b48f001iw4rp7PWNlbwst"}}
