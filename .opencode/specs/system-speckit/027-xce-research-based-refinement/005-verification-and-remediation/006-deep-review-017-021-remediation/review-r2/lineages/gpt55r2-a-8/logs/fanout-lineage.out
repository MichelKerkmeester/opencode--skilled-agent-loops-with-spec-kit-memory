{"type":"tool_use","timestamp":1781763821871,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_uG0me9jAz3L4TVs5zrbDsjuy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","offset":1,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Search Utilities\n3: // ───────────────────────────────────────────────────────────────\n4: // Extracted from handlers/memory-search.ts\n5: // Small, stateless utility functions used during search:\n6: // quality filtering, threshold resolution, cache key building,\n7: // context type resolution, and artifact routing helpers.\n8: \n9: import { applyRoutingWeights } from './artifact-routing.js';\n10: import type { RoutingResult, WeightedResult } from './artifact-routing.js';\n11: import { isContinuityQuery } from './intent-classifier.js';\n12: \n13: /* ───────────────────────────────────────────────────────────────\n14:    1. TYPES\n15: ──────────────────────────────────────────────────────────────── */\n16: \n17: /**\n18:  * Minimal row shape for search utility functions.\n19:  * Mirrors the subset of MemorySearchRow fields that these helpers access.\n20:  */\n21: interface SearchUtilRow extends Record<string, unknown> {\n22:   id: number;\n23:   contextType?: string;\n24:   context_type?: string;\n25:   quality_score?: number;\n26: }\n27: \n28: interface CacheArgsInput {\n29:   normalizedQuery: string | null;\n30:   hasValidConcepts: boolean;\n31:   concepts?: string[];\n32:   specFolder?: string;\n33:   tenantId?: string;\n34:   userId?: string;\n35:   agentId?: string;\n36:   limit: number;\n37:   mode?: string;\n38:   tier?: string;\n39:   contextType?: string;\n40:   useDecay: boolean;\n41:   includeArchived: boolean;\n42:   qualityThreshold?: number;\n43:   applyStateLimits: boolean | undefined;\n44:   includeContiguity: boolean;\n45:   includeConstitutional: boolean;\n46:   includeContent: boolean;\n47:   anchors?: string[] | string;\n48:   detectedIntent: string | null;\n49:   adaptiveFusionIntent?: string | null;\n50:   minState: string;\n51:   rerank: boolean;\n52:   applyLengthPenalty: boolean;\n53:   sessionId?: string;\n54:   enableSessionBoost: boolean;\n55:   enableCausalBoost: boolean;\n56:   includeTrace?: boolean;\n57:   cacheVersion?: string;\n58:   /**\n59:    * Causal-edges generation counter snapshot. When `enableCausalBoost`\n60:    * is true, callers should pass the current generation from\n61:    * `causalEdges.getCausalEdgesGeneration()` so that any causal-edge mutation\n62:    * naturally invalidates this cache key on the next lookup.\n63:    * Optional and ignored when undefined to keep cache keys stable for callers\n64:    * that do not depend on the causal graph.\n65:    */\n66:   causalEdgesGeneration?: number;\n67: }\n68: \n69: function resolveFusionIntentContract(\n70:   args: {\n71:     detectedIntent: string | null;\n72:     adaptiveFusionIntent?: string | null;\n73:     query?: string | null;\n74:   },\n75: ): string | null {\n76:   const { detectedIntent, adaptiveFusionIntent, query } = args;\n77:   if (typeof adaptiveFusionIntent === 'string' && adaptiveFusionIntent.trim().length > 0) {\n78:     return adaptiveFusionIntent;\n79:   }\n80:   if (typeof query === 'string' && isContinuityQuery(query)) {\n81:     return 'continuity';\n82:   }\n83:   if (typeof detectedIntent === 'string' && detectedIntent.trim().length > 0) {\n84:     return detectedIntent;\n85:   }\n86:   return null;\n87: }\n88: \n89: /* ───────────────────────────────────────────────────────────────\n90:    2. FUNCTIONS\n91: ──────────────────────────────────────────────────────────────── */\n92: \n93: /**\n94:  * Resolve the context type from a row, preferring camelCase over snake_case.\n95:  */\n96: function resolveRowContextType(row: SearchUtilRow): string | undefined {\n97:   if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n98:     return row.contextType;\n99:   }\n100:   if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n101:     return row.context_type;\n102:   }\n103:   return undefined;\n104: }\n105: \n106: /**\n107:  * Filter results by minimum quality score.\n108:  * Returns all results if no valid threshold is provided.\n109:  */\n110: function filterByMinQualityScore(results: SearchUtilRow[], minQualityScore?: number): SearchUtilRow[] {\n111:   if (typeof minQualityScore !== 'number' || !Number.isFinite(minQualityScore)) {\n112:     return results;\n113:   }\n114: \n115:   const threshold = Math.max(0, Math.min(1, minQualityScore));\n116:   return results.filter((result) => {\n117:     const rawScore = result.quality_score as number | undefined;\n118:     const score = typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n119:     return score >= threshold;\n120:   });\n121: }\n122: \n123: /**\n124:  * Resolve the quality threshold from camelCase or snake_case parameter.\n125:  */\n126: function resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n127:   if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n128:     return minQualityScore;\n129:   }\n130: \n131:   if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n132:     return minQualityScoreSnake;\n133:   }\n134: \n135:   return undefined;\n136: }\n137: \n138: /**\n139:  * Build a cache key arguments object from search parameters.\n140:  */\n141: function buildCacheArgs({\n142:   normalizedQuery,\n143:   hasValidConcepts,\n144:   concepts,\n145:   specFolder,\n146:   tenantId,\n147:   userId,\n148:   agentId,\n149:   limit,\n150:   mode,\n151:   tier,\n152:   contextType,\n153:   useDecay,\n154:   includeArchived,\n155:   qualityThreshold,\n156:   applyStateLimits,\n157:   includeContiguity,\n158:   includeConstitutional,\n159:   includeContent,\n160:   anchors,\n161:   detectedIntent,\n162:   adaptiveFusionIntent,\n163:   minState,\n164:   rerank,\n165:   applyLengthPenalty,\n166:   sessionId,\n167:   enableSessionBoost,\n168:   enableCausalBoost,\n169:   includeTrace = false,\n170:   cacheVersion,\n171:   causalEdgesGeneration,\n172: }: CacheArgsInput): Record<string, unknown> {\n173:   const resolvedFusionIntent = resolveFusionIntentContract({\n174:     detectedIntent,\n175:     adaptiveFusionIntent,\n176:     query: normalizedQuery,\n177:   });\n178:   // Only include causal-edges generation in the cache key when the\n179:   // caller has actually opted into causal boost; otherwise cache keys remain\n180:   // stable for callers that do not consume the causal graph.\n181:   const includeCausalGeneration = enableCausalBoost === true\n182:     && typeof causalEdgesGeneration === 'number'\n183:     && Number.isFinite(causalEdgesGeneration);\n184:   return {\n185:     query: normalizedQuery,\n186:     concepts: hasValidConcepts ? concepts : undefined,\n187:     specFolder,\n188:     tenantId,\n189:     userId,\n190:     agentId,\n191:     limit,\n192:     mode,\n193:     tier,\n194:     contextType,\n195:     useDecay,\n196:     includeArchived,\n197:     qualityThreshold,\n198:     applyStateLimits,\n199:     includeContiguity,\n200:     includeConstitutional,\n201:     includeContent,\n202:     anchors,\n203:     intent: resolvedFusionIntent ?? detectedIntent,\n204:     fusionIntent: resolvedFusionIntent,\n205:     minState,\n206:     rerank,\n207:     applyLengthPenalty,\n208:     sessionId,\n209:     enableSessionBoost,\n210:     enableCausalBoost,\n211:     includeTrace,\n212:     cacheVersion,\n213:     causalEdgesGeneration: includeCausalGeneration ? causalEdgesGeneration : undefined,\n214:   };\n215: }\n216: \n217: /**\n218:  * Resolve the best available query string for artifact routing.\n219:  * Falls back to joining concepts if no query string is provided.\n220:  */\n221: function resolveArtifactRoutingQuery(query: string | null, concepts?: string[]): string {\n222:   if (typeof query === 'string' && query.trim().length > 0) {\n223:     return query;\n224:   }\n225: \n226:   if (Array.isArray(concepts) && concepts.length > 0) {\n227:     return concepts.join(' ');\n228:   }\n229: \n230:   return '';\n231: }\n232: \n233: /**\n234:  * Apply artifact routing weights to search results.\n235:  * No-op if routing result is absent, unknown, or zero-confidence.\n236:  */\n237: function applyArtifactRouting(results: SearchUtilRow[], routingResult?: RoutingResult): SearchUtilRow[] {\n238:   if (!Array.isArray(results) || results.length === 0) {\n239:     return results;\n240:   }\n241: \n242:   if (!routingResult || routingResult.detectedClass === 'unknown' || routingResult.confidence <= 0) {\n243:     return results;\n244:   }\n245: \n246:   return applyRoutingWeights(results as WeightedResult[], routingResult.strategy) as SearchUtilRow[];\n247: }\n248: \n249: /* ───────────────────────────────────────────────────────────────\n250:    3. EXPORTS\n251: ──────────────────────────────────────────────────────────────── */\n252: \n253: export {\n254:   resolveRowContextType,\n255:   filterByMinQualityScore,\n256:   resolveQualityThreshold,\n257:   resolveFusionIntentContract,\n258:   buildCacheArgs,\n259:   resolveArtifactRoutingQuery,\n260:   applyArtifactRouting,\n261: };\n262: \n263: export type {\n264:   SearchUtilRow,\n265:   CacheArgsInput,\n266: };\n\n(End of file - total 266 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Utilities\n// ───────────────────────────────────────────────────────────────\n// Extracted from handlers/memory-search.ts\n// Small, stateless utility functions used during search:\n// quality filtering, threshold resolution, cache key building,\n// context type resolution, and artifact routing helpers.\n\nimport { applyRoutingWeights } from './artifact-routing.js';\nimport type { RoutingResult, WeightedResult } from './artifact-routing.js';\nimport { isContinuityQuery } from './intent-classifier.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Minimal row shape for search utility functions.\n * Mirrors the subset of MemorySearchRow fields that these helpers access.\n */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Utilities\n// ───────────────────────────────────────────────────────────────\n// Extracted from handlers/memory-search.ts\n// Small, stateless utility functions used during search:\n// quality filtering, threshold resolution, cache key building,\n// context type resolution, and artifact routing helpers.\n\nimport { applyRoutingWeights } from './artifact-routing.js';\nimport type { RoutingResult, WeightedResult } from './artifact-routing.js';\nimport { isContinuityQuery } from './intent-classifier.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Minimal row shape for search utility functions.\n * Mirrors the subset of MemorySearchRow fields that these helpers access.\n */\ninterface SearchUtilRow extends Record<string, unknown> {\n  id: number;\n  contextType?: string;\n  context_type?: string;\n  quality_score?: number;\n}\n\ninterface CacheArgsInput {\n  normalizedQuery: string | null;\n  hasValidConcepts: boolean;\n  concepts?: string[];\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit: number;\n  mode?: string;\n  tier?: string;\n  contextType?: string;\n  useDecay: boolean;\n  includeArchived: boolean;\n  qualityThreshold?: number;\n  applyStateLimits: boolean | undefined;\n  includeContiguity: boolean;\n  includeConstitutional: boolean;\n  includeContent: boolean;\n  anchors?: string[] | string;\n  detectedIntent: string | null;\n  adaptiveFusionIntent?: string | null;\n  minState: string;\n  rerank: boolean;\n  applyLengthPenalty: boolean;\n  sessionId?: string;\n  enableSessionBoost: boolean;\n  enableCausalBoost: boolean;\n  includeTrace?: boolean;\n  cacheVersion?: string;\n  /**\n   * Causal-edges generation counter snapshot. When `enableCausalBoost`\n   * is true, callers should pass the current generation from\n   * `causalEdges.getCausalEdgesGeneration()` so that any causal-edge mutation\n   * naturally invalidates this cache key on the next lookup.\n   * Optional and ignored when undefined to keep cache keys stable for callers\n   * that do not depend on the causal graph.\n   */\n  causalEdgesGeneration?: number;\n}\n\nfunction resolveFusionIntentContract(\n  args: {\n    detectedIntent: string | null;\n    adaptiveFusionIntent?: string | null;\n    query?: string | null;\n  },\n): string | null {\n  const { detectedIntent, adaptiveFusionIntent, query } = args;\n  if (typeof adaptiveFusionIntent === 'string' && adaptiveFusionIntent.trim().length > 0) {\n    return adaptiveFusionIntent;\n  }\n  if (typeof query === 'string' && isContinuityQuery(query)) {\n    return 'continuity';\n  }\n  if (typeof detectedIntent === 'string' && detectedIntent.trim().length > 0) {\n    return detectedIntent;\n  }\n  return null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. FUNCTIONS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Resolve the context type from a row, preferring camelCase over snake_case.\n */\nfunction resolveRowContextType(row: SearchUtilRow): string | undefined {\n  if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n    return row.contextType;\n  }\n  if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n    return row.context_type;\n  }\n  return undefined;\n}\n\n/**\n * Filter results by minimum quality score.\n * Returns all results if no valid threshold is provided.\n */\nfunction filterByMinQualityScore(results: SearchUtilRow[], minQualityScore?: number): SearchUtilRow[] {\n  if (typeof minQualityScore !== 'number' || !Number.isFinite(minQualityScore)) {\n    return results;\n  }\n\n  const threshold = Math.max(0, Math.min(1, minQualityScore));\n  return results.filter((result) => {\n    const rawScore = result.quality_score as number | undefined;\n    const score = typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n    return score >= threshold;\n  });\n}\n\n/**\n * Resolve the quality threshold from camelCase or snake_case parameter.\n */\nfunction resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n  if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n    return minQualityScore;\n  }\n\n  if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n    return minQualityScoreSnake;\n  }\n\n  return undefined;\n}\n\n/**\n * Build a cache key arguments object from search parameters.\n */\nfunction buildCacheArgs({\n  normalizedQuery,\n  hasValidConcepts,\n  concepts,\n  specFolder,\n  tenantId,\n  userId,\n  agentId,\n  limit,\n  mode,\n  tier,\n  contextType,\n  useDecay,\n  includeArchived,\n  qualityThreshold,\n  applyStateLimits,\n  includeContiguity,\n  includeConstitutional,\n  includeContent,\n  anchors,\n  detectedIntent,\n  adaptiveFusionIntent,\n  minState,\n  rerank,\n  applyLengthPenalty,\n  sessionId,\n  enableSessionBoost,\n  enableCausalBoost,\n  includeTrace = false,\n  cacheVersion,\n  causalEdgesGeneration,\n}: CacheArgsInput): Record<string, unknown> {\n  const resolvedFusionIntent = resolveFusionIntentContract({\n    detectedIntent,\n    adaptiveFusionIntent,\n    query: normalizedQuery,\n  });\n  // Only include causal-edges generation in the cache key when the\n  // caller has actually opted into causal boost; otherwise cache keys remain\n  // stable for callers that do not consume the causal graph.\n  const includeCausalGeneration = enableCausalBoost === true\n    && typeof causalEdgesGeneration === 'number'\n    && Number.isFinite(causalEdgesGeneration);\n  return {\n    query: normalizedQuery,\n    concepts: hasValidConcepts ? concepts : undefined,\n    specFolder,\n    tenantId,\n    userId,\n    agentId,\n    limit,\n    mode,\n    tier,\n    contextType,\n    useDecay,\n    includeArchived,\n    qualityThreshold,\n    applyStateLimits,\n    includeContiguity,\n    includeConstitutional,\n    includeContent,\n    anchors,\n    intent: resolvedFusionIntent ?? detectedIntent,\n    fusionIntent: resolvedFusionIntent,\n    minState,\n    rerank,\n    applyLengthPenalty,\n    sessionId,\n    enableSessionBoost,\n    enableCausalBoost,\n    includeTrace,\n    cacheVersion,\n    causalEdgesGeneration: includeCausalGeneration ? causalEdgesGeneration : undefined,\n  };\n}\n\n/**\n * Resolve the best available query string for artifact routing.\n * Falls back to joining concepts if no query string is provided.\n */\nfunction resolveArtifactRoutingQuery(query: string | null, concepts?: string[]): string {\n  if (typeof query === 'string' && query.trim().length > 0) {\n    return query;\n  }\n\n  if (Array.isArray(concepts) && concepts.length > 0) {\n    return concepts.join(' ');\n  }\n\n  return '';\n}\n\n/**\n * Apply artifact routing weights to search results.\n * No-op if routing result is absent, unknown, or zero-confidence.\n */\nfunction applyArtifactRouting(results: SearchUtilRow[], routingResult?: RoutingResult): SearchUtilRow[] {\n  if (!Array.isArray(results) || results.length === 0) {\n    return results;\n  }\n\n  if (!routingResult || routingResult.detectedClass === 'unknown' || routingResult.confidence <= 0) {\n    return results;\n  }\n\n  return applyRoutingWeights(results as WeightedResult[], routingResult.strategy) as SearchUtilRow[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  resolveRowContextType,\n  filterByMinQualityScore,\n  resolveQualityThreshold,\n  resolveFusionIntentContract,\n  buildCacheArgs,\n  resolveArtifactRoutingQuery,\n  applyArtifactRouting,\n};\n\nexport type {\n  SearchUtilRow,\n  CacheArgsInput,\n};","lineStart":1,"lineEnd":266,"totalLines":266,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","time":{"start":1781763821866,"end":1781763821870}},"metadata":{"openai":{"itemId":"fc_032f0ebce80c21f6016a338eeda8dc8191a7215e3dbc033f22"}},"id":"prt_ed966511000121ry4WgL6X0KsR","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed9662a5e001wM1Gv8zISlQ0Sc"}}
{"type":"tool_use","timestamp":1781763821891,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_q489NcoMkfTsjLj67KMt2LDG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage3 Rerank\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-Stage Retrieval Pipeline: Stage 3 of 4\n5: //\n6: // Responsibilities (in execution order):\n7: // 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n8: // 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n9: //\n10: // Pipeline position constraint:\n11: // MPAB MUST remain AFTER RRF fusion (Stage 2).\n12: // Stage 3 is the only stage that may change scores after Stage 2.\n13: //\n14: // I/O CONTRACT:\n15: // Input:  Stage3Input { scored: PipelineRow[], config }\n16: // Output: Stage3Output { reranked: PipelineRow[], metadata }\n17: // Key invariants:\n18: //     - reranked is sorted descending by effective score after all steps\n19: //     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n20: //     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'\n21: // Side effects:\n22: //     - DB reads to fetch parent content during MPAB reassembly\n23: //\n24: // Score changes: YES\n25: \n26: import { resolveEffectiveScore } from './types.js';\n27: import type { Stage3Input, Stage3Output, PipelineRow } from './types.js';\n28: import { isMMREnabled } from '../search-flags.js';\n29: import { computeMPAB } from '../../scoring/mpab-aggregation.js';\n30: import { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\n31: import type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\n32: import { INTENT_LAMBDA_MAP } from '../intent-classifier.js';\n33: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n34: import { requireDb } from '../../../utils/index.js';\n35: import { toErrorMessage } from '../../../utils/index.js';\n36: import type Database from 'better-sqlite3';\n37: import { compareDeterministicRows, sortDeterministicRows } from './ranking-contract.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: Hybrid search pipeline\n41: \n42: \n43: // -- Constants --------------------------------------------------\n44: \n45: /** Minimum number of candidates required before MMR diversity pruning is worthwhile. */\n46: const MMR_MIN_CANDIDATES = 2;\n47: \n48: /** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\n49: const MMR_DEFAULT_LAMBDA = 0.7;\n50: \n51: /**\n52:  * Enforce non-negative score outputs at Stage 3 boundaries.\n53:  */\n54: function floorScore(value: number): number {\n55:   return Math.max(0, value);\n56: }\n57: \n58: // -- Internal Interfaces ----------------------------------------\n59: \n60: /**\n61:  * Aggregated statistics from the MPAB chunk-collapse pass.\n62:  */\n63: interface ChunkReassemblyStats {\n64:   /** Number of child chunk rows removed from the result set. */\n65:   collapsedChunkHits: number;\n66:   /** Number of distinct parent IDs encountered among chunk hits. */\n67:   chunkParents: number;\n68:   /** Number of parents whose content was successfully reassembled from DB. */\n69:   reassembled: number;\n70:   /** Number of parents that fell back to using best-chunk content. */\n71:   fallback: number;\n72: }\n73: \n74: /**\n75:  * Internal representation of a chunk group — all chunks belonging\n76:  * to a single parent, ready for collapse and reassembly.\n77:  */\n78: interface ChunkGroup {\n79:   parentId: number;\n80:   chunks: PipelineRow[];\n81:   /** The chunk with the highest similarity/score — the representative row. */\n82:   bestChunk: PipelineRow;\n83:   /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n84:   parentScore: number;\n85: }\n86: \n87: type RerankProvider = 'fallback-sort' | 'none';\n88: \n89: // -- Stage 3 Entry Point ----------------------------------------\n90: \n91: /**\n92:  * Execute Stage 3: Rerank + Aggregate.\n93:  *\n94:  * Applies MMR diversity reranking (when enabled) and then collapses\n95:  * chunked memory hits into their parent documents (MPAB). Stage 3\n96:  * reduces near-duplicate chunks before parent reassembly aggregates\n97:  * the result set.\n98:  *\n99:  * @param input - Stage 3 input containing scored results from Stage 2\n100:  *   and the shared pipeline configuration.\n101:  * @returns Stage 3 output with reranked, aggregated results and metadata.\n102:  */\n103: export async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n104:   const stageStart = Date.now();\n105:   const { scored, config } = input;\n106: \n107:   let results = scored;\n108: \n109:   // -- Step 1: (removed) model-based cross-encoder reranking -----\n110:   // The cross-encoder / local-GGUF reranking layer was removed: it had no\n111:   // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n112:   // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n113:   // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n114:   // These constants preserve the unchanged metadata/envelope shape.\n115:   const rerankApplied = false;\n116:   const rerankProvider: RerankProvider = 'none';\n117: \n118:   // -- Step 2: MMR diversity pruning ----------------------------\n119:   // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n120:   // Vec_memories and applies Maximal Marginal Relevance to diversify\n121:   // The result set, matching the V1 hybrid-search behavior.\n122:   if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n123:     try {\n124:       const db = requireDb() as Database.Database;\n125:       const numericIds = results\n126:         .map(r => r.id)\n127:         .filter((id): id is number => typeof id === 'number');\n128: \n129:       if (numericIds.length >= MMR_MIN_CANDIDATES) {\n130:         const placeholders = numericIds.map(() => '?').join(', ');\n131:         const embRows = (db.prepare(\n132:           `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n133:         ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n134: \n135:         const embeddingMap = new Map<number, Float32Array>();\n136:         for (const row of embRows) {\n137:           if (Buffer.isBuffer(row.embedding)) {\n138:             embeddingMap.set(\n139:               row.rowid,\n140:               new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n141:             );\n142:           }\n143:         }\n144: \n145:         const mmrCandidates: MMRCandidate[] = [];\n146:         for (const r of results) {\n147:           const emb = embeddingMap.get(r.id);\n148:           if (emb) {\n149:             mmrCandidates.push({\n150:               id: r.id,\n151:               // Use effectiveScore() for consistent fallback chain\n152:               score: floorScore(effectiveScore(r)),\n153:               embedding: emb,\n154:             });\n155:           }\n156:         }\n157: \n158:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n159:           const originalPositionMap = new Map<number | string, number>();\n160:           results.forEach((row, index) => originalPositionMap.set(row.id, index));\n161:           const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n162:           const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n163:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n164: \n165:           // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n166:           // rows (lexical-only hits, graph injections) must be preserved and merged\n167:           // back in their original relative order instead of being silently dropped.\n168:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n169:           const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n170: \n171:           // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n172:           const rowMap = new Map<number | string, PipelineRow>();\n173:           for (const r of results) rowMap.set(r.id, r);\n174: \n175:           const diversifiedRows = diversified.map((candidate): PipelineRow => {\n176:             const existing = rowMap.get(candidate.id);\n177:             if (existing) return existing;\n178:             return { id: candidate.id as number, score: candidate.score };\n179:           });\n180: \n181:           const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n182:           diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n183:           nonEmbeddedRows.forEach((row) => {\n184:             const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n185:             positioned.push({ row, pos: originalPosition });\n186:           });\n187: \n188:           positioned.sort((left, right) => left.pos - right.pos);\n189:           results = positioned.map(({ row }) => row);\n190:         }\n191:       }\n192:     } catch (mmrErr: unknown) {\n193:       // Non-critical — MMR failure does not block pipeline\n194:       console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n195:     }\n196:   }\n197: \n198:   // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n199:   //\n200:   // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n201:   // Here in Stage 3 — never move it upstream.\n202:   const mpabStart = Date.now();\n203:   const beforeMpab = results.length;\n204: \n205:   const { results: aggregated, stats: chunkStats } =\n206:     await collapseAndReassembleChunkResults(results);\n207: \n208:   results = aggregated;\n209: \n210:   if (config.trace) {\n211:     addTraceEntry(\n212:       config.trace,\n213:       'final-rank',\n214:       beforeMpab,\n215:       results.length,\n216:       Date.now() - mpabStart,\n217:       {\n218:         collapsedChunkHits: chunkStats.collapsedChunkHits,\n219:         chunkParents: chunkStats.chunkParents,\n220:         reassembled: chunkStats.reassembled,\n221:         fallback: chunkStats.fallback,\n222:       }\n223:     );\n224:   }\n225: \n226:   const metadata = {\n227:     rerankApplied,\n228:     rerankProvider,\n229:     chunkReassemblyStats: chunkStats,\n230:     durationMs: Date.now() - stageStart,\n231:   };\n232: \n233:   return {\n234:     reranked: results,\n235:     metadata,\n236:   };\n237: }\n238: \n239: // -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n240: \n241: /**\n242:  * Collapse chunk-level hits and reassemble parent memory documents.\n243:  *\n244:  * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n245:  *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n246:  *   2. Group chunks by `parent_id`.\n247:  *   3. For each group, elect the best chunk (highest score).\n248:  *   4. Attempt to load the full parent content from the database.\n249:  *   5. If the DB query succeeds, emit a reassembled parent row.\n250:  *   6. If the DB query fails, fall back to the best-chunk content.\n251:  *   7. Merge non-chunks + reassembled parents, sort by score descending.\n252:  *\n253:  * Pipeline position constraint: this function MUST NOT be called before\n254:  * RRF fusion (Stage 2). It is intentionally placed in Stage 3.\n255:  *\n256:  * @param results - Scored pipeline rows from Stage 3.\n257:  * @returns Object with aggregated rows and chunk reassembly statistics.\n258:  */\n259: async function collapseAndReassembleChunkResults(\n260:   results: PipelineRow[]\n261: ): Promise<{ results: PipelineRow[]; stats: ChunkReassemblyStats }> {\n262:   const stats: ChunkReassemblyStats = {\n263:     collapsedChunkHits: 0,\n264:     chunkParents: 0,\n265:     reassembled: 0,\n266:     fallback: 0,\n267:   };\n268: \n269:   // Separate chunks from non-chunks\n270:   const nonChunks: PipelineRow[] = [];\n271:   const chunksByParent = new Map<number, PipelineRow[]>();\n272: \n273:   for (const row of results) {\n274:     const parentId = row.parent_id ?? row.parentId;\n275:     if (parentId != null && typeof parentId === 'number') {\n276:       // This row is a chunk — group by parent\n277:       const group = chunksByParent.get(parentId);\n278:       if (group) {\n279:         group.push(row);\n280:       } else {\n281:         chunksByParent.set(parentId, [row]);\n282:       }\n283:     } else {\n284:       nonChunks.push(row);\n285:     }\n286:   }\n287: \n288:   if (chunksByParent.size === 0) {\n289:     // No chunks to collapse — return results unchanged\n290:     return { results, stats };\n291:   }\n292: \n293:   stats.chunkParents = chunksByParent.size;\n294: \n295:   // Build chunk groups, electing the best chunk for each parent\n296:   const chunkGroups: ChunkGroup[] = [];\n297:   for (const [parentId, chunks] of chunksByParent) {\n298:     const bestChunk = electBestChunk(chunks);\n299:     const bestChunkScore = resolveEffectiveScore(bestChunk);\n300:     const chunkScores = chunks.map(c => resolveEffectiveScore(c));\n301:     const mpabScore = computeMPAB(chunkScores);\n302:     const parentScore = Math.max(mpabScore, bestChunkScore);\n303:     // Sort chunks by chunk_index (document order) for correct reassembly,\n304:     // Not by score order which is the default from upstream stages\n305:     chunks.sort((a, b) => {\n306:       const aIdx = ((a.chunk_index ?? a.chunkIndex) as number | undefined) ?? 0;\n307:       const bIdx = ((b.chunk_index ?? b.chunkIndex) as number | undefined) ?? 0;\n308:       return aIdx - bIdx;\n309:     });\n310:     chunkGroups.push({ parentId, chunks, bestChunk, parentScore });\n311:     // All chunks beyond the best one are collapsed\n312:     stats.collapsedChunkHits += chunks.length - 1;\n313:   }\n314: \n315:   // Attempt DB reassembly for each parent group (in parallel)\n316:   const reassembledRows = await Promise.all(\n317:     chunkGroups.map((group) => reassembleParentRow(group, stats))\n318:   );\n319: \n320:   // Merge non-chunks + reassembled parent rows, deduplicate by id (prefer highest score),\n321:   // Then sort by effective score.\n322:   // Parent rows could appear in both nonChunks and reassembledRows\n323:   // When a parent exists as a standalone row AND has chunk children.\n324:   const mergedMap = new Map<unknown, PipelineRow>();\n325:   for (const row of [...nonChunks, ...reassembledRows]) {\n326:     const existing = mergedMap.get(row.id);\n327:     if (!existing || floorScore(effectiveScore(row)) > floorScore(effectiveScore(existing))) {\n328:       mergedMap.set(row.id, row);\n329:     }\n330:   }\n331:   const merged = sortDeterministicRows(Array.from(mergedMap.values()) as Array<PipelineRow & { id: number }>);\n332: \n333:   return { results: merged, stats };\n334: }\n335: \n336: /**\n337:  * Elect the best representative chunk from a chunk group.\n338:  * Selection criteria: highest `score`, breaking ties by `similarity`.\n339:  *\n340:  * @param chunks - All chunk rows for a single parent.\n341:  * @returns The chunk with the highest effective score.\n342:  */\n343: function electBestChunk(chunks: PipelineRow[]): PipelineRow {\n344:   return chunks.reduce((best, current) => (\n345:     compareDeterministicRows(\n346:       { ...current, score: floorScore(effectiveScore(current)) } as Record<string, unknown> & { id: number },\n347:       { ...best, score: floorScore(effectiveScore(best)) } as Record<string, unknown> & { id: number },\n348:     ) < 0 ? current : best\n349:   ));\n350: }\n351: \n352: /**\n353:  * Compute the effective numeric score for a pipeline row.\n354:  * Checks all score fields in priority order to avoid silently\n355:  * discarding Stage 2 signal enrichment.\n356:  *\n357:  * Fallback chain expanded to include intentAdjustedScore\n358:  * and rrfScore before raw score/similarity, matching Stage 2's\n359:  * resolveBaseScore() pattern for defensive correctness.\n360:  *\n361:  * @param row - A pipeline result row.\n362:  * @returns Numeric score value in [0, 1] for comparison.\n363:  */\n364: // Replaced local implementation with\n365: // Shared resolveEffectiveScore() from types.ts for consistency with Stage 2.\n366: const effectiveScore = resolveEffectiveScore;\n367: \n368: /**\n369:  * Attempt to reassemble a full parent memory row from the database.\n370:  *\n371:  * On success, returns a PipelineRow that merges:\n372:  *   - All best-chunk fields as the base\n373:  *   - Parent-level content from the DB (if available)\n374:  *   - `contentSource: 'reassembled_chunks'` to mark provenance\n375:  *\n376:  * On failure, returns the best-chunk row with\n377:  *   `contentSource: 'file_read_fallback'`.\n378:  *\n379:  * @param group  - The chunk group (parentId + chunks + bestChunk).\n380:  * @param stats  - Mutable stats object updated in place.\n381:  * @returns A PipelineRow representing the parent document.\n382:  */\n383: async function reassembleParentRow(\n384:   group: ChunkGroup,\n385:   stats: ChunkReassemblyStats\n386: ): Promise<PipelineRow> {\n387:   const { parentId, bestChunk, parentScore } = group;\n388: \n389:   try {\n390:     const db = requireDb();\n391: \n392:     // Query the parent memory row for content and metadata\n393:     const parentRow = db\n394:       .prepare(\n395:         `SELECT id, file_path, content_text, importance_tier, importance_weight,\n396:                 quality_score, created_at, context_type\n397:          FROM memory_index\n398:          WHERE id = ?\n399:          LIMIT 1`\n400:       )\n401:       .get(parentId) as Record<string, unknown> | undefined;\n402: \n403:     if (!parentRow) {\n404:       // Parent not found in DB — use best chunk as fallback\n405:       stats.fallback++;\n406:       return markFallback(bestChunk, parentScore);\n407:     }\n408: \n409:     const reassembledContent =\n410:       (parentRow.content_text as string | undefined) ?? bestChunk.content;\n411: \n412:     // Merge parent metadata onto the best-chunk base row\n413:     const reassembled: PipelineRow = {\n414:       ...bestChunk,\n415:       // Override identity fields with parent values\n416:       id: parentId,\n417:       file_path: (parentRow.file_path as string | undefined) ?? bestChunk.file_path,\n418:       importance_tier: (parentRow.importance_tier as string | undefined) ?? bestChunk.importance_tier,\n419:       importance_weight: (parentRow.importance_weight as number | undefined) ?? bestChunk.importance_weight,\n420:       quality_score: (parentRow.quality_score as number | undefined) ?? bestChunk.quality_score,\n421:       created_at: (parentRow.created_at as string | undefined) ?? bestChunk.created_at,\n422:       context_type: (parentRow.context_type as string | undefined) ?? bestChunk.context_type,\n423:       // FIX #8: Sync content with precomputedContent after reassembly.\n424:       // Previously, `content` still had the chunk fragment while\n425:       // `precomputedContent` had the full reassembled parent text.\n426:       content: reassembledContent,\n427:       precomputedContent: reassembledContent,\n428:       contentSource: 'reassembled_chunks',\n429:       score: parentScore,\n430:       rrfScore: parentScore,\n431:       intentAdjustedScore: parentScore,\n432:       // Clear chunk-specific fields on the reassembled parent\n433:       parent_id: null,\n434:       parentId: null,\n435:       chunk_index: null,\n436:       chunkIndex: null,\n437:       chunk_label: null,\n438:       chunkLabel: null,\n439:       isChunk: false,\n440:     };\n441: \n442:     stats.reassembled++;\n443:     return reassembled;\n444:   } catch (err: unknown) {\n445:     // DB error — gracefully fall back to best-chunk content\n446:     console.warn(\n447:       `[stage3-rerank] MPAB DB reassembly failed for parent ${parentId}: ${toErrorMessage(err)} — using chunk fallback`\n448:     );\n449:     stats.fallback++;\n450:     return markFallback(bestChunk, parentScore);\n451:   }\n452: }\n453: \n454: /**\n455:  * Mark a pipeline row as a chunk-content fallback.\n456:  * Clears chunk-specific identity fields and marks the content source.\n457:  *\n458:  * @param chunk - The elected best-chunk row.\n459:  * @param parentScore - Parent-level score after MPAB aggregation.\n460:  * @returns A new PipelineRow annotated as a fallback parent representation.\n461:  */\n462: function markFallback(chunk: PipelineRow, parentScore: number): PipelineRow {\n463:   const parentId =\n464:     chunk.parent_id ??\n465:     chunk.parentId ??\n466:     (chunk as { parentMemoryId?: number | null }).parentMemoryId ??\n467:     chunk.id;\n468: \n469:   return {\n470:     ...chunk,\n471:     id: parentId,\n472:     contentSource: 'file_read_fallback',\n473:     score: parentScore,\n474:     rrfScore: parentScore,\n475:     intentAdjustedScore: parentScore,\n476:     // Promote chunk to parent-level identity by clearing chunk markers\n477:     parent_id: null,\n478:     parentId: null,\n479:     chunk_index: undefined,\n480:     chunkIndex: undefined,\n481:     chunk_label: null,\n482:     chunkLabel: null,\n483:     isChunk: false,\n484:     is_chunk: false,\n485:   };\n486: }\n487: \n488: // -- Test Exports -----------------------------------------------\n489: \n490: /**\n491:  * Internal functions exported for unit testing.\n492:  * Do not rely on these in production code — the API is not stable.\n493:  *\n494:  * @internal\n495:  */\n496: export const __testables = {\n497:   collapseAndReassembleChunkResults,\n498:   electBestChunk,\n499:   effectiveScore,\n500:   reassembleParentRow,\n501:   markFallback,\n502: };\n\n(End of file - total 502 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage3 Rerank\n// ───────────────────────────────────────────────────────────────\n// 4-Stage Retrieval Pipeline: Stage 3 of 4\n//\n// Responsibilities (in execution order):\n// 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n// 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n//\n// Pipeline position constraint:\n// MPAB MUST remain AFTER RRF fusion (Stage 2).\n// Stage 3 is the only stage that may change scores after Stage 2.\n//\n// I/O CONTRACT:\n// Input:  Stage3Input { scored: PipelineRow[], config }\n// Output: Stage3Output { reranked: PipelineRow[], metadata }\n// Key invariants:\n//     - reranked is sorted descending by effective score after all steps\n//     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n//     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage3 Rerank\n// ───────────────────────────────────────────────────────────────\n// 4-Stage Retrieval Pipeline: Stage 3 of 4\n//\n// Responsibilities (in execution order):\n// 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n// 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n//\n// Pipeline position constraint:\n// MPAB MUST remain AFTER RRF fusion (Stage 2).\n// Stage 3 is the only stage that may change scores after Stage 2.\n//\n// I/O CONTRACT:\n// Input:  Stage3Input { scored: PipelineRow[], config }\n// Output: Stage3Output { reranked: PipelineRow[], metadata }\n// Key invariants:\n//     - reranked is sorted descending by effective score after all steps\n//     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n//     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'\n// Side effects:\n//     - DB reads to fetch parent content during MPAB reassembly\n//\n// Score changes: YES\n\nimport { resolveEffectiveScore } from './types.js';\nimport type { Stage3Input, Stage3Output, PipelineRow } from './types.js';\nimport { isMMREnabled } from '../search-flags.js';\nimport { computeMPAB } from '../../scoring/mpab-aggregation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP } from '../intent-classifier.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/index.js';\nimport { toErrorMessage } from '../../../utils/index.js';\nimport type Database from 'better-sqlite3';\nimport { compareDeterministicRows, sortDeterministicRows } from './ranking-contract.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Hybrid search pipeline\n\n\n// -- Constants --------------------------------------------------\n\n/** Minimum number of candidates required before MMR diversity pruning is worthwhile. */\nconst MMR_MIN_CANDIDATES = 2;\n\n/** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\nconst MMR_DEFAULT_LAMBDA = 0.7;\n\n/**\n * Enforce non-negative score outputs at Stage 3 boundaries.\n */\nfunction floorScore(value: number): number {\n  return Math.max(0, value);\n}\n\n// -- Internal Interfaces ----------------------------------------\n\n/**\n * Aggregated statistics from the MPAB chunk-collapse pass.\n */\ninterface ChunkReassemblyStats {\n  /** Number of child chunk rows removed from the result set. */\n  collapsedChunkHits: number;\n  /** Number of distinct parent IDs encountered among chunk hits. */\n  chunkParents: number;\n  /** Number of parents whose content was successfully reassembled from DB. */\n  reassembled: number;\n  /** Number of parents that fell back to using best-chunk content. */\n  fallback: number;\n}\n\n/**\n * Internal representation of a chunk group — all chunks belonging\n * to a single parent, ready for collapse and reassembly.\n */\ninterface ChunkGroup {\n  parentId: number;\n  chunks: PipelineRow[];\n  /** The chunk with the highest similarity/score — the representative row. */\n  bestChunk: PipelineRow;\n  /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n  parentScore: number;\n}\n\ntype RerankProvider = 'fallback-sort' | 'none';\n\n// -- Stage 3 Entry Point ----------------------------------------\n\n/**\n * Execute Stage 3: Rerank + Aggregate.\n *\n * Applies MMR diversity reranking (when enabled) and then collapses\n * chunked memory hits into their parent documents (MPAB). Stage 3\n * reduces near-duplicate chunks before parent reassembly aggregates\n * the result set.\n *\n * @param input - Stage 3 input containing scored results from Stage 2\n *   and the shared pipeline configuration.\n * @returns Stage 3 output with reranked, aggregated results and metadata.\n */\nexport async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n  const stageStart = Date.now();\n  const { scored, config } = input;\n\n  let results = scored;\n\n  // -- Step 1: (removed) model-based cross-encoder reranking -----\n  // The cross-encoder / local-GGUF reranking layer was removed: it had no\n  // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n  // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n  // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n  // These constants preserve the unchanged metadata/envelope shape.\n  const rerankApplied = false;\n  const rerankProvider: RerankProvider = 'none';\n\n  // -- Step 2: MMR diversity pruning ----------------------------\n  // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n  // Vec_memories and applies Maximal Marginal Relevance to diversify\n  // The result set, matching the V1 hybrid-search behavior.\n  if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n    try {\n      const db = requireDb() as Database.Database;\n      const numericIds = results\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length >= MMR_MIN_CANDIDATES) {\n        const placeholders = numericIds.map(() => '?').join(', ');\n        const embRows = (db.prepare(\n          `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n        ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n        const embeddingMap = new Map<number, Float32Array>();\n        for (const row of embRows) {\n          if (Buffer.isBuffer(row.embedding)) {\n            embeddingMap.set(\n              row.rowid,\n              new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n            );\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of results) {\n          const emb = embeddingMap.get(r.id);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id,\n              // Use effectiveScore() for consistent fallback chain\n              score: floorScore(effectiveScore(r)),\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const originalPositionMap = new Map<number | string, number>();\n          results.forEach((row, index) => originalPositionMap.set(row.id, index));\n          const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n          const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n\n          // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n          // rows (lexical-only hits, graph injections) must be preserved and merged\n          // back in their original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n\n          // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n          const rowMap = new Map<number | string, PipelineRow>();\n          for (const r of results) rowMap.set(r.id, r);\n\n          const diversifiedRows = diversified.map((candidate): PipelineRow => {\n            const existing = rowMap.get(candidate.id);\n            if (existing) return existing;\n            return { id: candidate.id as number, score: candidate.score };\n          });\n\n          const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n          diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n          nonEmbeddedRows.forEach((row) => {\n            const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n            positioned.push({ row, pos: originalPosition });\n          });\n\n          positioned.sort((left, right) => left.pos - right.pos);\n          results = positioned.map(({ row }) => row);\n        }\n      }\n    } catch (mmrErr: unknown) {\n      // Non-critical — MMR failure does not block pipeline\n      console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n    }\n  }\n\n  // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n  //\n  // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n  // Here in Stage 3 — never move it upstream.\n  const mpabStart = Date.now();\n  const beforeMpab = results.length;\n\n  const { results: aggregated, stats: chunkStats } =\n    await collapseAndReassembleChunkResults(results);\n\n  results = aggregated;\n\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'final-rank',\n      beforeMpab,\n      results.length,\n      Date.now() - mpabStart,\n      {\n        collapsedChunkHits: chunkStats.collapsedChunkHits,\n        chunkParents: chunkStats.chunkParents,\n        reassembled: chunkStats.reassembled,\n        fallback: chunkStats.fallback,\n      }\n    );\n  }\n\n  const metadata = {\n    rerankApplied,\n    rerankProvider,\n    chunkReassemblyStats: chunkStats,\n    durationMs: Date.now() - stageStart,\n  };\n\n  return {\n    reranked: results,\n    metadata,\n  };\n}\n\n// -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n\n/**\n * Collapse chunk-level hits and reassemble parent memory documents.\n *\n * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n *   2. Group chunks by `parent_id`.\n *   3. For each group, elect the best chunk (highest score).\n *   4. Attempt to load the full parent content from the database.\n *   5. If the DB query succeeds, emit a reassembled parent row.\n *   6. If the DB query fails, fall back to the best-chunk content.\n *   7. Merge non-chunks + reassembled parents, sort by score descending.\n *\n * Pipeline position constraint: this function MUST NOT be called before\n * RRF fusion (Stage 2). It is intentionally placed in Stage 3.\n *\n * @param results - Scored pipeline rows from Stage 3.\n * @returns Object with aggregated rows and chunk reassembly statistics.\n */\nasync function collapseAndReassembleChunkResults(\n  results: PipelineRow[]\n): Promise<{ results: PipelineRow[]; stats: ChunkReassemblyStats }> {\n  const stats: ChunkReassemblyStats = {\n    collapsedChunkHits: 0,\n    chunkParents: 0,\n    reassembled: 0,\n    fallback: 0,\n  };\n\n  // Separate chunks from non-chunks\n  const nonChunks: PipelineRow[] = [];\n  const chunksByParent = new Map<number, PipelineRow[]>();\n\n  for (const row of results) {\n    const parentId = row.parent_id ?? row.parentId;\n    if (parentId != null && typeof parentId === 'number') {\n      // This row is a chunk — group by parent\n      const group = chunksByParent.get(parentId);\n      if (group) {\n        group.push(row);\n      } else {\n        chunksByParent.set(parentId, [row]);\n      }\n    } else {\n      nonChunks.push(row);\n    }\n  }\n\n  if (chunksByParent.size === 0) {\n    // No chunks to collapse — return results unchanged\n    return { results, stats };\n  }\n\n  stats.chunkParents = chunksByParent.size;\n\n  // Build chunk groups, electing the best chunk for each parent\n  const chunkGroups: ChunkGroup[] = [];\n  for (const [parentId, chunks] of chunksByParent) {\n    const bestChunk = electBestChunk(chunks);\n    const bestChunkScore = resolveEffectiveScore(bestChunk);\n    const chunkScores = chunks.map(c => resolveEffectiveScore(c));\n    const mpabScore = computeMPAB(chunkScores);\n    const parentScore = Math.max(mpabScore, bestChunkScore);\n    // Sort chunks by chunk_index (document order) for correct reassembly,\n    // Not by score order which is the default from upstream stages\n    chunks.sort((a, b) => {\n      const aIdx = ((a.chunk_index ?? a.chunkIndex) as number | undefined) ?? 0;\n      const bIdx = ((b.chunk_index ?? b.chunkIndex) as number | undefined) ?? 0;\n      return aIdx - bIdx;\n    });\n    chunkGroups.push({ parentId, chunks, bestChunk, parentScore });\n    // All chunks beyond the best one are collapsed\n    stats.collapsedChunkHits += chunks.length - 1;\n  }\n\n  // Attempt DB reassembly for each parent group (in parallel)\n  const reassembledRows = await Promise.all(\n    chunkGroups.map((group) => reassembleParentRow(group, stats))\n  );\n\n  // Merge non-chunks + reassembled parent rows, deduplicate by id (prefer highest score),\n  // Then sort by effective score.\n  // Parent rows could appear in both nonChunks and reassembledRows\n  // When a parent exists as a standalone row AND has chunk children.\n  const mergedMap = new Map<unknown, PipelineRow>();\n  for (const row of [...nonChunks, ...reassembledRows]) {\n    const existing = mergedMap.get(row.id);\n    if (!existing || floorScore(effectiveScore(row)) > floorScore(effectiveScore(existing))) {\n      mergedMap.set(row.id, row);\n    }\n  }\n  const merged = sortDeterministicRows(Array.from(mergedMap.values()) as Array<PipelineRow & { id: number }>);\n\n  return { results: merged, stats };\n}\n\n/**\n * Elect the best representative chunk from a chunk group.\n * Selection criteria: highest `score`, breaking ties by `similarity`.\n *\n * @param chunks - All chunk rows for a single parent.\n * @returns The chunk with the highest effective score.\n */\nfunction electBestChunk(chunks: PipelineRow[]): PipelineRow {\n  return chunks.reduce((best, current) => (\n    compareDeterministicRows(\n      { ...current, score: floorScore(effectiveScore(current)) } as Record<string, unknown> & { id: number },\n      { ...best, score: floorScore(effectiveScore(best)) } as Record<string, unknown> & { id: number },\n    ) < 0 ? current : best\n  ));\n}\n\n/**\n * Compute the effective numeric score for a pipeline row.\n * Checks all score fields in priority order to avoid silently\n * discarding Stage 2 signal enrichment.\n *\n * Fallback chain expanded to include intentAdjustedScore\n * and rrfScore before raw score/similarity, matching Stage 2's\n * resolveBaseScore() pattern for defensive correctness.\n *\n * @param row - A pipeline result row.\n * @returns Numeric score value in [0, 1] for comparison.\n */\n// Replaced local implementation with\n// Shared resolveEffectiveScore() from types.ts for consistency with Stage 2.\nconst effectiveScore = resolveEffectiveScore;\n\n/**\n * Attempt to reassemble a full parent memory row from the database.\n *\n * On success, returns a PipelineRow that merges:\n *   - All best-chunk fields as the base\n *   - Parent-level content from the DB (if available)\n *   - `contentSource: 'reassembled_chunks'` to mark provenance\n *\n * On failure, returns the best-chunk row with\n *   `contentSource: 'file_read_fallback'`.\n *\n * @param group  - The chunk group (parentId + chunks + bestChunk).\n * @param stats  - Mutable stats object updated in place.\n * @returns A PipelineRow representing the parent document.\n */\nasync function reassembleParentRow(\n  group: ChunkGroup,\n  stats: ChunkReassemblyStats\n): Promise<PipelineRow> {\n  const { parentId, bestChunk, parentScore } = group;\n\n  try {\n    const db = requireDb();\n\n    // Query the parent memory row for content and metadata\n    const parentRow = db\n      .prepare(\n        `SELECT id, file_path, content_text, importance_tier, importance_weight,\n                quality_score, created_at, context_type\n         FROM memory_index\n         WHERE id = ?\n         LIMIT 1`\n      )\n      .get(parentId) as Record<string, unknown> | undefined;\n\n    if (!parentRow) {\n      // Parent not found in DB — use best chunk as fallback\n      stats.fallback++;\n      return markFallback(bestChunk, parentScore);\n    }\n\n    const reassembledContent =\n      (parentRow.content_text as string | undefined) ?? bestChunk.content;\n\n    // Merge parent metadata onto the best-chunk base row\n    const reassembled: PipelineRow = {\n      ...bestChunk,\n      // Override identity fields with parent values\n      id: parentId,\n      file_path: (parentRow.file_path as string | undefined) ?? bestChunk.file_path,\n      importance_tier: (parentRow.importance_tier as string | undefined) ?? bestChunk.importance_tier,\n      importance_weight: (parentRow.importance_weight as number | undefined) ?? bestChunk.importance_weight,\n      quality_score: (parentRow.quality_score as number | undefined) ?? bestChunk.quality_score,\n      created_at: (parentRow.created_at as string | undefined) ?? bestChunk.created_at,\n      context_type: (parentRow.context_type as string | undefined) ?? bestChunk.context_type,\n      // FIX #8: Sync content with precomputedContent after reassembly.\n      // Previously, `content` still had the chunk fragment while\n      // `precomputedContent` had the full reassembled parent text.\n      content: reassembledContent,\n      precomputedContent: reassembledContent,\n      contentSource: 'reassembled_chunks',\n      score: parentScore,\n      rrfScore: parentScore,\n      intentAdjustedScore: parentScore,\n      // Clear chunk-specific fields on the reassembled parent\n      parent_id: null,\n      parentId: null,\n      chunk_index: null,\n      chunkIndex: null,\n      chunk_label: null,\n      chunkLabel: null,\n      isChunk: false,\n    };\n\n    stats.reassembled++;\n    return reassembled;\n  } catch (err: unknown) {\n    // DB error — gracefully fall back to best-chunk content\n    console.warn(\n      `[stage3-rerank] MPAB DB reassembly failed for parent ${parentId}: ${toErrorMessage(err)} — using chunk fallback`\n    );\n    stats.fallback++;\n    return markFallback(bestChunk, parentScore);\n  }\n}\n\n/**\n * Mark a pipeline row as a chunk-content fallback.\n * Clears chunk-specific identity fields and marks the content source.\n *\n * @param chunk - The elected best-chunk row.\n * @param parentScore - Parent-level score after MPAB aggregation.\n * @returns A new PipelineRow annotated as a fallback parent representation.\n */\nfunction markFallback(chunk: PipelineRow, parentScore: number): PipelineRow {\n  const parentId =\n    chunk.parent_id ??\n    chunk.parentId ??\n    (chunk as { parentMemoryId?: number | null }).parentMemoryId ??\n    chunk.id;\n\n  return {\n    ...chunk,\n    id: parentId,\n    contentSource: 'file_read_fallback',\n    score: parentScore,\n    rrfScore: parentScore,\n    intentAdjustedScore: parentScore,\n    // Promote chunk to parent-level identity by clearing chunk markers\n    parent_id: null,\n    parentId: null,\n    chunk_index: undefined,\n    chunkIndex: undefined,\n    chunk_label: null,\n    chunkLabel: null,\n    isChunk: false,\n    is_chunk: false,\n  };\n}\n\n// -- Test Exports -----------------------------------------------\n\n/**\n * Internal functions exported for unit testing.\n * Do not rely on these in production code — the API is not stable.\n *\n * @internal\n */\nexport const __testables = {\n  collapseAndReassembleChunkResults,\n  electBestChunk,\n  effectiveScore,\n  reassembleParentRow,\n  markFallback,\n};","lineStart":1,"lineEnd":502,"totalLines":502,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","time":{"start":1781763821886,"end":1781763821890}},"metadata":{"openai":{"itemId":"fc_032f0ebce80c21f6016a338eeda8ec8191b901f575430ff189"}},"id":"prt_ed9665139001j5KGRu4zphUs0K","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed9662a5e001wM1Gv8zISlQ0Sc"}}
{"type":"tool_use","timestamp":1781763821905,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_BG3zcl2fwQXlrSdiQI7S7xBA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage4 Filter\n3: // ───────────────────────────────────────────────────────────────\n4: // Final stage of the 4-stage retrieval pipeline.\n5: //\n6: // ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n7: // Any ordering change after Stage 3 is a bug. Score fields on\n8: // Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n9: // Via captureScoreSnapshot / verifyScoreInvariant provides a second\n10: // Defence-in-depth layer.\n11: //\n12: // I/O CONTRACT:\n13: // Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n14: // Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n15: // Key invariants:\n16: //     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n17: // AttentionScore, importance_weight) may change between input and output\n18: //     - Ordering from Stage 3 is preserved for all surviving rows\n19: //     - final contains only rows at or above config.minState priority\n20: // Side effects:\n21: //     - None — this stage is read-only with respect to the database\n22: //\n23: // FILTER APPLICATION ORDER (within filterByMemoryState):\n24: // 1. memoryState priority filter — rows below minState are removed\n25: // 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n26: //\n27: // Responsibilities (in execution order):\n28: // 1. Capture score snapshot BEFORE any operations (runtime invariant)\n29: // 2. Apply memory-state filtering (filterByMemoryState)\n30: // 3. Apply evidence gap detection via TRM (Z-score confidence check)\n31: // 4. Add annotation metadata (feature flags, state stats, etc.)\n32: // 5. Verify score invariant AFTER all operations\n33: //\n34: // NOT in Stage 4: session dedup — that happens after cache in the\n35: // Main handler to avoid double-counting and cache pollution.\n36: \n37: import type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\n38: import { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\n39: import { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\n40: import { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\n41: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n42: \n43: // Feature catalog: 4-stage pipeline architecture\n44: // Feature catalog: Confidence-based result truncation\n45: \n46: \n47: // ───────────────────────────────────────────────────────────────\n48: // 2. CONSTANTS\n49: \n50: \n51: // ───────────────────────────────────────────────────────────────\n52: /**\n53:  * Memory state priority map. Higher number = higher priority.\n54:  * Used to compare states numerically so filtering is O(1) per row.\n55:  */\n56: const STATE_PRIORITY: Record<string, number> = {\n57:   HOT: 5,\n58:   WARM: 4,\n59:   COLD: 3,\n60:   DORMANT: 2,\n61:   ARCHIVED: 1,\n62: };\n63: \n64: /**\n65:  * Per-tier hard limits applied when `applyStateLimits` is true.\n66:  * Prevents any single tier from monopolising the result window.\n67:  */\n68: export const STATE_LIMITS: Record<string, number> = {\n69:   HOT: 50,\n70:   WARM: 30,\n71:   COLD: 20,\n72:   DORMANT: 10,\n73:   ARCHIVED: 5,\n74: };\n75: \n76: /** Fallback priority for unknown/missing memoryState values.\n77:  * Set above HOT (5) so UNKNOWN memories always pass state filters.\n78:  * memoryState column doesn't exist yet — all memories are UNKNOWN.\n79:  * Reset to 0 when the TRM state column is implemented. */\n80: const UNKNOWN_STATE_PRIORITY = 6;\n81: \n82: function normalizeStateValue(state: unknown): string | null {\n83:   if (typeof state !== 'string') {\n84:     return null;\n85:   }\n86:   const normalizedState = state.toUpperCase();\n87:   return normalizedState in STATE_PRIORITY ? normalizedState : null;\n88: }\n89: \n90: function resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n91:   const explicitState = normalizeStateValue(row.memoryState);\n92:   if (explicitState) {\n93:     return explicitState;\n94:   }\n95: \n96:   return 'UNKNOWN';\n97: }\n98: \n99: // ───────────────────────────────────────────────────────────────\n100: // 3. TYPES\n101: \n102: \n103: // ───────────────────────────────────────────────────────────────\n104: /**\n105:  * Per-state tally produced by `filterByMemoryState`.\n106:  * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n107:  */\n108: export type StateStats = Record<string, number>;\n109: \n110: /**\n111:  * Return value of the internal `filterByMemoryState` function.\n112:  */\n113: export interface FilterResult {\n114:   /** Rows that survived state filtering, in original order. */\n115:   filtered: Stage4ReadonlyRow[];\n116:   /** Pre-filter per-state counts (includes removed rows). */\n117:   statsBefore: StateStats;\n118:   /** Post-filter per-state counts. */\n119:   statsAfter: StateStats;\n120:   /** Total number of rows removed. */\n121:   removedCount: number;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    3. INTERNAL: filterByMemoryState\n126:    ──────────────────────────────────────────────────────────────── */\n127: \n128: /**\n129:  * Remove rows whose `memoryState` falls below `minState` priority and,\n130:  * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n131:  *\n132:  * IMPORTANT: This function ONLY removes items — it never reorders or\n133:  * modifies score fields. The original ordering from Stage 3 is preserved\n134:  * for all rows that survive.\n135:  *\n136:  * @param results        - Read-only rows from Stage 3 output.\n137:  * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n138:  * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n139:  * @returns FilterResult with the surviving rows and before/after stats.\n140:  */\n141: export function filterByMemoryState(\n142:   results: Stage4ReadonlyRow[],\n143:   minState: string,\n144:   applyStateLimits: boolean,\n145: ): FilterResult {\n146:   const normalizedMinState = normalizeStateValue(minState);\n147:   const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n148: \n149:   // -- 3a. Tally states before filtering --\n150:   const statsBefore: StateStats = {};\n151:   for (const row of results) {\n152:     const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n153:     statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n154:   }\n155: \n156:   // -- 3b. State-priority filter --\n157:   let passing = results.filter(row => {\n158:     const state = resolveStateForFiltering(row);\n159:     const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n160:     return priority >= minPriority;\n161:   });\n162: \n163:   // -- 3c. Per-tier limits (optional) --\n164:   if (applyStateLimits) {\n165:     const tierCounters: Record<string, number> = {};\n166:     const limitPassing: Stage4ReadonlyRow[] = [];\n167: \n168:     for (const row of passing) {\n169:       const state = resolveStateForFiltering(row);\n170:       const limit = STATE_LIMITS[state] ?? Infinity;\n171:       const count = tierCounters[state] ?? 0;\n172: \n173:       if (count < limit) {\n174:         tierCounters[state] = count + 1;\n175:         limitPassing.push(row);\n176:       }\n177:       // Rows exceeding the per-tier limit are silently dropped (no score change).\n178:     }\n179: \n180:     passing = limitPassing;\n181:   }\n182: \n183:   // -- 3d. Tally states after filtering --\n184:   const statsAfter: StateStats = {};\n185:   for (const row of passing) {\n186:     const state = resolveStateForFiltering(row);\n187:     statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n188:   }\n189: \n190:   return {\n191:     filtered: passing,\n192:     statsBefore,\n193:     statsAfter,\n194:     removedCount: results.length - passing.length,\n195:   };\n196: }\n197: \n198: /* ───────────────────────────────────────────────────────────────\n199:    4. INTERNAL: extractScoringValues\n200:    ──────────────────────────────────────────────────────────────── */\n201: \n202: /**\n203:  * Extract the best available numeric score from a row for evidence-gap\n204:  * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n205:  * so scoring, sorting, and filtering all agree on precedence and normalization.\n206:  *\n207:  * A1 FIX: Previously used a different precedence order (rrfScore first) and\n208:  * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n209:  * that only had the similarity field set.\n210:  *\n211:  * @param row - A Stage4ReadonlyRow to inspect.\n212:  * @returns The best available numeric score clamped to [0,1], or 0.\n213:  */\n214: export function extractScoringValue(row: Stage4ReadonlyRow): number {\n215:   return resolveEffectiveScore(row as unknown as PipelineRow);\n216: }\n217: \n218: /* ───────────────────────────────────────────────────────────────\n219:    5. MAIN: executeStage4\n220:    ──────────────────────────────────────────────────────────────── */\n221: \n222: /**\n223:  * Execute Stage 4 of the 4-stage retrieval pipeline: Filter + Annotate.\n224:  *\n225:  * Stage 4 is the final pipeline stage. It removes results that fall below\n226:  * the configured minimum memory state, runs the Transparent Reasoning Module\n227:  * (TRM) evidence-gap check, attaches annotation metadata, and verifies the\n228:  * score invariant before returning.\n229:  *\n230:  * **Score invariant:** No score fields are modified in Stage 4. The compile-time\n231:  * guarantee is enforced via Stage4ReadonlyRow readonly fields; the runtime check\n232:  * via captureScoreSnapshot / verifyScoreInvariant provides defence-in-depth. If\n233:  * verifyScoreInvariant throws, it indicates a Stage 4 implementation bug.\n234:  *\n235:  * **Session dedup:** Session deduplication is intentionally NOT performed here.\n236:  * It happens after the cache layer in the main handler to avoid cache pollution.\n237:  *\n238:  * @param input - Stage4Input containing read-only results and pipeline config.\n239:  * @returns Stage4Output with filtered/annotated results and metadata.\n240:  * @throws Error if verifyScoreInvariant detects any score mutation (Stage 4 bug).\n241:  */\n242: export async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n243:   const stageStart = Date.now();\n244:   const { results, config } = input;\n245: \n246:   // -- Step 1: Capture score snapshot (runtime invariant) --\n247:   //\n248:   // This snapshot is the source-of-truth for the \"no score changes\" assertion.\n249:   // It is taken over the FULL input set BEFORE any operations, so rows that\n250:   // Are subsequently filtered out are still in the before-snapshot. The\n251:   // VerifyScoreInvariant call skips rows not present in the after-set.\n252:   const scoresBefore = captureScoreSnapshot(results);\n253: \n254:   // -- Step 2: State filtering --\n255:   const filterResult = filterByMemoryState(\n256:     results,\n257:     config.minState,\n258:     config.applyStateLimits,\n259:   );\n260: \n261:   let workingResults: Stage4ReadonlyRow[] = filterResult.filtered;\n262:   const stateFiltered = filterResult.removedCount;\n263: \n264:   // -- Step 3: Evidence gap detection (TRM) --\n265:   let evidenceGapDetected = false;\n266:   let evidenceGapWarning: string | undefined;\n267: \n268:   if (isTRMEnabled()) {\n269:     const scores = workingResults.map(extractScoringValue);\n270:     const trm = detectEvidenceGap(scores);\n271: \n272:     evidenceGapDetected = trm.gapDetected;\n273: \n274:     if (trm.gapDetected) {\n275:       evidenceGapWarning = formatEvidenceGapWarning(trm);\n276: \n277:       // Annotate each result with the gap metadata (non-score field).\n278:       workingResults = workingResults.map(row => ({\n279:         ...row,\n280:         evidenceGap: { gapDetected: true, warning: evidenceGapWarning },\n281:       }));\n282:     }\n283:   }\n284: \n285:   // -- Step 4: Build annotation metadata --\n286:   const featureFlags: Record<string, boolean> = {\n287:     trmEnabled: isTRMEnabled(),\n288:     multiQueryEnabled: isMultiQueryEnabled(),\n289:     stateLimitsApplied: config.applyStateLimits,\n290:   };\n291: \n292:   const stateStats: Record<string, unknown> = {\n293:     minState: config.minState,\n294:     before: filterResult.statsBefore,\n295:     after: filterResult.statsAfter,\n296:     removed: stateFiltered,\n297:   };\n298: \n299:   const annotations: Stage4Output['annotations'] = {\n300:     evidenceGapWarning,\n301:     stateStats,\n302:     featureFlags,\n303:   };\n304: \n305:   // -- Step 4b: Final limit cap --\n306:   // Enforce caller's limit after all filtering to prevent degraded paths exceeding requested count\n307:   if (typeof config.limit === 'number' && config.limit > 0 && workingResults.length > config.limit) {\n308:     workingResults = workingResults.slice(0, config.limit);\n309:   }\n310: \n311:   // -- Step 5: Verify score invariant (defence-in-depth) --\n312:   //\n313:   // VerifyScoreInvariant checks every row that survived filtering.\n314:   // Rows removed by filterByMemoryState are absent from workingResults,\n315:   // So the function correctly skips them (see types.ts implementation).\n316:   // Throws [Stage4Invariant] Error if any score field was mutated.\n317:   verifyScoreInvariant(scoresBefore, workingResults);\n318: \n319:   const durationMs = Date.now() - stageStart;\n320: \n321:   // -- Trace entry --\n322:   if (config.trace) {\n323:     addTraceEntry(\n324:       config.trace,\n325:       'filter',\n326:       results.length,\n327:       workingResults.length,\n328:       durationMs,\n329:       {\n330:         stateFiltered,\n331:         evidenceGapDetected,\n332:         trmEnabled: isTRMEnabled(),\n333:         applyStateLimits: config.applyStateLimits,\n334:         minState: config.minState,\n335:       },\n336:     );\n337:   }\n338: \n339:   return {\n340:     final: workingResults,\n341:     metadata: {\n342:       stateFiltered,\n343:       // sessionDeduped removed; dedup is post-cache in main handler\n344:       // constitutionalInjected passed from Stage 1 metadata\n345:       constitutionalInjected: input.stage1Metadata?.constitutionalInjected ?? 0,\n346:       evidenceGapDetected,\n347:       durationMs,\n348:     },\n349:     annotations,\n350:   };\n351: }\n352: \n353: // ───────────────────────────────────────────────────────────────\n354: // 4. TEST SURFACE\n355: \n356: \n357: // ───────────────────────────────────────────────────────────────\n358: /**\n359:  * Exported internals for unit testing.\n360:  * Not intended for production use outside the test harness.\n361:  */\n362: export const __testables = {\n363:   filterByMemoryState,\n364:   resolveStateForFiltering,\n365:   normalizeStateValue,\n366:   extractScoringValue,\n367:   STATE_PRIORITY,\n368:   STATE_LIMITS,\n369:   UNKNOWN_STATE_PRIORITY,\n370: } as const;\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:\n//     - None — this stage is read-only with respect to the database\n//\n// FILTER APPLICATION ORDER (within filterByMemoryState):\n// 1. memoryState priority filter — rows below minState are removed\n// 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n//\n// Responsibilities (in execution order):\n// 1. Capture score snapshot BEFORE any operations (runtime invariant)\n// 2. Apply memory-state filtering (filterByMemoryState)\n// 3. Apply evidence gap detection via TRM (Z-score confidence check)\n// 4. Add annotation metadata (feature flags, state stats, etc.)\n// 5. Verify score invariant AFTER all operations\n//\n// NOT in Stage 4: session dedup — that happens after cache in the\n// Main handler to avoid double-counting and cache pollution.\n\nimport type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\nimport { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\nimport { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\nimport { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Confidence-based result truncation\n\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Memory state priority map. Higher number = higher priority.\n * Used to compare states numerically so filtering is O(1) per row.\n */\nconst STATE_PRIORITY: Record<string, number> = {\n  HOT: 5,\n  WARM: 4,\n  COLD: 3,\n  DORMANT: 2,\n  ARCHIVED: 1,\n};\n\n/**\n * Per-tier hard limits applied when `applyStateLimits` is true.\n * Prevents any single tier from monopolising the result window.\n */\nexport const STATE_LIMITS: Record<string, number> = {\n  HOT: 50,\n  WARM: 30,\n  COLD: 20,\n  DORMANT: 10,\n  ARCHIVED: 5,\n};\n\n/** Fallback priority for unknown/missing memoryState values.\n * Set above HOT (5) so UNKNOWN memories always pass state filters.\n * memoryState column doesn't exist yet — all memories are UNKNOWN.\n * Reset to 0 when the TRM state column is implemented. */\nconst UNKNOWN_STATE_PRIORITY = 6;\n\nfunction normalizeStateValue(state: unknown): string | null {\n  if (typeof state !== 'string') {\n    return null;\n  }\n  const normalizedState = state.toUpperCase();\n  return normalizedState in STATE_PRIORITY ? normalizedState : null;\n}\n\nfunction resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n  const explicitState = normalizeStateValue(row.memoryState);\n  if (explicitState) {\n    return explicitState;\n  }\n\n  return 'UNKNOWN';\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. TYPES\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Per-state tally produced by `filterByMemoryState`.\n * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n */\nexport type StateStats = Record<string, number>;\n\n/**\n * Return value of the internal `filterByMemoryState` function.\n */\nexport interface FilterResult {\n  /** Rows that survived state filtering, in original order. */\n  filtered: Stage4ReadonlyRow[];\n  /** Pre-filter per-state counts (includes removed rows). */\n  statsBefore: StateStats;\n  /** Post-filter per-state counts. */\n  statsAfter: StateStats;\n  /** Total number of rows removed. */\n  removedCount: number;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. INTERNAL: filterByMemoryState\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Remove rows whose `memoryState` falls below `minState` priority and,\n * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n *\n * IMPORTANT: This function ONLY removes items — it never reorders or\n * modifies score fields. The original ordering from Stage 3 is preserved\n * for all rows that survive.\n *\n * @param results        - Read-only rows from Stage 3 output.\n * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n * @returns FilterResult with the surviving rows and before/after stats.\n */\nexport function filterByMemoryState(\n  results: Stage4ReadonlyRow[],\n  minState: string,\n  applyStateLimits: boolean,\n): FilterResult {\n  const normalizedMinState = normalizeStateValue(minState);\n  const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n\n  // -- 3a. Tally states before filtering --\n  const statsBefore: StateStats = {};\n  for (const row of results) {\n    const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n    statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n  }\n\n  // -- 3b. State-priority filter --\n  let passing = results.filter(row => {\n    const state = resolveStateForFiltering(row);\n    const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n    return priority >= minPriority;\n  });\n\n  // -- 3c. Per-tier limits (optional) --\n  if (applyStateLimits) {\n    const tierCounters: Record<string, number> = {};\n    const limitPassing: Stage4ReadonlyRow[] = [];\n\n    for (const row of passing) {\n      const state = resolveStateForFiltering(row);\n      const limit = STATE_LIMITS[state] ?? Infinity;\n      const count = tierCounters[state] ?? 0;\n\n      if (count < limit) {\n        tierCounters[state] = count + 1;\n        limitPassing.push(row);\n      }\n      // Rows exceeding the per-tier limit are silently dropped (no score change).\n    }\n\n    passing = limitPassing;\n  }\n\n  // -- 3d. Tally states after filtering --\n  const statsAfter: StateStats = {};\n  for (const row of passing) {\n    const state = resolveStateForFiltering(row);\n    statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n  }\n\n  return {\n    filtered: passing,\n    statsBefore,\n    statsAfter,\n    removedCount: results.length - passing.length,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INTERNAL: extractScoringValues\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Extract the best available numeric score from a row for evidence-gap\n * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n * so scoring, sorting, and filtering all agree on precedence and normalization.\n *\n * A1 FIX: Previously used a different precedence order (rrfScore first) and\n * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n * that only had the similarity field set.\n *\n * @param row - A Stage4ReadonlyRow to inspect.\n * @returns The best available numeric score clamped to [0,1], or 0.\n */\nexport function extractScoringValue(row: Stage4ReadonlyRow): number {\n  return resolveEffectiveScore(row as unknown as PipelineRow);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. MAIN: executeStage4\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Execute Stage 4 of the 4-stage retrieval pipeline: Filter + Annotate.\n *\n * Stage 4 is the final pipeline stage. It removes results that fall below\n * the configured minimum memory state, runs the Transparent Reasoning Module\n * (TRM) evidence-gap check, attaches annotation metadata, and verifies the\n * score invariant before returning.\n *\n * **Score invariant:** No score fields are modified in Stage 4. The compile-time\n * guarantee is enforced via Stage4ReadonlyRow readonly fields; the runtime check\n * via captureScoreSnapshot / verifyScoreInvariant provides defence-in-depth. If\n * verifyScoreInvariant throws, it indicates a Stage 4 implementation bug.\n *\n * **Session dedup:** Session deduplication is intentionally NOT performed here.\n * It happens after the cache layer in the main handler to avoid cache pollution.\n *\n * @param input - Stage4Input containing read-only results and pipeline config.\n * @returns Stage4Output with filtered/annotated results and metadata.\n * @throws Error if verifyScoreInvariant detects any score mutation (Stage 4 bug).\n */\nexport async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n  const stageStart = Date.now();\n  const { results, config } = input;\n\n  // -- Step 1: Capture score snapshot (runtime invariant) --\n  //\n  // This snapshot is the source-of-truth for the \"no score changes\" assertion.\n  // It is taken over the FULL input set BEFORE any operations, so rows that\n  // Are subsequently filtered out are still in the before-snapshot. The\n  // VerifyScoreInvariant call skips rows not present in the after-set.\n  const scoresBefore = captureScoreSnapshot(results);\n\n  // -- Step 2: State filtering --\n  const filterResult = filterByMemoryState(\n    results,\n    config.minState,\n    config.applyStateLimits,\n  );\n\n  let workingResults: Stage4ReadonlyRow[] = filterResult.filtered;\n  const stateFiltered = filterResult.removedCount;\n\n  // -- Step 3: Evidence gap detection (TRM) --\n  let evidenceGapDetected = false;\n  let evidenceGapWarning: string | undefined;\n\n  if (isTRMEnabled()) {\n    const scores = workingResults.map(extractScoringValue);\n    const trm = detectEvidenceGap(scores);\n\n    evidenceGapDetected = trm.gapDetected;\n\n    if (trm.gapDetected) {\n      evidenceGapWarning = formatEvidenceGapWarning(trm);\n\n      // Annotate each result with the gap metadata (non-score field).\n      workingResults = workingResults.map(row => ({\n        ...row,\n        evidenceGap: { gapDetected: true, warning: evidenceGapWarning },\n      }));\n    }\n  }\n\n  // -- Step 4: Build annotation metadata --\n  const featureFlags: Record<string, boolean> = {\n    trmEnabled: isTRMEnabled(),\n    multiQueryEnabled: isMultiQueryEnabled(),\n    stateLimitsApplied: config.applyStateLimits,\n  };\n\n  const stateStats: Record<string, unknown> = {\n    minState: config.minState,\n    before: filterResult.statsBefore,\n    after: filterResult.statsAfter,\n    removed: stateFiltered,\n  };\n\n  const annotations: Stage4Output['annotations'] = {\n    evidenceGapWarning,\n    stateStats,\n    featureFlags,\n  };\n\n  // -- Step 4b: Final limit cap --\n  // Enforce caller's limit after all filtering to prevent degraded paths exceeding requested count\n  if (typeof config.limit === 'number' && config.limit > 0 && workingResults.length > config.limit) {\n    workingResults = workingResults.slice(0, config.limit);\n  }\n\n  // -- Step 5: Verify score invariant (defence-in-depth) --\n  //\n  // VerifyScoreInvariant checks every row that survived filtering.\n  // Rows removed by filterByMemoryState are absent from workingResults,\n  // So the function correctly skips them (see types.ts implementation).\n  // Throws [Stage4Invariant] Error if any score field was mutated.\n  verifyScoreInvariant(scoresBefore, workingResults);\n\n  const durationMs = Date.now() - stageStart;\n\n  // -- Trace entry --\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'filter',\n      results.length,\n      workingResults.length,\n      durationMs,\n      {\n        stateFiltered,\n        evidenceGapDetected,\n        trmEnabled: isTRMEnabled(),\n        applyStateLimits: config.applyStateLimits,\n        minState: config.minState,\n      },\n    );\n  }\n\n  return {\n    final: workingResults,\n    metadata: {\n      stateFiltered,\n      // sessionDeduped removed; dedup is post-cache in main handler\n      // constitutionalInjected passed from Stage 1 metadata\n      constitutionalInjected: input.stage1Metadata?.constitutionalInjected ?? 0,\n      evidenceGapDetected,\n      durationMs,\n    },\n    annotations,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. TEST SURFACE\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Exported internals for unit testing.\n * Not intended for production use outside the test harness.\n */\nexport const __testables = {\n  filterByMemoryState,\n  resolveStateForFiltering,\n  normalizeStateValue,\n  extractScoringValue,\n  STATE_PRIORITY,\n  STATE_LIMITS,\n  UNKNOWN_STATE_PRIORITY,\n} as const;","lineStart":1,"lineEnd":370,"totalLines":370,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","time":{"start":1781763821901,"end":1781763821904}},"metadata":{"openai":{"itemId":"fc_032f0ebce80c21f6016a338eeda8f48191a3b7164b7c0c8e99"}},"id":"prt_ed9665148001oXpHs7hNQum2Lk","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed9662a5e001wM1Gv8zISlQ0Sc"}}
{"type":"tool_use","timestamp":1781763821938,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_LdV2JFjdSGrSPIxs3Y0I0RnS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/rerank/retrieval-rescue.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/rerank/retrieval-rescue.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retrieval Rescue\n3: // ───────────────────────────────────────────────────────────────\n4: // Default-on candidate rescue layer for trigger-rich paraphrase queries.\n5: \n6: import type Database from 'better-sqlite3';\n7: \n8: import { resolveEffectiveScore } from '../pipeline/types.js';\n9: import type { PipelineRow } from '../pipeline/types.js';\n10: import { createLogger } from '../../utils/logger.js';\n11: \n12: type RescueOptions = {\n13:   db?: Database.Database | null;\n14:   artifactClass?: string | null;\n15:   maxSiblingsPerFolder?: number;\n16: };\n17: \n18: type ScoredRow = PipelineRow & {\n19:   retrievalRescueScore?: number;\n20:   retrievalRescueBoost?: number;\n21:   retrievalRescueSignals?: string[];\n22: };\n23: \n24: const STOPWORDS = new Set([\n25:   'about', 'after', 'against', 'and', 'are', 'but', 'for', 'from', 'into',\n26:   'that', 'the', 'their', 'then', 'this', 'with', 'without', 'across', 'under',\n27:   'over', 'instead', 'covering', 'covers',\n28: ]);\n29: \n30: const GENERIC_TRIGGER_TOKENS = new Set([\n31:   'checklist',\n32:   'decision',\n33:   'feature',\n34:   'implementation',\n35:   'plan',\n36:   'record',\n37:   'research',\n38:   'spec',\n39:   'specification',\n40:   'summary',\n41:   'task',\n42:   'tasks',\n43:   'verification',\n44: ]);\n45: \n46: const DOCUMENT_HINTS: Array<{ terms: string[]; types: string[]; weight: number }> = [\n47:   { terms: ['adr', 'decision', 'decisions', 'rationale'], types: ['decision_record'], weight: 0.22 },\n48:   { terms: ['task', 'tasks', 'todo'], types: ['tasks'], weight: 0.18 },\n49:   { terms: ['checklist', 'verification'], types: ['checklist'], weight: 0.18 },\n50:   { terms: ['implementation', 'summary', 'implemented'], types: ['implementation_summary'], weight: 0.18 },\n51:   { terms: ['research', 'packet', 'spec', 'specification'], types: ['spec', 'research'], weight: 0.16 },\n52:   { terms: ['plan', 'planner', 'planning'], types: ['plan'], weight: 0.14 },\n53: ];\n54: \n55: const SIBLING_DOCUMENT_TYPES = [\n56:   'spec',\n57:   'decision_record',\n58:   'implementation_summary',\n59:   'tasks',\n60:   'checklist',\n61:   'plan',\n62:   'research',\n63: ];\n64: \n65: const RESCUE_SCORE_CAP = 1.0;\n66: const RESCUE_TOP_K = 10;\n67: const logger = createLogger('retrieval-rescue');\n68: \n69: const telemetryCounters = {\n70:   rescueRuns: 0,\n71:   rescueTopKHits: 0,\n72: };\n73: \n74: function envFlagExplicitFalse(name: string): boolean {\n75:   const raw = process.env[name]?.trim().toLowerCase();\n76:   return raw === 'false';\n77: }\n78: \n79: export function isRetrievalRescueEnabled(): boolean {\n80:   return !envFlagExplicitFalse('SPECKIT_RERANK_LAYER');\n81: }\n82: \n83: function normalizeText(value: unknown): string {\n84:   return String(value ?? '')\n85:     .toLowerCase()\n86:     .replace(/[^a-z0-9]+/g, ' ')\n87:     .replace(/\\s+/g, ' ')\n88:     .trim();\n89: }\n90: \n91: function queryTokens(query: string): string[] {\n92:   const compactRawTokens = Array.from(query.toLowerCase().matchAll(/[a-z]+[-_/]\\d+|[a-z0-9]+(?:[-_/][a-z0-9]+)+/g))\n93:     .map((match) => match[0].replace(/[^a-z0-9]+/g, ''))\n94:     .filter((token) => token.length >= 4);\n95:   return Array.from(new Set([\n96:     ...normalizeText(query)\n97:       .split(' ')\n98:       .filter((token) => token.length >= 3 && !STOPWORDS.has(token)),\n99:     ...compactRawTokens,\n100:   ]));\n101: }\n102: \n103: function importantTokens(tokens: string[]): string[] {\n104:   return tokens.filter((token) => token.length >= 5 || /\\d/.test(token));\n105: }\n106: \n107: function parseTriggerPhrases(value: unknown): string[] {\n108:   if (Array.isArray(value)) {\n109:     return value.filter((item): item is string => typeof item === 'string');\n110:   }\n111:   if (typeof value !== 'string' || value.trim().length === 0) return [];\n112:   try {\n113:     const parsed = JSON.parse(value) as unknown;\n114:     if (Array.isArray(parsed)) {\n115:       return parsed.filter((item): item is string => typeof item === 'string');\n116:     }\n117:   } catch {\n118:     // Fall through to legacy comma/newline parsing.\n119:   }\n120:   return value\n121:     .split(/[,;\\n]+/)\n122:     .map((item) => item.trim())\n123:     .filter(Boolean);\n124: }\n125: \n126: function rowText(row: PipelineRow): string {\n127:   const content = typeof row.content === 'string'\n128:     ? row.content\n129:     : typeof row.content_text === 'string'\n130:       ? row.content_text\n131:       : typeof row.precomputedContent === 'string'\n132:         ? row.precomputedContent\n133:         : '';\n134:   return [\n135:     row.title,\n136:     row.file_path,\n137:     row.spec_folder,\n138:     row.document_type,\n139:     row.context_type ?? row.contextType,\n140:     parseTriggerPhrases(row.trigger_phrases ?? row.triggerPhrases).join(' '),\n141:     content.slice(0, 4000),\n142:   ].filter(Boolean).join(' ');\n143: }\n144: \n145: function phraseScore(query: string, phrases: string[]): number {\n146:   const normalizedQuery = normalizeText(query);\n147:   if (!normalizedQuery || phrases.length === 0) return 0;\n148: \n149:   let best = 0;\n150:   const queryTokenSet = new Set(queryTokens(query));\n151:   for (const phrase of phrases) {\n152:     const normalizedPhrase = normalizeText(phrase);\n153:     if (!normalizedPhrase) continue;\n154:     const phraseTokens = new Set(\n155:       queryTokens(normalizedPhrase)\n156:         .filter((token) => !GENERIC_TRIGGER_TOKENS.has(token) || /\\d/.test(token))\n157:     );\n158:     if (phraseTokens.size === 0) continue;\n159:     if (normalizedPhrase === normalizedQuery) {\n160:       best = Math.max(best, 1);\n161:       continue;\n162:     }\n163:     if (normalizedQuery.includes(normalizedPhrase)) {\n164:       best = Math.max(best, phraseTokens.size === 1 ? 0.35 : 0.92);\n165:       continue;\n166:     }\n167:     if (normalizedPhrase.includes(normalizedQuery)) {\n168:       best = Math.max(best, phraseTokens.size === 1 ? 0.32 : 0.86);\n169:       continue;\n170:     }\n171:     const overlap = Array.from(phraseTokens).filter((token) => queryTokenSet.has(token)).length;\n172:     const coverage = overlap / Math.max(1, phraseTokens.size);\n173:     best = Math.max(best, coverage);\n174:   }\n175:   return best;\n176: }\n177: \n178: function documentHintScore(tokens: string[], row: PipelineRow, artifactClass?: string | null): number {\n179:   const docType = String(row.document_type ?? '').toLowerCase().trim();\n180:   const searchableDocType = normalizeText(row.document_type);\n181:   let score = 0;\n182:   for (const hint of DOCUMENT_HINTS) {\n183:     if (!hint.types.some((type) => type === docType || normalizeText(type) === searchableDocType)) continue;\n184:     if (hint.terms.some((term) => tokens.includes(term))) {\n185:       score = Math.max(score, hint.weight);\n186:     }\n187:   }\n188:   if (artifactClass && normalizeText(artifactClass).includes('decision') && docType === 'decision_record') {\n189:     score = Math.max(score, 0.24);\n190:   }\n191:   return score;\n192: }\n193: \n194: function computeRescueLayerScore(baseScore: number, rescueScore: number): number {\n195:   // Keep RESCUE_SCORE_CAP clamp as defense-in-depth even though the\n196:   // formula ceiling (0.03 + 0.78 = 0.81) is below the 1.0 cap with rescueScore\n197:   // bounded to [0,1] at the lexicalScore site. The cap exists in case the\n198:   // formula or input bounds change in the future.\n199:   const uncapped = Math.min(baseScore, 1) * 0.03 + rescueScore * 0.78;\n200:   return Math.min(RESCUE_SCORE_CAP, uncapped);\n201: }\n202: \n203: function lexicalScore(query: string, row: PipelineRow, artifactClass?: string | null): { score: number; signals: string[] } {\n204:   const tokens = queryTokens(query);\n205:   const focused = importantTokens(tokens);\n206:   const text = normalizeText(rowText(row));\n207:   const compactText = text.replace(/\\s+/g, '');\n208:   const textTokenSet = new Set(text.split(' ').filter(Boolean));\n209:   const matched = focused.filter((token) => textTokenSet.has(token) || text.includes(token) || compactText.includes(token));\n210:   const tokenCoverage = focused.length > 0 ? matched.length / focused.length : 0;\n211:   const triggerCoverage = phraseScore(query, parseTriggerPhrases(row.trigger_phrases ?? row.triggerPhrases));\n212:   const docHint = documentHintScore(tokens, row, artifactClass);\n213:   const titlePath = normalizeText(`${row.title ?? ''} ${row.file_path ?? ''} ${row.spec_folder ?? ''}`);\n214:   const titlePathMatches = focused.filter((token) => titlePath.includes(token)).length;\n215:   const titleOrPathHit = Math.min(0.16, titlePathMatches * 0.04);\n216:   const qualityPenalty = row.importance_tier === 'deprecated' ? -0.08 : 0;\n217:   const archivePenalty = !tokens.includes('archive') && /\\bz_archive\\b/.test(String(row.file_path ?? row.spec_folder ?? ''))\n218:     ? -0.16\n219:     : 0;\n220:   const score = Math.max(0, Math.min(1, tokenCoverage * 0.58 + triggerCoverage * 0.22 + docHint + titleOrPathHit + qualityPenalty + archivePenalty));\n221:   const signals = [\n222:     tokenCoverage >= 0.25 ? `token:${tokenCoverage.toFixed(2)}` : null,\n223:     triggerCoverage >= 0.25 ? `trigger:${triggerCoverage.toFixed(2)}` : null,\n224:     docHint > 0 ? `doc:${docHint.toFixed(2)}` : null,\n225:     titleOrPathHit > 0 ? `title-path:${titleOrPathHit.toFixed(2)}` : null,\n226:   ].filter((signal): signal is string => Boolean(signal));\n227:   return { score, signals };\n228: }\n229: \n230: function mergeRicherRow(existing: PipelineRow, candidate: PipelineRow): PipelineRow {\n231:   const firstString = (...values: unknown[]): string | undefined =>\n232:     values.find((value): value is string => typeof value === 'string');\n233:   return {\n234:     ...candidate,\n235:     ...existing,\n236:     content: firstString(existing.content, candidate.content, candidate.content_text),\n237:     content_text: firstString(existing.content_text, candidate.content_text, candidate.content),\n238:     precomputedContent: firstString(existing.precomputedContent, candidate.precomputedContent),\n239:     trigger_phrases: firstString(existing.trigger_phrases, candidate.trigger_phrases),\n240:     triggerPhrases: firstString(existing.triggerPhrases, candidate.triggerPhrases),\n241:     document_type: firstString(existing.document_type, candidate.document_type),\n242:     spec_folder: firstString(existing.spec_folder, candidate.spec_folder),\n243:     file_path: firstString(existing.file_path, candidate.file_path),\n244:     title: firstString(existing.title, candidate.title),\n245:   };\n246: }\n247: \n248: function syncScore(row: PipelineRow, score: number): ScoredRow {\n249:   return {\n250:     ...row,\n251:     score,\n252:     rrfScore: score,\n253:     intentAdjustedScore: score,\n254:   };\n255: }\n256: \n257: function fetchSiblingRows(db: Database.Database, rows: PipelineRow[], maxPerFolder: number): PipelineRow[] {\n258:   const folders = Array.from(new Set(\n259:     rows\n260:       .map((row) => row.spec_folder)\n261:       .filter((folder): folder is string => typeof folder === 'string' && folder.length > 0)\n262:   ));\n263:   if (folders.length === 0) return [];\n264: \n265:   const siblings: PipelineRow[] = [];\n266:   const stmt = db.prepare(`\n267:     SELECT *\n268:     FROM memory_index\n269:     WHERE spec_folder = ?\n270:       AND document_type IN (${SIBLING_DOCUMENT_TYPES.map(() => '?').join(',')})\n271:     ORDER BY\n272:       CASE document_type\n273:         WHEN 'spec' THEN 0\n274:         WHEN 'decision_record' THEN 1\n275:         WHEN 'implementation_summary' THEN 2\n276:         WHEN 'tasks' THEN 3\n277:         WHEN 'checklist' THEN 4\n278:         WHEN 'plan' THEN 5\n279:         ELSE 6\n280:       END,\n281:       id ASC\n282:     LIMIT ?\n283:   `);\n284: \n285:   for (const folder of folders) {\n286:     const rowsForFolder = stmt.all(folder, ...SIBLING_DOCUMENT_TYPES, maxPerFolder) as PipelineRow[];\n287:     siblings.push(...rowsForFolder);\n288:   }\n289:   return siblings;\n290: }\n291: \n292: function fetchLexicalBackfillRows(db: Database.Database, query: string): PipelineRow[] {\n293:   const tokens = importantTokens(queryTokens(query)).slice(0, 10);\n294:   if (tokens.length === 0) return [];\n295: \n296:   const clauses = tokens.map(() => `\n297:     LOWER(COALESCE(title, '') || ' ' || COALESCE(trigger_phrases, '') || ' ' || COALESCE(file_path, '') || ' ' || COALESCE(content_text, '')) LIKE ?\n298:   `);\n299:   const params = tokens.map((token) => `%${token}%`);\n300: \n301:   try {\n302:     return db.prepare(`\n303:       SELECT *, content_text AS content\n304:       FROM memory_index\n305:       WHERE ${clauses.join(' OR ')}\n306:       ORDER BY\n307:         CASE document_type\n308:           WHEN 'decision_record' THEN 0\n309:           WHEN 'implementation_summary' THEN 1\n310:           WHEN 'tasks' THEN 2\n311:           WHEN 'spec' THEN 3\n312:           WHEN 'checklist' THEN 4\n313:           WHEN 'plan' THEN 5\n314:           ELSE 6\n315:         END,\n316:         quality_score DESC,\n317:         id ASC\n318:       LIMIT 250\n319:     `).all(...params) as PipelineRow[];\n320:   } catch {\n321:     return [];\n322:   }\n323: }\n324: \n325: function hydrateCandidateRows(db: Database.Database, rows: PipelineRow[]): PipelineRow[] {\n326:   if (rows.length === 0) return rows;\n327:   const stmt = db.prepare('SELECT *, content_text AS content FROM memory_index WHERE id = ?');\n328:   return rows.map((row) => {\n329:     try {\n330:       const hydrated = stmt.get(row.id) as PipelineRow | undefined;\n331:       return hydrated ? mergeRicherRow(row, hydrated) : row;\n332:     } catch {\n333:       return row;\n334:     }\n335:   });\n336: }\n337: \n338: function mergeSiblingCandidates(query: string, rows: PipelineRow[], options: RescueOptions): PipelineRow[] {\n339:   if (!options.db) return rows;\n340:   const hydratedRows = hydrateCandidateRows(options.db, rows);\n341:   const maxSiblingsPerFolder = options.maxSiblingsPerFolder ?? 8;\n342:   const backfill = fetchLexicalBackfillRows(options.db, query);\n343:   const siblings = fetchSiblingRows(options.db, [...hydratedRows, ...backfill], maxSiblingsPerFolder);\n344:   if (siblings.length === 0 && backfill.length === 0) return hydratedRows;\n345: \n346:   const byId = new Map<number, PipelineRow>();\n347:   for (const row of hydratedRows) byId.set(row.id, row);\n348: \n349:   for (const candidate of [...backfill, ...siblings]) {\n350:     const existing = byId.get(candidate.id);\n351:     if (existing) {\n352:       byId.set(candidate.id, mergeRicherRow(existing, candidate));\n353:       continue;\n354:     }\n355:     const rescue = lexicalScore(query, candidate, options.artifactClass);\n356:     if (rescue.score < 0.24) continue;\n357:     byId.set(candidate.id, {\n358:       ...candidate,\n359:       retrievalRescueSibling: true,\n360:     });\n361:   }\n362: \n363:   return Array.from(byId.values());\n364: }\n365: \n366: export function applyRetrievalRescueLayer(\n367:   query: string,\n368:   rows: PipelineRow[],\n369:   options: RescueOptions = {},\n370: ): PipelineRow[] {\n371:   if (!isRetrievalRescueEnabled() || rows.length === 0) return rows;\n372: \n373:   const expanded = mergeSiblingCandidates(query, rows, options);\n374:   const rescued = expanded.map((row): ScoredRow => {\n375:     const baseScore = resolveEffectiveScore(row);\n376:     const rescue = lexicalScore(query, row, options.artifactClass);\n377:     // Rescue candidates should compete after the outer normalization\n378:     // clamp, not be held below original-lane candidates by a local 0.82 cap.\n379:     const score = computeRescueLayerScore(baseScore, rescue.score);\n380:     const boost = Math.max(0, score - baseScore);\n381:     return {\n382:       ...syncScore(row, score),\n383:       retrievalRescueScore: rescue.score,\n384:       retrievalRescueBoost: boost,\n385:       retrievalRescueSignals: rescue.signals,\n386:     };\n387:   });\n388: \n389:   const sorted = rescued.sort((a, b) => {\n390:     const scoreDelta = resolveEffectiveScore(b) - resolveEffectiveScore(a);\n391:     if (scoreDelta !== 0) return scoreDelta;\n392:     const aRescue = a.retrievalRescueScore ?? 0;\n393:     const bRescue = b.retrievalRescueScore ?? 0;\n394:     if (bRescue !== aRescue) return bRescue - aRescue;\n395:     return a.id - b.id;\n396:   });\n397: \n398:   telemetryCounters.rescueRuns += 1;\n399:   const topKHits = sorted\n400:     .slice(0, RESCUE_TOP_K)\n401:     .filter((row) => (row.retrievalRescueBoost ?? 0) > 0).length;\n402:   telemetryCounters.rescueTopKHits += topKHits;\n403:   logger.debug('retrieval rescue summary', {\n404:     event: 'retrieval_rescue_hit_rate',\n405:     topK: RESCUE_TOP_K,\n406:     topKHits,\n407:     hitRate: topKHits / Math.max(1, Math.min(RESCUE_TOP_K, sorted.length)),\n408:     cumulativeRuns: telemetryCounters.rescueRuns,\n409:     cumulativeTopKHits: telemetryCounters.rescueTopKHits,\n410:   });\n411: \n412:   return sorted;\n413: }\n414: \n415: export const __testables = {\n416:   queryTokens,\n417:   lexicalScore,\n418:   computeRescueLayerScore,\n419:   telemetryCounters,\n420:   resetTelemetryCounters: () => {\n421:     telemetryCounters.rescueRuns = 0;\n422:     telemetryCounters.rescueTopKHits = 0;\n423:   },\n424:   parseTriggerPhrases,\n425:   mergeSiblingCandidates,\n426: };\n\n(End of file - total 426 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retrieval Rescue\n// ───────────────────────────────────────────────────────────────\n// Default-on candidate rescue layer for trigger-rich paraphrase queries.\n\nimport type Database from 'better-sqlite3';\n\nimport { resolveEffectiveScore } from '../pipeline/types.js';\nimport type { PipelineRow } from '../pipeline/types.js';\nimport { createLogger } from '../../utils/logger.js';\n\ntype RescueOptions = {\n  db?: Database.Database | null;\n  artifactClass?: string | null;\n  maxSiblingsPerFolder?: number;\n};\n\ntype ScoredRow = PipelineRow & {\n  retrievalRescueScore?: number;\n  retrievalRescueBoost?: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/rerank/retrieval-rescue.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retrieval Rescue\n// ───────────────────────────────────────────────────────────────\n// Default-on candidate rescue layer for trigger-rich paraphrase queries.\n\nimport type Database from 'better-sqlite3';\n\nimport { resolveEffectiveScore } from '../pipeline/types.js';\nimport type { PipelineRow } from '../pipeline/types.js';\nimport { createLogger } from '../../utils/logger.js';\n\ntype RescueOptions = {\n  db?: Database.Database | null;\n  artifactClass?: string | null;\n  maxSiblingsPerFolder?: number;\n};\n\ntype ScoredRow = PipelineRow & {\n  retrievalRescueScore?: number;\n  retrievalRescueBoost?: number;\n  retrievalRescueSignals?: string[];\n};\n\nconst STOPWORDS = new Set([\n  'about', 'after', 'against', 'and', 'are', 'but', 'for', 'from', 'into',\n  'that', 'the', 'their', 'then', 'this', 'with', 'without', 'across', 'under',\n  'over', 'instead', 'covering', 'covers',\n]);\n\nconst GENERIC_TRIGGER_TOKENS = new Set([\n  'checklist',\n  'decision',\n  'feature',\n  'implementation',\n  'plan',\n  'record',\n  'research',\n  'spec',\n  'specification',\n  'summary',\n  'task',\n  'tasks',\n  'verification',\n]);\n\nconst DOCUMENT_HINTS: Array<{ terms: string[]; types: string[]; weight: number }> = [\n  { terms: ['adr', 'decision', 'decisions', 'rationale'], types: ['decision_record'], weight: 0.22 },\n  { terms: ['task', 'tasks', 'todo'], types: ['tasks'], weight: 0.18 },\n  { terms: ['checklist', 'verification'], types: ['checklist'], weight: 0.18 },\n  { terms: ['implementation', 'summary', 'implemented'], types: ['implementation_summary'], weight: 0.18 },\n  { terms: ['research', 'packet', 'spec', 'specification'], types: ['spec', 'research'], weight: 0.16 },\n  { terms: ['plan', 'planner', 'planning'], types: ['plan'], weight: 0.14 },\n];\n\nconst SIBLING_DOCUMENT_TYPES = [\n  'spec',\n  'decision_record',\n  'implementation_summary',\n  'tasks',\n  'checklist',\n  'plan',\n  'research',\n];\n\nconst RESCUE_SCORE_CAP = 1.0;\nconst RESCUE_TOP_K = 10;\nconst logger = createLogger('retrieval-rescue');\n\nconst telemetryCounters = {\n  rescueRuns: 0,\n  rescueTopKHits: 0,\n};\n\nfunction envFlagExplicitFalse(name: string): boolean {\n  const raw = process.env[name]?.trim().toLowerCase();\n  return raw === 'false';\n}\n\nexport function isRetrievalRescueEnabled(): boolean {\n  return !envFlagExplicitFalse('SPECKIT_RERANK_LAYER');\n}\n\nfunction normalizeText(value: unknown): string {\n  return String(value ?? '')\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction queryTokens(query: string): string[] {\n  const compactRawTokens = Array.from(query.toLowerCase().matchAll(/[a-z]+[-_/]\\d+|[a-z0-9]+(?:[-_/][a-z0-9]+)+/g))\n    .map((match) => match[0].replace(/[^a-z0-9]+/g, ''))\n    .filter((token) => token.length >= 4);\n  return Array.from(new Set([\n    ...normalizeText(query)\n      .split(' ')\n      .filter((token) => token.length >= 3 && !STOPWORDS.has(token)),\n    ...compactRawTokens,\n  ]));\n}\n\nfunction importantTokens(tokens: string[]): string[] {\n  return tokens.filter((token) => token.length >= 5 || /\\d/.test(token));\n}\n\nfunction parseTriggerPhrases(value: unknown): string[] {\n  if (Array.isArray(value)) {\n    return value.filter((item): item is string => typeof item === 'string');\n  }\n  if (typeof value !== 'string' || value.trim().length === 0) return [];\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed.filter((item): item is string => typeof item === 'string');\n    }\n  } catch {\n    // Fall through to legacy comma/newline parsing.\n  }\n  return value\n    .split(/[,;\\n]+/)\n    .map((item) => item.trim())\n    .filter(Boolean);\n}\n\nfunction rowText(row: PipelineRow): string {\n  const content = typeof row.content === 'string'\n    ? row.content\n    : typeof row.content_text === 'string'\n      ? row.content_text\n      : typeof row.precomputedContent === 'string'\n        ? row.precomputedContent\n        : '';\n  return [\n    row.title,\n    row.file_path,\n    row.spec_folder,\n    row.document_type,\n    row.context_type ?? row.contextType,\n    parseTriggerPhrases(row.trigger_phrases ?? row.triggerPhrases).join(' '),\n    content.slice(0, 4000),\n  ].filter(Boolean).join(' ');\n}\n\nfunction phraseScore(query: string, phrases: string[]): number {\n  const normalizedQuery = normalizeText(query);\n  if (!normalizedQuery || phrases.length === 0) return 0;\n\n  let best = 0;\n  const queryTokenSet = new Set(queryTokens(query));\n  for (const phrase of phrases) {\n    const normalizedPhrase = normalizeText(phrase);\n    if (!normalizedPhrase) continue;\n    const phraseTokens = new Set(\n      queryTokens(normalizedPhrase)\n        .filter((token) => !GENERIC_TRIGGER_TOKENS.has(token) || /\\d/.test(token))\n    );\n    if (phraseTokens.size === 0) continue;\n    if (normalizedPhrase === normalizedQuery) {\n      best = Math.max(best, 1);\n      continue;\n    }\n    if (normalizedQuery.includes(normalizedPhrase)) {\n      best = Math.max(best, phraseTokens.size === 1 ? 0.35 : 0.92);\n      continue;\n    }\n    if (normalizedPhrase.includes(normalizedQuery)) {\n      best = Math.max(best, phraseTokens.size === 1 ? 0.32 : 0.86);\n      continue;\n    }\n    const overlap = Array.from(phraseTokens).filter((token) => queryTokenSet.has(token)).length;\n    const coverage = overlap / Math.max(1, phraseTokens.size);\n    best = Math.max(best, coverage);\n  }\n  return best;\n}\n\nfunction documentHintScore(tokens: string[], row: PipelineRow, artifactClass?: string | null): number {\n  const docType = String(row.document_type ?? '').toLowerCase().trim();\n  const searchableDocType = normalizeText(row.document_type);\n  let score = 0;\n  for (const hint of DOCUMENT_HINTS) {\n    if (!hint.types.some((type) => type === docType || normalizeText(type) === searchableDocType)) continue;\n    if (hint.terms.some((term) => tokens.includes(term))) {\n      score = Math.max(score, hint.weight);\n    }\n  }\n  if (artifactClass && normalizeText(artifactClass).includes('decision') && docType === 'decision_record') {\n    score = Math.max(score, 0.24);\n  }\n  return score;\n}\n\nfunction computeRescueLayerScore(baseScore: number, rescueScore: number): number {\n  // Keep RESCUE_SCORE_CAP clamp as defense-in-depth even though the\n  // formula ceiling (0.03 + 0.78 = 0.81) is below the 1.0 cap with rescueScore\n  // bounded to [0,1] at the lexicalScore site. The cap exists in case the\n  // formula or input bounds change in the future.\n  const uncapped = Math.min(baseScore, 1) * 0.03 + rescueScore * 0.78;\n  return Math.min(RESCUE_SCORE_CAP, uncapped);\n}\n\nfunction lexicalScore(query: string, row: PipelineRow, artifactClass?: string | null): { score: number; signals: string[] } {\n  const tokens = queryTokens(query);\n  const focused = importantTokens(tokens);\n  const text = normalizeText(rowText(row));\n  const compactText = text.replace(/\\s+/g, '');\n  const textTokenSet = new Set(text.split(' ').filter(Boolean));\n  const matched = focused.filter((token) => textTokenSet.has(token) || text.includes(token) || compactText.includes(token));\n  const tokenCoverage = focused.length > 0 ? matched.length / focused.length : 0;\n  const triggerCoverage = phraseScore(query, parseTriggerPhrases(row.trigger_phrases ?? row.triggerPhrases));\n  const docHint = documentHintScore(tokens, row, artifactClass);\n  const titlePath = normalizeText(`${row.title ?? ''} ${row.file_path ?? ''} ${row.spec_folder ?? ''}`);\n  const titlePathMatches = focused.filter((token) => titlePath.includes(token)).length;\n  const titleOrPathHit = Math.min(0.16, titlePathMatches * 0.04);\n  const qualityPenalty = row.importance_tier === 'deprecated' ? -0.08 : 0;\n  const archivePenalty = !tokens.includes('archive') && /\\bz_archive\\b/.test(String(row.file_path ?? row.spec_folder ?? ''))\n    ? -0.16\n    : 0;\n  const score = Math.max(0, Math.min(1, tokenCoverage * 0.58 + triggerCoverage * 0.22 + docHint + titleOrPathHit + qualityPenalty + archivePenalty));\n  const signals = [\n    tokenCoverage >= 0.25 ? `token:${tokenCoverage.toFixed(2)}` : null,\n    triggerCoverage >= 0.25 ? `trigger:${triggerCoverage.toFixed(2)}` : null,\n    docHint > 0 ? `doc:${docHint.toFixed(2)}` : null,\n    titleOrPathHit > 0 ? `title-path:${titleOrPathHit.toFixed(2)}` : null,\n  ].filter((signal): signal is string => Boolean(signal));\n  return { score, signals };\n}\n\nfunction mergeRicherRow(existing: PipelineRow, candidate: PipelineRow): PipelineRow {\n  const firstString = (...values: unknown[]): string | undefined =>\n    values.find((value): value is string => typeof value === 'string');\n  return {\n    ...candidate,\n    ...existing,\n    content: firstString(existing.content, candidate.content, candidate.content_text),\n    content_text: firstString(existing.content_text, candidate.content_text, candidate.content),\n    precomputedContent: firstString(existing.precomputedContent, candidate.precomputedContent),\n    trigger_phrases: firstString(existing.trigger_phrases, candidate.trigger_phrases),\n    triggerPhrases: firstString(existing.triggerPhrases, candidate.triggerPhrases),\n    document_type: firstString(existing.document_type, candidate.document_type),\n    spec_folder: firstString(existing.spec_folder, candidate.spec_folder),\n    file_path: firstString(existing.file_path, candidate.file_path),\n    title: firstString(existing.title, candidate.title),\n  };\n}\n\nfunction syncScore(row: PipelineRow, score: number): ScoredRow {\n  return {\n    ...row,\n    score,\n    rrfScore: score,\n    intentAdjustedScore: score,\n  };\n}\n\nfunction fetchSiblingRows(db: Database.Database, rows: PipelineRow[], maxPerFolder: number): PipelineRow[] {\n  const folders = Array.from(new Set(\n    rows\n      .map((row) => row.spec_folder)\n      .filter((folder): folder is string => typeof folder === 'string' && folder.length > 0)\n  ));\n  if (folders.length === 0) return [];\n\n  const siblings: PipelineRow[] = [];\n  const stmt = db.prepare(`\n    SELECT *\n    FROM memory_index\n    WHERE spec_folder = ?\n      AND document_type IN (${SIBLING_DOCUMENT_TYPES.map(() => '?').join(',')})\n    ORDER BY\n      CASE document_type\n        WHEN 'spec' THEN 0\n        WHEN 'decision_record' THEN 1\n        WHEN 'implementation_summary' THEN 2\n        WHEN 'tasks' THEN 3\n        WHEN 'checklist' THEN 4\n        WHEN 'plan' THEN 5\n        ELSE 6\n      END,\n      id ASC\n    LIMIT ?\n  `);\n\n  for (const folder of folders) {\n    const rowsForFolder = stmt.all(folder, ...SIBLING_DOCUMENT_TYPES, maxPerFolder) as PipelineRow[];\n    siblings.push(...rowsForFolder);\n  }\n  return siblings;\n}\n\nfunction fetchLexicalBackfillRows(db: Database.Database, query: string): PipelineRow[] {\n  const tokens = importantTokens(queryTokens(query)).slice(0, 10);\n  if (tokens.length === 0) return [];\n\n  const clauses = tokens.map(() => `\n    LOWER(COALESCE(title, '') || ' ' || COALESCE(trigger_phrases, '') || ' ' || COALESCE(file_path, '') || ' ' || COALESCE(content_text, '')) LIKE ?\n  `);\n  const params = tokens.map((token) => `%${token}%`);\n\n  try {\n    return db.prepare(`\n      SELECT *, content_text AS content\n      FROM memory_index\n      WHERE ${clauses.join(' OR ')}\n      ORDER BY\n        CASE document_type\n          WHEN 'decision_record' THEN 0\n          WHEN 'implementation_summary' THEN 1\n          WHEN 'tasks' THEN 2\n          WHEN 'spec' THEN 3\n          WHEN 'checklist' THEN 4\n          WHEN 'plan' THEN 5\n          ELSE 6\n        END,\n        quality_score DESC,\n        id ASC\n      LIMIT 250\n    `).all(...params) as PipelineRow[];\n  } catch {\n    return [];\n  }\n}\n\nfunction hydrateCandidateRows(db: Database.Database, rows: PipelineRow[]): PipelineRow[] {\n  if (rows.length === 0) return rows;\n  const stmt = db.prepare('SELECT *, content_text AS content FROM memory_index WHERE id = ?');\n  return rows.map((row) => {\n    try {\n      const hydrated = stmt.get(row.id) as PipelineRow | undefined;\n      return hydrated ? mergeRicherRow(row, hydrated) : row;\n    } catch {\n      return row;\n    }\n  });\n}\n\nfunction mergeSiblingCandidates(query: string, rows: PipelineRow[], options: RescueOptions): PipelineRow[] {\n  if (!options.db) return rows;\n  const hydratedRows = hydrateCandidateRows(options.db, rows);\n  const maxSiblingsPerFolder = options.maxSiblingsPerFolder ?? 8;\n  const backfill = fetchLexicalBackfillRows(options.db, query);\n  const siblings = fetchSiblingRows(options.db, [...hydratedRows, ...backfill], maxSiblingsPerFolder);\n  if (siblings.length === 0 && backfill.length === 0) return hydratedRows;\n\n  const byId = new Map<number, PipelineRow>();\n  for (const row of hydratedRows) byId.set(row.id, row);\n\n  for (const candidate of [...backfill, ...siblings]) {\n    const existing = byId.get(candidate.id);\n    if (existing) {\n      byId.set(candidate.id, mergeRicherRow(existing, candidate));\n      continue;\n    }\n    const rescue = lexicalScore(query, candidate, options.artifactClass);\n    if (rescue.score < 0.24) continue;\n    byId.set(candidate.id, {\n      ...candidate,\n      retrievalRescueSibling: true,\n    });\n  }\n\n  return Array.from(byId.values());\n}\n\nexport function applyRetrievalRescueLayer(\n  query: string,\n  rows: PipelineRow[],\n  options: RescueOptions = {},\n): PipelineRow[] {\n  if (!isRetrievalRescueEnabled() || rows.length === 0) return rows;\n\n  const expanded = mergeSiblingCandidates(query, rows, options);\n  const rescued = expanded.map((row): ScoredRow => {\n    const baseScore = resolveEffectiveScore(row);\n    const rescue = lexicalScore(query, row, options.artifactClass);\n    // Rescue candidates should compete after the outer normalization\n    // clamp, not be held below original-lane candidates by a local 0.82 cap.\n    const score = computeRescueLayerScore(baseScore, rescue.score);\n    const boost = Math.max(0, score - baseScore);\n    return {\n      ...syncScore(row, score),\n      retrievalRescueScore: rescue.score,\n      retrievalRescueBoost: boost,\n      retrievalRescueSignals: rescue.signals,\n    };\n  });\n\n  const sorted = rescued.sort((a, b) => {\n    const scoreDelta = resolveEffectiveScore(b) - resolveEffectiveScore(a);\n    if (scoreDelta !== 0) return scoreDelta;\n    const aRescue = a.retrievalRescueScore ?? 0;\n    const bRescue = b.retrievalRescueScore ?? 0;\n    if (bRescue !== aRescue) return bRescue - aRescue;\n    return a.id - b.id;\n  });\n\n  telemetryCounters.rescueRuns += 1;\n  const topKHits = sorted\n    .slice(0, RESCUE_TOP_K)\n    .filter((row) => (row.retrievalRescueBoost ?? 0) > 0).length;\n  telemetryCounters.rescueTopKHits += topKHits;\n  logger.debug('retrieval rescue summary', {\n    event: 'retrieval_rescue_hit_rate',\n    topK: RESCUE_TOP_K,\n    topKHits,\n    hitRate: topKHits / Math.max(1, Math.min(RESCUE_TOP_K, sorted.length)),\n    cumulativeRuns: telemetryCounters.rescueRuns,\n    cumulativeTopKHits: telemetryCounters.rescueTopKHits,\n  });\n\n  return sorted;\n}\n\nexport const __testables = {\n  queryTokens,\n  lexicalScore,\n  computeRescueLayerScore,\n  telemetryCounters,\n  resetTelemetryCounters: () => {\n    telemetryCounters.rescueRuns = 0;\n    telemetryCounters.rescueTopKHits = 0;\n  },\n  parseTriggerPhrases,\n  mergeSiblingCandidates,\n};","lineStart":1,"lineEnd":426,"totalLines":426,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/rerank/retrieval-rescue.ts","time":{"start":1781763821930,"end":1781763821937}},"metadata":{"openai":{"itemId":"fc_032f0ebce80c21f6016a338eeda8fc8191bfe2b2a426ad828f"}},"id":"prt_ed966515d001BuSxDOgtVaF1y3","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed9662a5e001wM1Gv8zISlQ0Sc"}}
{"type":"tool_use","timestamp":1781763822074,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_XsqX2lGfW0Gxs89YFtA749Ho","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Trigger Embedding Backfill\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: \n6: import {\n7:   computeContentHash,\n8:   getActiveEmbeddingProfileKey,\n9:   lookupEmbedding,\n10:   storeEmbedding,\n11: } from '../cache/embedding-cache.js';\n12: import { normalizeTriggerText } from '../parsing/trigger-matcher.js';\n13: import * as embeddings from '../providers/embeddings.js';\n14: import { sanitizeAndLogEmbeddingFailure } from '../providers/retry-manager.js';\n15: import { ensureMemoryTriggerEmbeddingsSchema } from './vector-index-schema.js';\n16: \n17: type TriggerEmbeddingInputKind = 'document';\n18: \n19: interface TriggerSourceRow {\n20:   id: number;\n21:   trigger_phrases: string | null;\n22: }\n23: \n24: interface PendingTriggerEmbeddingRow {\n25:   memory_id: number;\n26:   phrase_hash: string;\n27: }\n28: \n29: interface TriggerEmbeddingBackfillOptions {\n30:   enabled?: boolean;\n31:   limit?: number;\n32:   isCancelled?: () => boolean;\n33: }\n34: \n35: export interface TriggerEmbeddingBackfillResult {\n36:   enabled: boolean;\n37:   status: 'skipped_default_off' | 'complete' | 'complete_with_pending' | 'failed' | 'cancelled';\n38:   scannedMemories: number;\n39:   phrasesSeen: number;\n40:   pendingRows: number;\n41:   readyRows: number;\n42:   failedRows: number;\n43:   cacheHits: number;\n44:   generated: number;\n45:   pendingRemaining: number;\n46:   warnings: string[];\n47: }\n48: \n49: const DEFAULT_TRIGGER_BACKFILL_LIMIT = 100;\n50: // The phrase-sync upserts the entire eligible corpus. better-sqlite3 transactions\n51: // run synchronously, so the corpus is processed in chunks and the loop yields\n52: // between chunk transactions — never inside one, which would suspend an open write\n53: // transaction and risk a partial commit. Chunking keeps the daemon able to service\n54: // IPC (status, cancel, health, a competing launcher's probe) throughout the sync.\n55: const PHRASE_SYNC_CHUNK_ROWS = 200;\n56: const TRIGGER_BACKFILL_FLAG = 'SPECKIT_TRIGGER_EMBEDDING_BACKFILL';\n57: const TRIGGER_INPUT_KIND: TriggerEmbeddingInputKind = 'document';\n58: \n59: function isEnabledByEnv(): boolean {\n60:   return process.env[TRIGGER_BACKFILL_FLAG] === 'true';\n61: }\n62: \n63: function emptyResult(enabled: boolean, status: TriggerEmbeddingBackfillResult['status']): TriggerEmbeddingBackfillResult {\n64:   return {\n65:     enabled,\n66:     status,\n67:     scannedMemories: 0,\n68:     phrasesSeen: 0,\n69:     pendingRows: 0,\n70:     readyRows: 0,\n71:     failedRows: 0,\n72:     cacheHits: 0,\n73:     generated: 0,\n74:     pendingRemaining: 0,\n75:     warnings: [],\n76:   };\n77: }\n78: \n79: function parseStoredTriggerPhrases(raw: string | null, memoryId: number): { phrases: string[]; warning: string | null } {\n80:   if (typeof raw !== 'string' || raw.trim().length === 0) {\n81:     return { phrases: [], warning: null };\n82:   }\n83: \n84:   try {\n85:     const parsed = JSON.parse(raw) as unknown;\n86:     if (!Array.isArray(parsed)) {\n87:       return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not a JSON array` };\n88:     }\n89: \n90:     const phrases = new Set<string>();\n91:     for (const value of parsed) {\n92:       if (typeof value !== 'string') {\n93:         continue;\n94:       }\n95:       const normalized = normalizeTriggerText(value);\n96:       if (normalized) {\n97:         phrases.add(normalized);\n98:       }\n99:     }\n100:     return { phrases: [...phrases], warning: null };\n101:   } catch {\n102:     return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not valid JSON` };\n103:   }\n104: }\n105: \n106: function countPendingRows(database: Database.Database, profileKey: string, inputKind: TriggerEmbeddingInputKind): number {\n107:   const row = database.prepare(`\n108:     SELECT COUNT(*) AS count\n109:     FROM memory_trigger_embeddings\n110:     WHERE profile_key = ?\n111:       AND input_kind = ?\n112:       AND embedding_status = 'pending'\n113:   `).get(profileKey, inputKind) as { count: number };\n114:   return row.count;\n115: }\n116: \n117: // On a cancel return the per-pass counters were never finalized, so populate them\n118: // from the live committed-pending backlog. This keeps a cancelled envelope honest\n119: // about remaining work and lets the caller's change-detection (which keys on\n120: // pendingRows) emit a statediff action for rows committed as 'pending' before the cancel.\n121: function reportCommittedPending(\n122:   database: Database.Database,\n123:   profileKey: string,\n124:   inputKind: TriggerEmbeddingInputKind,\n125:   result: TriggerEmbeddingBackfillResult,\n126: ): void {\n127:   const pending = countPendingRows(database, profileKey, inputKind);\n128:   result.pendingRemaining = pending;\n129:   result.pendingRows = pending;\n130: }\n131: \n132: function markTriggerEmbeddingStatus(\n133:   database: Database.Database,\n134:   row: PendingTriggerEmbeddingRow,\n135:   profileKey: string,\n136:   inputKind: TriggerEmbeddingInputKind,\n137:   status: 'ready' | 'failed',\n138:   failureReason: string | null,\n139: ): void {\n140:   database.prepare(`\n141:     UPDATE memory_trigger_embeddings\n142:     SET embedding_status = ?,\n143:         failure_reason = ?,\n144:         updated_at = datetime('now')\n145:     WHERE memory_id = ?\n146:       AND phrase_hash = ?\n147:       AND profile_key = ?\n148:       AND input_kind = ?\n149:   `).run(status, failureReason, row.memory_id, row.phrase_hash, profileKey, inputKind);\n150: }\n151: \n152: export async function runTriggerEmbeddingBackfill(\n153:   database: Database.Database,\n154:   options: TriggerEmbeddingBackfillOptions = {},\n155: ): Promise<TriggerEmbeddingBackfillResult> {\n156:   const enabled = options.enabled ?? isEnabledByEnv();\n157:   if (!enabled) {\n158:     return emptyResult(false, 'skipped_default_off');\n159:   }\n160: \n161:   const result = emptyResult(true, 'complete');\n162:   const limit = Math.max(1, Math.floor(options.limit ?? DEFAULT_TRIGGER_BACKFILL_LIMIT));\n163: \n164:   try {\n165:     ensureMemoryTriggerEmbeddingsSchema(database, 'trigger_embedding_backfill');\n166: \n167:     const profile = embeddings.getEmbeddingProfile();\n168:     const modelId = profile?.model ?? embeddings.getModelName();\n169:     const dimensions = profile?.dim ?? embeddings.getEmbeddingDimension();\n170:     const profileKey = getActiveEmbeddingProfileKey(database, modelId, dimensions);\n171:     const phraseByHash = new Map<string, string>();\n172: \n173:     // Single upfront read of the trigger-phrase source rows. This is a bounded\n174:     // projection (only id + trigger_phrases of non-empty rows) and the backfill\n175:     // is opt-in (default-off), so the one-shot load is acceptable; the heavy\n176:     // write work below is chunked and cooperatively yields between chunks.\n177:     const sourceRows = database.prepare(`\n178:       SELECT id, trigger_phrases\n179:       FROM memory_index\n180:       WHERE trigger_phrases IS NOT NULL\n181:         AND trim(trigger_phrases) != ''\n182:         AND trim(trigger_phrases) != '[]'\n183:       ORDER BY id ASC\n184:     `).all() as TriggerSourceRow[];\n185: \n186:     result.scannedMemories = sourceRows.length;\n187: \n188:     const syncPhraseChunk = database.transaction((rows: TriggerSourceRow[]) => {\n189:       const upsertPending = database.prepare(`\n190:         INSERT INTO memory_trigger_embeddings (\n191:           memory_id,\n192:           phrase_hash,\n193:           profile_key,\n194:           input_kind,\n195:           model_id,\n196:           dimensions,\n197:           embedding_status,\n198:           failure_reason,\n199:           updated_at\n200:         ) VALUES (?, ?, ?, ?, ?, ?, 'pending', NULL, datetime('now'))\n201:         ON CONFLICT(memory_id, phrase_hash, profile_key, input_kind)\n202:         DO UPDATE SET\n203:           model_id = excluded.model_id,\n204:           dimensions = excluded.dimensions,\n205:           embedding_status = CASE\n206:             WHEN memory_trigger_embeddings.embedding_status = 'ready'\n207:               AND memory_trigger_embeddings.model_id = excluded.model_id\n208:               AND memory_trigger_embeddings.dimensions = excluded.dimensions\n209:             THEN memory_trigger_embeddings.embedding_status\n210:             ELSE 'pending'\n211:           END,\n212:           failure_reason = CASE\n213:             WHEN memory_trigger_embeddings.embedding_status = 'ready'\n214:               AND memory_trigger_embeddings.model_id = excluded.model_id\n215:               AND memory_trigger_embeddings.dimensions = excluded.dimensions\n216:             THEN memory_trigger_embeddings.failure_reason\n217:             ELSE NULL\n218:           END,\n219:           updated_at = CASE\n220:             WHEN memory_trigger_embeddings.embedding_status = 'ready'\n221:               AND memory_trigger_embeddings.model_id = excluded.model_id\n222:               AND memory_trigger_embeddings.dimensions = excluded.dimensions\n223:             THEN memory_trigger_embeddings.updated_at\n224:             ELSE datetime('now')\n225:           END\n226:       `);\n227:       const deleteStaleForMemory = (memoryId: number, phraseHashes: string[]): void => {\n228:         if (phraseHashes.length === 0) {\n229:           database.prepare(`\n230:             DELETE FROM memory_trigger_embeddings\n231:             WHERE memory_id = ?\n232:               AND profile_key = ?\n233:               AND input_kind = ?\n234:           `).run(memoryId, profileKey, TRIGGER_INPUT_KIND);\n235:           return;\n236:         }\n237: \n238:         database.prepare(`\n239:           DELETE FROM memory_trigger_embeddings\n240:           WHERE memory_id = ?\n241:             AND profile_key = ?\n242:             AND input_kind = ?\n243:             AND phrase_hash NOT IN (${phraseHashes.map(() => '?').join(', ')})\n244:         `).run(memoryId, profileKey, TRIGGER_INPUT_KIND, ...phraseHashes);\n245:       };\n246: \n247:       for (const row of rows) {\n248:         const parsed = parseStoredTriggerPhrases(row.trigger_phrases, row.id);\n249:         if (parsed.warning) {\n250:           result.warnings.push(parsed.warning);\n251:         }\n252: \n253:         const phraseHashes: string[] = [];\n254:         for (const phrase of parsed.phrases) {\n255:           const phraseHash = computeContentHash(phrase);\n256:           phraseByHash.set(phraseHash, phrase);\n257:           phraseHashes.push(phraseHash);\n258:           result.phrasesSeen += 1;\n259:           upsertPending.run(row.id, phraseHash, profileKey, TRIGGER_INPUT_KIND, modelId, dimensions);\n260:         }\n261: \n262:         deleteStaleForMemory(row.id, phraseHashes);\n263:       }\n264:     });\n265: \n266:     for (let offset = 0; offset < sourceRows.length; offset += PHRASE_SYNC_CHUNK_ROWS) {\n267:       if (options.isCancelled?.()) {\n268:         result.status = 'cancelled';\n269:         result.warnings.push('Trigger embedding backfill cancelled during phrase sync');\n270:         // Already-committed chunks may have inserted 'pending' rows. Report that\n271:         // backlog so a cancelled run does not under-report remaining work and so\n272:         // downstream change-detection sees the committed-but-pending rows. The\n273:         // rows stay inert until embedded and the next scan reconciles them.\n274:         reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n275:         return result;\n276:       }\n277:       syncPhraseChunk(sourceRows.slice(offset, offset + PHRASE_SYNC_CHUNK_ROWS));\n278:       // Yield between self-contained chunk transactions, never inside one. Per-chunk\n279:       // atomicity replaces whole-corpus atomicity; safe here because the upserts are\n280:       // idempotent (ON CONFLICT DO UPDATE) and the deletes are per-memory-id, so a\n281:       // mid-sync cancel leaves a consistent partial state the next scan reconciles.\n282:       await new Promise<void>((resolve) => setImmediate(resolve));\n283:     }\n284: \n285:     const pendingRows = database.prepare(`\n286:       SELECT memory_id, phrase_hash\n287:       FROM memory_trigger_embeddings\n288:       WHERE profile_key = ?\n289:         AND input_kind = ?\n290:         AND embedding_status = 'pending'\n291:       ORDER BY updated_at ASC, memory_id ASC, phrase_hash ASC\n292:       LIMIT ?\n293:     `).all(profileKey, TRIGGER_INPUT_KIND, limit) as PendingTriggerEmbeddingRow[];\n294: \n295:     result.pendingRows = pendingRows.length;\n296: \n297:     let processedSinceYield = 0;\n298:     for (const row of pendingRows) {\n299:       if (options.isCancelled?.()) {\n300:         result.status = 'cancelled';\n301:         result.warnings.push('Trigger embedding backfill cancelled during embedding generation');\n302:         // Some rows in this pass may already be 'ready' and others still 'pending'.\n303:         // Report the live pending backlog so the cancelled envelope reflects true\n304:         // remaining work; the next scan reconciles the rest.\n305:         reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n306:         return result;\n307:       }\n308:       // The cache-hit and missing-phrase branches below `continue` without awaiting\n309:       // network I/O, so a long run of them would starve the loop; yield periodically.\n310:       if (++processedSinceYield % 50 === 0) {\n311:         await new Promise<void>((resolve) => setImmediate(resolve));\n312:       }\n313:       const phrase = phraseByHash.get(row.phrase_hash);\n314:       if (!phrase) {\n315:         markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Trigger phrase source unavailable');\n316:         result.failedRows += 1;\n317:         continue;\n318:       }\n319: \n320:       const cached = lookupEmbedding(database, row.phrase_hash, modelId, dimensions, {\n321:         profileKey,\n322:         inputKind: TRIGGER_INPUT_KIND,\n323:       });\n324:       if (cached) {\n325:         markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n326:         result.cacheHits += 1;\n327:         result.readyRows += 1;\n328:         continue;\n329:       }\n330: \n331:       try {\n332:         const embedding = await embeddings.generateDocumentEmbedding(phrase);\n333:         if (!embedding) {\n334:           markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Embedding generation returned null');\n335:           result.failedRows += 1;\n336:           continue;\n337:         }\n338: \n339:         const durableStore = database.transaction(() => {\n340:           storeEmbedding(\n341:             database,\n342:             row.phrase_hash,\n343:             modelId,\n344:             Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n345:             embedding.length,\n346:             { profileKey, inputKind: TRIGGER_INPUT_KIND },\n347:           );\n348:           markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n349:         });\n350:         durableStore();\n351:         result.generated += 1;\n352:         result.readyRows += 1;\n353:       } catch (error: unknown) {\n354:         const sanitized = sanitizeAndLogEmbeddingFailure(\n355:           '[trigger-embedding-backfill] Embedding generation failed',\n356:           error,\n357:           { provider: modelId, force: false },\n358:         ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n359:         markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', sanitized);\n360:         result.failedRows += 1;\n361:       }\n362:     }\n363: \n364:     result.pendingRemaining = countPendingRows(database, profileKey, TRIGGER_INPUT_KIND);\n365:     result.status = result.pendingRemaining > 0 ? 'complete_with_pending' : 'complete';\n366:     return result;\n367:   } catch (error: unknown) {\n368:     result.status = 'failed';\n369:     result.warnings.push(error instanceof Error ? error.message : String(error));\n370:     return result;\n371:   }\n372: }\n\n(End of file - total 372 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Trigger Embedding Backfill\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\n\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport { normalizeTriggerText } from '../parsing/trigger-matcher.js';\nimport * as embeddings from '../providers/embeddings.js';\nimport { sanitizeAndLogEmbeddingFailure } from '../providers/retry-manager.js';\nimport { ensureMemoryTriggerEmbeddingsSchema } from './vector-index-schema.js';\n\ntype TriggerEmbeddingInputKind = 'document';\n\ninterface TriggerSourceRow {\n  id: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Trigger Embedding Backfill\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\n\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport { normalizeTriggerText } from '../parsing/trigger-matcher.js';\nimport * as embeddings from '../providers/embeddings.js';\nimport { sanitizeAndLogEmbeddingFailure } from '../providers/retry-manager.js';\nimport { ensureMemoryTriggerEmbeddingsSchema } from './vector-index-schema.js';\n\ntype TriggerEmbeddingInputKind = 'document';\n\ninterface TriggerSourceRow {\n  id: number;\n  trigger_phrases: string | null;\n}\n\ninterface PendingTriggerEmbeddingRow {\n  memory_id: number;\n  phrase_hash: string;\n}\n\ninterface TriggerEmbeddingBackfillOptions {\n  enabled?: boolean;\n  limit?: number;\n  isCancelled?: () => boolean;\n}\n\nexport interface TriggerEmbeddingBackfillResult {\n  enabled: boolean;\n  status: 'skipped_default_off' | 'complete' | 'complete_with_pending' | 'failed' | 'cancelled';\n  scannedMemories: number;\n  phrasesSeen: number;\n  pendingRows: number;\n  readyRows: number;\n  failedRows: number;\n  cacheHits: number;\n  generated: number;\n  pendingRemaining: number;\n  warnings: string[];\n}\n\nconst DEFAULT_TRIGGER_BACKFILL_LIMIT = 100;\n// The phrase-sync upserts the entire eligible corpus. better-sqlite3 transactions\n// run synchronously, so the corpus is processed in chunks and the loop yields\n// between chunk transactions — never inside one, which would suspend an open write\n// transaction and risk a partial commit. Chunking keeps the daemon able to service\n// IPC (status, cancel, health, a competing launcher's probe) throughout the sync.\nconst PHRASE_SYNC_CHUNK_ROWS = 200;\nconst TRIGGER_BACKFILL_FLAG = 'SPECKIT_TRIGGER_EMBEDDING_BACKFILL';\nconst TRIGGER_INPUT_KIND: TriggerEmbeddingInputKind = 'document';\n\nfunction isEnabledByEnv(): boolean {\n  return process.env[TRIGGER_BACKFILL_FLAG] === 'true';\n}\n\nfunction emptyResult(enabled: boolean, status: TriggerEmbeddingBackfillResult['status']): TriggerEmbeddingBackfillResult {\n  return {\n    enabled,\n    status,\n    scannedMemories: 0,\n    phrasesSeen: 0,\n    pendingRows: 0,\n    readyRows: 0,\n    failedRows: 0,\n    cacheHits: 0,\n    generated: 0,\n    pendingRemaining: 0,\n    warnings: [],\n  };\n}\n\nfunction parseStoredTriggerPhrases(raw: string | null, memoryId: number): { phrases: string[]; warning: string | null } {\n  if (typeof raw !== 'string' || raw.trim().length === 0) {\n    return { phrases: [], warning: null };\n  }\n\n  try {\n    const parsed = JSON.parse(raw) as unknown;\n    if (!Array.isArray(parsed)) {\n      return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not a JSON array` };\n    }\n\n    const phrases = new Set<string>();\n    for (const value of parsed) {\n      if (typeof value !== 'string') {\n        continue;\n      }\n      const normalized = normalizeTriggerText(value);\n      if (normalized) {\n        phrases.add(normalized);\n      }\n    }\n    return { phrases: [...phrases], warning: null };\n  } catch {\n    return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not valid JSON` };\n  }\n}\n\nfunction countPendingRows(database: Database.Database, profileKey: string, inputKind: TriggerEmbeddingInputKind): number {\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_trigger_embeddings\n    WHERE profile_key = ?\n      AND input_kind = ?\n      AND embedding_status = 'pending'\n  `).get(profileKey, inputKind) as { count: number };\n  return row.count;\n}\n\n// On a cancel return the per-pass counters were never finalized, so populate them\n// from the live committed-pending backlog. This keeps a cancelled envelope honest\n// about remaining work and lets the caller's change-detection (which keys on\n// pendingRows) emit a statediff action for rows committed as 'pending' before the cancel.\nfunction reportCommittedPending(\n  database: Database.Database,\n  profileKey: string,\n  inputKind: TriggerEmbeddingInputKind,\n  result: TriggerEmbeddingBackfillResult,\n): void {\n  const pending = countPendingRows(database, profileKey, inputKind);\n  result.pendingRemaining = pending;\n  result.pendingRows = pending;\n}\n\nfunction markTriggerEmbeddingStatus(\n  database: Database.Database,\n  row: PendingTriggerEmbeddingRow,\n  profileKey: string,\n  inputKind: TriggerEmbeddingInputKind,\n  status: 'ready' | 'failed',\n  failureReason: string | null,\n): void {\n  database.prepare(`\n    UPDATE memory_trigger_embeddings\n    SET embedding_status = ?,\n        failure_reason = ?,\n        updated_at = datetime('now')\n    WHERE memory_id = ?\n      AND phrase_hash = ?\n      AND profile_key = ?\n      AND input_kind = ?\n  `).run(status, failureReason, row.memory_id, row.phrase_hash, profileKey, inputKind);\n}\n\nexport async function runTriggerEmbeddingBackfill(\n  database: Database.Database,\n  options: TriggerEmbeddingBackfillOptions = {},\n): Promise<TriggerEmbeddingBackfillResult> {\n  const enabled = options.enabled ?? isEnabledByEnv();\n  if (!enabled) {\n    return emptyResult(false, 'skipped_default_off');\n  }\n\n  const result = emptyResult(true, 'complete');\n  const limit = Math.max(1, Math.floor(options.limit ?? DEFAULT_TRIGGER_BACKFILL_LIMIT));\n\n  try {\n    ensureMemoryTriggerEmbeddingsSchema(database, 'trigger_embedding_backfill');\n\n    const profile = embeddings.getEmbeddingProfile();\n    const modelId = profile?.model ?? embeddings.getModelName();\n    const dimensions = profile?.dim ?? embeddings.getEmbeddingDimension();\n    const profileKey = getActiveEmbeddingProfileKey(database, modelId, dimensions);\n    const phraseByHash = new Map<string, string>();\n\n    // Single upfront read of the trigger-phrase source rows. This is a bounded\n    // projection (only id + trigger_phrases of non-empty rows) and the backfill\n    // is opt-in (default-off), so the one-shot load is acceptable; the heavy\n    // write work below is chunked and cooperatively yields between chunks.\n    const sourceRows = database.prepare(`\n      SELECT id, trigger_phrases\n      FROM memory_index\n      WHERE trigger_phrases IS NOT NULL\n        AND trim(trigger_phrases) != ''\n        AND trim(trigger_phrases) != '[]'\n      ORDER BY id ASC\n    `).all() as TriggerSourceRow[];\n\n    result.scannedMemories = sourceRows.length;\n\n    const syncPhraseChunk = database.transaction((rows: TriggerSourceRow[]) => {\n      const upsertPending = database.prepare(`\n        INSERT INTO memory_trigger_embeddings (\n          memory_id,\n          phrase_hash,\n          profile_key,\n          input_kind,\n          model_id,\n          dimensions,\n          embedding_status,\n          failure_reason,\n          updated_at\n        ) VALUES (?, ?, ?, ?, ?, ?, 'pending', NULL, datetime('now'))\n        ON CONFLICT(memory_id, phrase_hash, profile_key, input_kind)\n        DO UPDATE SET\n          model_id = excluded.model_id,\n          dimensions = excluded.dimensions,\n          embedding_status = CASE\n            WHEN memory_trigger_embeddings.embedding_status = 'ready'\n              AND memory_trigger_embeddings.model_id = excluded.model_id\n              AND memory_trigger_embeddings.dimensions = excluded.dimensions\n            THEN memory_trigger_embeddings.embedding_status\n            ELSE 'pending'\n          END,\n          failure_reason = CASE\n            WHEN memory_trigger_embeddings.embedding_status = 'ready'\n              AND memory_trigger_embeddings.model_id = excluded.model_id\n              AND memory_trigger_embeddings.dimensions = excluded.dimensions\n            THEN memory_trigger_embeddings.failure_reason\n            ELSE NULL\n          END,\n          updated_at = CASE\n            WHEN memory_trigger_embeddings.embedding_status = 'ready'\n              AND memory_trigger_embeddings.model_id = excluded.model_id\n              AND memory_trigger_embeddings.dimensions = excluded.dimensions\n            THEN memory_trigger_embeddings.updated_at\n            ELSE datetime('now')\n          END\n      `);\n      const deleteStaleForMemory = (memoryId: number, phraseHashes: string[]): void => {\n        if (phraseHashes.length === 0) {\n          database.prepare(`\n            DELETE FROM memory_trigger_embeddings\n            WHERE memory_id = ?\n              AND profile_key = ?\n              AND input_kind = ?\n          `).run(memoryId, profileKey, TRIGGER_INPUT_KIND);\n          return;\n        }\n\n        database.prepare(`\n          DELETE FROM memory_trigger_embeddings\n          WHERE memory_id = ?\n            AND profile_key = ?\n            AND input_kind = ?\n            AND phrase_hash NOT IN (${phraseHashes.map(() => '?').join(', ')})\n        `).run(memoryId, profileKey, TRIGGER_INPUT_KIND, ...phraseHashes);\n      };\n\n      for (const row of rows) {\n        const parsed = parseStoredTriggerPhrases(row.trigger_phrases, row.id);\n        if (parsed.warning) {\n          result.warnings.push(parsed.warning);\n        }\n\n        const phraseHashes: string[] = [];\n        for (const phrase of parsed.phrases) {\n          const phraseHash = computeContentHash(phrase);\n          phraseByHash.set(phraseHash, phrase);\n          phraseHashes.push(phraseHash);\n          result.phrasesSeen += 1;\n          upsertPending.run(row.id, phraseHash, profileKey, TRIGGER_INPUT_KIND, modelId, dimensions);\n        }\n\n        deleteStaleForMemory(row.id, phraseHashes);\n      }\n    });\n\n    for (let offset = 0; offset < sourceRows.length; offset += PHRASE_SYNC_CHUNK_ROWS) {\n      if (options.isCancelled?.()) {\n        result.status = 'cancelled';\n        result.warnings.push('Trigger embedding backfill cancelled during phrase sync');\n        // Already-committed chunks may have inserted 'pending' rows. Report that\n        // backlog so a cancelled run does not under-report remaining work and so\n        // downstream change-detection sees the committed-but-pending rows. The\n        // rows stay inert until embedded and the next scan reconciles them.\n        reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n        return result;\n      }\n      syncPhraseChunk(sourceRows.slice(offset, offset + PHRASE_SYNC_CHUNK_ROWS));\n      // Yield between self-contained chunk transactions, never inside one. Per-chunk\n      // atomicity replaces whole-corpus atomicity; safe here because the upserts are\n      // idempotent (ON CONFLICT DO UPDATE) and the deletes are per-memory-id, so a\n      // mid-sync cancel leaves a consistent partial state the next scan reconciles.\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n\n    const pendingRows = database.prepare(`\n      SELECT memory_id, phrase_hash\n      FROM memory_trigger_embeddings\n      WHERE profile_key = ?\n        AND input_kind = ?\n        AND embedding_status = 'pending'\n      ORDER BY updated_at ASC, memory_id ASC, phrase_hash ASC\n      LIMIT ?\n    `).all(profileKey, TRIGGER_INPUT_KIND, limit) as PendingTriggerEmbeddingRow[];\n\n    result.pendingRows = pendingRows.length;\n\n    let processedSinceYield = 0;\n    for (const row of pendingRows) {\n      if (options.isCancelled?.()) {\n        result.status = 'cancelled';\n        result.warnings.push('Trigger embedding backfill cancelled during embedding generation');\n        // Some rows in this pass may already be 'ready' and others still 'pending'.\n        // Report the live pending backlog so the cancelled envelope reflects true\n        // remaining work; the next scan reconciles the rest.\n        reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n        return result;\n      }\n      // The cache-hit and missing-phrase branches below `continue` without awaiting\n      // network I/O, so a long run of them would starve the loop; yield periodically.\n      if (++processedSinceYield % 50 === 0) {\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      const phrase = phraseByHash.get(row.phrase_hash);\n      if (!phrase) {\n        markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Trigger phrase source unavailable');\n        result.failedRows += 1;\n        continue;\n      }\n\n      const cached = lookupEmbedding(database, row.phrase_hash, modelId, dimensions, {\n        profileKey,\n        inputKind: TRIGGER_INPUT_KIND,\n      });\n      if (cached) {\n        markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n        result.cacheHits += 1;\n        result.readyRows += 1;\n        continue;\n      }\n\n      try {\n        const embedding = await embeddings.generateDocumentEmbedding(phrase);\n        if (!embedding) {\n          markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Embedding generation returned null');\n          result.failedRows += 1;\n          continue;\n        }\n\n        const durableStore = database.transaction(() => {\n          storeEmbedding(\n            database,\n            row.phrase_hash,\n            modelId,\n            Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n            embedding.length,\n            { profileKey, inputKind: TRIGGER_INPUT_KIND },\n          );\n          markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n        });\n        durableStore();\n        result.generated += 1;\n        result.readyRows += 1;\n      } catch (error: unknown) {\n        const sanitized = sanitizeAndLogEmbeddingFailure(\n          '[trigger-embedding-backfill] Embedding generation failed',\n          error,\n          { provider: modelId, force: false },\n        ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n        markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', sanitized);\n        result.failedRows += 1;\n      }\n    }\n\n    result.pendingRemaining = countPendingRows(database, profileKey, TRIGGER_INPUT_KIND);\n    result.status = result.pendingRemaining > 0 ? 'complete_with_pending' : 'complete';\n    return result;\n  } catch (error: unknown) {\n    result.status = 'failed';\n    result.warnings.push(error instanceof Error ? error.message : String(error));\n    return result;\n  }\n}","lineStart":1,"lineEnd":372,"totalLines":372,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts","time":{"start":1781763822068,"end":1781763822072}},"metadata":{"openai":{"itemId":"fc_032f0ebce80c21f6016a338eeda9008191903e76c143406b81"}},"id":"prt_ed966519b001rsz7E2ylIE92KZ","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed9662a5e001wM1Gv8zISlQ0Sc"}}
