pe\": \"int\"\n      },\n      {\n        \"default\": 0,\n        \"description\": \"op=query.\",\n        \"name\": \"offset\",\n        \"required\": false,\n        \"type\": \"int\"\n      },\n      {\n        \"default\": \"mcp-agent\",\n        \"description\": \"Caller agent.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=write; optional scoping filter for op=list_collections|search.\",\n        \"name\": \"fleet_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"op=search: natural-language query.\",\n        \"name\": \"query\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": 5,\n        \"description\": \"op=search: max results (1-50).\",\n        \"name\": \"top_k\",\n        \"required\": false,\n        \"type\": \"int\"\n      }\n    ],\n    \"plugin_exposed\": true,\n    \"trust_required\": 0\n  },\n  {\n    \"description\": \"Look up an entity by UUID. Use only when you have an entity_id from a prior search.\",\n    \"error_codes\": [],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_entity_get\",\n    \"ops\": [],\n    \"params\": [\n      {\n        \"description\": \"The UUID of the entity to look up.\",\n        \"name\": \"entity_id\",\n        \"required\": true,\n        \"type\": \"str\"\n      }\n    ],\n    \"plugin_exposed\": true,\n    \"trust_required\": 0\n  },\n  {\n    \"description\": \"Report what happened after acting on memories. outcome_type: success|failure|partial. related_ids = the memory UUIDs that influenced the action (use IDs from your most recent memclaw_recall). scope: agent (default, trust \\u2265 1)|fleet|all (trust \\u2265 2; fleet_id required when scope='fleet'). Weight adjustments and rule generation are scoped \\u2014 agents can only evolve memories they own (scope=agent), their fleet (scope=fleet), or any (scope=all).\",\n    \"error_codes\": [],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_evolve\",\n    \"ops\": [],\n    \"params\": [\n      {\n        \"description\": \"Natural-language description of what happened.\",\n        \"name\": \"outcome\",\n        \"required\": true,\n        \"type\": \"str\"\n      },\n      {\n        \"description\": \"success|failure|partial.\",\n        \"name\": \"outcome_type\",\n        \"required\": true,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"Memory UUIDs that influenced the action.\",\n        \"name\": \"related_ids\",\n        \"required\": false,\n        \"type\": \"list[str] | None\"\n      },\n      {\n        \"default\": \"agent\",\n        \"description\": \"agent|fleet|all.\",\n        \"name\": \"scope\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": \"mcp-agent\",\n        \"description\": \"Caller agent.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"Required when scope='fleet'.\",\n        \"name\": \"fleet_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      }\n    ],\n    \"plugin_exposed\": true,\n    \"trust_required\": 1\n  },\n  {\n    \"description\": \"Reflect over your memory store. focus: contradictions|failures|stale|divergence|patterns|discover. scope: agent (default, trust \\u2265 1)|fleet|all (trust \\u2265 2; divergence requires fleet/all). Findings are saved as insight-type memories for future runs to build on.\",\n    \"error_codes\": [],\n    \"impl_status\": \"live\",\n    \"name\": \"memclaw_insights\",\n    \"ops\": [],\n    \"params\": [\n      {\n        \"description\": \"contradictions|failures|stale|divergence|patterns|discover.\",\n        \"name\": \"focus\",\n        \"required\": true,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": \"agent\",\n        \"description\": \"agent|fleet|all.\",\n        \"name\": \"scope\",\n        \"required\": false,\n        \"type\": \"str\"\n      },\n      {\n        \"default\": null,\n        \"description\": \"Required when scope='fleet'.\",\n        \"name\": \"fleet_id\",\n        \"required\": false,\n        \"type\": \"str | None\"\n      },\n      {\n        \"default\": \"mcp-agent\",\n        \"description\": \"Caller agent.\",\n        \"name\": \"agent_id\",\n        \"required\": false,\n        \"type\": \"str\"\n      }\n    ],\n    \"plugin_exposed\": true,\n    \"trust_required\": 1","lineStart":1,"lineEnd":260,"totalLines":925,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/plugin/tools.json","time":{"start":1780728390101,"end":1780728390120}},"metadata":{"openai":{"itemId":"fc_06a9a7f5e5b14fe9016a23c245ec2c8191b6e98ddfe9900136"}},"id":"prt_e9baee1b5001eqGqK6djPDMytI","sessionID":"ses_164517a7bffeIaaPynAQONhoL2","messageID":"msg_e9bae8aca0016US3GawQg7j66u"}}
