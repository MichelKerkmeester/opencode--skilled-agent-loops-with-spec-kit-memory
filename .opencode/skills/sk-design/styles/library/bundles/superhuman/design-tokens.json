      "$value": "#f2f0eb",
      "$type": "color",
      "$description": "Warm Parchment — Page canvas — the dominant surface; warm cream that replaces white as the base, giving the whole system an editorial warmth"
    },
    "soft-mist": {
      "$value": "#e3e3e2",
      "$type": "color",
      "$description": "Soft Mist — Hairline borders, card outlines, divider lines — warm light gray that disappears against parchment but defines edges crisply"
    },
    "ink-charcoal": {
      "$value": "#292827",
      "$type": "color",
      "$description": "Ink Charcoal — Primary text, headings, icon strokes — warm near-black with just enough brown to feel like ink on paper, never a cold #000"
    },
    "stone-gray": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Stone Gray — Secondary body text, helper copy, muted descriptions — the only mid-gray, used sparingly so it never competes with primary text"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Elevated card surfaces, floating UI overlays, text on dark backgrounds — reserved for cards that must lift off the parchment canvas"
