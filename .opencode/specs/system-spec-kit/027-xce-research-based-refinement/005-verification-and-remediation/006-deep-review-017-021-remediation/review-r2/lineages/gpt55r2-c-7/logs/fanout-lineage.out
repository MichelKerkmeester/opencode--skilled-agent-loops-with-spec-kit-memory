ackendFailure('error');\n697:     });\n698:     socket.once('close', () => {\n699:       handleBackendFailure('close');\n700:     });\n701:     state = 'CONNECTED';\n702:     startKeepalive();\n703:     // The fresh backend may have died after receiving the client's initialize but before\n704:     // answering it on the old socket, leaving initialize pending. internalHandshake just\n705:     // re-sent and answered it; forward that single answer to the client and clear it from\n706:     // pending so replaySnapshot does not send a duplicate initialize to the backend.\n707:     const cachedInitializeId = tracker.getCachedInitializeId();\n708:     if (handshake.handshakeObserved\n709:         && handshake.initializeResponse\n710:         && cachedInitializeId !== null\n711:         && tracker.pendingRequests.has(cachedInitializeId)) {\n712:       tracker.pendingRequests.delete(cachedInitializeId);\n713:       enqueueOutputFrame(handshake.initializeResponse);\n714:     }\n715:     replaySnapshot(replaySnapshotEntries);\n716:     flushQueuedClientFrames();\n717:     pumpSocketQueue();\n718:     if (clientEnded) {\n719:       halfCloseSocketIfReady();\n720:       return;\n721:     }\n722:     resumeClientInputIfReady();\n723:   }\n724: \n725:   async function reattach() {\n726:     for (let attempt = 0; attempt < maxReattachAttempts && !stopped; attempt += 1) {\n727:       const ready = await waitForDaemonReady(socketPath, probe, connect, log, { maxAttempts: 1 });\n728:       if (ready.status === 'alive') {\n729:         try {\n730:           const snapshot = Array.from(tracker.pendingRequests.entries());\n731:           await attachFreshSocket({ replaySnapshotEntries: snapshot });\n732:           if (state === 'CONNECTED' || state === 'CLOSED' || stopped) return;\n733:           log('reattach observed nested backend failure; retrying');\n734:           continue;\n735:         } catch (error) {\n736:           if (state === 'REATTACHING') {\n737:             log(`reattac