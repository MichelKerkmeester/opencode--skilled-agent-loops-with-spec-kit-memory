   393	    if (!/^\|/.test(line)) continue;
   394	    const cells = line.split('|').map((c) => c.trim());
   395	    // Leading/trailing empties from the bounding pipes -> cells[1] is Feature ID.
   396	    const idCell = (cells[1] || '').replace(/`/g, '');
   397	    if (!/^[A-Z]{2,4}-\d{3}$/.test(idCell)) continue;
   398	    if (cells.length < 9) continue; // not a §7-13 scenario row
   399	    const prompt = (cells[4] || '').replace(/^`|`$/g, '').trim();
