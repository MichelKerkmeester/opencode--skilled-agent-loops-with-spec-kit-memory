{"type":"tool_use","timestamp":1780925316854,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_hSmvhQseHuue3VkQ7k5XGGh0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/resolveProject.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/resolveProject.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * resolveProject.ts\n3:  * Shared utility for resolving a cwd to { name, projectDir, isNew }.\n4:  *\n5:  * Resolution order:\n6:  *  1. Exact match in registry.json\n7:  *  2. Longest prefix match in registry.json\n8:  *  3. Fallback: slug derived from cwd\n9:  *\n10:  * Registry: ~/.claude/projects/registry.json\n11:  * Format: { \"/abs/path\": \"friendly-name\" }\n12:  */\n13: \n14: import { existsSync, readFileSync, writeFileSync, renameSync, openSync, fsyncSync, closeSync, mkdirSync, copyFileSync, unlinkSync, statSync } from \"fs\";\n15: import { join, sep } from \"path\";\n16: import { homedir } from \"os\";\n17: \n18: export const CLAUDE_DIR = join(homedir(), \".claude\");\n19: export const PROJECTS_DIR = join(CLAUDE_DIR, \"projects\");\n20: export const REGISTRY_PATH = join(PROJECTS_DIR, \"registry.json\");\n21: \n22: export function getDbPath(): string {\n23:   if (process.env.LTM_DB_PATH) return process.env.LTM_DB_PATH;\n24:   if (process.env.CLAUDE_PLUGIN_DATA) {\n25:     const targetDb = join(process.env.CLAUDE_PLUGIN_DATA, \"openltm.db\");\n26:     const legacyDb = join(CLAUDE_DIR, \"memory\", \"openltm.db\");\n27:     if (!existsSync(targetDb) && existsSync(legacyDb)) {\n28:       mkdirSync(process.env.CLAUDE_PLUGIN_DATA, { recursive: true });\n29:       copyFileSync(legacyDb, targetDb);\n30:     }\n31:     return targetDb;\n32:   }\n33:   return join(CLAUDE_DIR, \"memory\", \"openltm.db\");\n34: }\n35: \n36: export interface ProjectResolution {\n37:   name: string;\n38:   projectDir: string;\n39:   isNew: boolean;\n40:   registeredPath: string | null;\n41: }\n42: \n43: function deriveSlug(cwd: string): string {\n44:   return cwd.replace(new RegExp(\"\\\\\" + sep, \"g\"), \"-\").replace(/\\./g, \"-\");\n45: }\n46: \n47: function loadRegistry(): Record<string, string> {\n48:   if (!existsSync(REGISTRY_PATH)) return {};\n49:   try {\n50:     return JSON.parse(readFileSync(REGISTRY_PATH, \"utf-8\"));\n51:   } catch {\n52:     return {};\n53:   }\n54: }\n55: \n56: const LOCK_STALE_MS = 5000;\n57: const LOCK_RETRIES = 5;\n58: const LOCK_BASE_DELAY_MS = 50;\n59: \n60: function acquireLock(lockPath: string): void {\n61:   for (let i = 0; i < LOCK_RETRIES; i++) {\n62:     // Reclaim stale lock (process died before cleanup)\n63:     if (existsSync(lockPath)) {\n64:       try {\n65:         const age = Date.now() - statSync(lockPath).mtimeMs;\n66:         if (age > LOCK_STALE_MS) unlinkSync(lockPath);\n67:       } catch { /* lock removed by another process — retry */ }\n68:     }\n69:     try {\n70:       // O_EXCL: atomic creation — fails if file already exists\n71:       const fd = openSync(lockPath, \"wx\");\n72:       closeSync(fd);\n73:       return; // lock acquired\n74:     } catch {\n75:       // Another process holds the lock — exponential backoff\n76:       const delay = LOCK_BASE_DELAY_MS * Math.pow(2, i);\n77:       const start = Date.now();\n78:       while (Date.now() - start < delay) { /* spin-wait */ }\n79:     }\n80:   }\n81:   throw new Error(`[writeRegistryAtomic] could not acquire lock after ${LOCK_RETRIES} retries`);\n82: }\n83: \n84: export function writeRegistryAtomic(registryPath: string, data: unknown): void {\n85:   const lockPath = registryPath + \".lock\";\n86:   acquireLock(lockPath);\n87:   try {\n88:     const tmp = registryPath + \".tmp\";\n89:     const json = JSON.stringify(data, null, 2);\n90:     writeFileSync(tmp, json, \"utf8\");\n91:     const fd = openSync(tmp, \"r+\");\n92:     try {\n93:       fsyncSync(fd);\n94:     } finally {\n95:       closeSync(fd);\n96:     }\n97:     renameSync(tmp, registryPath);\n98:   } finally {\n99:     try { unlinkSync(lockPath); } catch { /* already removed — harmless */ }\n100:   }\n101: }\n102: \n103: export function saveRegistry(registry: Record<string, string>): void {\n104:   if (!existsSync(PROJECTS_DIR)) mkdirSync(PROJECTS_DIR, { recursive: true });\n105:   writeRegistryAtomic(REGISTRY_PATH, registry);\n106: }\n107: \n108: export function registerPath(cwd: string, name: string): void {\n109:   const registry = loadRegistry();\n110:   registry[cwd] = name;\n111:   saveRegistry(registry);\n112: }\n113: \n114: function makeResult(name: string, registeredPath: string | null, isNew: boolean): ProjectResolution {\n115:   return { name, projectDir: join(PROJECTS_DIR, name), isNew, registeredPath };\n116: }\n117: \n118: export function resolveProject(cwd: string): ProjectResolution {\n119:   const registry = loadRegistry();\n120: \n121:   // 1. Exact match\n122:   if (registry[cwd]) {\n123:     return makeResult(registry[cwd], cwd, false);\n124:   }\n125: \n126:   // 2. Longest prefix match\n127:   const sortedPaths = Object.keys(registry).sort((a, b) => b.length - a.length);\n128:   for (const path of sortedPaths) {\n129:     if (cwd.startsWith(path + \"/\") || cwd.startsWith(path + sep)) {\n130:       return makeResult(registry[path]!, path, false);\n131:     }\n132:   }\n133: \n134:   // 3. Slug fallback\n135:   const slug = deriveSlug(cwd);\n136:   const slugDir = join(PROJECTS_DIR, slug);\n137:   const contextFiles = [\"context-goals.md\", \"context-decisions.md\", \"context-progress.md\", \"context-gotchas.md\", \"context-summary.md\"];\n138:   const hasContent = contextFiles.some(f => existsSync(join(slugDir, f)));\n139: \n140:   return { name: slug, projectDir: slugDir, isNew: !hasContent, registeredPath: null };\n141: }\n\n(End of file - total 141 lines)\n</content>","metadata":{"preview":"/**\n * resolveProject.ts\n * Shared utility for resolving a cwd to { name, projectDir, isNew }.\n *\n * Resolution order:\n *  1. Exact match in registry.json\n *  2. Longest prefix match in registry.json\n *  3. Fallback: slug derived from cwd\n *\n * Registry: ~/.claude/projects/registry.json\n * Format: { \"/abs/path\": \"friendly-name\" }\n */\n\nimport { existsSync, readFileSync, writeFileSync, renameSync, openSync, fsyncSync, closeSync, mkdirSync, copyFileSync, unlinkSync, statSync } from \"fs\";\nimport { join, sep } from \"path\";\nimport { homedir } from \"os\";\n\nexport const CLAUDE_DIR = join(homedir(), \".claude\");\nexport const PROJECTS_DIR = join(CLAUDE_DIR, \"projects\");\nexport const REGISTRY_PATH = join(PROJECTS_DIR, \"registry.json\");","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/resolveProject.ts","text":"/**\n * resolveProject.ts\n * Shared utility for resolving a cwd to { name, projectDir, isNew }.\n *\n * Resolution order:\n *  1. Exact match in registry.json\n *  2. Longest prefix match in registry.json\n *  3. Fallback: slug derived from cwd\n *\n * Registry: ~/.claude/projects/registry.json\n * Format: { \"/abs/path\": \"friendly-name\" }\n */\n\nimport { existsSync, readFileSync, writeFileSync, renameSync, openSync, fsyncSync, closeSync, mkdirSync, copyFileSync, unlinkSync, statSync } from \"fs\";\nimport { join, sep } from \"path\";\nimport { homedir } from \"os\";\n\nexport const CLAUDE_DIR = join(homedir(), \".claude\");\nexport const PROJECTS_DIR = join(CLAUDE_DIR, \"projects\");\nexport const REGISTRY_PATH = join(PROJECTS_DIR, \"registry.json\");\n\nexport function getDbPath(): string {\n  if (process.env.LTM_DB_PATH) return process.env.LTM_DB_PATH;\n  if (process.env.CLAUDE_PLUGIN_DATA) {\n    const targetDb = join(process.env.CLAUDE_PLUGIN_DATA, \"openltm.db\");\n    const legacyDb = join(CLAUDE_DIR, \"memory\", \"openltm.db\");\n    if (!existsSync(targetDb) && existsSync(legacyDb)) {\n      mkdirSync(process.env.CLAUDE_PLUGIN_DATA, { recursive: true });\n      copyFileSync(legacyDb, targetDb);\n    }\n    return targetDb;\n  }\n  return join(CLAUDE_DIR, \"memory\", \"openltm.db\");\n}\n\nexport interface ProjectResolution {\n  name: string;\n  projectDir: string;\n  isNew: boolean;\n  registeredPath: string | null;\n}\n\nfunction deriveSlug(cwd: string): string {\n  return cwd.replace(new RegExp(\"\\\\\" + sep, \"g\"), \"-\").replace(/\\./g, \"-\");\n}\n\nfunction loadRegistry(): Record<string, string> {\n  if (!existsSync(REGISTRY_PATH)) return {};\n  try {\n    return JSON.parse(readFileSync(REGISTRY_PATH, \"utf-8\"));\n  } catch {\n    return {};\n  }\n}\n\nconst LOCK_STALE_MS = 5000;\nconst LOCK_RETRIES = 5;\nconst LOCK_BASE_DELAY_MS = 50;\n\nfunction acquireLock(lockPath: string): void {\n  for (let i = 0; i < LOCK_RETRIES; i++) {\n    // Reclaim stale lock (process died before cleanup)\n    if (existsSync(lockPath)) {\n      try {\n        const age = Date.now() - statSync(lockPath).mtimeMs;\n        if (age > LOCK_STALE_MS) unlinkSync(lockPath);\n      } catch { /* lock removed by another process — retry */ }\n    }\n    try {\n      // O_EXCL: atomic creation — fails if file already exists\n      const fd = openSync(lockPath, \"wx\");\n      closeSync(fd);\n      return; // lock acquired\n    } catch {\n      // Another process holds the lock — exponential backoff\n      const delay = LOCK_BASE_DELAY_MS * Math.pow(2, i);\n      const start = Date.now();\n      while (Date.now() - start < delay) { /* spin-wait */ }\n    }\n  }\n  throw new Error(`[writeRegistryAtomic] could not acquire lock after ${LOCK_RETRIES} retries`);\n}\n\nexport function writeRegistryAtomic(registryPath: string, data: unknown): void {\n  const lockPath = registryPath + \".lock\";\n  acquireLock(lockPath);\n  try {\n    const tmp = registryPath + \".tmp\";\n    const json = JSON.stringify(data, null, 2);\n    writeFileSync(tmp, json, \"utf8\");\n    const fd = openSync(tmp, \"r+\");\n    try {\n      fsyncSync(fd);\n    } finally {\n      closeSync(fd);\n    }\n    renameSync(tmp, registryPath);\n  } finally {\n    try { unlinkSync(lockPath); } catch { /* already removed — harmless */ }\n  }\n}\n\nexport function saveRegistry(registry: Record<string, string>): void {\n  if (!existsSync(PROJECTS_DIR)) mkdirSync(PROJECTS_DIR, { recursive: true });\n  writeRegistryAtomic(REGISTRY_PATH, registry);\n}\n\nexport function registerPath(cwd: string, name: string): void {\n  const registry = loadRegistry();\n  registry[cwd] = name;\n  saveRegistry(registry);\n}\n\nfunction makeResult(name: string, registeredPath: string | null, isNew: boolean): ProjectResolution {\n  return { name, projectDir: join(PROJECTS_DIR, name), isNew, registeredPath };\n}\n\nexport function resolveProject(cwd: string): ProjectResolution {\n  const registry = loadRegistry();\n\n  // 1. Exact match\n  if (registry[cwd]) {\n    return makeResult(registry[cwd], cwd, false);\n  }\n\n  // 2. Longest prefix match\n  const sortedPaths = Object.keys(registry).sort((a, b) => b.length - a.length);\n  for (const path of sortedPaths) {\n    if (cwd.startsWith(path + \"/\") || cwd.startsWith(path + sep)) {\n      return makeResult(registry[path]!, path, false);\n    }\n  }\n\n  // 3. Slug fallback\n  const slug = deriveSlug(cwd);\n  const slugDir = join(PROJECTS_DIR, slug);\n  const contextFiles = [\"context-goals.md\", \"context-decisions.md\", \"context-progress.md\", \"context-gotchas.md\", \"context-summary.md\"];\n  const hasContent = contextFiles.some(f => existsSync(join(slugDir, f)));\n\n  return { name: slug, projectDir: slugDir, isNew: !hasContent, registeredPath: null };\n}","lineStart":1,"lineEnd":141,"totalLines":141,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/resolveProject.ts","time":{"start":1780925316834,"end":1780925316851}},"metadata":{"openai":{"itemId":"fc_0bae4afcba7d9c49016a26c384c100819190b22319fc102488"}},"id":"prt_ea76bbeb8001PtjTObn7XlEK5Q","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b9c50001G8sFAEGl49i3G6"}}
{"type":"tool_use","timestamp":1780925316881,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_TypQLzpDQQaEjVr9lzV05yM5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/proposalQueue.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/proposalQueue.ts</path>\n<type>file</type>\n<content>\n1: import { writeFileSync, existsSync, mkdirSync } from \"fs\"\n2: import { dirname } from \"path\"\n3: \n4: export interface MemoryProposal {\n5:   content: string\n6:   category: string\n7:   importance: number\n8:   source: string\n9: }\n10: \n11: export function writeProposals(proposalsPath: string, proposals: MemoryProposal[]): void {\n12:   const dir = dirname(proposalsPath)\n13:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true })\n14:   writeFileSync(proposalsPath, JSON.stringify({ proposals, generatedAt: Date.now() }, null, 2), \"utf8\")\n15: }\n\n(End of file - total 15 lines)\n</content>","metadata":{"preview":"import { writeFileSync, existsSync, mkdirSync } from \"fs\"\nimport { dirname } from \"path\"\n\nexport interface MemoryProposal {\n  content: string\n  category: string\n  importance: number\n  source: string\n}\n\nexport function writeProposals(proposalsPath: string, proposals: MemoryProposal[]): void {\n  const dir = dirname(proposalsPath)\n  if (!existsSync(dir)) mkdirSync(dir, { recursive: true })\n  writeFileSync(proposalsPath, JSON.stringify({ proposals, generatedAt: Date.now() }, null, 2), \"utf8\")\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/proposalQueue.ts","text":"import { writeFileSync, existsSync, mkdirSync } from \"fs\"\nimport { dirname } from \"path\"\n\nexport interface MemoryProposal {\n  content: string\n  category: string\n  importance: number\n  source: string\n}\n\nexport function writeProposals(proposalsPath: string, proposals: MemoryProposal[]): void {\n  const dir = dirname(proposalsPath)\n  if (!existsSync(dir)) mkdirSync(dir, { recursive: true })\n  writeFileSync(proposalsPath, JSON.stringify({ proposals, generatedAt: Date.now() }, null, 2), \"utf8\")\n}","lineStart":1,"lineEnd":15,"totalLines":15,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/proposalQueue.ts","time":{"start":1780925316849,"end":1780925316867}},"metadata":{"openai":{"itemId":"fc_0bae4afcba7d9c49016a26c384c1208191b38d1ca86b51decb"}},"id":"prt_ea76bbeee001CM0MD6goBycULY","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b9c50001G8sFAEGl49i3G6"}}
{"type":"tool_use","timestamp":1780925316881,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_59F1pcKsDLwcTiUjmESBMe10","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * llmExtract.ts — Shared LLM extraction logic for EvaluateSession and GitCommit.\n3:  * Sends text to an LLM and stores extracted decisions/gotchas/patterns as LTM memories.\n4:  */\n5: import type { MemoryProposal } from \"./proposalQueue.js\";\n6: \n7: import { learn, getLlmConfig, callLlm, type MemoryCategory } from \"@rohirik/openltm-core\";\n8: const SYSTEM_PROMPT = `Extract learnings from the provided text. Return ONLY valid JSON:\n9: {\"decisions\":[\"...\"],\"gotchas\":[\"...\"],\"patterns\":[\"...\"],\"progress\":\"...\"}\n10: - decisions: architectural choices made (max 5, <120 chars each)\n11: - gotchas: problems hit and how fixed (max 5, <120 chars each)\n12: - patterns: reusable patterns discovered (max 5, <120 chars each)\n13: - progress: single sentence of what was accomplished\n14: Empty array if nothing found. No markdown fences.`;\n15: \n16: const LEARN_ITEMS: Array<{ key: \"decisions\" | \"gotchas\" | \"patterns\"; category: MemoryCategory; importance: number }> = [\n17:   { key: \"decisions\", category: \"architecture\", importance: 3 },\n18:   { key: \"gotchas\",   category: \"gotcha\",       importance: 4 },\n19:   { key: \"patterns\",  category: \"pattern\",       importance: 3 },\n20: ];\n21: \n22: export interface ExtractOptions {\n23:   source: string;\n24:   tags?: string[];\n25:   sessionId?: string;\n26:   preamble?: string;\n27: }\n28: \n29: /** Returns the progress string if extracted, or undefined. */\n30: export async function extractAndLearn(\n31:   text: string,\n32:   projectName: string,\n33:   opts: ExtractOptions,\n34: ): Promise<string | undefined> {\n35:   const cfg = getLlmConfig();\n36:   if (!cfg) return;\n37: \n38:   const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n39: \n40:   const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n41:   if (!raw) return;\n42: \n43:   let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n44:   try {\n45:     extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n46:   } catch {\n47:     return undefined; // silent: LLM returned non-JSON; caller treats undefined as no learnings\n48:   }\n49: \n50:   for (const { key, category, importance } of LEARN_ITEMS) {\n51:     for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n52:       if (item.length > 10) {\n53:         learn({\n54:           content: item,\n55:           category,\n56:           importance,\n57:           project_scope: projectName,\n58:           source: opts.source,\n59:           tags: opts.tags,\n60:           skipExport: true,\n61:         });\n62:       }\n63:     }\n64:   }\n65: \n66:   return extracted.progress?.length > 5 ? extracted.progress : undefined;\n67: }\n68: \n69: /** Returns memory proposals without writing to the DB. Caller decides what to persist. */\n70: export async function extractProposals(\n71:   text: string,\n72:   projectName: string,\n73:   opts: ExtractOptions,\n74: ): Promise<{ proposals: MemoryProposal[]; progress: string | undefined }> {\n75:   const cfg = getLlmConfig();\n76:   if (!cfg) return { proposals: [], progress: undefined };\n77: \n78:   const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n79: \n80:   const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n81:   if (!raw) return { proposals: [], progress: undefined };\n82: \n83:   let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n84:   try {\n85:     extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n86:   } catch {\n87:     return { proposals: [], progress: undefined }; // silent: same as extractAndLearn — non-JSON LLM response\n88:   }\n89: \n90:   const proposals: MemoryProposal[] = [];\n91:   for (const { key, category, importance } of LEARN_ITEMS) {\n92:     for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n93:       if (item.length > 10) {\n94:         proposals.push({ content: item, category, importance, source: opts.source });\n95:       }\n96:     }\n97:   }\n98: \n99:   const progress = extracted.progress?.length > 5 ? extracted.progress : undefined;\n100:   return { proposals, progress };\n101: }\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"/**\n * llmExtract.ts — Shared LLM extraction logic for EvaluateSession and GitCommit.\n * Sends text to an LLM and stores extracted decisions/gotchas/patterns as LTM memories.\n */\nimport type { MemoryProposal } from \"./proposalQueue.js\";\n\nimport { learn, getLlmConfig, callLlm, type MemoryCategory } from \"@rohirik/openltm-core\";\nconst SYSTEM_PROMPT = `Extract learnings from the provided text. Return ONLY valid JSON:\n{\"decisions\":[\"...\"],\"gotchas\":[\"...\"],\"patterns\":[\"...\"],\"progress\":\"...\"}\n- decisions: architectural choices made (max 5, <120 chars each)\n- gotchas: problems hit and how fixed (max 5, <120 chars each)\n- patterns: reusable patterns discovered (max 5, <120 chars each)\n- progress: single sentence of what was accomplished\nEmpty array if nothing found. No markdown fences.`;\n\nconst LEARN_ITEMS: Array<{ key: \"decisions\" | \"gotchas\" | \"patterns\"; category: MemoryCategory; importance: number }> = [\n  { key: \"decisions\", category: \"architecture\", importance: 3 },\n  { key: \"gotchas\",   category: \"gotcha\",       importance: 4 },\n  { key: \"patterns\",  category: \"pattern\",       importance: 3 },\n];","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts","text":"/**\n * llmExtract.ts — Shared LLM extraction logic for EvaluateSession and GitCommit.\n * Sends text to an LLM and stores extracted decisions/gotchas/patterns as LTM memories.\n */\nimport type { MemoryProposal } from \"./proposalQueue.js\";\n\nimport { learn, getLlmConfig, callLlm, type MemoryCategory } from \"@rohirik/openltm-core\";\nconst SYSTEM_PROMPT = `Extract learnings from the provided text. Return ONLY valid JSON:\n{\"decisions\":[\"...\"],\"gotchas\":[\"...\"],\"patterns\":[\"...\"],\"progress\":\"...\"}\n- decisions: architectural choices made (max 5, <120 chars each)\n- gotchas: problems hit and how fixed (max 5, <120 chars each)\n- patterns: reusable patterns discovered (max 5, <120 chars each)\n- progress: single sentence of what was accomplished\nEmpty array if nothing found. No markdown fences.`;\n\nconst LEARN_ITEMS: Array<{ key: \"decisions\" | \"gotchas\" | \"patterns\"; category: MemoryCategory; importance: number }> = [\n  { key: \"decisions\", category: \"architecture\", importance: 3 },\n  { key: \"gotchas\",   category: \"gotcha\",       importance: 4 },\n  { key: \"patterns\",  category: \"pattern\",       importance: 3 },\n];\n\nexport interface ExtractOptions {\n  source: string;\n  tags?: string[];\n  sessionId?: string;\n  preamble?: string;\n}\n\n/** Returns the progress string if extracted, or undefined. */\nexport async function extractAndLearn(\n  text: string,\n  projectName: string,\n  opts: ExtractOptions,\n): Promise<string | undefined> {\n  const cfg = getLlmConfig();\n  if (!cfg) return;\n\n  const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n\n  const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n  if (!raw) return;\n\n  let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n  try {\n    extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n  } catch {\n    return undefined; // silent: LLM returned non-JSON; caller treats undefined as no learnings\n  }\n\n  for (const { key, category, importance } of LEARN_ITEMS) {\n    for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n      if (item.length > 10) {\n        learn({\n          content: item,\n          category,\n          importance,\n          project_scope: projectName,\n          source: opts.source,\n          tags: opts.tags,\n          skipExport: true,\n        });\n      }\n    }\n  }\n\n  return extracted.progress?.length > 5 ? extracted.progress : undefined;\n}\n\n/** Returns memory proposals without writing to the DB. Caller decides what to persist. */\nexport async function extractProposals(\n  text: string,\n  projectName: string,\n  opts: ExtractOptions,\n): Promise<{ proposals: MemoryProposal[]; progress: string | undefined }> {\n  const cfg = getLlmConfig();\n  if (!cfg) return { proposals: [], progress: undefined };\n\n  const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n\n  const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n  if (!raw) return { proposals: [], progress: undefined };\n\n  let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n  try {\n    extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n  } catch {\n    return { proposals: [], progress: undefined }; // silent: same as extractAndLearn — non-JSON LLM response\n  }\n\n  const proposals: MemoryProposal[] = [];\n  for (const { key, category, importance } of LEARN_ITEMS) {\n    for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n      if (item.length > 10) {\n        proposals.push({ content: item, category, importance, source: opts.source });\n      }\n    }\n  }\n\n  const progress = extracted.progress?.length > 5 ? extracted.progress : undefined;\n  return { proposals, progress };\n}","lineStart":1,"lineEnd":101,"totalLines":101,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts","time":{"start":1780925316842,"end":1780925316872}},"metadata":{"openai":{"itemId":"fc_0bae4afcba7d9c49016a26c384c1148191be4e302599e25f5c"}},"id":"prt_ea76bbee5001VKQv9F9DhvCbxe","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b9c50001G8sFAEGl49i3G6"}}
{"type":"tool_use","timestamp":1780925316888,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_UbUaIlB2OmbCs9rF758IPIzA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/context.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/context.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * context.ts — Per-project context items (goals, decisions, progress, gotchas)\n3:  * Replaces the 4 per-project Markdown context files.\n4:  * Used by: PreCompact, UpdateContext, Cleanup, SessionStart hooks.\n5:  */\n6: import { existsSync, mkdirSync, writeFileSync } from \"fs\";\n7: import { join } from \"path\";\n8: import { homedir } from \"os\";\n9: import { getDb, DB_PATH } from \"./shared-db.js\";\n10: import { learn } from \"./db.js\";\n11: \n12: export { DB_PATH };\n13: const CLAUDE_DIR   = join(homedir(), \".claude\");\n14: const PROJECTS_DIR = join(CLAUDE_DIR, \"projects\");\n15: \n16: export type ContextType = \"goal\" | \"decision\" | \"progress\" | \"gotcha\";\n17: \n18: export interface ContextItem {\n19:   id: number;\n20:   project_name: string;\n21:   type: ContextType;\n22:   content: string;\n23:   session_id: string | null;\n24:   permanent: number;\n25:   memory_id?: number;\n26:   created_at: string;\n27: }\n28: \n29: \n30: /** Budget-capped section for context-summary.md output. */\n31: function section(label: string, items: ContextItem[], budget: number): string {\n32:   if (items.length === 0) return \"\";\n33:   const lines = items.map(i => i.content);\n34:   const available = Math.max(0, budget - 2); // header(1) + trailing blank\n35:   if (lines.length <= available) {\n36:     return [`${label}`, ...lines, \"\"].join(\"\\n\");\n37:   }\n38:   const kept = lines.slice(-available);\n39:   return [`${label}`, ...kept, `… (${lines.length - available} more not shown)`, \"\"].join(\"\\n\");\n40: }\n41: \n42: /**\n43:  * Add a context item for a project.\n44:  * - goal: one row per project (delete+insert to maintain uniqueness)\n45:  * - decision/gotcha: permanent=1, append only\n46:  * - progress: permanent=0, dedup by session_id\n47:  * @param skipExport  Skip regenerating context-summary.md (use during bulk imports)\n48:  */\n49: export function addItem(\n50:   project: string,\n51:   type: ContextType,\n52:   content: string,\n53:   sessionId?: string,\n54:   skipExport = false\n55: ): void {\n56:   const db = getDb();\n57: \n58:   if (type === \"goal\") {\n59:     db.transaction(() => {\n60:       db.run(`DELETE FROM context_items WHERE type='goal' AND project_name=?`, [project]);\n61:       db.run(\n62:         `INSERT INTO context_items (project_name, type, content, session_id, permanent)\n63:          VALUES (?, 'goal', ?, ?, 0)`,\n64:         [project, content, sessionId ?? null]\n65:       );\n66:     })();\n67:   } else if (type === \"decision\" || type === \"gotcha\") {\n68:     db.run(\n69:       `INSERT INTO context_items (project_name, type, content, session_id, permanent)\n70:        VALUES (?, ?, ?, ?, 1)`,\n71:       [project, type, content, sessionId ?? null]\n72:     );\n73:   } else {\n74:     // progress — dedup by session_id\n75:     if (sessionId) {\n76:       const existing = db.query<{ id: number }, [string, string]>(\n77:         `SELECT id FROM context_items WHERE type='progress' AND project_name=? AND session_id=? LIMIT 1`\n78:       ).get(project, sessionId);\n79:       if (existing) return;\n80:     }\n81:     db.run(\n82:       `INSERT INTO context_items (project_name, type, content, session_id, permanent)\n83:        VALUES (?, 'progress', ?, ?, 0)`,\n84:       [project, content, sessionId ?? null]\n85:     );\n86:   }\n87: \n88:   if (!skipExport) exportContextMarkdown(project);\n89: }\n90: \n91: /**\n92:  * Retrieve context items for a project, optionally filtered by type.\n93:  */\n94: export function getItems(\n95:   project: string,\n96:   type?: ContextType,\n97:   limit?: number\n98: ): ContextItem[] {\n99:   const db = getDb();\n100: \n101:   if (type === \"progress\") {\n102:     const cap = limit ?? 20;\n103:     return db.query<ContextItem, [string]>(\n104:       `SELECT * FROM context_items WHERE type='progress' AND project_name=?\n105:        ORDER BY id DESC LIMIT ${cap}`\n106:     ).all(project).reverse();\n107:   }\n108: \n109:   if (type) {\n110:     return db.query<ContextItem, [string, string]>(\n111:       `SELECT * FROM context_items WHERE type=? AND project_name=? ORDER BY id ASC`\n112:     ).all(type, project);\n113:   }\n114: \n115:   return db.query<ContextItem, [string]>(\n116:     `SELECT * FROM context_items WHERE project_name=? ORDER BY id ASC`\n117:   ).all(project);\n118: }\n119: \n120: /**\n121:  * Trim progress items to last N for a project.\n122:  */\n123: export function trimProgress(project: string, max = 20): void {\n124:   getDb().run(\n125:     `DELETE FROM context_items WHERE type='progress' AND project_name=? AND id NOT IN\n126:      (SELECT id FROM context_items WHERE type='progress' AND project_name=? ORDER BY id DESC LIMIT ?)`,\n127:     [project, project, max]\n128:   );\n129: }\n130: \n131: /**\n132:  * Export context-summary.md for a project from DB contents.\n133:  * Keeps the file as a human-readable snapshot and backward-compat fallback.\n134:  */\n135: export function exportContextMarkdown(project: string): void {\n136:   const projectDir = join(PROJECTS_DIR, project);\n137:   if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n138: \n139:   const date = new Date().toISOString().slice(0, 10);\n140:   const summary = [\n141:     `# ${project} | ${date}\\n`,\n142:     section(\"GOAL:\",     getItems(project, \"goal\"),         10),\n143:     section(\"PROGRESS:\", getItems(project, \"progress\", 20), 20),\n144:     section(\"DEC:\",      getItems(project, \"decision\"),     15),\n145:     section(\"WATCH:\",    getItems(project, \"gotcha\"),       15),\n146:   ].join(\"\");\n147: \n148:   writeFileSync(join(projectDir, \"context-summary.md\"), summary);\n149: }\n150: \n151: /**\n152:  * Promote a decision or gotcha context_item into global LTM memories.\n153:  * Returns the new memory id, or null if the item is not promotable.\n154:  */\n155: export function promote(itemId: number): number | null {\n156:   const db = getDb();\n157:   const item = db.query<ContextItem, [number]>(\n158:     \"SELECT * FROM context_items WHERE id = ?\"\n159:   ).get(itemId);\n160:   if (!item || ![\"decision\", \"gotcha\"].includes(item.type)) return null;\n161:   const category = item.type === \"decision\" ? \"architecture\" : \"gotcha\";\n162:   const importance = item.type === \"gotcha\" ? 4 : 3;\n163:   const result = learn({\n164:     content: item.content,\n165:     category,\n166:     importance,\n167:     project_scope: item.project_name,\n168:     source: \"context_item\",\n169:   });\n170:   db.prepare(\"UPDATE context_items SET memory_id = ? WHERE id = ?\").run(result.id, itemId);\n171:   return result.id;\n172: }\n\n(End of file - total 172 lines)\n</content>","metadata":{"preview":"/**\n * context.ts — Per-project context items (goals, decisions, progress, gotchas)\n * Replaces the 4 per-project Markdown context files.\n * Used by: PreCompact, UpdateContext, Cleanup, SessionStart hooks.\n */\nimport { existsSync, mkdirSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { getDb, DB_PATH } from \"./shared-db.js\";\nimport { learn } from \"./db.js\";\n\nexport { DB_PATH };\nconst CLAUDE_DIR   = join(homedir(), \".claude\");\nconst PROJECTS_DIR = join(CLAUDE_DIR, \"projects\");\n\nexport type ContextType = \"goal\" | \"decision\" | \"progress\" | \"gotcha\";\n\nexport interface ContextItem {\n  id: number;\n  project_name: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/context.ts","text":"/**\n * context.ts — Per-project context items (goals, decisions, progress, gotchas)\n * Replaces the 4 per-project Markdown context files.\n * Used by: PreCompact, UpdateContext, Cleanup, SessionStart hooks.\n */\nimport { existsSync, mkdirSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { getDb, DB_PATH } from \"./shared-db.js\";\nimport { learn } from \"./db.js\";\n\nexport { DB_PATH };\nconst CLAUDE_DIR   = join(homedir(), \".claude\");\nconst PROJECTS_DIR = join(CLAUDE_DIR, \"projects\");\n\nexport type ContextType = \"goal\" | \"decision\" | \"progress\" | \"gotcha\";\n\nexport interface ContextItem {\n  id: number;\n  project_name: string;\n  type: ContextType;\n  content: string;\n  session_id: string | null;\n  permanent: number;\n  memory_id?: number;\n  created_at: string;\n}\n\n\n/** Budget-capped section for context-summary.md output. */\nfunction section(label: string, items: ContextItem[], budget: number): string {\n  if (items.length === 0) return \"\";\n  const lines = items.map(i => i.content);\n  const available = Math.max(0, budget - 2); // header(1) + trailing blank\n  if (lines.length <= available) {\n    return [`${label}`, ...lines, \"\"].join(\"\\n\");\n  }\n  const kept = lines.slice(-available);\n  return [`${label}`, ...kept, `… (${lines.length - available} more not shown)`, \"\"].join(\"\\n\");\n}\n\n/**\n * Add a context item for a project.\n * - goal: one row per project (delete+insert to maintain uniqueness)\n * - decision/gotcha: permanent=1, append only\n * - progress: permanent=0, dedup by session_id\n * @param skipExport  Skip regenerating context-summary.md (use during bulk imports)\n */\nexport function addItem(\n  project: string,\n  type: ContextType,\n  content: string,\n  sessionId?: string,\n  skipExport = false\n): void {\n  const db = getDb();\n\n  if (type === \"goal\") {\n    db.transaction(() => {\n      db.run(`DELETE FROM context_items WHERE type='goal' AND project_name=?`, [project]);\n      db.run(\n        `INSERT INTO context_items (project_name, type, content, session_id, permanent)\n         VALUES (?, 'goal', ?, ?, 0)`,\n        [project, content, sessionId ?? null]\n      );\n    })();\n  } else if (type === \"decision\" || type === \"gotcha\") {\n    db.run(\n      `INSERT INTO context_items (project_name, type, content, session_id, permanent)\n       VALUES (?, ?, ?, ?, 1)`,\n      [project, type, content, sessionId ?? null]\n    );\n  } else {\n    // progress — dedup by session_id\n    if (sessionId) {\n      const existing = db.query<{ id: number }, [string, string]>(\n        `SELECT id FROM context_items WHERE type='progress' AND project_name=? AND session_id=? LIMIT 1`\n      ).get(project, sessionId);\n      if (existing) return;\n    }\n    db.run(\n      `INSERT INTO context_items (project_name, type, content, session_id, permanent)\n       VALUES (?, 'progress', ?, ?, 0)`,\n      [project, content, sessionId ?? null]\n    );\n  }\n\n  if (!skipExport) exportContextMarkdown(project);\n}\n\n/**\n * Retrieve context items for a project, optionally filtered by type.\n */\nexport function getItems(\n  project: string,\n  type?: ContextType,\n  limit?: number\n): ContextItem[] {\n  const db = getDb();\n\n  if (type === \"progress\") {\n    const cap = limit ?? 20;\n    return db.query<ContextItem, [string]>(\n      `SELECT * FROM context_items WHERE type='progress' AND project_name=?\n       ORDER BY id DESC LIMIT ${cap}`\n    ).all(project).reverse();\n  }\n\n  if (type) {\n    return db.query<ContextItem, [string, string]>(\n      `SELECT * FROM context_items WHERE type=? AND project_name=? ORDER BY id ASC`\n    ).all(type, project);\n  }\n\n  return db.query<ContextItem, [string]>(\n    `SELECT * FROM context_items WHERE project_name=? ORDER BY id ASC`\n  ).all(project);\n}\n\n/**\n * Trim progress items to last N for a project.\n */\nexport function trimProgress(project: string, max = 20): void {\n  getDb().run(\n    `DELETE FROM context_items WHERE type='progress' AND project_name=? AND id NOT IN\n     (SELECT id FROM context_items WHERE type='progress' AND project_name=? ORDER BY id DESC LIMIT ?)`,\n    [project, project, max]\n  );\n}\n\n/**\n * Export context-summary.md for a project from DB contents.\n * Keeps the file as a human-readable snapshot and backward-compat fallback.\n */\nexport function exportContextMarkdown(project: string): void {\n  const projectDir = join(PROJECTS_DIR, project);\n  if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n\n  const date = new Date().toISOString().slice(0, 10);\n  const summary = [\n    `# ${project} | ${date}\\n`,\n    section(\"GOAL:\",     getItems(project, \"goal\"),         10),\n    section(\"PROGRESS:\", getItems(project, \"progress\", 20), 20),\n    section(\"DEC:\",      getItems(project, \"decision\"),     15),\n    section(\"WATCH:\",    getItems(project, \"gotcha\"),       15),\n  ].join(\"\");\n\n  writeFileSync(join(projectDir, \"context-summary.md\"), summary);\n}\n\n/**\n * Promote a decision or gotcha context_item into global LTM memories.\n * Returns the new memory id, or null if the item is not promotable.\n */\nexport function promote(itemId: number): number | null {\n  const db = getDb();\n  const item = db.query<ContextItem, [number]>(\n    \"SELECT * FROM context_items WHERE id = ?\"\n  ).get(itemId);\n  if (!item || ![\"decision\", \"gotcha\"].includes(item.type)) return null;\n  const category = item.type === \"decision\" ? \"architecture\" : \"gotcha\";\n  const importance = item.type === \"gotcha\" ? 4 : 3;\n  const result = learn({\n    content: item.content,\n    category,\n    importance,\n    project_scope: item.project_name,\n    source: \"context_item\",\n  });\n  db.prepare(\"UPDATE context_items SET memory_id = ? WHERE id = ?\").run(result.id, itemId);\n  return result.id;\n}","lineStart":1,"lineEnd":172,"totalLines":172,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/context.ts","time":{"start":1780925316862,"end":1780925316887}},"metadata":{"openai":{"itemId":"fc_0bae4afcba7d9c49016a26c384c12c8191ab8c25e687b1f14d"}},"id":"prt_ea76bbefb001SMczjEUJ4a3GT2","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b9c50001G8sFAEGl49i3G6"}}
{"type":"tool_use","timestamp":1780925316893,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_7cssDLqWEQU1eGJTXS7ukkOW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/docs/06-hooks.md","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/docs/06-hooks.md</path>\n<type>file</type>\n<content>\n1: # Hooks\n2: \n3: Hooks are the lifeblood of OpenLTM. They run automatically at session boundaries — no manual setup, no opt-in checklist, no \"remember to run this.\" On install, four Claude Code lifecycle hooks and one git post-commit hook wire themselves automatically. You see them only when something goes wrong.\n4: \n5: If a hook fails, run `/openltm:health` to diagnose.\n6: \n7: ---\n8: \n9: ## The five hooks\n10: \n11: **Four Claude Code lifecycle hooks** (wired in `hooks/hooks.json`):\n12: \n13: | Hook | Event | What It Does |\n14: |------|-------|-------------|\n15: | `SessionStart` | Session opens | Injects top memories + project context (goals, decisions, gotchas) |\n16: | `UpdateContext` | Session stops | Saves session progress to `context_items` |\n17: | `EvaluateSession` | Session stops | Extracts patterns from transcript into `memories` |\n18: | `PreCompact` | Before compaction | Snapshots context to `context-summary.md` so it survives |\n19: \n20: **One git post-commit hook** (wired into `.git/hooks/post-commit` by `scripts/install-wiring.ts`):\n21: \n22: | Hook | Event | What It Does |\n23: |------|-------|-------------|\n24: | `GitCommit` | After git commit | Extracts learnings from diffs (opt-in via `ltm.gitLearnEnabled`) |\n25: \n26: ---\n27: \n28: ## How they execute\n29: \n30: All hooks run via `hooks/bin/run-hook.sh` — a small wrapper that locates `bun` across Homebrew, nvm, and system installs before executing.\n31: \n32: This is not a luxury. Claude Code spawns hooks in a stripped-PATH subprocess environment, and bare `bun` lookups fail with `exit 127` on a fresh shell. The wrapper checks six common install paths before giving up. If you ever move `bun` somewhere unusual, add the path to `run-hook.sh`.\n33: \n34: ---\n35: \n36: ## Lifecycle at a glance\n37: \n38: ```\n39: SessionStart            ─▶ inject top memories + project context\n40:    │\n41:    │  (you work)\n42:    │\n43: SessionStop             ─▶ UpdateContext (save progress)\n44: SessionStop             ─▶ EvaluateSession (extract patterns)\n45:    │\n46: PreCompact              ─▶ snapshot context-summary.md\n47:    │\n48: git commit (if enabled) ─▶ GitCommit (extract from diffs)\n49: ```\n50: \n51: ---\n52: \n53: ## See also\n54: \n55: - [README](../README.md) — back to the top\n56: - [Architecture](03-architecture.md) — full hook architecture spec\n57: - [Configuration](04-configuration.md) — `gitLearnEnabled`, `gitLearnMinDiffChars`\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"# Hooks\n\nHooks are the lifeblood of OpenLTM. They run automatically at session boundaries — no manual setup, no opt-in checklist, no \"remember to run this.\" On install, four Claude Code lifecycle hooks and one git post-commit hook wire themselves automatically. You see them only when something goes wrong.\n\nIf a hook fails, run `/openltm:health` to diagnose.\n\n---\n\n## The five hooks\n\n**Four Claude Code lifecycle hooks** (wired in `hooks/hooks.json`):\n\n| Hook | Event | What It Does |\n|------|-------|-------------|\n| `SessionStart` | Session opens | Injects top memories + project context (goals, decisions, gotchas) |\n| `UpdateContext` | Session stops | Saves session progress to `context_items` |\n| `EvaluateSession` | Session stops | Extracts patterns from transcript into `memories` |\n| `PreCompact` | Before compaction | Snapshots context to `context-summary.md` so it survives |\n\n**One git post-commit hook** (wired into `.git/hooks/post-commit` by `scripts/install-wiring.ts`):","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/docs/06-hooks.md","text":"# Hooks\n\nHooks are the lifeblood of OpenLTM. They run automatically at session boundaries — no manual setup, no opt-in checklist, no \"remember to run this.\" On install, four Claude Code lifecycle hooks and one git post-commit hook wire themselves automatically. You see them only when something goes wrong.\n\nIf a hook fails, run `/openltm:health` to diagnose.\n\n---\n\n## The five hooks\n\n**Four Claude Code lifecycle hooks** (wired in `hooks/hooks.json`):\n\n| Hook | Event | What It Does |\n|------|-------|-------------|\n| `SessionStart` | Session opens | Injects top memories + project context (goals, decisions, gotchas) |\n| `UpdateContext` | Session stops | Saves session progress to `context_items` |\n| `EvaluateSession` | Session stops | Extracts patterns from transcript into `memories` |\n| `PreCompact` | Before compaction | Snapshots context to `context-summary.md` so it survives |\n\n**One git post-commit hook** (wired into `.git/hooks/post-commit` by `scripts/install-wiring.ts`):\n\n| Hook | Event | What It Does |\n|------|-------|-------------|\n| `GitCommit` | After git commit | Extracts learnings from diffs (opt-in via `ltm.gitLearnEnabled`) |\n\n---\n\n## How they execute\n\nAll hooks run via `hooks/bin/run-hook.sh` — a small wrapper that locates `bun` across Homebrew, nvm, and system installs before executing.\n\nThis is not a luxury. Claude Code spawns hooks in a stripped-PATH subprocess environment, and bare `bun` lookups fail with `exit 127` on a fresh shell. The wrapper checks six common install paths before giving up. If you ever move `bun` somewhere unusual, add the path to `run-hook.sh`.\n\n---\n\n## Lifecycle at a glance\n\n```\nSessionStart            ─▶ inject top memories + project context\n   │\n   │  (you work)\n   │\nSessionStop             ─▶ UpdateContext (save progress)\nSessionStop             ─▶ EvaluateSession (extract patterns)\n   │\nPreCompact              ─▶ snapshot context-summary.md\n   │\ngit commit (if enabled) ─▶ GitCommit (extract from diffs)\n```\n\n---\n\n## See also\n\n- [README](../README.md) — back to the top\n- [Architecture](03-architecture.md) — full hook architecture spec\n- [Configuration](04-configuration.md) — `gitLearnEnabled`, `gitLearnMinDiffChars`","lineStart":1,"lineEnd":57,"totalLines":57,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/docs/06-hooks.md","time":{"start":1780925316878,"end":1780925316891}},"metadata":{"openai":{"itemId":"fc_0bae4afcba7d9c49016a26c384c1348191b2a3c00d1a06f21c"}},"id":"prt_ea76bbeff0018gsmQMb4Vks4P2","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76b9c50001G8sFAEGl49i3G6"}}
{"type":"step_finish","timestamp":1780925317451,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"id":"prt_ea76bc146001MwNonnOJxcycmD","reason":"tool-calls","snapshot":"3f2a50d043f79c27831625ba0604c92f2cc4894a","messageID":"msg_ea76b9c50001G8sFAEGl49i3G6","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","type":"step-finish","tokens":{"total":54827,"input":710,"output":344,"reasoning":13,"cache":{"write":0,"read":53760}},"cost":0}}
{"type":"step_start","timestamp":1780925319817,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"id":"prt_ea76bca88001tOc6yIBk2NouVs","messageID":"msg_ea76bc2a9001k6FaMIsU2Q3zRf","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","snapshot":"f09fc7badfa68c946b978becb327d28bfb687695","type":"step-start"}}
{"type":"tool_use","timestamp":1780925325930,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_STgejJIaunwsXCAmwvyKtR9H","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/hookUtils.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/hookUtils.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * hookUtils.ts\n3:  * Shared utilities for Claude Code hooks.\n4:  */\n5: \n6: import { existsSync, readFileSync, writeFileSync } from \"fs\";\n7: import { logHook } from \"./hookLogger.js\";\n8: \n9: /**\n10:  * Run an async hook body safely. Never throws.\n11:  * Returns { ok: true, value } on success or { ok: false, error } on failure.\n12:  * On failure, writes structured JSON to stderr (Claude Code reads hook stderr)\n13:  * and records to the hook log.\n14:  */\n15: export async function safeRun<T>(\n16:   label: string,\n17:   fn: () => Promise<T>,\n18: ): Promise<{ ok: true; value: T } | { ok: false; error: Error }> {\n19:   try {\n20:     const value = await fn();\n21:     return { ok: true, value };\n22:   } catch (err) {\n23:     const error = err instanceof Error ? err : new Error(String(err));\n24:     logHook(label, \"error\", error.message, error.stack);\n25:     process.stderr.write(\n26:       JSON.stringify({\n27:         hook: label,\n28:         error: error.message,\n29:         stack: error.stack,\n30:         timestamp: new Date().toISOString(),\n31:       }) + \"\\n\",\n32:     );\n33:     return { ok: false, error };\n34:   }\n35: }\n36: \n37: /** Read stdin fully as a string. */\n38: export async function readStdin(): Promise<string> {\n39:   let result = \"\";\n40:   try {\n41:     for await (const chunk of Bun.stdin.stream()) {\n42:       result += new TextDecoder().decode(chunk);\n43:     }\n44:   } catch {} // silent: stdin may be closed or absent in non-interactive hook invocations\n45:   return result;\n46: }\n47: \n48: /** Read stdin and echo it to stdout (for passthrough hooks like Stop). */\n49: export async function readStdinPassthrough(): Promise<string> {\n50:   let result = \"\";\n51:   try {\n52:     for await (const chunk of Bun.stdin.stream()) {\n53:       result += new TextDecoder().decode(chunk);\n54:       process.stdout.write(chunk);\n55:     }\n56:   } catch {} // silent: same as readStdin — stream may close unexpectedly\n57:   return result;\n58: }\n59: \n60: /** Parse JSON input and extract cwd. Returns { input, cwd } or null if no cwd. */\n61: export function parseHookInput(raw: string): { input: Record<string, any>; cwd: string } | null {\n62:   let input: Record<string, any> = {};\n63:   try { input = JSON.parse(raw); } catch {} // silent: malformed stdin yields empty input; cwd check below handles it\n64: \n65:   const cwd: string = input.cwd || input.working_directory || input.session?.cwd || \"\";\n66:   if (!cwd) return null;\n67: \n68:   return { input, cwd };\n69: }\n70: \n71: /** Read a file safely, returning empty string if missing or unreadable. */\n72: export function readFileSafe(path: string): string {\n73:   if (!existsSync(path)) return \"\";\n74:   return readFileSync(path, \"utf-8\").trim();\n75: }\n76: \n77: /** Append a line to a file, creating it if needed. */\n78: export function appendLine(path: string, line: string): void {\n79:   const existing = readFileSafe(path);\n80:   const content = existing ? `${existing}\\n${line}\\n` : `${line}\\n`;\n81:   writeFileSync(path, content);\n82: }\n83: \n84: /** Trim content to the last N lines. */\n85: export function trimToLines(content: string, max: number): string {\n86:   const lines = content.split(\"\\n\");\n87:   if (lines.length <= max) return content;\n88:   return lines.slice(lines.length - max).join(\"\\n\");\n89: }\n90: \n91: /**\n92:  * Build a budget-capped section for context summaries.\n93:  * @param lines   Content lines (no header)\n94:  * @param label   Section heading text\n95:  * @param budget  Max total lines including header + trailing blank\n96:  */\n97: export function budgetSection(lines: string[], label: string, budget: number): string {\n98:   if (lines.length === 0) return \"\";\n99:   const available = Math.max(0, budget - 3); // header(2) + trailing blank\n100:   if (lines.length <= available) {\n101:     return [`## ${label}`, \"\", ...lines, \"\"].join(\"\\n\");\n102:   }\n103:   const kept = lines.slice(-available);\n104:   const omitted = lines.length - available;\n105:   return [`## ${label}`, \"\", ...kept, `… (${omitted} more entries not shown)`, \"\"].join(\"\\n\");\n106: }\n\n(End of file - total 106 lines)\n</content>","metadata":{"preview":"/**\n * hookUtils.ts\n * Shared utilities for Claude Code hooks.\n */\n\nimport { existsSync, readFileSync, writeFileSync } from \"fs\";\nimport { logHook } from \"./hookLogger.js\";\n\n/**\n * Run an async hook body safely. Never throws.\n * Returns { ok: true, value } on success or { ok: false, error } on failure.\n * On failure, writes structured JSON to stderr (Claude Code reads hook stderr)\n * and records to the hook log.\n */\nexport async function safeRun<T>(\n  label: string,\n  fn: () => Promise<T>,\n): Promise<{ ok: true; value: T } | { ok: false; error: Error }> {\n  try {\n    const value = await fn();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/hookUtils.ts","text":"/**\n * hookUtils.ts\n * Shared utilities for Claude Code hooks.\n */\n\nimport { existsSync, readFileSync, writeFileSync } from \"fs\";\nimport { logHook } from \"./hookLogger.js\";\n\n/**\n * Run an async hook body safely. Never throws.\n * Returns { ok: true, value } on success or { ok: false, error } on failure.\n * On failure, writes structured JSON to stderr (Claude Code reads hook stderr)\n * and records to the hook log.\n */\nexport async function safeRun<T>(\n  label: string,\n  fn: () => Promise<T>,\n): Promise<{ ok: true; value: T } | { ok: false; error: Error }> {\n  try {\n    const value = await fn();\n    return { ok: true, value };\n  } catch (err) {\n    const error = err instanceof Error ? err : new Error(String(err));\n    logHook(label, \"error\", error.message, error.stack);\n    process.stderr.write(\n      JSON.stringify({\n        hook: label,\n        error: error.message,\n        stack: error.stack,\n        timestamp: new Date().toISOString(),\n      }) + \"\\n\",\n    );\n    return { ok: false, error };\n  }\n}\n\n/** Read stdin fully as a string. */\nexport async function readStdin(): Promise<string> {\n  let result = \"\";\n  try {\n    for await (const chunk of Bun.stdin.stream()) {\n      result += new TextDecoder().decode(chunk);\n    }\n  } catch {} // silent: stdin may be closed or absent in non-interactive hook invocations\n  return result;\n}\n\n/** Read stdin and echo it to stdout (for passthrough hooks like Stop). */\nexport async function readStdinPassthrough(): Promise<string> {\n  let result = \"\";\n  try {\n    for await (const chunk of Bun.stdin.stream()) {\n      result += new TextDecoder().decode(chunk);\n      process.stdout.write(chunk);\n    }\n  } catch {} // silent: same as readStdin — stream may close unexpectedly\n  return result;\n}\n\n/** Parse JSON input and extract cwd. Returns { input, cwd } or null if no cwd. */\nexport function parseHookInput(raw: string): { input: Record<string, any>; cwd: string } | null {\n  let input: Record<string, any> = {};\n  try { input = JSON.parse(raw); } catch {} // silent: malformed stdin yields empty input; cwd check below handles it\n\n  const cwd: string = input.cwd || input.working_directory || input.session?.cwd || \"\";\n  if (!cwd) return null;\n\n  return { input, cwd };\n}\n\n/** Read a file safely, returning empty string if missing or unreadable. */\nexport function readFileSafe(path: string): string {\n  if (!existsSync(path)) return \"\";\n  return readFileSync(path, \"utf-8\").trim();\n}\n\n/** Append a line to a file, creating it if needed. */\nexport function appendLine(path: string, line: string): void {\n  const existing = readFileSafe(path);\n  const content = existing ? `${existing}\\n${line}\\n` : `${line}\\n`;\n  writeFileSync(path, content);\n}\n\n/** Trim content to the last N lines. */\nexport function trimToLines(content: string, max: number): string {\n  const lines = content.split(\"\\n\");\n  if (lines.length <= max) return content;\n  return lines.slice(lines.length - max).join(\"\\n\");\n}\n\n/**\n * Build a budget-capped section for context summaries.\n * @param lines   Content lines (no header)\n * @param label   Section heading text\n * @param budget  Max total lines including header + trailing blank\n */\nexport function budgetSection(lines: string[], label: string, budget: number): string {\n  if (lines.length === 0) return \"\";\n  const available = Math.max(0, budget - 3); // header(2) + trailing blank\n  if (lines.length <= available) {\n    return [`## ${label}`, \"\", ...lines, \"\"].join(\"\\n\");\n  }\n  const kept = lines.slice(-available);\n  const omitted = lines.length - available;\n  return [`## ${label}`, \"\", ...kept, `… (${omitted} more entries not shown)`, \"\"].join(\"\\n\");\n}","lineStart":1,"lineEnd":106,"totalLines":106,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/hookUtils.ts","time":{"start":1780925325924,"end":1780925325929}},"metadata":{"openai":{"itemId":"fc_0abacff16bf0b904016a26c38d5b488193ba6578b5f0d65d2a"}},"id":"prt_ea76be115001QAZ3eNh0hWBt12","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76bc2a9001k6FaMIsU2Q3zRf"}}
