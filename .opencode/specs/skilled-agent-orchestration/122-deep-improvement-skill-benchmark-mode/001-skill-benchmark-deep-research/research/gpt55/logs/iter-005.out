     1	# ─────────────────────────────────────────────────────────────────
     2	# MODEL BENCHMARK: EVALUATION LOOP (AUTONOMOUS MODE)
     3	# ─────────────────────────────────────────────────────────────────
     4	role: Model Benchmark Specialist using deep-agent-improvement model-benchmark mode autonomously
     5	purpose: Profile-driven model and prompt-framework benchmarking with deterministic fixture scoring and guarded promotion
     6	action: Resolve a benchmark profile, materialize fixtures, score model variants across fixtures, reduce evidence, and decide keep/reject/promote
     7	
     8	# ─────────────────────────────────────────────────────────────────
     9	# OPERATING MODE
    10	# ─────────────────────────────────────────────────────────────────
    11	operating_mode:
    12	  workflow: iterative_evaluation_loop
    13	  workflow_compliance: MANDATORY
    14	  workflow_execution: autonomous
    15	  approvals: none
    16	  tracking: append_only_jsonl_ledger
    17	  validation: profile_driven_fixture_scoring
    18	  promotion: guarded_canonical_only
    19	  description: |
    20	    Executes the model benchmark loop without step-by-step approval.
    21	    Each iteration: resolve profile -> run loop-host model-benchmark (materialize then run-benchmark) -> reduce -> decide.
    22	    The benchmark scores model or prompt-framework variants against deterministic fixtures using the selected scorer.
    23	    Stops when: max iterations reached, benchmark scores plateau (3+ identical aggregate scores),
    24	    infra failures exceed threshold, or reducer signals shouldStop.
    25	
    26	# ─────────────────────────────────────────────────────────────────
    27	# EVALUATION PHILOSOPHY
    28	# ─────────────────────────────────────────────────────────────────
    29	evaluation_philosophy:
    30	  principle: "Prove improvement before promotion"
    31	  approach: "Profile-driven fixture benchmarking with deterministic scoring"
    32	  mandate: "Every variant is bounded, every score is repeatable, every decision is auditable"
    33	
    34	# ─────────────────────────────────────────────────────────────────
    35	# USER INPUTS
    36	# ─────────────────────────────────────────────────────────────────
    37	user_inputs:
    38	  profile: "[PROFILE] - Path or ID of the benchmark profile. Default: .opencode/skills/deep-agent-improvement/assets/model-benchmark/benchmark-profiles/default.json."
    39	  scoring_method: "[SCORING_METHOD] - 'pattern' for the default heading/pattern matcher, '5dim' for the ported 5-dimension scorer. Default: pattern."
    40	  grader: "[GRADER] - 'noop' deterministic no-dispatch grader, 'mock', or 'llm' (model dispatch). Default: noop."
    41	  spec_folder: "[SPEC_FOLDER] - Spec folder path for benchmark runtime. REQUIRED."
    42	  max_iterations: "[MAX_ITERATIONS] - Maximum loop iterations before forced stop. Default: 5."
    43	  target_model: "[TARGET_MODEL] - Model identifier dispatched only when grader=llm. Optional; ignored for noop/mock graders."
    44	  execution_mode: "[EXECUTION_MODE] - AUTONOMOUS or INTERACTIVE. Derived from :auto/:confirm suffix."
    45	
    46	# ─────────────────────────────────────────────────────────────────
    47	# FIELD HANDLING
    48	# ─────────────────────────────────────────────────────────────────
    49	field_handling:
    50	  defaults:
    51	    profile_empty: ".opencode/skills/deep-agent-improvement/assets/model-benchmark/benchmark-profiles/default.json"
    52	    scoring_method_empty: "pattern"
    53	    grader_empty: "noop"
    54	    max_iterations_empty: "5"
    55	    target_model_empty: "Unused unless grader == 'llm'"
    56	  validation:
    57	    spec_folder_required: true
    58	    profile_must_resolve: "Profile path or ID must resolve to an existing profile JSON before phase_loop"
    59	    scoring_method_enum: "Must be one of: pattern, 5dim"
    60	    grader_enum: "Must be one of: noop, mock, llm"
    61	    target_model_required_when_llm: "When grader == 'llm', target_model MUST be provided"
    62	
    63	# ─────────────────────────────────────────────────────────────────
    64	# CONTEXT LOADING
    65	# ─────────────────────────────────────────────────────────────────
    66	context_loading:
    67	  trigger: "At workflow START, before phase_init"
    68	  mcp_integration:
    69	    tool: memory_search
    70	    note: "Call MCP tools directly - NEVER through Code Mode"
    71	    parameters: { query: "model benchmark context for {profile}", specFolder: "{spec_folder}", anchors: ['summary', 'decisions', 'state', 'improvement'] }
    72	  command_reference: "/memory:search"
    73	  when_to_skip: ["First-time benchmark of this profile", "User explicitly says 'skip context' or 'fresh start'", "No spec folder context exists"]
    74	  behavior:
    75	    if_context_found: "Surface prior benchmark history, best-known aggregate scores, and scoring-method trends before first iteration"
    76	    if_no_context: "Proceed to phase_init without delay"
    77	
    78	# ─────────────────────────────────────────────────────────────────
    79	# SKILL REFERENCE
