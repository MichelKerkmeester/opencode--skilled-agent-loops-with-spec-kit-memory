{"type":"text","timestamp":1781764291621,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"id":"prt_ed96d69c0001pKEEsXu4BRf5sU","messageID":"msg_ed96d4724001EM0Q4JhcIf6D4Z","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","type":"text","text":"The main `memory_save` entry point validates the existence probe before parsing; I’m checking whether that probe also enforces allowed roots before `parseMemoryFile` reads the user-supplied path.","time":{"start":1781764286912,"end":1781764291614},"metadata":{"openai":{"itemId":"msg_09c937c8af5e7c26016a3390beccdc8191b4212e8981732438","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781764291680,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_DCyrxO5cOmtaBEhWbjoP8zzO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":3000,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n3000:     // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n3001:     setImmediate(task);\n3002:   };\n3003:   const run = (): void => {\n3004:     void (async () => {\n3005:       try {\n3006:         if (enrichmentShuttingDown) return; // fenced before this run started — do not reopen the DB during shutdown\n3007:         let db: ReturnType<typeof requireDb>;\n3008:         try {\n3009:           db = requireDb();\n3010:         } catch {\n3011:           return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n3012:         }\n3013:         const row = db\n3014:           .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n3015:           .get(memoryId) as { importance_tier?: string } | undefined;\n3016:         if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n3017:           return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n3018:         }\n3019:         const result = await runPostInsertEnrichment(db, memoryId, parsed);\n3020:         if (enrichmentShuttingDown) return; // shutdown began during the embed await — do not write after the close checkpoint\n3021:         recordEnrichmentResult(db, memoryId, result);\n3022:         emitPostInsertEnrichmentSubscribers(memoryId, 'post-insert-enrichment-async');\n3023:       } catch (bgErr: unknown) {\n3024:         enrichmentFailureTotal++;\n3025:         enrichmentLastError = bgErr instanceof Error ? bgErr.message : String(bgErr);\n3026:         enrichmentLastErrorAt = new Date().toISOString();\n3027:         // Rate-limit the per-failure warning so a systemic failure burst cannot spam the log; the\n3028:         // running total + last error stay available via memory_health. Log the first few, then suppress\n3029:         // and fold a suppressed-count summary into the next emitted line.\n3030:         if (enrichmentFailureTotal <= 5 || enrichmentFailureTotal % 100 === 0) {\n3031:           const suppressed = enrichmentSuppressedWarnings;\n3032:           enrichmentSuppressedWarnings = 0;\n3033:           console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n3034:         } else {\n3035:           enrichmentSuppressedWarnings++;\n3036:         }\n3037:       } finally {\n3038:         activeBackgroundEnrichments--;\n3039:         if (!enrichmentShuttingDown) {\n3040:           const next = backgroundEnrichmentQueue.shift();\n3041:           if (next) start(next);\n3042:         }\n3043:       }\n3044:     })();\n3045:   };\n3046:   if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n3047:     start(run);\n3048:   } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n3049:     backgroundEnrichmentQueue.push(run);\n3050:   } else {\n3051:     // Overflow: drop rather than grow the queue (and its retained parsed payloads) without bound under\n3052:     // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n3053:     // path re-enriches it later. Surfaced via the dropped counter in memory_health.\n3054:     enrichmentDroppedTotal++;\n3055:   }\n3056: }\n3057: \n3058: /* --- 9. MEMORY SAVE HANDLER --- */\n3059: \n3060: /** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\n3061: async function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n3062:   // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n3063:   // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n3064:   // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n3065:   // carries a code (e.g. preflight.PreflightError) keeps it.\n3066:   const requestId = randomUUID();\n3067:   try {\n3068:     return await handleMemorySaveInner(args, requestId);\n3069:   } catch (error: unknown) {\n3070:     if (error instanceof VRuleUnavailableError) {\n3071:       return createMCPErrorResponse({\n3072:         tool: 'memory_save',\n3073:         error: error.message,\n3074:         code: 'E_RUNTIME',\n3075:         details: { requestId },\n3076:         recovery: {\n3077:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3078:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3079:           severity: 'warning',\n3080:         },\n3081:       });\n3082:     }\n3083:     const message = error instanceof Error ? error.message : String(error);\n3084:     const existingCode = (error as { code?: string }).code;\n3085:     const code = typeof existingCode === 'string' && existingCode.length > 0\n3086:       ? existingCode\n3087:       : classifySaveErrorCode(message);\n3088:     return createMCPErrorResponse({\n3089:       tool: 'memory_save',\n3090:       error: message,\n3091:       code,\n3092:       details: { requestId, ...extractSaveErrorDetails(message) },\n3093:       recovery: {\n3094:         hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n3095:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3096:         severity: 'warning',\n3097:       },\n3098:     });\n3099:   }\n3100: }\n3101: \n3102: async function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n3103:   await ensureMemoryRuntimeInitialized('handler:memory_save');\n3104: \n3105:   // Fail fast with a clear message when the target file does not exist, before any\n3106:   // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n3107:   // caller-supplied path is safe to echo back.\n3108:   if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n3109:     const probePath = path.isAbsolute(args.filePath)\n3110:       ? args.filePath\n3111:       : path.resolve(process.cwd(), args.filePath);\n3112:     if (!fs.existsSync(probePath)) {\n3113:       return createMCPErrorResponse({\n3114:         tool: 'memory_save',\n3115:         error: `File not found: ${probePath}`,\n3116:         code: 'E089',\n3117:         details: { requestId, filePath: probePath },\n3118:         recovery: {\n3119:           hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n3120:           actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n3121:           severity: 'warning',\n3122:         },\n3123:       });\n3124:     }\n3125:   }\n3126: \n3127:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n3128: \n3129:   if (restoreBarrier) {\n3130:     return createMCPErrorResponse({\n3131:       tool: 'memory_save',\n3132:       error: restoreBarrier.message,\n3133:       code: restoreBarrier.code,\n3134:       details: {\n3135:         requestId,\n3136:       },\n3137:       recovery: {\n3138:         hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n3139:         actions: ['Wait for the restore to finish', 'Retry the save request'],\n3140:         severity: 'warning',\n3141:       },\n3142:     });\n3143:   }\n3144: \n3145:   const {\n3146:     filePath: file_path,\n3147:     force = false,\n3148:     dryRun = false,\n3149:     plannerMode: requestedPlannerMode,\n3150:     skipPreflight = false,\n3151:     asyncEmbedding = false,\n3152:     routeAs,\n3153:     mergeModeHint,\n3154:     targetAnchorId,\n3155:     tenantId,\n3156:     userId,\n3157:     agentId,\n3158:     sessionId,\n3159:     provenanceSource,\n3160:     provenanceActor,\n3161:     governedAt,\n3162:     retentionPolicy,\n3163:     deleteAfter,\n3164:   } = args;\n3165:   const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n3166:   const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n3167: \n3168:   // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n3169:   // Return a classified validation error instead of a bare throw, which the dispatcher would\n3170:   // otherwise flatten into the generic \"unexpected error\" (E081).\n3171:   if (!file_path || typeof file_path !== 'string') {\n3172:     return createMCPErrorResponse({\n3173:       tool: 'memory_save',\n3174:       error: 'filePath is required and must be a string',\n3175:       code: 'E089',\n3176:       details: { requestId },\n3177:       recovery: {\n3178:         hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n3179:         actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n3180:         severity: 'warning',\n3181:       },\n3182:     });\n3183:   }\n3184: \n3185:   await checkDatabaseUpdated();\n3186: \n3187:   const validatedPath: string = validateFilePathLocal(file_path);\n3188:   const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n3189:   const database = requireDb();\n3190: \n3191:   if (!shouldIndexForMemory(canonicalValidatedPath)) {\n3192:     return createIndexScopeExcludedResponse(requestId, canonicalValidatedPath, validatedPath);\n3193:   }\n3194: \n3195:   // A non-canonical target (e.g. a scratch file outside specs/**) returns a clear\n3196:   // validation error rather than a bare throw the dispatcher would surface as E081.\n3197:   if (!memoryParser.isMemoryFile(validatedPath)) {\n3198:     return createMCPErrorResponse({\n3199:       tool: 'memory_save',\n3200:       error: 'File must be a canonical spec document under specs/**/ (spec.md, plan.md, tasks.md, checklist.md, decision-record.md, implementation-summary.md, handover.md, research.md, resource-map.md, review-report.md, description.json, graph-metadata.json) or a constitutional memory under .opencode/skills/*/constitutional/',\n3201:       code: 'E089',\n3202:       details: { requestId, filePath: validatedPath },\n3203:       recovery: {\n3204:         hint: 'Save a canonical spec document or constitutional memory; scratch files outside specs/** are not indexable.',\n3205:         actions: ['Move the content into a spec folder under specs/** or .opencode/specs/**', 'Retry memory_save with the canonical path'],\n3206:         severity: 'warning',\n3207:       },\n3208:     });\n3209:   }\n3210: \n3211:   // Fail fast with a clear message when a spec doc's folder lacks both structural\n3212:   // metadata files, instead of the generic save \"unexpected error\" (E081).\n3213:   if (path.basename(canonicalValidatedPath) !== 'description.json'\n3214:     && path.basename(canonicalValidatedPath) !== 'graph-metadata.json'\n3215:     && !canonicalValidatedPath.includes('/constitutional/')) {\n3216:     const specFolderDir = path.dirname(canonicalValidatedPath);\n3217:     const missingMetadata = ['description.json', 'graph-metadata.json']\n3218:       .filter((name) => !fs.existsSync(path.join(specFolderDir, name)));\n3219:     if (missingMetadata.length === 2) {\n3220:       return createMCPErrorResponse({\n3221:         tool: 'memory_save',\n3222:         error: `Spec folder is missing required metadata (${missingMetadata.join(', ')}): ${specFolderDir}`,\n3223:         code: 'E089',\n3224:         details: { requestId, filePath: canonicalValidatedPath, missingMetadata },\n3225:         recovery: {\n3226:           hint: 'Generate the spec-folder metadata before indexing its other documents.',\n3227:           actions: ['Run generate-context.js / generate-description.js for this spec folder', 'Then retry memory_save'],\n3228:           severity: 'warning',\n3229:         },\n3230:       });\n3231:     }\n3232:   }\n3233: \n3234:   if (typeof database.exec === 'function') {\n3235:     ensureGovernanceRuntime(database);\n3236:   }\n3237: \n3238:   const governanceDecision = validateGovernedIngest({\n3239:     tenantId,\n3240:     userId,\n3241:     agentId,\n3242:     sessionId,\n3243:     provenanceSource,\n3244:     provenanceActor,\n3245:     governedAt,\n3246:     retentionPolicy,\n3247:     deleteAfter,\n3248:   });\n3249: \n3250:   if (!governanceDecision.allowed) {\n3251:     recordGovernanceAudit(database, {\n3252:       action: 'memory_save',\n3253:       decision: 'deny',\n3254:       tenantId,\n3255:       userId,\n3256:       agentId,\n3257:       sessionId,\n3258:       reason: governanceDecision.reason ?? 'governance_rejected',\n3259:       metadata: { issues: governanceDecision.issues },\n\n(Showing lines 3000-3259 of 4082. Use offset=3260 to continue.)\n</content>","metadata":{"preview":"    // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n    setImmediate(task);\n  };\n  const run = (): void => {\n    void (async () => {\n      try {\n        if (enrichmentShuttingDown) return; // fenced before this run started — do not reopen the DB during shutdown\n        let db: ReturnType<typeof requireDb>;\n        try {\n          db = requireDb();\n        } catch {\n          return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n        }\n        const row = db\n          .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n          .get(memoryId) as { importance_tier?: string } | undefined;\n        if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n          return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n        }\n        const result = await runPostInsertEnrichment(db, memoryId, parsed);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"    // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n    setImmediate(task);\n  };\n  const run = (): void => {\n    void (async () => {\n      try {\n        if (enrichmentShuttingDown) return; // fenced before this run started — do not reopen the DB during shutdown\n        let db: ReturnType<typeof requireDb>;\n        try {\n          db = requireDb();\n        } catch {\n          return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n        }\n        const row = db\n          .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n          .get(memoryId) as { importance_tier?: string } | undefined;\n        if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n          return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n        }\n        const result = await runPostInsertEnrichment(db, memoryId, parsed);\n        if (enrichmentShuttingDown) return; // shutdown began during the embed await — do not write after the close checkpoint\n        recordEnrichmentResult(db, memoryId, result);\n        emitPostInsertEnrichmentSubscribers(memoryId, 'post-insert-enrichment-async');\n      } catch (bgErr: unknown) {\n        enrichmentFailureTotal++;\n        enrichmentLastError = bgErr instanceof Error ? bgErr.message : String(bgErr);\n        enrichmentLastErrorAt = new Date().toISOString();\n        // Rate-limit the per-failure warning so a systemic failure burst cannot spam the log; the\n        // running total + last error stay available via memory_health. Log the first few, then suppress\n        // and fold a suppressed-count summary into the next emitted line.\n        if (enrichmentFailureTotal <= 5 || enrichmentFailureTotal % 100 === 0) {\n          const suppressed = enrichmentSuppressedWarnings;\n          enrichmentSuppressedWarnings = 0;\n          console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n        } else {\n          enrichmentSuppressedWarnings++;\n        }\n      } finally {\n        activeBackgroundEnrichments--;\n        if (!enrichmentShuttingDown) {\n          const next = backgroundEnrichmentQueue.shift();\n          if (next) start(next);\n        }\n      }\n    })();\n  };\n  if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n    start(run);\n  } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n    backgroundEnrichmentQueue.push(run);\n  } else {\n    // Overflow: drop rather than grow the queue (and its retained parsed payloads) without bound under\n    // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n    // path re-enriches it later. Surfaced via the dropped counter in memory_health.\n    enrichmentDroppedTotal++;\n  }\n}\n\n/* --- 9. MEMORY SAVE HANDLER --- */\n\n/** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\nasync function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n  // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n  // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n  // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n  // carries a code (e.g. preflight.PreflightError) keeps it.\n  const requestId = randomUUID();\n  try {\n    return await handleMemorySaveInner(args, requestId);\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    const message = error instanceof Error ? error.message : String(error);\n    const existingCode = (error as { code?: string }).code;\n    const code = typeof existingCode === 'string' && existingCode.length > 0\n      ? existingCode\n      : classifySaveErrorCode(message);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: message,\n      code,\n      details: { requestId, ...extractSaveErrorDetails(message) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n}\n\nasync function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_save');\n\n  // Fail fast with a clear message when the target file does not exist, before any\n  // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n  // caller-supplied path is safe to echo back.\n  if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n    const probePath = path.isAbsolute(args.filePath)\n      ? args.filePath\n      : path.resolve(process.cwd(), args.filePath);\n    if (!fs.existsSync(probePath)) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `File not found: ${probePath}`,\n        code: 'E089',\n        details: { requestId, filePath: probePath },\n        recovery: {\n          hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n          actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        requestId,\n      },\n      recovery: {\n        hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the save request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    filePath: file_path,\n    force = false,\n    dryRun = false,\n    plannerMode: requestedPlannerMode,\n    skipPreflight = false,\n    asyncEmbedding = false,\n    routeAs,\n    mergeModeHint,\n    targetAnchorId,\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  } = args;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n  // Return a classified validation error instead of a bare throw, which the dispatcher would\n  // otherwise flatten into the generic \"unexpected error\" (E081).\n  if (!file_path || typeof file_path !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'filePath is required and must be a string',\n      code: 'E089',\n      details: { requestId },\n      recovery: {\n        hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n        actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const validatedPath: string = validateFilePathLocal(file_path);\n  const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n  const database = requireDb();\n\n  if (!shouldIndexForMemory(canonicalValidatedPath)) {\n    return createIndexScopeExcludedResponse(requestId, canonicalValidatedPath, validatedPath);\n  }\n\n  // A non-canonical target (e.g. a scratch file outside specs/**) returns a clear\n  // validation error rather than a bare throw the dispatcher would surface as E081.\n  if (!memoryParser.isMemoryFile(validatedPath)) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'File must be a canonical spec document under specs/**/ (spec.md, plan.md, tasks.md, checklist.md, decision-record.md, implementation-summary.md, handover.md, research.md, resource-map.md, review-report.md, description.json, graph-metadata.json) or a constitutional memory under .opencode/skills/*/constitutional/',\n      code: 'E089',\n      details: { requestId, filePath: validatedPath },\n      recovery: {\n        hint: 'Save a canonical spec document or constitutional memory; scratch files outside specs/** are not indexable.',\n        actions: ['Move the content into a spec folder under specs/** or .opencode/specs/**', 'Retry memory_save with the canonical path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Fail fast with a clear message when a spec doc's folder lacks both structural\n  // metadata files, instead of the generic save \"unexpected error\" (E081).\n  if (path.basename(canonicalValidatedPath) !== 'description.json'\n    && path.basename(canonicalValidatedPath) !== 'graph-metadata.json'\n    && !canonicalValidatedPath.includes('/constitutional/')) {\n    const specFolderDir = path.dirname(canonicalValidatedPath);\n    const missingMetadata = ['description.json', 'graph-metadata.json']\n      .filter((name) => !fs.existsSync(path.join(specFolderDir, name)));\n    if (missingMetadata.length === 2) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `Spec folder is missing required metadata (${missingMetadata.join(', ')}): ${specFolderDir}`,\n        code: 'E089',\n        details: { requestId, filePath: canonicalValidatedPath, missingMetadata },\n        recovery: {\n          hint: 'Generate the spec-folder metadata before indexing its other documents.',\n          actions: ['Run generate-context.js / generate-description.js for this spec folder', 'Then retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  if (typeof database.exec === 'function') {\n    ensureGovernanceRuntime(database);\n  }\n\n  const governanceDecision = validateGovernedIngest({\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  });\n\n  if (!governanceDecision.allowed) {\n    recordGovernanceAudit(database, {\n      action: 'memory_save',\n      decision: 'deny',\n      tenantId,\n      userId,\n      agentId,\n      sessionId,\n      reason: governanceDecision.reason ?? 'governance_rejected',\n      metadata: { issues: governanceDecision.issues },","lineStart":3000,"lineEnd":3259,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781764291669,"end":1781764291679}},"metadata":{"openai":{"itemId":"fc_09c937c8af5e7c26016a3390c38d708191a3ac423184bd56ac"}},"id":"prt_ed96d7c22001fHalSrFmJvkgc5","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed96d4724001EM0Q4JhcIf6D4Z"}}
