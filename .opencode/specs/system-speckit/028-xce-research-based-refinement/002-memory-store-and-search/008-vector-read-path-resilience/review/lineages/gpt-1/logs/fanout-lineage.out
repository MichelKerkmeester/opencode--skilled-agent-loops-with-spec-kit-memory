;\n      try {\n        const rows = new_db.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n        const first = rows?.[0] ? Object.values(rows[0])[0] : undefined;\n        probe_verdict = typeof first === 'string' ? first : 'quick_check returned no verdict';\n      } catch (probe_error: unknown) {\n        probe_verdict = get_error_message(probe_error);\n      }\n      if (probe_verdict !== 'ok') {\n        const msg = `post-crash integrity probe failed: ${probe_verdict}`;\n        console.error(`[vector-index] FATAL: ${msg}`);\n        console.error('[vector-index] Wrote checkpoint needs-rebuild sentinel; the next boot rebuilds cleanly instead of serving corrupted data.');\n        write_needs_rebuild_sentinel_for_corruption(target_path, probe_verdict);\n        try { new_db.close(); } catch (_: unknown) { /* best-effort */ }\n        throw new VectorIndexError(msg, VectorIndexErrorCode.INTEGRITY_ERROR);\n      }\n    }\n  }\n\n  write_unclean_shutdown_marker(target_path);\n\n  if (target_path !== ':memory:') {\n    const startupShardPath = get_vector_shard_path(startupProfile, path.dirname(target_path));\n    if (!fs.existsSync(startupShardPath)) {\n      const canonicalDimCheck = validate_embedding_dimension_for_connection(new_db, vec_available);\n      if (!canonicalDimCheck.valid && canonicalDimCheck.stored != null) {\n        const msg = canonicalDimCheck.warning ||\n          `Embedding dimension mismatch: DB=${canonicalDimCheck.stored}, provider=${canonicalDimCheck.current}`;\n        console.error(`[vector-index] FATAL: ${msg}`);\n        try { new_db.close(); } catch (_: unknown) { /* best-effort */ }\n        throw new VectorIndexError(msg, VectorIndexErrorCode.INTEGRITY_ERROR);\n      }\n    }\n  }\n\n  attachActiveVectorShard(new_db, startupProfile);\n\n  const preBootstrapDimCheck = validate_embedding_dimension_for_connection(new_db, vec_available);\n  if (!preBootstrapDimCheck.valid && preBootstrapDimCheck.stored != null) {\n    const msg = preBootstrapDimCheck.warning ||\n      `Embedding dimension mismatch: DB=${preBootstrapDimCheck.stored}, provider=${preBootstrapDimCheck.current}`;\n    console.error(`[vector-index] FATAL: ${msg}`);\n    try { new_db.close(); } catch (_: unknown) { /* best-effort */ }\n    throw new VectorIndexError(msg, VectorIndexErrorCode.INTEGRITY_ERROR);\n  }","lineStart":1740,"lineEnd":1819,"totalLines":1989,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1781151294922,"end":1781151294925}},"metadata":{"openai":{"itemId":"fc_0a3c79976b7d1942016a2a363ed3c88191a3d16069cfb404db"}},"id":"prt_eb4e3e5c0001k7i53iN8PHlgmc","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3bebc001TVrc4Vv5DX0iRt"}}
{"type":"tool_use","timestamp":1781151294962,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_1anreKYbFZmwDCn0FgYDPIUC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","offset":720,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts</path>\n<type>file</type>\n<content>\n720:     INSERT INTO embedder_jobs (\n721:       id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n722:     ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n723:   `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n724: \n725:   if (runtimeOptions.vectorShardRepair) {\n726:     vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n727:   }\n728: \n729:   if (runtimeOptions.autoStart !== false) {\n730:     enqueueJob(db, id);\n731:   }\n732: \n733:   return id;\n734: }\n735: \n736: export function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n737:   return selectJob(resolveDb(db), jobId);\n738: }\n739: \n740: export function getActiveJob(db?: Database.Database): ReindexJob | null {\n741:   return selectActiveJob(resolveDb(db));\n742: }\n743: \n744: export function cancelJob(jobId: string, db?: Database.Database): ReindexJob | null {\n745:   const resolvedDb = resolveDb(db);\n746:   ensureJobTable(resolvedDb);\n747:   const job = selectJob(resolvedDb, jobId);\n748:   if (!job) {\n749:     return null;\n750:   }\n751: \n752:   if (job.status === 'completed' || job.status === 'failed' || job.status === 'cancelled') {\n753:     return job;\n754:   }\n755: \n756:   setJobStatus(resolvedDb, jobId, 'cancelled');\n757:   return selectJob(resolvedDb, jobId);\n758: }\n759: \n760: export function resumeReindexJobs(db?: Database.Database): ReindexJob[] {\n761:   const resolvedDb = resolveDb(db);\n762:   requireDatabaseDir(resolvedDb, 'resume');\n763:   ensureJobTable(resolvedDb);\n764:   const rows = resolvedDb.prepare(`\n765:     SELECT ${JOB_SELECT_COLUMNS}\n766:     FROM embedder_jobs\n767:     WHERE status IN ('queued', 'running')\n768:     ORDER BY started_at ASC, id ASC\n769:   `).all() as JobRow[];\n770: \n771:   const jobs = rows.map(jobFromRow);\n772:   for (const job of jobs) {\n773:     enqueueJob(resolvedDb, job.id);\n774:   }\n775:   return jobs;\n776: }\n777: \n778: export function startReindexForTest(\n779:   options: StartReindexOptions,\n780:   runtimeOptions: ReindexInternalRuntimeOptions = {},\n781: ): string {\n782:   return startReindexInternal(options, runtimeOptions);\n783: }\n784: \n785: export function startVectorShardRepairReindex(\n786:   profile: EmbeddingProfile,\n787:   runtimeOptions: ReindexRuntimeOptions & { readonly reason: string; readonly shardPath: string; readonly autoStart?: boolean },\n788: ): string {\n789:   return startReindexInternal(\n790:     { toName: profile.model },\n791:     {\n792:       db: runtimeOptions.db,\n793:       autoStart: runtimeOptions.autoStart,\n794:       vectorShardRepair: {\n795:         reason: runtimeOptions.reason,\n796:         shardPath: runtimeOptions.shardPath,\n797:       },\n798:     },\n799:   );\n800: }\n801: \n802: export function estimateEta(job: ReindexJob | null): number | null {\n803:   if (!job || job.status === 'completed') {\n804:     return 0;\n805:   }\n806:   if (job.processed <= 0 || job.total <= 0) {\n807:     return null;\n808:   }\n809: \n810:   const elapsedMs = Date.now() - Date.parse(job.startedAt);\n811:   if (!Number.isFinite(elapsedMs) || elapsedMs <= 0) {\n812:     return null;\n813:   }\n814: \n815:   const ratePerMs = job.processed / elapsedMs;\n816:   if (ratePerMs <= 0) {\n817:     return null;\n818:   }\n819: \n820:   return Math.ceil((job.total - job.processed) / ratePerMs / 1000);\n821: }\n\n(End of file - total 821 lines)\n</content>","metadata":{"preview":"    INSERT INTO embedder_jobs (\n      id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n    ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n  `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n\n  if (runtimeOptions.vectorShardRepair) {\n    vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n  }\n\n  if (runtimeOptions.autoStart !== false) {\n    enqueueJob(db, id);\n  }\n\n  return id;\n}\n\nexport function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n  return selectJob(resolveDb(db), jobId);\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","text":"    INSERT INTO embedder_jobs (\n      id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n    ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n  `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n\n  if (runtimeOptions.vectorShardRepair) {\n    vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n  }\n\n  if (runtimeOptions.autoStart !== false) {\n    enqueueJob(db, id);\n  }\n\n  return id;\n}\n\nexport function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n  return selectJob(resolveDb(db), jobId);\n}\n\nexport function getActiveJob(db?: Database.Database): ReindexJob | null {\n  return selectActiveJob(resolveDb(db));\n}\n\nexport function cancelJob(jobId: string, db?: Database.Database): ReindexJob | null {\n  const resolvedDb = resolveDb(db);\n  ensureJobTable(resolvedDb);\n  const job = selectJob(resolvedDb, jobId);\n  if (!job) {\n    return null;\n  }\n\n  if (job.status === 'completed' || job.status === 'failed' || job.status === 'cancelled') {\n    return job;\n  }\n\n  setJobStatus(resolvedDb, jobId, 'cancelled');\n  return selectJob(resolvedDb, jobId);\n}\n\nexport function resumeReindexJobs(db?: Database.Database): ReindexJob[] {\n  const resolvedDb = resolveDb(db);\n  requireDatabaseDir(resolvedDb, 'resume');\n  ensureJobTable(resolvedDb);\n  const rows = resolvedDb.prepare(`\n    SELECT ${JOB_SELECT_COLUMNS}\n    FROM embedder_jobs\n    WHERE status IN ('queued', 'running')\n    ORDER BY started_at ASC, id ASC\n  `).all() as JobRow[];\n\n  const jobs = rows.map(jobFromRow);\n  for (const job of jobs) {\n    enqueueJob(resolvedDb, job.id);\n  }\n  return jobs;\n}\n\nexport function startReindexForTest(\n  options: StartReindexOptions,\n  runtimeOptions: ReindexInternalRuntimeOptions = {},\n): string {\n  return startReindexInternal(options, runtimeOptions);\n}\n\nexport function startVectorShardRepairReindex(\n  profile: EmbeddingProfile,\n  runtimeOptions: ReindexRuntimeOptions & { readonly reason: string; readonly shardPath: string; readonly autoStart?: boolean },\n): string {\n  return startReindexInternal(\n    { toName: profile.model },\n    {\n      db: runtimeOptions.db,\n      autoStart: runtimeOptions.autoStart,\n      vectorShardRepair: {\n        reason: runtimeOptions.reason,\n        shardPath: runtimeOptions.shardPath,\n      },\n    },\n  );\n}\n\nexport function estimateEta(job: ReindexJob | null): number | null {\n  if (!job || job.status === 'completed') {\n    return 0;\n  }\n  if (job.processed <= 0 || job.total <= 0) {\n    return null;\n  }\n\n  const elapsedMs = Date.now() - Date.parse(job.startedAt);\n  if (!Number.isFinite(elapsedMs) || elapsedMs <= 0) {\n    return null;\n  }\n\n  const ratePerMs = job.processed / elapsedMs;\n  if (ratePerMs <= 0) {\n    return null;\n  }\n\n  return Math.ceil((job.total - job.processed) / ratePerMs / 1000);\n}","lineStart":720,"lineEnd":821,"totalLines":821,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","time":{"start":1781151294958,"end":1781151294961}},"metadata":{"openai":{"itemId":"fc_0a3c79976b7d1942016a2a363ed3cc8191b557657ec79c49e6"}},"id":"prt_eb4e3e5de001DulmzBG6PfS6HP","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3bebc001TVrc4Vv5DX0iRt"}}
{"type":"tool_use","timestamp":1781151294984,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_kIDIsQCOxzz6wVZGQKar9BNd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1,"limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Queries\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL query/search functions,\n6: // Content extraction, ranking, stats, cleanup, and integrity checks.\n7: \n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: import type Database from 'better-sqlite3';\n11: import { formatAgeString as format_age_string } from '../utils/format-helpers.js';\n12: import { createLogger } from '../utils/logger.js';\n13: import { recordHistory } from '../storage/history.js';\n14: import * as embeddingsProvider from '../providers/embeddings.js';\n15: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\n16: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n17: import { getEmbedderAdapter } from '../embedders/execution-router.js';\n18: import { getManifest } from '../embedders/registry.js';\n19: import {\n20:   computeContentHash,\n21:   getActiveEmbeddingProfileKey,\n22:   lookupEmbedding,\n23:   storeEmbedding,\n24: } from '../cache/embedding-cache.js';\n25: import {\n26:   get_error_message,\n27:   parse_trigger_phrases,\n28:   to_embedding_buffer,\n29:   VectorIndexError,\n30:   VectorIndexErrorCode,\n31: } from './vector-index-types.js';\n32: import {\n33:   initialize_db,\n34:   get_embedding_dim,\n35:   get_constitutional_memories,\n36:   init_prepared_statements,\n37:   validate_file_path_local,\n38:   safe_read_file_async,\n39:   safe_parse_json,\n40:   search_weights,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource as activeVectorSchema,\n43: } from './vector-index-store.js';\n44: import { delete_memory_from_database } from './vector-index-mutations.js';\n45: import type {\n46:   EmbeddingInput,\n47:   EnrichedSearchResult,\n48:   MemoryRow,\n49:   VectorSearchOptions,\n50: } from './vector-index-types.js';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: type RelatedMemoryLink = { id: number; similarity: number };\n55: type UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\n56: type CleanupOptions = {\n57:   maxAgeDays?: number;\n58:   maxAccessCount?: number;\n59:   maxConfidence?: number;\n60:   limit?: number;\n61: };\n62: type VectorSource = {\n63:   dim: number;\n64:   tableName: string;\n65:   idColumn: string;\n66:   embeddingColumn: string;\n67: };\n68: \n69: export interface KnnQueryShapeBenchmarkResult {\n70:   readonly corpusSize: number;\n71:   readonly iterations: number;\n72:   readonly scalarJoinAverageMs: number;\n73:   readonly matchAverageMs: number | null;\n74:   readonly matchSupported: boolean;\n75:   readonly matchImprovementPct: number | null;\n76:   readonly decision: 'adopt_match' | 'keep_scalar_join';\n77:   readonly reason: string;\n78: }\n79: \n80: const KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n81: \n82: function appendSpecFolderScope(\n83:   clauses: string[],\n84:   params: unknown[],\n85:   specFolder: string | null | undefined,\n86:   column = 'm.spec_folder',\n87: ): void {\n88:   if (!specFolder) return;\n89:   clauses.push(`(${column} = ? OR ${column} LIKE ?)`);\n90:   params.push(specFolder, `${specFolder}/%`);\n91: }\n92: \n93: function tableExists(database: Database.Database, tableName: string): boolean {\n94:   const row = database.prepare(`\n95:     SELECT 1 AS found\n96:     FROM active_vec.sqlite_master\n97:     WHERE type = 'table' AND name = ?\n98:     LIMIT 1\n99:   `).get(tableName) as { found?: number } | undefined;\n100:   return row?.found === 1;\n101: }\n102: \n103: function getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n104:   const active = getActiveEmbedder(database);\n105:   const dimTableName = `vec_${active.dim}`;\n106:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n107:     return {\n108:       dim: active.dim,\n109:       tableName: activeVectorSchema(dimTableName),\n110:       idColumn: 'id',\n111:       embeddingColumn: 'vec',\n112:     };\n113:   }\n114: \n115:   return {\n116:     dim: get_embedding_dim(),\n117:     tableName: activeVectorSchema('vec_memories'),\n118:     idColumn: 'rowid',\n119:     embeddingColumn: 'embedding',\n120:   };\n121: }\n122: \n123: function elapsedMs(start: bigint): number {\n124:   return Number(process.hrtime.bigint() - start) / 1_000_000;\n125: }\n126: \n127: function average(values: number[]): number {\n128:   if (values.length === 0) return 0;\n129:   return values.reduce((sum, value) => sum + value, 0) / values.length;\n130: }\n131: \n132: export function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n133:   return result.matchSupported === true\n134:     && typeof result.matchImprovementPct === 'number'\n135:     && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n136: }\n137: \n138: export function benchmarkKnnQueryShapes(\n139:   query_embedding: EmbeddingInput,\n140:   options: { iterations?: number; limit?: number } = {},\n141:   database: Database.Database = initialize_db(),\n142: ): KnnQueryShapeBenchmarkResult {\n143:   const vectorSource = getActiveVectorSourceForQuery(database);\n144:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n145:     throw new VectorIndexError(\n146:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n147:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n148:     );\n149:   }\n150: \n151:   const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n152:   const limit = Math.max(1, Math.floor(options.limit ?? 20));\n153:   const queryBuffer = to_embedding_buffer(query_embedding);\n154:   const corpusSize = (database.prepare(`\n155:     SELECT COUNT(*) AS count\n156:     FROM memory_index m\n157:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n158:     WHERE m.embedding_status = 'success'\n159:   `).get() as { count: number }).count;\n160: \n161:   const scalarSql = `\n162:     SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n163:     FROM memory_index m\n164:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n165:     JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n166:     WHERE m.embedding_status = 'success'\n167:     ORDER BY distance ASC\n168:     LIMIT ?\n169:   `;\n170:   const scalarStmt = database.prepare(scalarSql);\n171:   scalarStmt.all(queryBuffer, limit);\n172:   const scalarRuns: number[] = [];\n173:   for (let i = 0; i < iterations; i += 1) {\n174:     const start = process.hrtime.bigint();\n175:     scalarStmt.all(queryBuffer, limit);\n176:     scalarRuns.push(elapsedMs(start));\n177:   }\n178: \n179:   const matchTable = activeVectorSchema('vec_memories');\n180:   const matchAvailable = tableExists(database, 'vec_memories');\n181:   let matchAverageMs: number | null = null;\n182:   let matchError: string | null = null;\n183: \n184:   if (matchAvailable) {\n185:     try {\n186:       const matchSql = `\n187:         WITH knn AS (\n188:           SELECT rowid, distance\n189:           FROM ${matchTable}\n190:           WHERE embedding MATCH ? AND k = ?\n191:         )\n192:         SELECT m.id, knn.distance\n193:         FROM knn\n194:         JOIN memory_index m ON m.id = knn.rowid\n195:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n196:         WHERE m.embedding_status = 'success'\n197:         ORDER BY knn.distance ASC\n198:         LIMIT ?\n199:       `;\n200:       const matchStmt = database.prepare(matchSql);\n201:       matchStmt.all(queryBuffer, limit, limit);\n202:       const matchRuns: number[] = [];\n203:       for (let i = 0; i < iterations; i += 1) {\n204:         const start = process.hrtime.bigint();\n205:         matchStmt.all(queryBuffer, limit, limit);\n206:         matchRuns.push(elapsedMs(start));\n207:       }\n208:       matchAverageMs = average(matchRuns);\n209:     } catch (error: unknown) {\n210:       matchError = get_error_message(error);\n211:     }\n212:   }\n213: \n214:   const scalarJoinAverageMs = average(scalarRuns);\n215:   const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n216:     ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n217:     : null;\n218:   const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n219:     matchSupported: matchAverageMs !== null,\n220:     matchImprovementPct,\n221:   };\n222:   const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n223: \n224:   return {\n225:     corpusSize,\n226:     iterations,\n227:     scalarJoinAverageMs,\n228:     matchAverageMs,\n229:     matchSupported: matchAverageMs !== null,\n230:     matchImprovementPct,\n\n(Showing lines 1-230 of 1706. Use offset=231 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport {\n  get_error_message,\n  parse_trigger_phrases,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  initialize_db,\n  get_embedding_dim,\n  get_constitutional_memories,\n  init_prepared_statements,\n  validate_file_path_local,\n  safe_read_file_async,\n  safe_parse_json,\n  search_weights,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource as activeVectorSchema,\n} from './vector-index-store.js';\nimport { delete_memory_from_database } from './vector-index-mutations.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\nconst logger = createLogger('VectorIndex');\n\ntype RelatedMemoryLink = { id: number; similarity: number };\ntype UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\ntype CleanupOptions = {\n  maxAgeDays?: number;\n  maxAccessCount?: number;\n  maxConfidence?: number;\n  limit?: number;\n};\ntype VectorSource = {\n  dim: number;\n  tableName: string;\n  idColumn: string;\n  embeddingColumn: string;\n};\n\nexport interface KnnQueryShapeBenchmarkResult {\n  readonly corpusSize: number;\n  readonly iterations: number;\n  readonly scalarJoinAverageMs: number;\n  readonly matchAverageMs: number | null;\n  readonly matchSupported: boolean;\n  readonly matchImprovementPct: number | null;\n  readonly decision: 'adopt_match' | 'keep_scalar_join';\n  readonly reason: string;\n}\n\nconst KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n\nfunction appendSpecFolderScope(\n  clauses: string[],\n  params: unknown[],\n  specFolder: string | null | undefined,\n  column = 'm.spec_folder',\n): void {\n  if (!specFolder) return;\n  clauses.push(`(${column} = ? OR ${column} LIKE ?)`);\n  params.push(specFolder, `${specFolder}/%`);\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM active_vec.sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\nfunction getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n  const active = getActiveEmbedder(database);\n  const dimTableName = `vec_${active.dim}`;\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n    return {\n      dim: active.dim,\n      tableName: activeVectorSchema(dimTableName),\n      idColumn: 'id',\n      embeddingColumn: 'vec',\n    };\n  }\n\n  return {\n    dim: get_embedding_dim(),\n    tableName: activeVectorSchema('vec_memories'),\n    idColumn: 'rowid',\n    embeddingColumn: 'embedding',\n  };\n}\n\nfunction elapsedMs(start: bigint): number {\n  return Number(process.hrtime.bigint() - start) / 1_000_000;\n}\n\nfunction average(values: number[]): number {\n  if (values.length === 0) return 0;\n  return values.reduce((sum, value) => sum + value, 0) / values.length;\n}\n\nexport function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n  return result.matchSupported === true\n    && typeof result.matchImprovementPct === 'number'\n    && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n}\n\nexport function benchmarkKnnQueryShapes(\n  query_embedding: EmbeddingInput,\n  options: { iterations?: number; limit?: number } = {},\n  database: Database.Database = initialize_db(),\n): KnnQueryShapeBenchmarkResult {\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n  const limit = Math.max(1, Math.floor(options.limit ?? 20));\n  const queryBuffer = to_embedding_buffer(query_embedding);\n  const corpusSize = (database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE m.embedding_status = 'success'\n  `).get() as { count: number }).count;\n\n  const scalarSql = `\n    SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n    WHERE m.embedding_status = 'success'\n    ORDER BY distance ASC\n    LIMIT ?\n  `;\n  const scalarStmt = database.prepare(scalarSql);\n  scalarStmt.all(queryBuffer, limit);\n  const scalarRuns: number[] = [];\n  for (let i = 0; i < iterations; i += 1) {\n    const start = process.hrtime.bigint();\n    scalarStmt.all(queryBuffer, limit);\n    scalarRuns.push(elapsedMs(start));\n  }\n\n  const matchTable = activeVectorSchema('vec_memories');\n  const matchAvailable = tableExists(database, 'vec_memories');\n  let matchAverageMs: number | null = null;\n  let matchError: string | null = null;\n\n  if (matchAvailable) {\n    try {\n      const matchSql = `\n        WITH knn AS (\n          SELECT rowid, distance\n          FROM ${matchTable}\n          WHERE embedding MATCH ? AND k = ?\n        )\n        SELECT m.id, knn.distance\n        FROM knn\n        JOIN memory_index m ON m.id = knn.rowid\n        JOIN active_memory_projection p ON p.active_memory_id = m.id\n        WHERE m.embedding_status = 'success'\n        ORDER BY knn.distance ASC\n        LIMIT ?\n      `;\n      const matchStmt = database.prepare(matchSql);\n      matchStmt.all(queryBuffer, limit, limit);\n      const matchRuns: number[] = [];\n      for (let i = 0; i < iterations; i += 1) {\n        const start = process.hrtime.bigint();\n        matchStmt.all(queryBuffer, limit, limit);\n        matchRuns.push(elapsedMs(start));\n      }\n      matchAverageMs = average(matchRuns);\n    } catch (error: unknown) {\n      matchError = get_error_message(error);\n    }\n  }\n\n  const scalarJoinAverageMs = average(scalarRuns);\n  const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n    ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n    : null;\n  const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n  };\n  const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n\n  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,","lineStart":1,"lineEnd":230,"totalLines":1706,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781151294978,"end":1781151294983}},"metadata":{"openai":{"itemId":"fc_0a3c79976b7d1942016a2a363ed3d481918b201079f48a5914"}},"id":"prt_eb4e3e5f3001npPDAPo3fIf3KS","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3bebc001TVrc4Vv5DX0iRt"}}
{"type":"tool_use","timestamp":1781151294986,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_yG7CYfGYN4KF26O8P4htPT8i","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts","offset":1,"limit":310},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retrieval Observability\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type Database from 'better-sqlite3';\n6: \n7: type MaintenanceTool = 'memory_index_scan' | 'memory_embedding_reconcile' | 'memory_retention_sweep';\n8: \n9: export interface DocumentAnchorKey {\n10:   path: string;\n11:   anchor: string | null;\n12: }\n13: \n14: export interface WhyRankedTrace {\n15:   document: DocumentAnchorKey;\n16:   rank: number;\n17:   effectiveScore: number | null;\n18:   scoreSource: string;\n19:   channels: Record<'vector' | 'bm25' | 'fts' | 'graph' | 'trigger', number | null>;\n20:   signals: Record<'fsrs' | 'importance' | 'recency', number | null>;\n21:   source: 'ranker_intermediates';\n22: }\n23: \n24: export interface RetrievalConflictWarning {\n25:   type: 'verify_before_applying';\n26:   relation: 'contradicts' | 'supersedes';\n27:   documents: [DocumentAnchorKey, DocumentAnchorKey];\n28:   message: string;\n29: }\n30: \n31: export interface VectorDegradationSignal {\n32:   degraded: boolean;\n33:   vectorSearchAvailable: boolean;\n34:   mode: 'hybrid' | 'lexical_only';\n35:   reason: string | null;\n36:   degradedVector?: DegradedVectorHealthSnapshot;\n37: }\n38: \n39: export type DegradedVectorRepairState = 'healthy' | 'detected' | 'quarantined' | 'rebuilding' | 'rebuild_failed';\n40: \n41: export interface DegradedVectorHealthSnapshot {\n42:   state: DegradedVectorRepairState;\n43:   degraded: boolean;\n44:   detections: number;\n45:   quarantines: number;\n46:   rebuildsStarted: number;\n47:   rebuildsCompleted: number;\n48:   rebuildsFailed: number;\n49:   lastEventAt: string | null;\n50:   lastReason: string | null;\n51:   lastShard: string | null;\n52:   lastQuarantine: string | null;\n53:   activeJobId: string | null;\n54: }\n55: \n56: export interface MaintenanceRunCounters {\n57:   tool: MaintenanceTool;\n58:   lastRunAt: string | null;\n59:   lastStatus: 'success' | 'error' | 'coalesced' | null;\n60:   counts: Record<string, number>;\n61:   staleCandidates: number;\n62: }\n63: \n64: const CHANNEL_KEYS = ['vector', 'bm25', 'fts', 'graph', 'trigger'] as const;\n65: \n66: const maintenanceRuns: Record<MaintenanceTool, MaintenanceRunCounters> = {\n67:   memory_index_scan: emptyMaintenanceRun('memory_index_scan'),\n68:   memory_embedding_reconcile: emptyMaintenanceRun('memory_embedding_reconcile'),\n69:   memory_retention_sweep: emptyMaintenanceRun('memory_retention_sweep'),\n70: };\n71: \n72: const degradedVectorHealth: DegradedVectorHealthSnapshot = {\n73:   state: 'healthy',\n74:   degraded: false,\n75:   detections: 0,\n76:   quarantines: 0,\n77:   rebuildsStarted: 0,\n78:   rebuildsCompleted: 0,\n79:   rebuildsFailed: 0,\n80:   lastEventAt: null,\n81:   lastReason: null,\n82:   lastShard: null,\n83:   lastQuarantine: null,\n84:   activeJobId: null,\n85: };\n86: \n87: function emptyMaintenanceRun(tool: MaintenanceTool): MaintenanceRunCounters {\n88:   return {\n89:     tool,\n90:     lastRunAt: null,\n91:     lastStatus: null,\n92:     counts: {},\n93:     staleCandidates: 0,\n94:   };\n95: }\n96: \n97: function finiteNumber(value: unknown): number | null {\n98:   if (typeof value === 'number' && Number.isFinite(value)) return value;\n99:   if (typeof value === 'string' && value.trim().length > 0) {\n100:     const parsed = Number(value);\n101:     if (Number.isFinite(parsed)) return parsed;\n102:   }\n103:   return null;\n104: }\n105: \n106: function scoreMap(value: unknown): Record<string, number> {\n107:   if (!value || typeof value !== 'object' || Array.isArray(value)) return {};\n108:   const output: Record<string, number> = {};\n109:   for (const [key, raw] of Object.entries(value as Record<string, unknown>)) {\n110:     const score = finiteNumber(raw);\n111:     if (score !== null) output[key] = score;\n112:   }\n113:   return output;\n114: }\n115: \n116: function basenameOrNull(value: string | null | undefined): string | null {\n117:   if (!value) return null;\n118:   const normalized = value.replace(/\\\\/g, '/');\n119:   return normalized.slice(normalized.lastIndexOf('/') + 1);\n120: }\n121: \n122: function updateDegradedVectorHealth(update: Partial<DegradedVectorHealthSnapshot>): void {\n123:   Object.assign(degradedVectorHealth, update, {\n124:     degraded: update.state ? update.state !== 'healthy' : degradedVectorHealth.state !== 'healthy',\n125:     lastEventAt: new Date().toISOString(),\n126:   });\n127: }\n128: \n129: function channelScore(rawResult: Record<string, unknown>, channel: typeof CHANNEL_KEYS[number]): number | null {\n130:   const scores = scoreMap(rawResult.sourceScores);\n131:   if (scores[channel] !== undefined) return scores[channel];\n132:   if (channel === 'fts') return finiteNumber(rawResult.fts_score);\n133:   if (channel === 'bm25') return finiteNumber(rawResult.bm25_score);\n134:   if (channel === 'trigger') return finiteNumber(rawResult.triggerScore);\n135:   if (channel === 'graph') {\n136:     const contribution = rawResult.graphContribution;\n137:     if (contribution && typeof contribution === 'object' && !Array.isArray(contribution)) {\n138:       const total = finiteNumber((contribution as Record<string, unknown>).totalDelta);\n139:       if (total !== null) return total;\n140:     }\n141:   }\n142:   if (channel === 'vector') {\n143:     const similarity = finiteNumber(rawResult.similarity ?? rawResult.averageSimilarity);\n144:     return similarity !== null ? similarity / 100 : null;\n145:   }\n146:   return null;\n147: }\n148: \n149: function resolveEffectiveScore(rawResult: Record<string, unknown>): { score: number | null; source: string } {\n150:   for (const [field, source] of [\n151:     ['intentAdjustedScore', 'intentAdjusted'],\n152:     ['rrfScore', 'fusion'],\n153:     ['stage2Score', 'stage2'],\n154:     ['score', 'score'],\n155:     ['similarity', 'semantic'],\n156:     ['averageSimilarity', 'semantic'],\n157:   ] as const) {\n158:     const score = finiteNumber(rawResult[field]);\n159:     if (score !== null) {\n160:       return { score: field === 'similarity' || field === 'averageSimilarity' ? score / 100 : score, source };\n161:     }\n162:   }\n163:   return { score: null, source: 'none' };\n164: }\n165: \n166: export function resolveDocumentAnchor(rawResult: Record<string, unknown>): DocumentAnchorKey {\n167:   const filePath = rawResult.file_path ?? rawResult.filePath;\n168:   const anchor = rawResult.anchor_id ?? rawResult.anchorId;\n169:   return {\n170:     path: typeof filePath === 'string' ? filePath : '',\n171:     anchor: typeof anchor === 'string' && anchor.trim().length > 0 ? anchor.trim() : null,\n172:   };\n173: }\n174: \n175: export function buildWhyRankedTrace(rawResult: Record<string, unknown>, rank: number): WhyRankedTrace {\n176:   const effective = resolveEffectiveScore(rawResult);\n177:   return {\n178:     document: resolveDocumentAnchor(rawResult),\n179:     rank,\n180:     effectiveScore: effective.score,\n181:     scoreSource: effective.source,\n182:     channels: {\n183:       vector: channelScore(rawResult, 'vector'),\n184:       bm25: channelScore(rawResult, 'bm25'),\n185:       fts: channelScore(rawResult, 'fts'),\n186:       graph: channelScore(rawResult, 'graph'),\n187:       trigger: channelScore(rawResult, 'trigger'),\n188:     },\n189:     signals: {\n190:       fsrs: finiteNumber(rawResult.attentionScore ?? rawResult.retrievability ?? rawResult.stability),\n191:       importance: finiteNumber(rawResult.importance_weight),\n192:       recency: finiteNumber(rawResult.recencyScore ?? rawResult.recency_score),\n193:     },\n194:     source: 'ranker_intermediates',\n195:   };\n196: }\n197: \n198: export function buildVectorDegradationSignal(\n199:   vectorSearchAvailable: boolean,\n200:   degradedVector = getDegradedVectorObservabilitySnapshot(),\n201: ): VectorDegradationSignal {\n202:   const degraded = !vectorSearchAvailable || degradedVector.degraded;\n203:   return {\n204:     degraded,\n205:     vectorSearchAvailable,\n206:     mode: vectorSearchAvailable ? 'hybrid' : 'lexical_only',\n207:     reason: !vectorSearchAvailable\n208:       ? 'vector_search_unavailable'\n209:       : degradedVector.degraded\n210:         ? `vector_shard_${degradedVector.state}`\n211:         : null,\n212:     degradedVector,\n213:   };\n214: }\n215: \n216: export function recordVectorShardProbeFailure(input: { shardPath: string; reason: string }): void {\n217:   degradedVectorHealth.detections += 1;\n218:   updateDegradedVectorHealth({\n219:     state: 'detected',\n220:     lastReason: input.reason,\n221:     lastShard: basenameOrNull(input.shardPath),\n222:   });\n223: }\n224: \n225: export function recordVectorShardQuarantined(input: { shardPath: string; quarantinePath: string; reason: string }): void {\n226:   degradedVectorHealth.quarantines += 1;\n227:   updateDegradedVectorHealth({\n228:     state: 'quarantined',\n229:     lastReason: input.reason,\n230:     lastShard: basenameOrNull(input.shardPath),\n231:     lastQuarantine: basenameOrNull(input.quarantinePath),\n232:   });\n233: }\n234: \n235: export function recordVectorShardRebuildStarted(input: { jobId: string; shardPath: string; reason: string }): void {\n236:   degradedVectorHealth.rebuildsStarted += 1;\n237:   updateDegradedVectorHealth({\n238:     state: 'rebuilding',\n239:     activeJobId: input.jobId,\n240:     lastReason: input.reason,\n241:     lastShard: basenameOrNull(input.shardPath),\n242:   });\n243: }\n244: \n245: export function recordVectorShardRebuildCompleted(input: { jobId: string; shardPath: string }): void {\n246:   degradedVectorHealth.rebuildsCompleted += 1;\n247:   updateDegradedVectorHealth({\n248:     state: 'healthy',\n249:     activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n250:     lastReason: null,\n251:     lastShard: basenameOrNull(input.shardPath),\n252:   });\n253: }\n254: \n255: export function recordVectorShardRebuildFailed(input: { jobId: string; shardPath: string; reason: string }): void {\n256:   degradedVectorHealth.rebuildsFailed += 1;\n257:   updateDegradedVectorHealth({\n258:     state: 'rebuild_failed',\n259:     activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n260:     lastReason: input.reason,\n261:     lastShard: basenameOrNull(input.shardPath),\n262:   });\n263: }\n264: \n265: export function getDegradedVectorObservabilitySnapshot(): DegradedVectorHealthSnapshot {\n266:   return { ...degradedVectorHealth };\n267: }\n268: \n269: export function resetDegradedVectorObservabilityForTest(): void {\n270:   Object.assign(degradedVectorHealth, {\n271:     state: 'healthy',\n272:     degraded: false,\n273:     detections: 0,\n274:     quarantines: 0,\n275:     rebuildsStarted: 0,\n276:     rebuildsCompleted: 0,\n277:     rebuildsFailed: 0,\n278:     lastEventAt: null,\n279:     lastReason: null,\n280:     lastShard: null,\n281:     lastQuarantine: null,\n282:     activeJobId: null,\n283:   });\n284: }\n285: \n286: export function recordMaintenanceRun(\n287:   tool: MaintenanceTool,\n288:   input: { status: MaintenanceRunCounters['lastStatus']; counts?: Record<string, unknown>; staleCandidates?: number },\n289: ): void {\n290:   const counts: Record<string, number> = {};\n291:   for (const [key, value] of Object.entries(input.counts ?? {})) {\n292:     const count = finiteNumber(value);\n293:     if (count !== null) counts[key] = count;\n294:   }\n295:   maintenanceRuns[tool] = {\n296:     tool,\n297:     lastRunAt: new Date().toISOString(),\n298:     lastStatus: input.status,\n299:     counts,\n300:     staleCandidates: Math.max(0, Math.floor(input.staleCandidates ?? 0)),\n301:   };\n302: }\n303: \n304: export function getMaintenanceObservabilitySnapshot(): Record<MaintenanceTool, MaintenanceRunCounters> {\n305:   return {\n306:     memory_index_scan: { ...maintenanceRuns.memory_index_scan, counts: { ...maintenanceRuns.memory_index_scan.counts } },\n307:     memory_embedding_reconcile: { ...maintenanceRuns.memory_embedding_reconcile, counts: { ...maintenanceRuns.memory_embedding_reconcile.counts } },\n308:     memory_retention_sweep: { ...maintenanceRuns.memory_retention_sweep, counts: { ...maintenanceRuns.memory_retention_sweep.counts } },\n309:   };\n310: }\n\n(Showing lines 1-310 of 375. Use offset=311 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retrieval Observability\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype MaintenanceTool = 'memory_index_scan' | 'memory_embedding_reconcile' | 'memory_retention_sweep';\n\nexport interface DocumentAnchorKey {\n  path: string;\n  anchor: string | null;\n}\n\nexport interface WhyRankedTrace {\n  document: DocumentAnchorKey;\n  rank: number;\n  effectiveScore: number | null;\n  scoreSource: string;\n  channels: Record<'vector' | 'bm25' | 'fts' | 'graph' | 'trigger', number | null>;\n  signals: Record<'fsrs' | 'importance' | 'recency', number | null>;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retrieval Observability\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype MaintenanceTool = 'memory_index_scan' | 'memory_embedding_reconcile' | 'memory_retention_sweep';\n\nexport interface DocumentAnchorKey {\n  path: string;\n  anchor: string | null;\n}\n\nexport interface WhyRankedTrace {\n  document: DocumentAnchorKey;\n  rank: number;\n  effectiveScore: number | null;\n  scoreSource: string;\n  channels: Record<'vector' | 'bm25' | 'fts' | 'graph' | 'trigger', number | null>;\n  signals: Record<'fsrs' | 'importance' | 'recency', number | null>;\n  source: 'ranker_intermediates';\n}\n\nexport interface RetrievalConflictWarning {\n  type: 'verify_before_applying';\n  relation: 'contradicts' | 'supersedes';\n  documents: [DocumentAnchorKey, DocumentAnchorKey];\n  message: string;\n}\n\nexport interface VectorDegradationSignal {\n  degraded: boolean;\n  vectorSearchAvailable: boolean;\n  mode: 'hybrid' | 'lexical_only';\n  reason: string | null;\n  degradedVector?: DegradedVectorHealthSnapshot;\n}\n\nexport type DegradedVectorRepairState = 'healthy' | 'detected' | 'quarantined' | 'rebuilding' | 'rebuild_failed';\n\nexport interface DegradedVectorHealthSnapshot {\n  state: DegradedVectorRepairState;\n  degraded: boolean;\n  detections: number;\n  quarantines: number;\n  rebuildsStarted: number;\n  rebuildsCompleted: number;\n  rebuildsFailed: number;\n  lastEventAt: string | null;\n  lastReason: string | null;\n  lastShard: string | null;\n  lastQuarantine: string | null;\n  activeJobId: string | null;\n}\n\nexport interface MaintenanceRunCounters {\n  tool: MaintenanceTool;\n  lastRunAt: string | null;\n  lastStatus: 'success' | 'error' | 'coalesced' | null;\n  counts: Record<string, number>;\n  staleCandidates: number;\n}\n\nconst CHANNEL_KEYS = ['vector', 'bm25', 'fts', 'graph', 'trigger'] as const;\n\nconst maintenanceRuns: Record<MaintenanceTool, MaintenanceRunCounters> = {\n  memory_index_scan: emptyMaintenanceRun('memory_index_scan'),\n  memory_embedding_reconcile: emptyMaintenanceRun('memory_embedding_reconcile'),\n  memory_retention_sweep: emptyMaintenanceRun('memory_retention_sweep'),\n};\n\nconst degradedVectorHealth: DegradedVectorHealthSnapshot = {\n  state: 'healthy',\n  degraded: false,\n  detections: 0,\n  quarantines: 0,\n  rebuildsStarted: 0,\n  rebuildsCompleted: 0,\n  rebuildsFailed: 0,\n  lastEventAt: null,\n  lastReason: null,\n  lastShard: null,\n  lastQuarantine: null,\n  activeJobId: null,\n};\n\nfunction emptyMaintenanceRun(tool: MaintenanceTool): MaintenanceRunCounters {\n  return {\n    tool,\n    lastRunAt: null,\n    lastStatus: null,\n    counts: {},\n    staleCandidates: 0,\n  };\n}\n\nfunction finiteNumber(value: unknown): number | null {\n  if (typeof value === 'number' && Number.isFinite(value)) return value;\n  if (typeof value === 'string' && value.trim().length > 0) {\n    const parsed = Number(value);\n    if (Number.isFinite(parsed)) return parsed;\n  }\n  return null;\n}\n\nfunction scoreMap(value: unknown): Record<string, number> {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};\n  const output: Record<string, number> = {};\n  for (const [key, raw] of Object.entries(value as Record<string, unknown>)) {\n    const score = finiteNumber(raw);\n    if (score !== null) output[key] = score;\n  }\n  return output;\n}\n\nfunction basenameOrNull(value: string | null | undefined): string | null {\n  if (!value) return null;\n  const normalized = value.replace(/\\\\/g, '/');\n  return normalized.slice(normalized.lastIndexOf('/') + 1);\n}\n\nfunction updateDegradedVectorHealth(update: Partial<DegradedVectorHealthSnapshot>): void {\n  Object.assign(degradedVectorHealth, update, {\n    degraded: update.state ? update.state !== 'healthy' : degradedVectorHealth.state !== 'healthy',\n    lastEventAt: new Date().toISOString(),\n  });\n}\n\nfunction channelScore(rawResult: Record<string, unknown>, channel: typeof CHANNEL_KEYS[number]): number | null {\n  const scores = scoreMap(rawResult.sourceScores);\n  if (scores[channel] !== undefined) return scores[channel];\n  if (channel === 'fts') return finiteNumber(rawResult.fts_score);\n  if (channel === 'bm25') return finiteNumber(rawResult.bm25_score);\n  if (channel === 'trigger') return finiteNumber(rawResult.triggerScore);\n  if (channel === 'graph') {\n    const contribution = rawResult.graphContribution;\n    if (contribution && typeof contribution === 'object' && !Array.isArray(contribution)) {\n      const total = finiteNumber((contribution as Record<string, unknown>).totalDelta);\n      if (total !== null) return total;\n    }\n  }\n  if (channel === 'vector') {\n    const similarity = finiteNumber(rawResult.similarity ?? rawResult.averageSimilarity);\n    return similarity !== null ? similarity / 100 : null;\n  }\n  return null;\n}\n\nfunction resolveEffectiveScore(rawResult: Record<string, unknown>): { score: number | null; source: string } {\n  for (const [field, source] of [\n    ['intentAdjustedScore', 'intentAdjusted'],\n    ['rrfScore', 'fusion'],\n    ['stage2Score', 'stage2'],\n    ['score', 'score'],\n    ['similarity', 'semantic'],\n    ['averageSimilarity', 'semantic'],\n  ] as const) {\n    const score = finiteNumber(rawResult[field]);\n    if (score !== null) {\n      return { score: field === 'similarity' || field === 'averageSimilarity' ? score / 100 : score, source };\n    }\n  }\n  return { score: null, source: 'none' };\n}\n\nexport function resolveDocumentAnchor(rawResult: Record<string, unknown>): DocumentAnchorKey {\n  const filePath = rawResult.file_path ?? rawResult.filePath;\n  const anchor = rawResult.anchor_id ?? rawResult.anchorId;\n  return {\n    path: typeof filePath === 'string' ? filePath : '',\n    anchor: typeof anchor === 'string' && anchor.trim().length > 0 ? anchor.trim() : null,\n  };\n}\n\nexport function buildWhyRankedTrace(rawResult: Record<string, unknown>, rank: number): WhyRankedTrace {\n  const effective = resolveEffectiveScore(rawResult);\n  return {\n    document: resolveDocumentAnchor(rawResult),\n    rank,\n    effectiveScore: effective.score,\n    scoreSource: effective.source,\n    channels: {\n      vector: channelScore(rawResult, 'vector'),\n      bm25: channelScore(rawResult, 'bm25'),\n      fts: channelScore(rawResult, 'fts'),\n      graph: channelScore(rawResult, 'graph'),\n      trigger: channelScore(rawResult, 'trigger'),\n    },\n    signals: {\n      fsrs: finiteNumber(rawResult.attentionScore ?? rawResult.retrievability ?? rawResult.stability),\n      importance: finiteNumber(rawResult.importance_weight),\n      recency: finiteNumber(rawResult.recencyScore ?? rawResult.recency_score),\n    },\n    source: 'ranker_intermediates',\n  };\n}\n\nexport function buildVectorDegradationSignal(\n  vectorSearchAvailable: boolean,\n  degradedVector = getDegradedVectorObservabilitySnapshot(),\n): VectorDegradationSignal {\n  const degraded = !vectorSearchAvailable || degradedVector.degraded;\n  return {\n    degraded,\n    vectorSearchAvailable,\n    mode: vectorSearchAvailable ? 'hybrid' : 'lexical_only',\n    reason: !vectorSearchAvailable\n      ? 'vector_search_unavailable'\n      : degradedVector.degraded\n        ? `vector_shard_${degradedVector.state}`\n        : null,\n    degradedVector,\n  };\n}\n\nexport function recordVectorShardProbeFailure(input: { shardPath: string; reason: string }): void {\n  degradedVectorHealth.detections += 1;\n  updateDegradedVectorHealth({\n    state: 'detected',\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function recordVectorShardQuarantined(input: { shardPath: string; quarantinePath: string; reason: string }): void {\n  degradedVectorHealth.quarantines += 1;\n  updateDegradedVectorHealth({\n    state: 'quarantined',\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n    lastQuarantine: basenameOrNull(input.quarantinePath),\n  });\n}\n\nexport function recordVectorShardRebuildStarted(input: { jobId: string; shardPath: string; reason: string }): void {\n  degradedVectorHealth.rebuildsStarted += 1;\n  updateDegradedVectorHealth({\n    state: 'rebuilding',\n    activeJobId: input.jobId,\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function recordVectorShardRebuildCompleted(input: { jobId: string; shardPath: string }): void {\n  degradedVectorHealth.rebuildsCompleted += 1;\n  updateDegradedVectorHealth({\n    state: 'healthy',\n    activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n    lastReason: null,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function recordVectorShardRebuildFailed(input: { jobId: string; shardPath: string; reason: string }): void {\n  degradedVectorHealth.rebuildsFailed += 1;\n  updateDegradedVectorHealth({\n    state: 'rebuild_failed',\n    activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function getDegradedVectorObservabilitySnapshot(): DegradedVectorHealthSnapshot {\n  return { ...degradedVectorHealth };\n}\n\nexport function resetDegradedVectorObservabilityForTest(): void {\n  Object.assign(degradedVectorHealth, {\n    state: 'healthy',\n    degraded: false,\n    detections: 0,\n    quarantines: 0,\n    rebuildsStarted: 0,\n    rebuildsCompleted: 0,\n    rebuildsFailed: 0,\n    lastEventAt: null,\n    lastReason: null,\n    lastShard: null,\n    lastQuarantine: null,\n    activeJobId: null,\n  });\n}\n\nexport function recordMaintenanceRun(\n  tool: MaintenanceTool,\n  input: { status: MaintenanceRunCounters['lastStatus']; counts?: Record<string, unknown>; staleCandidates?: number },\n): void {\n  const counts: Record<string, number> = {};\n  for (const [key, value] of Object.entries(input.counts ?? {})) {\n    const count = finiteNumber(value);\n    if (count !== null) counts[key] = count;\n  }\n  maintenanceRuns[tool] = {\n    tool,\n    lastRunAt: new Date().toISOString(),\n    lastStatus: input.status,\n    counts,\n    staleCandidates: Math.max(0, Math.floor(input.staleCandidates ?? 0)),\n  };\n}\n\nexport function getMaintenanceObservabilitySnapshot(): Record<MaintenanceTool, MaintenanceRunCounters> {\n  return {\n    memory_index_scan: { ...maintenanceRuns.memory_index_scan, counts: { ...maintenanceRuns.memory_index_scan.counts } },\n    memory_embedding_reconcile: { ...maintenanceRuns.memory_embedding_reconcile, counts: { ...maintenanceRuns.memory_embedding_reconcile.counts } },\n    memory_retention_sweep: { ...maintenanceRuns.memory_retention_sweep, counts: { ...maintenanceRuns.memory_retention_sweep.counts } },\n  };\n}","lineStart":1,"lineEnd":310,"totalLines":375,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts","time":{"start":1781151294981,"end":1781151294985}},"metadata":{"openai":{"itemId":"fc_0a3c79976b7d1942016a2a363ed43c819192077af98c6ad8c4"}},"id":"prt_eb4e3e60300116UNtAbWMtMJTm","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3bebc001TVrc4Vv5DX0iRt"}}
