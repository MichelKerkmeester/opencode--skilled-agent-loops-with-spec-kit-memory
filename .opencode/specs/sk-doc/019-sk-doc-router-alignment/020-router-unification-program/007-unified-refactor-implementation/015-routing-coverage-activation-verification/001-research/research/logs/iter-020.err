   853	            `advisor_lookups=${state.advisorLookups}`,
   854	            `cache_entries=${state.advisorCache.size}`,
   855	            `cache_hits=${state.cacheHits}`,
   856	            `cache_misses=${state.cacheMisses}`,
   857	            `cache_hit_rate=${cacheHitRate()}`,
   858	          ].join('\n');
   859	        },
   860	      }),
   861	    },
   862	  };
