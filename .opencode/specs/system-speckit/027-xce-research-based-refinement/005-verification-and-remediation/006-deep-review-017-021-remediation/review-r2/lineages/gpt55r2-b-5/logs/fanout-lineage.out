pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/README.md:\n  Line 142: | `transaction-manager.ts` | Manages pending-file paths and crash-recovery support for atomic save flows. |\n\n  Line 202: | `getPendingPath()` | Function | Builds pending-file paths used by atomic save promotion. |\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/atomic-index-memory.vitest.ts:\n  Line 7: import { atomicIndexMemory, type AtomicIndexDependencies } from '../handlers/save/atomic-index-memory.js';\n\n  Line 45:     indexPrepared: async () => buildIndexResult(),\n\n  Line 50: describe('atomicIndexMemory', () => {\n\n  Line 72:     const result = await atomicIndexMemory(params, { force: true }, buildDependencies({\n\n  Line 79:       indexPrepared: async ({ ready }) => buildIndexResult({\n\n  Line 98:     const result = await atomicIndexMemory(paramsFrom(sourcePath), { force: true }, buildDependencies({\n\n  Line 106:       indexPrepared: async () => buildIndexResult({\n\n  Line 125:     const indexPrepared = vi.fn(async () => buildIndexResult({\n\n  Line 132:     const result = await atomicIndexMemory(\n\n  Line 135:       buildDependencies({ indexPrepared }),\n\n  Line 141:     expect(indexPrepared).toHaveBeenCalledTimes(1);\n\n  Line 150:     const result = await atomicIndexMemory(\n\n  Line 154:         indexPrepared: async () => buildIndexResult({\n\n  Line 185:     const indexPrepared = vi.fn()\n\n  Line 192:     const result = await atomicIndexMemory(\n\n  Line 195:       buildDependencies({ prepare, indexPrepared }),\n\n  Line 201:     expect(indexPrepared).toHaveBeenCalledTimes(2);\n\n  Line 210:     const result = await atomicIndexMemory(\n\n  Line 214:         indexPrepared: async () => {\n\n  Line 260:       promotePendingFile: (pendingPath, finalPath) => {\n\n  Line 264:       indexPrepared: async () => {\n\n  Line 274:     const firstSave = atomicIndexMemory(\n\n  Line 285:     const secondSave = atomicIndexMemory(\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/manual_testing_playbook.md:\n  Line 2360: > **Catalog:** [14--pipeline-architecture/atomic-pending-file-recovery.md](../feature_catalog/14--pipeline-architecture/atomic-pending-file-recovery.md)\n\n  Line 3687: | 115 | Features | Transaction atomicity on rename failure (P0-5) | [115](14--pipeline-architecture/transaction-atomicity-on-rename-failure-p0-5.md) | [14--pipeline-architecture/atomic-pending-file-recovery.md](../feature_catalog/14--pipeline-architecture/atomic-pending-file-recovery.md) |\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/14--pipeline-architecture/atomic-write-then-index-api.md:\n  Line 19: - Real user request: `Please validate Atomic write-then-index API against the documented validation surface and tell me whether the expected signals are present: Unique pending path is created before promotion; indexing runs before final rename; transient indexing failure gets one retry; successful flow ends with pending-file rename into place; validation/index failure cleans up the pending file and leaves the original target untouched.`\n\n  Line 22: - Expected signals: Unique pending path is created before promotion; indexing runs before final rename; transient indexing failure gets one retry; successful flow ends with pending-file rename into place; validation/index failure cleans up the pending file and leaves the original target untouched\n\n  Line 38: 1. Trigger a normal save and capture the pending-file path creation before the final file exists\n\n  Line 46: Unique pending path is created before promotion; indexing runs before final rename; transient indexing failure gets one retry; successful flow ends with pending-file rename into place; validation/index failure cleans up the pending file and leaves the original target untouched\n\n  Line 50: Save transcript + pending-file path evidence + retry evidence + before/after filesystem state for success and failure cases\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/14--pipeline-architecture/transaction-atomicity-on-rename-failure-p0-5.md:\n  Line 63: - Feature catalog: [14--pipeline-architecture/atomic-pending-file-recovery.md](../../feature_catalog/14--pipeline-architecture/atomic-pending-file-recovery.md)\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/13--memory-quality-and-indexing/canonical-continuity-save-substrate.md:\n  Line 17: - Real user request: `` Please validate Canonical continuity save substrate against contentRouter and tell me whether the expected signals are present: contentRouter chooses the correct category and tier; routeAs can override safely; anchorMergeOperation uses the right mode; atomicIndexMemory writes the canonical result or safe refusal; `_memory.continuity` stays thin and readable; every successful save refreshes packet metadata; continuity-freshness stays aligned. ``\n\n  Line 20: - Expected signals: contentRouter chooses the correct category and tier; routeAs can override safely; anchorMergeOperation uses the right mode; atomicIndexMemory writes the canonical result or safe refusal; `_memory.continuity` stays thin and readable; every successful save refreshes packet metadata; continuity-freshness stays aligned\n\n  Line 41: 6. Confirm `atomicIndexMemory` writes the canonical output or safely refuses the drop case\n\n  Line 50: contentRouter chooses the correct category and tier; routeAs preserves the natural decision for audit; anchorMergeOperation uses the right mode; atomicIndexMemory writes the canonical result or safe refusal; `_memory.continuity` stays thin and readable; packet metadata refreshes on the save; continuity-freshness stays aligned\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/05--lifecycle/async-ingestion-job-lifecycle.md:\n  Line 151: - [startup-pending-file-recovery.md](startup-pending-file-recovery.md) — Startup pending-file recovery\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/05--lifecycle/constitutional-memory-end-to-end-lifecycle.md:\n  Line 84: - [startup-pending-file-recovery.md](startup-pending-file-recovery.md) — Startup pending-file recovery\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/05--lifecycle/startup-pending-file-recovery.md:\n  Line 2: title: \"Startup pending-file recovery\"\n\n  Line 5:   - \"startup pending-file recovery\"\n\n  Line 12: # Startup pending-file recovery\n\n  Line 40: | `mcp_server/lib/storage/transaction-manager.ts` | Lib | Atomic write + pending-file recovery |\n\n  Line 48: | `mcp_server/tests/transaction-manager-recovery.vitest.ts` | Automated test | Startup pending-file recovery edge coverage |\n\n  Line 55: - Feature file path: `05--lifecycle/startup-pending-file-recovery.md`\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/14--pipeline-architecture/atomic-write-then-index-api.md:\n  Line 3: description: \"The atomic write-then-index API provides crash-safe file persistence via pending-file rename with decoupled asynchronous indexing.\"\n\n  Line 6:   - \"pending-file rename\"\n\n  Line 18: The atomic write-then-index API provides crash-safe file persistence via pending-file rename with decoupled asynchronous indexing.\n\n  Line 40: | `mcp_server/lib/storage/transaction-manager.ts` | Lib | Pending-path derivation and pending-file cleanup/recovery helpers |\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/14--pipeline-architecture/lineage-state-active-projection-and-asof-resolution.md:\n  Line 59: - [atomic-pending-file-recovery.md](atomic-pending-file-recovery.md) — Atomic pending-file recovery\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/14--pipeline-architecture/pipeline-and-mutation-hardening.md:\n  Line 49: - **Canonical save routing (018):** `memory_save` now routes through `contentRouter`, applies `anchorMergeOperation`, validates legality with `spec-doc-structure.ts`, and commits through `atomicIndexMemory` inside the existing spec-folder lock. `memory-save.ts` remains the orchestration shell.\n\n  Line 115: | `mcp_server/tests/transaction-manager.vitest.ts` | Automated test | Atomic-save and pending-file transaction behavior |\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/14--pipeline-architecture/7-layer-tool-architecture-metadata.md:\n  Line 60: - [atomic-pending-file-recovery.md](atomic-pending-file-recovery.md) — Atomic pending-file recovery\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/14--pipeline-architecture/atomic-pending-file-recovery.md:\n  Line 2: title: \"Atomic pending-file recovery\"\n\n  Line 3: description: \"Atomic pending-file recovery scans for `_pending` files left by interrupted saves and completes the rename when the DB row exists.\"\n\n  Line 5:   - \"atomic pending-file recovery\"\n\n  Line 12: # Atomic pending-file recovery\n\n  Line 18: Atomic pending-file recovery scans for `_pending` files left by interrupted saves and completes the rename when the DB row exists.\n\n  Line 53: - Feature file path: `14--pipeline-architecture/atomic-pending-file-recovery.md`\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/feature_catalog.md:\n  Line 352: `memory_save` is the save entry point for the canonical packet continuity path. You point it at a packet document or other supported markdown input, and it routes the content through `contentRouter`, applies the selected merge behavior via `anchorMergeOperation`, and writes the result through `atomicIndexMemory` inside the existing spec-folder lock. `_memory.continuity` now lives as supporting frontmatter state inside the spec doc, and `/speckit:resume` remains the canonical recovery surface.\n\n  Line 859: ### Startup pending-file recovery\n\n  Line 875: See [`05--lifecycle/startup-pending-file-recovery.md`](05--lifecycle/startup-pending-file-recovery.md) for full implementation and test file listings.\n\n  Line 3485: ### Atomic pending-file recovery\n\n  Line 3499: See [`14--pipeline-architecture/atomic-pending-file-recovery.md`](14--pipeline-architecture/atomic-pending-file-recovery.md) for full implementation and test file listings.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/02--mutation/memory-indexing-memorysave.md:\n  Line 27: `memory_save` is the save entry point for the canonical packet continuity path. You point it at a packet document or other supported markdown input, and it routes the content through `contentRouter`, applies the selected merge behavior via `anchorMergeOperation`, and writes the result through `atomicIndexMemory` inside the existing spec-folder lock. `_memory.continuity` now lives as supporting frontmatter state inside the spec doc, and `/speckit:resume` remains the canonical recovery surface.\n\n  Line 60: When `SPECKIT_QUALITY_LOOP=true`, a verify-fix-verify loop runs before storage: one initial evaluation plus up to 2 auto-fix retries. If the loop rejects, `atomicIndexMemory()` returns `status: 'rejected'` and rolls back the index write.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/13--memory-quality-and-indexing/canonical-continuity-save-substrate.md:\n  Line 3: description: \"Canonical continuity save substrate routes canonical saves through contentRouter, anchorMergeOperation, atomicIndexMemory and the thin _memory.continuity block while preserving the resume ladder.\"\n\n  Line 6:   - \"contentRouter anchorMergeOperation atomicIndexMemory\"\n\n  Line 18: Canonical continuity save substrate routes canonical saves through contentRouter, anchorMergeOperation, atomicIndexMemory and the thin `_memory.continuity` block while preserving the resume ladder.\n\n  Line 30: - `atomicIndexMemory` replaces the old atomic save helper and promotes the canonical spec-doc result.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/changelog/v3.1.2.0.md:\n  Line 108: Every `it.todo()` in crash-recovery.vitest.ts now has a real test body exercising session-state, recovery markdown, and pending-file recovery behavior.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/feature_catalog/02--mutation/transaction-wrappers-on-mutation-handlers.md:\n  Line 25: `memory-crud-update.ts` wraps its mutation steps in a transaction (`runInTransaction`) so the DB update, embedding status write, BM25 re-index and mutation ledger append either commit together or roll back together. `memory-crud-delete.ts` wraps both the single-delete and bulk-folder delete paths in database transactions so confirmed deletes, history rows, causal-edge cleanup and mutation-ledger entries stay aligned. Cache invalidation and post-mutation hooks remain outside the transaction as in-memory/post-commit work. Unlike update, delete no longer falls back when the DB handle is missing: it aborts early to avoid orphaned causal edges or missing audit/history writes. The save path now funnels its final indexed write through `atomicIndexMemory()` inside the existing spec-folder lock, and the reconsolidation bridge `storeMemory` callback still wraps index, metadata, BM25 and history writes in a transaction for atomicity. Lifecycle `recordHistory()` writes now run inside mutation transactions across ADD/UPDATE/DELETE paths, and update BM25 handling distinguishes infrastructure failures (warn and continue) from data failures (roll back).\n","metadata":{"matches":99,"truncated":false},"title":"promotePendingFile|atomicIndexMemory|Atomic index|pending-file|promote-before-index|indexPrepared","time":{"start":1781762641469,"end":1781762641534}},"metadata":{"openai":{"itemId":"fc_081965e686174837016a338a515f0c8191a8c8ea58d1ca51c3"}},"id":"prt_ed9544e32001rtB35qba8gmRNN","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95429fa001hxj6IvreQR283l"}}
{"type":"tool_use","timestamp":1781762641537,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_9dOT5DsauIX91g3pEbtpOau2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Transaction Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Atomic file + index operations with pending file recovery\n6: import type Database from 'better-sqlite3';\n7: import * as fs from 'fs';\n8: import * as path from 'path';\n9: import { resolveDatabasePaths } from '../../core/config.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. CONSTANTS\n13: ----------------------------------------------------------------*/\n14: \n15: const PENDING_SUFFIX = '_pending';\n16: const TEMP_SUFFIX = '.tmp';\n17: const PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. INTERFACES\n21: ----------------------------------------------------------------*/\n22: \n23: interface TransactionMetrics {\n24:   totalAtomicWrites: number;\n25:   totalDeletes: number;\n26:   totalRecoveries: number;\n27:   totalErrors: number;\n28:   lastOperationTime: string | null;\n29:   [key: string]: unknown;\n30: }\n31: \n32: interface AtomicSaveResult {\n33:   success: boolean;\n34:   filePath: string;\n35:   error?: string;\n36:   /** Set when DB committed but rename failed, indicating partial state */\n37:   dbCommitted?: boolean;\n38: }\n39: \n40: interface RecoveryResult {\n41:   path: string;\n42:   recovered: boolean;\n43:   error?: string;\n44: }\n45: \n46: /**\n47:  * Optional database probe used during pending-file recovery.\n48:  * Return `true` when the original path already has a committed `memory_index` row.\n49:  * Return `false` to leave the `_pending` file in place for manual review.\n50:  * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n51:  */\n52: type IsCommittedCheck = (originalPath: string) => boolean;\n53: \n54: /* ───────────────────────────────────────────────────────────────\n55:    3. MODULE STATE\n56: ----------------------------------------------------------------*/\n57: \n58: const metrics: TransactionMetrics = {\n59:   totalAtomicWrites: 0,\n60:   totalDeletes: 0,\n61:   totalRecoveries: 0,\n62:   totalErrors: 0,\n63:   lastOperationTime: null,\n64: };\n65: \n66: const activeTransactions = new WeakMap<object, number>();\n67: \n68: /* ───────────────────────────────────────────────────────────────\n69:    4. METRICS\n70: ----------------------------------------------------------------*/\n71: \n72: function getMetrics(): TransactionMetrics {\n73:   return { ...metrics };\n74: }\n75: \n76: function resetMetrics(): void {\n77:   metrics.totalAtomicWrites = 0;\n78:   metrics.totalDeletes = 0;\n79:   metrics.totalRecoveries = 0;\n80:   metrics.totalErrors = 0;\n81:   metrics.lastOperationTime = null;\n82: }\n83: \n84: /* ───────────────────────────────────────────────────────────────\n85:    5. PATH HELPERS\n86: ----------------------------------------------------------------*/\n87: \n88: function getPendingPath(filePath: string): string {\n89:   const dir = path.dirname(filePath);\n90:   const ext = path.extname(filePath);\n91:   const base = path.basename(filePath, ext);\n92:   return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n93: }\n94: \n95: interface PendingPathInfo {\n96:   originalPath: string;\n97:   basePendingPath: string;\n98:   uniqueSuffix: string | null;\n99: }\n100: \n101: function parsePendingPath(filePath: string): PendingPathInfo | null {\n102:   const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n103:     const dir = path.dirname(candidatePath);\n104:     const ext = path.extname(candidatePath);\n105:     const base = path.basename(candidatePath, ext);\n106:     if (!base.endsWith(PENDING_SUFFIX)) {\n107:       return null;\n108:     }\n109: \n110:     const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n111:     return {\n112:       originalPath: path.join(dir, `${originalBase}${ext}`),\n113:       basePendingPath: candidatePath,\n114:       uniqueSuffix: null,\n115:     };\n116:   };\n117: \n118:   const suffixExt = path.extname(filePath);\n119:   if (suffixExt) {\n120:     const uniqueSuffix = suffixExt.slice(1);\n121:     const basePendingPath = filePath.slice(0, -suffixExt.length);\n122:     const suffixedMatch = parseBasePendingPath(basePendingPath);\n123:     if (\n124:       suffixedMatch &&\n125:       path.extname(suffixedMatch.basePendingPath) &&\n126:       PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n127:     ) {\n128:       return {\n129:         ...suffixedMatch,\n130:         uniqueSuffix,\n131:       };\n132:     }\n133:   }\n134: \n135:   return parseBasePendingPath(filePath);\n136: }\n137: \n138: function isPendingFile(filePath: string): boolean {\n139:   return parsePendingPath(filePath) !== null;\n140: }\n141: \n142: function getOriginalPath(pendingPath: string): string {\n143:   return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n144: }\n145: \n146: function runInTransaction<T>(database: Database.Database, callback: () => T): T {\n147:   const runCallback = (): T => {\n148:     const depth = activeTransactions.get(database) ?? 0;\n149:     activeTransactions.set(database, depth + 1);\n150:     try {\n151:       return callback();\n152:     } finally {\n153:       const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n154:       if (nextDepth > 0) {\n155:         activeTransactions.set(database, nextDepth);\n156:       } else {\n157:         activeTransactions.delete(database);\n158:       }\n159:     }\n160:   };\n161: \n162:   if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n163:     return runCallback();\n164:   }\n165: \n166:   return database.transaction(() => runCallback())();\n167: }\n168: \n169: /* ───────────────────────────────────────────────────────────────\n170:    6. ATOMIC FILE OPERATIONS\n171: ----------------------------------------------------------------*/\n172: \n173: /**\n174:  * Write a file atomically using write-to-temp-then-rename pattern.\n175:  * This prevents partial writes if the process crashes mid-write.\n176:  */\n177: function atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n178:   const tempPath = filePath + TEMP_SUFFIX;\n179: \n180:   try {\n181:     // Ensure directory exists\n182:     const dir = path.dirname(filePath);\n183:     if (!fs.existsSync(dir)) {\n184:       fs.mkdirSync(dir, { recursive: true });\n185:     }\n186: \n187:     // Write to temp file\n188:     fs.writeFileSync(tempPath, content, encoding);\n189: \n190:     // Atomic rename\n191:     fs.renameSync(tempPath, filePath);\n192: \n193:     metrics.totalAtomicWrites++;\n194:     metrics.lastOperationTime = new Date().toISOString();\n195:     return true;\n196:   } catch (error: unknown) {\n197:     const msg = error instanceof Error ? error.message : String(error);\n198:     console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n199:     metrics.totalErrors++;\n200: \n201:     // Clean up temp file\n202:     try {\n203:       if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n204:     } catch { /* ignore cleanup errors */ }\n205: \n206:     return false;\n207:   }\n208: }\n209: \n210: /**\n211:  * Delete a file if it exists.\n212:  */\n213: function deleteFileIfExists(filePath: string): boolean {\n214:   try {\n215:     if (fs.existsSync(filePath)) {\n216:       fs.unlinkSync(filePath);\n217:       metrics.totalDeletes++;\n218:       metrics.lastOperationTime = new Date().toISOString();\n219:       return true;\n220:     }\n221:     return false;\n222:   } catch (error: unknown) {\n223:     const msg = error instanceof Error ? error.message : String(error);\n224:     console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n225:     metrics.totalErrors++;\n226:     return false;\n227:   }\n228: }\n229: \n230: /**\n231:  * Execute an atomic save with pending file pattern.\n232:  * 1. Write to pending path\n233:  * 2. Execute database operations\n234:  * 3. Rename pending to final\n235:  *\n236:  * This function provides file-system-level atomicity (write-to-pending + rename),\n237:  * NOT database transaction isolation. Callers needing transactional guarantees for\n238:  * dbOperation() must wrap it in their own db.transaction() call. The rename step\n239:  * ensures the file is either fully written or not present, but the DB operation\n240:  * is not rolled back if the rename fails (extremely rare on local filesystems).\n241:  */\n242: function executeAtomicSave(\n243:   filePath: string,\n244:   content: string,\n245:   dbOperation: () => void\n246: ): AtomicSaveResult {\n247:   const pendingPath = getPendingPath(filePath);\n248: \n249:   try {\n250:     // Step 1: Write to pending path\n251:     const dir = path.dirname(pendingPath);\n252:     if (!fs.existsSync(dir)) {\n253:       fs.mkdirSync(dir, { recursive: true });\n254:     }\n255:     fs.writeFileSync(pendingPath, content, 'utf-8');\n256: \n257:     // Flag-based rollback coordination.\n258:     // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n259:     // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n260:     // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n261:     // Can report which step failed. No SAVEPOINT is used — better-sqlite3 transactions\n262:     // Are all-or-nothing within the dbOperation() callback itself.\n263:     let dbCommitted = false;\n264: \n265:     // Step 2: Execute database operation\n266:     try {\n267:       dbOperation();\n268:       dbCommitted = true;\n269:     } catch (dbError: unknown) {\n270:       // Database failed - clean up pending file\n271:       try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n272:       const msg = dbError instanceof Error ? dbError.message : String(dbError);\n273:       metrics.totalErrors++;\n274:       return { success: false, filePath, error: `DB operation failed: ${msg}` };\n275:     }\n276: \n277:     // Step 3: Rename pending to final (atomic)\n278:     // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n279:     // The DB contains the new state but the file is not at its final path. This is\n280:     // A window of vulnerability that cannot be eliminated without two-phase commit.\n281:     // The `dbCommitted` flag on the returned error result enables callers to detect\n282:     // This state and trigger recovery (e.g., re-index from DB or replay the write).\n283:     // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n284:     // Orphaned pending files and rename them to their final paths.\n285:     try {\n286:       fs.renameSync(pendingPath, filePath);\n287:     } catch (renameError: unknown) {\n288:       // Rename failed after DB committed — DB has new state but file wasn't renamed.\n289:       // Leave pending file for startup recovery and report failure with dbCommitted flag.\n290:       const msg = renameError instanceof Error ? renameError.message : String(renameError);\n291:       console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n292:       metrics.totalErrors++;\n293:       return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n294:     }\n295: \n296:     metrics.totalAtomicWrites++;\n297:     metrics.lastOperationTime = new Date().toISOString();\n298:     return { success: true, filePath };\n299:   } catch (error: unknown) {\n300:     const msg = error instanceof Error ? error.message : String(error);\n301:     metrics.totalErrors++;\n302: \n303:     // Clean up pending file\n304:     try {\n305:       if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n306:     } catch { /* ignore */ }\n307: \n308:     return { success: false, filePath, error: msg };\n309:   }\n310: }\n311: \n312: /* ───────────────────────────────────────────────────────────────\n313:    7. RECOVERY\n314: ----------------------------------------------------------------*/\n315: \n316: /**\n317:  * Find pending files in a directory (crash recovery).\n318:  */\n319: function listFilesRecursive(dirPath: string): string[] {\n320:   const files: string[] = [];\n321:   const stack: string[] = [dirPath];\n322: \n323:   while (stack.length > 0) {\n324:     const current = stack.pop();\n325:     if (!current) continue;\n326: \n327:     const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n328:     for (const entry of entries) {\n329:       const fullPath = path.join(current, entry.name);\n330:       if (entry.isDirectory()) {\n331:         stack.push(fullPath);\n332:       } else if (entry.isFile()) {\n333:         files.push(fullPath);\n334:       }\n335:     }\n336:   }\n337: \n338:   return files;\n339: }\n340: \n341: function findPendingFiles(dirPath: string): string[] {\n342:   try {\n343:     if (!fs.existsSync(dirPath)) return [];\n344: \n345:     let files: string[];\n346:     try {\n347:       files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n348:     } catch {\n349:       // Node 18 compatibility fallback when recursive readdir is unavailable.\n350:       files = listFilesRecursive(dirPath);\n351:     }\n352: \n353:     return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n354:   } catch (error: unknown) {\n355:     const msg = error instanceof Error ? error.message : String(error);\n356:     console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n357:     return [];\n358:   }\n359: }\n360: \n361: /**\n362:  * Recover a single pending file by renaming to its original path.\n363:  */\n364: function recoverPendingFile(\n365:   pendingPath: string,\n366:   isCommittedInDb?: IsCommittedCheck,\n367:   databasePathOverride?: string\n368: ): RecoveryResult {\n369:   try {\n370:     // Guard: verify pending file still exists before attempting recovery\n371:     if (!fs.existsSync(pendingPath)) {\n372:       return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n373:     }\n374:     const pendingInfo = parsePendingPath(pendingPath);\n375:     if (!pendingInfo) {\n376:       return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n377:     }\n378: \n379:     const originalPath = pendingInfo.originalPath;\n380:     const originalExists = fs.existsSync(originalPath);\n381:     let committedInDb: boolean | null = null;\n382:     if (isCommittedInDb) {\n383:       const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n384:       if (!fs.existsSync(databasePath)) {\n385:         console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n386:         return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n387:       }\n388:       committedInDb = isCommittedInDb(originalPath);\n389:     }\n390: \n391:     // If original exists and is newer, delete pending\n392:     if (originalExists) {\n393:       const pendingStats = fs.statSync(pendingPath);\n394:       const originalStats = fs.statSync(originalPath);\n395:       if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n396:         fs.unlinkSync(pendingPath);\n397:         return { path: pendingPath, recovered: false, error: 'Original is newer' };\n398:       }\n399:     }\n400: \n401:     // Stale detection: if DB check is provided and row was never committed,\n402:     // Log and leave for manual review instead of renaming.\n403:     if (committedInDb === false) {\n404:       console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n405:       return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n406:     }\n407: \n408:     // Rename pending to original\n409:     fs.renameSync(pendingPath, originalPath);\n410:     metrics.totalRecoveries++;\n411:     metrics.lastOperationTime = new Date().toISOString();\n412: \n413:     return { path: pendingPath, recovered: true };\n414:   } catch (error: unknown) {\n415:     const msg = error instanceof Error ? error.message : String(error);\n416:     metrics.totalErrors++;\n417:     return { path: pendingPath, recovered: false, error: msg };\n418:   }\n419: }\n420: \n421: /**\n422:  * Recover all pending files in a directory.\n423:  */\n424: function recoverAllPendingFiles(\n425:   dirPath: string,\n426:   isCommittedInDb?: IsCommittedCheck,\n427:   databasePathOverride?: string\n428: ): RecoveryResult[] {\n429:   const pendingFiles = findPendingFiles(dirPath);\n430:   return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n431: }\n432: \n433: /* ───────────────────────────────────────────────────────────────\n434:    8. EXPORTS\n435: ----------------------------------------------------------------*/\n436: \n437: export {\n438:   PENDING_SUFFIX,\n439:   TEMP_SUFFIX,\n440: \n441:   // Metrics\n442:   getMetrics,\n443:   resetMetrics,\n444: \n445:   // Path helpers\n446:   getPendingPath,\n447:   isPendingFile,\n448:   getOriginalPath,\n449:   runInTransaction,\n450: \n451:   // Atomic operations\n452:   atomicWriteFile,\n453:   deleteFileIfExists,\n454:   executeAtomicSave,\n455: \n456:   // Recovery\n457:   findPendingFiles,\n458:   recoverPendingFile,\n459:   recoverAllPendingFiles,\n460: };\n461: \n462: /**\n463:  * Re-exports related public types.\n464:  */\n465: export type {\n466:   TransactionMetrics,\n467:   AtomicSaveResult,\n468:   RecoveryResult,\n469:   IsCommittedCheck,\n470: };\n\n(End of file - total 470 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface TransactionMetrics {\n  totalAtomicWrites: number;\n  totalDeletes: number;\n  totalRecoveries: number;\n  totalErrors: number;\n  lastOperationTime: string | null;\n  [key: string]: unknown;\n}\n\ninterface AtomicSaveResult {\n  success: boolean;\n  filePath: string;\n  error?: string;\n  /** Set when DB committed but rename failed, indicating partial state */\n  dbCommitted?: boolean;\n}\n\ninterface RecoveryResult {\n  path: string;\n  recovered: boolean;\n  error?: string;\n}\n\n/**\n * Optional database probe used during pending-file recovery.\n * Return `true` when the original path already has a committed `memory_index` row.\n * Return `false` to leave the `_pending` file in place for manual review.\n * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n */\ntype IsCommittedCheck = (originalPath: string) => boolean;\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nconst metrics: TransactionMetrics = {\n  totalAtomicWrites: 0,\n  totalDeletes: 0,\n  totalRecoveries: 0,\n  totalErrors: 0,\n  lastOperationTime: null,\n};\n\nconst activeTransactions = new WeakMap<object, number>();\n\n/* ───────────────────────────────────────────────────────────────\n   4. METRICS\n----------------------------------------------------------------*/\n\nfunction getMetrics(): TransactionMetrics {\n  return { ...metrics };\n}\n\nfunction resetMetrics(): void {\n  metrics.totalAtomicWrites = 0;\n  metrics.totalDeletes = 0;\n  metrics.totalRecoveries = 0;\n  metrics.totalErrors = 0;\n  metrics.lastOperationTime = null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. PATH HELPERS\n----------------------------------------------------------------*/\n\nfunction getPendingPath(filePath: string): string {\n  const dir = path.dirname(filePath);\n  const ext = path.extname(filePath);\n  const base = path.basename(filePath, ext);\n  return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n}\n\ninterface PendingPathInfo {\n  originalPath: string;\n  basePendingPath: string;\n  uniqueSuffix: string | null;\n}\n\nfunction parsePendingPath(filePath: string): PendingPathInfo | null {\n  const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n    const dir = path.dirname(candidatePath);\n    const ext = path.extname(candidatePath);\n    const base = path.basename(candidatePath, ext);\n    if (!base.endsWith(PENDING_SUFFIX)) {\n      return null;\n    }\n\n    const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n    return {\n      originalPath: path.join(dir, `${originalBase}${ext}`),\n      basePendingPath: candidatePath,\n      uniqueSuffix: null,\n    };\n  };\n\n  const suffixExt = path.extname(filePath);\n  if (suffixExt) {\n    const uniqueSuffix = suffixExt.slice(1);\n    const basePendingPath = filePath.slice(0, -suffixExt.length);\n    const suffixedMatch = parseBasePendingPath(basePendingPath);\n    if (\n      suffixedMatch &&\n      path.extname(suffixedMatch.basePendingPath) &&\n      PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n    ) {\n      return {\n        ...suffixedMatch,\n        uniqueSuffix,\n      };\n    }\n  }\n\n  return parseBasePendingPath(filePath);\n}\n\nfunction isPendingFile(filePath: string): boolean {\n  return parsePendingPath(filePath) !== null;\n}\n\nfunction getOriginalPath(pendingPath: string): string {\n  return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n}\n\nfunction runInTransaction<T>(database: Database.Database, callback: () => T): T {\n  const runCallback = (): T => {\n    const depth = activeTransactions.get(database) ?? 0;\n    activeTransactions.set(database, depth + 1);\n    try {\n      return callback();\n    } finally {\n      const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n      if (nextDepth > 0) {\n        activeTransactions.set(database, nextDepth);\n      } else {\n        activeTransactions.delete(database);\n      }\n    }\n  };\n\n  if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n    return runCallback();\n  }\n\n  return database.transaction(() => runCallback())();\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. ATOMIC FILE OPERATIONS\n----------------------------------------------------------------*/\n\n/**\n * Write a file atomically using write-to-temp-then-rename pattern.\n * This prevents partial writes if the process crashes mid-write.\n */\nfunction atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n  const tempPath = filePath + TEMP_SUFFIX;\n\n  try {\n    // Ensure directory exists\n    const dir = path.dirname(filePath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n\n    // Write to temp file\n    fs.writeFileSync(tempPath, content, encoding);\n\n    // Atomic rename\n    fs.renameSync(tempPath, filePath);\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n    metrics.totalErrors++;\n\n    // Clean up temp file\n    try {\n      if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n    } catch { /* ignore cleanup errors */ }\n\n    return false;\n  }\n}\n\n/**\n * Delete a file if it exists.\n */\nfunction deleteFileIfExists(filePath: string): boolean {\n  try {\n    if (fs.existsSync(filePath)) {\n      fs.unlinkSync(filePath);\n      metrics.totalDeletes++;\n      metrics.lastOperationTime = new Date().toISOString();\n      return true;\n    }\n    return false;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n    metrics.totalErrors++;\n    return false;\n  }\n}\n\n/**\n * Execute an atomic save with pending file pattern.\n * 1. Write to pending path\n * 2. Execute database operations\n * 3. Rename pending to final\n *\n * This function provides file-system-level atomicity (write-to-pending + rename),\n * NOT database transaction isolation. Callers needing transactional guarantees for\n * dbOperation() must wrap it in their own db.transaction() call. The rename step\n * ensures the file is either fully written or not present, but the DB operation\n * is not rolled back if the rename fails (extremely rare on local filesystems).\n */\nfunction executeAtomicSave(\n  filePath: string,\n  content: string,\n  dbOperation: () => void\n): AtomicSaveResult {\n  const pendingPath = getPendingPath(filePath);\n\n  try {\n    // Step 1: Write to pending path\n    const dir = path.dirname(pendingPath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n    fs.writeFileSync(pendingPath, content, 'utf-8');\n\n    // Flag-based rollback coordination.\n    // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n    // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n    // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n    // Can report which step failed. No SAVEPOINT is used — better-sqlite3 transactions\n    // Are all-or-nothing within the dbOperation() callback itself.\n    let dbCommitted = false;\n\n    // Step 2: Execute database operation\n    try {\n      dbOperation();\n      dbCommitted = true;\n    } catch (dbError: unknown) {\n      // Database failed - clean up pending file\n      try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n      const msg = dbError instanceof Error ? dbError.message : String(dbError);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `DB operation failed: ${msg}` };\n    }\n\n    // Step 3: Rename pending to final (atomic)\n    // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n    // The DB contains the new state but the file is not at its final path. This is\n    // A window of vulnerability that cannot be eliminated without two-phase commit.\n    // The `dbCommitted` flag on the returned error result enables callers to detect\n    // This state and trigger recovery (e.g., re-index from DB or replay the write).\n    // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n    // Orphaned pending files and rename them to their final paths.\n    try {\n      fs.renameSync(pendingPath, filePath);\n    } catch (renameError: unknown) {\n      // Rename failed after DB committed — DB has new state but file wasn't renamed.\n      // Leave pending file for startup recovery and report failure with dbCommitted flag.\n      const msg = renameError instanceof Error ? renameError.message : String(renameError);\n      console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n    }\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return { success: true, filePath };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n\n    // Clean up pending file\n    try {\n      if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n    } catch { /* ignore */ }\n\n    return { success: false, filePath, error: msg };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. RECOVERY\n----------------------------------------------------------------*/\n\n/**\n * Find pending files in a directory (crash recovery).\n */\nfunction listFilesRecursive(dirPath: string): string[] {\n  const files: string[] = [];\n  const stack: string[] = [dirPath];\n\n  while (stack.length > 0) {\n    const current = stack.pop();\n    if (!current) continue;\n\n    const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n    for (const entry of entries) {\n      const fullPath = path.join(current, entry.name);\n      if (entry.isDirectory()) {\n        stack.push(fullPath);\n      } else if (entry.isFile()) {\n        files.push(fullPath);\n      }\n    }\n  }\n\n  return files;\n}\n\nfunction findPendingFiles(dirPath: string): string[] {\n  try {\n    if (!fs.existsSync(dirPath)) return [];\n\n    let files: string[];\n    try {\n      files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n    } catch {\n      // Node 18 compatibility fallback when recursive readdir is unavailable.\n      files = listFilesRecursive(dirPath);\n    }\n\n    return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Recover a single pending file by renaming to its original path.\n */\nfunction recoverPendingFile(\n  pendingPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult {\n  try {\n    // Guard: verify pending file still exists before attempting recovery\n    if (!fs.existsSync(pendingPath)) {\n      return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n    }\n    const pendingInfo = parsePendingPath(pendingPath);\n    if (!pendingInfo) {\n      return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n    }\n\n    const originalPath = pendingInfo.originalPath;\n    const originalExists = fs.existsSync(originalPath);\n    let committedInDb: boolean | null = null;\n    if (isCommittedInDb) {\n      const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n      if (!fs.existsSync(databasePath)) {\n        console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n        return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n      }\n      committedInDb = isCommittedInDb(originalPath);\n    }\n\n    // If original exists and is newer, delete pending\n    if (originalExists) {\n      const pendingStats = fs.statSync(pendingPath);\n      const originalStats = fs.statSync(originalPath);\n      if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n        fs.unlinkSync(pendingPath);\n        return { path: pendingPath, recovered: false, error: 'Original is newer' };\n      }\n    }\n\n    // Stale detection: if DB check is provided and row was never committed,\n    // Log and leave for manual review instead of renaming.\n    if (committedInDb === false) {\n      console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n      return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n    }\n\n    // Rename pending to original\n    fs.renameSync(pendingPath, originalPath);\n    metrics.totalRecoveries++;\n    metrics.lastOperationTime = new Date().toISOString();\n\n    return { path: pendingPath, recovered: true };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n    return { path: pendingPath, recovered: false, error: msg };\n  }\n}\n\n/**\n * Recover all pending files in a directory.\n */\nfunction recoverAllPendingFiles(\n  dirPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult[] {\n  const pendingFiles = findPendingFiles(dirPath);\n  return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  PENDING_SUFFIX,\n  TEMP_SUFFIX,\n\n  // Metrics\n  getMetrics,\n  resetMetrics,\n\n  // Path helpers\n  getPendingPath,\n  isPendingFile,\n  getOriginalPath,\n  runInTransaction,\n\n  // Atomic operations\n  atomicWriteFile,\n  deleteFileIfExists,\n  executeAtomicSave,\n\n  // Recovery\n  findPendingFiles,\n  recoverPendingFile,\n  recoverAllPendingFiles,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  TransactionMetrics,\n  AtomicSaveResult,\n  RecoveryResult,\n  IsCommittedCheck,\n};","lineStart":1,"lineEnd":470,"totalLines":470,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781762641475,"end":1781762641536}},"metadata":{"openai":{"itemId":"fc_081965e686174837016a338a515f1c8191b7ecce0497b207ea"}},"id":"prt_ed9544e41001ej10NXmoXnvChY","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95429fa001hxj6IvreQR283l"}}
