z.record(AdvisorLaneSchema, z.number().min(0)),\n  semanticLaneHealth: semanticLaneHealthSchema.optional(),\n  daemonPid: z.number().int().positive().optional(),\n  errors: z.array(z.string()).optional(),\n}).strict();\n\nexport const AdvisorRebuildInputSchema = z.object({\n  force: z.boolean().optional(),\n  // Bound workspaceRoot to allowed prefix set.\n  workspaceRoot: BoundedWorkspaceRootSchema.optional(),\n}).strict();\n\nexport const AdvisorRebuildOutputSchema = z.object({\n  rebuilt: z.boolean(),\n  skipped: z.boolean(),\n  reason: z.enum(['status-live', 'stale', 'absent', 'unavailable', 'force']),\n  freshnessBefore: AdvisorFreshnessSchema,\n  freshnessAfter: AdvisorFreshnessSchema,","lineStart":150,"lineEnd":269,"totalLines":419,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/schemas/advisor-tool-schemas.ts","time":{"start":1781128856944,"end":1781128856946}},"metadata":{"openai":{"itemId":"fc_058a63936a7aba6a016a29de98bdb88191907ffba0238494a7"}},"id":"prt_eb38d856e0013nVD789uotFdw5","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d5ab90010oj5ax5ezt1Mr1"}}
{"type":"tool_use","timestamp":1781128856948,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_IioOBLYvd4m1olbRHihIA6C8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lane-registry.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lane-registry.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Scorer Lane Registry\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { LaneDampingConfig } from './types.js';\n6: import { ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID } from './lanes/bm25.js';\n7: \n8: const LANE_DEFINITIONS = [\n9:   { id: 'explicit_author', defaultWeight: 0.42, defaultShadowWeight: 0.40, live: true },\n10:   { id: 'lexical', defaultWeight: 0.28, defaultShadowWeight: 0.25, live: true },\n11:   { id: 'graph_causal', defaultWeight: 0.13, defaultShadowWeight: 0.20, live: true },\n12:   { id: 'derived_generated', defaultWeight: 0.12, defaultShadowWeight: 0.10, live: true },\n13:   { id: 'semantic_shadow', defaultWeight: 0.05, defaultShadowWeight: 0.05, live: true },\n14: ] as const satisfies readonly {\n15:   readonly id: string;\n16:   readonly defaultWeight: number;\n17:   readonly defaultShadowWeight: number;\n18:   readonly live: boolean;\n19: }[];\n20: \n21: export const SHADOW_SCORER_LANE_DEFINITIONS = [\n22:   {\n23:     id: ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID,\n24:     defaultWeight: 0,\n25:     defaultShadowWeight: 0.10,\n26:     live: false,\n27:     envFlag: 'SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW',\n28:   },\n29: ] as const;\n30: \n31: export type ScorerLaneId = (typeof LANE_DEFINITIONS)[number]['id'];\n32: \n33: const DEFAULT_WEIGHTS = Object.fromEntries(\n34:   LANE_DEFINITIONS.map((lane) => [lane.id, lane.defaultWeight]),\n35: ) as Record<ScorerLaneId, number>;\n36: \n37: const DEFAULT_SHADOW_WEIGHTS = Object.fromEntries(\n38:   LANE_DEFINITIONS.map((lane) => [lane.id, lane.defaultShadowWeight]),\n39: ) as Record<ScorerLaneId, number>;\n40: \n41: function resolveLaneWeightsOverride(\n42:   envKey: string,\n43:   defaults: Record<ScorerLaneId, number>,\n44: ): Record<ScorerLaneId, number> {\n45:   const raw = process.env[envKey];\n46:   if (typeof raw !== 'string' || raw.trim() === '') return defaults;\n47:   let parsed: unknown;\n48:   try {\n49:     parsed = JSON.parse(raw);\n50:   } catch {\n51:     return defaults;\n52:   }\n53:   if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n54:     return defaults;\n55:   }\n56:   const merged: Record<ScorerLaneId, number> = { ...defaults };\n57:   for (const key of Object.keys(parsed) as ScorerLaneId[]) {\n58:     if (!(key in defaults)) continue;\n59:     const value = (parsed as Record<string, unknown>)[key];\n60:     if (typeof value === 'number' && Number.isFinite(value) && value >= 0 && value <= 1) {\n61:       merged[key] = value;\n62:     }\n63:   }\n64:   return merged;\n65: }\n66: \n67: const RESOLVED_WEIGHTS = resolveLaneWeightsOverride(\n68:   'SPECKIT_ADVISOR_LANE_WEIGHTS_JSON',\n69:   DEFAULT_WEIGHTS,\n70: );\n71: const RESOLVED_SHADOW_WEIGHTS = resolveLaneWeightsOverride(\n72:   'SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON',\n73:   DEFAULT_SHADOW_WEIGHTS,\n74: );\n75: \n76: export const SCORER_LANE_REGISTRY: readonly {\n77:   readonly id: ScorerLaneId;\n78:   readonly weight: number;\n79:   readonly shadowWeight: number;\n80:   readonly live: boolean;\n81:   readonly damping?: LaneDampingConfig;\n82: }[] = LANE_DEFINITIONS.map((lane) => ({\n83:   id: lane.id,\n84:   weight: RESOLVED_WEIGHTS[lane.id],\n85:   shadowWeight: RESOLVED_SHADOW_WEIGHTS[lane.id],\n86:   live: lane.live,\n87: }));\n88: \n89: export const SCORER_LANE_IDS = SCORER_LANE_REGISTRY.map((lane) => lane.id) as [\n90:   ScorerLaneId,\n91:   ...ScorerLaneId[],\n92: ];\n93: \n94: export const LIVE_SCORER_LANE_IDS = SCORER_LANE_REGISTRY\n95:   .filter((lane) => lane.live)\n96:   .map((lane) => lane.id) as ScorerLaneId[];\n97: \n98: export const DEFAULT_SCORER_LANE_WEIGHTS = RESOLVED_WEIGHTS;\n99: \n100: export const DEFAULT_SHADOW_SCORER_LANE_WEIGHTS = RESOLVED_SHADOW_WEIGHTS;\n101: \n102: export function isLiveScorerLane(lane: ScorerLaneId): boolean {\n103:   return SCORER_LANE_REGISTRY.some((entry) => entry.id === lane && entry.live);\n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Lane Registry\n// ───────────────────────────────────────────────────────────────\n\nimport type { LaneDampingConfig } from './types.js';\nimport { ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID } from './lanes/bm25.js';\n\nconst LANE_DEFINITIONS = [\n  { id: 'explicit_author', defaultWeight: 0.42, defaultShadowWeight: 0.40, live: true },\n  { id: 'lexical', defaultWeight: 0.28, defaultShadowWeight: 0.25, live: true },\n  { id: 'graph_causal', defaultWeight: 0.13, defaultShadowWeight: 0.20, live: true },\n  { id: 'derived_generated', defaultWeight: 0.12, defaultShadowWeight: 0.10, live: true },\n  { id: 'semantic_shadow', defaultWeight: 0.05, defaultShadowWeight: 0.05, live: true },\n] as const satisfies readonly {\n  readonly id: string;\n  readonly defaultWeight: number;\n  readonly defaultShadowWeight: number;\n  readonly live: boolean;\n}[];\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lane-registry.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Lane Registry\n// ───────────────────────────────────────────────────────────────\n\nimport type { LaneDampingConfig } from './types.js';\nimport { ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID } from './lanes/bm25.js';\n\nconst LANE_DEFINITIONS = [\n  { id: 'explicit_author', defaultWeight: 0.42, defaultShadowWeight: 0.40, live: true },\n  { id: 'lexical', defaultWeight: 0.28, defaultShadowWeight: 0.25, live: true },\n  { id: 'graph_causal', defaultWeight: 0.13, defaultShadowWeight: 0.20, live: true },\n  { id: 'derived_generated', defaultWeight: 0.12, defaultShadowWeight: 0.10, live: true },\n  { id: 'semantic_shadow', defaultWeight: 0.05, defaultShadowWeight: 0.05, live: true },\n] as const satisfies readonly {\n  readonly id: string;\n  readonly defaultWeight: number;\n  readonly defaultShadowWeight: number;\n  readonly live: boolean;\n}[];\n\nexport const SHADOW_SCORER_LANE_DEFINITIONS = [\n  {\n    id: ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID,\n    defaultWeight: 0,\n    defaultShadowWeight: 0.10,\n    live: false,\n    envFlag: 'SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW',\n  },\n] as const;\n\nexport type ScorerLaneId = (typeof LANE_DEFINITIONS)[number]['id'];\n\nconst DEFAULT_WEIGHTS = Object.fromEntries(\n  LANE_DEFINITIONS.map((lane) => [lane.id, lane.defaultWeight]),\n) as Record<ScorerLaneId, number>;\n\nconst DEFAULT_SHADOW_WEIGHTS = Object.fromEntries(\n  LANE_DEFINITIONS.map((lane) => [lane.id, lane.defaultShadowWeight]),\n) as Record<ScorerLaneId, number>;\n\nfunction resolveLaneWeightsOverride(\n  envKey: string,\n  defaults: Record<ScorerLaneId, number>,\n): Record<ScorerLaneId, number> {\n  const raw = process.env[envKey];\n  if (typeof raw !== 'string' || raw.trim() === '') return defaults;\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    return defaults;\n  }\n  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n    return defaults;\n  }\n  const merged: Record<ScorerLaneId, number> = { ...defaults };\n  for (const key of Object.keys(parsed) as ScorerLaneId[]) {\n    if (!(key in defaults)) continue;\n    const value = (parsed as Record<string, unknown>)[key];\n    if (typeof value === 'number' && Number.isFinite(value) && value >= 0 && value <= 1) {\n      merged[key] = value;\n    }\n  }\n  return merged;\n}\n\nconst RESOLVED_WEIGHTS = resolveLaneWeightsOverride(\n  'SPECKIT_ADVISOR_LANE_WEIGHTS_JSON',\n  DEFAULT_WEIGHTS,\n);\nconst RESOLVED_SHADOW_WEIGHTS = resolveLaneWeightsOverride(\n  'SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON',\n  DEFAULT_SHADOW_WEIGHTS,\n);\n\nexport const SCORER_LANE_REGISTRY: readonly {\n  readonly id: ScorerLaneId;\n  readonly weight: number;\n  readonly shadowWeight: number;\n  readonly live: boolean;\n  readonly damping?: LaneDampingConfig;\n}[] = LANE_DEFINITIONS.map((lane) => ({\n  id: lane.id,\n  weight: RESOLVED_WEIGHTS[lane.id],\n  shadowWeight: RESOLVED_SHADOW_WEIGHTS[lane.id],\n  live: lane.live,\n}));\n\nexport const SCORER_LANE_IDS = SCORER_LANE_REGISTRY.map((lane) => lane.id) as [\n  ScorerLaneId,\n  ...ScorerLaneId[],\n];\n\nexport const LIVE_SCORER_LANE_IDS = SCORER_LANE_REGISTRY\n  .filter((lane) => lane.live)\n  .map((lane) => lane.id) as ScorerLaneId[];\n\nexport const DEFAULT_SCORER_LANE_WEIGHTS = RESOLVED_WEIGHTS;\n\nexport const DEFAULT_SHADOW_SCORER_LANE_WEIGHTS = RESOLVED_SHADOW_WEIGHTS;\n\nexport function isLiveScorerLane(lane: ScorerLaneId): boolean {\n  return SCORER_LANE_REGISTRY.some((entry) => entry.id === lane && entry.live);\n}","lineStart":1,"lineEnd":104,"totalLines":104,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lane-registry.ts","time":{"start":1781128856941,"end":1781128856947}},"metadata":{"openai":{"itemId":"fc_058a63936a7aba6a016a29de98bdb081918013ed635cb1e337"}},"id":"prt_eb38d8566001owy5hy3VpLsELn","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d5ab90010oj5ax5ezt1Mr1"}}
