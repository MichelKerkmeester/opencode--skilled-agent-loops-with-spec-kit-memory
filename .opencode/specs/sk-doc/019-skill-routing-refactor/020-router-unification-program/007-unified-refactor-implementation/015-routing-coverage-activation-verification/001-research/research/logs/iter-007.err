  1158	                    print(f"    Auto-fixable: Yes (use --fix)")
  1159	
  1160	        if result['warnings'] and not args.blocking_only:
  1161	            print(f"\n⚠️ Warnings ({len(result['warnings'])}):")
  1162	            for warning in result['warnings']:
  1163	                print(f"  - [{warning['type']}] {warning['message']}")
  1164	
  1165	        if result['auto_fixable_count'] > 0 and not args.fix:
  1166	            print(f"\n💡 {result['auto_fixable_count']} issues can be auto-fixed. Run with --fix")
  1167	
  1168	    sys.exit(result['exit_code'])
  1169	
  1170	
  1171	if __name__ == '__main__':
  1172	    main()

