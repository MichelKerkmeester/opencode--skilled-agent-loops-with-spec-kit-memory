.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deep-research-state.jsonl:3:{"type":"iteration","iteration":2,"run":2,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.88,"status":"complete","focus":"Safe checkout freshness, autostash failure modes, guarded updates, and rollback","findingsCount":6,"noveltyJustification":"Established the fetch-only versus working-tree freshness boundary and documented why autostash and destructive reset cannot provide a no-loss invariant.","keyQuestions":["How can a local IDE checkout stay current without disturbing uncommitted changes?","Which invariants prevent orphaned autostashes, overwritten work, force-push loss, and make rollback reliable?","Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?"],"answeredQuestions":["How can a local IDE checkout stay current without disturbing uncommitted changes?"],"ruledOut":[{"approach":"blind pull --rebase --autostash in a dirty shared IDE worktree","reason":"Autostash application can conflict and temporary stash state can remain after quit","evidence":"https://git-scm.com/docs/git-pull"},{"approach":"blind git reset --hard for checkout freshness","reason":"Can overwrite tracked edits and remove obstructing untracked files","evidence":"https://git-scm.com/docs/git-reset"},{"approach":"fast-forward-only as the complete integration strategy","reason":"Refuses when local and incoming histories diverge","evidence":"https://git-scm.com/docs/git-merge"}],"graphEvents":[{"type":"node","id":"q-rq3","kind":"QUESTION","label":"RQ3 current checkout"},{"type":"node","id":"q-rq4","kind":"QUESTION","label":"RQ4 safety and rollback"},{"type":"node","id":"q-rq5","kind":"QUESTION","label":"RQ5 automation surface"},{"type":"node","id":"f-fetch-watch","kind":"CLAIM","label":"Fetch-only watcher refreshes refs without rewriting the worktree"},{"type":"node","id":"f-ff-view","kind":"CLAIM","label":"Fast-forward-only update belongs on a clean current-view worktree"},{"type":"node","id":"f-autostash","kind":"CLAIM","label":"Autostash needs identity tracking and post-apply verification"},{"type":"node","id":"f-reset-keep","kind":"CLAIM","label":"reset --keep refuses overlap while reset --hard can lose work"},{"type":"node","id":"f-split-ownership","kind":"CLAIM","label":"Always-current files and lossless arbitrary dirty edits require separate ownership"},{"type":"node","id":"f-rollback","kind":"CLAIM","label":"Rollback needs explicit old state and retained recovery material"},{"type":"node","id":"s-fetch-2","kind":"SOURCE","label":"git-fetch manual"},{"type":"node","id":"s-pull-2","kind":"SOURCE","label":"git-pull manual"},{"type":"node","id":"s-merge-2","kind":"SOURCE","label":"git-merge manual"},{"type":"node","id":"s-reset-2","kind":"SOURCE","label":"git-reset manual"},{"type":"node","id":"s-rebase-2","kind":"SOURCE","label":"git-rebase manual"},{"type":"node","id":"s-reflog-2","kind":"SOURCE","label":"git-reflog manual"},{"type":"edge","id":"e-fetch-rq3","source":"f-fetch-watch","target":"q-rq3","relation":"COVERS"},{"type":"edge","id":"e-view-rq3","source":"f-ff-view","target":"q-rq3","relation":"COVERS"},{"type":"edge","id":"e-auto-rq4","source":"f-autostash","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-reset-rq4","source":"f-reset-keep","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-split-rq3","source":"f-split-ownership","target":"q-rq3","relation":"COVERS"},{"type":"edge","id":"e-roll-rq4","source":"f-rollback","target":"q-rq4","relation":"COVERS"},{"type":"edge","id":"e-fetch-src","source":"s-fetch-2","target":"f-fetch-watch","relation":"SUPPORTS"},{"type":"edge","id":"e-pull-src","source":"s-pull-2","target":"f-autostash","relation":"SUPPORTS"},{"type":"edge","id":"e-merge-src","source":"s-merge-2","target":"f-ff-view",