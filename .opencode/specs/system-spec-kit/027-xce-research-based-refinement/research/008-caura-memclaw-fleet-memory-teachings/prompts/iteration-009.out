nt,\n    InjectSTMContext,\n    LoadAndSerialize,\n    ParallelEmbedAndEntityBoost,\n    PostFilterResults,\n    ResolveSearchProfile,\n    TrackRecalls,\n)\n\n\ndef build_search_pipeline() -> Pipeline:\n    return Pipeline(\n        \"search\",\n        [","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/compositions/search.py","text":"\"\"\"Search pipeline composition — single linear pipeline for search_memories().\"\"\"\n\nfrom core_api.pipeline.runner import Pipeline\nfrom core_api.pipeline.steps.search import (\n    ClassifyQuery,\n    ExecuteScoredSearch,\n    ExtractTemporalHint,\n    InjectSTMContext,\n    LoadAndSerialize,\n    ParallelEmbedAndEntityBoost,\n    PostFilterResults,\n    ResolveSearchProfile,\n    TrackRecalls,\n)\n\n\ndef build_search_pipeline() -> Pipeline:\n    return Pipeline(\n        \"search\",\n        [\n            ResolveSearchProfile(),\n            ExtractTemporalHint(),\n            ClassifyQuery(),\n            ParallelEmbedAndEntityBoost(),\n            ExecuteScoredSearch(),\n            PostFilterResults(),\n            LoadAndSerialize(),\n            InjectSTMContext(),\n            TrackRecalls(),\n        ],\n    )","lineStart":1,"lineEnd":31,"totalLines":31,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/compositions/search.py","time":{"start":1780728452584,"end":1780728452588}},"metadata":{"openai":{"itemId":"fc_0fd3db6468185be0016a23c28474748191acbb345e99ad59ea"}},"id":"prt_e9bafd5e0001XyCivCCkTdiOQQ","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9bafab7d001RqCnAxh0z9efCw"}}
