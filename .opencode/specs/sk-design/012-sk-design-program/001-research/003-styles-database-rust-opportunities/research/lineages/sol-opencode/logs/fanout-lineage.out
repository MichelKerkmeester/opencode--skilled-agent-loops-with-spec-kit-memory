arch-state.jsonl`,\"utf8\").split(/\\r?\\n/).map(x=>x.trim()).filter(Boolean).map(JSON.parse), its=records.filter(r=>r.type===\"iteration\"); if(its.length!==10||new Set(its.map(r=>r.iteration)).size!==10) throw new Error(\"iteration count/uniqueness failed\"); for(const event of [\"synthesis_complete\",\"spec_synthesis_deferred\",\"lock_released\"]) if(!records.some(r=>r.event===event)) throw new Error(`missing ${event}`); const cfg=JSON.parse(fs.readFileSync(`${a}/deep-research-config.json`,\"utf8\")), reg=JSON.parse(fs.readFileSync(`${a}/findings-registry.json`,\"utf8\")); if(cfg.status!==\"complete\"||reg.status!==\"COMPLETE\"||reg.metrics.iterationsCompleted!==10) throw new Error(\"terminal state failed\"); if(fs.existsSync(`${a}/.deep-research.lock`)) throw new Error(\"lock still present\"); const research=fs.readFileSync(`${a}/research.md`,\"utf8\"); if(!research.includes(\"| opportunity | class: feature/optimization/automation/integration | capability unlocked | Rust necessary? | effort | risk | gate verdict |\")) throw new Error(\"matrix columns failed\"); console.log(JSON.stringify({ok:true,counts,stateRecords:records.length,status:reg.status,stopReason:\"maxIterationsReached\",researchBytes:Buffer.byteLength(research),resourceMapBytes:fs.statSync(`${a}/resource-map.md`).size}));'","time":{"start":1784525090116,"end":1784525090121}},"metadata":{"openai":{"itemId":"fc_0d9f9511751a5d24016a5db121fee081918dd7d83c68174461"}},"id":"prt_f7dfbece7001w2k0kgcR2i393u","sessionID":"ses_082429307ffehbt81HPaprV8I0","messageID":"msg_f7dfb9384001Zh33nTDrPpkXpt"}}
