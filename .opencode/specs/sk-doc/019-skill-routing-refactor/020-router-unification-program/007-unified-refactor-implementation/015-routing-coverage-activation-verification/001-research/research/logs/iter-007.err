61-/**
62- * Select the executor class for a scenario: routing/advisor run via router-replay
63- * or live cli-opencode; browser scenarios need a real browser (bdg) and are routed
64- * out of the text executors.
65- *
66- * Classification is skill-agnostic. The authoritative signal is an explicit
67- * per-scenario `kind`/`scenario_kind` — a scenario declares its own executor
68: * class in frontmatter, so classification never has to key off a skill-specific
69- * id prefix. Absent that, a general fallback runs off the scenario's own CATEGORY
70- * vocabulary (a browser/motion/visual concern needs a real browser), an asserted
71- * in-skill surface (a routing test), or an advisor skill-selection signal.
72- *
73- * A hardcoded `MR-`/`CB-` id prefix used to force "browser" here — an sk-code
74- * browser-suite naming convention that collided with other skills using `MR-`
75- * for "Mode Routing" and forced them to rename (sk-design → `MDR-`,
76- * system-deep-loop → `MO-`). That prefix hardcode is gone: sk-code's own browser
77- * suite still classifies as browser through its category vocabulary
78- * ("Motion.dev And Animation Regression", "Cross-Browser And Performance Gates"),
79- * and a `MR-` id in any other skill is now free to mean whatever its category /
80- * declared kind says.
81- *
82- * @param {string} scenarioId - Scenario id (e.g. SD-001).
83- * @param {string} category - Category label / directory basename for the scenario.
84- * @param {string} expectedSurface - Asserted in-skill surface, if any.
85- * @param {string} passCriteria - Pass/fail criteria text.
86: * @param {string} [declaredKind] - Explicit per-scenario kind from frontmatter.
87- * @returns {'browser'|'advisor'|'routing'} The executor class.
88- */
89-function classifyKind(scenarioId, category, expectedSurface, passCriteria, declaredKind) {
90-  const declared = typeof declaredKind === 'string' ? declaredKind.trim().toLowerCase() : '';
91-  if (VALID_SCENARIO_KINDS.has(declared)) return declared;
92-
93-  const cat = (category || '').toLowerCase();
94-  const prefix = (ID_RE.exec(scenarioId || '') || [])[1] || '';
95-  // Category vocabulary is a semantic signal every skill shares, not a per-skill
96-  // id convention: a browser/motion/visual/performance category needs a browser.
97-  if (/motion|animation|browser|performance|visual|compositing|cross-browser/.test(cat)) {
98-    return 'browser';
99-  }
100-  // A scenario that asserts an in-skill SURFACE is a routing test (the advisor
101-  // check is just its precondition). Advisor-class is reserved for scenarios
102-  // whose WHOLE test is skill selection — no surface — run as a skill_advisor.py
103-  // probe (SA-*, and the sk-code-vs-sk-doc anti-pattern).
104-  if (expectedSurface) return 'routing';
