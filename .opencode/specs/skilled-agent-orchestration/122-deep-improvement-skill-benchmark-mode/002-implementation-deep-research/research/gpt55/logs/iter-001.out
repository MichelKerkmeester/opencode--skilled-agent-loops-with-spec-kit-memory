    98	type LaneMatchIndex = Map<string, { rawScore: number; evidence: string[] }>;
    99	
   100	function buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {
   101	  const index: LaneMatchIndex = new Map();
   102	  for (const match of matches) {
   103	    const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [] };
   104	    existing.rawScore = Math.max(existing.rawScore, match.score);
   105	    if (existing.evidence.length < 6) {
   106	      existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));
   107	    }
   108	    index.set(match.skillId, existing);
   109	  }
   110	  return index;
   111	}
