\n2125:     // Background retry job for pending embeddings\n2126:     // Processes memories with failed embeddings in the background.\n2127:     // No options passed: use BACKGROUND_JOB_CONFIG, which reads SPECKIT_RETRY_INTERVAL_MS /\n2128:     // SPECKIT_RETRY_BATCH_SIZE / SPECKIT_RETRY_ENABLED. Passing hardcoded options here would\n2129:     // spread after the env-derived config and silently clobber the tuned values.\n2130:     try {\n2131:       const retryJobResult = retryManager.startBackgroundJob();\n2132:       if (retryJobResult) {\n2133:         const { intervalMs, batchSize } = retryManager.BACKGROUND_JOB_CONFIG;\n2134:         console.error(`[context-server] Background retry job started (interval: ${intervalMs}ms, batch: ${batchSize})`);\n2135:       } else {\n2136:         console.error('[context-server] Background retry job already running or disabled');\n2137:       }\n2138:     } catch (retryErr: unknown) {\n2139:       const message = retryErr instanceof Error ? retryErr.message : String(retryErr);\n2140:       console.warn('[context-server] Background retry job failed to start:', message);\n2141:     }\n2142: \n2143:     // Shadow feedback holdout evaluation background scheduler.\n2144:     // Replays recent production queries through a shadow-only path once the\n2145:     // weekly holdout cycle is due. Fail-safe and gated by SPECKIT_SHADOW_FEEDBACK.\n2146:     try {\n2147:       const shadowSchedulerStarted = shadowEvaluationRuntime.startShadowEvaluationScheduler(database);\n2148:       if (shadowSchedulerStarted) {\n2149:         console.error('[context-server] Shadow feedback evaluation scheduler started');\n2150:       } else {\n2151:         console.error('[context-server] Shadow feedback evaluation scheduler not started (already running or disabled)');\n2152:       }\n2153:     } catch (shadowEvalErr: unknown) {\n2154:       const message = shadowEvalErr instanceof Error ? shadowEvalErr.message : String(shadowEvalErr);\n2155:       console.warn('[context-server] Shadow feedback evaluation scheduler failed to start:', message);\n2156:     }\n2157: \n2158:     // Batch feedback learning — runs one cycle at startup (shadow-only, no live ranking mutations).\n2159:     // Feature-flag gated by SPECKIT_BATCH_LEARNED_FEEDBACK (default ON, graduated).\n2160:     try {\n2161:       const batchResult = runBatchLearning(database);\n2162:       if (batchResult.candidatesEvaluated > 0) {\n2163:         console.error(`[context-server] Batch learning: ${batchResult.shadowApplied} shadow-applied, ${batchResult.skippedMinSupport} skipped (min-support), window=${Math.round((batchResult.runAt - batchResult.windowStart) / 86_400_000)}d`);\n2164:       } else {\n2165:         console.error('[context-server] Batch learning: no eligible candidates in window (or flag disabled)');\n2166:       }\n2167:     } catch (batchErr: unknown) {\n2168:       const message = batchErr instanceof Error ? batchErr.message : String(batchErr);\n2169:       console.warn('[context-server] Batch learning failed (non-fatal):', message);\n2170:     }\n2171: \n2172:     // Session deduplication module\n2173:     try {\n2174:       const sessionResult = sessionManager.init(database);\n2175:       if (sessionResult.success) {\n2176:         console.error(`[context-server] Session manager initialized (enabled: ${sessionManager.isEnabled()})`);\n2177: \n2178:         // Crash Recovery Pattern\n2179:         // Reset any sessions that were active when server last crashed\n2180:         const recoveryResult = sessionManager.resetInterruptedSessions();\n2181:         if (recoveryResult.interruptedCount > 0) {\n2182:           console.error(`[context-server] Crash recovery: marked ${recoveryResult.interruptedCount} sessions as interrupted`);\n2183:           // Log interrupted sessions for visibility\n2184:           const interrupted = sessionManager.getInterruptedSessions();\n2185:           if (interrupted.sessions && interrupted.sessions.length > 0) {\n2186:             console.error('[context-server] Recoverable sessions:', interrupted.sessions.map((s: { sessionId: string }) => s.sessionId).join(', '));\n2187:           }\n2188:         }\n2189:       } else {\n2190:         console.warn('[context-server] Session manager initialization returned:', sessionResult.error);\n2191:       }\n2192:     } catch (sessionErr: unknown) {\n2193:       const message = sessionErr instanceof Error ? sessionErr.message : String(sessionErr);\n2194:       console.warn('[context-server] Session manager failed:', message);\n2195:     }\n2196: \n2197:     // Async ingestion job queue initialization + crash recovery reset.\n2198:     try {\n2199:       const ingestInit = initIngestJobQueue({\n2200:         processFile: async (filePath: string, governance) => {\n2201:           await indexSingleFile(filePath, false, governance\n2202:             ? { governance }\n2203:             : {\n2204:                 provenance: {\n2205:                   provenanceSource: 'memory_ingest_start',\n2206:                   provenanceActor: 'async-ingest',\n2207:                   tool: 'memory_ingest_start',\n2208:                 },\n2209:               });\n2210:         },\n2211:       });\n2212:       if (ingestInit.resetCount > 0) {\n2213:         console.error(`[context-server] Ingest crash recovery reset ${ingestInit.resetCount} incomplete job(s) to queued`);\n2214:       }\n2215:     } catch (ingestInitErr: unknown) {\n2216:       const message = ingestInitErr instanceof Error ? ingestInitErr.message : String(ingestInitErr);\n2217:       console.warn('[context-server] Ingest queue init failed:', message);\n2218:     }\n2219: \n2220:     // Background index-scan job store init + crash-recovery reset. An interrupted\n2221:     // scan re-runs fresh, so incomplete jobs are marked failed (never re-enqueued);\n2222:     // a hard-crash scan lease is already reaped by the lease-expiry path.\n2223:     try {\n2224:       ensureMaintenanceJobsTable();\n2225:       const resetScanJobs = resetRunningJobsForKind('index_scan', { to: 'failed' });\n2226:       if (resetScanJobs.length > 0) {\n2227:         console.error(`[context-server] Index scan crash recovery marked ${resetScanJobs.length} incomplete job(s) failed`);\n2228:       }\n2229:     } catch (scanJobInitErr: unknown) {\n2230:       const message = scanJobInitErr instanceof Error ? scanJobInitErr.message : String(scanJobInitErr);\n2231:       console.warn('[context-server] Maintenance job store init failed:', message);\n2232:     }\n2233: \n2234:     // Optional real-time markdown watcher for automatic re-indexing.\n2235:     if (isFileWatcherEnabled()) {\n2236:       try {\n2237:         const watchPaths = getSpecsBasePaths(DEFAULT_BASE_PATH);\n2238:         if (watchPaths.length > 0) {\n2239:           fileWatcher = startFileWatcher({\n2240:             paths: watchPaths,\n2241:             reindexFn: async (filePath: string) => {\n2242:               const result = await indexSingleFile(filePath, false);\n2243:               if (isMutationStatus(result.status)) {\n2244:                 try {\n2245:                   runPostMutationHooks('scan', {\n2246:                     indexed: result.status === 'indexed' || result.status === 'deferred' ? 1 : 0,\n2247:                     updated: result.status === 'updated' || result.status === 'reinforced' ? 1 : 0,\n2248:                     staleDeleted: 0,\n2249:                     staleDeleteFailed: 0,\n2250:                     operation: 'file-watcher-reindex',\n2251:                     filePath,\n2252:                     status: result.status,\n2253:                   });\n2254:                 } catch (_error: unknown) {\n2255:                   // Non-fatal by design for file-watcher callback path.\n2256:                 }\n2257:               }\n2258:             },\n2259:             removeFn: async (filePath: string) => {\n2260:               await removeIndexedMemoriesForFile(filePath);\n2261:             },\n2262:           });\n2263:           console.error(`[context-server] File watcher started for ${watchPaths.length} path(s)`);\n2264:         } else {\n2265:           console.warn('[context-server] File watcher enabled, but no spec directories were found');\n2266:         }\n2267:       } catch (watchErr: unknown) {\n2268:         const message = watchErr instanceof Error ? watchErr.message : String(watchErr);\n2269:         console.warn('[context-server] File watcher startup failed:', message);\n2270:       }\n2271: \n2272:     }\n2273:   } catch (err: unknown) {\n2274:     const message = err instanceof Error ? err.message : String(err);\n2275:     console.error('[context-server] Integrity check failed:', message);\n2276:     throw err instanceof Error ? err : new Error(message);\n2277:   }\n2278: \n2279:     // Background startup scan\n2280:     setImmediate(() => {\n2281:       try {\n2282:         runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n2283:       } catch (repairErr: unknown) {\n2284:         const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n2285:         console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n2286:       }\n2287:       startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n2288:     });\n2289:   });\n2290: \n2291:   // Assign to module-level transport (not const) so shutdown handlers can close it\n2292:   if (isDynamicInitEnabled()) {\n2293:     try {\n2294:       const dynamicInstructions = await buildServerInstructions();\n2295:       if (dynamicInstructions.length > 0) {\n2296:         serverWithInstructions.setInstructions?.(dynamicInstructions);\n2297:       }\n2298:     } catch (instructionErr: unknown) {\n2299:       const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);\n2300:       console.warn('[context-server] Dynamic instructions init failed (non-fatal):', message);\n2301:     }\n2302:   }\n2303: \n2304:   const backendOnly = process.env.SPECKIT_BACKEND_ONLY === '1';\n2305:   if (!backendOnly) {\n2306:     transportConnectedAt = new Date().toISOString();\n2307:     transport = new StdioServerTransport();\n2308:     await server.connect(transport);\n2309:   }\n2310:   scheduleBootFtsIntegrityCheck();\n2311:   registerInterval(() => vectorIndex.checkpointAllWal(), 300_000, { unref: true });\n2312:   launcherIdleMonitor = createLauncherIdleMonitor({\n2313:     serviceName: 'context-server',\n2314:     getActiveClientCount: () => getIpcBridgeStats().secondary_clients_count,\n2315:     onIdle: () => fatalShutdown('Launcher idle timeout reached, shutting down...', 0),\n2316:     log: (message) => console.error(message),\n2317:     stdin: backendOnly ? null : undefined,\n2318:   });\n2319:   ipcBridge = await startIpcSocketServer({\n2320:     socketPath: resolveIpcSocketPath(DATABASE_DIR),\n2321:     createServer: () => {\n2322:       const secondaryServer = createContextMcpServer();\n2323:       registerContextServerHandlers(secondaryServer);\n2324:       return secondaryServer;\n2325:     },\n2326:     log: (message) => console.error(message),\n2327:     onActivity: () => launcherIdleMonitor?.markActivity(),\n2328:   });\n2329:   const rssMb = Math.round(process.memoryUsage().rss / 1024 / 1024);\n2330:   console.error(`[health] startup pid=${process.pid} rss=${rssMb}MB uptime=0s`);\n2331:   console.error(backendOnly\n2332:     ? '[context-server] Context MCP server running on IPC socket only'\n2333:     : '[context-server] Context MCP server running on stdio and IPC socket');\n2334: \n2335: }\n2336: \n2337: const isMain = process.argv[1] && decodeURIComponent(import.meta.url).endsWith(process.argv[1].replace(/\\\\/g, '/'));\n2338: \n2339: if (isMain) {\n2340:   main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n2341: }\n\n(End of file - total 2341 lines)\n</content>","metadata":{"preview":"      console.error('[context-server] Cognitive memory modules initialized');\n      console.error(`[context-server] Working memory: ${workingMemory.isEnabled()}, Co-activation: ${coActivation.isEnabled()}`);\n    } catch (cognitiveErr: unknown) {\n      const message = cognitiveErr instanceof Error ? cognitiveErr.message : String(cognitiveErr);\n      console.warn('[context-server] Cognitive modules partially failed:', message);\n    }\n\n    try {\n      initExtractionAdapter(database, registerAfterToolCallback);\n      console.error('[context-server] Extraction adapter initialized');\n    } catch (extractionErr: unknown) {\n      const message = extractionErr instanceof Error ? extractionErr.message : String(extractionErr);\n      throw new Error(`[context-server] Extraction adapter startup failed: ${message}`);\n    }\n\n    try {\n      const resumedEmbedderJobs = resumeReindexJobs(database);\n      if (resumedEmbedderJobs.length > 0) {\n        console.error('[context-server] Resumed embedder re-index jobs: %d', resumedEmbedderJobs.length);\n      }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"      console.error('[context-server] Cognitive memory modules initialized');\n      console.error(`[context-server] Working memory: ${workingMemory.isEnabled()}, Co-activation: ${coActivation.isEnabled()}`);\n    } catch (cognitiveErr: unknown) {\n      const message = cognitiveErr instanceof Error ? cognitiveErr.message : String(cognitiveErr);\n      console.warn('[context-server] Cognitive modules partially failed:', message);\n    }\n\n    try {\n      initExtractionAdapter(database, registerAfterToolCallback);\n      console.error('[context-server] Extraction adapter initialized');\n    } catch (extractionErr: unknown) {\n      const message = extractionErr instanceof Error ? extractionErr.message : String(extractionErr);\n      throw new Error(`[context-server] Extraction adapter startup failed: ${message}`);\n    }\n\n    try {\n      const resumedEmbedderJobs = resumeReindexJobs(database);\n      if (resumedEmbedderJobs.length > 0) {\n        console.error('[context-server] Resumed embedder re-index jobs: %d', resumedEmbedderJobs.length);\n      }\n    } catch (reindexErr: unknown) {\n      const message = reindexErr instanceof Error ? reindexErr.message : String(reindexErr);\n      console.warn('[context-server] Embedder re-index resume failed:', message);\n    }\n\n    // Background retry job for pending embeddings\n    // Processes memories with failed embeddings in the background.\n    // No options passed: use BACKGROUND_JOB_CONFIG, which reads SPECKIT_RETRY_INTERVAL_MS /\n    // SPECKIT_RETRY_BATCH_SIZE / SPECKIT_RETRY_ENABLED. Passing hardcoded options here would\n    // spread after the env-derived config and silently clobber the tuned values.\n    try {\n      const retryJobResult = retryManager.startBackgroundJob();\n      if (retryJobResult) {\n        const { intervalMs, batchSize } = retryManager.BACKGROUND_JOB_CONFIG;\n        console.error(`[context-server] Background retry job started (interval: ${intervalMs}ms, batch: ${batchSize})`);\n      } else {\n        console.error('[context-server] Background retry job already running or disabled');\n      }\n    } catch (retryErr: unknown) {\n      const message = retryErr instanceof Error ? retryErr.message : String(retryErr);\n      console.warn('[context-server] Background retry job failed to start:', message);\n    }\n\n    // Shadow feedback holdout evaluation background scheduler.\n    // Replays recent production queries through a shadow-only path once the\n    // weekly holdout cycle is due. Fail-safe and gated by SPECKIT_SHADOW_FEEDBACK.\n    try {\n      const shadowSchedulerStarted = shadowEvaluationRuntime.startShadowEvaluationScheduler(database);\n      if (shadowSchedulerStarted) {\n        console.error('[context-server] Shadow feedback evaluation scheduler started');\n      } else {\n        console.error('[context-server] Shadow feedback evaluation scheduler not started (already running or disabled)');\n      }\n    } catch (shadowEvalErr: unknown) {\n      const message = shadowEvalErr instanceof Error ? shadowEvalErr.message : String(shadowEvalErr);\n      console.warn('[context-server] Shadow feedback evaluation scheduler failed to start:', message);\n    }\n\n    // Batch feedback learning — runs one cycle at startup (shadow-only, no live ranking mutations).\n    // Feature-flag gated by SPECKIT_BATCH_LEARNED_FEEDBACK (default ON, graduated).\n    try {\n      const batchResult = runBatchLearning(database);\n      if (batchResult.candidatesEvaluated > 0) {\n        console.error(`[context-server] Batch learning: ${batchResult.shadowApplied} shadow-applied, ${batchResult.skippedMinSupport} skipped (min-support), window=${Math.round((batchResult.runAt - batchResult.windowStart) / 86_400_000)}d`);\n      } else {\n        console.error('[context-server] Batch learning: no eligible candidates in window (or flag disabled)');\n      }\n    } catch (batchErr: unknown) {\n      const message = batchErr instanceof Error ? batchErr.message : String(batchErr);\n      console.warn('[context-server] Batch learning failed (non-fatal):', message);\n    }\n\n    // Session deduplication module\n    try {\n      const sessionResult = sessionManager.init(database);\n      if (sessionResult.success) {\n        console.error(`[context-server] Session manager initialized (enabled: ${sessionManager.isEnabled()})`);\n\n        // Crash Recovery Pattern\n        // Reset any sessions that were active when server last crashed\n        const recoveryResult = sessionManager.resetInterruptedSessions();\n        if (recoveryResult.interruptedCount > 0) {\n          console.error(`[context-server] Crash recovery: marked ${recoveryResult.interruptedCount} sessions as interrupted`);\n          // Log interrupted sessions for visibility\n          const interrupted = sessionManager.getInterruptedSessions();\n          if (interrupted.sessions && interrupted.sessions.length > 0) {\n            console.error('[context-server] Recoverable sessions:', interrupted.sessions.map((s: { sessionId: string }) => s.sessionId).join(', '));\n          }\n        }\n      } else {\n        console.warn('[context-server] Session manager initialization returned:', sessionResult.error);\n      }\n    } catch (sessionErr: unknown) {\n      const message = sessionErr instanceof Error ? sessionErr.message : String(sessionErr);\n      console.warn('[context-server] Session manager failed:', message);\n    }\n\n    // Async ingestion job queue initialization + crash recovery reset.\n    try {\n      const ingestInit = initIngestJobQueue({\n        processFile: async (filePath: string, governance) => {\n          await indexSingleFile(filePath, false, governance\n            ? { governance }\n            : {\n                provenance: {\n                  provenanceSource: 'memory_ingest_start',\n                  provenanceActor: 'async-ingest',\n                  tool: 'memory_ingest_start',\n                },\n              });\n        },\n      });\n      if (ingestInit.resetCount > 0) {\n        console.error(`[context-server] Ingest crash recovery reset ${ingestInit.resetCount} incomplete job(s) to queued`);\n      }\n    } catch (ingestInitErr: unknown) {\n      const message = ingestInitErr instanceof Error ? ingestInitErr.message : String(ingestInitErr);\n      console.warn('[context-server] Ingest queue init failed:', message);\n    }\n\n    // Background index-scan job store init + crash-recovery reset. An interrupted\n    // scan re-runs fresh, so incomplete jobs are marked failed (never re-enqueued);\n    // a hard-crash scan lease is already reaped by the lease-expiry path.\n    try {\n      ensureMaintenanceJobsTable();\n      const resetScanJobs = resetRunningJobsForKind('index_scan', { to: 'failed' });\n      if (resetScanJobs.length > 0) {\n        console.error(`[context-server] Index scan crash recovery marked ${resetScanJobs.length} incomplete job(s) failed`);\n      }\n    } catch (scanJobInitErr: unknown) {\n      const message = scanJobInitErr instanceof Error ? scanJobInitErr.message : String(scanJobInitErr);\n      console.warn('[context-server] Maintenance job store init failed:', message);\n    }\n\n    // Optional real-time markdown watcher for automatic re-indexing.\n    if (isFileWatcherEnabled()) {\n      try {\n        const watchPaths = getSpecsBasePaths(DEFAULT_BASE_PATH);\n        if (watchPaths.length > 0) {\n          fileWatcher = startFileWatcher({\n            paths: watchPaths,\n            reindexFn: async (filePath: string) => {\n              const result = await indexSingleFile(filePath, false);\n              if (isMutationStatus(result.status)) {\n                try {\n                  runPostMutationHooks('scan', {\n                    indexed: result.status === 'indexed' || result.status === 'deferred' ? 1 : 0,\n                    updated: result.status === 'updated' || result.status === 'reinforced' ? 1 : 0,\n                    staleDeleted: 0,\n                    staleDeleteFailed: 0,\n                    operation: 'file-watcher-reindex',\n                    filePath,\n                    status: result.status,\n                  });\n                } catch (_error: unknown) {\n                  // Non-fatal by design for file-watcher callback path.\n                }\n              }\n            },\n            removeFn: async (filePath: string) => {\n              await removeIndexedMemoriesForFile(filePath);\n            },\n          });\n          console.error(`[context-server] File watcher started for ${watchPaths.length} path(s)`);\n        } else {\n          console.warn('[context-server] File watcher enabled, but no spec directories were found');\n        }\n      } catch (watchErr: unknown) {\n        const message = watchErr instanceof Error ? watchErr.message : String(watchErr);\n        console.warn('[context-server] File watcher startup failed:', message);\n      }\n\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.error('[context-server] Integrity check failed:', message);\n    throw err instanceof Error ? err : new Error(message);\n  }\n\n    // Background startup scan\n    setImmediate(() => {\n      try {\n        runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n      } catch (repairErr: unknown) {\n        const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n        console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n      }\n      startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n    });\n  });\n\n  // Assign to module-level transport (not const) so shutdown handlers can close it\n  if (isDynamicInitEnabled()) {\n    try {\n      const dynamicInstructions = await buildServerInstructions();\n      if (dynamicInstructions.length > 0) {\n        serverWithInstructions.setInstructions?.(dynamicInstructions);\n      }\n    } catch (instructionErr: unknown) {\n      const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);\n      console.warn('[context-server] Dynamic instructions init failed (non-fatal):', message);\n    }\n  }\n\n  const backendOnly = process.env.SPECKIT_BACKEND_ONLY === '1';\n  if (!backendOnly) {\n    transportConnectedAt = new Date().toISOString();\n    transport = new StdioServerTransport();\n    await server.connect(transport);\n  }\n  scheduleBootFtsIntegrityCheck();\n  registerInterval(() => vectorIndex.checkpointAllWal(), 300_000, { unref: true });\n  launcherIdleMonitor = createLauncherIdleMonitor({\n    serviceName: 'context-server',\n    getActiveClientCount: () => getIpcBridgeStats().secondary_clients_count,\n    onIdle: () => fatalShutdown('Launcher idle timeout reached, shutting down...', 0),\n    log: (message) => console.error(message),\n    stdin: backendOnly ? null : undefined,\n  });\n  ipcBridge = await startIpcSocketServer({\n    socketPath: resolveIpcSocketPath(DATABASE_DIR),\n    createServer: () => {\n      const secondaryServer = createContextMcpServer();\n      registerContextServerHandlers(secondaryServer);\n      return secondaryServer;\n    },\n    log: (message) => console.error(message),\n    onActivity: () => launcherIdleMonitor?.markActivity(),\n  });\n  const rssMb = Math.round(process.memoryUsage().rss / 1024 / 1024);\n  console.error(`[health] startup pid=${process.pid} rss=${rssMb}MB uptime=0s`);\n  console.error(backendOnly\n    ? '[context-server] Context MCP server running on IPC socket only'\n    : '[context-server] Context MCP server running on stdio and IPC socket');\n\n}\n\nconst isMain = process.argv[1] && decodeURIComponent(import.meta.url).endsWith(process.argv[1].replace(/\\\\/g, '/'));\n\nif (isMain) {\n  main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n}","lineStart":2100,"lineEnd":2341,"totalLines":2341,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781764157100,"end":1781764157111}},"metadata":{"openai":{"itemId":"fc_0684a91ecc97d236016a33903be8ec8191863df922ab259f22"}},"id":"prt_ed96b6a170013UMrxJ5Yjlsbh5","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed96b5f83001dtcqVMPzlpEEJP"}}
