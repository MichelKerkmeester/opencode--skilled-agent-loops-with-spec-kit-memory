p-review', 1.6], ['sk-code-review', -0.6]],\n107:   ':review:confirm': [['deep-review', 1.6], ['sk-code-review', -0.6]],\n108:   // Domain phrase anchors (multi-token, so they lift confidence via the direct\n109:   // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n110:   'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n111:   'cms collection': [['mcp-code-mode', 1.4]],\n112:   'structural search': [['system-code-graph', 1.5]],\n113:   'code graph search': [['system-code-graph', 1.5]],\n114:   'find code that': [['system-code-graph', 1.4]],\n115:   'code that handles': [['system-code-graph', 1.4]],\n116:   '5d scoring': [['deep-agent-improvement', 1.5]],\n117:   '5-dimension agent scoring': [['deep-agent-improvement', 1.6]],\n118:   'integration scan': [['deep-agent-improvement', 1.5]],\n119:   'dynamic profile': [['deep-agent-improvement', 1.5]],\n120:   // Lane B (model-benchmark) command anchors. These benchmark or optimize a\n121:   // model / prompt framework against fixtures, routed by the\n122:   // /deep:start-model-benchmark-loop command (canonical deep-model-benchmark).\n123:   // Lane B runs as a MODE of the deep-agent-improvement skill. The projection\n124:   // exposes a single canonical node for that skill (deep-agent-improvement),\n125:   // so the disambiguation penalty must target that canonical id to actually\n126:   // lower the ranked Lane A candidate. The earlier alias-shaped target\n127:   // (command-spec-kit-deep-agent-improvement) is not a projection node, so it\n128:   // never reached the ranked skill and the penalty was inert. The bounded\n129:   // penalty keeps benchmark phrasing from out-ranking deep-model-benchmark.\n130:   'benchmark a model': [['deep-model-benchmark', 1.6], ['deep-agent-improvement', -0.6]],\n131:   'benchmark a prompt framework': [['deep-model-benchmark', 1.6], ['deep-agent-improvement', -0.6]],\n132:   'benchmark a prompt': [['deep-model-benchmark', 1.4], ['deep-agent-improvement', -0.4]],\n133:   'optimize a model': [['deep-model-benchmark', 1.5], ['deep-agent-improvement', -0.6]],\n134:   'optimize a prompt framework': [['deep-model-benchmark', 1.5], ['deep-agent-improvement', -0.6]],\n135:   'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-agent-improvement', -0.4]],\n136:   'model benchmark': [['deep-model-benchmark', 1.4], ['deep-agent-improvement', -0.4]],\n137:   'benchmark fixtures': [['deep-model-benchmark', 1.3]],\n138:   'prompt framework benchmark': [['deep-model-benchmark', 1.5], ['deep-agent-improvement', -0.4]],\n139:   'chrome devtools': [['mcp-chrome-devtools', 1]],\n140:   'staging url': [['mcp-chrome-devtools', 0.65]],\n141:   'staging site': [['mcp-chrome-devtools', 0.65]],\n142:   'staging website': [['mcp-chrome-devtools', 0.65]],\n143:   'live site': [['mcp-chrome-devtools', 0.65]],\n144:   'live website': [['mcp-chrome-devtools', 0.65]],\n145:   'live url': [['mcp-chrome-devtools', 0.65]],\n146:   'production site': [['mcp-chrome-devtools', 0.65]],\n147:   'production website': [['mcp-chrome-devtools', 0.65]],\n148:   'production url': [['mcp-chrome-devtools', 0.65]],\n149:   'browser console': [['mcp-chrome-devtools', 0.75]],\n150:   'cleaner prompt': [['sk-prompt', 1]],\n151:   'code review': [['sk-code-review', 1]],\n152:   'review the routing': [['sk-code-review', 0.6]],\n153:   'review the taxonomy': [['sk-code-review', 0.6]],\n154:   'review the routing taxonomy': [['sk-code-review', 1.1], ['sk-doc', -0.4]],\n155:   'review the packet docs': [['sk-code-review', 1.2]],\n156:   'audit packet docs': [['sk-code-review', 1.2]],\n157:   'documented consistently': [['sk-code-review', 1]],\n158:   'scoped correctly': [['sk-code-review', 1]],\n159:   'iteration is scoped': [['sk-code-review', 1]],\n160:   'classifier vocabulary': [['sk-code-review', 0.9]],\n161:   'commonjs helper': [['sk-code', 1]],\n162:   'create a prompt': [['sk-prompt', 0.95]],\n163:   'deep research': [['deep-research', 1]],\n164:   'deep review': [['deep-review', 1]],\n165:   'deep ai council': [['deep-ai-council', 1.6]],\n166:   'deep-ai-council': [['deep-ai-council', 1.6]],\n167:   'deep-research': [['deep-research', 1.3]],\n168:   'deep-review': [['deep-review', 1.3]],\n169:   'ai council': [['deep-ai-council', 1.4]],\n\n(Showing lines 90-169 of 332. Use offset=170 to continue.)\n</content>","metadata":{"preview":"};\n\nconst PHRASE_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  '/create:agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n  '/create:testing-playbook': [['create:testing-playbook', 1.8], ['command-create-testing-playbook', 1.2], ['sk-doc', 0.2]],\n  '/memory:save': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n  '/deep:start-research-loop': [['deep-research', 1.6], ['command-spec-kit', 0.45]],\n  '/deep:start-review-loop': [['deep-review', 1.6], ['command-spec-kit', 0.45]],\n  '/deep:start-model-benchmark-loop': [['deep-model-benchmark', 1.6], ['command-spec-kit', 0.45]],\n  '/deep:start-agent-improvement-loop': [['deep-agent-improvement', 1.6], ['command-spec-kit', 0.45]],\n  '/speckit:resume': [['system-spec-kit', 0.9], ['command-spec-kit', 0.75]],\n  'auto review release readiness': [['deep-review', 1]],\n  // Colon-command syntax (\":review:auto\") is a deep-review LOOP invocation,\n  // distinct from natural-language \"auto review this PR\" (which stays\n  // sk-code-review). Strong direct-evidence anchor + a bounded code-review\n  // penalty so the loop skill wins the rank.\n  ':review:auto': [['deep-review', 1.6], ['sk-code-review', -0.6]],\n  ':review:confirm': [['deep-review', 1.6], ['sk-code-review', -0.6]],\n  // Domain phrase anchors (multi-token, so they lift confidence via the direct\n  // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").","truncated":true,"loaded":[]},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","tim