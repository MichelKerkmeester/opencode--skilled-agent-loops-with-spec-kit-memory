r,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/advisor-server.ts:\n  Line 35:   startIpcSocketServer,\n\n  Line 315:   ipcBridge = await startIpcSocketServer({\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/lib/ipc-socket-toctou.vitest.ts:\n  Line 24:   startIpcSocketServer,\n\n  Line 40: // Bind a real raw UNIX socket and leave it listening so a subsequent startIpcSocketServer on the\n\n  Line 108:     const handle = await startIpcSocketServer({\n\n  Line 144:     const handle = await startIpcSocketServer({\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/lib/security-hardening.vitest.ts:\n  Line 6: import { startIpcSocketServer } from '../../lib/ipc/socket-server.js';\n\n  Line 32:       startIpcSocketServer({\n\n  Line 52:         startIpcSocketServer({\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts:\n  Line 11:   canUnlinkExistingSocket,\n\n  Line 15:   startIpcSocketServer,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/ipc-socket-fresh-bind.vitest.ts:\n  Line 5: // (canUnlinkExistingSocket). The FRESH-bind path — where no socket is\n\n  Line 23:   startIpcSocketServer,\n\n  Line 93:       startIpcSocketServer({\n\n  Line 109:     const handle = await startIpcSocketServer({\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts:\n  Line 188: // `canUnlinkExistingSocket` preserves the unlink-hardening intent.\n\n  Line 218: function canUnlinkExistingSocket(socketPath: string): boolean {\n\n  Line 307: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n\n  Line 326: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n\n  Line 356:     // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n\n  Line 443:       // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n\n  Line 445:       if (!canUnlinkExistingSocket(socketPath)) {\n\n  Line 507:   canUnlinkExistingSocket,\n\n  Line 511:   startIpcSocketServer,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/ipc-client-cap-fanout-stress.vitest.ts:\n  Line 12:   startIpcSocketServer,\n\n  Line 168:     const handle = await startIpcSocketServer({\n\n  Line 185:     const handle = await startIpcSocketServer({\n\n  Line 213:     const handle = await startIpcSocketServer({\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts:\n  Line 23:   startIpcSocketServer,\n\n  Line 265:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n\n  Line 283:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n\n  Line 306:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer, maxClients: 8 });\n\n  Line 328:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/ipc-socket-activity.vitest.ts:\n  Line 8:   startIpcSocketServer,\n\n  Line 77:     const handle = await startIpcSocketServer({\n","metadata":{"matches":50,"truncated":false},"title":"function startIpcSocketServer|canUnlinkExistingSocket|startIpcSocketServer","time":{"start":1781761514817,"end":1781761514919}},"metadata":{"openai":{"itemId":"fc_0cbfc703d10