"assets/**/motion*.*\",\n377:           \"references/smart_routing.md\",\n378:           \"references/webflow/javascript/quick_reference.md\",\n379:           \"references/motion_dev/**/*.md\",\n380:           \"assets/motion_dev/**/*\",\n381:           \"references/webflow/**/*\",\n382:           \"references/motion_dev/quick_start.md\",\n383:           \"references/motion_dev/integration_patterns.md\",\n384:           \"assets/motion_dev/install_card.md\",\n385:           \"assets/motion_dev/snippets/cdn_bootstrap.js\",\n386:           \"assets/motion_dev/snippets/in_view_reveal.js\"\n387:         ],\n388:         \"statedRoutingParsed\": true,\n389:         \"responseHead\": \"```json\\n{\\\"surface\\\":\\\"WEBFLOW\\\",\\\"subLanguage\\\":\\\"\\\",\\\"resources\\\":[\\\"references/stack_detection.md\\\",\\\"references/smart_routing.md\\\",\\\"references/webflow/implementation/animation_workflows.md\\\",\\\"references/webflow/implementation/implementation_workflows.md\\\",\\\"references/webflow/implementation/performance_patterns.\"\n390:       }\n\n(Showing lines 1-390 of 401. Use offset=391 to continue.)\n</content>","metadata":{"preview":"{\n  \"schemaVersion\": \"skill-benchmark-report.v1\",\n  \"status\": \"skill-benchmark-complete\",\n  \"mode\": \"skill-benchmark\",\n  \"scoringMethod\": \"mode-b-live\",\n  \"traceMode\": \"live\",\n  \"targetSkill\": {\n    \"id\": \"sk-code\",\n    \"root\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code\"\n  },\n  \"verdict\": \"CONDITIONAL\",\n  \"aggregateScore\": 71,\n  \"gate\": {\n    \"d5Score\": 100,\n    \"gateFailed\": false,\n    \"reason\": null\n  },\n  \"dimensionScores\": {\n    \"D1inter\": {\n      \"points\": 12,","truncated":true,"loaded":[]},"title":".opencode/skills/sk-code/benchmark/live-final/skill-benchmark-report.json","time":{"start":1780373712725,"end":1780373712738}},"metadata":{"openai":{"itemId":"fc_02b211f53edda6ed016a1e58d09c188191800fd0404d3614