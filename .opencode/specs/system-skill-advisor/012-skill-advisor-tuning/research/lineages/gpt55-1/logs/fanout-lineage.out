eview-mode\",\n106:       \"ai-council-mode\",\n107:       \"improvement-mode\",\n108:       \"agent-improvement\",\n109:       \"model-benchmark\",\n110:       \"skill-benchmark\",\n111:       \"non-dev-ai-system-refine\"\n112:     ],\n113:     \"key_files\": [\n114:       \".opencode/skills/deep-loop-workflows/SKILL.md\",\n115:       \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n116:       \".opencode/skills/deep-loop-workflows/deep-research/SKILL.md\",\n117:       \".opencode/skills/deep-loop-workflows/deep-review/SKILL.md\",\n118:       \".opencode/skills/deep-loop-workflows/deep-ai-council/SKILL.md\",\n119:       \".opencode/skills/deep-loop-workflows/deep-improvement/SKILL.md\",\n120:       \".opencode/skills/deep-loop-workflows/shared/synthesis/resource-map.cjs\"\n121:     ],\n122:     \"entities\": [\n123:       {\n124:         \"name\": \"deep-loop-workflows\",\n125:         \"kind\": \"skill\",\n126:         \"path\": \".opencode/skills/deep-loop-workflows/SKILL.md\",\n127:         \"source\": \"derived\"\n128:       },\n129:       {\n130:         \"name\": \"mode-registry\",\n131:         \"kind\": \"config\",\n132:         \"path\": \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n133:         \"source\": \"derived\"\n134:       },\n135:       {\n136:         \"name\": \"deep-loop-runtime\",\n137:         \"kind\": \"skill\",\n138:         \"path\": \".opencode/skills/deep-loop-runtime/SKILL.md\",\n139:         \"source\": \"derived\"\n140:       }\n141:     ],\n142:     \"causal_summary\": \"deep-loop-workflows is the single public skill that merges active deep-loop persona modes (deep-research, deep-review, deep-ai-council, deep-improvement) into one advisor identity with active mode packets, routed by workflowMode through mode-registry.json over the frozen MCP-free deep-loop-runtime backend. @context owns one-shot retrieval while research and review carry bounded context snapshots. Per-mode convergence, state, artifacts, and tool-permission contracts are preserved unflattened; the three-tier discriminator (workflowMode / runtimeLoopType / backendKind) keeps graph-backed modes and improvement-host/external-adapter modes distinct.\",\n143:     \"source_docs\": [\n144:       \"SKILL.md\",\n145:       \"README.md\",\n146:       \"mode-registry.json\",\n147:       \"deep-research/SKILL.md\",\n148:       \"deep-review/SKILL.md\",\n149:       \"deep-ai-council/SKILL.md\",\n150:       \"deep-improvement/SKILL.md\"\n151:     ],\n152:     \"created_at\": \"2026-06-15T00:00:00Z\",\n153:     \"last_updated_at\": \"2026-07-04T16:30:21Z\"\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 2,\n  \"packet_id\": \"147-deep-loop-workflows\",\n  \"skill_id\": \"deep-loop-workflows\",\n  \"family\": \"deep-loop\",\n  \"category\": \"workflow\",\n  \"importance_tier\": \"important\",\n  \"edges\": {\n    \"depends_on\": [\n      {\n        \"target\": \"deep-loop-runtime\",\n        \"weight\": 0.8,\n        \"context\": \"consumes the frozen MCP-free backend (executor, coverage-graph, scoring, fan-out, council primitives, promoted plumbing) for every mode\"\n      },\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.6,\n        \"context\": \"spec-folder workflow, artifact-root topology, and command YAML consumers\"\n      }\n    ],","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/graph-metadata.json","text":"{\n  \"schema_version\": 2,\n  \"packet_id\": \"147-deep-loop-workflows\",\n  \"skill_id\": \"deep-loop-workflows\",\n  \"family\": \"deep-loop\",\n  \"category\": \"workflow\",\n  \"importance_tier\": \"important\",\n  \"edges\": {\n    \"depends_on\": [\n      {\n        \"target\": \"deep-loop-runtime\",\n        \"weight\": 0.8,\n        \"context\": \"consumes the frozen MCP-free backend (executor, coverage-graph, scoring, fan-out, council primitives, promoted plumbing) for every mode\"\n      },\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.6,\n        \"context\": \"spec-folder workflow, artifact-root topology, and command YAML consumers\"\n      }\n    ],\n    \"enhances\": [\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.6,\n        \"context\": \"research and review modes provide bounded context outputs for spec-kit planning and implementation workflows\"\n      }\n    ],\n    \"siblings\": [\n      {\n        \"target\": \"deep-loop-runtime\",\n        \"weight\": 0.7,\n        \"context\": \"the backend peer in the deep-loop family\"\n      },\n      {\n        \"target\": \"sk-prompt\",\n        \"weight\": 0.4,\n        \"context\": \"improvement utility peer\"\n      }\n    ],\n    \"conflicts_with\": [],\n    \"prerequisite_for\": []\n  },\n  \"manual\": {\n    \"depends_on\": [\"deep-loop-runtime\"],\n    \"related_to\": [\"system-spec-kit\", \"system-code-graph\", \"system-skill-advisor\"]\n  },\n  \"domains\": [\n    \"deep-loop\",\n    \"workflow\",\n    \"research\",\n    \"code-review\",\n    \"ai-council\",\n    \"agent-improvement\",\n    \"convergence\",\n    \"coverage-graph\",\n    \"mode-registry\"\n  ],\n  \"intent_signals\": [\n    \"deep loop workflow\",\n    \"deep-research\",\n    \"deep-review\",\n    \"deep-ai-council\",\n    \"deep-improvement\",\n    \"research loop\",\n    \"code review loop\",\n    \"ai council deliberation\",\n    \"agent improvement benchmark\"\n  ],\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"deep-loop-workflows\",\n      \"deep loop workflows\",\n      \"deep research\",\n      \"research loop\",\n      \"iterative investigation workflow\",\n      \"deep-research\",\n      \"autoresearch\",\n      \"deep review\",\n      \"review loop\",\n      \"iterative code audit\",\n      \"severity weighted findings\",\n      \"deep-review\",\n      \"code audit\",\n      \"deep-ai-council\",\n      \"ai council deliberation\",\n      \"multi-seat planning council\",\n      \"council convergence\",\n      \"improve agent\",\n      \"evaluate agent\",\n      \"score agent candidate\",\n      \"deep-improvement\",\n      \"agent-improvement\",\n      \"model benchmark\",\n      \"benchmark a model or prompt framework\",\n      \"skill benchmark\",\n      \"non-dev ai system\"\n    ],\n    \"key_topics\": [\n      \"deep-loop-workflows\",\n      \"mode-registry\",\n      \"workflowMode\",\n      \"runtimeLoopType\",\n      \"backendKind\",\n      \"research-mode\",\n      \"review-mode\",\n      \"ai-council-mode\",\n      \"improvement-mode\",\n      \"agent-improvement\",\n      \"model-benchmark\",\n      \"skill-benchmark\",\n      \"non-dev-ai-system-refine\"\n    ],\n    \"key_files\": [\n      \".opencode/skills/deep-loop-workflows/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n      \".opencode/skills/deep-loop-workflows/deep-research/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/deep-review/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/deep-ai-council/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/deep-improvement/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/shared/synthesis/resource-map.cjs\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"deep-loop-workflows\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/deep-loop-workflows/SKILL.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"mode-registry\",\n        \"kind\": \"config\",\n        \"path\": \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"deep-loop-runtime\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/deep-loop-runtime/SKILL.md\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"deep-loop-workflows is the single public skill that merges active deep-loop persona modes (deep-research, deep-review, deep-ai-council, deep-improvement) into one advisor identity with active mode packets, routed by workflowMode through mode-registry.json over the frozen MCP-free deep-loop-runtime backend. @context owns one-shot retrieval while research and review carry bounded context snapshots. Per-mode convergence, state, artifacts, and tool-permission contracts are preserved unflattened; the three-tier discriminator (workflowMode / runtimeLoopType / backendKind) keeps graph-backed modes and improvement-host/external-adapter modes distinct.\",\n    \"source_docs\": [\n      \"SKILL.md\",\n      \"README.md\",\n      \"mode-registry.json\",\n      \"deep-research/SKILL.md\",\n      \"deep-review/SKILL.md\",\n      \"deep-ai-council/SKILL.md\",\n      \"deep-improvement/SKILL.md\"\n    ],\n    \"created_at\": \"2026-06-15T00:00:00Z\",\n    \"last_updated_at\": \"2026-07-04T16:30:21Z\"\n  }\n}","lineStart":1,"lineEnd":155,"totalLines":155,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/graph-metadata.json","time":{"start":1783437201995,"end":1783437201997}},"metadata":{"openai":{"itemId":"fc_002f97d8e79f1a0a016a4d1791ce088191bb3879fcac155cb1"}},"id":"prt_f3d24124a001IoV4o1NCGkLkPL","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ"}}
{"type":"tool_use","timestamp":1783437202004,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_BP4xgARRablUj4secmzo0oDs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","offset":1,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Ambiguity\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorScoredRecommendation } from './types.js';\n6: \n7: export const AMBIGUITY_MARGIN = 0.05;\n8: export const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n9: \n10: // Compute ambiguity from ranking `score` so the cluster aligns\n11: // with the score-based fusion ranking (top-two-by-confidence may not match\n12: // top-two-by-score).\n13: //\n14: // Also compute on `confidence` and union the two\n15: // clusters. Score-margin keeps ranking alignment; confidence-margin restores\n16: // the documented \"0.05 confidence window\" and catches\n17: // cross-domain prompts where confidence is near-tied (user-visible signal)\n18: // even when score gaps just exceed the score margin. A candidate is in the\n19: // ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n20: // \"outside both margins\" is required to be unambiguously ranked.\n21: \n22: function ambiguousCluster(\n23:   recommendations: readonly AdvisorScoredRecommendation[],\n24: ): AdvisorScoredRecommendation[] {\n25:   const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);\n26:   const [top] = passing;\n27:   if (!top) return [];\n28:   return passing.filter((recommendation) => {\n29:     const scoreGap = Math.abs(top.score - recommendation.score);\n30:     const confidenceGap = Math.abs(top.confidence - recommendation.confidence);\n31:     return (\n32:       scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON\n33:       || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON\n34:     );\n35:   });\n36: }\n37: \n38: export function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {\n39:   // Name preserved for back-compat with existing call sites; semantics are\n40:   // now \"is the passing top a member of an ambiguity cluster of size >= 2\".\n41:   return ambiguousCluster(recommendations).length >= 2;\n42: }\n43: \n44: export function applyAmbiguity(\n45:   recommendations: readonly AdvisorScoredRecommendation[],\n46: ): AdvisorScoredRecommendation[] {\n47:   const cluster = ambiguousCluster(recommendations);\n48:   if (cluster.length < 2) return [...recommendations];\n49:   const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));\n50:   return recommendations.map((recommendation) => (\n51:     ambiguousSet.has(recommendation.skill)\n52:       ? {\n53:         ...recommendation,\n54:         ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),\n55:       }\n56:       : recommendation\n57:   ));\n58: }\n\n(End of file - total 58 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Ambiguity\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorScoredRecommendation } from './types.js';\n\nexport const AMBIGUITY_MARGIN = 0.05;\nexport const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n\n// Compute ambiguity from ranking `score` so the cluster aligns\n// with the score-based fusion ranking (top-two-by-confidence may not match\n// top-two-by-score).\n//\n// Also compute on `confidence` and union the two\n// clusters. Score-margin keeps ranking alignment; confidence-margin restores\n// the documented \"0.05 confidence window\" and catches\n// cross-domain prompts where confidence is near-tied (user-visible signal)\n// even when score gaps just exceed the score margin. A candidate is in the\n// ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n// \"outside both margins\" is required to be unambiguously ranked.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Ambiguity\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorScoredRecommendation } from './types.js';\n\nexport const AMBIGUITY_MARGIN = 0.05;\nexport const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n\n// Compute ambiguity from ranking `score` so the cluster aligns\n// with the score-based fusion ranking (top-two-by-confidence may not match\n// top-two-by-score).\n//\n// Also compute on `confidence` and union the two\n// clusters. Score-margin keeps ranking alignment; confidence-margin restores\n// the documented \"0.05 confidence window\" and catches\n// cross-domain prompts where confidence is near-tied (user-visible signal)\n// even when score gaps just exceed the score margin. A candidate is in the\n// ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n// \"outside both margins\" is required to be unambiguously ranked.\n\nfunction ambiguousCluster(\n  recommendations: readonly AdvisorScoredRecommendation[],\n): AdvisorScoredRecommendation[] {\n  const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);\n  const [top] = passing;\n  if (!top) return [];\n  return passing.filter((recommendation) => {\n    const scoreGap = Math.abs(top.score - recommendation.score);\n    const confidenceGap = Math.abs(top.confidence - recommendation.confidence);\n    return (\n      scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON\n      || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON\n    );\n  });\n}\n\nexport function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {\n  // Name preserved for back-compat with existing call sites; semantics are\n  // now \"is the passing top a member of an ambiguity cluster of size >= 2\".\n  return ambiguousCluster(recommendations).length >= 2;\n}\n\nexport function applyAmbiguity(\n  recommendations: readonly AdvisorScoredRecommendation[],\n): AdvisorScoredRecommendation[] {\n  const cluster = ambiguousCluster(recommendations);\n  if (cluster.length < 2) return [...recommendations];\n  const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));\n  return recommendations.map((recommendation) => (\n    ambiguousSet.has(recommendation.skill)\n      ? {\n        ...recommendation,\n        ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),\n      }\n      : recommendation\n  ));\n}","lineStart":1,"lineEnd":58,"totalLines":58,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","time":{"start":1783437201991,"end":1783437202003}},"metadata":{"openai":{"itemId":"fc_002f97d8e79f1a0a016a4d1791cdf48191a1ca9692e11d05de"}},"id":"prt_f3d241246001PrVit2LHpssAf8","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ"}}
{"type":"tool_use","timestamp":1783437202005,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_JXrf8QdtY2xGQgjIWxrBuiDi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Derived Generated Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: // Pull the age-haircut policy from the scorer-local seam\n6: // instead of reaching into the lifecycle subsystem directly. The lifecycle\n7: // implementation stays the source of truth; the seam keeps the scorer's\n8: // dependency direction inward.\n9: import { applyAgeHaircutToLane } from '../age-policy.js';\n10: import type { NormalizedAffordance } from '../../affordance-normalizer.js';\n11: import type { AdvisorProjection, LaneMatch } from '../types.js';\n12: import { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n13: \n14: function affordancesForSkill(\n15:   affordances: readonly NormalizedAffordance[],\n16:   skillId: string,\n17: ): NormalizedAffordance[] {\n18:   return affordances.filter((affordance) => affordance.skillId === skillId);\n19: }\n20: \n21: // Doc-level harvest contribution is bounded twice: only the strongest\n22: // few docs count (so doc-heavy skills cannot outscore lean skills on\n23: // volume alone) and the summed contribution is capped below the level a\n24: // skill's own curated triggers can reach.\n25: const DOC_TOP_N = 3;\n26: const DOC_PHRASE_FACTOR = 0.5;\n27: const DOC_CONTRIBUTION_CAP = 0.45;\n28: \n29: interface DocMatch {\n30:   readonly docPath: string;\n31:   readonly score: number;\n32: }\n33: \n34: function scoreDocTriggers(\n35:   lower: string,\n36:   skill: AdvisorProjection['skills'][number],\n37: ): DocMatch[] {\n38:   const matches: DocMatch[] = [];\n39:   for (const doc of skill.docTriggers ?? []) {\n40:     let best = 0;\n41:     for (const phrase of doc.phrases) {\n42:       if (!matchesPhraseBoundary(lower, phrase)) continue;\n43:       best = Math.max(best, phraseSpecificity(phrase));\n44:     }\n45:     if (best <= 0) continue;\n46:     matches.push({ docPath: doc.docPath, score: best * doc.tierWeight });\n47:   }\n48:   return matches.sort((left, right) => right.score - left.score).slice(0, DOC_TOP_N);\n49: }\n50: \n51: export function scoreDerivedLane(\n52:   prompt: string,\n53:   projection: AdvisorProjection,\n54:   now: Date = new Date(),\n55:   affordances: readonly NormalizedAffordance[] = [],\n56: ): LaneMatch[] {\n57:   const lower = prompt.toLowerCase();\n58:   const tokens = tokenize(prompt);\n59:   const matches: LaneMatch[] = [];\n60: \n61:   for (const skill of projection.skills) {\n62:     const phrases = [...skill.derivedTriggers, ...skill.derivedKeywords];\n63:     const skillAffordances = affordancesForSkill(affordances, skill.id);\n64:     const affordancePhrases = skillAffordances.flatMap((affordance) => [...affordance.derivedTriggers]);\n65:     const docMatches = scoreDocTriggers(lower, skill);\n66:     if (phrases.length === 0 && affordancePhrases.length === 0 && docMatches.length === 0) continue;\n67:     const evidence: string[] = docMatches.map((doc) => `doc:${doc.docPath}`);\n68:     let score = Math.min(\n69:       docMatches.reduce((total, doc) => total + doc.score, 0) * DOC_PHRASE_FACTOR,\n70:       DOC_CONTRIBUTION_CAP,\n71:     );\n72:     for (const phrase of phrases) {\n73:       if (!matchesPhraseBoundary(lower, phrase)) continue;\n74:       score += phraseSpecificity(phrase) * 0.7;\n75:       evidence.push(`derived:${phrase}`);\n76:     }\n77:     for (const affordance of skillAffordances) {\n78:       let matched = false;\n79:       for (const phrase of affordance.derivedTriggers) {\n80:         if (!matchesPhraseBoundary(lower, phrase)) continue;\n81:         matched = true;\n82:         score += phraseSpecificity(phrase) * 0.45;\n83:       }\n84:       if (matched) evidence.push(affordance.evidenceLabel);\n85:     }\n86:     score += scoreTokenOverlap(tokens, phrases) * 0.45;\n87:     score += scoreTokenOverlap(tokens, affordancePhrases) * 0.25;\n88:     // Decay by the skill's own derived-content age — derivedGeneratedAt is the\n89:     // author/sync time of the derived block (author-time, not refreshed by\n90:     // rebuild; see SkillProjection.derivedGeneratedAt). The projection.generatedAt\n91:     // fallback is a last-resort, timestamp-less value (near-now on every run, so\n92:     // it exempts the skill from the haircut), used ONLY when a skill has no\n93:     // derived.generated_at — it is not a runtime freshness signal.\n94:     const adjusted = applyAgeHaircutToLane(\n95:       { trustLane: 'derived_generated', score: Math.min(score, 1) },\n96:       {\n97:         generatedAt: skill.derivedGeneratedAt ?? projection.generatedAt,\n98:         now,\n99:         lifecycleStatus: skill.lifecycleStatus,\n100:       },\n101:     );\n102:     if (adjusted.score <= 0.05) continue;\n103:     matches.push({\n104:       skillId: skill.id,\n105:       lane: 'derived_generated',\n106:       score: Number((adjusted.score * (skill.derivedDemotion ?? 1)).toFixed(6)),\n107:       evidence: evidence.slice(0, 6),\n108:     });\n109:   }\n110: \n111:   return matches;\n112: }\n\n(End of file - total 112 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Generated Lane\n// ───────────────────────────────────────────────────────────────\n\n// Pull the age-haircut policy from the scorer-local seam\n// instead of reaching into the lifecycle subsystem directly. The lifecycle\n// implementation stays the source of truth; the seam keeps the scorer's\n// dependency direction inward.\nimport { applyAgeHaircutToLane } from '../age-policy.js';\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n\nfunction affordancesForSkill(\n  affordances: readonly NormalizedAffordance[],\n  skillId: string,\n): NormalizedAffordance[] {\n  return affordances.filter((affordance) => affordance.skillId === skillId);\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Generated Lane\n// ───────────────────────────────────────────────────────────────\n\n// Pull the age-haircut policy from the scorer-local seam\n// instead of reaching into the lifecycle subsystem directly. The lifecycle\n// implementation stays the source of truth; the seam keeps the scorer's\n// dependency direction inward.\nimport { applyAgeHaircutToLane } from '../age-policy.js';\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, scoreTokenOverlap, tokenize } from '../text.js';\n\nfunction affordancesForSkill(\n  affordances: readonly NormalizedAffordance[],\n  skillId: string,\n): NormalizedAffordance[] {\n  return affordances.filter((affordance) => affordance.skillId === skillId);\n}\n\n// Doc-level harvest contribution is bounded twice: only the strongest\n// few docs count (so doc-heavy skills cannot outscore lean skills on\n// volume alone) and the summed contribution is capped below the level a\n// skill's own curated triggers can reach.\nconst DOC_TOP_N = 3;\nconst DOC_PHRASE_FACTOR = 0.5;\nconst DOC_CONTRIBUTION_CAP = 0.45;\n\ninterface DocMatch {\n  readonly docPath: string;\n  readonly score: number;\n}\n\nfunction scoreDocTriggers(\n  lower: string,\n  skill: AdvisorProjection['skills'][number],\n): DocMatch[] {\n  const matches: DocMatch[] = [];\n  for (const doc of skill.docTriggers ?? []) {\n    let best = 0;\n    for (const phrase of doc.phrases) {\n      if (!matchesPhraseBoundary(lower, phrase)) continue;\n      best = Math.max(best, phraseSpecificity(phrase));\n    }\n    if (best <= 0) continue;\n    matches.push({ docPath: doc.docPath, score: best * doc.tierWeight });\n  }\n  return matches.sort((left, right) => right.score - left.score).slice(0, DOC_TOP_N);\n}\n\nexport function scoreDerivedLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  now: Date = new Date(),\n  affordances: readonly NormalizedAffordance[] = [],\n): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = tokenize(prompt);\n  const matches: LaneMatch[] = [];\n\n  for (const skill of projection.skills) {\n    const phrases = [...skill.derivedTriggers, ...skill.derivedKeywords];\n    const skillAffordances = affordancesForSkill(affordances, skill.id);\n    const affordancePhrases = skillAffordances.flatMap((affordance) => [...affordance.derivedTriggers]);\n    const docMatches = scoreDocTriggers(lower, skill);\n    if (phrases.length === 0 && affordancePhrases.length === 0 && docMatches.length === 0) continue;\n    const evidence: string[] = docMatches.map((doc) => `doc:${doc.docPath}`);\n    let score = Math.min(\n      docMatches.reduce((total, doc) => total + doc.score, 0) * DOC_PHRASE_FACTOR,\n      DOC_CONTRIBUTION_CAP,\n    );\n    for (const phrase of phrases) {\n      if (!matchesPhraseBoundary(lower, phrase)) continue;\n      score += phraseSpecificity(phrase) * 0.7;\n      evidence.push(`derived:${phrase}`);\n    }\n    for (const affordance of skillAffordances) {\n      let matched = false;\n      for (const phrase of affordance.derivedTriggers) {\n        if (!matchesPhraseBoundary(lower, phrase)) continue;\n        matched = true;\n        score += phraseSpecificity(phrase) * 0.45;\n      }\n      if (matched) evidence.push(affordance.evidenceLabel);\n    }\n    score += scoreTokenOverlap(tokens, phrases) * 0.45;\n    score += scoreTokenOverlap(tokens, affordancePhrases) * 0.25;\n    // Decay by the skill's own derived-content age — derivedGeneratedAt is the\n    // author/sync time of the derived block (author-time, not refreshed by\n    // rebuild; see SkillProjection.derivedGeneratedAt). The projection.generatedAt\n    // fallback is a last-resort, timestamp-less value (near-now on every run, so\n    // it exempts the skill from the haircut), used ONLY when a skill has no\n    // derived.generated_at — it is not a runtime freshness signal.\n    const adjusted = applyAgeHaircutToLane(\n      { trustLane: 'derived_generated', score: Math.min(score, 1) },\n      {\n        generatedAt: skill.derivedGeneratedAt ?? projection.generatedAt,\n        now,\n        lifecycleStatus: skill.lifecycleStatus,\n      },\n    );\n    if (adjusted.score <= 0.05) continue;\n    matches.push({\n      skillId: skill.id,\n      lane: 'derived_generated',\n      score: Number((adjusted.score * (skill.derivedDemotion ?? 1)).toFixed(6)),\n      evidence: evidence.slice(0, 6),\n    });\n  }\n\n  return matches;\n}","lineStart":1,"lineEnd":112,"totalLines":112,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/derived.ts","time":{"start":1783437201993,"end":1783437202005}},"metadata":{"openai":{"itemId":"fc_002f97d8e79f1a0a016a4d1791ce008191937706b5fa27592a"}},"id":"prt_f3d2412480011i5tvn92sW3EJ2","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ"}}
{"type":"step_finish","timestamp":1783437202415,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"id":"prt_f3d2413ec001uyBbVQ7LwLpamX","reason":"tool-calls","snapshot":"3e0a2609233042b8a75b514995cd4b8c73f28055","messageID":"msg_f3d23e6da001pKWl3gbN0YbFRZ","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","type":"step-finish","tokens":{"total":77502,"input":12539,"output":430,"reasoning":21,"cache":{"write":0,"read":64512}},"cost":0}}
{"type":"step_start","timestamp":1783437206062,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"id":"prt_f3d24222d001taERLa0WbhMCQw","messageID":"msg_f3d241668001EHlfCAY3jsFXlr","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","snapshot":"3e0a2609233042b8a75b514995cd4b8c73f28055","type":"step-start"}}
{"type":"text","timestamp":1783437215414,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"id":"prt_f3d2425d6001U8TWdHyPQuGGzc","messageID":"msg_f3d241668001EHlfCAY3jsFXlr","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","type":"text","text":"The projection layer separates `derived.trigger_phrases` from `derived.key_topics/entities/key_files/source_docs`; the derived lane then scores both together. That makes Angle 4 important: current guard coverage over only trigger phrases misses projected key-topic/keyword effects.","time":{"start":1783437206998,"end":1783437215408},"metadata":{"openai":{"itemId":"msg_06b076b532d084a9016a4d1796e92081988317ac94d1ccb8c5","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1783437215679,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_9vLIb84sH5qDhaq1IwZ6yalv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":521,"limit":450},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n521:   }\n522:   if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n523:     return true;\n524:   }\n525:   if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n526:     return true;\n527:   }\n528:   if (skillId === 'deep-loop-workflows' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n529:     return true;\n530:   }\n531:   if (skillId === 'mcp-chrome-devtools' && /\\b(\\.opencode\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n532:     return true;\n533:   }\n534:   // Browser/devtools inspection is a genuine chrome-devtools task even though\n535:   // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n536:   // explainer floor when the prompt carries devtools-specific vocabulary.\n537:   if (skillId === 'mcp-chrome-devtools'\n538:     && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n539:     return true;\n540:   }\n541:   if (skillId === 'sk-code' && /\\bgate-3-classifier\\.ts\\b/.test(promptLower)) {\n542:     return true;\n543:   }\n544:   return false;\n545: }\n546: \n547: function isPlainFileSavePrompt(promptLower: string): boolean {\n548:   return FILE_SAVE_OPERATION.test(promptLower) && !MEMORY_SAVE_CONTEXT_ANCHOR.test(promptLower.replace(/\\bfile(s)?\\b/g, ''));\n549: }\n550: \n551: function primaryIntentBonus(\n552:   promptLower: string,\n553:   recommendation: AdvisorScoredRecommendation,\n554:   selfRecommendationGuardEnabled: boolean,\n555: ): number {\n556:   const R = SCORING_CALIBRATION.routing;\n557:   if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n558:     if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n559:   }\n560:   if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n561:     if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n562:   }\n563:   if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n564:     if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchOtherSkillsPenalty;\n565:   }\n566:   if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n567:     if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n568:   }\n569:   if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n570:     if (recommendation.skill === 'sk-code') return R.compareAuditCodeReviewBonus;\n571:   }\n572:   if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n573:     if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n574:     if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;\n575:   }\n576:   if (promptLower.includes('/speckit:resume')) {\n577:     if (recommendation.skill === 'system-spec-kit') return R.speckitResumeSpecKitBonus;\n578:     if (recommendation.skill === 'command-spec-kit') return R.speckitResumeCommandPenalty;\n579:   }\n580:   if (promptLower.includes('/speckit:plan')) {\n581:     if (recommendation.skill === 'command-spec-kit') return R.speckitPlanCommandBonus;\n582:     if (recommendation.skill === 'sk-doc') return R.speckitPlanSkDocPenalty;\n583:   }\n584:   // External-tool-chain (\"call_tool_chain\") vocabulary belongs to mcp-code-mode,\n585:   // not the generic code skill. Disambiguate so the best guess for these\n586:   // toolchain-shaped prompts is mcp-code-mode.\n587:   // Toolchain + external-data-source vocabulary (webflow CMS, cms collection)\n588:   // is mcp-code-mode territory, not the generic code skill.\n589:   if (/\\b(call_tool_chain|code mode|tool ?chain|api chain|webflow cms|cms collection)\\b/.test(promptLower)) {\n590:     if (recommendation.skill === 'mcp-code-mode') return R.mcpToolchainCodeModeBonus;\n591:     if (recommendation.skill === 'sk-code') return R.mcpToolchainSkCodePenalty;\n592:   }\n593:   // A \"code audit\" is a code-review task, not a deep-review loop. On the\n594:   // near-tie this phrase produces, prefer sk-code over deep-review.\n595:   if (/\\bcode audit\\b/.test(promptLower)) {\n596:     if (recommendation.skill === 'sk-code') return R.codeAuditCodeReviewBonus;\n597:     if (recommendation.skill === 'deep-review' || recommendation.skill === 'deep-loop-workflows') return R.codeAuditDeepReviewPenalty;\n598:   }\n599:   // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n600:   // loop; rank it above single-pass code review.\n601:   if (/:review:(auto|confirm)\\b/.test(promptLower)) {\n602:     if (recommendation.skill === 'deep-loop-workflows') return R.reviewLoopDeepReviewBonus;\n603:     if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n604:   }\n605:   // Auditing recommendation quality is a review task, not an advisor-self task.\n606:   if (/\\baudit\\b/.test(promptLower) && /\\b(recommendation|recommendations|recommendation quality|routing quality)\\b/.test(promptLower)) {\n607:     if (recommendation.skill === 'sk-code') return R.auditRecsCodeReviewBonus;\n608:     if (!selfRecommendationGuardEnabled && isAdvisorSelfRecommendationSkill(recommendation.skill)) return R.auditRecsAdvisorPenalty;\n609:     if (shouldApplyAdvisorSelfRecommendationGuard({\n610:       skillId: recommendation.skill,\n611:       guardEnabled: selfRecommendationGuardEnabled,\n612:     })) {\n613:       return R.auditRecsAdvisorPenalty;\n614:     }\n615:   }\n616:   if (/\\b(save context|save memory)\\b/.test(promptLower)) {\n617:     if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;\n618:     if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;\n619:   }\n620:   if (/\\b(create (a )?new agent|create agent)\\b/.test(promptLower) || promptLower.includes('/create:agent')) {\n621:     if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;\n622:     if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;\n623:   }\n624:   if (/\\bcreate (a )?(test|testing) playbook\\b/.test(promptLower) || promptLower.includes('/create:manual-testing-playbook')) {\n625:     if (recommendation.skill === 'create:manual-testing-playbook' || recommendation.skill === 'command-create-manual-testing-playbook') return R.createTestingPlaybookBonus;\n626:     if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;\n627:     if (recommendation.skill === 'deep-loop-workflows') return R.createTestingPlaybookOtherSkillsPenalty;\n628:   }\n629:   if (/\\bphase folder\\b/.test(promptLower)) {\n630:     if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n631:   }\n632:   return 0;\n633: }\n634: \n635: export function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n636:   const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n637:   const promptLower = prompt.toLowerCase();\n638:   const queryClass = classifyAdvisorQuery(promptLower);\n639:   const weights = effectiveScorerWeights(\n640:     options.laneWeightsOverride,\n641:     isAdvisorQueryClassRoutingEnabled() ? queryClass : 'unknown',\n642:   );\n643:   const disabled = new Set(options.disabledLanes ?? []);\n644:   const affordances = normalize(options.affordances ?? []);\n645:   const useRrfFusion = isAdvisorRrfFusionEnabled();\n646:   const useExactSemanticRerank = useRrfFusion && isAdvisorExactSemanticRerankEnabled();\n647:   const selfRecommendationGuardEnabled = isAdvisorSelfRecommendationGuardEnabled();\n648:   const { laneScores, graphConflictMatches } = buildLaneScores(\n649:     prompt,\n650:     projection,\n651:     disabled,\n652:     affordances,\n653:     useRrfFusion,\n654:     selfRecommendationGuardEnabled,\n655:   );\n656:   const runtimeLaneHealth = projectionRuntimeLaneHealth(projection, options.runtimeLaneHealth);\n657:   const laneHealth = buildLaneRuntimeHealth(laneScores, disabled, runtimeLaneHealth);\n658:   const degradedLanes = laneHealth\n659:     .filter((lane) => lane.status === 'runtime_degraded')\n660:     .map((lane) => lane.lane);\n661:   const runtimeDegradedLanes = new Set(degradedLanes);\n662:   const graphConflictIndex = buildConflictMatchIndex(graphConflictMatches);\n663:   const rrfFusion = useRrfFusion\n664:     ? fuseAdvisorLaneRanks(laneScores, weights, disabled, runtimeDegradedLanes)\n665:     : null;\n666:   const laneScoreIndexes = Object.fromEntries(\n667:     SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n668:   ) as Record<ScorerLane, LaneMatchIndex>;\n669:   const liveTotal = SCORER_LANES\n670:     .filter((lane) => !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n671:     .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n672:   const runtimeLiveLaneCount = SCORER_LANES\n673:     .filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n674:     .length;\n675:   if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n676:     for (const lane of SCORER_LANES) {\n677:       if (!isLiveScorerLane(lane) || disabled.has(lane) || runtimeDegradedLanes.has(lane)) continue;\n678:       speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n679:     }\n680:   }\n681:   const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n682:   const hasTaskIntent = TASK_INTENT.test(promptLower);\n683:   const recommendations: AdvisorScoredRecommendation[] = [];\n684: \n685:   for (const skill of projection.skills) {\n686:     if (!isDefaultRoutable(promptLower, skill)) continue;\n687:     const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n688:       const laneMatch = laneScoreIndexes[lane].get(skill.id);\n689:       const rawScore = laneMatch?.rawScore ?? 0;\n690:       const shadowOnly = !isLiveScorerLane(lane);\n691:       const runtimeDegraded = runtimeDegradedLanes.has(lane);\n692:       return {\n693:         lane,\n694:         rawScore,\n695:         weightedScore: shadowOnly || disabled.has(lane) || runtimeDegraded ? 0 : rawScore * weights[lane],\n696:         weight: disabled.has(lane) || runtimeDegraded ? 0 : weights[lane],\n697:         evidence: laneMatch?.evidence ?? [],\n698:         shadowOnly,\n699:       };\n700:     });\n701:     const weightedScore = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n702:     const rrfScore = rrfFusion?.scoreBySkill.get(skill.id);\n703:     const score = useRrfFusion ? rrfScore ?? 0 : weightedScore;\n704:     if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n705:     if (isSpeckitMetricsEnabled()) {\n706:       for (const contribution of contributions) {\n707:         if (contribution.weightedScore !== 0) {\n708:           speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n709:         }\n710:       }\n711:     }\n712: \n713:     const directScore = Math.max(\n714:       contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n715:       contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n716:     );\n717:     const derivedDominant = isDerivedDominant(contributions);\n718:     const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n719:     const explicitMatch = laneScoreIndexes.explicit_author.get(skill.id);\n720:     const liveNormalized = score / liveTotal;\n721:     let confidence = confidenceFor({\n722:       liveNormalized,\n723:       directScore,\n724:       readOnlyExplainer,\n725:       hasExplicitWorkflowSignal: explicitSignal,\n726:       hasTaskIntent,\n727:       readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n728:       derivedDominant,\n729:       skillId: skill.id,\n730:       selfRecommendationGuardEnabled,\n731:       hasAdvisorSelfAuthoredSignal: hasAdvisorSelfAuthoredSignal(skill.id, explicitMatch),\n732:     });\n733:     if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n734:       confidence = Math.min(confidence, 0.49);\n735:     }\n736:     recommendations.push({\n737:       skill: skill.id,\n738:       kind: skill.kind,\n739:       confidence,\n740:       uncertainty: uncertaintyFor(contributions, confidence, 0),\n741:       passes_threshold: false,\n742:       reason: attributionReason(contributions),\n743:       score: useRrfFusion ? score : Number(score.toFixed(6)),\n744:       laneContributions: contributions,\n745:       dominantLane: dominantLane(contributions),\n746:       redirectTo: skill.redirectTo ?? undefined,\n747:       redirectFrom: skill.redirectFrom,\n748:       lifecycleStatus: skill.lifecycleStatus,\n749:     });\n750:   }\n751: \n752:   if (isSpeckitMetricsEnabled()) {\n753:     for (const recommendation of recommendations) {\n754:       if (primaryIntentBonus(promptLower, recommendation, selfRecommendationGuardEnabled) !== 0) {\n755:         speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n756:       }\n757:       if (useRrfFusion && graphConflictAdjustment(graphConflictIndex, recommendation) !== 0) {\n758:         speckitMetrics.incrementCounter('spec_kit.scorer.graph_conflict_demote_applied_total', { skill_id: recommendation.skill });\n759:       }\n760:     }\n761:   }\n762:   const exactSemanticRerankIndex = useExactSemanticRerank\n763:     ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n764:     : new Map<string, ExactSemanticRerankEntry>();\n765:   let ranked = recommendations.sort((left, right) => {\n766:     const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n767:     const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n768:     const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n769:     const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n770:     const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n771:     const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n772:     const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n773:       - (left.score + leftCommandBonus + leftIntent + leftConflict);\n774:     if (useRrfFusion) {\n775:       const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n776:       const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n777:       if (leftExactSemantic !== null\n778:         && rightExactSemantic !== null\n779:         && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {\n780:         const exactSemanticDiff = rightExactSemantic - leftExactSemantic;\n781:         if (exactSemanticDiff !== 0) {\n782:           return exactSemanticDiff;\n783:         }\n784:       }\n785:       return adjustedScoreDiff\n786:         || rrfRankFor(rrfFusion, left) - rrfRankFor(rrfFusion, right)\n787:         || left.skill.localeCompare(right.skill);\n788:     }\n789:     return adjustedScoreDiff\n790:       || right.confidence - left.confidence\n791:       || left.skill.localeCompare(right.skill);\n792:   });\n793: \n794:   ranked = ranked.map((recommendation, index) => {\n795:     const next = ranked[index + 1];\n796:     const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n797:     const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n798:     return {\n799:       ...recommendation,\n800:       uncertainty,\n801:       passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n802:         && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n803:     };\n804:   });\n805:   ranked = applyAmbiguity(ranked);\n806: \n807:   // Low-information ambiguity abstention: a short, intent-less prompt that lands\n808:   // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n809:   // every cluster member's uncertainty above the strict threshold so strict\n810:   // callers abstain, while confidence-only callers still surface the best guess\n811:   // (the disambiguated top-ranked candidate).\n812:   const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n813:   const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n814:   if (lowInfoPrompt) {\n815:     const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n816:     // Only abstain when the cluster's lead is built from diffuse, shared\n817:     // single-word keyword matches rather than a distinctive multi-word phrase\n818:     // anchor (an explicit-author/derived phrase match such as \"code audit\").\n819:     // A multi-word anchor means the prompt does pin a specific skill, so it\n820:     // should route instead of abstaining.\n821:     const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (\n822:       recommendation.laneContributions.some((contribution) => (\n823:         (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')\n824:         && contribution.evidence.some((entry) => entry.includes(' '))\n825:       ))\n826:     ));\n827:     if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {\n828:       const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n829:       const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n830:       const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n831:       ranked = ranked.map((recommendation) => {\n832:         if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;\n833:         const uncertainty = Math.max(recommendation.uncertainty, floor);\n834:         return {\n835:           ...recommendation,\n836:           uncertainty,\n837:           passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n838:         };\n839:       });\n840:     }\n841:   }\n842: \n843:   // Class C: breadth / multi-concern abstention. A broad greenfield build\n844:   // (\"build full stack typescript service\") or a multi-concern optimization\n845:   // (\"optimize X execution speed and recommendation quality\") is under-specified\n846:   // for single-skill routing. When the top code-like candidate carries that\n847:   // shape, floor every passing candidate's uncertainty so strict callers abstain.\n848:   // Narrow anchors (a file, failing test, named component/route, benchmark, or\n849:   // review intent) bypass the broad-build branch; the multi-concern branch\n850:   // requires two distinct concern classes, so a file + single concern still routes.\n851:   if (!promptLower.includes('/')) {\n852:     const concernClasses = (CONCERN_PERF.test(promptLower) ? 1 : 0) + (CONCERN_QUALITY.test(promptLower) ? 1 : 0);\n853:     const broadBuild = BREADTH_BUILD_VERB.test(promptLower) && BREADTH_NOUN.test(promptLower) && !BREADTH_NARROW_ANCHOR.test(promptLower);\n854:     const multiConcern = MULTI_CONCERN_VERB.test(promptLower) && concernClasses >= 2;\n855:     if (broadBuild || multiConcern) {\n856:       const topRec = ranked.find((recommendation) => recommendation.passes_threshold) ?? null;\n857:       if (topRec && (topRec.skill === 'sk-code' || topRec.skill === 'system-skill-advisor')) {\n858:         const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n859:         const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n860:         const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n861:         ranked = ranked.map((recommendation) => {\n862:           if (!recommendation.passes_threshold) return recommendation;\n863:           const uncertainty = Math.max(recommendation.uncertainty, floor);\n864:           return {\n865:             ...recommendation,\n866:             uncertainty,\n867:             passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n868:           };\n869:         });\n870:       }\n871:     }\n872:   }\n873: \n874:   // Post-fusion so a resolved executor delegation can carry negative evidence\n875:   // the pre-clamp explicit lane cannot express, and so it runs after every\n876:   // abstention gate. The alias table is metadata-derived, so new executors or\n877:   // small models need no change here. It is a no-op on non-delegation prompts.\n878:   ranked = applyExecutorDelegationOverride(ranked, {\n879:     promptLower,\n880:     projection,\n881:     workspaceRoot: options.workspaceRoot,\n882:     confidenceThreshold: options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD,\n883:     uncertaintyThreshold: options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD,\n884:   });\n885: \n886:   const passing = ranked.filter((recommendation) => recommendation.passes_threshold);\n887:   const visible = options.includeAllCandidates ? ranked : passing;\n888:   const top = passing[0] ?? null;\n889:   const laneHealthReason = degradedLaneReason(degradedLanes);\n890:   const abstainReasons = laneHealthReason ? [laneHealthReason] : [];\n891:   if (isSpeckitMetricsEnabled() && top) {\n892:     const runtimeLabel = normalizeRuntimeLabel(process.env.SPECKIT_RUNTIME);\n893:     const freshnessLabel = normalizeFreshnessLabel(process.env.SPECKIT_ADVISOR_FRESHNESS);\n894:     if (runtimeLabel && freshnessLabel) {\n895:       speckitMetrics.incrementCounter('spec_kit.advisor.recommendation_emitted_total', { runtime: runtimeLabel, freshness_state: freshnessLabel });\n896:     }\n897:     speckitMetrics.recordConfidenceBracket(top.confidence);\n898:   }\n899:   return {\n900:     recommendations: visible,\n901:     topSkill: top?.skill ?? null,\n902:     unknown: !top,\n903:     ambiguous: isAmbiguousTopTwo(ranked),\n904:     metrics: {\n905:       candidateCount: ranked.length,\n906:       liveLaneCount: runtimeLiveLaneCount,\n907:       ...(degradedLanes.length > 0 ? { degradedLanes, laneHealth } : {}),\n908:     },\n909:     ...(abstainReasons.length > 0 ? { abstainReasons } : {}),\n910:   };\n911: }\n\n(End of file - total 911 lines)\n</content>","metadata":{"preview":"  }\n  if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'deep-loop-workflows' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'mcp-chrome-devtools' && /\\b(\\.opencode\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n    return true;\n  }\n  // Browser/devtools inspection is a genuine chrome-devtools task even though\n  // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n  // explainer floor when the prompt carries devtools-specific vocabulary.\n  if (skillId === 'mcp-chrome-devtools'\n    && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n    return true;\n  }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"  }\n  if (skillId === 'system-spec-kit' && /\\b(memory_save|resume_write|routing taxonomy|corpus|source-type|routing bucket)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'system-spec-kit' && /\\b(packet|spec folder|save memory|phase|continuation prompts|resume handling)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'deep-loop-workflows' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'mcp-chrome-devtools' && /\\b(\\.opencode\\/agents|state log|predictions schema|current labels|gate-3-classifier\\.ts)\\b/.test(promptLower)) {\n    return true;\n  }\n  // Browser/devtools inspection is a genuine chrome-devtools task even though\n  // its verb (\"inspect\") reads as a read-only explainer. Lift it off the\n  // explainer floor when the prompt carries devtools-specific vocabulary.\n  if (skillId === 'mcp-chrome-devtools'\n    && /\\b(network waterfall|network tab|network request|dev ?tools|browser console|page inspector|dom inspector|performance trace|inspect (the )?(network|dom|page|element|browser))\\b/.test(promptLower)) {\n    return true;\n  }\n  if (skillId === 'sk-code' && /\\bgate-3-classifier\\.ts\\b/.test(promptLower)) {\n    return true;\n  }\n  return false;\n}\n\nfunction isPlainFileSavePrompt(promptLower: string): boolean {\n  return FILE_SAVE_OPERATION.test(promptLower) && !MEMORY_SAVE_CONTEXT_ANCHOR.test(promptLower.replace(/\\bfile(s)?\\b/g, ''));\n}\n\nfunction primaryIntentBonus(\n  promptLower: string,\n  recommendation: AdvisorScoredRecommendation,\n  selfRecommendationGuardEnabled: boolean,\n): number {\n  const R = SCORING_CALIBRATION.routing;\n  if (/\\bsemantic (code )?search\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-code-graph') return R.semanticSearchCodeGraphBonus;\n  }\n  if (/\\bdeep[- ]review\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n  }\n  if (/\\bdeep[- ]research\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchOtherSkillsPenalty;\n  }\n  if (DEEP_RESEARCH_CYCLE.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit' || recommendation.skill === 'sk-code') return R.deepResearchCycleOtherSkillsPenalty;\n  }\n  if (/\\b(compare|audit|review)\\b/.test(promptLower) && /\\b(classifier|vocabulary|prose|implementation|agents\\.md|drift|mismatch)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.compareAuditCodeReviewBonus;\n  }\n  if (/\\b(corpus ids?|first-100 predictions|continuation prompts|routing study config|confusion matrix|source-mix note|prompt template|packet-local)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.corpusStudySpecKitBonus;\n    if (recommendation.skill === 'sk-prompt' || recommendation.skill === 'mcp-chrome-devtools' || recommendation.skill === 'sk-doc') return R.corpusStudyOtherSkillsPenalty;\n  }\n  if (promptLower.includes('/speckit:resume')) {\n    if (recommendation.skill === 'system-spec-kit') return R.speckitResumeSpecKitBonus;\n    if (recommendation.skill === 'command-spec-kit') return R.speckitResumeCommandPenalty;\n  }\n  if (promptLower.includes('/speckit:plan')) {\n    if (recommendation.skill === 'command-spec-kit') return R.speckitPlanCommandBonus;\n    if (recommendation.skill === 'sk-doc') return R.speckitPlanSkDocPenalty;\n  }\n  // External-tool-chain (\"call_tool_chain\") vocabulary belongs to mcp-code-mode,\n  // not the generic code skill. Disambiguate so the best guess for these\n  // toolchain-shaped prompts is mcp-code-mode.\n  // Toolchain + external-data-source vocabulary (webflow CMS, cms collection)\n  // is mcp-code-mode territory, not the generic code skill.\n  if (/\\b(call_tool_chain|code mode|tool ?chain|api chain|webflow cms|cms collection)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'mcp-code-mode') return R.mcpToolchainCodeModeBonus;\n    if (recommendation.skill === 'sk-code') return R.mcpToolchainSkCodePenalty;\n  }\n  // A \"code audit\" is a code-review task, not a deep-review loop. On the\n  // near-tie this phrase produces, prefer sk-code over deep-review.\n  if (/\\bcode audit\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.codeAuditCodeReviewBonus;\n    if (recommendation.skill === 'deep-review' || recommendation.skill === 'deep-loop-workflows') return R.codeAuditDeepReviewPenalty;\n  }\n  // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n  // loop; rank it above single-pass code review.\n  if (/:review:(auto|confirm)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'deep-loop-workflows') return R.reviewLoopDeepReviewBonus;\n    if (recommendation.skill === 'sk-code') return R.deepReviewSkCodeReviewPenalty;\n  }\n  // Auditing recommendation quality is a review task, not an advisor-self task.\n  if (/\\baudit\\b/.test(promptLower) && /\\b(recommendation|recommendations|recommendation quality|routing quality)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'sk-code') return R.auditRecsCodeReviewBonus;\n    if (!selfRecommendationGuardEnabled && isAdvisorSelfRecommendationSkill(recommendation.skill)) return R.auditRecsAdvisorPenalty;\n    if (shouldApplyAdvisorSelfRecommendationGuard({\n      skillId: recommendation.skill,\n      guardEnabled: selfRecommendationGuardEnabled,\n    })) {\n      return R.auditRecsAdvisorPenalty;\n    }\n  }\n  if (/\\b(save context|save memory)\\b/.test(promptLower)) {\n    if (recommendation.skill === 'memory:save') return R.saveContextMemorySaveBonus;\n    if (recommendation.skill === 'system-spec-kit') return R.saveContextMemorySpecKitPenalty;\n  }\n  if (/\\b(create (a )?new agent|create agent)\\b/.test(promptLower) || promptLower.includes('/create:agent')) {\n    if (recommendation.skill === 'create:agent') return R.createAgentCreateAgentBonus;\n    if (recommendation.skill === 'sk-doc') return R.createAgentSkDocPenalty;\n  }\n  if (/\\bcreate (a )?(test|testing) playbook\\b/.test(promptLower) || promptLower.includes('/create:manual-testing-playbook')) {\n    if (recommendation.skill === 'create:manual-testing-playbook' || recommendation.skill === 'command-create-manual-testing-playbook') return R.createTestingPlaybookBonus;\n    if (recommendation.skill === 'sk-doc') return R.createTestingPlaybookSkDocPenalty;\n    if (recommendation.skill === 'deep-loop-workflows') return R.createTestingPlaybookOtherSkillsPenalty;\n  }\n  if (/\\bphase folder\\b/.test(promptLower)) {\n    if (recommendation.skill === 'system-spec-kit') return R.phaseFolderSpecKitBonus;\n  }\n  return 0;\n}\n\nexport function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {\n  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);\n  const promptLower = prompt.toLowerCase();\n  const queryClass = classifyAdvisorQuery(promptLower);\n  const weights = effectiveScorerWeights(\n    options.laneWeightsOverride,\n    isAdvisorQueryClassRoutingEnabled() ? queryClass : 'unknown',\n  );\n  const disabled = new Set(options.disabledLanes ?? []);\n  const affordances = normalize(options.affordances ?? []);\n  const useRrfFusion = isAdvisorRrfFusionEnabled();\n  const useExactSemanticRerank = useRrfFusion && isAdvisorExactSemanticRerankEnabled();\n  const selfRecommendationGuardEnabled = isAdvisorSelfRecommendationGuardEnabled();\n  const { laneScores, graphConflictMatches } = buildLaneScores(\n    prompt,\n    projection,\n    disabled,\n    affordances,\n    useRrfFusion,\n    selfRecommendationGuardEnabled,\n  );\n  const runtimeLaneHealth = projectionRuntimeLaneHealth(projection, options.runtimeLaneHealth);\n  const laneHealth = buildLaneRuntimeHealth(laneScores, disabled, runtimeLaneHealth);\n  const degradedLanes = laneHealth\n    .filter((lane) => lane.status === 'runtime_degraded')\n    .map((lane) => lane.lane);\n  const runtimeDegradedLanes = new Set(degradedLanes);\n  const graphConflictIndex = buildConflictMatchIndex(graphConflictMatches);\n  const rrfFusion = useRrfFusion\n    ? fuseAdvisorLaneRanks(laneScores, weights, disabled, runtimeDegradedLanes)\n    : null;\n  const laneScoreIndexes = Object.fromEntries(\n    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n  ) as Record<ScorerLane, LaneMatchIndex>;\n  const liveTotal = SCORER_LANES\n    .filter((lane) => !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n  const runtimeLiveLaneCount = SCORER_LANES\n    .filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n    .length;\n  if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n    for (const lane of SCORER_LANES) {\n      if (!isLiveScorerLane(lane) || disabled.has(lane) || runtimeDegradedLanes.has(lane)) continue;\n      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n    }\n  }\n  const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n  const hasTaskIntent = TASK_INTENT.test(promptLower);\n  const recommendations: AdvisorScoredRecommendation[] = [];\n\n  for (const skill of projection.skills) {\n    if (!isDefaultRoutable(promptLower, skill)) continue;\n    const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n      const laneMatch = laneScoreIndexes[lane].get(skill.id);\n      const rawScore = laneMatch?.rawScore ?? 0;\n      const shadowOnly = !isLiveScorerLane(lane);\n      const runtimeDegraded = runtimeDegradedLanes.has(lane);\n      return {\n        lane,\n        rawScore,\n        weightedScore: shadowOnly || disabled.has(lane) || runtimeDegraded ? 0 : rawScore * weights[lane],\n        weight: disabled.has(lane) || runtimeDegraded ? 0 : weights[lane],\n        evidence: laneMatch?.evidence ?? [],\n        shadowOnly,\n      };\n    });\n    const weightedScore = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n    const rrfScore = rrfFusion?.scoreBySkill.get(skill.id);\n    const score = useRrfFusion ? rrfScore ?? 0 : weightedScore;\n    if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n    if (isSpeckitMetricsEnabled()) {\n      for (const contribution of contributions) {\n        if (contribution.weightedScore !== 0) {\n          speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n        }\n      }\n    }\n\n    const directScore = Math.max(\n      contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n      contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n    );\n    const derivedDominant = isDerivedDominant(contributions);\n    const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n    const explicitMatch = laneScoreIndexes.explicit_author.get(skill.id);\n    const liveNormalized = score / liveTotal;\n    let confidence = confidenceFor({\n      liveNormalized,\n      directScore,\n      readOnlyExplainer,\n      hasExplicitWorkflowSignal: explicitSignal,\n      hasTaskIntent,\n      readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n      derivedDominant,\n      skillId: skill.id,\n      selfRecommendationGuardEnabled,\n      hasAdvisorSelfAuthoredSignal: hasAdvisorSelfAuthoredSignal(skill.id, explicitMatch),\n    });\n    if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n      confidence = Math.min(confidence, 0.49);\n    }\n    recommendations.push({\n      skill: skill.id,\n      kind: skill.kind,\n      confidence,\n      uncertainty: uncertaintyFor(contributions, confidence, 0),\n      passes_threshold: false,\n      reason: attributionReason(contributions),\n      score: useRrfFusion ? score : Number(score.toFixed(6)),\n      laneContributions: contributions,\n      dominantLane: dominantLane(contributions),\n      redirectTo: skill.redirectTo ?? undefined,\n      redirectFrom: skill.redirectFrom,\n      lifecycleStatus: skill.lifecycleStatus,\n    });\n  }\n\n  if (isSpeckitMetricsEnabled()) {\n    for (const recommendation of recommendations) {\n      if (primaryIntentBonus(promptLower, recommendation, selfRecommendationGuardEnabled) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n      }\n      if (useRrfFusion && graphConflictAdjustment(graphConflictIndex, recommendation) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.graph_conflict_demote_applied_total', { skill_id: recommendation.skill });\n      }\n    }\n  }\n  const exactSemanticRerankIndex = useExactSemanticRerank\n    ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n    : new Map<string, ExactSemanticRerankEntry>();\n  let ranked = recommendations.sort((left, right) => {\n    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n    const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n    const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n    const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n    const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n      - (left.score + leftCommandBonus + leftIntent + leftConflict);\n    if (useRrfFusion) {\n      const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n      const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n      if (leftExactSemantic !== null\n        && rightExactSemantic !== null\n        && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {\n        const exactSemanticDiff = rightExactSemantic - leftExactSemantic;\n        if (exactSemanticDiff !== 0) {\n          return exactSemanticDiff;\n        }\n      }\n      return adjustedScoreDiff\n        || rrfRankFor(rrfFusion, left) - rrfRankFor(rrfFusion, right)\n        || left.skill.localeCompare(right.skill);\n    }\n    return adjustedScoreDiff\n      || right.confidence - left.confidence\n      || left.skill.localeCompare(right.skill);\n  });\n\n  ranked = ranked.map((recommendation, index) => {\n    const next = ranked[index + 1];\n    const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n    const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n    return {\n      ...recommendation,\n      uncertainty,\n      passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n        && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n    };\n  });\n  ranked = applyAmbiguity(ranked);\n\n  // Low-information ambiguity abstention: a short, intent-less prompt that lands\n  // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n  // every cluster member's uncertainty above the strict threshold so strict\n  // callers abstain, while confidence-only callers still surface the best guess\n  // (the disambiguated top-ranked candidate).\n  const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n  const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n  if (lowInfoPrompt) {\n    const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n    // Only abstain when the cluster's lead is built from diffuse, shared\n    // single-word keyword matches rather than a distinctive multi-word phrase\n    // anchor (an explicit-author/derived phrase match such as \"code audit\").\n    // A multi-word anchor means the prompt does pin a specific skill, so it\n    // should route instead of abstaining.\n    const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (\n      recommendation.laneContributions.some((contribution) => (\n        (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')\n        && contribution.evidence.some((entry) => entry.includes(' '))\n      ))\n    ));\n    if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {\n      const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n      const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n      const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n      ranked = ranked.map((recommendation) => {\n        if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;\n        const uncertainty = Math.max(recommendation.uncertainty, floor);\n        return {\n          ...recommendation,\n          uncertainty,\n          passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n        };\n      });\n    }\n  }\n\n  // Class C: breadth / multi-concern abstention. A broad greenfield build\n  // (\"build full stack typescript service\") or a multi-concern optimization\n  // (\"optimize X execution speed and recommendation quality\") is under-specified\n  // for single-skill routing. When the top code-like candidate carries that\n  // shape, floor every passing candidate's uncertainty so strict callers abstain.\n  // Narrow anchors (a file, failing test, named component/route, benchmark, or\n  // review intent) bypass the broad-build branch; the multi-concern branch\n  // requires two distinct concern classes, so a file + single concern still routes.\n  if (!promptLower.includes('/')) {\n    const concernClasses = (CONCERN_PERF.test(promptLower) ? 1 : 0) + (CONCERN_QUALITY.test(promptLower) ? 1 : 0);\n    const broadBuild = BREADTH_BUILD_VERB.test(promptLower) && BREADTH_NOUN.test(promptLower) && !BREADTH_NARROW_ANCHOR.test(promptLower);\n    const multiConcern = MULTI_CONCERN_VERB.test(promptLower) && concernClasses >= 2;\n    if (broadBuild || multiConcern) {\n      const topRec = ranked.find((recommendation) => recommendation.passes_threshold) ?? null;\n      if (topRec && (topRec.skill === 'sk-code' || topRec.skill === 'system-skill-advisor')) {\n        const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;\n        const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;\n        const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;\n        ranked = ranked.map((recommendation) => {\n          if (!recommendation.passes_threshold) return recommendation;\n          const uncertainty = Math.max(recommendation.uncertainty, floor);\n          return {\n            ...recommendation,\n            uncertainty,\n            passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,\n          };\n        });\n      }\n    }\n  }\n\n  // Post-fusion so a resolved executor delegation can carry negative evidence\n  // the pre-clamp explicit lane cannot express, and so it runs after every\n  // abstention gate. The alias table is metadata-derived, so new executors or\n  // small models need no change here. It is a no-op on non-delegation prompts.\n  ranked = applyExecutorDelegationOverride(ranked, {\n    promptLower,\n    projection,\n    workspaceRoot: options.workspaceRoot,\n    confidenceThreshold: options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD,\n    uncertaintyThreshold: options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD,\n  });\n\n  const passing = ranked.filter((recommendation) => recommendation.passes_threshold);\n  const visible = options.includeAllCandidates ? ranked : passing;\n  const top = passing[0] ?? null;\n  const laneHealthReason = degradedLaneReason(degradedLanes);\n  const abstainReasons = laneHealthReason ? [laneHealthReason] : [];\n  if (isSpeckitMetricsEnabled() && top) {\n    const runtimeLabel = normalizeRuntimeLabel(process.env.SPECKIT_RUNTIME);\n    const freshnessLabel = normalizeFreshnessLabel(process.env.SPECKIT_ADVISOR_FRESHNESS);\n    if (runtimeLabel && freshnessLabel) {\n      speckitMetrics.incrementCounter('spec_kit.advisor.recommendation_emitted_total', { runtime: runtimeLabel, freshness_state: freshnessLabel });\n    }\n    speckitMetrics.recordConfidenceBracket(top.confidence);\n  }\n  return {\n    recommendations: visible,\n    topSkill: top?.skill ?? null,\n    unknown: !top,\n    ambiguous: isAmbiguousTopTwo(ranked),\n    metrics: {\n      candidateCount: ranked.length,\n      liveLaneCount: runtimeLiveLaneCount,\n      ...(degradedLanes.length > 0 ? { degradedLanes, laneHealth } : {}),\n    },\n    ...(abstainReasons.length > 0 ? { abstainReasons } : {}),\n  };\n}","lineStart":521,"lineEnd":911,"totalLines":911,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437215655,"end":1783437215660}},"metadata":{"openai":{"itemId":"fc_06b076b532d084a9016a4d179f3e7881989f8f329f109dc0f9"}},"id":"prt_f3d2446b5001tnH40alTDQsJjc","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d241668001EHlfCAY3jsFXlr"}}
{"type":"tool_use","timestamp":1783437215948,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_cOZvJjGKA3A2B2w8ZPuADla4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","offset":521,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts</path>\n<type>file</type>\n<content>\n521:   }\n522:   if (summary.missingModelCount > 0) {\n523:     return { ...base, stale: true, reason: 'projection embedding model missing' };\n524:   }\n525:   if (summary.modelIds.length !== 1) {\n526:     return {\n527:       ...base,\n528:       stale: true,\n529:       reason: `projection model set '${summary.modelIds.join(', ')}' != active '${active.name}'`,\n530:     };\n531:   }\n532:   if (stored && stored.dim > 0 && stored.provider !== null && stored.dim !== active.dim) {\n533:     return { ...base, stale: true, reason: `projection dim ${stored.dim} != active ${active.dim}` };\n534:   }\n535:   if (!activeCompatibleModelIds(active).has(summary.modelIds[0])) {\n536:     return {\n537:       ...base,\n538:       stale: true,\n539:       reason: `projection model '${summary.modelIds[0]}' != active '${active.name}'`,\n540:     };\n541:   }\n542:   return { ...base, stale: false };\n543: }\n544: \n545: export function readAdvisorEmbeddingStaleness(db: Database.Database): AdvisorEmbeddingStalenessVerdict {\n546:   try {\n547:     const activePointer = readActiveEmbeddingPointer(db);\n548:     const active = activePointer ? signatureFromPointer(activePointer) : null;\n549:     return buildEmbeddingStalenessVerdict(active, storedEmbeddingSummary(db, activePointer));\n550:   } catch (error: unknown) {\n551:     const reason = error instanceof Error ? error.message : String(error);\n552:     return {\n553:       stale: true,\n554:       reason: `projection embedding staleness check failed: ${reason}`,\n555:       active: null,\n556:       stored: null,\n557:       vectorCount: 0,\n558:       modelIds: [],\n559:     };\n560:   }\n561: }\n562: \n563: /**\n564:  * Load doc-level trigger projections grouped by skill id. Tolerates a\n565:  * pre-migration database (missing skill_docs table) by returning an\n566:  * empty map — the read-only recommend path never runs migrations.\n567:  */\n568: function loadDocTriggersBySkill(db: Database.Database): Map<string, SkillDocTriggerProjection[]> {\n569:   const bySkill = new Map<string, SkillDocTriggerProjection[]>();\n570:   if (!isDocTriggerHarvestEnabled()) return bySkill;\n571:   let docRows: SkillDocRow[];\n572:   try {\n573:     docRows = db.prepare(`\n574:       SELECT skill_id, doc_path, trigger_phrases, importance_tier\n575:       FROM skill_docs\n576:       ORDER BY skill_id ASC, doc_path ASC\n577:     `).all() as SkillDocRow[];\n578:   } catch {\n579:     return bySkill;\n580:   }\n581:   for (const row of docRows) {\n582:     const phrases = unique(parseJsonStringArray(row.trigger_phrases).flatMap((entry) => phraseVariants(entry)));\n583:     if (phrases.length === 0) continue;\n584:     const entry: SkillDocTriggerProjection = {\n585:       docPath: row.doc_path,\n586:       phrases,\n587:       tierWeight: docTierWeight(row.importance_tier),\n588:     };\n589:     const existing = bySkill.get(row.skill_id);\n590:     if (existing) existing.push(entry);\n591:     else bySkill.set(row.skill_id, [entry]);\n592:   }\n593:   return bySkill;\n594: }\n595: \n596: function loadSqliteProjection(workspaceRoot: string): AdvisorProjection | null {\n597:   const dbPath = isAbsolute(SKILL_GRAPH_DB) ? SKILL_GRAPH_DB : join(workspaceRoot, SKILL_GRAPH_DB);\n598:   if (!existsSync(dbPath)) return null;\n599:   const db = new Database(dbPath, { readonly: true, fileMustExist: true });\n600:   try {\n601:     const rows = db.prepare(`\n602:       SELECT id, family, category, domains, intent_signals, derived, source_path\n603:       FROM skill_nodes\n604:       ORDER BY id ASC\n605:     `).all() as SkillNodeRow[];\n606:     const edgeRows = db.prepare(`\n607:       SELECT source_id, target_id, edge_type, weight, context\n608:       FROM skill_edges\n609:       ORDER BY source_id ASC, edge_type ASC, target_id ASC\n610:     `).all() as SkillEdgeRow[];\n611:     const docTriggersBySkill = loadDocTriggersBySkill(db);\n612:     const embeddingStaleness = readAdvisorEmbeddingStaleness(db);\n613:     return {\n614:       skills: [\n615:         ...rows.map((row) => {\n616:           const projection = projectionFromRow(row);\n617:           const docTriggers = docTriggersBySkill.get(row.id);\n618:           return docTriggers && docTriggers.length > 0 ? { ...projection, docTriggers } : projection;\n619:         }),\n620:         ...COMMAND_BRIDGES,\n621:       ],\n622:       edges: edgeRows.map((row) => ({\n623:         sourceId: row.source_id,\n624:         targetId: row.target_id,\n625:         edgeType: row.edge_type,\n626:         weight: Math.max(0, Math.min(1, row.weight)),\n627:         context: row.context,\n628:       })),\n629:       generatedAt: new Date().toISOString(),\n630:       source: 'sqlite',\n631:       embeddingSignature: embeddingStaleness.stored,\n632:       embeddingStaleness,\n633:     };\n634:   } finally {\n635:     db.close();\n636:   }\n637: }\n638: \n639: function loadFilesystemProjection(workspaceRoot: string): AdvisorProjection {\n640:   const skillRoot = join(workspaceRoot, '.opencode', 'skills');\n641:   const skills: SkillProjection[] = [];\n642:   const edges: SkillEdgeProjection[] = [];\n643:   if (!existsSync(skillRoot)) {\n644:     return { skills: [...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n645:   }\n646:   for (const entry of readdirSync(skillRoot, { withFileTypes: true })) {\n647:     if (!entry.isDirectory()) continue;\n648:     const skillDir = join(skillRoot, entry.name);\n649:     const metadataPath = join(skillDir, 'graph-metadata.json');\n650:     if (!existsSync(metadataPath)) continue;\n651:     const metadata = readJson(metadataPath);\n652:     const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), entry.name);\n653:     const skillId = typeof metadata.skill_id === 'string' ? metadata.skill_id : entry.name;\n654:     const rawDerived = typeof metadata.derived === 'object' && metadata.derived !== null && !Array.isArray(metadata.derived)\n655:       ? metadata.derived as Record<string, unknown>\n656:       : {};\n657:     const derived = sanitizeDerivedMetadata(rawDerived, metadataPath) ?? {};\n658:     // Same split applied here as in projectionFromRow above —\n659:     // derivedTriggers (from trigger_phrases) and derivedKeywords (from\n660:     // key_topics + entities + key_files + source_docs) are now distinct.\n661:     const derivedTriggers = unique(\n662:       stringArray(derived.trigger_phrases).flatMap((item) => phraseVariants(item)),\n663:     );\n664:     const derivedKeywords = unique([\n665:       ...stringArray(derived.key_topics),\n666:       ...stringArray(derived.entities),\n667:       ...stringArray(derived.key_files),\n668:       ...stringArray(derived.source_docs),\n669:     ].flatMap((item) => phraseVariants(item)));\n670:     skills.push({\n671:       id: skillId,\n672:       kind: 'skill',\n673:       family: typeof metadata.family === 'string' ? metadata.family : 'system',\n674:       category: typeof metadata.category === 'string' ? metadata.category : 'skill',\n675:       name: skillMd.name,\n676:       description: skillMd.description,\n677:       keywords: unique(skillMd.keywords.flatMap((item) => phraseVariants(item))),\n678:       domains: unique(sanitizeMetadataStringArray(stringArray(metadata.domains), metadataPath).flatMap((item) => phraseVariants(item))),\n679:       intentSignals: unique(sanitizeMetadataStringArray(stringArray(metadata.intent_signals), metadataPath).flatMap((item) => phraseVariants(item))),\n680:       derivedTriggers,\n681:       derivedKeywords,\n682:       derivedDemotion: boundedDemotion(derived.demotion),\n683:       // generated_at leads the chain (canonical V2 author/sync time); see the\n684:       // SQLite branch above for why this is author-time, not runtime.\n685:       derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n686:       sourcePath: metadataPath,\n687:       lifecycleStatus: lifecycleStatus(metadata.lifecycle_status ?? derived.lifecycle_status, metadataPath),\n688:       redirectTo: typeof metadata.redirect_to === 'string' ? metadata.redirect_to : undefined,\n689:       redirectFrom: stringArray(metadata.redirect_from),\n690:     });\n691:   }\n692:   return { skills: [...skills, ...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n693: }\n694: \n695: // Previously a bare `catch {}` swallowed every SQLite read error\n696: // and silently fell back to the filesystem projection, hiding corrupt-DB and\n697: // schema-drift failures from operators. We now distinguish three cases:\n698: //   1. SQLite read succeeded → return that projection ('sqlite').\n699: //   2. SQLite DB does not exist yet → loadSqliteProjection returns null and we\n700: //      fall through to a clean 'filesystem' projection (legitimate first run).\n701: //   3. SQLite read THREW → we still degrade to filesystem so the daemon stays\n702: //      up, but the projection is tagged 'filesystem-fallback' with a\n703: //      fallbackReason carrying the underlying error message AND the failure\n704: //      is logged via console.warn so it surfaces in daemon logs.\n705: export function loadAdvisorProjection(workspaceRoot: string): AdvisorProjection {\n706:   const resolvedRoot = resolve(workspaceRoot);\n707:   try {\n708:     const sqliteProjection = loadSqliteProjection(resolvedRoot);\n709:     if (sqliteProjection !== null) return sqliteProjection;\n710:     return loadFilesystemProjection(resolvedRoot);\n711:   } catch (error: unknown) {\n712:     const reason = error instanceof Error ? error.message : String(error);\n713:     console.warn(`[advisor-projection] SQLite projection failed; degraded to filesystem fallback: ${reason}`);\n714:     const fallback = loadFilesystemProjection(resolvedRoot);\n715:     return {\n716:       ...fallback,\n717:       source: 'filesystem-fallback',\n718:       fallbackReason: reason,\n719:     };\n720:   }\n721: }\n722: \n723: export function createFixtureProjection(\n724:   skills: readonly SkillProjection[],\n725:   edges: readonly SkillEdgeProjection[] = [],\n726: ): AdvisorProjection {\n727:   return {\n728:     skills,\n729:     edges,\n730:     generatedAt: new Date().toISOString(),\n731:     source: 'fixture',\n732:   };\n733: }\n\n(End of file - total 733 lines)\n</content>","metadata":{"preview":"  }\n  if (summary.missingModelCount > 0) {\n    return { ...base, stale: true, reason: 'projection embedding model missing' };\n  }\n  if (summary.modelIds.length !== 1) {\n    return {\n      ...base,\n      stale: true,\n      reason: `projection model set '${summary.modelIds.join(', ')}' != active '${active.name}'`,\n    };\n  }\n  if (stored && stored.dim > 0 && stored.provider !== null && stored.dim !== active.dim) {\n    return { ...base, stale: true, reason: `projection dim ${stored.dim} != active ${active.dim}` };\n  }\n  if (!activeCompatibleModelIds(active).has(summary.modelIds[0])) {\n    return {\n      ...base,\n      stale: true,\n      reason: `projection model '${summary.modelIds[0]}' != active '${active.name}'`,\n    };","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","text":"  }\n  if (summary.missingModelCount > 0) {\n    return { ...base, stale: true, reason: 'projection embedding model missing' };\n  }\n  if (summary.modelIds.length !== 1) {\n    return {\n      ...base,\n      stale: true,\n      reason: `projection model set '${summary.modelIds.join(', ')}' != active '${active.name}'`,\n    };\n  }\n  if (stored && stored.dim > 0 && stored.provider !== null && stored.dim !== active.dim) {\n    return { ...base, stale: true, reason: `projection dim ${stored.dim} != active ${active.dim}` };\n  }\n  if (!activeCompatibleModelIds(active).has(summary.modelIds[0])) {\n    return {\n      ...base,\n      stale: true,\n      reason: `projection model '${summary.modelIds[0]}' != active '${active.name}'`,\n    };\n  }\n  return { ...base, stale: false };\n}\n\nexport function readAdvisorEmbeddingStaleness(db: Database.Database): AdvisorEmbeddingStalenessVerdict {\n  try {\n    const activePointer = readActiveEmbeddingPointer(db);\n    const active = activePointer ? signatureFromPointer(activePointer) : null;\n    return buildEmbeddingStalenessVerdict(active, storedEmbeddingSummary(db, activePointer));\n  } catch (error: unknown) {\n    const reason = error instanceof Error ? error.message : String(error);\n    return {\n      stale: true,\n      reason: `projection embedding staleness check failed: ${reason}`,\n      active: null,\n      stored: null,\n      vectorCount: 0,\n      modelIds: [],\n    };\n  }\n}\n\n/**\n * Load doc-level trigger projections grouped by skill id. Tolerates a\n * pre-migration database (missing skill_docs table) by returning an\n * empty map — the read-only recommend path never runs migrations.\n */\nfunction loadDocTriggersBySkill(db: Database.Database): Map<string, SkillDocTriggerProjection[]> {\n  const bySkill = new Map<string, SkillDocTriggerProjection[]>();\n  if (!isDocTriggerHarvestEnabled()) return bySkill;\n  let docRows: SkillDocRow[];\n  try {\n    docRows = db.prepare(`\n      SELECT skill_id, doc_path, trigger_phrases, importance_tier\n      FROM skill_docs\n      ORDER BY skill_id ASC, doc_path ASC\n    `).all() as SkillDocRow[];\n  } catch {\n    return bySkill;\n  }\n  for (const row of docRows) {\n    const phrases = unique(parseJsonStringArray(row.trigger_phrases).flatMap((entry) => phraseVariants(entry)));\n    if (phrases.length === 0) continue;\n    const entry: SkillDocTriggerProjection = {\n      docPath: row.doc_path,\n      phrases,\n      tierWeight: docTierWeight(row.importance_tier),\n    };\n    const existing = bySkill.get(row.skill_id);\n    if (existing) existing.push(entry);\n    else bySkill.set(row.skill_id, [entry]);\n  }\n  return bySkill;\n}\n\nfunction loadSqliteProjection(workspaceRoot: string): AdvisorProjection | null {\n  const dbPath = isAbsolute(SKILL_GRAPH_DB) ? SKILL_GRAPH_DB : join(workspaceRoot, SKILL_GRAPH_DB);\n  if (!existsSync(dbPath)) return null;\n  const db = new Database(dbPath, { readonly: true, fileMustExist: true });\n  try {\n    const rows = db.prepare(`\n      SELECT id, family, category, domains, intent_signals, derived, source_path\n      FROM skill_nodes\n      ORDER BY id ASC\n    `).all() as SkillNodeRow[];\n    const edgeRows = db.prepare(`\n      SELECT source_id, target_id, edge_type, weight, context\n      FROM skill_edges\n      ORDER BY source_id ASC, edge_type ASC, target_id ASC\n    `).all() as SkillEdgeRow[];\n    const docTriggersBySkill = loadDocTriggersBySkill(db);\n    const embeddingStaleness = readAdvisorEmbeddingStaleness(db);\n    return {\n      skills: [\n        ...rows.map((row) => {\n          const projection = projectionFromRow(row);\n          const docTriggers = docTriggersBySkill.get(row.id);\n          return docTriggers && docTriggers.length > 0 ? { ...projection, docTriggers } : projection;\n        }),\n        ...COMMAND_BRIDGES,\n      ],\n      edges: edgeRows.map((row) => ({\n        sourceId: row.source_id,\n        targetId: row.target_id,\n        edgeType: row.edge_type,\n        weight: Math.max(0, Math.min(1, row.weight)),\n        context: row.context,\n      })),\n      generatedAt: new Date().toISOString(),\n      source: 'sqlite',\n      embeddingSignature: embeddingStaleness.stored,\n      embeddingStaleness,\n    };\n  } finally {\n    db.close();\n  }\n}\n\nfunction loadFilesystemProjection(workspaceRoot: string): AdvisorProjection {\n  const skillRoot = join(workspaceRoot, '.opencode', 'skills');\n  const skills: SkillProjection[] = [];\n  const edges: SkillEdgeProjection[] = [];\n  if (!existsSync(skillRoot)) {\n    return { skills: [...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n  }\n  for (const entry of readdirSync(skillRoot, { withFileTypes: true })) {\n    if (!entry.isDirectory()) continue;\n    const skillDir = join(skillRoot, entry.name);\n    const metadataPath = join(skillDir, 'graph-metadata.json');\n    if (!existsSync(metadataPath)) continue;\n    const metadata = readJson(metadataPath);\n    const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), entry.name);\n    const skillId = typeof metadata.skill_id === 'string' ? metadata.skill_id : entry.name;\n    const rawDerived = typeof metadata.derived === 'object' && metadata.derived !== null && !Array.isArray(metadata.derived)\n      ? metadata.derived as Record<string, unknown>\n      : {};\n    const derived = sanitizeDerivedMetadata(rawDerived, metadataPath) ?? {};\n    // Same split applied here as in projectionFromRow above —\n    // derivedTriggers (from trigger_phrases) and derivedKeywords (from\n    // key_topics + entities + key_files + source_docs) are now distinct.\n    const derivedTriggers = unique(\n      stringArray(derived.trigger_phrases).flatMap((item) => phraseVariants(item)),\n    );\n    const derivedKeywords = unique([\n      ...stringArray(derived.key_topics),\n      ...stringArray(derived.entities),\n      ...stringArray(derived.key_files),\n      ...stringArray(derived.source_docs),\n    ].flatMap((item) => phraseVariants(item)));\n    skills.push({\n      id: skillId,\n      kind: 'skill',\n      family: typeof metadata.family === 'string' ? metadata.family : 'system',\n      category: typeof metadata.category === 'string' ? metadata.category : 'skill',\n      name: skillMd.name,\n      description: skillMd.description,\n      keywords: unique(skillMd.keywords.flatMap((item) => phraseVariants(item))),\n      domains: unique(sanitizeMetadataStringArray(stringArray(metadata.domains), metadataPath).flatMap((item) => phraseVariants(item))),\n      intentSignals: unique(sanitizeMetadataStringArray(stringArray(metadata.intent_signals), metadataPath).flatMap((item) => phraseVariants(item))),\n      derivedTriggers,\n      derivedKeywords,\n      derivedDemotion: boundedDemotion(derived.demotion),\n      // generated_at leads the chain (canonical V2 author/sync time); see the\n      // SQLite branch above for why this is author-time, not runtime.\n      derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n      sourcePath: metadataPath,\n      lifecycleStatus: lifecycleStatus(metadata.lifecycle_status ?? derived.lifecycle_status, metadataPath),\n      redirectTo: typeof metadata.redirect_to === 'string' ? metadata.redirect_to : undefined,\n      redirectFrom: stringArray(metadata.redirect_from),\n    });\n  }\n  return { skills: [...skills, ...COMMAND_BRIDGES], edges, generatedAt: new Date().toISOString(), source: 'filesystem' };\n}\n\n// Previously a bare `catch {}` swallowed every SQLite read error\n// and silently fell back to the filesystem projection, hiding corrupt-DB and\n// schema-drift failures from operators. We now distinguish three cases:\n//   1. SQLite read succeeded → return that projection ('sqlite').\n//   2. SQLite DB does not exist yet → loadSqliteProjection returns null and we\n//      fall through to a clean 'filesystem' projection (legitimate first run).\n//   3. SQLite read THREW → we still degrade to filesystem so the daemon stays\n//      up, but the projection is tagged 'filesystem-fallback' with a\n//      fallbackReason carrying the underlying error message AND the failure\n//      is logged via console.warn so it surfaces in daemon logs.\nexport function loadAdvisorProjection(workspaceRoot: string): AdvisorProjection {\n  const resolvedRoot = resolve(workspaceRoot);\n  try {\n    const sqliteProjection = loadSqliteProjection(resolvedRoot);\n    if (sqliteProjection !== null) return sqliteProjection;\n    return loadFilesystemProjection(resolvedRoot);\n  } catch (error: unknown) {\n    const reason = error instanceof Error ? error.message : String(error);\n    console.warn(`[advisor-projection] SQLite projection failed; degraded to filesystem fallback: ${reason}`);\n    const fallback = loadFilesystemProjection(resolvedRoot);\n    return {\n      ...fallback,\n      source: 'filesystem-fallback',\n      fallbackReason: reason,\n    };\n  }\n}\n\nexport function createFixtureProjection(\n  skills: readonly SkillProjection[],\n  edges: readonly SkillEdgeProjection[] = [],\n): AdvisorProjection {\n  return {\n    skills,\n    edges,\n    generatedAt: new Date().toISOString(),\n    source: 'fixture',\n  };\n}","lineStart":521,"lineEnd":733,"totalLines":733,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","time":{"start":1783437215943,"end":1783437215947}},"metadata":{"openai":{"itemId":"fc_06b076b532d084a9016a4d179f3e908198afa9c7177301b1e1"}},"id":"prt_f3d2447fb001Vh7KdWGKyCc6qE","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d241668001EHlfCAY3jsFXlr"}}
