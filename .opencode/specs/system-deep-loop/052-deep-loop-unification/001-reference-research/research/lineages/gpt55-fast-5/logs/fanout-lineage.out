{"type":"text","timestamp":1783486645557,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"id":"prt_f40166a760015VkP8j02FZ13YM","messageID":"msg_f401648cd001cy2V6YZm8jKDec","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","type":"text","text":"This prompt is generated by `fanout-run.cjs`; in this child lineage, the current OpenCode process is the detached CLI executor. I’ll execute the loop directly in the lineage artifact directory and include the required route-proof fields rather than recursively spawning another `opencode run`.","time":{"start":1783486638710,"end":1783486645555},"metadata":{"openai":{"itemId":"msg_070f0586237a5998016a4dd8aeb5f0819192a9450359303670","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1783486645593,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_MoWMcHR0wOLtKfiT0ZjPYQqW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep Research State Reducer                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: const crypto = require('node:crypto');\n14: const { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\n15: const { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\n16: const {\n17:   buildCarriedForwardOpenQuestions,\n18:   deriveNextFocusFromContinuity,\n19:   formatCarriedForwardOpenQuestions,\n20: } = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');\n21: const { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n22: \n23: // ─────────────────────────────────────────────────────────────────────────────\n24: // 2. HELPERS\n25: // ─────────────────────────────────────────────────────────────────────────────\n26: \n27: const DEFAULT_SPARKLINE_WIDTH = 20;\n28: const DEFAULT_TREND_FLATLINE_WINDOW = 3;\n29: const DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\n30: const DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\n31: const DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\n32: const MIN_IDEA_OBSERVATIONS = 1;\n33: const MAX_IDEA_OBSERVATIONS = 10;\n34: const INBOX_FILE_NAME = 'inbox.jsonl';\n35: const DEFAULT_INBOX_SOURCE = 'research-inbox';\n36: const LEGACY_IMPORT_ORIGIN = 'legacy-import';\n37: const LEGACY_IMPORT_SOURCE = 'key-questions';\n38: const QUESTION_CONFLICT_EVENT = 'question_conflict';\n39: const DEFAULT_QUESTION_DECISION = 'needs_decision';\n40: const MAX_REJECTED_PATTERNS = 100;\n41: const REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\n42: const REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\n43: const IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\n44: const IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\n45: const IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\n46: const IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\n47: const IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\n48: const IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\n49: const VALID_QUESTION_ORIGINS = new Set([\n50:   'angle-bank',\n51:   'analyst-strategy',\n52:   'operator',\n53:   LEGACY_IMPORT_ORIGIN,\n54: ]);\n55: const VALID_QUESTION_DECISIONS = new Set([\n56:   'accepted',\n57:   'rejected',\n58:   'superseded',\n59:   DEFAULT_QUESTION_DECISION,\n60: ]);\n61: const SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n62: \n63: function readUtf8(filePath) {\n64:   return fs.readFileSync(filePath, 'utf8');\n65: }\n66: \n67: function writeUtf8(filePath, content) {\n68:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n69:   fs.writeFileSync(filePath, content, 'utf8');\n70: }\n71: \n72: function readJson(filePath) {\n73:   return JSON.parse(readUtf8(filePath));\n74: }\n75: \n76: function getResourceMapEmitSetting(config) {\n77:   const nested = config && typeof config === 'object'\n78:     ? (config.resource_map || config.resourceMap || null)\n79:     : null;\n80:   if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n81:     return nested.emit;\n82:   }\n83:   return true;\n84: }\n85: \n86: function slugify(value) {\n87:   return value\n88:     .toLowerCase()\n89:     .replace(/[^a-z0-9]+/g, '-')\n90:     .replace(/^-+|-+$/g, '')\n91:     .slice(0, 80) || 'entry';\n92: }\n93: \n94: function normalizeText(value) {\n95:   return value.replace(/\\s+/g, ' ').trim();\n96: }\n97: \n98: function normalizeOptionalText(value) {\n99:   return typeof value === 'string' ? normalizeText(value) : '';\n100: }\n101: \n102: function normalizeQuestionOrigin(value) {\n103:   const origin = normalizeOptionalText(value).toLowerCase();\n104:   return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n105: }\n106: \n107: function normalizeQuestionSource(value, fallback) {\n108:   return normalizeOptionalText(value) || fallback;\n109: }\n110: \n111: function normalizeQuestionIteration(value) {\n112:   return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n113: }\n114: \n115: function normalizeQuestionId(value) {\n116:   const normalized = normalizeOptionalText(value);\n117:   return normalized || null;\n118: }\n119: \n120: function normalizeQuestionDecision(value) {\n121:   const decision = normalizeOptionalText(value).toLowerCase();\n122:   return VALID_QUESTION_DECISIONS.has(decision) ? decision : null;\n123: }\n124: \n125: function contentHash(value) {\n126:   return crypto\n127:     .createHash('sha256')\n128:     .update(normalizeText(String(value)).toLowerCase())\n129:     .digest('hex')\n130:     .slice(0, 12);\n131: }\n132: \n133: function normalizeRejectedPatternKey(value) {\n134:   return normalizeText(String(value ?? ''))\n135:     .toLowerCase()\n136:     .replace(/[^a-z0-9]+/g, ' ')\n137:     .trim();\n138: }\n139: \n140: function normalizeRejectedPatternCategory(value) {\n141:   const normalized = normalizeOptionalText(value).toLowerCase();\n142:   return normalized || DEFAULT_REJECTED_PATTERN_CATEGORY;\n143: }\n144: \n145: function normalizeRejectedPatternId(value) {\n146:   const normalized = normalizeOptionalText(value);\n147:   return normalized || null;\n148: }\n149: \n150: function isNamedEvent(record, eventNames) {\n151:   return record\n152:     && record.type === 'event'\n153:     && typeof record.event === 'string'\n154:     && eventNames.has(record.event);\n155: }\n156: \n157: function readFirstTextField(record, fields) {\n158:   if (!record || typeof record !== 'object' || Array.isArray(record)) {\n159:     return '';\n160:   }\n161: \n162:   for (const field of fields) {\n163:     const value = normalizeOptionalText(record[field]);\n164:     if (value) {\n165:       return value;\n166:     }\n167:   }\n168:   return '';\n169: }\n170: \n171: function readRejectedPatternText(record) {\n172:   return readFirstTextField(record, REJECTED_PATTERN_EVENT_FIELDS);\n173: }\n174: \n175: function readCandidateText(candidate) {\n176:   if (typeof candidate === 'string') {\n177:     return normalizeOptionalText(candidate);\n178:   }\n179:   return readFirstTextField(candidate, REJECTED_PATTERN_CANDIDATE_FIELDS);\n180: }\n181: \n182: function readCandidateCategory(candidate, fallbackCategory) {\n183:   if (candidate && typeof candidate === 'object' && !Array.isArray(candidate)) {\n184:     return normalizeRejectedPatternCategory(candidate.category ?? fallbackCategory);\n185:   }\n186:   return normalizeRejectedPatternCategory(fallbackCategory);\n187: }\n188: \n189: function isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory) {\n190:   const rejected = normalizeRejectedPatternCategory(rejectedCategory);\n191:   const candidate = normalizeRejectedPatternCategory(candidateCategory);\n192:   return rejected === candidate\n193:     || rejected === DEFAULT_REJECTED_PATTERN_CATEGORY\n194:     || candidate === DEFAULT_REJECTED_PATTERN_CATEGORY;\n195: }\n196: \n197: function resolveRejectedPatternFuzzyThreshold(config) {\n198:   const rawThreshold =\n199:     config?.rejectedPatternFuzzyThreshold\n200:     ?? config?.rejectedPatterns?.fuzzyThreshold\n201:     ?? DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n202:   return typeof rawThreshold === 'number' && Number.isFinite(rawThreshold) && rawThreshold >= 0 && rawThreshold <= 1\n203:     ? rawThreshold\n204:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n205: }\n206: \n207: function normalizeRejectedPatternEvent(record) {\n208:   const pattern = readRejectedPatternText(record);\n209:   const normalizedPattern = normalizeRejectedPatternKey(pattern);\n210:   if (!normalizedPattern) {\n211:     return null;\n212:   }\n213: \n214:   const category = normalizeRejectedPatternCategory(record.category);\n215:   return {\n216:     id: normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id)\n217:       || `rejected-${category}-${contentHash(normalizedPattern)}`,\n218:     ideaId: normalizeRejectedPatternId(record.ideaId),\n219:     pattern,\n220:     normalizedPattern,\n221:     category,\n222:     reason: normalizeOptionalText(record.reason),\n223:     addedAtRun: isFiniteNumber(record.run) ? record.run : null,\n224:     timestamp: normalizeOptionalText(record.timestamp),\n225:     sessionId: normalizeRejectedPatternId(record.sessionId),\n226:     generation: isFiniteNumber(record.generation) ? record.generation : null,\n227:   };\n228: }\n229: \n230: function removeRejectedPatternEntries(entries, record) {\n231:   const rejectedId = normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id);\n232:   const patternKey = normalizeRejectedPatternKey(readRejectedPatternText(record));\n233:   const rawCategory = normalizeOptionalText(record.category);\n234:   const category = rawCategory ? normalizeRejectedPatternCategory(rawCategory) : null;\n235: \n236:   return entries.filter((entry) => {\n237:     if (rejectedId && (entry.id === rejectedId || entry.ideaId === rejectedId)) {\n238:       return false;\n239:     }\n240:     if (!patternKey || entry.normalizedPattern !== patternKey) {\n241:       return true;\n242:     }\n243:     return category ? entry.category !== category : false;\n244:   });\n245: }\n246: \n247: /**\n248:  * Derive the active rejected-pattern cache from append-only research events.\n249:  *\n250:  * @param {Array<Object>} eventRecords - Parsed JSONL event records.\n251:  * @param {Object} [options] - Index options.\n252:  * @param {number} [options.fuzzyThreshold=0.85] - Similarity threshold used by candidate checks.\n253:  * @returns {{entries: Array<Object>, maxEntries: number, fuzzyThreshold: number, warnings: string[]}} Bounded rejected-pattern index.\n254:  */\n255: function deriveRejectedPatternIndex(eventRecords, options = {}) {\n256:   const fuzzyThreshold = typeof options.fuzzyThreshold === 'number'\n257:     ? options.fuzzyThreshold\n258:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n259:   const entries = [];\n260:   const warnings = [];\n261: \n262:   for (const record of Array.isArray(eventRecords) ? eventRecords : []) {\n263:     if (!record || record.type !== 'event') {\n264:       continue;\n265:     }\n266: \n267:     if (isNamedEvent(record, IDEA_REJECTED_RESET_EVENTS)) {\n268:       entries.length = 0;\n269:       continue;\n270:     }\n271: \n272:     if (isNamedEvent(record, IDEA_REJECTED_REMOVED_EVENTS)) {\n273:       const nextEntries = removeRejectedPatternEntries(entries, record);\n274:       entries.length = 0;\n275:       entries.push(...nextEntries);\n276:       continue;\n277:     }\n278: \n279:     if (!isNamedEvent(record, IDEA_REJECTED_EVENTS)) {\n280:       continue;\n281:     }\n282: \n283:     const entry = normalizeRejectedPatternEvent(record);\n284:     if (!entry) {\n285:       continue;\n286:     }\n287: \n288:     const replacedEntries = entries.filter((existing) =>\n289:       existing.id !== entry.id\n290:       && !(existing.category === entry.category && existing.normalizedPattern === entry.normalizedPattern),\n291:     );\n292:     replacedEntries.push(entry);\n293:     entries.length = 0;\n294:     entries.push(...replacedEntries);\n295: \n296:     while (entries.length > MAX_REJECTED_PATTERNS) {\n297:       const evicted = entries.shift();\n298:       warnings.push(\n299:         `[deep-research] evicted rejected pattern \"${evicted.pattern}\" from bounded rejected-pattern cache (max ${MAX_REJECTED_PATTERNS})`,\n300:       );\n301:     }\n302:   }\n303: \n304:   return {\n305:     entries,\n306:     maxEntries: MAX_REJECTED_PATTERNS,\n307:     fuzzyThreshold,\n308:     warnings,\n309:   };\n310: }\n311: \n312: function calculateLevenshteinDistance(left, right) {\n313:   if (left === right) {\n314:     return 0;\n315:   }\n316:   if (!left.length) {\n317:     return right.length;\n318:   }\n319:   if (!right.length) {\n320:     return left.length;\n321:   }\n322: \n323:   const previous = Array.from({ length: right.length + 1 }, (_unused, index) => index);\n324:   const current = new Array(right.length + 1);\n325: \n326:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n327:     current[0] = leftIndex;\n328:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n329:       const substitutionCost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n330:       current[rightIndex] = Math.min(\n331:         previous[rightIndex] + 1,\n332:         current[rightIndex - 1] + 1,\n333:         previous[rightIndex - 1] + substitutionCost,\n334:       );\n335:     }\n336:     previous.splice(0, previous.length, ...current);\n337:   }\n338: \n339:   return previous[right.length];\n340: }\n341: \n342: function calculateRejectedPatternSimilarity(left, right) {\n343:   const normalizedLeft = normalizeRejectedPatternKey(left).slice(0, 500);\n344:   const normalizedRight = normalizeRejectedPatternKey(right).slice(0, 500);\n345:   if (!normalizedLeft || !normalizedRight) {\n346:     return 0;\n347:   }\n348:   if (normalizedLeft === normalizedRight) {\n349:     return 1;\n350:   }\n351: \n352:   const distance = calculateLevenshteinDistance(normalizedLeft, normalizedRight);\n353:   return 1 - (distance / Math.max(normalizedLeft.length, normalizedRight.length));\n354: }\n355: \n356: function readRejectedEntries(rejectedIndex) {\n357:   if (Array.isArray(rejectedIndex)) {\n358:     return rejectedIndex;\n359:   }\n360:   return Array.isArray(rejectedIndex?.entries) ? rejectedIndex.entries : [];\n361: }\n362: \n363: function resolveCandidateThreshold(rejectedIndex, options) {\n364:   const threshold = options?.fuzzyThreshold ?? rejectedIndex?.fuzzyThreshold ?? rejectedIndex?.threshold;\n365:   return typeof threshold === 'number' && Number.isFinite(threshold) && threshold >= 0 && threshold <= 1\n366:     ? threshold\n367:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n368: }\n369: \n370: /**\n371:  * Find the active rejected pattern that suppresses a candidate, if any.\n372:  *\n373:  * @param {string|Object} candidate - Candidate text or structured candidate.\n374:  * @param {Object|Array<Object>} rejectedIndex - Derived rejected-pattern index.\n375:  * @param {Object} [options] - Match options.\n376:  * @param {string} [options.category=\"general\"] - Candidate category.\n377:  * @returns {Object|null} Match metadata when the candidate is suppressed.\n378:  */\n379: function findRejectedPatternMatch(candidate, rejectedIndex, options = {}) {\n380:   const candidateText = readCandidateText(candidate);\n381:   const candidateKey = normalizeRejectedPatternKey(candidateText);\n382:   if (!candidateKey) {\n383:     return null;\n384:   }\n385: \n386:   const candidateCategory = readCandidateCategory(candidate, options.category);\n387:   const fuzzyThreshold = resolveCandidateThreshold(rejectedIndex, options);\n388:   let bestFuzzyMatch = null;\n389: \n390:   for (const entry of readRejectedEntries(rejectedIndex)) {\n391:     const rejectedPattern = entry.pattern || entry.text || '';\n392:     const rejectedKey = entry.normalizedPattern || normalizeRejectedPatternKey(rejectedPattern);\n393:     const rejectedCategory = normalizeRejectedPatternCategory(entry.category);\n394:     if (!rejectedKey || !isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory)) {\n395:       continue;\n396:     }\n397: \n398:     if (rejectedKey === candidateKey) {\n399:       return {\n400:         candidateText,\n401:         candidateCategory,\n402:         matchType: 'exact',\n403:         similarity: 1,\n404:         rejectedPattern: {\n405:           ...entry,\n406:           pattern: rejectedPattern,\n407:           normalizedPattern: rejectedKey,\n408:           category: rejectedCategory,\n409:         },\n410:       };\n411:     }\n412: \n413:     const similarity = calculateRejectedPatternSimilarity(candidateKey, rejectedKey);\n414:     if (similarity < fuzzyThreshold) {\n415:       continue;\n416:     }\n417:     if (!bestFuzzyMatch || similarity > bestFuzzyMatch.similarity) {\n418:       bestFuzzyMatch = {\n419:         candidateText,\n420:         candidateCategory,\n\n(Showing lines 1-420 of 2758. Use offset=421 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Research State Reducer                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst crypto = require('node:crypto');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\nconst {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n} = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Research State Reducer                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst crypto = require('node:crypto');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\nconst {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n} = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst DEFAULT_SPARKLINE_WIDTH = 20;\nconst DEFAULT_TREND_FLATLINE_WINDOW = 3;\nconst DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\nconst DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\nconst DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\nconst MIN_IDEA_OBSERVATIONS = 1;\nconst MAX_IDEA_OBSERVATIONS = 10;\nconst INBOX_FILE_NAME = 'inbox.jsonl';\nconst DEFAULT_INBOX_SOURCE = 'research-inbox';\nconst LEGACY_IMPORT_ORIGIN = 'legacy-import';\nconst LEGACY_IMPORT_SOURCE = 'key-questions';\nconst QUESTION_CONFLICT_EVENT = 'question_conflict';\nconst DEFAULT_QUESTION_DECISION = 'needs_decision';\nconst MAX_REJECTED_PATTERNS = 100;\nconst REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\nconst REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\nconst IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\nconst IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\nconst IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\nconst IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\nconst IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\nconst IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\nconst VALID_QUESTION_ORIGINS = new Set([\n  'angle-bank',\n  'analyst-strategy',\n  'operator',\n  LEGACY_IMPORT_ORIGIN,\n]);\nconst VALID_QUESTION_DECISIONS = new Set([\n  'accepted',\n  'rejected',\n  'superseded',\n  DEFAULT_QUESTION_DECISION,\n]);\nconst SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n\nfunction readUtf8(filePath) {\n  return fs.readFileSync(filePath, 'utf8');\n}\n\nfunction writeUtf8(filePath, content) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.writeFileSync(filePath, content, 'utf8');\n}\n\nfunction readJson(filePath) {\n  return JSON.parse(readUtf8(filePath));\n}\n\nfunction getResourceMapEmitSetting(config) {\n  const nested = config && typeof config === 'object'\n    ? (config.resource_map || config.resourceMap || null)\n    : null;\n  if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n    return nested.emit;\n  }\n  return true;\n}\n\nfunction slugify(value) {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 80) || 'entry';\n}\n\nfunction normalizeText(value) {\n  return value.replace(/\\s+/g, ' ').trim();\n}\n\nfunction normalizeOptionalText(value) {\n  return typeof value === 'string' ? normalizeText(value) : '';\n}\n\nfunction normalizeQuestionOrigin(value) {\n  const origin = normalizeOptionalText(value).toLowerCase();\n  return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n}\n\nfunction normalizeQuestionSource(value, fallback) {\n  return normalizeOptionalText(value) || fallback;\n}\n\nfunction normalizeQuestionIteration(value) {\n  return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n}\n\nfunction normalizeQuestionId(value) {\n  const normalized = normalizeOptionalText(value);\n  return normalized || null;\n}\n\nfunction normalizeQuestionDecision(value) {\n  const decision = normalizeOptionalText(value).toLowerCase();\n  return VALID_QUESTION_DECISIONS.has(decision) ? decision : null;\n}\n\nfunction contentHash(value) {\n  return crypto\n    .createHash('sha256')\n    .update(normalizeText(String(value)).toLowerCase())\n    .digest('hex')\n    .slice(0, 12);\n}\n\nfunction normalizeRejectedPatternKey(value) {\n  return normalizeText(String(value ?? ''))\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .trim();\n}\n\nfunction normalizeRejectedPatternCategory(value) {\n  const normalized = normalizeOptionalText(value).toLowerCase();\n  return normalized || DEFAULT_REJECTED_PATTERN_CATEGORY;\n}\n\nfunction normalizeRejectedPatternId(value) {\n  const normalized = normalizeOptionalText(value);\n  return normalized || null;\n}\n\nfunction isNamedEvent(record, eventNames) {\n  return record\n    && record.type === 'event'\n    && typeof record.event === 'string'\n    && eventNames.has(record.event);\n}\n\nfunction readFirstTextField(record, fields) {\n  if (!record || typeof record !== 'object' || Array.isArray(record)) {\n    return '';\n  }\n\n  for (const field of fields) {\n    const value = normalizeOptionalText(record[field]);\n    if (value) {\n      return value;\n    }\n  }\n  return '';\n}\n\nfunction readRejectedPatternText(record) {\n  return readFirstTextField(record, REJECTED_PATTERN_EVENT_FIELDS);\n}\n\nfunction readCandidateText(candidate) {\n  if (typeof candidate === 'string') {\n    return normalizeOptionalText(candidate);\n  }\n  return readFirstTextField(candidate, REJECTED_PATTERN_CANDIDATE_FIELDS);\n}\n\nfunction readCandidateCategory(candidate, fallbackCategory) {\n  if (candidate && typeof candidate === 'object' && !Array.isArray(candidate)) {\n    return normalizeRejectedPatternCategory(candidate.category ?? fallbackCategory);\n  }\n  return normalizeRejectedPatternCategory(fallbackCategory);\n}\n\nfunction isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory) {\n  const rejected = normalizeRejectedPatternCategory(rejectedCategory);\n  const candidate = normalizeRejectedPatternCategory(candidateCategory);\n  return rejected === candidate\n    || rejected === DEFAULT_REJECTED_PATTERN_CATEGORY\n    || candidate === DEFAULT_REJECTED_PATTERN_CATEGORY;\n}\n\nfunction resolveRejectedPatternFuzzyThreshold(config) {\n  const rawThreshold =\n    config?.rejectedPatternFuzzyThreshold\n    ?? config?.rejectedPatterns?.fuzzyThreshold\n    ?? DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n  return typeof rawThreshold === 'number' && Number.isFinite(rawThreshold) && rawThreshold >= 0 && rawThreshold <= 1\n    ? rawThreshold\n    : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n}\n\nfunction normalizeRejectedPatternEvent(record) {\n  const pattern = readRejectedPatternText(record);\n  const normalizedPattern = normalizeRejectedPatternKey(pattern);\n  if (!normalizedPattern) {\n    return null;\n  }\n\n  const category = normalizeRejectedPatternCategory(record.category);\n  return {\n    id: normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id)\n      || `rejected-${category}-${contentHash(normalizedPattern)}`,\n    ideaId: normalizeRejectedPatternId(record.ideaId),\n    pattern,\n    normalizedPattern,\n    category,\n    reason: normalizeOptionalText(record.reason),\n    addedAtRun: isFiniteNumber(record.run) ? record.run : null,\n    timestamp: normalizeOptionalText(record.timestamp),\n    sessionId: normalizeRejectedPatternId(record.sessionId),\n    generation: isFiniteNumber(record.generation) ? record.generation : null,\n  };\n}\n\nfunction removeRejectedPatternEntries(entries, record) {\n  const rejectedId = normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id);\n  const patternKey = normalizeRejectedPatternKey(readRejectedPatternText(record));\n  const rawCategory = normalizeOptionalText(record.category);\n  const category = rawCategory ? normalizeRejectedPatternCategory(rawCategory) : null;\n\n  return entries.filter((entry) => {\n    if (rejectedId && (entry.id === rejectedId || entry.ideaId === rejectedId)) {\n      return false;\n    }\n    if (!patternKey || entry.normalizedPattern !== patternKey) {\n      return true;\n    }\n    return category ? entry.category !== category : false;\n  });\n}\n\n/**\n * Derive the active rejected-pattern cache from append-only research events.\n *\n * @param {Array<Object>} eventRecords - Parsed JSONL event records.\n * @param {Object} [options] - Index options.\n * @param {number} [options.fuzzyThreshold=0.85] - Similarity threshold used by candidate checks.\n * @returns {{entries: Array<Object>, maxEntries: number, fuzzyThreshold: number, warnings: string[]}} Bounded rejected-pattern index.\n */\nfunction deriveRejectedPatternIndex(eventRecords, options = {}) {\n  const fuzzyThreshold = typeof options.fuzzyThreshold === 'number'\n    ? options.fuzzyThreshold\n    : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n  const entries = [];\n  const warnings = [];\n\n  for (const record of Array.isArray(eventRecords) ? eventRecords : []) {\n    if (!record || record.type !== 'event') {\n      continue;\n    }\n\n    if (isNamedEvent(record, IDEA_REJECTED_RESET_EVENTS)) {\n      entries.length = 0;\n      continue;\n    }\n\n    if (isNamedEvent(record, IDEA_REJECTED_REMOVED_EVENTS)) {\n      const nextEntries = removeRejectedPatternEntries(entries, record);\n      entries.length = 0;\n      entries.push(...nextEntries);\n      continue;\n    }\n\n    if (!isNamedEvent(record, IDEA_REJECTED_EVENTS)) {\n      continue;\n    }\n\n    const entry = normalizeRejectedPatternEvent(record);\n    if (!entry) {\n      continue;\n    }\n\n    const replacedEntries = entries.filter((existing) =>\n      existing.id !== entry.id\n      && !(existing.category === entry.category && existing.normalizedPattern === entry.normalizedPattern),\n    );\n    replacedEntries.push(entry);\n    entries.length = 0;\n    entries.push(...replacedEntries);\n\n    while (entries.length > MAX_REJECTED_PATTERNS) {\n      const evicted = entries.shift();\n      warnings.push(\n        `[deep-research] evicted rejected pattern \"${evicted.pattern}\" from bounded rejected-pattern cache (max ${MAX_REJECTED_PATTERNS})`,\n      );\n    }\n  }\n\n  return {\n    entries,\n    maxEntries: MAX_REJECTED_PATTERNS,\n    fuzzyThreshold,\n    warnings,\n  };\n}\n\nfunction calculateLevenshteinDistance(left, right) {\n  if (left === right) {\n    return 0;\n  }\n  if (!left.length) {\n    return right.length;\n  }\n  if (!right.length) {\n    return left.length;\n  }\n\n  const previous = Array.from({ length: right.length + 1 }, (_unused, index) => index);\n  const current = new Array(right.length + 1);\n\n  for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n    current[0] = leftIndex;\n    for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n      const substitutionCost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n      current[rightIndex] = Math.min(\n        previous[rightIndex] + 1,\n        current[rightIndex - 1] + 1,\n        previous[rightIndex - 1] + substitutionCost,\n      );\n    }\n    previous.splice(0, previous.length, ...current);\n  }\n\n  return previous[right.length];\n}\n\nfunction calculateRejectedPatternSimilarity(left, right) {\n  const normalizedLeft = normalizeRejectedPatternKey(left).slice(0, 500);\n  const normalizedRight = normalizeRejectedPatternKey(right).slice(0, 500);\n  if (!normalizedLeft || !normalizedRight) {\n    return 0;\n  }\n  if (normalizedLeft === normalizedRight) {\n    return 1;\n  }\n\n  const distance = calculateLevenshteinDistance(normalizedLeft, normalizedRight);\n  return 1 - (distance / Math.max(normalizedLeft.length, normalizedRight.length));\n}\n\nfunction readRejectedEntries(rejectedIndex) {\n  if (Array.isArray(rejectedIndex)) {\n    return rejectedIndex;\n  }\n  return Array.isArray(rejectedIndex?.entries) ? rejectedIndex.entries : [];\n}\n\nfunction resolveCandidateThreshold(rejectedIndex, options) {\n  const threshold = options?.fuzzyThreshold ?? rejectedIndex?.fuzzyThreshold ?? rejectedIndex?.threshold;\n  return typeof threshold === 'number' && Number.isFinite(threshold) && threshold >= 0 && threshold <= 1\n    ? threshold\n    : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n}\n\n/**\n * Find the active rejected pattern that suppresses a candidate, if any.\n *\n * @param {string|Object} candidate - Candidate text or structured candidate.\n * @param {Object|Array<Object>} rejectedIndex - Derived rejected-pattern index.\n * @param {Object} [options] - Match options.\n * @param {string} [options.category=\"general\"] - Candidate category.\n * @returns {Object|null} Match metadata when the candidate is suppressed.\n */\nfunction findRejectedPatternMatch(candidate, rejectedIndex, options = {}) {\n  const candidateText = readCandidateText(candidate);\n  const candidateKey = normalizeRejectedPatternKey(candidateText);\n  if (!candidateKey) {\n    return null;\n  }\n\n  const candidateCategory = readCandidateCategory(candidate, options.category);\n  const fuzzyThreshold = resolveCandidateThreshold(rejectedIndex, options);\n  let bestFuzzyMatch = null;\n\n  for (const entry of readRejectedEntries(rejectedIndex)) {\n    const rejectedPattern = entry.pattern || entry.text || '';\n    const rejectedKey = entry.normalizedPattern || normalizeRejectedPatternKey(rejectedPattern);\n    const rejectedCategory = normalizeRejectedPatternCategory(entry.category);\n    if (!rejectedKey || !isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory)) {\n      continue;\n    }\n\n    if (rejectedKey === candidateKey) {\n      return {\n        candidateText,\n        candidateCategory,\n        matchType: 'exact',\n        similarity: 1,\n        rejectedPattern: {\n          ...entry,\n          pattern: rejectedPattern,\n          normalizedPattern: rejectedKey,\n          category: rejectedCategory,\n        },\n      };\n    }\n\n    const similarity = calculateRejectedPatternSimilarity(candidateKey, rejectedKey);\n    if (similarity < fuzzyThreshold) {\n      continue;\n    }\n    if (!bestFuzzyMatch || similarity > bestFuzzyMatch.similarity) {\n      bestFuzzyMatch = {\n        candidateText,\n        candidateCategory,","lineStart":1,"lineEnd":420,"totalLines":2758,"truncated":true}},"title":".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","time":{"start":1783486645586,"end":1783486645591}},"metadata":{"openai":{"itemId":"fc_070f0586237a5998016a4dd8b578bc8191bdf509d9a020211a"}},"id":"prt_f4016853400113abbeEpbc5BAo","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f401648cd001cy2V6YZm8jKDec"}}
{"type":"tool_use","timestamp":1783486645619,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_LBUyC28WWQxCY9SVeIu9hkBg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: // After-dispatch leaf-reliability check for the deep-loop iteration loop.\n5: //\n6: // A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n7: // (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n8: // per-iteration delta file. The state-log record must also carry route-proof\n9: // fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n10: // resolved_route). A model-driven loop is trusted to self-check today, which lets a\n11: // silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n12: // non-zero with a single machine reason so the workflow can re-dispatch the same\n13: // iteration once before recording an error and continuing.\n14: \n15: const fs = require('node:fs');\n16: const path = require('node:path');\n17: \n18: const LEAF_BY_LOOP = {\n19:   review: 'deep-review',\n20:   research: 'deep-research',\n21: };\n22: \n23: const STATE_LOG_BY_LOOP = {\n24:   review: 'deep-review-state.jsonl',\n25:   research: 'deep-research-state.jsonl',\n26: };\n27: \n28: const REASONS = {\n29:   ITERATION_FILE_MISSING: 'iteration_file_missing',\n30:   ITERATION_VERDICT_MISSING: 'iteration_verdict_missing',\n31:   STATE_RECORD_MISSING: 'state_record_missing',\n32:   ROUTE_PROOF_MISSING: 'route_proof_missing',\n33:   ROUTE_PROOF_MISMATCH: 'route_proof_mismatch',\n34:   DELTA_FILE_MISSING: 'delta_file_missing',\n35: };\n36: \n37: function pad3(n) {\n38:   return String(n).padStart(3, '0');\n39: }\n40: \n41: function parseArgs(argv) {\n42:   const out = { json: false };\n43:   for (let i = 0; i < argv.length; i += 1) {\n44:     const a = argv[i];\n45:     if (a === '--loop-type') { out.loopType = argv[i + 1]; i += 1; }\n46:     else if (a === '--artifact-dir') { out.artifactDir = argv[i + 1]; i += 1; }\n47:     else if (a === '--iteration') { out.iteration = parseInt(argv[i + 1], 10); i += 1; }\n48:     else if (a === '--json') { out.json = true; }\n49:     else if (a === '--help' || a === '-h') { out.help = true; }\n50:     else { out.error = `unknown flag: ${a}`; }\n51:   }\n52:   return out;\n53: }\n54: \n55: // Read a JSONL file and return parsed objects, skipping blank/malformed lines so a\n56: // single corrupt append never crashes the gate.\n57: function readJsonlRecords(filePath) {\n58:   let raw;\n59:   try {\n60:     raw = fs.readFileSync(filePath, 'utf8');\n61:   } catch (_) {\n62:     return null; // file absent/unreadable\n63:   }\n64:   const records = [];\n65:   for (const line of raw.split('\\n')) {\n66:     const trimmed = line.trim();\n67:     if (!trimmed) continue;\n68:     try {\n69:       records.push(JSON.parse(trimmed));\n70:     } catch (_) {\n71:       // skip malformed line\n72:     }\n73:   }\n74:   return records;\n75: }\n76: \n77: // The narrative file is written as iteration-NNN.md but the leaf may append a\n78: // descriptive suffix (iteration-NNN-some-focus.md), so match the padded number as a\n79: // prefix bounded by \".\" or \"-\" to avoid confusing 002 with 020.\n80: function findIterationNarrative(iterationsDir, iteration) {\n81:   const nnn = pad3(iteration);\n82:   let entries;\n83:   try {\n84:     entries = fs.readdirSync(iterationsDir);\n85:   } catch (_) {\n86:     return null;\n87:   }\n88:   const re = new RegExp(`^iteration-${nnn}(?:\\\\.md$|-.*\\\\.md$)`);\n89:   for (const name of entries) {\n90:     if (re.test(name)) return path.join(iterationsDir, name);\n91:   }\n92:   return null;\n93: }\n94: \n95: function isNonEmptyString(value) {\n96:   return typeof value === 'string' && value.trim().length > 0;\n97: }\n98: \n99: // Route-proof lives on the canonical iteration record. Absent fields => the leaf did\n100: // not emit route-proof at all; present-but-wrong => it ran as something other than\n101: // its own leaf identity or in the wrong mode.\n102: function checkRouteProof(record, loopType, leaf) {\n103:   const hasMode = 'mode' in record;\n104:   const hasTarget = 'target_agent' in record;\n105:   const hasLoaded = 'agent_definition_loaded' in record;\n106:   const hasRoute = 'resolved_route' in record;\n107:   if (!hasMode || !hasTarget || !hasLoaded || !hasRoute) {\n108:     return REASONS.ROUTE_PROOF_MISSING;\n109:   }\n110:   if (\n111:     record.mode !== loopType ||\n112:     record.target_agent !== leaf ||\n113:     record.agent_definition_loaded !== true ||\n114:     !isNonEmptyString(record.resolved_route)\n115:   ) {\n116:     return REASONS.ROUTE_PROOF_MISMATCH;\n117:   }\n118:   return null;\n119: }\n120: \n121: function verify(loopType, artifactDir, iteration) {\n122:   const leaf = LEAF_BY_LOOP[loopType];\n123:   const stateLogName = STATE_LOG_BY_LOOP[loopType];\n124: \n125:   // 1. Iteration narrative markdown.\n126:   const narrativePath = findIterationNarrative(path.join(artifactDir, 'iterations'), iteration);\n127:   if (!narrativePath) {\n128:     return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `no iterations/iteration-${pad3(iteration)}*.md under ${artifactDir}` };\n129:   }\n130:   const narrative = fs.readFileSync(narrativePath, 'utf8');\n131:   if (!narrative.trim()) {\n132:     return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `${narrativePath} is empty` };\n133:   }\n134:   // Review narratives must end on a machine-readable verdict; research/context use a\n135:   // different closing shape, so only review enforces the verdict line here.\n136:   if (loopType === 'review' && !/Review verdict:\\s*(PASS|CONDITIONAL|FAIL)/i.test(narrative)) {\n137:     return { ok: false, reason: REASONS.ITERATION_VERDICT_MISSING, detail: `${narrativePath} lacks a \"Review verdict: PASS|CONDITIONAL|FAIL\" line` };\n138:   }\n139: \n140:   // 2. Canonical state-log record for this iteration + route-proof.\n141:   const stateRecords = readJsonlRecords(path.join(artifactDir, stateLogName));\n142:   // Review/research key the iteration number as `iteration`; context keys it as `run`.\n143:   // Match either so one shim covers all three modes (a non-numeric run-id yields NaN\n144:   // and never false-matches). Take the LAST matching record, not the first: the state\n145:   // log is append-only, so a re-dispatched iteration appends a corrected record after\n146:   // the bad one -- matching the first would keep reporting the stale failure and defeat\n147:   // the bounded retry. The state reducer applies the same latest-record-wins rule.\n148:   const iterationRecord = (stateRecords || []).findLast(\n149:     (r) => r && r.type === 'iteration' && (Number(r.iteration) === iteration || Number(r.run) === iteration),\n150:   );\n151:   if (!iterationRecord) {\n152:     return { ok: false, reason: REASONS.STATE_RECORD_MISSING, detail: `no type=iteration record with iteration=${iteration} in ${stateLogName}` };\n153:   }\n154:   const routeReason = checkRouteProof(iterationRecord, loopType, leaf);\n155:   if (routeReason) {\n156:     return { ok: false, reason: routeReason, detail: `iteration ${iteration} state record failed route-proof (expected mode=${loopType} target_agent=${leaf})` };\n157:   }\n158: \n159:   // 3. Per-iteration delta file with at least one iteration record.\n160:   const deltaRecords = readJsonlRecords(path.join(artifactDir, 'deltas', `iter-${pad3(iteration)}.jsonl`));\n161:   if (!deltaRecords || !deltaRecords.some((r) => r && r.type === 'iteration')) {\n162:     return { ok: false, reason: REASONS.DELTA_FILE_MISSING, detail: `deltas/iter-${pad3(iteration)}.jsonl missing or has no type=iteration record` };\n163:   }\n164: \n165:   return { ok: true, reason: null, detail: `iteration ${iteration} complete: narrative + route-proof + delta` };\n166: }\n167: \n168: function main(argv = process.argv.slice(2)) {\n169:   const args = parseArgs(argv);\n170:   if (args.help) {\n171:     process.stdout.write('Usage: verify-iteration.cjs --loop-type review|research|context --artifact-dir <dir> --iteration <N> [--json]\\n');\n172:     return 0;\n173:   }\n174:   if (args.error) { process.stderr.write(`${args.error}\\n`); return 2; }\n175:   if (!args.loopType || !LEAF_BY_LOOP[args.loopType]) { process.stderr.write('--loop-type must be one of review|research\\n'); return 2; }\n176:   if (!args.artifactDir) { process.stderr.write('--artifact-dir is required\\n'); return 2; }\n177:   if (!Number.isInteger(args.iteration) || args.iteration < 1) { process.stderr.write('--iteration must be a positive integer\\n'); return 2; }\n178: \n179:   const result = verify(args.loopType, args.artifactDir, args.iteration);\n180:   if (args.json) {\n181:     process.stdout.write(`${JSON.stringify(result)}\\n`);\n182:   } else if (result.ok) {\n183:     process.stdout.write(`OK ${result.detail}\\n`);\n184:   } else {\n185:     process.stderr.write(`${result.reason} ${result.detail}\\n`);\n186:   }\n187:   return result.ok ? 0 : 1;\n188: }\n189: \n190: if (require.main === module) {\n191:   process.exit(main());\n192: }\n193: \n194: module.exports = { verify, checkRouteProof, findIterationNarrative, readJsonlRecords, pad3, REASONS, LEAF_BY_LOOP, STATE_LOG_BY_LOOP };\n\n(End of file - total 194 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n// After-dispatch leaf-reliability check for the deep-loop iteration loop.\n//\n// A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n// (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n// per-iteration delta file. The state-log record must also carry route-proof\n// fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n// resolved_route). A model-driven loop is trusted to self-check today, which lets a\n// silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n// non-zero with a single machine reason so the workflow can re-dispatch the same\n// iteration once before recording an error and continuing.\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst LEAF_BY_LOOP = {\n  review: 'deep-review',\n  research: 'deep-research',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs","text":"#!/usr/bin/env node\n'use strict';\n\n// After-dispatch leaf-reliability check for the deep-loop iteration loop.\n//\n// A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n// (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n// per-iteration delta file. The state-log record must also carry route-proof\n// fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n// resolved_route). A model-driven loop is trusted to self-check today, which lets a\n// silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n// non-zero with a single machine reason so the workflow can re-dispatch the same\n// iteration once before recording an error and continuing.\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst LEAF_BY_LOOP = {\n  review: 'deep-review',\n  research: 'deep-research',\n};\n\nconst STATE_LOG_BY_LOOP = {\n  review: 'deep-review-state.jsonl',\n  research: 'deep-research-state.jsonl',\n};\n\nconst REASONS = {\n  ITERATION_FILE_MISSING: 'iteration_file_missing',\n  ITERATION_VERDICT_MISSING: 'iteration_verdict_missing',\n  STATE_RECORD_MISSING: 'state_record_missing',\n  ROUTE_PROOF_MISSING: 'route_proof_missing',\n  ROUTE_PROOF_MISMATCH: 'route_proof_mismatch',\n  DELTA_FILE_MISSING: 'delta_file_missing',\n};\n\nfunction pad3(n) {\n  return String(n).padStart(3, '0');\n}\n\nfunction parseArgs(argv) {\n  const out = { json: false };\n  for (let i = 0; i < argv.length; i += 1) {\n    const a = argv[i];\n    if (a === '--loop-type') { out.loopType = argv[i + 1]; i += 1; }\n    else if (a === '--artifact-dir') { out.artifactDir = argv[i + 1]; i += 1; }\n    else if (a === '--iteration') { out.iteration = parseInt(argv[i + 1], 10); i += 1; }\n    else if (a === '--json') { out.json = true; }\n    else if (a === '--help' || a === '-h') { out.help = true; }\n    else { out.error = `unknown flag: ${a}`; }\n  }\n  return out;\n}\n\n// Read a JSONL file and return parsed objects, skipping blank/malformed lines so a\n// single corrupt append never crashes the gate.\nfunction readJsonlRecords(filePath) {\n  let raw;\n  try {\n    raw = fs.readFileSync(filePath, 'utf8');\n  } catch (_) {\n    return null; // file absent/unreadable\n  }\n  const records = [];\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) continue;\n    try {\n      records.push(JSON.parse(trimmed));\n    } catch (_) {\n      // skip malformed line\n    }\n  }\n  return records;\n}\n\n// The narrative file is written as iteration-NNN.md but the leaf may append a\n// descriptive suffix (iteration-NNN-some-focus.md), so match the padded number as a\n// prefix bounded by \".\" or \"-\" to avoid confusing 002 with 020.\nfunction findIterationNarrative(iterationsDir, iteration) {\n  const nnn = pad3(iteration);\n  let entries;\n  try {\n    entries = fs.readdirSync(iterationsDir);\n  } catch (_) {\n    return null;\n  }\n  const re = new RegExp(`^iteration-${nnn}(?:\\\\.md$|-.*\\\\.md$)`);\n  for (const name of entries) {\n    if (re.test(name)) return path.join(iterationsDir, name);\n  }\n  return null;\n}\n\nfunction isNonEmptyString(value) {\n  return typeof value === 'string' && value.trim().length > 0;\n}\n\n// Route-proof lives on the canonical iteration record. Absent fields => the leaf did\n// not emit route-proof at all; present-but-wrong => it ran as something other than\n// its own leaf identity or in the wrong mode.\nfunction checkRouteProof(record, loopType, leaf) {\n  const hasMode = 'mode' in record;\n  const hasTarget = 'target_agent' in record;\n  const hasLoaded = 'agent_definition_loaded' in record;\n  const hasRoute = 'resolved_route' in record;\n  if (!hasMode || !hasTarget || !hasLoaded || !hasRoute) {\n    return REASONS.ROUTE_PROOF_MISSING;\n  }\n  if (\n    record.mode !== loopType ||\n    record.target_agent !== leaf ||\n    record.agent_definition_loaded !== true ||\n    !isNonEmptyString(record.resolved_route)\n  ) {\n    return REASONS.ROUTE_PROOF_MISMATCH;\n  }\n  return null;\n}\n\nfunction verify(loopType, artifactDir, iteration) {\n  const leaf = LEAF_BY_LOOP[loopType];\n  const stateLogName = STATE_LOG_BY_LOOP[loopType];\n\n  // 1. Iteration narrative markdown.\n  const narrativePath = findIterationNarrative(path.join(artifactDir, 'iterations'), iteration);\n  if (!narrativePath) {\n    return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `no iterations/iteration-${pad3(iteration)}*.md under ${artifactDir}` };\n  }\n  const narrative = fs.readFileSync(narrativePath, 'utf8');\n  if (!narrative.trim()) {\n    return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `${narrativePath} is empty` };\n  }\n  // Review narratives must end on a machine-readable verdict; research/context use a\n  // different closing shape, so only review enforces the verdict line here.\n  if (loopType === 'review' && !/Review verdict:\\s*(PASS|CONDITIONAL|FAIL)/i.test(narrative)) {\n    return { ok: false, reason: REASONS.ITERATION_VERDICT_MISSING, detail: `${narrativePath} lacks a \"Review verdict: PASS|CONDITIONAL|FAIL\" line` };\n  }\n\n  // 2. Canonical state-log record for this iteration + route-proof.\n  const stateRecords = readJsonlRecords(path.join(artifactDir, stateLogName));\n  // Review/research key the iteration number as `iteration`; context keys it as `run`.\n  // Match either so one shim covers all three modes (a non-numeric run-id yields NaN\n  // and never false-matches). Take the LAST matching record, not the first: the state\n  // log is append-only, so a re-dispatched iteration appends a corrected record after\n  // the bad one -- matching the first would keep reporting the stale failure and defeat\n  // the bounded retry. The state reducer applies the same latest-record-wins rule.\n  const iterationRecord = (stateRecords || []).findLast(\n    (r) => r && r.type === 'iteration' && (Number(r.iteration) === iteration || Number(r.run) === iteration),\n  );\n  if (!iterationRecord) {\n    return { ok: false, reason: REASONS.STATE_RECORD_MISSING, detail: `no type=iteration record with iteration=${iteration} in ${stateLogName}` };\n  }\n  const routeReason = checkRouteProof(iterationRecord, loopType, leaf);\n  if (routeReason) {\n    return { ok: false, reason: routeReason, detail: `iteration ${iteration} state record failed route-proof (expected mode=${loopType} target_agent=${leaf})` };\n  }\n\n  // 3. Per-iteration delta file with at least one iteration record.\n  const deltaRecords = readJsonlRecords(path.join(artifactDir, 'deltas', `iter-${pad3(iteration)}.jsonl`));\n  if (!deltaRecords || !deltaRecords.some((r) => r && r.type === 'iteration')) {\n    return { ok: false, reason: REASONS.DELTA_FILE_MISSING, detail: `deltas/iter-${pad3(iteration)}.jsonl missing or has no type=iteration record` };\n  }\n\n  return { ok: true, reason: null, detail: `iteration ${iteration} complete: narrative + route-proof + delta` };\n}\n\nfunction main(argv = process.argv.slice(2)) {\n  const args = parseArgs(argv);\n  if (args.help) {\n    process.stdout.write('Usage: verify-iteration.cjs --loop-type review|research|context --artifact-dir <dir> --iteration <N> [--json]\\n');\n    return 0;\n  }\n  if (args.error) { process.stderr.write(`${args.error}\\n`); return 2; }\n  if (!args.loopType || !LEAF_BY_LOOP[args.loopType]) { process.stderr.write('--loop-type must be one of review|research\\n'); return 2; }\n  if (!args.artifactDir) { process.stderr.write('--artifact-dir is required\\n'); return 2; }\n  if (!Number.isInteger(args.iteration) || args.iteration < 1) { process.stderr.write('--iteration must be a positive integer\\n'); return 2; }\n\n  const result = verify(args.loopType, args.artifactDir, args.iteration);\n  if (args.json) {\n    process.stdout.write(`${JSON.stringify(result)}\\n`);\n  } else if (result.ok) {\n    process.stdout.write(`OK ${result.detail}\\n`);\n  } else {\n    process.stderr.write(`${result.reason} ${result.detail}\\n`);\n  }\n  return result.ok ? 0 : 1;\n}\n\nif (require.main === module) {\n  process.exit(main());\n}\n\nmodule.exports = { verify, checkRouteProof, findIterationNarrative, readJsonlRecords, pad3, REASONS, LEAF_BY_LOOP, STATE_LOG_BY_LOOP };","lineStart":1,"lineEnd":194,"totalLines":194,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs","time":{"start":1783486645609,"end":1783486645617}},"metadata":{"openai":{"itemId":"fc_070f0586237a5998016a4dd8b57c6c8191ad5305ff5d5e597f"}},"id":"prt_f40168567001UeuewVRp23VxRt","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f401648cd001cy2V6YZm8jKDec"}}
{"type":"tool_use","timestamp":1783486645619,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_etccUTzscjnGTlobDwBvbE8N","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Convergence Entrypoint                               ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Input:  CLI args (--spec-folder, --loop-type, --session-id, optional     ║\n7: // ║         --iteration, --persist-snapshot).                                ║\n8: // ║ Output: JSON to stdout.                                                  ║\n9: // ║ Exit:   0=ok, 1=script error, 2=DB error, 3=input validation error.     ║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: \n12: 'use strict';\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 1. IMPORTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: const fs = require('node:fs');\n19: const path = require('node:path');\n20: const { spawnSync } = require('node:child_process');\n21: \n22: const {\n23:   acquireWriterLock,\n24:   classifyExitCode,\n25:   installSignalHandlers,\n26:   maybeThrowTestFault,\n27:   validateNamespaceValue,\n28: } = require('./lib/cli-guards.cjs');\n29: \n30: const {\n31:   appendObservabilityEvent,\n32: } = require('../lib/deep-loop/observability-events.cjs');\n33: \n34: // ─────────────────────────────────────────────────────────────────────────────\n35: // 2. CONSTANTS\n36: // ─────────────────────────────────────────────────────────────────────────────\n37: \n38: const TSX_LOADER = require.resolve('tsx');\n39: const DEFAULT_REPORTED_NOVELTY_THRESHOLD = 0.05;\n40: const DEFAULT_GRAPH_NOVELTY_FLOOR = 0.05;\n41: const DEFAULT_MIN_OBSERVATIONS = 2;\n42: const DEFAULT_SLIDING_WINDOW_SIZE = 5;\n43: const MIN_OBSERVATIONS_FLOOR = 1;\n44: const MIN_OBSERVATIONS_CEILING = 10;\n45: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n46: const VALID_CONVERGENCE_MODES = new Set(['default', 'off', 'sliding-window']);\n47: \n48: /**\n49:  * Shared convergence profile schema:\n50:  * - threshold: numeric boundary a metric is compared against before STOP can be allowed.\n51:  * - weight: contribution a metric makes to a loop-local composite score; use 0 for pure guards.\n52:  * - role: whether a metric is a weighted score input, a blocking guard, or both.\n53:  * - direction: passing comparison for the metric (`gte`, `lte`, or `eq`).\n54:  * - normalizer: named loop-local transform that converts raw observations into comparable metric values.\n55:  *\n56:  * The shared shape keeps metric contracts explicit while each loop preserves its\n57:  * own semantics; convergence does not collapse into one universal formula.\n58:  */\n59: /**\n60:  * @typedef {'weighted' | 'blocking_guard' | 'weighted_guard'} ConvergenceProfileRole\n61:  * @typedef {'gte' | 'lte' | 'eq'} ConvergenceProfileDirection\n62:  * @typedef {'identity' | 'clamp01' | 'inverseClamp01' | 'capRatio' | 'presence'} ConvergenceProfileNormalizer\n63:  * @typedef {Object} ConvergenceProfileSchema\n64:  * @property {'number'} threshold\n65:  * @property {'number'} weight\n66:  * @property {ReadonlyArray<ConvergenceProfileRole>} role\n67:  * @property {ReadonlyArray<ConvergenceProfileDirection>} direction\n68:  * @property {ReadonlyArray<ConvergenceProfileNormalizer>} normalizer\n69:  */\n70: /** @type {Readonly<ConvergenceProfileSchema>} */\n71: const CONVERGENCE_PROFILE_SCHEMA = Object.freeze({\n72:   threshold: 'number',\n73:   weight: 'number',\n74:   role: Object.freeze(['weighted', 'blocking_guard', 'weighted_guard']),\n75:   direction: Object.freeze(['gte', 'lte', 'eq']),\n76:   normalizer: Object.freeze(['identity', 'clamp01', 'inverseClamp01', 'capRatio', 'presence']),\n77: });\n78: \n79: // ─────────────────────────────────────────────────────────────────────────────\n80: // 3. TSX BOOTSTRAP\n81: // ─────────────────────────────────────────────────────────────────────────────\n82: \n83: if (require.main === module && process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n84:   const child = spawnSync(\n85:     process.execPath,\n86:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n87:     {\n88:       cwd: process.cwd(),\n89:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n90:       input: process.stdin.isTTY ? undefined : fs.readFileSync(0),\n91:       encoding: 'utf8',\n92:     },\n93:   );\n94:   if (child.stdout) process.stdout.write(child.stdout);\n95:   if (child.stderr) process.stderr.write(child.stderr);\n96:   process.exit(child.status === null ? 1 : child.status);\n97: }\n98: \n99: // ─────────────────────────────────────────────────────────────────────────────\n100: // 4. HELPERS\n101: // ─────────────────────────────────────────────────────────────────────────────\n102: \n103: function parseArgs(argv = process.argv.slice(2)) {\n104:   const args = {};\n105:   for (let i = 0; i < argv.length; i += 1) {\n106:     const token = argv[i];\n107:     if (!token.startsWith('--')) {\n108:       throw inputError(`Unexpected positional argument: ${token}`);\n109:     }\n110:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n111:     const next = argv[i + 1];\n112:     if (next === undefined || next.startsWith('--')) {\n113:       args[key] = true;\n114:     } else {\n115:       args[key] = next;\n116:       i += 1;\n117:     }\n118:   }\n119:   return args;\n120: }\n121: \n122: function inputError(message) {\n123:   const err = new Error(message);\n124:   err.code = 'INPUT_VALIDATION';\n125:   return err;\n126: }\n127: \n128: function ensureString(args, key) {\n129:   if (!args[key] || typeof args[key] !== 'string') {\n130:     throw inputError(`${key} is required`);\n131:   }\n132:   return args[key];\n133: }\n134: \n135: function asBoolean(value) {\n136:   return value === true || value === 'true' || value === '1';\n137: }\n138: \n139: function parseOptionalJsonObject(value, key) {\n140:   if (value === undefined || value === null || value === true || value === '') return {};\n141:   if (typeof value !== 'string') throw inputError(`${key} must be a JSON object`);\n142:   let parsed;\n143:   try {\n144:     parsed = JSON.parse(value);\n145:   } catch {\n146:     throw inputError(`${key} must be valid JSON`);\n147:   }\n148:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n149:     throw inputError(`${key} must be a JSON object`);\n150:   }\n151:   return parsed;\n152: }\n153: \n154: function parseOptionalRatio(value, key) {\n155:   if (value === undefined || value === null || value === true || value === '') return null;\n156:   const parsed = Number(value);\n157:   if (!Number.isFinite(parsed) || parsed < 0 || parsed > 1) {\n158:     throw inputError(`${key} must be a number between 0 and 1`);\n159:   }\n160:   return parsed;\n161: }\n162: \n163: function parseRatioWithDefault(value, key, fallback) {\n164:   const parsed = parseOptionalRatio(value, key);\n165:   return parsed === null ? fallback : parsed;\n166: }\n167: \n168: function parseMinObservationsValue(value, key = 'minObservations') {\n169:   if (value === undefined || value === null || value === true || value === '') return DEFAULT_MIN_OBSERVATIONS;\n170:   const parsed = Number(value);\n171:   if (!Number.isFinite(parsed)) {\n172:     throw inputError(`${key} must be a finite number`);\n173:   }\n174:   return Math.max(MIN_OBSERVATIONS_FLOOR, Math.min(MIN_OBSERVATIONS_CEILING, Math.trunc(parsed)));\n175: }\n176: \n177: function parseConvergenceModeValue(value, key = 'convergenceMode') {\n178:   if (value === undefined || value === null || value === '') return 'default';\n179:   if (typeof value !== 'string') {\n180:     throw inputError(`${key} must be \"default\", \"off\", or \"sliding-window\"`);\n181:   }\n182:   const mode = value.trim();\n183:   if (!VALID_CONVERGENCE_MODES.has(mode)) {\n184:     throw inputError(`${key} must be \"default\", \"off\", or \"sliding-window\"`);\n185:   }\n186:   return mode;\n187: }\n188: \n189: function parseSlidingWindowSizeValue(value, key = 'slidingWindowSize') {\n190:   if (value === undefined || value === null || value === '') return DEFAULT_SLIDING_WINDOW_SIZE;\n191:   const parsed = Number(value);\n192:   if (!Number.isInteger(parsed) || parsed <= 0) {\n193:     throw inputError(`${key} must be a positive integer`);\n194:   }\n195:   return parsed;\n196: }\n197: \n198: function configSection(config, key) {\n199:   const section = config[key];\n200:   return section && typeof section === 'object' && !Array.isArray(section) ? section : {};\n201: }\n202: \n203: function firstDefined(...values) {\n204:   for (const value of values) {\n205:     if (value !== undefined) return value;\n206:   }\n207:   return undefined;\n208: }\n209: \n210: function readConvergenceModeConfig(args) {\n211:   const config = parseOptionalJsonObject(args.configJson, 'configJson');\n212:   const antiConvergence = configSection(config, 'antiConvergence');\n213:   const mode = parseConvergenceModeValue(firstDefined(\n214:     args.convergenceMode,\n215:     args.convergence_mode,\n216:     config.convergenceMode,\n217:     config.convergence_mode,\n218:     antiConvergence.convergenceMode,\n219:     antiConvergence.convergence_mode,\n220:   ));\n221: \n222:   if (mode !== 'sliding-window') {\n223:     return { mode, slidingWindowSize: DEFAULT_SLIDING_WINDOW_SIZE };\n224:   }\n225: \n226:   return {\n227:     mode,\n228:     slidingWindowSize: parseSlidingWindowSizeValue(firstDefined(\n229:       args.slidingWindowSize,\n230:       args.sliding_window_size,\n231:       config.slidingWindowSize,\n232:       config.sliding_window_size,\n233:       antiConvergence.slidingWindowSize,\n234:       antiConvergence.sliding_window_size,\n235:     )),\n236:   };\n237: }\n238: \n239: function resolveMinObservationsInput(args) {\n240:   if (args.minObservations !== undefined) return { value: args.minObservations, key: 'minObservations' };\n241:   if (args.min_observations !== undefined) return { value: args.min_observations, key: 'min_observations' };\n242: \n243:   const config = parseOptionalJsonObject(args.configJson, 'configJson');\n244:   if (config.min_observations !== undefined) return { value: config.min_observations, key: 'min_observations' };\n245:   if (config.minObservations !== undefined) return { value: config.minObservations, key: 'minObservations' };\n246:   if (process.env.DEEP_LOOP_MIN_OBSERVATIONS !== undefined) {\n247:     return { value: process.env.DEEP_LOOP_MIN_OBSERVATIONS, key: 'DEEP_LOOP_MIN_OBSERVATIONS' };\n248:   }\n249:   return null;\n250: }\n251: \n252: function readObservationThresholdConfig(args) {\n253:   const input = resolveMinObservationsInput(args);\n254:   const enabledByFlag =\n255:     asBoolean(args.observationThresholdGuard) ||\n256:     asBoolean(args.minObservationsGuard) ||\n257:     asBoolean(process.env.DEEP_LOOP_MIN_OBSERVATIONS_GUARD);\n258: \n259:   if (!input && !enabledByFlag) {\n260:     return { enabled: false, minObservations: 1 };\n\n(Showing lines 1-260 of 890. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Convergence Entrypoint                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --session-id, optional     ║\n// ║         --iteration, --persist-snapshot).                                ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=ok, 1=script error, 2=DB error, 3=input validation error.     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Convergence Entrypoint                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --session-id, optional     ║\n// ║         --iteration, --persist-snapshot).                                ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=ok, 1=script error, 2=DB error, 3=input validation error.     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');\n\nconst {\n  acquireWriterLock,\n  classifyExitCode,\n  installSignalHandlers,\n  maybeThrowTestFault,\n  validateNamespaceValue,\n} = require('./lib/cli-guards.cjs');\n\nconst {\n  appendObservabilityEvent,\n} = require('../lib/deep-loop/observability-events.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\nconst DEFAULT_REPORTED_NOVELTY_THRESHOLD = 0.05;\nconst DEFAULT_GRAPH_NOVELTY_FLOOR = 0.05;\nconst DEFAULT_MIN_OBSERVATIONS = 2;\nconst DEFAULT_SLIDING_WINDOW_SIZE = 5;\nconst MIN_OBSERVATIONS_FLOOR = 1;\nconst MIN_OBSERVATIONS_CEILING = 10;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\nconst VALID_CONVERGENCE_MODES = new Set(['default', 'off', 'sliding-window']);\n\n/**\n * Shared convergence profile schema:\n * - threshold: numeric boundary a metric is compared against before STOP can be allowed.\n * - weight: contribution a metric makes to a loop-local composite score; use 0 for pure guards.\n * - role: whether a metric is a weighted score input, a blocking guard, or both.\n * - direction: passing comparison for the metric (`gte`, `lte`, or `eq`).\n * - normalizer: named loop-local transform that converts raw observations into comparable metric values.\n *\n * The shared shape keeps metric contracts explicit while each loop preserves its\n * own semantics; convergence does not collapse into one universal formula.\n */\n/**\n * @typedef {'weighted' | 'blocking_guard' | 'weighted_guard'} ConvergenceProfileRole\n * @typedef {'gte' | 'lte' | 'eq'} ConvergenceProfileDirection\n * @typedef {'identity' | 'clamp01' | 'inverseClamp01' | 'capRatio' | 'presence'} ConvergenceProfileNormalizer\n * @typedef {Object} ConvergenceProfileSchema\n * @property {'number'} threshold\n * @property {'number'} weight\n * @property {ReadonlyArray<ConvergenceProfileRole>} role\n * @property {ReadonlyArray<ConvergenceProfileDirection>} direction\n * @property {ReadonlyArray<ConvergenceProfileNormalizer>} normalizer\n */\n/** @type {Readonly<ConvergenceProfileSchema>} */\nconst CONVERGENCE_PROFILE_SCHEMA = Object.freeze({\n  threshold: 'number',\n  weight: 'number',\n  role: Object.freeze(['weighted', 'blocking_guard', 'weighted_guard']),\n  direction: Object.freeze(['gte', 'lte', 'eq']),\n  normalizer: Object.freeze(['identity', 'clamp01', 'inverseClamp01', 'capRatio', 'presence']),\n});\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module && process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  const child = spawnSync(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      input: process.stdin.isTTY ? undefined : fs.readFileSync(0),\n      encoding: 'utf8',\n    },\n  );\n  if (child.stdout) process.stdout.write(child.stdout);\n  if (child.stderr) process.stderr.write(child.stderr);\n  process.exit(child.status === null ? 1 : child.status);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction asBoolean(value) {\n  return value === true || value === 'true' || value === '1';\n}\n\nfunction parseOptionalJsonObject(value, key) {\n  if (value === undefined || value === null || value === true || value === '') return {};\n  if (typeof value !== 'string') throw inputError(`${key} must be a JSON object`);\n  let parsed;\n  try {\n    parsed = JSON.parse(value);\n  } catch {\n    throw inputError(`${key} must be valid JSON`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw inputError(`${key} must be a JSON object`);\n  }\n  return parsed;\n}\n\nfunction parseOptionalRatio(value, key) {\n  if (value === undefined || value === null || value === true || value === '') return null;\n  const parsed = Number(value);\n  if (!Number.isFinite(parsed) || parsed < 0 || parsed > 1) {\n    throw inputError(`${key} must be a number between 0 and 1`);\n  }\n  return parsed;\n}\n\nfunction parseRatioWithDefault(value, key, fallback) {\n  const parsed = parseOptionalRatio(value, key);\n  return parsed === null ? fallback : parsed;\n}\n\nfunction parseMinObservationsValue(value, key = 'minObservations') {\n  if (value === undefined || value === null || value === true || value === '') return DEFAULT_MIN_OBSERVATIONS;\n  const parsed = Number(value);\n  if (!Number.isFinite(parsed)) {\n    throw inputError(`${key} must be a finite number`);\n  }\n  return Math.max(MIN_OBSERVATIONS_FLOOR, Math.min(MIN_OBSERVATIONS_CEILING, Math.trunc(parsed)));\n}\n\nfunction parseConvergenceModeValue(value, key = 'convergenceMode') {\n  if (value === undefined || value === null || value === '') return 'default';\n  if (typeof value !== 'string') {\n    throw inputError(`${key} must be \"default\", \"off\", or \"sliding-window\"`);\n  }\n  const mode = value.trim();\n  if (!VALID_CONVERGENCE_MODES.has(mode)) {\n    throw inputError(`${key} must be \"default\", \"off\", or \"sliding-window\"`);\n  }\n  return mode;\n}\n\nfunction parseSlidingWindowSizeValue(value, key = 'slidingWindowSize') {\n  if (value === undefined || value === null || value === '') return DEFAULT_SLIDING_WINDOW_SIZE;\n  const parsed = Number(value);\n  if (!Number.isInteger(parsed) || parsed <= 0) {\n    throw inputError(`${key} must be a positive integer`);\n  }\n  return parsed;\n}\n\nfunction configSection(config, key) {\n  const section = config[key];\n  return section && typeof section === 'object' && !Array.isArray(section) ? section : {};\n}\n\nfunction firstDefined(...values) {\n  for (const value of values) {\n    if (value !== undefined) return value;\n  }\n  return undefined;\n}\n\nfunction readConvergenceModeConfig(args) {\n  const config = parseOptionalJsonObject(args.configJson, 'configJson');\n  const antiConvergence = configSection(config, 'antiConvergence');\n  const mode = parseConvergenceModeValue(firstDefined(\n    args.convergenceMode,\n    args.convergence_mode,\n    config.convergenceMode,\n    config.convergence_mode,\n    antiConvergence.convergenceMode,\n    antiConvergence.convergence_mode,\n  ));\n\n  if (mode !== 'sliding-window') {\n    return { mode, slidingWindowSize: DEFAULT_SLIDING_WINDOW_SIZE };\n  }\n\n  return {\n    mode,\n    slidingWindowSize: parseSlidingWindowSizeValue(firstDefined(\n      args.slidingWindowSize,\n      args.sliding_window_size,\n      config.slidingWindowSize,\n      config.sliding_window_size,\n      antiConvergence.slidingWindowSize,\n      antiConvergence.sliding_window_size,\n    )),\n  };\n}\n\nfunction resolveMinObservationsInput(args) {\n  if (args.minObservations !== undefined) return { value: args.minObservations, key: 'minObservations' };\n  if (args.min_observations !== undefined) return { value: args.min_observations, key: 'min_observations' };\n\n  const config = parseOptionalJsonObject(args.configJson, 'configJson');\n  if (config.min_observations !== undefined) return { value: config.min_observations, key: 'min_observations' };\n  if (config.minObservations !== undefined) return { value: config.minObservations, key: 'minObservations' };\n  if (process.env.DEEP_LOOP_MIN_OBSERVATIONS !== undefined) {\n    return { value: process.env.DEEP_LOOP_MIN_OBSERVATIONS, key: 'DEEP_LOOP_MIN_OBSERVATIONS' };\n  }\n  return null;\n}\n\nfunction readObservationThresholdConfig(args) {\n  const input = resolveMinObservationsInput(args);\n  const enabledByFlag =\n    asBoolean(args.observationThresholdGuard) ||\n    asBoolean(args.minObservationsGuard) ||\n    asBoolean(process.env.DEEP_LOOP_MIN_OBSERVATIONS_GUARD);\n\n  if (!input && !enabledByFlag) {\n    return { enabled: false, minObservations: 1 };","lineStart":1,"lineEnd":260,"totalLines":890,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/convergence.cjs","time":{"start":1783486645610,"end":1783486645618}},"metadata":{"openai":{"itemId":"fc_070f0586237a5998016a4dd8b57c7881918c0e908c76c3b2f5"}},"id":"prt_f40168569001U9FYukdlIyMZTO","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f401648cd001cy2V6YZm8jKDec"}}
