{"type":"tool_use","timestamp":1782750785866,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_cd017e2a310d4909a5ed569d","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/numeric_law_check.py"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/numeric_law_check.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"Deterministic completeness and uniqueness gate for the numeric design laws index.\n3: \n4: The index is a reference surface, so the first failure mode is a row that looks\n5: canonical while leaving a value, owner, source, or caveat blank. This checker\n6: parses the law table and exits non-zero unless every law row has all six\n7: required cells populated and no two rows register the same value.\n8: \n9: Usage:\n10:   numeric_law_check.py numeric_design_laws.md\n11:   numeric_law_check.py --json numeric_design_laws.md\n12: \n13: Exit: 0 = rows present, complete, and unique; 1 = missing rows, incomplete\n14: cells, or duplicate values; 2 = usage or read error.\n15: \"\"\"\n16: import json\n17: from pathlib import Path\n18: import re\n19: import sys\n20: from typing import Any\n21: \n22: REQUIRED_COLUMNS = [\n23:     \"law_id\",\n24:     \"value/range\",\n25:     \"owner mode\",\n26:     \"enforcement target\",\n27:     \"source\",\n28:     \"caveat\",\n29: ]\n30: LAW_TABLE_HEADING = re.compile(r\"^#{1,6}\\s+(?:\\d+\\.\\s+)?Law Index\\s*$\", re.I)\n31: MARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+\")\n32: PLACEHOLDER = re.compile(r\"^(?:_+|TBD|TODO|-)$\", re.I)\n33: \n34: \n35: def _clean_cell(value: str) -> str:\n36:     value = value.strip()\n37:     if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n38:         value = value[1:-1].strip()\n39:     return value\n40: \n41: \n42: def _split_table_row(line: str) -> list[str]:\n43:     line = line.strip()\n44:     if not line.startswith(\"|\") or not line.endswith(\"|\"):\n45:         return []\n46:     return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n47: \n48: \n49: def _is_separator_row(cells: list[str]) -> bool:\n50:     return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n51: \n52: \n53: def _is_placeholder(value: str) -> bool:\n54:     return not _clean_cell(value) or bool(PLACEHOLDER.fullmatch(_clean_cell(value)))\n55: \n56: \n57: def _normalized_header(cells: list[str]) -> list[str]:\n58:     return [re.sub(r\"\\s+\", \" \", _clean_cell(cell).lower()) for cell in cells]\n59: \n60: \n61: def _normalized_value(value: str) -> str:\n62:     return re.sub(r\"\\s+\", \" \", _clean_cell(value).lower()).strip()\n63: \n64: \n65: def _find_law_table_start(lines: list[str]) -> int:\n66:     for index, line in enumerate(lines):\n67:         if LAW_TABLE_HEADING.match(line):\n68:             return index + 1\n69:     return 0\n70: \n71: \n72: def _find_law_rows(text: str) -> tuple[list[dict[str, Any]], list[str]]:\n73:     lines = text.splitlines()\n74:     start = _find_law_table_start(lines)\n75:     rows: list[dict[str, Any]] = []\n76:     errors: list[str] = []\n77:     in_table = False\n78:     saw_header = False\n79: \n80:     for line_number, line in enumerate(lines[start:], start + 1):\n81:         cells = _split_table_row(line)\n82:         if not cells:\n83:             if in_table:\n84:                 break\n85:             if MARKDOWN_HEADING.match(line) and start != 0:\n86:                 break\n87:             continue\n88: \n89:         if len(cells) != len(REQUIRED_COLUMNS):\n90:             errors.append(f\"line {line_number}: expected 6 columns, found {len(cells)}\")\n91:             in_table = True\n92:             continue\n93: \n94:         normalized = _normalized_header(cells)\n95:         if normalized == REQUIRED_COLUMNS:\n96:             in_table = True\n97:             saw_header = True\n98:             continue\n99:         if _is_separator_row(cells):\n100:             in_table = True\n101:             continue\n102:         if not saw_header:\n103:             continue\n104: \n105:         row = dict(zip(REQUIRED_COLUMNS, [_clean_cell(cell) for cell in cells]))\n106:         row[\"line\"] = line_number\n107:         rows.append(row)\n108: \n109:     if not saw_header:\n110:         errors.append(\"numeric-law table header missing\")\n111:     return rows, errors\n112: \n113: \n114: def _find_duplicates(rows: list[dict[str, Any]]) -> list[dict[str, Any]]:\n115:     values: dict[str, list[dict[str, str]]] = {}\n116: \n117:     for index, row in enumerate(rows, 1):\n118:         if _is_placeholder(row[\"value/range\"]):\n119:             continue\n120: \n121:         value = _normalized_value(row[\"value/range\"])\n122:         law_id = row[\"law_id\"] if not _is_placeholder(row[\"law_id\"]) else f\"row-{index}\"\n123:         owner = row[\"owner mode\"] if not _is_placeholder(row[\"owner mode\"]) else \"\"\n124:         values.setdefault(value, []).append({\"law_id\": law_id, \"owner\": owner})\n125: \n126:     duplicates: list[dict[str, Any]] = []\n127:     for value, grouped_rows in values.items():\n128:         if len(grouped_rows) < 2:\n129:             continue\n130: \n131:         duplicates.append(\n132:             {\n133:                 \"value\": value,\n134:                 \"law_ids\": [row[\"law_id\"] for row in grouped_rows],\n135:                 \"owners\": [row[\"owner\"] for row in grouped_rows],\n136:             }\n137:         )\n138: \n139:     return duplicates\n140: \n141: \n142: def check(text: str) -> dict[str, Any]:\n143:     rows, errors = _find_law_rows(text)\n144:     incomplete: list[dict[str, str]] = []\n145: \n146:     for index, row in enumerate(rows, 1):\n147:         law_id = row[\"law_id\"] if not _is_placeholder(row[\"law_id\"]) else f\"row-{index}\"\n148:         for column in REQUIRED_COLUMNS:\n149:             if _is_placeholder(row[column]):\n150:                 incomplete.append({\"law_id\": law_id, \"column\": column})\n151: \n152:     missing = []\n153:     if not rows:\n154:         missing.append(\"numeric-law rows missing\")\n155: \n156:     duplicates = _find_duplicates(rows)\n157:     ok = not errors and not missing and not incomplete and not duplicates\n158:     return {\n159:         \"rows\": len(rows),\n160:         \"errors\": errors,\n161:         \"missing\": missing,\n162:         \"incomplete\": incomplete,\n163:         \"duplicates\": duplicates,\n164:         \"ok\": ok,\n165:     }\n166: \n167: \n168: def main(argv: list[str]) -> int:\n169:     as_json = \"--json\" in argv\n170:     paths = [arg for arg in argv if arg != \"--json\"]\n171:     if len(paths) != 1:\n172:         sys.stderr.write(\"usage: numeric_law_check.py [--json] <numeric_design_laws.md>\\n\")\n173:         return 2\n174: \n175:     path = Path(paths[0])\n176:     try:\n177:         text = path.read_text(encoding=\"utf-8\")\n178:     except OSError as exc:\n179:         sys.stderr.write(f\"cannot read {path}: {exc}\\n\")\n180:         return 2\n181: \n182:     result = check(text)\n183:     if as_json:\n184:         print(json.dumps({\"file\": str(path), **result}, indent=2))\n185:     else:\n186:         print(f\"Numeric law completeness gate - {path}\")\n187:         print(f\"  rows: {result['rows']}\")\n188:         if result[\"ok\"]:\n189:             print(\"PASS - all numeric law rows are fully populated and unique.\")\n190:         else:\n191:             for error in result[\"errors\"]:\n192:                 print(f\"FAIL - {error}\")\n193:             for missing in result[\"missing\"]:\n194:                 print(f\"FAIL - {missing}\")\n195:             for item in result[\"incomplete\"]:\n196:                 print(f\"FAIL - {item['law_id']}: blank {item['column']}\")\n197:             for item in result[\"duplicates\"]:\n198:                 print(\n199:                     f\"FAIL - duplicate law value \\\"{item['value']}\\\" shared by \"\n200:                     f\"{', '.join(item['law_ids'])} \"\n201:                     f\"(owners: {', '.join(item['owners'])})\"\n202:                 )\n203: \n204:     return 0 if result[\"ok\"] else 1\n205: \n206: \n207: if __name__ == \"__main__\":\n208:     raise SystemExit(main(sys.argv[1:]))\n\n(End of file - total 208 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Deterministic completeness and uniqueness gate for the numeric design laws index.\n\nThe index is a reference surface, so the first failure mode is a row that looks\ncanonical while leaving a value, owner, source, or caveat blank. This checker\nparses the law table and exits non-zero unless every law row has all six\nrequired cells populated and no two rows register the same value.\n\nUsage:\n  numeric_law_check.py numeric_design_laws.md\n  numeric_law_check.py --json numeric_design_laws.md\n\nExit: 0 = rows present, complete, and unique; 1 = missing rows, incomplete\ncells, or duplicate values; 2 = usage or read error.\n\"\"\"\nimport json\nfrom pathlib import Path\nimport re\nimport sys\nfrom typing import Any","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/numeric_law_check.py","text":"#!/usr/bin/env python3\n\"\"\"Deterministic completeness and uniqueness gate for the numeric design laws index.\n\nThe index is a reference surface, so the first failure mode is a row that looks\ncanonical while leaving a value, owner, source, or caveat blank. This checker\nparses the law table and exits non-zero unless every law row has all six\nrequired cells populated and no two rows register the same value.\n\nUsage:\n  numeric_law_check.py numeric_design_laws.md\n  numeric_law_check.py --json numeric_design_laws.md\n\nExit: 0 = rows present, complete, and unique; 1 = missing rows, incomplete\ncells, or duplicate values; 2 = usage or read error.\n\"\"\"\nimport json\nfrom pathlib import Path\nimport re\nimport sys\nfrom typing import Any\n\nREQUIRED_COLUMNS = [\n    \"law_id\",\n    \"value/range\",\n    \"owner mode\",\n    \"enforcement target\",\n    \"source\",\n    \"caveat\",\n]\nLAW_TABLE_HEADING = re.compile(r\"^#{1,6}\\s+(?:\\d+\\.\\s+)?Law Index\\s*$\", re.I)\nMARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+\")\nPLACEHOLDER = re.compile(r\"^(?:_+|TBD|TODO|-)$\", re.I)\n\n\ndef _clean_cell(value: str) -> str:\n    value = value.strip()\n    if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n        value = value[1:-1].strip()\n    return value\n\n\ndef _split_table_row(line: str) -> list[str]:\n    line = line.strip()\n    if not line.startswith(\"|\") or not line.endswith(\"|\"):\n        return []\n    return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n\n\ndef _is_separator_row(cells: list[str]) -> bool:\n    return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n\n\ndef _is_placeholder(value: str) -> bool:\n    return not _clean_cell(value) or bool(PLACEHOLDER.fullmatch(_clean_cell(value)))\n\n\ndef _normalized_header(cells: list[str]) -> list[str]:\n    return [re.sub(r\"\\s+\", \" \", _clean_cell(cell).lower()) for cell in cells]\n\n\ndef _normalized_value(value: str) -> str:\n    return re.sub(r\"\\s+\", \" \", _clean_cell(value).lower()).strip()\n\n\ndef _find_law_table_start(lines: list[str]) -> int:\n    for index, line in enumerate(lines):\n        if LAW_TABLE_HEADING.match(line):\n            return index + 1\n    return 0\n\n\ndef _find_law_rows(text: str) -> tuple[list[dict[str, Any]], list[str]]:\n    lines = text.splitlines()\n    start = _find_law_table_start(lines)\n    rows: list[dict[str, Any]] = []\n    errors: list[str] = []\n    in_table = False\n    saw_header = False\n\n    for line_number, line in enumerate(lines[start:], start + 1):\n        cells = _split_table_row(line)\n        if not cells:\n            if in_table:\n                break\n            if MARKDOWN_HEADING.match(line) and start != 0:\n                break\n            continue\n\n        if len(cells) != len(REQUIRED_COLUMNS):\n            errors.append(f\"line {line_number}: expected 6 columns, found {len(cells)}\")\n            in_table = True\n            continue\n\n        normalized = _normalized_header(cells)\n        if normalized == REQUIRED_COLUMNS:\n            in_table = True\n            saw_header = True\n            continue\n        if _is_separator_row(cells):\n            in_table = True\n            continue\n        if not saw_header:\n            continue\n\n        row = dict(zip(REQUIRED_COLUMNS, [_clean_cell(cell) for cell in cells]))\n        row[\"line\"] = line_number\n        rows.append(row)\n\n    if not saw_header:\n        errors.append(\"numeric-law table header missing\")\n    return rows, errors\n\n\ndef _find_duplicates(rows: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    values: dict[str, list[dict[str, str]]] = {}\n\n    for index, row in enumerate(rows, 1):\n        if _is_placeholder(row[\"value/range\"]):\n            continue\n\n        value = _normalized_value(row[\"value/range\"])\n        law_id = row[\"law_id\"] if not _is_placeholder(row[\"law_id\"]) else f\"row-{index}\"\n        owner = row[\"owner mode\"] if not _is_placeholder(row[\"owner mode\"]) else \"\"\n        values.setdefault(value, []).append({\"law_id\": law_id, \"owner\": owner})\n\n    duplicates: list[dict[str, Any]] = []\n    for value, grouped_rows in values.items():\n        if len(grouped_rows) < 2:\n            continue\n\n        duplicates.append(\n            {\n                \"value\": value,\n                \"law_ids\": [row[\"law_id\"] for row in grouped_rows],\n                \"owners\": [row[\"owner\"] for row in grouped_rows],\n            }\n        )\n\n    return duplicates\n\n\ndef check(text: str) -> dict[str, Any]:\n    rows, errors = _find_law_rows(text)\n    incomplete: list[dict[str, str]] = []\n\n    for index, row in enumerate(rows, 1):\n        law_id = row[\"law_id\"] if not _is_placeholder(row[\"law_id\"]) else f\"row-{index}\"\n        for column in REQUIRED_COLUMNS:\n            if _is_placeholder(row[column]):\n                incomplete.append({\"law_id\": law_id, \"column\": column})\n\n    missing = []\n    if not rows:\n        missing.append(\"numeric-law rows missing\")\n\n    duplicates = _find_duplicates(rows)\n    ok = not errors and not missing and not incomplete and not duplicates\n    return {\n        \"rows\": len(rows),\n        \"errors\": errors,\n        \"missing\": missing,\n        \"incomplete\": incomplete,\n        \"duplicates\": duplicates,\n        \"ok\": ok,\n    }\n\n\ndef main(argv: list[str]) -> int:\n    as_json = \"--json\" in argv\n    paths = [arg for arg in argv if arg != \"--json\"]\n    if len(paths) != 1:\n        sys.stderr.write(\"usage: numeric_law_check.py [--json] <numeric_design_laws.md>\\n\")\n        return 2\n\n    path = Path(paths[0])\n    try:\n        text = path.read_text(encoding=\"utf-8\")\n    except OSError as exc:\n        sys.stderr.write(f\"cannot read {path}: {exc}\\n\")\n        return 2\n\n    result = check(text)\n    if as_json:\n        print(json.dumps({\"file\": str(path), **result}, indent=2))\n    else:\n        print(f\"Numeric law completeness gate - {path}\")\n        print(f\"  rows: {result['rows']}\")\n        if result[\"ok\"]:\n            print(\"PASS - all numeric law rows are fully populated and unique.\")\n        else:\n            for error in result[\"errors\"]:\n                print(f\"FAIL - {error}\")\n            for missing in result[\"missing\"]:\n                print(f\"FAIL - {missing}\")\n            for item in result[\"incomplete\"]:\n                print(f\"FAIL - {item['law_id']}: blank {item['column']}\")\n            for item in result[\"duplicates\"]:\n                print(\n                    f\"FAIL - duplicate law value \\\"{item['value']}\\\" shared by \"\n                    f\"{', '.join(item['law_ids'])} \"\n                    f\"(owners: {', '.join(item['owners'])})\"\n                )\n\n    return 0 if result[\"ok\"] else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main(sys.argv[1:]))","lineStart":1,"lineEnd":208,"totalLines":208,"truncated":false}},"title":".opencode/skills/sk-design/shared/scripts/numeric_law_check.py","time":{"start":1782750785861,"end":1782750785864}},"id":"prt_f143a3143001hhCFpndBuJzVlN","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f1439efbd001z90CKCW6FZQyLn"}}
