     \"source\": \"derived\"\n85:       },\n86:       {\n87:         \"name\": \"implementation-summary.md\",\n88:         \"kind\": \"doc\",\n89:         \"path\": \"implementation-summary.md\",\n90:         \"source\": \"derived\"\n91:       },\n92:       {\n93:         \"name\": \"tasks.md\",\n94:         \"kind\": \"doc\",\n95:         \"path\": \"tasks.md\",\n96:         \"source\": \"derived\"\n97:       },\n98:       {\n99:         \"name\": \"Feature Specification\",\n100:         \"kind\": \"proper_noun\",\n101:         \"path\": \"spec.md\",\n102:         \"source\": \"derived\"\n103:       },\n104:       {\n105:         \"name\": \"Parent Spec\",\n106:         \"kind\": \"proper_noun\",\n107:         \"path\": \"spec.md\",\n108:         \"source\": \"derived\"\n109:       },\n110:       {\n111:         \"name\": \"Handoff Criteria\",\n112:         \"kind\": \"proper_noun\",\n113:         \"path\": \"spec.md\",\n114:         \"source\": \"derived\"\n115:       },\n116:       {\n117:         \"name\": \"Phase Context This\",\n118:         \"kind\": \"proper_noun\",\n119:         \"path\": \"spec.md\",\n120:         \"source\": \"derived\"\n121:       },\n122:       {\n123:         \"name\": \"Scope Boundary\",\n124:         \"kind\": \"proper_noun\",\n125:         \"path\": \"spec.md\",\n126:         \"source\": \"derived\"\n127:       },\n128:       {\n129:         \"name\": \"Problem Statement After\",\n130:         \"kind\": \"proper_noun\",\n131:         \"path\": \"spec.md\",\n132:         \"source\": \"derived\"\n133:       },\n134:       {\n135:         \"name\": \"Implementation Plan\",\n136:         \"kind\": \"proper_noun\",\n137:         \"path\": \"plan.md\",\n138:         \"source\": \"derived\"\n139:       },\n140:       {\n141:         \"name\": \"Uses Node\",\n142:         \"kind\": \"proper_noun\",\n143:         \"path\": \"plan.md\",\n144:         \"source\": \"derived\"\n145:       },\n146:       {\n147:         \"name\": \"a\",\n148:         \"kind\": \"key_phrase\",\n149:         \"path\": \"plan.md\",\n150:         \"source\": \"derived\"\n151:       },\n152:       {\n153:         \"name\": \"injectable\",\n154:         \"kind\": \"key_phrase\",\n155:         \"path\": \"plan.md\",\n156:         \"source\": \"derived\"\n157:       },\n158:       {\n159:         \"name\": \"the\",\n160:         \"kind\": \"key_phrase\",\n161:         \"path\": \"plan.md\",\n162:         \"source\": \"derived\"\n163:       },\n164:       {\n165:         \"name\": \"adopt\",\n166:         \"kind\": \"key_phrase\",\n167:         \"path\": \"plan.md\",\n168:         \"source\": \"derived\"\n169:       },\n170:       {\n171:         \"name\": \"Task Format\",\n172:         \"kind\": \"proper_noun\",\n173:         \"path\": \"tasks.md\",\n174:         \"source\": \"derived\"\n175:       },\n176:       {\n177:         \"name\": \"Task Notation\",\n178:         \"kind\": \"proper_noun\",\n179:         \"path\": \"tasks.md\",\n180:         \"source\": \"derived\"\n181:       },\n182:       {\n183:         \"name\": \"Completion Criteria The\",\n184:         \"kind\": \"proper_noun\",\n185:         \"path\": \"tasks.md\",\n186:         \"source\": \"derived\"\n187:       },\n188:       {\n189:         \"name\": \"Implementation Summary\",\n190:         \"kind\": \"proper_noun\",\n191:         \"path\": \"implementation-summary.md\",\n192:         \"source\": \"derived\"\n193:       },\n194:       {\n195:         \"name\": \"Spec Folder\",\n196:         \"kind\": \"proper_noun\",\n197:         \"path\": \"implementation-summary.md\",\n198:         \"source\": \"derived\"\n199:       }\n200:     ],\n201:     \"causal_summary\": \"This phase is the direct follow-on to 018. Making the background scan cooperative kept the event loop responsive, but a full reindex still could not run to completion: the launcher kept recycling the daemon mid-scan. The root cause was traced to `mk-spec-memory-launcher.cjs` (~line 1680) and `lib/launcher-ipc-bridge.cjs`. When a second launcher appears (e.g. the editor's MCP reconnecting mid-scan), it tries to adopt the live daemon but requires a JSON-RPC liveness reply. A daemon busy in a scan cannot reply during a CPU block, so the probe deems it wedged, reaps and respawns it, and the new daemon's boot marks the running scan failed. The launcher could not distinguish \\\"busy with a known maintenance scan\\\" from \\\"wedged forever\\\". This was confirmed empirically: re-election fired even in a clean single-launcher state, because a concurrent MCP launcher contended.\",\n202:     \"created_at\": \"2026-06-17T12:47:01.644Z\",\n203:     \"last_save_at\": \"2026-06-17T12:47:01.644Z\",\n204:     \"save_lineage\": \"same_pass\",\n205:     \"last_accessed_at\": null,\n206:     \"source_docs\": [\n207:       \"spec.md\",\n208:       \"plan.md\",\n209:       \"tasks.md\",\n210:       \"implementation-summary.md\"\n211:     ],\n212:     \"last_active_child_id\": null,\n213:     \"last_active_at\": null\n214:   }\n215: }\n\n(End of file - total 215 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/019-maintenance-grace-daemon-survives-reelection\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/019-maintenance-grace-daemon-survives-reelection\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"maintenance grace daemon survives re-election\",\n      \"maintenance-active marker launcher adopt\",\n      \"reindex daemon reaped mid-scan re-election\",\n      \"027 002/019\",\n      \"maintenance grace daemon survives re-election plan\",\n      \"maintenance-active marker adopt 