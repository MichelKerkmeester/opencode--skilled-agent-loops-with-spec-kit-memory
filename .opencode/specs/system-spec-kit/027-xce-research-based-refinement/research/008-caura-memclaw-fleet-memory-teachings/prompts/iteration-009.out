{"type":"tool_use","timestamp":1780728429655,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_sxY2pxQBLJohQHgJ1NuYkvsg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/hooks.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/hooks.py</path>\n<type>file</type>\n<content>\n1: \"\"\"\n2: Service hooks — decouples core services from platform concerns.\n3: \n4: In business mode, hooks are wired at startup to audit logging and recall\n5: tracking. In OSS mode (hooks not configured), these operations are silently\n6: skipped, allowing the core engine to run standalone.\n7: \n8: Note: Trust enforcement (enforce_update) is access control and always runs\n9: directly — it is not a hook.\n10: \"\"\"\n11: \n12: from __future__ import annotations\n13: \n14: import logging\n15: from collections.abc import Awaitable, Callable\n16: from dataclasses import dataclass\n17: from typing import TYPE_CHECKING\n18: from uuid import UUID\n19: \n20: if TYPE_CHECKING:\n21:     from sqlalchemy.ext.asyncio import AsyncSession\n22: \n23: logger = logging.getLogger(__name__)\n24: \n25: # Type aliases for hook signatures\n26: AuditHook = Callable[..., Awaitable[None]]\n27: # Signature: (db, *, tenant_id, agent_id, action, resource_type, resource_id, detail) -> None\n28: \n29: RecallHook = Callable[[\"AsyncSession\", list[UUID]], Awaitable[None]]\n30: # Signature: (db, memory_ids) -> None\n31: \n32: \n33: @dataclass\n34: class ServiceHooks:\n35:     \"\"\"Optional hooks injected by the platform layer at startup.\n36: \n37:     When a hook is None, the corresponding operation is skipped.\n38:     This enables the core engine to run without audit or metering.\n39:     \"\"\"\n40: \n41:     audit_log: AuditHook | None = None\n42:     on_recall: RecallHook | None = None\n43: \n44: \n45: _hooks = ServiceHooks()\n46: \n47: \n48: def configure_hooks(hooks: ServiceHooks) -> None:\n49:     \"\"\"Wire platform hooks. Called once at app startup.\"\"\"\n50:     global _hooks\n51:     _hooks = hooks\n52:     logger.info(\n53:         \"Service hooks configured: audit=%s, recall=%s\",\n54:         hooks.audit_log is not None,\n55:         hooks.on_recall is not None,\n56:     )\n57: \n58: \n59: def get_hooks() -> ServiceHooks:\n60:     \"\"\"Get the current hooks instance.\"\"\"\n61:     return _hooks\n62: \n63: \n64: def reset_hooks() -> None:\n65:     \"\"\"Reset to no-op hooks. Used in tests and OSS mode.\"\"\"\n66:     global _hooks\n67:     _hooks = ServiceHooks()\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"\"\"\"\nService hooks — decouples core services from platform concerns.\n\nIn business mode, hooks are wired at startup to audit logging and recall\ntracking. In OSS mode (hooks not configured), these operations are silently\nskipped, allowing the core engine to run standalone.\n\nNote: Trust enforcement (enforce_update) is access control and always runs\ndirectly — it is not a hook.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections.abc import Awaitable, Callable\nfrom dataclasses import dataclass\nfrom typing import TYPE_CHECKING\nfrom uuid import UUID\n\nif TYPE_CHECKING:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/hooks.py","text":"\"\"\"\nService hooks — decouples core services from platform concerns.\n\nIn business mode, hooks are wired at startup to audit logging and recall\ntracking. In OSS mode (hooks not configured), these operations are silently\nskipped, allowing the core engine to run standalone.\n\nNote: Trust enforcement (enforce_update) is access control and always runs\ndirectly — it is not a hook.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections.abc import Awaitable, Callable\nfrom dataclasses import dataclass\nfrom typing import TYPE_CHECKING\nfrom uuid import UUID\n\nif TYPE_CHECKING:\n    from sqlalchemy.ext.asyncio import AsyncSession\n\nlogger = logging.getLogger(__name__)\n\n# Type aliases for hook signatures\nAuditHook = Callable[..., Awaitable[None]]\n# Signature: (db, *, tenant_id, agent_id, action, resource_type, resource_id, detail) -> None\n\nRecallHook = Callable[[\"AsyncSession\", list[UUID]], Awaitable[None]]\n# Signature: (db, memory_ids) -> None\n\n\n@dataclass\nclass ServiceHooks:\n    \"\"\"Optional hooks injected by the platform layer at startup.\n\n    When a hook is None, the corresponding operation is skipped.\n    This enables the core engine to run without audit or metering.\n    \"\"\"\n\n    audit_log: AuditHook | None = None\n    on_recall: RecallHook | None = None\n\n\n_hooks = ServiceHooks()\n\n\ndef configure_hooks(hooks: ServiceHooks) -> None:\n    \"\"\"Wire platform hooks. Called once at app startup.\"\"\"\n    global _hooks\n    _hooks = hooks\n    logger.info(\n        \"Service hooks configured: audit=%s, recall=%s\",\n        hooks.audit_log is not None,\n        hooks.on_recall is not None,\n    )\n\n\ndef get_hooks() -> ServiceHooks:\n    \"\"\"Get the current hooks instance.\"\"\"\n    return _hooks\n\n\ndef reset_hooks() -> None:\n    \"\"\"Reset to no-op hooks. Used in tests and OSS mode.\"\"\"\n    global _hooks\n    _hooks = ServiceHooks()","lineStart":1,"lineEnd":67,"totalLines":67,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/hooks.py","time":{"start":1780728429592,"end":1780728429652}},"metadata":{"openai":{"itemId":"fc_0afc2b9926a7c25e016a23c26d7db8819193934b28c84bb8aa"}},"id":"prt_e9baf7c17001wYTm6JH6FxdVG8","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baf5023001H4YMsIYdBK7d2F"}}
