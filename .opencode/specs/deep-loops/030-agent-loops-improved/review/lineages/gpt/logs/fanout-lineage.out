.iterations);\n638:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n639:   return {\n640:     ...guards,\n641:     iterations,\n642:     estimated_cost_units: iterations * guards.cost_units_per_iteration,\n643:   };\n644: }\n645: \n646: function evaluateLineageBudgetCap(input = {}) {\n647:   const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n648:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n649:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n650:   return {\n651:     continue_allowed: !exceeded,\n652:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n653:     upper_bound: upperBound,\n654:   };\n655: }\n656: \n657: function normalizeNonNegativeDelayMs(value) {\n658:   if (value === undefined || value === null) return null;\n659:   const n = Number(value);\n660:   if (!Number.isFinite(n) || n < 0) return null;\n661:   return Math.floor(n);\n662: }\n663: \n664: function normalizeWaitDurationMs(value) {\n665:   return normalizeNonNegativeDelayMs(value) ?? 0;\n666: }\n667: \n668: function waitCheckpointPath(baseArtifactDir) {\n669:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n670: }\n671: \n672: function atomicWriteJson(filePath, payload) {\n673:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n674:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n675:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n676:   fs.renameSync(tmpPath, filePath);\n677: }\n678: \n679: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n680:   const durationMs = normalizeWaitDurationMs(waitMs);\n681:   const updatedAt = new Date(nowMs).toISOString();\n682:   if (durationMs <= 0) {\n683:     return {\n684:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n685:       status: 'idle',\n686:       nextRunAt: null,\n687:       remainingDelayMs: null,\n688:       updatedAt,\n689:       runId,\n690:       loopType,\n691:       specFolder,\n692:     };\n693:   }\n694: \n695:   return {\n696:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n697:     status: 'waiting',\n698:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n699:     remainingDelayMs: durationMs,\n700:     updatedAt,\n701:     runId,\n702:     loopType,\n703:     specFolder,\n704:   };\n705: }\n706: \n707: function normalizeWaitCheckpoint(raw, context) {\n708:   if (!isRecord(raw)) {\n709:     throw inputError('wait checkpoint must be a JSON object');\n710:   }\n711: \n712:   const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n713:   const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n714:   const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n715:   const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n716:     ? raw.nextRunAt\n717:     : null;\n718:   const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n719:   const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n720:   const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n721:   const base = {\n722:     runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n723:     loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n724:     specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n725:   };\n726: \n727:   const checkpoint = waiting\n728:     ? {\n729:         schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n730:         status: 'waiting',\n731:         nextRunAt,\n732:         remainingDelayMs,\n733:         updatedAt: new Date(nowMs).toISOString(),\n734:         ...base,\n735:       }\n736:     : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n737:   const staleWaitingFields = !waiting\n738:     && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n739:   const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n740: \n741:   return {\n742:     checkpoint,\n743:     migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n744:   };\n745: }\n746: \n747: function readWaitCheckpoint(checkpointPath, context) {\n748:   if (!fs.existsSync(checkpointPath)) {\n749:     return { exists: false, checkpoint: null, migrated: false };\n750:   }\n751: \n752:   let raw;\n753:   try {\n754:     raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n755:   } catch (error) {\n756:     throw inputError(\n757:       `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n758:     );\n759:   }\n760: \n761:   const normalized = normalizeWaitCheckpoint(raw, context);\n762:   if (normalized.migrated) {\n763:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n764:   }\n765:   return { exists: true, ...normalized };\n766: }\n767: \n768: function sleepWaitChunk(ms) {\n769:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n770: }\n771: \n772: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n773:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n774:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n775: \n776:   while (remainingDelayMs > 0) {\n777:     atomicWriteJson(checkpointPath, {\n778:       ...checkpoint,\n779:       remainingDelayMs,\n780:       updatedAt: new Date().toISOString(),\n781:     });\n782:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n783:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n784:   }\n785: \n786:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n787: }\n788: \n789: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n790:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n791:   const loaded = readWaitCheckpoint(checkpointPath, context);\n792:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n793:     return { didWait: false, migrated: loaded.migrated };\n794:   }\n795: \n796:   appendFanoutStatusLedger(ledgerPath, {\n797:     event: 'resume_waiting',\n798:     at: new Date().toISOString(),\n799:     run_id: runId,\n800:     loop_type: loopType,\n801:     spec_folder: specFolder,\n802:     nextRunAt: loaded.checkpoint.nextRunAt,\n803:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n804:   });\n805: \n806:   await waitUntilCheckpointExpires({\n807:     checkpointPath,\n808:     checkpoint: loaded.checkpoint,\n809:     context: { runId, loopType, specFolder },\n810:   });\n811: \n812:   appendFanoutStatusLedger(ledgerPath, {\n813:     event: 'resume_waiting_complete',\n814:     at: new Date().toISOString(),\n815:     run_id: runId,\n816:     loop_type: loopType,\n817:     spec_folder: specFolder,\n818:   });\n819: \n820:   return { didWait: true, migrated: loaded.migrated };\n821: }\n822: \n823: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n824:   const durationMs = normalizeWaitDurationMs(waitMs);\n825:   if (durationMs <= 0) {\n826:     return { didWait: false };\n827:   }\n828: \n829:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n830:   atomicWriteJson(checkpointPath, checkpoint);\n831:   appendFanoutStatusLedger(ledgerPath, {\n832:     event: 'wait_checkpoint_persisted',\n833:     at: checkpoint.updatedAt,\n834:     run_id: runId,\n835:     loop_type: loopType,\n836:     spec_folder: specFolder,\n837:     nextRunAt: checkpoint.nextRunAt,\n838:     remainingDelayMs: checkpoint.remainingDelayMs,\n839:   });\n840: \n841:   await waitUntilCheckpointExpires({\n842:     checkpointPath,\n843:     checkpoint,\n844:     context: { runId, loopType, specFolder },\n845:   });\n846: \n847:   appendFanoutStatusLedger(ledgerPath, {\n848:     event: 'wait_checkpoint_cleared',\n849:     at: new Date().toISOString(),\n850:     run_id: runId,\n851:     loop_type: loopType,\n852:     spec_folder: specFolder,\n853:   });\n854: \n855:   return { didWait: true };\n856: }\n857: \n858: /**\n859:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n860:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n861:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n862:  */\n863: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n864:   const skillFile =\n865:     loopType === 'review'\n866:       ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n867:       : loopType === 'context'\n868:         ? '.opencode/skills/deep-loop-workflows/deep-context/SKILL.md'\n869:         : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n870:   const agentName = loopType === 'review' ? 'deep-review' : loopType === 'context' ? 'deep-context' : 'deep-research';\n871:   const detachedIntro = lineage.kind === 'cli-opencode'\n872:     ? [\n873:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n874:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n875:         ``,\n876:       ]\n877:     : lineage.kind === 'native'\n878:       ? [\n879:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n880:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n881:           ``,\n882:         ]\n883:       : [];\n884:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n885:   const stopPolicy = options.stopPolicy || 'convergence';\n886:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n887:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n888:     : hasIterationCap\n889:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n890:       : 'to legal convergence';\n891:   const params = [\n892:     `  spec_folder: ${specFolder}`,\n893:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n894:     `  session_id: ${sessionId}`,\n895:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n896:     `  loop_type: ${loopType}`,\n897:     `  config.stopPolicy: ${stopPolicy}`,\n898:   ];\n899:   if (researchTopic) {\n900:     // A research lineage's phase_init binds research_topic from this line. Without it a\n901:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n902:     // Review and context loops scope by spec_folder and intentionally pass no topic.\n903:     params.push(`  research_topic: ${researchTopic}`);\n904:   }\n905:   if (hasIterationCap) {\n906:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n907:   }\n908:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n909:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n910:   }\n911:   // Review/context lineages scope by spec_folder but the auto-workflow preflight\n912:   // still requires the same review setup bindings the native command path pre-binds.\n913:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n914:   // different setup contract than native lineages.\n915:   const setupBindings =\n916:     loopType === 'review' || loopType === 'context'\n917:       ? [\n918:           ``,\n919:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n920:           `review_target: ${specFolder}`,\n921:           `review_target_type: spec-folder`,\n922:           `review_dimensions: all`,\n923:           `spec_folder: ${specFolder}`,\n924:           `execution_mode: AUTONOMOUS`,\n925:           `lineage_mode: auto`,\n926:           ``,\n927:         ]\n928:       : [];\n929:   return [\n930:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n931:     ...detachedIntro,\n932:     ``,\n933:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n934:     ...params,\n935:     ...setupBindings,\n936:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n937:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n938:     `command; bind artifact_dir directly to the override value.`,\n939:     ``,\n940:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n941:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n942:     ``,\n943:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n944:   ].join('\\n');\n945: }\n946: \n947: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n948:   const maxIterations = lineage.iterations || 12;\n949:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n950:   const stopPolicy = options.stopPolicy || 'convergence';\n951:   const sessionId = options.sessionId || '';\n952:   const args = [\n953:     ':auto',\n954:     JSON.stringify(specFolder),\n955:     `--spec-folder=${specFolder}`,\n956:     `--max-iterations=${maxIterations}`,\n957:     `--convergence=${convergenceThreshold}`,\n958:     `--stop-policy=${stopPolicy}`,\n959:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n960:     '--lineage-mode=auto',\n961:   ];\n962:   if (loopType === 'research' && options.researchTopic) {\n963:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n964:   }\n965: \n966:   return [\n967:     args.join(' '),\n968:     '',\n969:     'PRE-BOUND SETUP ANSWERS:',\n970:     `review_target: ${specFolder}`,\n971:     'review_target_type: spec-folder',\n972:     'review_dimensions: all',\n973:     `spec_folder: ${specFolder}`,\n974:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n975:     'execution_mode: AUTONOMOUS',\n976:     'lineage_mode: auto',\n977:     `maxIterations: ${maxIterations}`,\n978:     `convergenceThreshold: ${convergenceThreshold}`,\n979:     `stop_policy: ${stopPolicy}`,\n980:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n981:   ].join('\\n');\n982: }\n983: \n984: /**\n985:  * Compute a generous timeout for a full lineage loop run.\n986:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n987:  * We double it for safety and cap at 4 hours.\n988:  */\n989: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n990:   const iters = lineage.iterations || 12;\n991:   const perIterSecs = lineage.timeoutSeconds || 900;\n992:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n993:     ? ceilingHoursOverride * 60 * 60 * 1000\n994:     : 4 * 60 * 60 * 1000;\n995:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n996: }\n997: \n998: function normalizeProgressHeartbeatMs(seconds) {\n999:   const value = Number(seconds);\n1000:   if (!Number.isFinite(value) || value <= 0) return 0;\n1001:   return Math.max(1, Math.floor(value * 1000));\n1002: }\n1003: \n1004: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1005:   const explicit = readRawConfigNumber(rawConfig, [\n1006:     'postExitGraceMs',\n1007:     'post_exit_grace_ms',\n1008:     'postSubprocessExitGraceMs',\n1009:     'post_subprocess_exit_grace_ms',\n1010:     'orchestratorPostExitGraceMs',\n1011:     'orchestrator_post_exit_grace_ms',\n1012:   ], 'postExitGraceMs');\n1013:   if (explicit !== null) return explicit;\n1014: \n1015:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1016:     ? progressHeartbeatMs * 2\n1017:     : 0;\n1018:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1019: }\n\n(Showing lines 600-1019 of 1747. Use offset=1020 to continue.)\n</content>","metadata":{"preview":"  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  return readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs') ?? 0;\n}\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  return readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs') ?? 0;\n}\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? 0,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  return {\n    ...guards,\n    iterations,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };\n}\n\nfunction normalizeWaitCheckpoint(raw, context) {\n  if (!isRecord(raw)) {\n    throw inputError('wait checkpoint must be a JSON object');\n  }\n\n  const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n  const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n  const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n  const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n    ? raw.nextRunAt\n    : null;\n  const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n  const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n  const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n  const base = {\n    runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n    loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n    specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n  };\n\n  const checkpoint = waiting\n    ? {\n        schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n        status: 'waiting',\n        nextRunAt,\n        remainingDelayMs,\n        updatedAt: new Date(nowMs).toISOString(),\n        ...base,\n      }\n    : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n  const staleWaitingFields = !waiting\n    && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n  const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n\n  return {\n    checkpoint,\n    migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n  };\n}\n\nfunction readWaitCheckpoint(checkpointPath, context) {\n  if (!fs.existsSync(checkpointPath)) {\n    return { exists: false, checkpoint: null, migrated: false };\n  }\n\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n  } catch (error) {\n    throw inputError(\n      `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n\n  const normalized = normalizeWaitCheckpoint(raw, context);\n  if (normalized.migrated) {\n    atomicWriteJson(checkpointPath, normalized.checkpoint);\n  }\n  return { exists: true, ...normalized };\n}\n\nfunction sleepWaitChunk(ms) {\n  return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n}\n\nasync function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n  const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n  let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n\n  while (remainingDelayMs > 0) {\n    atomicWriteJson(checkpointPath, {\n      ...checkpoint,\n      remainingDelayMs,\n      updatedAt: new Date().toISOString(),\n    });\n    await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n    remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n  }\n\n  atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n}\n\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : loopType === 'context'\n        ? '.opencode/skills/deep-loop-workflows/deep-context/SKILL.md'\n        : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : loopType === 'context' ? 'deep-context' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review and context loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review/context lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review' || loopType === 'context'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : 4 * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}","lineStart":600,"lineEnd":1019,"totalLines":1747,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1782998790464,"end":1782998790470}},"metadata":{"openai":{"itemId":"fc_09bc3f87ace35d68016a4667062ffc8194a8f9240262b754ff"}},"id":"prt_f230270fc001HqWjYaD3AjxDkF","sessionID":"ses_0dd080809ffeSxS04s909esZ2m","messageID":"msg_f23023e1e001KXK3j57r3KRWp0"}}
{"type":"tool_use","timestamp":1782998790499,"sessionID":"ses_0dd080809ffeSxS04s909esZ2m","part":{"type":"tool","tool":"read","callID":"call_jgRbRWyxAEdbzXz1twQGtIN9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":1020,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1020: \n1021: function slotDurationMsFromHrtime(hrStart) {\n1022:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1023:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1024: }\n1025: \n1026: function computeSkippedCount(slotDurationMs, intervalMs) {\n1027:   const elapsed = Number(slotDurationMs);\n1028:   const interval = Number(intervalMs);\n1029:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1030:     return 0;\n1031:   }\n1032:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1033: }\n1034: \n1035: function buildSlotAccounting(hrStart, intervalMs) {\n1036:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1037:   return {\n1038:     slotDurationMs,\n1039:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1040:   };\n1041: }\n1042: \n1043: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1044:   if (!event || typeof event.label !== 'string') return event;\n1045:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1046: \n1047:   const accounting = accountingByLabel.get(event.label);\n1048:   if (!accounting) return event;\n1049:   return {\n1050:     ...event,\n1051:     skippedCount: accounting.skippedCount,\n1052:     slotDurationMs: accounting.slotDurationMs,\n1053:   };\n1054: }\n1055: \n1056: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1057:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1058:     return () => {};\n1059:   }\n1060:   const startedAtMs = Date.now();\n1061:   const timer = setInterval(() => {\n1062:     appendFanoutStatusLedger(ledgerPath, {\n1063:       event: 'progress',\n1064:       label,\n1065:       at: new Date().toISOString(),\n1066:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1067:         gauges: getGauges(),\n1068:       });\n1069:       if (typeof onProgress === 'function') onProgress();\n1070:     }, cadenceMs);\n1071:   timer.unref?.();\n1072:   return () => clearInterval(timer);\n1073: }\n1074: \n1075: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1076:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1077:     return () => {};\n1078:   }\n1079: \n1080:   let timer = null;\n1081:   let fired = false;\n1082:   const schedule = () => {\n1083:     if (fired) return;\n1084:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1085:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1086:     timer = setTimeout(() => {\n1087:       timer = null;\n1088:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1089:       if (latestQuietMs >= thresholdMs) {\n1090:         fired = true;\n1091:         appendFanoutStatusLedger(ledgerPath, {\n1092:           event: 'stall_detected',\n1093:           label,\n1094:           at: new Date().toISOString(),\n1095:           severity: 'warning',\n1096:           metric: 'time_since_last_lineage_event',\n1097:           stall_watchdog_ms: thresholdMs,\n1098:           quiet_ms: Math.floor(latestQuietMs),\n1099:           gauges: getGauges(),\n1100:         });\n1101:         return;\n1102:       }\n1103:       schedule();\n1104:     }, delayMs);\n1105:     timer.unref?.();\n1106:   };\n1107: \n1108:   schedule();\n1109:   return () => {\n1110:     fired = true;\n1111:     if (timer) clearTimeout(timer);\n1112:   };\n1113: }\n1114: \n1115: /**\n1116:  * Run a lineage subprocess without blocking the Node event loop.\n1117:  *\n1118:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1119:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1120:  * thread until each child exited, serializing every lineage regardless of the\n1121:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1122:  *\n1123:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1124:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1125:  *\n1126:  * @param {string} command - Executable to run.\n1127:  * @param {string[]} cmdArgs - Arguments for the executable.\n1128:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1129:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1130:  */\n1131: function runLineageProcess(command, cmdArgs, opts) {\n1132:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1133:   const hasInput = typeof opts.input === 'string';\n1134: \n1135:   return new Promise((resolvePromise) => {\n1136:     let child;\n1137:     try {\n1138:       child = spawn(command, cmdArgs, {\n1139:         cwd,\n1140:         env,\n1141:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1142:         detached: process.platform !== 'win32',\n1143:       });\n1144:     } catch (error) {\n1145:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1146:       return;\n1147:     }\n1148:     activeLineageProcesses.add(child);\n1149:     if (typeof opts.onSpawn === 'function') {\n1150:       opts.onSpawn({ pid: child.pid });\n1151:     }\n1152: \n1153:     let stdout = '';\n1154:     let stdoutBytes = 0;\n1155:     let truncated = false;\n1156:     let timedOut = false;\n1157:     let settled = false;\n1158:     let spawnError;\n1159: \n1160:     const timer = setTimeout(() => {\n1161:       timedOut = true;\n1162:       terminateLineageProcess(child, 'SIGTERM');\n1163:     }, timeoutMs);\n1164:     timer.unref?.();\n1165: \n1166:     const abortHandler = () => {\n1167:       terminateLineageProcess(child, 'SIGTERM');\n1168:     };\n1169:     if (opts.abortSignal) {\n1170:       if (opts.abortSignal.aborted) {\n1171:         abortHandler();\n1172:       } else {\n1173:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1174:       }\n1175:     }\n1176: \n1177:     child.stdout?.setEncoding('utf8');\n1178:     child.stdout?.on('data', (chunk) => {\n1179:       if (truncated) return;\n1180:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1181:       if (stdoutBytes > maxBuffer) {\n1182:         truncated = true;\n1183:         terminateLineageProcess(child, 'SIGTERM');\n1184:         return;\n1185:       }\n1186:       stdout += chunk;\n1187:     });\n1188:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1189:     child.stderr?.resume();\n1190: \n1191:     child.on('error', (error) => {\n1192:       spawnError = error;\n1193:     });\n1194: \n1195:     child.on('close', (code, signal) => {\n1196:       if (settled) return;\n1197:       settled = true;\n1198:       activeLineageProcesses.delete(child);\n1199:       clearTimeout(timer);\n1200:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1201:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1202:       if (typeof opts.onExit === 'function') {\n1203:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1204:       }\n1205:       resolvePromise({\n1206:         status: timedOut ? null : code,\n1207:         signal: effectiveSignal,\n1208:         stdout,\n1209:         ...(spawnError ? { error: spawnError } : {}),\n1210:       });\n1211:     });\n1212: \n1213:     if (hasInput) {\n1214:       child.stdin?.on('error', () => {});\n1215:       child.stdin?.end(opts.input);\n1216:     }\n1217:   });\n1218: }\n1219: \n1220: /**\n1221:  * Build the subprocess command for a fan-out lineage.\n1222:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1223:  */\n1224: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1225:   const kind = lineage.kind;\n1226: \n1227:   if (kind === 'cli-claude-code') {\n1228:     const args = [\n1229:       '-p',\n1230:       prompt,\n1231:       '--model',\n1232:       lineage.model || 'claude-opus-4-8',\n1233:       '--permission-mode',\n1234:       resolvedPermission,\n1235:       '--output-format',\n1236:       'text',\n1237:     ];\n1238:     if (lineage.reasoningEffort) {\n1239:       args.push('--effort', lineage.reasoningEffort);\n1240:     }\n1241:     return { command: 'claude', args };\n1242:   }\n1243: \n1244:   if (kind === 'native') {\n1245:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1246:     // For review runs this is the real deep/review command surface with a lineage\n1247:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1248:     const args = [\n1249:       'run',\n1250:       '--format',\n1251:       'json',\n1252:       '--dangerously-skip-permissions',\n1253:       '--dir',\n1254:       process.cwd(),\n1255:       '--command',\n1256:       `deep/${options.loopType || 'review'}`,\n1257:     ];\n1258:     args.push(buildNativeCommandInput(\n1259:       options.loopType || 'review',\n1260:       options.specFolder || '',\n1261:       options.lineageDir || '',\n1262:       lineage,\n1263:       options,\n1264:     ));\n1265:     return { command: 'opencode', args, input: '' };\n1266:   }\n1267: \n1268:   if (kind === 'cli-opencode') {\n1269:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1270:     // on a top-level `run`. The default agent runs when none is named, and a\n1271:     // specific agent profile can be requested in the prompt body instead.\n1272:     const args = [\n1273:       'run',\n1274:       '--model',\n1275:       lineage.model || 'anthropic/claude-opus-4-8',\n1276:       '--format',\n1277:       'json',\n1278:       '--pure',\n1279:       '--dir',\n1280:       process.cwd(),\n1281:     ];\n1282:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1283:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1284:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1285:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1286:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n1287:     // must now opt into full bypass rather than getting it silently by default.\n1288:     const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n1289:     if (useDangerousBypass) {\n1290:       args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n1291:       process.stderr.write(\n1292:         `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n1293:           + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n1294:       );\n1295:     }\n1296:     if (lineage.reasoningEffort) {\n1297:       args.push('--variant', lineage.reasoningEffort);\n1298:     }\n1299:     args.push(prompt);\n1300:     return { command: 'opencode', args, input: '' };\n1301:   }\n1302: \n1303:   throw inputError(`Unknown fan-out executor kind: ${kind}`);\n1304: }\n1305: \n1306: // ─────────────────────────────────────────────────────────────────────────────\n1307: // 4. CORE LOGIC\n1308: // ─────────────────────────────────────────────────────────────────────────────\n1309: \n1310: async function main() {\n1311:   const args = parseArgs();\n1312:   const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n1313:   const loopType = ensureString(args, 'loopType');\n1314:   if (loopType !== 'research' && loopType !== 'review' && loopType !== 'context') {\n1315:     throw inputError('loopType must be \"research\", \"review\", or \"context\"');\n1316:   }\n1317:   // Optional shared research question, threaded into each lineage prompt so a research\n1318:   // fan-out can bind research_topic. Absent for review/context, which scope by folder.\n1319:   const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n1320:     ? args.researchTopic.trim()\n1321:     : null;\n1322:   const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n1323:   const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n1324:   const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n1325:   const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n1326:   const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n1327: \n1328:   const {\n1329:     parseFanoutConfig,\n1330:     expandLineages,\n1331:     resolveSandboxMode,\n1332:     resolveClaudePermissionMode,\n1333:   } = await import('../lib/deep-loop/executor-config.ts');\n1334:   const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n1335: \n1336:   maybeThrowTestFault();\n1337: \n1338:   let rawConfig;\n1339:   try {\n1340:     rawConfig = JSON.parse(fanoutConfigJson);\n1341:   } catch {\n1342:     throw inputError('fanoutConfigJson is not valid JSON');\n1343:   }\n1344: \n1345:   const lineagesDir = path.join(baseArtifactDir, 'lineages');\n1346:   const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n1347:   const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n1348:   const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n1349:   const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n1350:   const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n1351:   const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n1352:   const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n1353:   const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n1354:   const fanoutConfig = guardedAssignment.config;\n1355:   const allLineages = expandLineages(fanoutConfig);\n1356:   const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n1357:   const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n1358:   const slotIntervalMs = progressHeartbeatMs;\n1359: \n1360:   logFlatPoolGuardRejections({\n1361:     rejections: guardedAssignment.rejections,\n1362:     ledgerPath,\n1363:     runId,\n1364:     loopType,\n1365:     specFolder,\n1366:   });\n1367: \n1368:   // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n1369:   // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n1370:   // ownership here so all lineages share the same retries and artifact validation.\n1371:   const cliLineages = allLineages;\n1372:   const checkpointPath = waitCheckpointPath(baseArtifactDir);\n1373:   const resumeWaiting = await resumeWaitingCheckpoint({\n1374:     checkpointPath,\n1375:     ledgerPath,\n1376:     runId,\n1377:     loopType,\n1378:     specFolder,\n1379:   });\n\n(Showing lines 1020-1379 of 1747. Use offset=1380 to continue.)\n</content>","metadata":{"preview":"\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n    // --dangerously-skip-permissions so their writes are subject to the CLI permission\n    // boundary. opencode has no path-scoped write flag, so a workspace-write review\n    // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n    // must now opt into full bypass rather than getting it silently by default.\n    const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n    if (useDangerousBypass) {\n      args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n      process.stderr.write(\n        `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n          + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n      );\n    }\n    if (lineage.reasoningEffort) {\n      args.push('--variant', lineage.reasoningEffort);\n    }\n    args.push(prompt);\n    return { command: 'opencode', args, input: '' };\n  }\n\n  throw inputError(`Unknown fan-out executor kind: ${kind}`);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const args = parseArgs();\n  const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n  const loopType = ensureString(args, 'loopType');\n  if (loopType !== 'research' && loopType !== 'review' && loopType !== 'context') {\n    throw inputError('loopType must be \"research\", \"review\", or \"context\"');\n  }\n  // Optional shared research question, threaded into each lineage prompt so a research\n  // fan-out can bind research_topic. Absent for review/context, which scope by folder.\n  const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n    ? args.researchTopic.trim()\n    : null;\n  const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n  const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n  const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n  const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n  const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n\n  const {\n    parseFanoutConfig,\n    expandLineages,\n    resolveSandboxMode,\n    resolveClaudePermissionMode,\n  } = await import('../lib/deep-loop/executor-config.ts');\n  const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n\n  maybeThrowTestFault();\n\n  let rawConfig;\n  try {\n    rawConfig = JSON.parse(fanoutConfigJson);\n  } catch {\n    throw inputError('fanoutConfigJson is not valid JSON');\n  }\n\n  const lineagesDir = path.join(baseArtifactDir, 'lineages');\n  const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n  const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n  const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n  const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n  const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n  const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n  const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n  const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n  const fanoutConfig = guardedAssignment.config;\n  const allLineages = expandLineages(fanoutConfig);\n  const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n  const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n  const slotIntervalMs = progressHeartbeatMs;\n\n  logFlatPoolGuardRejections({\n    rejections: guardedAssignment.rejections,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n\n  // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n  // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n  // ownership here so all lineages share the same retries and artifact validation.\n  const cliLineages = allLineages;\n  const checkpointPath = waitCheckpointPath(baseArtifactDir);\n  const resumeWaiting = await resumeWaitingCheckpoint({\n    checkpointPath,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });","lineStart":1020,"lineEnd":1379,"totalLines":1747,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1782998790492,"end":1782998790497}},"metadata":{"openai":{"itemId":"fc_09bc3f87ace35d68016a466706300481948f09331ac21709f3"}},"id":"prt_f23027141001Hidx6Jt52gib1q","sessionID":"ses_0dd080809ffeSxS04s909esZ2m","messageID":"msg_f23023e1e001KXK3j57r3KRWp0"}}
{"type":"tool_use","timestamp":1782998790579,"sessionID":"ses_0dd080809ffeSxS04s909esZ2m","part":{"type":"tool","tool":"read","callID":"call_Pl10NGRlbJZTdIJZLL467k8t","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Convergence Entrypoint                               ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Input:  CLI args (--spec-folder, --loop-type, --session-id, optional     ║\n7: // ║         --iteration, --persist-snapshot).                                ║\n8: // ║ Output: JSON to stdout.                                                  ║\n9: // ║ Exit:   0=ok, 1=script error, 2=DB error, 3=input validation error.     ║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: \n12: 'use strict';\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 1. IMPORTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: const fs = require('node:fs');\n19: const path = require('node:path');\n20: const { spawnSync } = require('node:child_process');\n21: \n22: const {\n23:   acquireWriterLock,\n24:   classifyExitCode,\n25:   installSignalHandlers,\n26:   maybeThrowTestFault,\n27:   validateNamespaceValue,\n28: } = require('./lib/cli-guards.cjs');\n29: \n30: const {\n31:   appendObservabilityEvent,\n32: } = require('../lib/deep-loop/observability-events.cjs');\n33: \n34: // ─────────────────────────────────────────────────────────────────────────────\n35: // 2. CONSTANTS\n36: // ─────────────────────────────────────────────────────────────────────────────\n37: \n38: const TSX_LOADER = require.resolve('tsx');\n39: const DEFAULT_REPORTED_NOVELTY_THRESHOLD = 0.05;\n40: const DEFAULT_GRAPH_NOVELTY_FLOOR = 0.05;\n41: const DEFAULT_MIN_OBSERVATIONS = 2;\n42: const MIN_OBSERVATIONS_FLOOR = 1;\n43: const MIN_OBSERVATIONS_CEILING = 10;\n44: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n45: \n46: /**\n47:  * Shared convergence profile schema:\n48:  * - threshold: numeric boundary a metric is compared against before STOP can be allowed.\n49:  * - weight: contribution a metric makes to a loop-local composite score; use 0 for pure guards.\n50:  * - role: whether a metric is a weighted score input, a blocking guard, or both.\n51:  * - direction: passing comparison for the metric (`gte`, `lte`, or `eq`).\n52:  * - normalizer: named loop-local transform that converts raw observations into comparable metric values.\n53:  *\n54:  * The shared shape keeps metric contracts explicit while each loop preserves its\n55:  * own semantics; convergence does not collapse into one universal formula.\n56:  */\n57: /**\n58:  * @typedef {'weighted' | 'blocking_guard' | 'weighted_guard'} ConvergenceProfileRole\n59:  * @typedef {'gte' | 'lte' | 'eq'} ConvergenceProfileDirection\n60:  * @typedef {'identity' | 'clamp01' | 'inverseClamp01' | 'capRatio' | 'presence'} ConvergenceProfileNormalizer\n61:  * @typedef {Object} ConvergenceProfileSchema\n62:  * @property {'number'} threshold\n63:  * @property {'number'} weight\n64:  * @property {ReadonlyArray<ConvergenceProfileRole>} role\n65:  * @property {ReadonlyArray<ConvergenceProfileDirection>} direction\n66:  * @property {ReadonlyArray<ConvergenceProfileNormalizer>} normalizer\n67:  */\n68: /** @type {Readonly<ConvergenceProfileSchema>} */\n69: const CONVERGENCE_PROFILE_SCHEMA = Object.freeze({\n70:   threshold: 'number',\n71:   weight: 'number',\n72:   role: Object.freeze(['weighted', 'blocking_guard', 'weighted_guard']),\n73:   direction: Object.freeze(['gte', 'lte', 'eq']),\n74:   normalizer: Object.freeze(['identity', 'clamp01', 'inverseClamp01', 'capRatio', 'presence']),\n75: });\n76: \n77: // ─────────────────────────────────────────────────────────────────────────────\n78: // 3. TSX BOOTSTRAP\n79: // ─────────────────────────────────────────────────────────────────────────────\n80: \n81: if (require.main === module && process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n82:   const child = spawnSync(\n83:     process.execPath,\n84:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n85:     {\n86:       cwd: process.cwd(),\n87:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n88:       input: process.stdin.isTTY ? undefined : fs.readFileSync(0),\n89:       encoding: 'utf8',\n90:     },\n91:   );\n92:   if (child.stdout) process.stdout.write(child.stdout);\n93:   if (child.stderr) process.stderr.write(child.stderr);\n94:   process.exit(child.status === null ? 1 : child.status);\n95: }\n96: \n97: // ─────────────────────────────────────────────────────────────────────────────\n98: // 4. HELPERS\n99: // ─────────────────────────────────────────────────────────────────────────────\n100: \n101: function parseArgs(argv = process.argv.slice(2)) {\n102:   const args = {};\n103:   for (let i = 0; i < argv.length; i += 1) {\n104:     const token = argv[i];\n105:     if (!token.startsWith('--')) {\n106:       throw inputError(`Unexpected positional argument: ${token}`);\n107:     }\n108:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n109:     const next = argv[i + 1];\n110:     if (next === undefined || next.startsWith('--')) {\n111:       args[key] = true;\n112:     } else {\n113:       args[key] = next;\n114:       i += 1;\n115:     }\n116:   }\n117:   return args;\n118: }\n119: \n120: function inputError(message) {\n121:   const err = new Error(message);\n122:   err.code = 'INPUT_VALIDATION';\n123:   return err;\n124: }\n125: \n126: function ensureString(args, key) {\n127:   if (!args[key] || typeof args[key] !== 'string') {\n128:     throw inputError(`${key} is required`);\n129:   }\n130:   return args[key];\n131: }\n132: \n133: function asBoolean(value) {\n134:   return value === true || value === 'true' || value === '1';\n135: }\n136: \n137: function parseOptionalJsonObject(value, key) {\n138:   if (value === undefined || value === null || value === true || value === '') return {};\n139:   if (typeof value !== 'string') throw inputError(`${key} must be a JSON object`);\n140:   let parsed;\n141:   try {\n142:     parsed = JSON.parse(value);\n143:   } catch {\n144:     throw inputError(`${key} must be valid JSON`);\n145:   }\n146:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n147:     throw inputError(`${key} must be a JSON object`);\n148:   }\n149:   return parsed;\n150: }\n151: \n152: function parseOptionalRatio(value, key) {\n153:   if (value === undefined || value === null || value === true || value === '') return null;\n154:   const parsed = Number(value);\n155:   if (!Number.isFinite(parsed) || parsed < 0 || parsed > 1) {\n156:     throw inputError(`${key} must be a number between 0 and 1`);\n157:   }\n158:   return parsed;\n159: }\n160: \n161: function parseRatioWithDefault(value, key, fallback) {\n162:   const parsed = parseOptionalRatio(value, key);\n163:   return parsed === null ? fallback : parsed;\n164: }\n165: \n166: function parseMinObservationsValue(value, key = 'minObservations') {\n167:   if (value === undefined || value === null || value === true || value === '') return DEFAULT_MIN_OBSERVATIONS;\n168:   const parsed = Number(value);\n169:   if (!Number.isFinite(parsed)) {\n170:     throw inputError(`${key} must be a finite number`);\n171:   }\n172:   return Math.max(MIN_OBSERVATIONS_FLOOR, Math.min(MIN_OBSERVATIONS_CEILING, Math.trunc(parsed)));\n173: }\n174: \n175: function resolveMinObservationsInput(args) {\n176:   if (args.minObservations !== undefined) return { value: args.minObservations, key: 'minObservations' };\n177:   if (args.min_observations !== undefined) return { value: args.min_observations, key: 'min_observations' };\n178: \n179:   const config = parseOptionalJsonObject(args.configJson, 'configJson');\n180:   if (config.min_observations !== undefined) return { value: config.min_observations, key: 'min_observations' };\n181:   if (config.minObservations !== undefined) return { value: config.minObservations, key: 'minObservations' };\n182:   if (process.env.DEEP_LOOP_MIN_OBSERVATIONS !== undefined) {\n183:     return { value: process.env.DEEP_LOOP_MIN_OBSERVATIONS, key: 'DEEP_LOOP_MIN_OBSERVATIONS' };\n184:   }\n185:   return null;\n186: }\n187: \n188: function readObservationThresholdConfig(args) {\n189:   const input = resolveMinObservationsInput(args);\n190:   const enabledByFlag =\n191:     asBoolean(args.observationThresholdGuard) ||\n192:     asBoolean(args.minObservationsGuard) ||\n193:     asBoolean(process.env.DEEP_LOOP_MIN_OBSERVATIONS_GUARD);\n194: \n195:   if (!input && !enabledByFlag) {\n196:     return { enabled: false, minObservations: 1 };\n197:   }\n198: \n199:   return {\n200:     enabled: true,\n201:     minObservations: parseMinObservationsValue(input?.value, input?.key),\n202:   };\n203: }\n204: \n205: function jsonOut(payload) {\n206:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n207: }\n208: \n209: function observabilityPathForDb(dbModule) {\n210:   const dbDir = dbModule?.COVERAGE_GRAPH_DATABASE_DIR ?? dbModule?.COUNCIL_GRAPH_STORAGE_DIR;\n211:   return typeof dbDir === 'string' && dbDir.trim() !== ''\n212:     ? path.join(dbDir, OBSERVABILITY_EVENTS_FILENAME)\n213:     : null;\n214: }\n215: \n216: function appendConvergenceObservabilityEvent(dbModule, payload, ns) {\n217:   const eventPath = observabilityPathForDb(dbModule);\n218:   if (!eventPath) return;\n219:   try {\n220:     appendObservabilityEvent(eventPath, payload, {\n221:       producer: 'convergence',\n222:       stream: 'graph-convergence',\n223:       subject: ns,\n224:       event: 'convergence_evaluated',\n225:       status: payload.graph_decision ?? payload.status,\n226:     });\n227:   } catch {\n228:     // Convergence stdout and snapshot persistence remain authoritative.\n229:   }\n230: }\n231: \n232: function blockersCsv(blockers) {\n233:   return blockers\n234:     .filter((blocker) => blocker && blocker.severity === 'blocking')\n235:     .map((blocker) => `${blocker.type}:${blocker.count}`)\n236:     .join(',');\n237: }\n238: \n239: function computeCompositeScore(signals, loopType) {\n240:   if (!signals || typeof signals !== 'object') return 0;\n241:   const clamp = (value) => Math.max(0, Math.min(1, value));\n242:   const safe = (value) => (typeof value === 'number' && Number.isFinite(value) ? value : 0);\n243:   if (loopType === 'research') {\n244:     const normalizedDiversity = Math.min(safe(signals.sourceDiversity) / 3.0, 1.0);\n245:     const normalizedDepth = Math.min(safe(signals.evidenceDepth) / 5.0, 1.0);\n246:     const invertedContradictions = 1.0 - clamp(safe(signals.contradictionDensity));\n247:     const score =\n248:       clamp(safe(signals.questionCoverage)) * 0.30 +\n249:       clamp(safe(signals.claimVerificationRate)) * 0.25 +\n250:       invertedContradictions * 0.15 +\n251:       normalizedDiversity * 0.15 +\n252:       normalizedDepth * 0.15;\n253:     return Math.round(clamp(score) * 1000) / 1000;\n254:   }\n255:   if (loopType === 'context') {\n256:     // REUSE catalog weighted highest (reuse-first principle); agreement second\n257:     // (by-model confidence); then scope coverage, relevance gate, dependency map.\n258:     const score =\n259:       clamp(safe(signals.reuseCatalogCoverage)) * 0.30 +\n260:       clamp(safe(signals.agreementRate)) * 0.25 +\n\n(Showing lines 1-260 of 797. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Convergence Entrypoint                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --session-id, optional     ║\n// ║         --iteration, --persist-snapshot).                                ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=ok, 1=script error, 2=DB error, 3=input validation error.     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/convergence.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Convergence Entrypoint                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --session-id, optional     ║\n// ║         --iteration, --persist-snapshot).                                ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=ok, 1=script error, 2=DB error, 3=input validation error.     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');\n\nconst {\n  acquireWriterLock,\n  classifyExitCode,\n  installSignalHandlers,\n  maybeThrowTestFault,\n  validateNamespaceValue,\n} = require('./lib/cli-guards.cjs');\n\nconst {\n  appendObservabilityEvent,\n} = require('../lib/deep-loop/observability-events.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\nconst DEFAULT_REPORTED_NOVELTY_THRESHOLD = 0.05;\nconst DEFAULT_GRAPH_NOVELTY_FLOOR = 0.05;\nconst DEFAULT_MIN_OBSERVATIONS = 2;\nconst MIN_OBSERVATIONS_FLOOR = 1;\nconst MIN_OBSERVATIONS_CEILING = 10;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n\n/**\n * Shared convergence profile schema:\n * - threshold: numeric boundary a metric is compared against before STOP can be allowed.\n * - weight: contribution a metric makes to a loop-local composite score; use 0 for pure guards.\n * - role: whether a metric is a weighted score input, a blocking guard, or both.\n * - direction: passing comparison for the metric (`gte`, `lte`, or `eq`).\n * - normalizer: named loop-local transform that converts raw observations into comparable metric values.\n *\n * The shared shape keeps metric contracts explicit while each loop preserves its\n * own semantics; convergence does not collapse into one universal formula.\n */\n/**\n * @typedef {'weighted' | 'blocking_guard' | 'weighted_guard'} ConvergenceProfileRole\n * @typedef {'gte' | 'lte' | 'eq'} ConvergenceProfileDirection\n * @typedef {'identity' | 'clamp01' | 'inverseClamp01' | 'capRatio' | 'presence'} ConvergenceProfileNormalizer\n * @typedef {Object} ConvergenceProfileSchema\n * @property {'number'} threshold\n * @property {'number'} weight\n * @property {ReadonlyArray<ConvergenceProfileRole>} role\n * @property {ReadonlyArray<ConvergenceProfileDirection>} direction\n * @property {ReadonlyArray<ConvergenceProfileNormalizer>} normalizer\n */\n/** @type {Readonly<ConvergenceProfileSchema>} */\nconst CONVERGENCE_PROFILE_SCHEMA = Object.freeze({\n  threshold: 'number',\n  weight: 'number',\n  role: Object.freeze(['weighted', 'blocking_guard', 'weighted_guard']),\n  direction: Object.freeze(['gte', 'lte', 'eq']),\n  normalizer: Object.freeze(['identity', 'clamp01', 'inverseClamp01', 'capRatio', 'presence']),\n});\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module && process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  const child = spawnSync(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      input: process.stdin.isTTY ? undefined : fs.readFileSync(0),\n      encoding: 'utf8',\n    },\n  );\n  if (child.stdout) process.stdout.write(child.stdout);\n  if (child.stderr) process.stderr.write(child.stderr);\n  process.exit(child.status === null ? 1 : child.status);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction asBoolean(value) {\n  return value === true || value === 'true' || value === '1';\n}\n\nfunction parseOptionalJsonObject(value, key) {\n  if (value === undefined || value === null || value === true || value === '') return {};\n  if (typeof value !== 'string') throw inputError(`${key} must be a JSON object`);\n  let parsed;\n  try {\n    parsed = JSON.parse(value);\n  } catch {\n    throw inputError(`${key} must be valid JSON`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw inputError(`${key} must be a JSON object`);\n  }\n  return parsed;\n}\n\nfunction parseOptionalRatio(value, key) {\n  if (value === undefined || value === null || value === true || value === '') return null;\n  const parsed = Number(value);\n  if (!Number.isFinite(parsed) || parsed < 0 || parsed > 1) {\n    throw inputError(`${key} must be a number between 0 and 1`);\n  }\n  return parsed;\n}\n\nfunction parseRatioWithDefault(value, key, fallback) {\n  const parsed = parseOptionalRatio(value, key);\n  return parsed === null ? fallback : parsed;\n}\n\nfunction parseMinObservationsValue(value, key = 'minObservations') {\n  if (value === undefined || value === null || value === true || value === '') return DEFAULT_MIN_OBSERVATIONS;\n  const parsed = Number(value);\n  if (!Number.isFinite(parsed)) {\n    throw inputError(`${key} must be a finite number`);\n  }\n  return Math.max(MIN_OBSERVATIONS_FLOOR, Math.min(MIN_OBSERVATIONS_CEILING, Math.trunc(parsed)));\n}\n\nfunction resolveMinObservationsInput(args) {\n  if (args.minObservations !== undefined) return { value: args.minObservations, key: 'minObservations' };\n  if (args.min_observations !== undefined) return { value: args.min_observations, key: 'min_observations' };\n\n  const config = parseOptionalJsonObject(args.configJson, 'configJson');\n  if (config.min_observations !== undefined) return { value: config.min_observations, key: 'min_observations' };\n  if (config.minObservations !== undefined) return { value: config.minObservations, key: 'minObservations' };\n  if (process.env.DEEP_LOOP_MIN_OBSERVATIONS !== undefined) {\n    return { value: process.env.DEEP_LOOP_MIN_OBSERVATIONS, key: 'DEEP_LOOP_MIN_OBSERVATIONS' };\n  }\n  return null;\n}\n\nfunction readObservationThresholdConfig(args) {\n  const input = resolveMinObservationsInput(args);\n  const enabledByFlag =\n    asBoolean(args.observationThresholdGuard) ||\n    asBoolean(args.minObservationsGuard) ||\n    asBoolean(process.env.DEEP_LOOP_MIN_OBSERVATIONS_GUARD);\n\n  if (!input && !enabledByFlag) {\n    return { enabled: false, minObservations: 1 };\n  }\n\n  return {\n    enabled: true,\n    minObservations: parseMinObservationsValue(input?.value, input?.key),\n  };\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\nfunction observabilityPathForDb(dbModule) {\n  const dbDir = dbModule?.COVERAGE_GRAPH_DATABASE_DIR ?? dbModule?.COUNCIL_GRAPH_STORAGE_DIR;\n  return typeof dbDir === 'string' && dbDir.trim() !== ''\n    ? path.join(dbDir, OBSERVABILITY_EVENTS_FILENAME)\n    : null;\n}\n\nfunction appendConvergenceObservabilityEvent(dbModule, payload, ns) {\n  const eventPath = observabilityPathForDb(dbModule);\n  if (!eventPath) return;\n  try {\n    appendObservabilityEvent(eventPath, payload, {\n      producer: 'convergence',\n      stream: 'graph-convergence',\n      subject: ns,\n      event: 'convergence_evaluated',\n      status: payload.graph_decision ?? payload.status,\n    });\n  } catch {\n    // Convergence stdout and snapshot persistence remain authoritative.\n  }\n}\n\nfunction blockersCsv(blockers) {\n  return blockers\n    .filter((blocker) => blocker && blocker.severity === 'blocking')\n    .map((blocker) => `${blocker.type}:${blocker.count}`)\n    .join(',');\n}\n\nfunction computeCompositeScore(signals, loopType) {\n  if (!signals || typeof signals !== 'object') return 0;\n  const clamp = (value) => Math.max(0, Math.min(1, value));\n  const safe = (value) => (typeof value === 'number' && Number.isFinite(value) ? value : 0);\n  if (loopType === 'research') {\n    const normalizedDiversity = Math.min(safe(signals.sourceDiversity) / 3.0, 1.0);\n    const normalizedDepth = Math.min(safe(signals.evidenceDepth) / 5.0, 1.0);\n    const invertedContradictions = 1.0 - clamp(safe(signals.contradictionDensity));\n    const score =\n      clamp(safe(signals.questionCoverage)) * 0.30 +\n      clamp(safe(signals.claimVerificationRate)) * 0.25 +\n      invertedContradictions * 0.15 +\n      normalizedDiversity * 0.15 +\n      normalizedDepth * 0.15;\n    return Math.round(clamp(score) * 1000) / 1000;\n  }\n  if (loopType === 'context') {\n    // REUSE catalog weighted highest (reuse-first principle); agreement second\n    // (by-model confidence); then scope coverage, relevance gate, dependency map.\n    const score =\n      clamp(safe(signals.reuseCatalogCoverage)) * 0.30 +\n      clamp(safe(signals.agreementRate)) * 0.25 +","lineStart":1,"lineEnd":260,"totalLines":797,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/convergence.cjs","time":{"start":1782998790573,"end":1782998790578}},"metadata":{"openai":{"itemId":"fc_09bc3f87ace35d68016a466706300c8194b344e18aaec56ab6"}},"id":"prt_f2302716a001JswWMhXIaYXtwI","sessionID":"ses_0dd080809ffeSxS04s909esZ2m","messageID":"msg_f23023e1e001KXK3j57r3KRWp0"}}
