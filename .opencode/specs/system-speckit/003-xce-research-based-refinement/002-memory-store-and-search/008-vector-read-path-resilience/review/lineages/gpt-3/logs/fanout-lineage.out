e/sqlite-to-turso context-report.md and 004 - gap-alternatives.md section 2.\",\n    \"created_at\": \"2026-06-10T17:48:33Z\",\n    \"last_save_at\": \"2026-06-10T19:22:14.994Z\",\n    \"save_lineage\": \"graph_only\",\n    \"last_accessed_at\": null,\n    \"source_docs\": [\n      \"spec.md\",\n      \"plan.md\",\n      \"tasks.md\",\n      \"implementation-summary.md\"\n    ],\n    \"last_active_child_id\": null,\n    \"last_active_at\": null\n  }\n}","lineStart":1,"lineEnd":218,"totalLines":218,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/013-vector-read-path-resilience/graph-metadata.json","time":{"start":1781151283356,"end":1781151283361}},"metadata":{"openai":{"itemId":"fc_0a73b9fb58a0a128016a2a363335708191baf8f8882707719f"}},"id":"prt_eb4e3b89b001ZEPoRPPtVa2YHx","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e38a3800174HJodr6mZSkm6"}}
