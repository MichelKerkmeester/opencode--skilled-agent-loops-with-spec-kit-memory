   130	export function findCoverageGaps(ns: Namespace): CoverageGap[] {
   250	/**
   251	 * BFS from a node following CITES/EVIDENCE_FOR/DERIVED_FROM/SUPPORTS edges.
   252	 *
   253	 * Detects cycles and returns cumulative path strength. Fully namespace-scoped
   254	 * to prevent cross-packet provenance reads.
   255	 *
   256	 * @param ns - Namespace identifying the coverage graph.
   257	 * @param nodeId - Starting node ID.
   258	 * @param maxDepth - Maximum traversal depth (default: 10).
   259	 * @returns Array of provenance steps in BFS order.
   260	 */
   261	export function findProvenanceChain(ns: Namespace, nodeId: string, maxDepth: number = 10): ProvenanceStep[] {
   262	  const provenanceRelations = ns.loopType === 'research'
   263	    ? ['CITES', 'DERIVED_FROM', 'SUPPORTS']
   264	    : ['EVIDENCE_FOR', 'CONFIRMS'];
   265	
   266	  const visited = new Set<string>();
   267	  const results: ProvenanceStep[] = [];
   268	  let frontier: Array<{ id: string; depth: number; cumulativeWeight: number }> = [
   269	    { id: nodeId, depth: 0, cumulativeWeight: 1.0 },
   270	  ];
   271	
   272	  while (frontier.length > 0) {
   273	    const next: typeof frontier = [];
   274	
   275	    for (const item of frontier) {
   276	      if (visited.has(item.id) || item.depth >= maxDepth) continue;
   277	      visited.add(item.id);
   278	
   279	      const edges = getEdgesFromNode(item.id, ns);
   280	      for (const edge of edges) {
   281	        if (!provenanceRelations.includes(edge.relation)) continue;
   282	        if (visited.has(edge.targetId)) continue;
   283	
   284	        const targetNode = getNodeById(edge.targetId, ns);
   285	        if (!targetNode) continue;
   286	
   287	        const cumWeight = item.cumulativeWeight * edge.weight;
   288	        results.push({
   289	          nodeId: edge.targetId,
   290	          kind: targetNode.kind,
   291	          name: targetNode.name,
   292	          depth: item.depth + 1,
   293	          edgeRelation: edge.relation,
   294	          cumulativeWeight: cumWeight,
   295	        });
   296	
   297	        next.push({ id: edge.targetId, depth: item.depth + 1, cumulativeWeight: cumWeight });
   298	      }
   299	    }
   300	
   301	    frontier = next;
   302	  }
   303	
   304	  return results;
   305	}
