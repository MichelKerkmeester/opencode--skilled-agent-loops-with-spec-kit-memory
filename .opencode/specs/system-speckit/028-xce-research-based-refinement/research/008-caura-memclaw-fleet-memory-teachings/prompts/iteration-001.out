{"type":"text","timestamp":1780727753076,"sessionID":"ses_1645cad2dffe08ToAptcWOhE23","part":{"id":"prt_e9ba5084e001gUjxZEXu3EAesO","messageID":"msg_e9ba4ff3f001CdUWYpPZelMsqi","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","type":"text","text":"The route layer adds two idempotency scopes: single-write response replay via `Idempotency-Key`, and bulk per-row attempt ids via `X-Bulk-Attempt-Id`. I’m reading those exact sections and storage persistence now.","time":{"start":1780727744590,"end":1780727753073},"metadata":{"openai":{"itemId":"msg_014134f6ec7663c2016a23bfc092d88191b41f9561ee63a825","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780727753167,"sessionID":"ses_1645cad2dffe08ToAptcWOhE23","part":{"type":"tool","tool":"read","callID":"call_Z5kxmGKWkJfO9APAYaa66MYs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Idempotency-Key helper (CAURA-601).\n2: \n3: Per-route opt-in: handlers call :func:`idempotency_for` after auth\n4: has enforced the tenant, get back a :class:`IdempotencyGuard`, check\n5: ``guard.cached_replay`` for a cached response, and call\n6: ``guard.record(...)`` after running the work.\n7: \n8: Not a middleware — slowapi + FastAPI already handle the request/response\n9: pipeline, and per-handler wiring keeps the replay contract explicit at\n10: the route level. The boilerplate is five lines per decorated handler.\n11: \"\"\"\n12: \n13: from __future__ import annotations\n14: \n15: import asyncio\n16: import hashlib\n17: import logging\n18: from datetime import UTC, datetime, timedelta\n19: from typing import Any, Literal\n20: \n21: from fastapi import HTTPException, Request\n22: \n23: from core_api.clients.storage_client import get_storage_client\n24: from core_api.config import settings\n25: \n26: logger = logging.getLogger(__name__)\n27: \n28: IDEMPOTENCY_HEADER = \"Idempotency-Key\"\n29: # Matches Stripe's limit. Guards the `Text` column against oversized\n30: # values from buggy or adversarial clients before it reaches storage.\n31: MAX_IDEMPOTENCY_KEY_LEN = 255\n32: \n33: # Poll cadence + budget while waiting for a concurrent holder of the\n34: # same key to finish. Total wait =\n35: # ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n36: # enough to absorb a typical write pipeline (~2-5s end-to-end) without\n37: # holding the second request indefinitely; on timeout the caller gets\n38: # 409 and can retry.\n39: _CLAIM_POLL_INTERVAL_SECONDS = 0.5\n40: _CLAIM_POLL_MAX_ATTEMPTS = 20\n41: \n42: # Sentinels ``_poll_until_complete`` may return alongside the\n43: # completed row dict and ``None`` (budget exhausted):\n44: #\n45: # - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n46: #   or pending TTL elapsed). Caller can tell the client to retry as\n47: #   a fresh request.\n48: # - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n49: #   timeout, network). Caller should respond 503 — retrying into a\n50: #   downed cluster wastes the client's retry budget.\n51: _POLL_VANISHED = \"vanished\"\n52: _POLL_STORAGE_ERROR = \"storage_error\"\n53: \n54: # Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n55: # header is absent. ``Idempotency-Key`` (header) remains the\n56: # canonical form per the IETF draft; the body fallback exists for\n57: # SDK / load-test clients that can't easily set headers per request.\n58: # ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n59: # alias the loadtest harness uses.\n60: _IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n61: \n62: \n63: def idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n64:     \"\"\"Extract the idempotency key from a request body's ``metadata``\n65:     dict, if present. Returns ``None`` if metadata is missing/empty\n66:     or no recognised key field is set.\n67: \n68:     The header takes precedence — call this only as a fallback when\n69:     the header is absent. Routes that wire idempotency wire it once\n70:     via:\n71: \n72:         key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n73:     \"\"\"\n74:     if not metadata:\n75:         return None\n76:     for field in _IDEMPOTENCY_BODY_FIELDS:\n77:         value = metadata.get(field)\n78:         # Return the un-stripped value: ``idempotency_for`` hashes the\n79:         # RAW request bytes for replay-conflict detection, so any\n80:         # normalisation here would let two byte-identical retries —\n81:         # one with surrounding whitespace, one without — hit the same\n82:         # cache bucket but mismatch on body hash, triggering a false\n83:         # 422. The blank guard still rejects pure-whitespace values.\n84:         if isinstance(value, str) and value.strip():\n85:             return value\n86:     return None\n87: \n88: \n89: class IdempotencyGuard:\n90:     \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n91: \n92:     def __init__(\n93:         self,\n94:         tenant_id: str,\n95:         key: str,\n96:         request_hash: str,\n97:         cached: dict | None,\n98:     ) -> None:\n99:         self.tenant_id = tenant_id\n100:         self.key = key\n101:         self.request_hash = request_hash\n102:         self._cached = cached\n103: \n104:     @property\n105:     def cached_replay(self) -> tuple[Any, int] | None:\n106:         \"\"\"``(response_body, status_code)`` if the same key + body was\n107:         served before and is still within TTL; else ``None``.\"\"\"\n108:         if self._cached is None:\n109:             return None\n110:         return self._cached[\"response_body\"], self._cached[\"status_code\"]\n111: \n112:     async def record(self, response_body: Any, status_code: int = 200) -> None:\n113:         \"\"\"Cache the response body under this key. Failures are logged,\n114:         not raised — the client already has the live response; losing the\n115:         cache only costs a chance at future dedup.\"\"\"\n116:         expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n117:         try:\n118:             await get_storage_client().upsert_idempotency(\n119:                 tenant_id=self.tenant_id,\n120:                 idempotency_key=self.key,\n121:                 request_hash=self.request_hash,\n122:                 response_body=response_body,\n123:                 status_code=status_code,\n124:                 expires_at=expires_at.isoformat(),\n125:             )\n126:         except Exception:\n127:             logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n128: \n129: \n130: async def idempotency_for(\n131:     request: Request,\n132:     tenant_id: str,\n133:     idempotency_key: str | None,\n134:     *,\n135:     source: Literal[\"header\", \"body\"] = \"header\",\n136: ) -> IdempotencyGuard | None:\n137:     \"\"\"Look up — and atomically claim — the inbox for (tenant, key).\n138: \n139:     Returns None if the key was absent. On a cache hit with a\n140:     *different* body hash, raises 422 — reusing the same key with\n141:     different content is explicitly a client error per the IETF\n142:     idempotency-key draft.\n143: \n144:     Call this inside a route handler *after* auth enforcement, so the\n145:     tenant_id passed here is already vetted.\n146: \n147:     ``source`` selects a transport-specific prefix (``\"header\"`` →\n148:     ``header:``, ``\"body\"`` → ``body:``) prepended before the lookup\n149:     so the same string value sent via different transports never\n150:     shares a cache bucket. Validation runs against the RAW key the\n151:     caller supplied; the prefix is added only for storage.\n152: \n153:     Body hashing note: uses raw request bytes. Clients retrying a write\n154:     MUST send byte-identical bodies (same JSON serializer, same key\n155:     ordering). Non-deterministic serialization will falsely flag a\n156:     retry as a conflict. Matches Stripe and the IETF draft.\n157: \n158:     Concurrency: closes the race where two requests with the same key\n159:     arrive within milliseconds. The flow is lookup → claim → poll:\n160: \n161:     1. ``get_idempotency`` reads any existing row.\n162:     2. If a completed row matches the request hash, replay it.\n163:     3. If no row, ``claim_idempotency`` atomically inserts a pending\n164:        sentinel via INSERT ... ON CONFLICT DO NOTHING. The winning\n165:        caller proceeds with the handler; ``record()`` flips\n166:        ``is_pending`` to False.\n167:     4. If the claim collided (a concurrent caller raced ahead between\n168:        step 1 and step 3, or the row was pending in step 1), poll the\n169:        existing row until ``is_pending`` is False, then replay.\n170: \n171:     Storage outages degrade to \"no cache\" — a lost dedup opportunity\n172:     beats a blocked write.\n173:     \"\"\"\n174:     if not idempotency_key:\n175:         return None\n176:     if not idempotency_key.strip():\n177:         raise HTTPException(status_code=400, detail=\"Idempotency-Key must not be blank\")\n178:     if len(idempotency_key) > MAX_IDEMPOTENCY_KEY_LEN:\n179:         raise HTTPException(\n180:             status_code=400,\n181:             detail=f\"Idempotency-Key must be at most {MAX_IDEMPOTENCY_KEY_LEN} characters\",\n182:         )\n183: \n184:     namespaced_key = f\"{source}:{idempotency_key}\"\n185: \n186:     body_bytes = await request.body()\n187:     request_hash = hashlib.sha256(body_bytes).hexdigest()\n188: \n189:     sc = get_storage_client()\n190: \n191:     cached: dict | None\n192:     try:\n193:         cached = await sc.get_idempotency(tenant_id, namespaced_key)\n194:     except Exception:\n195:         logger.warning(\"Idempotency lookup failed (degrading to no-cache)\", exc_info=True)\n196:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n197: \n198:     if cached and not cached.get(\"is_pending\", False):\n199:         if cached[\"request_hash\"] != request_hash:\n200:             raise HTTPException(\n201:                 status_code=422,\n202:                 detail=\"Idempotency-Key reused with a different request body\",\n203:             )\n204:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=cached)\n205: \n206:     if cached and cached.get(\"is_pending\", False):\n207:         # Hash-check before polling: a different body for the same key is\n208:         # always a 422 regardless of the in-flight handler's outcome,\n209:         # and the pending row already carries the original hash. Without\n210:         # this short-circuit the loser burns the full poll budget before\n211:         # getting the same 422.\n212:         if cached[\"request_hash\"] != request_hash:\n213:             raise HTTPException(\n214:                 status_code=422,\n215:                 detail=\"Idempotency-Key reused with a different request body\",\n216:             )\n217:         completed = await _poll_until_complete(sc, tenant_id, namespaced_key)\n218:         if completed is None:\n219:             raise HTTPException(\n220:                 status_code=409,\n221:                 detail=\"Idempotency-Key still in progress; retry shortly\",\n222:             )\n223:         if completed == _POLL_STORAGE_ERROR:\n224:             raise HTTPException(\n225:                 status_code=503,\n226:                 detail=\"Upstream storage unavailable; retry later\",\n227:             )\n228:         if completed == _POLL_VANISHED:\n229:             raise HTTPException(\n230:                 status_code=409,\n231:                 detail=\"Previous request did not complete; safe to retry\",\n232:             )\n233:         assert isinstance(completed, dict)  # narrow for mypy after sentinel checks\n234:         if completed[\"request_hash\"] != request_hash:\n235:             raise HTTPException(\n236:                 status_code=422,\n237:                 detail=\"Idempotency-Key reused with a different request body\",\n238:             )\n239:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=completed)\n240: \n241:     # Claim with a short pending-TTL. ``record()`` later extends to the\n242:     # full TTL on success. A crashed handler leaves the row pending only\n243:     # until ``idempotency_pending_ttl_seconds`` elapses; after that the\n244:     # expired-row reclaim path in ``idempotency_claim`` lets a fresh\n245:     # request take over the key automatically.\n246:     pending_expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_pending_ttl_seconds)\n247:     try:\n248:         claimed, existing = await sc.claim_idempotency(\n249:             tenant_id=tenant_id,\n250:             idempotency_key=namespaced_key,\n251:             request_hash=request_hash,\n252:             expires_at=pending_expires_at.isoformat(),\n253:         )\n254:     except Exception:\n255:         logger.warning(\"Idempotency claim failed (degrading to no-cache)\", exc_info=True)\n256:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n257: \n258:     if claimed:\n259:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n260: \n\n(Showing lines 1-260 of 333. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","text":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n\nfrom fastapi import HTTPException, Request\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\nIDEMPOTENCY_HEADER = \"Idempotency-Key\"\n# Matches Stripe's limit. Guards the `Text` column against oversized\n# values from buggy or adversarial clients before it reaches storage.\nMAX_IDEMPOTENCY_KEY_LEN = 255\n\n# Poll cadence + budget while waiting for a concurrent holder of the\n# same key to finish. Total wait =\n# ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n# enough to absorb a typical write pipeline (~2-5s end-to-end) without\n# holding the second request indefinitely; on timeout the caller gets\n# 409 and can retry.\n_CLAIM_POLL_INTERVAL_SECONDS = 0.5\n_CLAIM_POLL_MAX_ATTEMPTS = 20\n\n# Sentinels ``_poll_until_complete`` may return alongside the\n# completed row dict and ``None`` (budget exhausted):\n#\n# - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n#   or pending TTL elapsed). Caller can tell the client to retry as\n#   a fresh request.\n# - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n#   timeout, network). Caller should respond 503 — retrying into a\n#   downed cluster wastes the client's retry budget.\n_POLL_VANISHED = \"vanished\"\n_POLL_STORAGE_ERROR = \"storage_error\"\n\n# Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n# header is absent. ``Idempotency-Key`` (header) remains the\n# canonical form per the IETF draft; the body fallback exists for\n# SDK / load-test clients that can't easily set headers per request.\n# ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n# alias the loadtest harness uses.\n_IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n\n\ndef idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n    \"\"\"Extract the idempotency key from a request body's ``metadata``\n    dict, if present. Returns ``None`` if metadata is missing/empty\n    or no recognised key field is set.\n\n    The header takes precedence — call this only as a fallback when\n    the header is absent. Routes that wire idempotency wire it once\n    via:\n\n        key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n    \"\"\"\n    if not metadata:\n        return None\n    for field in _IDEMPOTENCY_BODY_FIELDS:\n        value = metadata.get(field)\n        # Return the un-stripped value: ``idempotency_for`` hashes the\n        # RAW request bytes for replay-conflict detection, so any\n        # normalisation here would let two byte-identical retries —\n        # one with surrounding whitespace, one without — hit the same\n        # cache bucket but mismatch on body hash, triggering a false\n        # 422. The blank guard still rejects pure-whitespace values.\n        if isinstance(value, str) and value.strip():\n            return value\n    return None\n\n\nclass IdempotencyGuard:\n    \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n\n    def __init__(\n        self,\n        tenant_id: str,\n        key: str,\n        request_hash: str,\n        cached: dict | None,\n    ) -> None:\n        self.tenant_id = tenant_id\n        self.key = key\n        self.request_hash = request_hash\n        self._cached = cached\n\n    @property\n    def cached_replay(self) -> tuple[Any, int] | None:\n        \"\"\"``(response_body, status_code)`` if the same key + body was\n        served before and is still within TTL; else ``None``.\"\"\"\n        if self._cached is None:\n            return None\n        return self._cached[\"response_body\"], self._cached[\"status_code\"]\n\n    async def record(self, response_body: Any, status_code: int = 200) -> None:\n        \"\"\"Cache the response body under this key. Failures are logged,\n        not raised — the client already has the live response; losing the\n        cache only costs a chance at future dedup.\"\"\"\n        expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n        try:\n            await get_storage_client().upsert_idempotency(\n                tenant_id=self.tenant_id,\n                idempotency_key=self.key,\n                request_hash=self.request_hash,\n                response_body=response_body,\n                status_code=status_code,\n                expires_at=expires_at.isoformat(),\n            )\n        except Exception:\n            logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n\n\nasync def idempotency_for(\n    request: Request,\n    tenant_id: str,\n    idempotency_key: str | None,\n    *,\n    source: Literal[\"header\", \"body\"] = \"header\",\n) -> IdempotencyGuard | None:\n    \"\"\"Look up — and atomically claim — the inbox for (tenant, key).\n\n    Returns None if the key was absent. On a cache hit with a\n    *different* body hash, raises 422 — reusing the same key with\n    different content is explicitly a client error per the IETF\n    idempotency-key draft.\n\n    Call this inside a route handler *after* auth enforcement, so the\n    tenant_id passed here is already vetted.\n\n    ``source`` selects a transport-specific prefix (``\"header\"`` →\n    ``header:``, ``\"body\"`` → ``body:``) prepended before the lookup\n    so the same string value sent via different transports never\n    shares a cache bucket. Validation runs against the RAW key the\n    caller supplied; the prefix is added only for storage.\n\n    Body hashing note: uses raw request bytes. Clients retrying a write\n    MUST send byte-identical bodies (same JSON serializer, same key\n    ordering). Non-deterministic serialization will falsely flag a\n    retry as a conflict. Matches Stripe and the IETF draft.\n\n    Concurrency: closes the race where two requests with the same key\n    arrive within milliseconds. The flow is lookup → claim → poll:\n\n    1. ``get_idempotency`` reads any existing row.\n    2. If a completed row matches the request hash, replay it.\n    3. If no row, ``claim_idempotency`` atomically inserts a pending\n       sentinel via INSERT ... ON CONFLICT DO NOTHING. The winning\n       caller proceeds with the handler; ``record()`` flips\n       ``is_pending`` to False.\n    4. If the claim collided (a concurrent caller raced ahead between\n       step 1 and step 3, or the row was pending in step 1), poll the\n       existing row until ``is_pending`` is False, then replay.\n\n    Storage outages degrade to \"no cache\" — a lost dedup opportunity\n    beats a blocked write.\n    \"\"\"\n    if not idempotency_key:\n        return None\n    if not idempotency_key.strip():\n        raise HTTPException(status_code=400, detail=\"Idempotency-Key must not be blank\")\n    if len(idempotency_key) > MAX_IDEMPOTENCY_KEY_LEN:\n        raise HTTPException(\n            status_code=400,\n            detail=f\"Idempotency-Key must be at most {MAX_IDEMPOTENCY_KEY_LEN} characters\",\n        )\n\n    namespaced_key = f\"{source}:{idempotency_key}\"\n\n    body_bytes = await request.body()\n    request_hash = hashlib.sha256(body_bytes).hexdigest()\n\n    sc = get_storage_client()\n\n    cached: dict | None\n    try:\n        cached = await sc.get_idempotency(tenant_id, namespaced_key)\n    except Exception:\n        logger.warning(\"Idempotency lookup failed (degrading to no-cache)\", exc_info=True)\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n\n    if cached and not cached.get(\"is_pending\", False):\n        if cached[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=cached)\n\n    if cached and cached.get(\"is_pending\", False):\n        # Hash-check before polling: a different body for the same key is\n        # always a 422 regardless of the in-flight handler's outcome,\n        # and the pending row already carries the original hash. Without\n        # this short-circuit the loser burns the full poll budget before\n        # getting the same 422.\n        if cached[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        completed = await _poll_until_complete(sc, tenant_id, namespaced_key)\n        if completed is None:\n            raise HTTPException(\n                status_code=409,\n                detail=\"Idempotency-Key still in progress; retry shortly\",\n            )\n        if completed == _POLL_STORAGE_ERROR:\n            raise HTTPException(\n                status_code=503,\n                detail=\"Upstream storage unavailable; retry later\",\n            )\n        if completed == _POLL_VANISHED:\n            raise HTTPException(\n                status_code=409,\n                detail=\"Previous request did not complete; safe to retry\",\n            )\n        assert isinstance(completed, dict)  # narrow for mypy after sentinel checks\n        if completed[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=completed)\n\n    # Claim with a short pending-TTL. ``record()`` later extends to the\n    # full TTL on success. A crashed handler leaves the row pending only\n    # until ``idempotency_pending_ttl_seconds`` elapses; after that the\n    # expired-row reclaim path in ``idempotency_claim`` lets a fresh\n    # request take over the key automatically.\n    pending_expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_pending_ttl_seconds)\n    try:\n        claimed, existing = await sc.claim_idempotency(\n            tenant_id=tenant_id,\n            idempotency_key=namespaced_key,\n            request_hash=request_hash,\n            expires_at=pending_expires_at.isoformat(),\n        )\n    except Exception:\n        logger.warning(\"Idempotency claim failed (degrading to no-cache)\", exc_info=True)\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n\n    if claimed:\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n","lineStart":1,"lineEnd":260,"totalLines":333,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","time":{"start":1780727753148,"end":1780727753165}},"metadata":{"openai":{"itemId":"fc_014134f6ec7663c2016a23bfc9068c8191b491f9d9389d9a4d"}},"id":"prt_e9ba529b9001Du6pvD8ER48vps","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","messageID":"msg_e9ba4ff3f001CdUWYpPZelMsqi"}}
{"type":"tool_use","timestamp":1780727753173,"sessionID":"ses_1645cad2dffe08ToAptcWOhE23","part":{"type":"tool","tool":"read","callID":"call_9CAjrJwBH9PAjKUZSgRbL3SF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","offset":850,"limit":330},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py</path>\n<type>file</type>\n<content>\n850:                 \"created_at\": m.created_at.isoformat() if m.created_at else None,\n851:             }\n852:             for m in supersessors\n853:         ],\n854:         # CAURA-604: detector-result fields. See docstring above for semantics.\n855:         \"detection_status\": detection_status,\n856:         \"contradictions\": contradictions,\n857:     }\n858: \n859: \n860: @router.post(\"/memories\", response_model=MemoryOut, status_code=201)\n861: @write_limit\n862: async def write_memory(\n863:     request: Request,\n864:     body: MemoryCreate,\n865:     response: Response,\n866:     auth: AuthContext = Depends(get_auth_context),\n867:     db: AsyncSession = Depends(get_db),\n868:     idempotency_key: str | None = Header(None, alias=IDEMPOTENCY_HEADER),\n869: ):\n870:     auth.enforce_read_only()\n871:     auth.enforce_usage_limits()\n872:     auth.enforce_tenant(body.tenant_id)\n873:     _reject_reserved_memory_type(body.memory_type)\n874:     # Idempotency replay is short-circuited BEFORE the per-tenant slot —\n875:     # a cached retry must not consume a write-concurrency slot, or a\n876:     # tenant retry storm starves its own legitimate new writes.\n877:     # ``idempotency_for`` handles transport-prefixing (``header:`` /\n878:     # ``body:``) and length validation; each transport gets a disjoint\n879:     # cache namespace.\n880:     if idempotency_key:\n881:         _idem = await idempotency_for(request, body.tenant_id, idempotency_key, source=\"header\")\n882:     else:\n883:         _idem = await idempotency_for(\n884:             request,\n885:             body.tenant_id,\n886:             idempotency_key_from_metadata(body.metadata),\n887:             source=\"body\",\n888:         )\n889:     if _idem and (_replay := _idem.cached_replay):\n890:         _body, _status = _replay\n891:         # Replays bypass the per-tenant slot AND the\n892:         # ``check_and_increment`` quota call below, so ``response.headers``\n893:         # is empty here — emit no rate-limit headers rather than\n894:         # passing empties. Acceptable trade-off: a replayed request\n895:         # didn't consume quota, so there's no fresh ``remaining`` value\n896:         # to publish.\n897:         return JSONResponse(content=_body, status_code=_status)\n898:     # Per-tenant in-flight cap fails fast with 429 if a single tenant is\n899:     # already saturating its slot budget on this instance, instead of\n900:     # queueing requests until they time out at the worker layer. Only\n901:     # the new-write path is gated; replays returned above bypass it.\n902:     async with per_tenant_slot(\"write\", body.tenant_id):\n903:         return await _write_memory_inner(body, response, auth, db, _idem)\n904: \n905: \n906: async def _write_memory_inner(\n907:     body: MemoryCreate,\n908:     response: Response,\n909:     auth: AuthContext,\n910:     db: AsyncSession,\n911:     idem: IdempotencyGuard | None,\n912: ):\n913:     from core_api.services.organization_settings import resolve_config\n914: \n915:     write_config = await resolve_config(db, body.tenant_id)\n916:     agent = await get_or_create_agent(\n917:         db,\n918:         body.tenant_id,\n919:         body.agent_id,\n920:         body.fleet_id,\n921:         require_approval=write_config.require_agent_approval,\n922:     )\n923:     if agent.get(\"trust_level\", 0) == 0:\n924:         raise HTTPException(\n925:             status_code=403,\n926:             detail=f\"Agent '{body.agent_id}' is not approved. Contact tenant admin to set trust_level >= 1.\",\n927:         )\n928:     # Resolve fleet_id from agent's home fleet if not provided\n929:     if not body.fleet_id and agent.get(\"fleet_id\"):\n930:         body.fleet_id = agent[\"fleet_id\"]\n931:     usage = None\n932:     if auth.tenant_id:  # skip enforcement + metering for admin\n933:         await enforce_fleet_write(db, body.tenant_id, body.agent_id, body.fleet_id)\n934:         usage = await check_and_increment(db, body.tenant_id, \"write\")\n935:     if usage:\n936:         response.headers[\"X-RateLimit-Limit\"] = str(usage.get(\"limit\", \"unlimited\"))\n937:         response.headers[\"X-RateLimit-Remaining\"] = str(usage.get(\"remaining\", \"unlimited\"))\n938:     result = await create_memory(db, body)\n939:     # STM writes return STMWriteResponse (different shape from MemoryOut)\n940:     if isinstance(result, STMWriteResponse):\n941:         stm_body = result.model_dump(mode=\"json\")\n942:         if idem:\n943:             await idem.record(stm_body, 201)\n944:         return JSONResponse(content=stm_body, status_code=201)\n945:     if usage:\n946:         result.usage = UsageSummary(\n947:             writes_remaining=usage.get(\"remaining\"),\n948:             memories_limit=usage.get(\"limit\"),\n949:         )\n950:     # Cache AFTER attaching usage so replays return a structurally\n951:     # identical response. The usage snapshot is stale in the replay\n952:     # (bounded by idempotency_ttl_seconds, default 24h) — callers who\n953:     # need live quota should consult a fresh endpoint, not a replay.\n954:     if idem:\n955:         await idem.record(result.model_dump(mode=\"json\"), 201)\n956:     return result\n957: \n958: \n959: BULK_ATTEMPT_ID_HEADER = \"X-Bulk-Attempt-Id\"\n960: # Tighter than ``MAX_IDEMPOTENCY_KEY_LEN`` (255) because the token is\n961: # concatenated with ``:{i}`` to form the per-row ``client_request_id``\n962: # stored on every memory; 128 leaves comfortable room for a 100-item\n963: # batch (``:99`` adds 3 chars) while keeping the partial-unique index\n964: # leaves narrow.\n965: MAX_BULK_ATTEMPT_ID_LEN = 128\n966: _BULK_ATTEMPT_ID_PATTERN = re.compile(rf\"^[A-Za-z0-9._:\\-]{{1,{MAX_BULK_ATTEMPT_ID_LEN}}}$\")\n967: \n968: \n969: @router.post(\n970:     \"/memories/bulk\",\n971:     status_code=200,\n972:     # The route returns ``JSONResponse`` directly so it can vary the\n973:     # status code between 200 and 207, which strips FastAPI's automatic\n974:     # response-model inference. Declare both shapes explicitly so the\n975:     # OpenAPI doc keeps documenting the body for SDK generators.\n976:     responses={\n977:         200: {\"model\": BulkMemoryResponse},\n978:         207: {\"model\": BulkMemoryResponse},\n979:     },\n980: )\n981: @write_bulk_limit\n982: async def write_memories_bulk(\n983:     request: Request,\n984:     body: BulkMemoryCreate,\n985:     response: Response,\n986:     auth: AuthContext = Depends(get_auth_context),\n987:     db: AsyncSession = Depends(get_db),\n988:     idempotency_key: str | None = Header(None, alias=IDEMPOTENCY_HEADER),\n989:     bulk_attempt_id: str | None = Header(None, alias=BULK_ATTEMPT_ID_HEADER),\n990: ):\n991:     \"\"\"Write up to 100 memories with per-attempt idempotency (CAURA-602).\n992: \n993:     Required header ``X-Bulk-Attempt-Id`` identifies the *attempt*. A\n994:     retry of the same logical batch reuses the same value; storage's\n995:     per-item unique constraint then converts each row into either\n996:     ``created`` or ``duplicate_attempt`` deterministically. The route\n997:     returns:\n998: \n999:     - ``200`` when every item resolved as ``created``,\n1000:       ``duplicate_attempt``, or ``duplicate_content``.\n1001:     - ``207 Multi-Status`` when at least one item has ``status=\"error\"``\n1002:       (validation, enrichment timeout, missing storage id) AND at least\n1003:       one item succeeded — partial outcomes are explicit, never inferred\n1004:       from a 5xx with side effects.\n1005:     - ``200`` when every item is an error too — the request was processed\n1006:       successfully; per-item ``status`` carries the rejection. We\n1007:       deliberately don't reuse 422 here because FastAPI already emits\n1008:       422 for request-body Pydantic validation, and clients that branch\n1009:       on status code alone shouldn't have to disambiguate \"request was\n1010:       malformed\" from \"request parsed and every item was rejected on\n1011:       merit.\"\n1012:     - ``504`` when the bulk-only budget burns before storage commits;\n1013:       the response carries no per-item state, so a retry with the same\n1014:       attempt id is the recovery path.\n1015: \n1016:     The pre-existing ``Idempotency-Key`` header still controls\n1017:     *response*-level replay; ``X-Bulk-Attempt-Id`` is a separate\n1018:     contract operating one layer down. Both are honoured: the header\n1019:     cache short-circuits when the receipt is final, the per-row\n1020:     constraint resolves the slow path when the receipt is missing or\n1021:     pending.\n1022:     \"\"\"\n1023:     auth.enforce_read_only()\n1024:     auth.enforce_usage_limits()\n1025:     auth.enforce_tenant(body.tenant_id)\n1026:     for _idx, _item in enumerate(body.items):\n1027:         _reject_reserved_memory_type(_item.memory_type, index=_idx)\n1028: \n1029:     # Broker (kind=install_credential, ``mci_v1_…`` wire prefix) calls\n1030:     # don't carry an attempt id header or an ``agent_id`` body field\n1031:     # — the broker's own per-\n1032:     # session ``client_hash`` de-dup is the design contract per\n1033:     # cloud-data-plane.md §2.4 (gap G3). Server-derive a per-request\n1034:     # attempt id and attribute writes to the install. Non-broker\n1035:     # callers (dashboard, SDK) keep the CAURA-602 invariants in full.\n1036:     if auth.is_install_credential:\n1037:         if not bulk_attempt_id:\n1038:             import uuid as _uuid\n1039: \n1040:             bulk_attempt_id = f\"broker-{auth.install_uuid or 'unknown'}-{_uuid.uuid4()}\"\n1041:         if not body.agent_id:\n1042:             body.agent_id = f\"broker:{auth.install_uuid or 'unknown'}\"\n1043:     if not bulk_attempt_id:\n1044:         # Required as of CAURA-602 — without it we can't make the bulk\n1045:         # write retry-safe, and silent-create regressions reappear under\n1046:         # any storage-side cancellation. Reject with a 4xx so SDKs see\n1047:         # the breaking change, not a soft-fallback that masks the bug.\n1048:         raise HTTPException(\n1049:             status_code=400,\n1050:             detail=f\"Missing required {BULK_ATTEMPT_ID_HEADER} header\",\n1051:         )\n1052:     if not _BULK_ATTEMPT_ID_PATTERN.match(bulk_attempt_id):\n1053:         raise HTTPException(\n1054:             status_code=400,\n1055:             detail=(f\"Invalid {BULK_ATTEMPT_ID_HEADER}: must match ^[A-Za-z0-9._:\\\\-]{{1,128}}$\"),\n1056:         )\n1057: \n1058:     # Idempotency replay short-circuits BEFORE the per-tenant slot — a\n1059:     # cached retry must not consume a write-concurrency slot.\n1060:     _idem = await idempotency_for(request, body.tenant_id, idempotency_key)\n1061:     if _idem and (_replay := _idem.cached_replay):\n1062:         _body, _status = _replay\n1063:         # Replays bypass the per-tenant slot and the bulk\n1064:         # quota-increment, so no rate-limit headers are available to\n1065:         # carry on the cached response.\n1066:         return JSONResponse(content=_body, status_code=_status)\n1067:     async with per_tenant_slot(\"write\", body.tenant_id):\n1068:         return await _write_memories_bulk_inner(body, response, auth, db, _idem, bulk_attempt_id)\n1069: \n1070: \n1071: def _bulk_response(result: BulkMemoryResponse) -> JSONResponse:\n1072:     \"\"\"Pick HTTP status per CAURA-602 contract:\n1073: \n1074:     - 200 when there are no errors at all, OR every item is an error\n1075:       (the request was processed; rejections are per-item business\n1076:       logic, not a transport-level failure). Avoiding 422 here keeps\n1077:       the route's response space disjoint from FastAPI's automatic\n1078:       422-on-body-validation.\n1079:     - 207 Multi-Status when the batch is mixed — at least one error\n1080:       AND at least one resolved row. ``duplicate_attempt`` and\n1081:       ``duplicate_content`` both count as resolved (they carry an\n1082:       ``id``), so a batch of ``[error, duplicate_attempt]`` (i.e.\n1083:       ``created=0, duplicates=1, errors=1``) is 207, not 200 — the\n1084:       condition tests ``created == 0 and duplicates == 0`` *together*\n1085:       so any duplicate keeps the response in the mixed bucket.\n1086: \n1087:     Always returns the body verbatim; per-item ``status`` carries the\n1088:     real outcome, so the HTTP code is purely a hint for clients that\n1089:     can branch on 2xx / 207.\n1090:     \"\"\"\n1091:     if result.errors == 0 or (result.created == 0 and result.duplicates == 0):\n1092:         status_code = 200\n1093:     else:\n1094:         status_code = 207\n1095:     return JSONResponse(content=result.model_dump(mode=\"json\"), status_code=status_code)\n1096: \n1097: \n1098: async def _write_memories_bulk_inner(\n1099:     body: BulkMemoryCreate,\n1100:     response: Response,\n1101:     auth: AuthContext,\n1102:     db: AsyncSession,\n1103:     idem: IdempotencyGuard | None,\n1104:     bulk_attempt_id: str,\n1105: ):\n1106:     agent = await get_or_create_agent(db, body.tenant_id, body.agent_id, body.fleet_id)\n1107:     if not body.fleet_id and agent.get(\"fleet_id\"):\n1108:         body.fleet_id = agent[\"fleet_id\"]\n1109:     usage = None\n1110:     if auth.tenant_id:  # skip enforcement + metering for admin\n1111:         await enforce_fleet_write(db, body.tenant_id, body.agent_id, body.fleet_id)\n1112:         usage = await bulk_check_and_increment(db, body.tenant_id, len(body.items))\n1113:     if usage:\n1114:         response.headers[\"X-RateLimit-Limit\"] = str(usage.get(\"limit\", \"unlimited\"))\n1115:         response.headers[\"X-RateLimit-Remaining\"] = str(usage.get(\"remaining\", \"unlimited\"))\n1116: \n1117:     try:\n1118:         result = await asyncio.wait_for(\n1119:             create_memories_bulk(db, body, bulk_attempt_id=bulk_attempt_id),\n1120:             timeout=app_settings.bulk_request_timeout_seconds,\n1121:         )\n1122:     except (TimeoutError, httpx.TimeoutException):\n1123:         # ``asyncio.wait_for`` documents raising ``asyncio.TimeoutError``,\n1124:         # which Python 3.11 aliased to the builtin ``TimeoutError``.\n1125:         # Project floor is 3.12 (``requires-python = \">=3.12\"``), so the\n1126:         # builtin form is correct everywhere we run; ruff UP041 also\n1127:         # mandates this shape. Anyone porting back to Python 3.10 must\n1128:         # change this to ``except asyncio.TimeoutError:`` first.\n1129:         #\n1130:         # ``httpx.TimeoutException`` is the base for ReadTimeout /\n1131:         # WriteTimeout / ConnectTimeout / PoolTimeout. The storage\n1132:         # client's pool sets ``read=120s`` deliberately above the 90s\n1133:         # ``bulk_request_timeout_seconds`` so the asyncio cancellation\n1134:         # almost always wins the race, but we catch httpx timeouts here\n1135:         # as a defence-in-depth fallback. Either path means the storage\n1136:         # call may have committed without surfacing an id; the\n1137:         # ``X-Bulk-Attempt-Id`` retry contract recovers it.\n1138:         #\n1139:         # The per-phase ``storage_bulk_timeout_seconds`` deadline (raised\n1140:         # from ``asyncio.timeout`` inside ``create_memories_bulk``) also\n1141:         # lands here as a plain ``TimeoutError`` — same recovery contract.\n1142:         # Both caps are logged as static config values so the access-log\n1143:         # entry is self-explanatory; the actual elapsed time on the\n1144:         # request line distinguishes which timer fired (storage cap at\n1145:         # ~25s elapsed vs umbrella at ~90s elapsed).\n1146:         logger.warning(\n1147:             \"bulk write timed out (storage cap %ss / request cap %ss); client should retry with same %s\",\n1148:             app_settings.storage_bulk_timeout_seconds,\n1149:             app_settings.bulk_request_timeout_seconds,\n1150:             BULK_ATTEMPT_ID_HEADER,\n1151:         )\n1152:         # No per-item state to surface — the storage call may have\n1153:         # committed some rows, none, or be still in flight. Do NOT\n1154:         # record the idempotency receipt so a retry doesn't replay an\n1155:         # incomplete answer; the per-item attempt-id is the recovery\n1156:         # contract and a retry will resolve every committed row to\n1157:         # ``duplicate_attempt`` with its canonical id.\n1158:         raise HTTPException(\n1159:             status_code=504,\n1160:             detail=(\n1161:                 \"bulk write timed out before completing; retry with \"\n1162:                 f\"the same {BULK_ATTEMPT_ID_HEADER} to recover any \"\n1163:                 \"committed items.\"\n1164:             ),\n1165:         )\n1166:     except httpx.HTTPStatusError as exc:\n1167:         # Storage 5xx (raised by ``resp.raise_for_status()`` in the storage\n1168:         # client) may have committed rows before failing — same shape as\n1169:         # the timeout branch — so map to 504 to keep the\n1170:         # ``X-Bulk-Attempt-Id`` retry contract intact. 4xx escapes here\n1171:         # intentionally: it signals a request-shape problem the client\n1172:         # must fix, not transient noise the retry path can recover from.\n1173:         if not (500 <= exc.response.status_code < 600):\n1174:             # Log so the 4xx path is observable in structured logs;\n1175:             # without this, only FastAPI's generic unhandled-exception\n1176:             # log surfaces and it has no bulk context.\n1177:             logger.warning(\n1178:                 \"bulk write got unexpected %s from storage; this is a request-shape bug\",\n1179:                 exc.response.status_code,\n\n(Showing lines 850-1179 of 2023. Use offset=1180 to continue.)\n</content>","metadata":{"preview":"                \"created_at\": m.created_at.isoformat() if m.created_at else None,\n            }\n            for m in supersessors\n        ],\n        # CAURA-604: detector-result fields. See docstring above for semantics.\n        \"detection_status\": detection_status,\n        \"contradictions\": contradictions,\n    }\n\n\n@router.post(\"/memories\", response_model=MemoryOut, status_code=201)\n@write_limit\nasync def write_memory(\n    request: Request,\n    body: MemoryCreate,\n    response: Response,\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n    idempotency_key: str | None = Header(None, alias=IDEMPOTENCY_HEADER),\n):","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","text":"                \"created_at\": m.created_at.isoformat() if m.created_at else None,\n            }\n            for m in supersessors\n        ],\n        # CAURA-604: detector-result fields. See docstring above for semantics.\n        \"detection_status\": detection_status,\n        \"contradictions\": contradictions,\n    }\n\n\n@router.post(\"/memories\", response_model=MemoryOut, status_code=201)\n@write_limit\nasync def write_memory(\n    request: Request,\n    body: MemoryCreate,\n    response: Response,\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n    idempotency_key: str | None = Header(None, alias=IDEMPOTENCY_HEADER),\n):\n    auth.enforce_read_only()\n    auth.enforce_usage_limits()\n    auth.enforce_tenant(body.tenant_id)\n    _reject_reserved_memory_type(body.memory_type)\n    # Idempotency replay is short-circuited BEFORE the per-tenant slot —\n    # a cached retry must not consume a write-concurrency slot, or a\n    # tenant retry storm starves its own legitimate new writes.\n    # ``idempotency_for`` handles transport-prefixing (``header:`` /\n    # ``body:``) and length validation; each transport gets a disjoint\n    # cache namespace.\n    if idempotency_key:\n        _idem = await idempotency_for(request, body.tenant_id, idempotency_key, source=\"header\")\n    else:\n        _idem = await idempotency_for(\n            request,\n            body.tenant_id,\n            idempotency_key_from_metadata(body.metadata),\n            source=\"body\",\n        )\n    if _idem and (_replay := _idem.cached_replay):\n        _body, _status = _replay\n        # Replays bypass the per-tenant slot AND the\n        # ``check_and_increment`` quota call below, so ``response.headers``\n        # is empty here — emit no rate-limit headers rather than\n        # passing empties. Acceptable trade-off: a replayed request\n        # didn't consume quota, so there's no fresh ``remaining`` value\n        # to publish.\n        return JSONResponse(content=_body, status_code=_status)\n    # Per-tenant in-flight cap fails fast with 429 if a single tenant is\n    # already saturating its slot budget on this instance, instead of\n    # queueing requests until they time out at the worker layer. Only\n    # the new-write path is gated; replays returned above bypass it.\n    async with per_tenant_slot(\"write\", body.tenant_id):\n        return await _write_memory_inner(body, response, auth, db, _idem)\n\n\nasync def _write_memory_inner(\n    body: MemoryCreate,\n    response: Response,\n    auth: AuthContext,\n    db: AsyncSession,\n    idem: IdempotencyGuard | None,\n):\n    from core_api.services.organization_settings import resolve_config\n\n    write_config = await resolve_config(db, body.tenant_id)\n    agent = await get_or_create_agent(\n        db,\n        body.tenant_id,\n        body.agent_id,\n        body.fleet_id,\n        require_approval=write_config.require_agent_approval,\n    )\n    if agent.get(\"trust_level\", 0) == 0:\n        raise HTTPException(\n            status_code=403,\n            detail=f\"Agent '{body.agent_id}' is not approved. Contact tenant admin to set trust_level >= 1.\",\n        )\n    # Resolve fleet_id from agent's home fleet if not provided\n    if not body.fleet_id and agent.get(\"fleet_id\"):\n        body.fleet_id = agent[\"fleet_id\"]\n    usage = None\n    if auth.tenant_id:  # skip enforcement + metering for admin\n        await enforce_fleet_write(db, body.tenant_id, body.agent_id, body.fleet_id)\n        usage = await check_and_increment(db, body.tenant_id, \"write\")\n    if usage:\n        response.headers[\"X-RateLimit-Limit\"] = str(usage.get(\"limit\", \"unlimited\"))\n        response.headers[\"X-RateLimit-Remaining\"] = str(usage.get(\"remaining\", \"unlimited\"))\n    result = await create_memory(db, body)\n    # STM writes return STMWriteResponse (different shape from MemoryOut)\n    if isinstance(result, STMWriteResponse):\n        stm_body = result.model_dump(mode=\"json\")\n        if idem:\n            await idem.record(stm_body, 201)\n        return JSONResponse(content=stm_body, status_code=201)\n    if usage:\n        result.usage = UsageSummary(\n            writes_remaining=usage.get(\"remaining\"),\n            memories_limit=usage.get(\"limit\"),\n        )\n    # Cache AFTER attaching usage so replays return a structurally\n    # identical response. The usage snapshot is stale in the replay\n    # (bounded by idempotency_ttl_seconds, default 24h) — callers who\n    # need live quota should consult a fresh endpoint, not a replay.\n    if idem:\n        await idem.record(result.model_dump(mode=\"json\"), 201)\n    return result\n\n\nBULK_ATTEMPT_ID_HEADER = \"X-Bulk-Attempt-Id\"\n# Tighter than ``MAX_IDEMPOTENCY_KEY_LEN`` (255) because the token is\n# concatenated with ``:{i}`` to form the per-row ``client_request_id``\n# stored on every memory; 128 leaves comfortable room for a 100-item\n# batch (``:99`` adds 3 chars) while keeping the partial-unique index\n# leaves narrow.\nMAX_BULK_ATTEMPT_ID_LEN = 128\n_BULK_ATTEMPT_ID_PATTERN = re.compile(rf\"^[A-Za-z0-9._:\\-]{{1,{MAX_BULK_ATTEMPT_ID_LEN}}}$\")\n\n\n@router.post(\n    \"/memories/bulk\",\n    status_code=200,\n    # The route returns ``JSONResponse`` directly so it can vary the\n    # status code between 200 and 207, which strips FastAPI's automatic\n    # response-model inference. Declare both shapes explicitly so the\n    # OpenAPI doc keeps documenting the body for SDK generators.\n    responses={\n        200: {\"model\": BulkMemoryResponse},\n        207: {\"model\": BulkMemoryResponse},\n    },\n)\n@write_bulk_limit\nasync def write_memories_bulk(\n    request: Request,\n    body: BulkMemoryCreate,\n    response: Response,\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n    idempotency_key: str | None = Header(None, alias=IDEMPOTENCY_HEADER),\n    bulk_attempt_id: str | None = Header(None, alias=BULK_ATTEMPT_ID_HEADER),\n):\n    \"\"\"Write up to 100 memories with per-attempt idempotency (CAURA-602).\n\n    Required header ``X-Bulk-Attempt-Id`` identifies the *attempt*. A\n    retry of the same logical batch reuses the same value; storage's\n    per-item unique constraint then converts each row into either\n    ``created`` or ``duplicate_attempt`` deterministically. The route\n    returns:\n\n    - ``200`` when every item resolved as ``created``,\n      ``duplicate_attempt``, or ``duplicate_content``.\n    - ``207 Multi-Status`` when at least one item has ``status=\"error\"``\n      (validation, enrichment timeout, missing storage id) AND at least\n      one item succeeded — partial outcomes are explicit, never inferred\n      from a 5xx with side effects.\n    - ``200`` when every item is an error too — the request was processed\n      successfully; per-item ``status`` carries the rejection. We\n      deliberately don't reuse 422 here because FastAPI already emits\n      422 for request-body Pydantic validation, and clients that branch\n      on status code alone shouldn't have to disambiguate \"request was\n      malformed\" from \"request parsed and every item was rejected on\n      merit.\"\n    - ``504`` when the bulk-only budget burns before storage commits;\n      the response carries no per-item state, so a retry with the same\n      attempt id is the recovery path.\n\n    The pre-existing ``Idempotency-Key`` header still controls\n    *response*-level replay; ``X-Bulk-Attempt-Id`` is a separate\n    contract operating one layer down. Both are honoured: the header\n    cache short-circuits when the receipt is final, the per-row\n    constraint resolves the slow path when the receipt is missing or\n    pending.\n    \"\"\"\n    auth.enforce_read_only()\n    auth.enforce_usage_limits()\n    auth.enforce_tenant(body.tenant_id)\n    for _idx, _item in enumerate(body.items):\n        _reject_reserved_memory_type(_item.memory_type, index=_idx)\n\n    # Broker (kind=install_credential, ``mci_v1_…`` wire prefix) calls\n    # don't carry an attempt id header or an ``agent_id`` body field\n    # — the broker's own per-\n    # session ``client_hash`` de-dup is the design contract per\n    # cloud-data-plane.md §2.4 (gap G3). Server-derive a per-request\n    # attempt id and attribute writes to the install. Non-broker\n    # callers (dashboard, SDK) keep the CAURA-602 invariants in full.\n    if auth.is_install_credential:\n        if not bulk_attempt_id:\n            import uuid as _uuid\n\n            bulk_attempt_id = f\"broker-{auth.install_uuid or 'unknown'}-{_uuid.uuid4()}\"\n        if not body.agent_id:\n            body.agent_id = f\"broker:{auth.install_uuid or 'unknown'}\"\n    if not bulk_attempt_id:\n        # Required as of CAURA-602 — without it we can't make the bulk\n        # write retry-safe, and silent-create regressions reappear under\n        # any storage-side cancellation. Reject with a 4xx so SDKs see\n        # the breaking change, not a soft-fallback that masks the bug.\n        raise HTTPException(\n            status_code=400,\n            detail=f\"Missing required {BULK_ATTEMPT_ID_HEADER} header\",\n        )\n    if not _BULK_ATTEMPT_ID_PATTERN.match(bulk_attempt_id):\n        raise HTTPException(\n            status_code=400,\n            detail=(f\"Invalid {BULK_ATTEMPT_ID_HEADER}: must match ^[A-Za-z0-9._:\\\\-]{{1,128}}$\"),\n        )\n\n    # Idempotency replay short-circuits BEFORE the per-tenant slot — a\n    # cached retry must not consume a write-concurrency slot.\n    _idem = await idempotency_for(request, body.tenant_id, idempotency_key)\n    if _idem and (_replay := _idem.cached_replay):\n        _body, _status = _replay\n        # Replays bypass the per-tenant slot and the bulk\n        # quota-increment, so no rate-limit headers are available to\n        # carry on the cached response.\n        return JSONResponse(content=_body, status_code=_status)\n    async with per_tenant_slot(\"write\", body.tenant_id):\n        return await _write_memories_bulk_inner(body, response, auth, db, _idem, bulk_attempt_id)\n\n\ndef _bulk_response(result: BulkMemoryResponse) -> JSONResponse:\n    \"\"\"Pick HTTP status per CAURA-602 contract:\n\n    - 200 when there are no errors at all, OR every item is an error\n      (the request was processed; rejections are per-item business\n      logic, not a transport-level failure). Avoiding 422 here keeps\n      the route's response space disjoint from FastAPI's automatic\n      422-on-body-validation.\n    - 207 Multi-Status when the batch is mixed — at least one error\n      AND at least one resolved row. ``duplicate_attempt`` and\n      ``duplicate_content`` both count as resolved (they carry an\n      ``id``), so a batch of ``[error, duplicate_attempt]`` (i.e.\n      ``created=0, duplicates=1, errors=1``) is 207, not 200 — the\n      condition tests ``created == 0 and duplicates == 0`` *together*\n      so any duplicate keeps the response in the mixed bucket.\n\n    Always returns the body verbatim; per-item ``status`` carries the\n    real outcome, so the HTTP code is purely a hint for clients that\n    can branch on 2xx / 207.\n    \"\"\"\n    if result.errors == 0 or (result.created == 0 and result.duplicates == 0):\n        status_code = 200\n    else:\n        status_code = 207\n    return JSONResponse(content=result.model_dump(mode=\"json\"), status_code=status_code)\n\n\nasync def _write_memories_bulk_inner(\n    body: BulkMemoryCreate,\n    response: Response,\n    auth: AuthContext,\n    db: AsyncSession,\n    idem: IdempotencyGuard | None,\n    bulk_attempt_id: str,\n):\n    agent = await get_or_create_agent(db, body.tenant_id, body.agent_id, body.fleet_id)\n    if not body.fleet_id and agent.get(\"fleet_id\"):\n        body.fleet_id = agent[\"fleet_id\"]\n    usage = None\n    if auth.tenant_id:  # skip enforcement + metering for admin\n        await enforce_fleet_write(db, body.tenant_id, body.agent_id, body.fleet_id)\n        usage = await bulk_check_and_increment(db, body.tenant_id, len(body.items))\n    if usage:\n        response.headers[\"X-RateLimit-Limit\"] = str(usage.get(\"limit\", \"unlimited\"))\n        response.headers[\"X-RateLimit-Remaining\"] = str(usage.get(\"remaining\", \"unlimited\"))\n\n    try:\n        result = await asyncio.wait_for(\n            create_memories_bulk(db, body, bulk_attempt_id=bulk_attempt_id),\n            timeout=app_settings.bulk_request_timeout_seconds,\n        )\n    except (TimeoutError, httpx.TimeoutException):\n        # ``asyncio.wait_for`` documents raising ``asyncio.TimeoutError``,\n        # which Python 3.11 aliased to the builtin ``TimeoutError``.\n        # Project floor is 3.12 (``requires-python = \">=3.12\"``), so the\n        # builtin form is correct everywhere we run; ruff UP041 also\n        # mandates this shape. Anyone porting back to Python 3.10 must\n        # change this to ``except asyncio.TimeoutError:`` first.\n        #\n        # ``httpx.TimeoutException`` is the base for ReadTimeout /\n        # WriteTimeout / ConnectTimeout / PoolTimeout. The storage\n        # client's pool sets ``read=120s`` deliberately above the 90s\n        # ``bulk_request_timeout_seconds`` so the asyncio cancellation\n        # almost always wins the race, but we catch httpx timeouts here\n        # as a defence-in-depth fallback. Either path means the storage\n        # call may have committed without surfacing an id; the\n        # ``X-Bulk-Attempt-Id`` retry contract recovers it.\n        #\n        # The per-phase ``storage_bulk_timeout_seconds`` deadline (raised\n        # from ``asyncio.timeout`` inside ``create_memories_bulk``) also\n        # lands here as a plain ``TimeoutError`` — same recovery contract.\n        # Both caps are logged as static config values so the access-log\n        # entry is self-explanatory; the actual elapsed time on the\n        # request line distinguishes which timer fired (storage cap at\n        # ~25s elapsed vs umbrella at ~90s elapsed).\n        logger.warning(\n            \"bulk write timed out (storage cap %ss / request cap %ss); client should retry with same %s\",\n            app_settings.storage_bulk_timeout_seconds,\n            app_settings.bulk_request_timeout_seconds,\n            BULK_ATTEMPT_ID_HEADER,\n        )\n        # No per-item state to surface — the storage call may have\n        # committed some rows, none, or be still in flight. Do NOT\n        # record the idempotency receipt so a retry doesn't replay an\n        # incomplete answer; the per-item attempt-id is the recovery\n        # contract and a retry will resolve every committed row to\n        # ``duplicate_attempt`` with its canonical id.\n        raise HTTPException(\n            status_code=504,\n            detail=(\n                \"bulk write timed out before completing; retry with \"\n                f\"the same {BULK_ATTEMPT_ID_HEADER} to recover any \"\n                \"committed items.\"\n            ),\n        )\n    except httpx.HTTPStatusError as exc:\n        # Storage 5xx (raised by ``resp.raise_for_status()`` in the storage\n        # client) may have committed rows before failing — same shape as\n        # the timeout branch — so map to 504 to keep the\n        # ``X-Bulk-Attempt-Id`` retry contract intact. 4xx escapes here\n        # intentionally: it signals a request-shape problem the client\n        # must fix, not transient noise the retry path can recover from.\n        if not (500 <= exc.response.status_code < 600):\n            # Log so the 4xx path is observable in structured logs;\n            # without this, only FastAPI's generic unhandled-exception\n            # log surfaces and it has no bulk context.\n            logger.warning(\n                \"bulk write got unexpected %s from storage; this is a request-shape bug\",\n                exc.response.status_code,","lineStart":850,"lineEnd":1179,"totalLines":2023,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","time":{"start":1780727753135,"end":1780727753170}},"metadata":{"openai":{"itemId":"fc_014134f6ec7663c2016a23bfc906708191bfb41048e34371ba"}},"id":"prt_e9ba52973001WtDQU4AsJMd1o9","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","messageID":"msg_e9ba4ff3f001CdUWYpPZelMsqi"}}
{"type":"tool_use","timestamp":1780727753173,"sessionID":"ses_1645cad2dffe08ToAptcWOhE23","part":{"type":"tool","tool":"read","callID":"call_MdLs2NXm2xp2jxsftNBs1lc2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","offset":1320,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py</path>\n<type>file</type>\n<content>\n1320:         tenant_id=tenant_id,\n1321:         agent_id=memory.agent_id,\n1322:         action=\"status_update\",\n1323:         resource_type=\"memory\",\n1324:         resource_id=memory_id,\n1325:         detail={\"old_status\": old_status, \"new_status\": status},\n1326:     )\n1327:     await db.commit()\n1328:     return {\"memory_id\": str(memory_id), \"old_status\": old_status, \"new_status\": status}\n1329: \n1330: \n1331: @router.patch(\"/memories/{memory_id}\", response_model=MemoryOut)\n1332: async def update_memory_endpoint(\n1333:     memory_id: UUID,\n1334:     body: MemoryUpdate,\n1335:     tenant_id: str = Query(...),\n1336:     agent_id: str | None = Query(default=None),\n1337:     metadata_mode: str | None = Query(\n1338:         default=None,\n1339:         pattern=\"^(merge|replace)$\",\n1340:         description=(\n1341:             \"C7: alias for the body field of the same name. Body wins on \"\n1342:             \"conflict. When supplied as a query param without a matching \"\n1343:             \"``metadata`` field in the body, returns 422 (same contract \"\n1344:             \"as the body-side validator). Provided so SDK callers that \"\n1345:             \"thread the toggle through a URL query don't silently get \"\n1346:             \"the default merge behaviour.\"\n1347:         ),\n1348:     ),\n1349:     auth: AuthContext = Depends(get_auth_context),\n1350:     db: AsyncSession = Depends(get_db),\n1351: ):\n1352:     \"\"\"Update a memory. Only provide fields you want to change.\n1353: \n1354:     If content changes, embedding and entity extraction are re-run automatically.\n1355: \n1356:     Concurrency contract (intentional, not a bug):\n1357: \n1358:     - Each top-level column is **last-write-wins**. Two concurrent PATCHes that\n1359:       set the same column (e.g. ``title``) will both return 200 and the row\n1360:       will hold whichever update commits second. There is no compare-and-swap\n1361:       and no optimistic-lock token — callers that need that must coordinate\n1362:       externally or use ``If-Match`` semantics layered on top.\n1363:     - ``metadata`` defaults to a **JSONB top-level merge** (``||``): keys not\n1364:       present in the patch are preserved, keys present in both patches resolve\n1365:       last-write-wins per key. Pass ``metadata_mode: \"replace\"`` for a full\n1366:       overwrite. Two concurrent PATCHes that each set a distinct metadata key\n1367:       will therefore leave **both keys present** on the row — that is the\n1368:       defined behaviour, not a partial-merge anomaly.\n1369:     \"\"\"\n1370:     auth.enforce_tenant(tenant_id)\n1371:     # C7: propagate ``?metadata_mode=...`` query param into the body when\n1372:     # body didn't supply its own. Body wins on conflict, so a caller who\n1373:     # sends both ?metadata_mode=replace AND {\"metadata_mode\": \"merge\"} in\n1374:     # the body gets merge — the body field is the canonical write\n1375:     # payload, the query is a convenience shim. Mirror the body-side\n1376:     # validator (``metadata_mode_requires_metadata``) by rejecting the\n1377:     # query param when body has no ``metadata`` patch — sending only the\n1378:     # mode flag is a real-value no-op the validator already rejects.\n1379:     if metadata_mode is not None and body.metadata_mode is None:\n1380:         if \"metadata\" not in body.model_fields_set:\n1381:             raise HTTPException(\n1382:                 status_code=422,\n1383:                 detail=\"metadata_mode is only valid when metadata is also provided\",\n1384:             )\n1385:         body.metadata_mode = metadata_mode\n1386:     if auth.tenant_id:  # skip usage metering for admin\n1387:         await check_and_increment(db, tenant_id, \"write\")\n1388:     # Authenticated agent identity (gateway X-Agent-ID) takes precedence over\n1389:     # the caller-supplied query param for trust/fleet enforcement.\n1390:     return await update_memory(\n1391:         db,\n1392:         memory_id,\n1393:         tenant_id,\n1394:         body,\n1395:         agent_id=(auth.agent_id or agent_id) if auth.tenant_id else None,\n1396:     )\n1397: \n1398: \n1399: @router.post(\"/search\", response_model=SearchResponse)\n1400: @search_limit\n1401: async def search(\n1402:     request: Request,\n1403:     body: SearchRequest,\n1404:     response: Response,\n1405:     auth: AuthContext = Depends(get_auth_context),\n1406:     db: AsyncSession = Depends(get_db),\n1407: ):\n1408:     # Read endpoint — honors cross-tenant readable set. The SQL\n1409:     # widens to readable_tenant_ids inside search_memories so the\n\n(Showing lines 1320-1409 of 2023. Use offset=1410 to continue.)\n</content>","metadata":{"preview":"        tenant_id=tenant_id,\n        agent_id=memory.agent_id,\n        action=\"status_update\",\n        resource_type=\"memory\",\n        resource_id=memory_id,\n        detail={\"old_status\": old_status, \"new_status\": status},\n    )\n    await db.commit()\n    return {\"memory_id\": str(memory_id), \"old_status\": old_status, \"new_status\": status}\n\n\n@router.patch(\"/memories/{memory_id}\", response_model=MemoryOut)\nasync def update_memory_endpoint(\n    memory_id: UUID,\n    body: MemoryUpdate,\n    tenant_id: str = Query(...),\n    agent_id: str | None = Query(default=None),\n    metadata_mode: str | None = Query(\n        default=None,\n        pattern=\"^(merge|replace)$\",","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","text":"        tenant_id=tenant_id,\n        agent_id=memory.agent_id,\n        action=\"status_update\",\n        resource_type=\"memory\",\n        resource_id=memory_id,\n        detail={\"old_status\": old_status, \"new_status\": status},\n    )\n    await db.commit()\n    return {\"memory_id\": str(memory_id), \"old_status\": old_status, \"new_status\": status}\n\n\n@router.patch(\"/memories/{memory_id}\", response_model=MemoryOut)\nasync def update_memory_endpoint(\n    memory_id: UUID,\n    body: MemoryUpdate,\n    tenant_id: str = Query(...),\n    agent_id: str | None = Query(default=None),\n    metadata_mode: str | None = Query(\n        default=None,\n        pattern=\"^(merge|replace)$\",\n        description=(\n            \"C7: alias for the body field of the same name. Body wins on \"\n            \"conflict. When supplied as a query param without a matching \"\n            \"``metadata`` field in the body, returns 422 (same contract \"\n            \"as the body-side validator). Provided so SDK callers that \"\n            \"thread the toggle through a URL query don't silently get \"\n            \"the default merge behaviour.\"\n        ),\n    ),\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n):\n    \"\"\"Update a memory. Only provide fields you want to change.\n\n    If content changes, embedding and entity extraction are re-run automatically.\n\n    Concurrency contract (intentional, not a bug):\n\n    - Each top-level column is **last-write-wins**. Two concurrent PATCHes that\n      set the same column (e.g. ``title``) will both return 200 and the row\n      will hold whichever update commits second. There is no compare-and-swap\n      and no optimistic-lock token — callers that need that must coordinate\n      externally or use ``If-Match`` semantics layered on top.\n    - ``metadata`` defaults to a **JSONB top-level merge** (``||``): keys not\n      present in the patch are preserved, keys present in both patches resolve\n      last-write-wins per key. Pass ``metadata_mode: \"replace\"`` for a full\n      overwrite. Two concurrent PATCHes that each set a distinct metadata key\n      will therefore leave **both keys present** on the row — that is the\n      defined behaviour, not a partial-merge anomaly.\n    \"\"\"\n    auth.enforce_tenant(tenant_id)\n    # C7: propagate ``?metadata_mode=...`` query param into the body when\n    # body didn't supply its own. Body wins on conflict, so a caller who\n    # sends both ?metadata_mode=replace AND {\"metadata_mode\": \"merge\"} in\n    # the body gets merge — the body field is the canonical write\n    # payload, the query is a convenience shim. Mirror the body-side\n    # validator (``metadata_mode_requires_metadata``) by rejecting the\n    # query param when body has no ``metadata`` patch — sending only the\n    # mode flag is a real-value no-op the validator already rejects.\n    if metadata_mode is not None and body.metadata_mode is None:\n        if \"metadata\" not in body.model_fields_set:\n            raise HTTPException(\n                status_code=422,\n                detail=\"metadata_mode is only valid when metadata is also provided\",\n            )\n        body.metadata_mode = metadata_mode\n    if auth.tenant_id:  # skip usage metering for admin\n        await check_and_increment(db, tenant_id, \"write\")\n    # Authenticated agent identity (gateway X-Agent-ID) takes precedence over\n    # the caller-supplied query param for trust/fleet enforcement.\n    return await update_memory(\n        db,\n        memory_id,\n        tenant_id,\n        body,\n        agent_id=(auth.agent_id or agent_id) if auth.tenant_id else None,\n    )\n\n\n@router.post(\"/search\", response_model=SearchResponse)\n@search_limit\nasync def search(\n    request: Request,\n    body: SearchRequest,\n    response: Response,\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n):\n    # Read endpoint — honors cross-tenant readable set. The SQL\n    # widens to readable_tenant_ids inside search_memories so the","lineStart":1320,"lineEnd":1409,"totalLines":2023,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","time":{"start":1780727753144,"end":1780727753171}},"metadata":{"openai":{"itemId":"fc_014134f6ec7663c2016a23bfc90684819183b8185964ab18a2"}},"id":"prt_e9ba529b5001eMkS16DPTzUSdP","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","messageID":"msg_e9ba4ff3f001CdUWYpPZelMsqi"}}
{"type":"tool_use","timestamp":1780727753177,"sessionID":"ses_1645cad2dffe08ToAptcWOhE23","part":{"type":"tool","tool":"read","callID":"call_NDIZ3Kon7ey6LYp3HRyR7QBF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":990,"limit":470},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n990: \n991: \n992: async def create_memories_bulk(\n993:     db: AsyncSession,\n994:     data: BulkMemoryCreate,\n995:     *,\n996:     bulk_attempt_id: str,\n997: ) -> BulkMemoryResponse:\n998:     \"\"\"Create multiple memories with per-attempt idempotency (CAURA-602).\n999: \n1000:     The route binds each item to a stable ``client_request_id`` of the\n1001:     form ``f\"{bulk_attempt_id}:{index}\"``. Storage's per-item unique\n1002:     constraint then turns retries into deterministic outcomes:\n1003: \n1004:     - first attempt → ``status=\"created\"`` per item.\n1005:     - retry of the same ``X-Bulk-Attempt-Id`` after a lost response →\n1006:       every previously-committed row resolves to ``duplicate_attempt``\n1007:       with the canonical id, so no row is ever silently committed.\n1008:     - same content already exists from an earlier *different* attempt →\n1009:       ``duplicate_content``, matching today's content-hash dedup\n1010:       semantics.\n1011:     - validation, embed/enrich budget, or storage-side missing id →\n1012:       ``error`` per item.\n1013: \n1014:     Embed + enrich + content-hash pre-dedup runs as before; the storage\n1015:     call returns one entry per surviving item, and we map by\n1016:     ``client_request_id`` so input order is preserved without relying on\n1017:     Postgres ``RETURNING`` order.\n1018:     \"\"\"\n1019:     sc = get_storage_client()\n1020:     t0 = time.perf_counter()\n1021:     items = data.items\n1022:     n = len(items)\n1023: \n1024:     # -- Per-item validation. Short content used to raise a 422 for the\n1025:     # whole batch; now it's a per-item \"error\" result. Indices in this\n1026:     # dict are skipped through the embed / enrich / dedup / write path.\n1027:     short_content_errors: dict[int, str] = {\n1028:         i: f\"content too short (minimum {CRYSTALLIZER_SHORT_CONTENT_CHARS} characters)\"\n1029:         for i, item in enumerate(items)\n1030:         if len(item.content.strip()) < CRYSTALLIZER_SHORT_CONTENT_CHARS\n1031:     }\n1032: \n1033:     # -- Resolve per-tenant config once --\n1034:     from core_api.services.organization_settings import resolve_config\n1035: \n1036:     tenant_config = await resolve_config(db, data.tenant_id)\n1037: \n1038:     # -- Batch embeddings + parallel enrichment (valid items only). Short\n1039:     # items are skipped so we don't spend provider budget on content\n1040:     # that will surface as an error anyway.\n1041:     valid_indices = [i for i in range(n) if i not in short_content_errors]\n1042:     embeddings: list = [None] * n\n1043:     if valid_indices and settings.inline_embedding:\n1044:         try:\n1045:             async with asyncio.timeout(BULK_EMBEDDING_TIMEOUT_SECONDS):\n1046:                 valid_embeddings = await get_embeddings_batch(\n1047:                     [items[i].content for i in valid_indices], tenant_config\n1048:                 )\n1049:         except TimeoutError:\n1050:             raise HTTPException(status_code=504, detail=\"Bulk embedding timed out\")\n1051:         for emb_pos, item_idx in enumerate(valid_indices):\n1052:             embeddings[item_idx] = valid_embeddings[emb_pos]\n1053: \n1054:     enrichments: list = [None] * n\n1055:     # CAURA-595: ``deployment_mode=deferred`` defers the LLM call to\n1056:     # ``core-worker``; the bulk-persist loop below still proceeds with\n1057:     # all-None enrichments and the publish happens post-persist (one\n1058:     # event per successfully-created row).\n1059:     if (\n1060:         valid_indices\n1061:         and settings.inline_enrichment\n1062:         and tenant_config.enrichment_enabled\n1063:         and tenant_config.enrichment_provider != \"none\"\n1064:     ):\n1065:         from core_api.services.memory_enrichment import enrich_memory\n1066: \n1067:         sem = asyncio.Semaphore(BULK_ENRICHMENT_CONCURRENCY)\n1068: \n1069:         async def _enrich(idx: int):\n1070:             async with sem:\n1071:                 try:\n1072:                     enrichments[idx] = await enrich_memory(\n1073:                         items[idx].content,\n1074:                         tenant_config,\n1075:                         reference_datetime=items[idx].reference_datetime,\n1076:                     )\n1077:                 except (ValueError, RuntimeError, OpenAIError, GoogleAPIError):\n1078:                     logger.warning(\"Enrichment failed for bulk item %d\", idx)\n1079: \n1080:         try:\n1081:             async with asyncio.timeout(BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS):\n1082:                 await asyncio.gather(*[_enrich(i) for i in valid_indices])\n1083:         except TimeoutError:\n1084:             logger.warning(\n1085:                 \"Bulk enrichment exceeded %ss budget; proceeding with partial results\",\n1086:                 BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS,\n1087:             )\n1088: \n1089:     # -- Batch hash dedup: compute all hashes, query storage API in one shot.\n1090:     # Storage returns ``{content_hash: {id, client_request_id}}`` so the\n1091:     # per-item classifier below can split content matches into\n1092:     # ``duplicate_attempt`` (this caller's own prior commit) vs\n1093:     # ``duplicate_content`` (a different attempt's row).\n1094:     hashes = [_content_hash(data.tenant_id, data.fleet_id, item.content) for item in items]\n1095: \n1096:     existing_hashes: dict[str, dict] = {}\n1097:     if hashes:\n1098:         # Stage 5: scope bulk dedup to (tenant, fleet, agent) so a batch\n1099:         # from agent-A and a batch from agent-B in the same fleet don't\n1100:         # collide on identical content.\n1101:         existing_hashes = await sc.bulk_find_by_content_hashes(\n1102:             data.tenant_id,\n1103:             hashes,\n1104:             fleet_id=data.fleet_id,\n1105:             agent_id=data.agent_id,\n1106:         )\n1107: \n1108:     # -- Also detect intra-batch duplicates (same content appearing twice) --\n1109:     seen_hashes: dict[str, int] = {}  # hash -> first index\n1110: \n1111:     # -- Build memories and track results --\n1112:     results: list[BulkItemResult | None] = [None] * n\n1113:     # Each queued entry pairs the original input index with the row dict\n1114:     # we'll send to storage. Carrying ``orig_idx`` alongside the dict\n1115:     # avoids a parallel ``memory_index_map`` list, and the dict isn't\n1116:     # mutated with the index because storage's column-filter would drop\n1117:     # an unknown key on the way in.\n1118:     pending: list[tuple[int, dict]] = []\n1119:     created_count = 0\n1120:     dup_count = 0\n1121:     error_count = 0\n1122: \n1123:     for i, item in enumerate(items):\n1124:         # Server-derived per-item attempt id. Stable across retries\n1125:         # because ``bulk_attempt_id`` is the client-supplied\n1126:         # ``X-Bulk-Attempt-Id`` and the index is positional within the\n1127:         # request body — same body + same attempt id ⇒ same per-item id.\n1128:         item_request_id = f\"{bulk_attempt_id}:{i}\"\n1129: \n1130:         # Short-content items surface as per-item errors; never embedded,\n1131:         # enriched, deduped, or written.\n1132:         if i in short_content_errors:\n1133:             results[i] = BulkItemResult(\n1134:                 index=i,\n1135:                 client_request_id=item_request_id,\n1136:                 status=\"error\",\n1137:                 error=short_content_errors[i],\n1138:             )\n1139:             error_count += 1\n1140:             continue\n1141: \n1142:         ch = hashes[i]\n1143: \n1144:         # An existing row matches this content. Two flavours:\n1145:         #   - ``duplicate_attempt``: the stored row's\n1146:         #     ``client_request_id`` equals the per-item id we're about\n1147:         #     to claim — i.e. *this* caller's prior commit landed and\n1148:         #     we're seeing our own retry. ``duplicate_of`` is omitted\n1149:         #     because the row IS this attempt's row, not a foreign one.\n1150:         #   - ``duplicate_content``: a different attempt (or a legacy\n1151:         #     row with NULL ``client_request_id``) wrote the same\n1152:         #     content first. Same semantics as the pre-CAURA-602\n1153:         #     ``\"duplicate\"`` state.\n1154:         if ch in existing_hashes:\n1155:             existing = existing_hashes[ch]\n1156:             existing_id = existing[\"id\"]\n1157:             # Subscript (not ``.get()``) so a future router shape\n1158:             # regression that drops the key surfaces as KeyError instead\n1159:             # of silently misclassifying every retry as\n1160:             # ``duplicate_content``. The router is the contract owner;\n1161:             # see ``bulk_find_by_content_hashes`` in\n1162:             # core-storage-api/routers/memories.py.\n1163:             if existing[\"client_request_id\"] == item_request_id:\n1164:                 results[i] = BulkItemResult(\n1165:                     index=i,\n1166:                     client_request_id=item_request_id,\n1167:                     status=\"duplicate_attempt\",\n1168:                     id=existing_id,\n1169:                 )\n1170:             else:\n1171:                 results[i] = BulkItemResult(\n1172:                     index=i,\n1173:                     client_request_id=item_request_id,\n1174:                     status=\"duplicate_content\",\n1175:                     id=existing_id,\n1176:                     duplicate_of=existing_id,\n1177:                 )\n1178:             dup_count += 1\n1179:             continue\n1180: \n1181:         # Intra-batch duplicate: two items with identical content in\n1182:         # the same call. Surface as ``duplicate_content`` for caller\n1183:         # consistency with the cross-batch case — both states mean\n1184:         # \"this row was not the canonical writer of the content.\"\n1185:         if ch in seen_hashes:\n1186:             results[i] = BulkItemResult(\n1187:                 index=i,\n1188:                 client_request_id=item_request_id,\n1189:                 status=\"duplicate_content\",\n1190:             )\n1191:             dup_count += 1\n1192:             continue\n1193:         seen_hashes[ch] = i\n1194: \n1195:         # Apply enrichment\n1196:         enrichment = enrichments[i]\n1197:         memory_type = item.memory_type\n1198:         weight = item.weight\n1199:         title = None\n1200:         metadata = item.metadata or {}\n1201:         ts_valid_start = item.ts_valid_start\n1202:         ts_valid_end = item.ts_valid_end\n1203: \n1204:         if enrichment:\n1205:             if memory_type is None:\n1206:                 memory_type = enrichment.memory_type\n1207:             if weight is None:\n1208:                 weight = enrichment.weight\n1209:             title = enrichment.title or None\n1210:             if enrichment.summary:\n1211:                 metadata[\"summary\"] = enrichment.summary\n1212:             if enrichment.tags:\n1213:                 metadata[\"tags\"] = enrichment.tags\n1214:             if enrichment.llm_ms:\n1215:                 metadata[\"llm_ms\"] = enrichment.llm_ms\n1216:             if ts_valid_start is None and enrichment.ts_valid_start:\n1217:                 ts_valid_start = datetime.fromisoformat(enrichment.ts_valid_start.replace(\"Z\", \"+00:00\"))\n1218:             if ts_valid_end is None and enrichment.ts_valid_end:\n1219:                 ts_valid_end = datetime.fromisoformat(enrichment.ts_valid_end.replace(\"Z\", \"+00:00\"))\n1220:             if enrichment.contains_pii:\n1221:                 metadata[\"contains_pii\"] = True\n1222:                 if enrichment.pii_types:\n1223:                     metadata[\"pii_types\"] = enrichment.pii_types\n1224: \n1225:         if memory_type is None:\n1226:             memory_type = \"fact\"\n1227:         if weight is None:\n1228:             weight = DEFAULT_MEMORY_WEIGHT\n1229: \n1230:         status = item.status\n1231:         if not status and enrichment:\n1232:             status = getattr(enrichment, \"status\", None)\n1233:         if not status:\n1234:             status = \"active\"\n1235: \n1236:         entity_link_dicts = [\n1237:             {\"entity_id\": str(link.entity_id), \"role\": link.role} for link in item.entity_links\n1238:         ]\n1239: \n1240:         mem_data = {\n1241:             \"tenant_id\": data.tenant_id,\n1242:             \"fleet_id\": data.fleet_id,\n1243:             \"agent_id\": data.agent_id,\n1244:             \"memory_type\": memory_type,\n1245:             \"title\": title,\n1246:             \"content\": item.content,\n1247:             \"embedding\": embeddings[i],\n1248:             \"weight\": weight,\n1249:             \"source_uri\": item.source_uri,\n1250:             \"run_id\": item.run_id,\n1251:             # See ``write_memory_row`` for the falsy-``{}`` trap. The\n1252:             # bulk path doesn't append ``write_latency_ms`` so an item\n1253:             # with ``item.metadata={}`` and no enrichment-added keys\n1254:             # genuinely reaches here as ``{}`` — pass it through so the\n1255:             # column stores ``{}`` instead of NULL.\n1256:             \"metadata_\": metadata,\n1257:             \"content_hash\": ch,\n1258:             \"client_request_id\": item_request_id,\n1259:             \"expires_at\": item.expires_at.isoformat() if item.expires_at else None,\n1260:             \"subject_entity_id\": item.subject_entity_id,\n1261:             \"predicate\": item.predicate,\n1262:             \"object_value\": item.object_value,\n1263:             \"ts_valid_start\": ts_valid_start.isoformat() if ts_valid_start else None,\n1264:             \"ts_valid_end\": ts_valid_end.isoformat() if ts_valid_end else None,\n1265:             \"status\": status,\n1266:             \"visibility\": data.visibility or \"scope_team\",\n1267:             \"entity_links\": entity_link_dicts,\n1268:         }\n1269:         pending.append((i, mem_data))\n1270: \n1271:     # -- Bulk insert via storage client. The storage layer returns one\n1272:     # entry per submitted item with ``was_inserted`` distinguishing\n1273:     # newly-committed rows from those resolved against a prior attempt's\n1274:     # commit (the silent-create eliminator). The legacy ReadTimeout\n1275:     # reconcile branch is intentionally gone — its job is now done at\n1276:     # the row level by the per-attempt unique constraint, and a retry of\n1277:     # the entire request is the documented recovery path.\n1278:     #\n1279:     # Per-tenant storage bulkhead (CAURA-602 follow-up): the slot wraps\n1280:     # only the storage roundtrip itself, holding tight while the call\n1281:     # is in flight and releasing as soon as the storage response (or\n1282:     # cancellation) returns. Embed/enrich already finished above and\n1283:     # the audit/contradiction/reembed fan-out below runs as\n1284:     # fire-and-forget tasks, so the slot's grip on storage stays tight\n1285:     # even for long-tail batches.\n1286:     if pending:\n1287:         # Per-phase deadline on the storage roundtrip itself (CAURA-599).\n1288:         # Without this the only deadline on this phase is the outer\n1289:         # ``bulk_request_timeout_seconds`` umbrella in the route handler;\n1290:         # a hung storage call would consume any unused embed/enrich slack\n1291:         # before the 504 path fires.\n1292:         #\n1293:         # Order matters: ``asyncio.timeout`` is the OUTER context manager\n1294:         # so the deadline arms before ``per_tenant_storage_slot`` calls\n1295:         # ``asyncio.Semaphore.acquire()`` (which blocks indefinitely under\n1296:         # contention). Compound ``async with (A, B):`` enters left-to-right,\n1297:         # so swapping the order would leave the slot wait outside the\n1298:         # deadline. Cancellation during a queued acquire raises cleanly\n1299:         # from inside the semaphore's __aenter__ — no slot is held, so\n1300:         # no release is needed on the timeout path.\n1301:         async with (\n1302:             asyncio.timeout(settings.storage_bulk_timeout_seconds),\n1303:             per_tenant_storage_slot(\"storage_write\", data.tenant_id),\n1304:         ):\n1305:             storage_results = await sc.create_memories([d for _, d in pending])\n1306: \n1307:         # Map each storage result back to its source item via\n1308:         # ``client_request_id``. Postgres ``RETURNING`` order is\n1309:         # unspecified for ``ON CONFLICT DO NOTHING``, so we never\n1310:         # zip on positional index.\n1311:         by_request_id = {r[\"client_request_id\"]: r for r in storage_results}\n1312: \n1313:         # Track the (orig_idx, mem_data, mem_id) trios for the\n1314:         # successfully-resolved items so the audit log + background\n1315:         # task loops below operate on rows that actually exist.\n1316:         resolved: list[tuple[int, dict, str]] = []\n1317: \n1318:         for orig_idx, mem_data in pending:\n1319:             crid = mem_data[\"client_request_id\"]\n1320:             sr = by_request_id.get(crid)\n1321:             if sr is None or not sr.get(\"id\"):\n1322:                 # Storage didn't return a row for this id — concurrent\n1323:                 # soft-delete or schema drift. Surface as per-item\n1324:                 # error rather than fabricating an id.\n1325:                 results[orig_idx] = BulkItemResult(\n1326:                     index=orig_idx,\n1327:                     client_request_id=crid,\n1328:                     status=\"error\",\n1329:                     error=\"storage did not return an id for this item\",\n1330:                 )\n1331:                 error_count += 1\n1332:                 continue\n1333: \n1334:             mem_id = sr[\"id\"]\n1335:             if sr.get(\"was_inserted\"):\n1336:                 results[orig_idx] = BulkItemResult(\n1337:                     index=orig_idx,\n1338:                     client_request_id=crid,\n1339:                     status=\"created\",\n1340:                     id=mem_id,\n1341:                 )\n1342:                 created_count += 1\n1343:                 resolved.append((orig_idx, mem_data, mem_id))\n1344:             else:\n1345:                 # Same attempt id already committed — i.e. a retry. The\n1346:                 # row exists; we don't re-run audit / entity-extraction\n1347:                 # / contradiction tasks for it because the original\n1348:                 # attempt already kicked those off (or will, if its\n1349:                 # tracked tasks haven't drained yet).\n1350:                 results[orig_idx] = BulkItemResult(\n1351:                     index=orig_idx,\n1352:                     client_request_id=crid,\n1353:                     status=\"duplicate_attempt\",\n1354:                     id=mem_id,\n1355:                 )\n1356:                 dup_count += 1\n1357: \n1358:         # Back-fill ``id`` / ``duplicate_of`` on intra-batch\n1359:         # ``duplicate_content`` rows. The first-occurrence loop above\n1360:         # marks them with no canonical id — at the time we couldn't\n1361:         # know it, since the canonical row hadn't been written yet.\n1362:         # Now that ``results[seen_hashes[ch]]`` carries the storage id\n1363:         # (whether it's ``created`` or ``duplicate_attempt``), copy it\n1364:         # forward so the ``BulkItemResult`` docstring contract holds:\n1365:         # ``duplicate_content`` always has both fields populated.\n1366:         for j in range(n):\n1367:             later = results[j]\n1368:             if later is None or later.status != \"duplicate_content\" or later.id is not None:\n1369:                 continue\n1370:             canonical = results[seen_hashes[hashes[j]]]\n1371:             if canonical is None or canonical.id is None:\n1372:                 # Canonical row never persisted (storage error) — leaving\n1373:                 # this slot as a contract-violating\n1374:                 # ``duplicate_content`` with both id fields ``None``\n1375:                 # would silently break clients that branch on status.\n1376:                 # Downgrade to ``error`` and rebalance the aggregate\n1377:                 # counts: we'd previously incremented ``dup_count`` for\n1378:                 # this item, undo that.\n1379:                 results[j] = BulkItemResult(\n1380:                     index=j,\n1381:                     client_request_id=later.client_request_id,\n1382:                     status=\"error\",\n1383:                     error=\"canonical row for intra-batch duplicate did not persist\",\n1384:                 )\n1385:                 dup_count -= 1\n1386:                 error_count += 1\n1387:                 continue\n1388:             results[j] = BulkItemResult(\n1389:                 index=j,\n1390:                 client_request_id=later.client_request_id,\n1391:                 status=\"duplicate_content\",\n1392:                 id=canonical.id,\n1393:                 duplicate_of=canonical.id,\n1394:             )\n1395: \n1396:         # Bulk audit log — only for newly-inserted rows. Fire-and-forget\n1397:         # so a parent ``asyncio.wait_for`` cancellation (e.g. the 90s\n1398:         # bulk budget firing after storage commits but before the\n1399:         # in-flight audit call returns) can't strand committed rows\n1400:         # without their audit records: the retry sees those rows as\n1401:         # ``duplicate_attempt`` and never re-enters this block, so the\n1402:         # audit had to land on the original attempt or it's lost. The\n1403:         # tasks reference ``data.tenant_id`` etc. by value, not the\n1404:         # request-scoped ``db`` session (``log_action`` doesn't actually\n1405:         # touch ``db`` — it calls ``sc.create_audit_log`` over HTTP),\n1406:         # so a teardown of the request context after cancellation\n1407:         # doesn't affect them.\n1408:         _hooks = get_hooks()\n1409:         if _hooks.audit_log:\n1410:             for _orig_idx, mem_data, mem_id in resolved:\n1411:                 track_task(\n1412:                     tracked_task(\n1413:                         _hooks.audit_log(\n1414:                             db,\n1415:                             tenant_id=data.tenant_id,\n1416:                             agent_id=data.agent_id,\n1417:                             action=\"create\",\n1418:                             resource_type=\"memory\",\n1419:                             resource_id=mem_id,\n1420:                             detail={\n1421:                                 \"memory_type\": mem_data[\"memory_type\"],\n1422:                                 \"title\": mem_data.get(\"title\"),\n1423:                                 \"content_length\": len(mem_data[\"content\"]),\n1424:                                 \"source\": \"bulk\",\n1425:                             },\n1426:                         ),\n1427:                         \"audit_log\",\n1428:                         mem_id,\n1429:                         data.tenant_id,\n1430:                     )\n1431:                 )\n1432: \n1433:         # Fire-and-forget async tasks for each newly-created memory.\n1434:         # ``duplicate_attempt`` rows skip these — the original attempt\n1435:         # already enqueued them (and re-running would double-bill the\n1436:         # LLM provider for entity extraction + enrichment).\n1437:         from core_api.services.contradiction_detector import detect_contradictions_async\n1438: \n1439:         # CAURA-595: per-row enrich publishes when deployment_mode is deferred.\n1440:         defer_enrich_publish = (\n1441:             not settings.inline_enrichment\n1442:             and tenant_config.enrichment_enabled\n1443:             and tenant_config.enrichment_provider != \"none\"\n1444:         )\n1445: \n1446:         reembed_batch: list[tuple[UUID, str]] = []\n1447:         for orig_idx, mem_data, mem_id in resolved:\n1448:             if tenant_config.entity_extraction_enabled:\n1449:                 track_task(\n1450:                     tracked_task(\n1451:                         process_entity_extraction(\n1452:                             mem_id,\n1453:                             data.tenant_id,\n1454:                             data.fleet_id,\n1455:                             data.agent_id,\n1456:                             items[orig_idx].content,\n1457:                             mem_data[\"memory_type\"],\n1458:                         ),\n1459:                         \"entity_extraction\",\n\n(Showing lines 990-1459 of 3230. Use offset=1460 to continue.)\n</content>","metadata":{"preview":"\n\nasync def create_memories_bulk(\n    db: AsyncSession,\n    data: BulkMemoryCreate,\n    *,\n    bulk_attempt_id: str,\n) -> BulkMemoryResponse:\n    \"\"\"Create multiple memories with per-attempt idempotency (CAURA-602).\n\n    The route binds each item to a stable ``client_request_id`` of the\n    form ``f\"{bulk_attempt_id}:{index}\"``. Storage's per-item unique\n    constraint then turns retries into deterministic outcomes:\n\n    - first attempt → ``status=\"created\"`` per item.\n    - retry of the same ``X-Bulk-Attempt-Id`` after a lost response →\n      every previously-committed row resolves to ``duplicate_attempt``\n      with the canonical id, so no row is ever silently committed.\n    - same content already exists from an earlier *different* attempt →\n      ``duplicate_content``, matching today's content-hash dedup","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"\n\nasync def create_memories_bulk(\n    db: AsyncSession,\n    data: BulkMemoryCreate,\n    *,\n    bulk_attempt_id: str,\n) -> BulkMemoryResponse:\n    \"\"\"Create multiple memories with per-attempt idempotency (CAURA-602).\n\n    The route binds each item to a stable ``client_request_id`` of the\n    form ``f\"{bulk_attempt_id}:{index}\"``. Storage's per-item unique\n    constraint then turns retries into deterministic outcomes:\n\n    - first attempt → ``status=\"created\"`` per item.\n    - retry of the same ``X-Bulk-Attempt-Id`` after a lost response →\n      every previously-committed row resolves to ``duplicate_attempt``\n      with the canonical id, so no row is ever silently committed.\n    - same content already exists from an earlier *different* attempt →\n      ``duplicate_content``, matching today's content-hash dedup\n      semantics.\n    - validation, embed/enrich budget, or storage-side missing id →\n      ``error`` per item.\n\n    Embed + enrich + content-hash pre-dedup runs as before; the storage\n    call returns one entry per surviving item, and we map by\n    ``client_request_id`` so input order is preserved without relying on\n    Postgres ``RETURNING`` order.\n    \"\"\"\n    sc = get_storage_client()\n    t0 = time.perf_counter()\n    items = data.items\n    n = len(items)\n\n    # -- Per-item validation. Short content used to raise a 422 for the\n    # whole batch; now it's a per-item \"error\" result. Indices in this\n    # dict are skipped through the embed / enrich / dedup / write path.\n    short_content_errors: dict[int, str] = {\n        i: f\"content too short (minimum {CRYSTALLIZER_SHORT_CONTENT_CHARS} characters)\"\n        for i, item in enumerate(items)\n        if len(item.content.strip()) < CRYSTALLIZER_SHORT_CONTENT_CHARS\n    }\n\n    # -- Resolve per-tenant config once --\n    from core_api.services.organization_settings import resolve_config\n\n    tenant_config = await resolve_config(db, data.tenant_id)\n\n    # -- Batch embeddings + parallel enrichment (valid items only). Short\n    # items are skipped so we don't spend provider budget on content\n    # that will surface as an error anyway.\n    valid_indices = [i for i in range(n) if i not in short_content_errors]\n    embeddings: list = [None] * n\n    if valid_indices and settings.inline_embedding:\n        try:\n            async with asyncio.timeout(BULK_EMBEDDING_TIMEOUT_SECONDS):\n                valid_embeddings = await get_embeddings_batch(\n                    [items[i].content for i in valid_indices], tenant_config\n                )\n        except TimeoutError:\n            raise HTTPException(status_code=504, detail=\"Bulk embedding timed out\")\n        for emb_pos, item_idx in enumerate(valid_indices):\n            embeddings[item_idx] = valid_embeddings[emb_pos]\n\n    enrichments: list = [None] * n\n    # CAURA-595: ``deployment_mode=deferred`` defers the LLM call to\n    # ``core-worker``; the bulk-persist loop below still proceeds with\n    # all-None enrichments and the publish happens post-persist (one\n    # event per successfully-created row).\n    if (\n        valid_indices\n        and settings.inline_enrichment\n        and tenant_config.enrichment_enabled\n        and tenant_config.enrichment_provider != \"none\"\n    ):\n        from core_api.services.memory_enrichment import enrich_memory\n\n        sem = asyncio.Semaphore(BULK_ENRICHMENT_CONCURRENCY)\n\n        async def _enrich(idx: int):\n            async with sem:\n                try:\n                    enrichments[idx] = await enrich_memory(\n                        items[idx].content,\n                        tenant_config,\n                        reference_datetime=items[idx].reference_datetime,\n                    )\n                except (ValueError, RuntimeError, OpenAIError, GoogleAPIError):\n                    logger.warning(\"Enrichment failed for bulk item %d\", idx)\n\n        try:\n            async with asyncio.timeout(BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS):\n                await asyncio.gather(*[_enrich(i) for i in valid_indices])\n        except TimeoutError:\n            logger.warning(\n                \"Bulk enrichment exceeded %ss budget; proceeding with partial results\",\n                BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS,\n            )\n\n    # -- Batch hash dedup: compute all hashes, query storage API in one shot.\n    # Storage returns ``{content_hash: {id, client_request_id}}`` so the\n    # per-item classifier below can split content matches into\n    # ``duplicate_attempt`` (this caller's own prior commit) vs\n    # ``duplicate_content`` (a different attempt's row).\n    hashes = [_content_hash(data.tenant_id, data.fleet_id, item.content) for item in items]\n\n    existing_hashes: dict[str, dict] = {}\n    if hashes:\n        # Stage 5: scope bulk dedup to (tenant, fleet, agent) so a batch\n        # from agent-A and a batch from agent-B in the same fleet don't\n        # collide on identical content.\n        existing_hashes = await sc.bulk_find_by_content_hashes(\n            data.tenant_id,\n            hashes,\n            fleet_id=data.fleet_id,\n            agent_id=data.agent_id,\n        )\n\n    # -- Also detect intra-batch duplicates (same content appearing twice) --\n    seen_hashes: dict[str, int] = {}  # hash -> first index\n\n    # -- Build memories and track results --\n    results: list[BulkItemResult | None] = [None] * n\n    # Each queued entry pairs the original input index with the row dict\n    # we'll send to storage. Carrying ``orig_idx`` alongside the dict\n    # avoids a parallel ``memory_index_map`` list, and the dict isn't\n    # mutated with the index because storage's column-filter would drop\n    # an unknown key on the way in.\n    pending: list[tuple[int, dict]] = []\n    created_count = 0\n    dup_count = 0\n    error_count = 0\n\n    for i, item in enumerate(items):\n        # Server-derived per-item attempt id. Stable across retries\n        # because ``bulk_attempt_id`` is the client-supplied\n        # ``X-Bulk-Attempt-Id`` and the index is positional within the\n        # request body — same body + same attempt id ⇒ same per-item id.\n        item_request_id = f\"{bulk_attempt_id}:{i}\"\n\n        # Short-content items surface as per-item errors; never embedded,\n        # enriched, deduped, or written.\n        if i in short_content_errors:\n            results[i] = BulkItemResult(\n                index=i,\n                client_request_id=item_request_id,\n                status=\"error\",\n                error=short_content_errors[i],\n            )\n            error_count += 1\n            continue\n\n        ch = hashes[i]\n\n        # An existing row matches this content. Two flavours:\n        #   - ``duplicate_attempt``: the stored row's\n        #     ``client_request_id`` equals the per-item id we're about\n        #     to claim — i.e. *this* caller's prior commit landed and\n        #     we're seeing our own retry. ``duplicate_of`` is omitted\n        #     because the row IS this attempt's row, not a foreign one.\n        #   - ``duplicate_content``: a different attempt (or a legacy\n        #     row with NULL ``client_request_id``) wrote the same\n        #     content first. Same semantics as the pre-CAURA-602\n        #     ``\"duplicate\"`` state.\n        if ch in existing_hashes:\n            existing = existing_hashes[ch]\n            existing_id = existing[\"id\"]\n            # Subscript (not ``.get()``) so a future router shape\n            # regression that drops the key surfaces as KeyError instead\n            # of silently misclassifying every retry as\n            # ``duplicate_content``. The router is the contract owner;\n            # see ``bulk_find_by_content_hashes`` in\n            # core-storage-api/routers/memories.py.\n            if existing[\"client_request_id\"] == item_request_id:\n                results[i] = BulkItemResult(\n                    index=i,\n                    client_request_id=item_request_id,\n                    status=\"duplicate_attempt\",\n                    id=existing_id,\n                )\n            else:\n                results[i] = BulkItemResult(\n                    index=i,\n                    client_request_id=item_request_id,\n                    status=\"duplicate_content\",\n                    id=existing_id,\n                    duplicate_of=existing_id,\n                )\n            dup_count += 1\n            continue\n\n        # Intra-batch duplicate: two items with identical content in\n        # the same call. Surface as ``duplicate_content`` for caller\n        # consistency with the cross-batch case — both states mean\n        # \"this row was not the canonical writer of the content.\"\n        if ch in seen_hashes:\n            results[i] = BulkItemResult(\n                index=i,\n                client_request_id=item_request_id,\n                status=\"duplicate_content\",\n            )\n            dup_count += 1\n            continue\n        seen_hashes[ch] = i\n\n        # Apply enrichment\n        enrichment = enrichments[i]\n        memory_type = item.memory_type\n        weight = item.weight\n        title = None\n        metadata = item.metadata or {}\n        ts_valid_start = item.ts_valid_start\n        ts_valid_end = item.ts_valid_end\n\n        if enrichment:\n            if memory_type is None:\n                memory_type = enrichment.memory_type\n            if weight is None:\n                weight = enrichment.weight\n            title = enrichment.title or None\n            if enrichment.summary:\n                metadata[\"summary\"] = enrichment.summary\n            if enrichment.tags:\n                metadata[\"tags\"] = enrichment.tags\n            if enrichment.llm_ms:\n                metadata[\"llm_ms\"] = enrichment.llm_ms\n            if ts_valid_start is None and enrichment.ts_valid_start:\n                ts_valid_start = datetime.fromisoformat(enrichment.ts_valid_start.replace(\"Z\", \"+00:00\"))\n            if ts_valid_end is None and enrichment.ts_valid_end:\n                ts_valid_end = datetime.fromisoformat(enrichment.ts_valid_end.replace(\"Z\", \"+00:00\"))\n            if enrichment.contains_pii:\n                metadata[\"contains_pii\"] = True\n                if enrichment.pii_types:\n                    metadata[\"pii_types\"] = enrichment.pii_types\n\n        if memory_type is None:\n            memory_type = \"fact\"\n        if weight is None:\n            weight = DEFAULT_MEMORY_WEIGHT\n\n        status = item.status\n        if not status and enrichment:\n            status = getattr(enrichment, \"status\", None)\n        if not status:\n            status = \"active\"\n\n        entity_link_dicts = [\n            {\"entity_id\": str(link.entity_id), \"role\": link.role} for link in item.entity_links\n        ]\n\n        mem_data = {\n            \"tenant_id\": data.tenant_id,\n            \"fleet_id\": data.fleet_id,\n            \"agent_id\": data.agent_id,\n            \"memory_type\": memory_type,\n            \"title\": title,\n            \"content\": item.content,\n            \"embedding\": embeddings[i],\n            \"weight\": weight,\n            \"source_uri\": item.source_uri,\n            \"run_id\": item.run_id,\n            # See ``write_memory_row`` for the falsy-``{}`` trap. The\n            # bulk path doesn't append ``write_latency_ms`` so an item\n            # with ``item.metadata={}`` and no enrichment-added keys\n            # genuinely reaches here as ``{}`` — pass it through so the\n            # column stores ``{}`` instead of NULL.\n            \"metadata_\": metadata,\n            \"content_hash\": ch,\n            \"client_request_id\": item_request_id,\n            \"expires_at\": item.expires_at.isoformat() if item.expires_at else None,\n            \"subject_entity_id\": item.subject_entity_id,\n            \"predicate\": item.predicate,\n            \"object_value\": item.object_value,\n            \"ts_valid_start\": ts_valid_start.isoformat() if ts_valid_start else None,\n            \"ts_valid_end\": ts_valid_end.isoformat() if ts_valid_end else None,\n            \"status\": status,\n            \"visibility\": data.visibility or \"scope_team\",\n            \"entity_links\": entity_link_dicts,\n        }\n        pending.append((i, mem_data))\n\n    # -- Bulk insert via storage client. The storage layer returns one\n    # entry per submitted item with ``was_inserted`` distinguishing\n    # newly-committed rows from those resolved against a prior attempt's\n    # commit (the silent-create eliminator). The legacy ReadTimeout\n    # reconcile branch is intentionally gone — its job is now done at\n    # the row level by the per-attempt unique constraint, and a retry of\n    # the entire request is the documented recovery path.\n    #\n    # Per-tenant storage bulkhead (CAURA-602 follow-up): the slot wraps\n    # only the storage roundtrip itself, holding tight while the call\n    # is in flight and releasing as soon as the storage response (or\n    # cancellation) returns. Embed/enrich already finished above and\n    # the audit/contradiction/reembed fan-out below runs as\n    # fire-and-forget tasks, so the slot's grip on storage stays tight\n    # even for long-tail batches.\n    if pending:\n        # Per-phase deadline on the storage roundtrip itself (CAURA-599).\n        # Without this the only deadline on this phase is the outer\n        # ``bulk_request_timeout_seconds`` umbrella in the route handler;\n        # a hung storage call would consume any unused embed/enrich slack\n        # before the 504 path fires.\n        #\n        # Order matters: ``asyncio.timeout`` is the OUTER context manager\n        # so the deadline arms before ``per_tenant_storage_slot`` calls\n        # ``asyncio.Semaphore.acquire()`` (which blocks indefinitely under\n        # contention). Compound ``async with (A, B):`` enters left-to-right,\n        # so swapping the order would leave the slot wait outside the\n        # deadline. Cancellation during a queued acquire raises cleanly\n        # from inside the semaphore's __aenter__ — no slot is held, so\n        # no release is needed on the timeout path.\n        async with (\n            asyncio.timeout(settings.storage_bulk_timeout_seconds),\n            per_tenant_storage_slot(\"storage_write\", data.tenant_id),\n        ):\n            storage_results = await sc.create_memories([d for _, d in pending])\n\n        # Map each storage result back to its source item via\n        # ``client_request_id``. Postgres ``RETURNING`` order is\n        # unspecified for ``ON CONFLICT DO NOTHING``, so we never\n        # zip on positional index.\n        by_request_id = {r[\"client_request_id\"]: r for r in storage_results}\n\n        # Track the (orig_idx, mem_data, mem_id) trios for the\n        # successfully-resolved items so the audit log + background\n        # task loops below operate on rows that actually exist.\n        resolved: list[tuple[int, dict, str]] = []\n\n        for orig_idx, mem_data in pending:\n            crid = mem_data[\"client_request_id\"]\n            sr = by_request_id.get(crid)\n            if sr is None or not sr.get(\"id\"):\n                # Storage didn't return a row for this id — concurrent\n                # soft-delete or schema drift. Surface as per-item\n                # error rather than fabricating an id.\n                results[orig_idx] = BulkItemResult(\n                    index=orig_idx,\n                    client_request_id=crid,\n                    status=\"error\",\n                    error=\"storage did not return an id for this item\",\n                )\n                error_count += 1\n                continue\n\n            mem_id = sr[\"id\"]\n            if sr.get(\"was_inserted\"):\n                results[orig_idx] = BulkItemResult(\n                    index=orig_idx,\n                    client_request_id=crid,\n                    status=\"created\",\n                    id=mem_id,\n                )\n                created_count += 1\n                resolved.append((orig_idx, mem_data, mem_id))\n            else:\n                # Same attempt id already committed — i.e. a retry. The\n                # row exists; we don't re-run audit / entity-extraction\n                # / contradiction tasks for it because the original\n                # attempt already kicked those off (or will, if its\n                # tracked tasks haven't drained yet).\n                results[orig_idx] = BulkItemResult(\n                    index=orig_idx,\n                    client_request_id=crid,\n                    status=\"duplicate_attempt\",\n                    id=mem_id,\n                )\n                dup_count += 1\n\n        # Back-fill ``id`` / ``duplicate_of`` on intra-batch\n        # ``duplicate_content`` rows. The first-occurrence loop above\n        # marks them with no canonical id — at the time we couldn't\n        # know it, since the canonical row hadn't been written yet.\n        # Now that ``results[seen_hashes[ch]]`` carries the storage id\n        # (whether it's ``created`` or ``duplicate_attempt``), copy it\n        # forward so the ``BulkItemResult`` docstring contract holds:\n        # ``duplicate_content`` always has both fields populated.\n        for j in range(n):\n            later = results[j]\n            if later is None or later.status != \"duplicate_content\" or later.id is not None:\n                continue\n            canonical = results[seen_hashes[hashes[j]]]\n            if canonical is None or canonical.id is None:\n                # Canonical row never persisted (storage error) — leaving\n                # this slot as a contract-violating\n                # ``duplicate_content`` with both id fields ``None``\n                # would silently break clients that branch on status.\n                # Downgrade to ``error`` and rebalance the aggregate\n                # counts: we'd previously incremented ``dup_count`` for\n                # this item, undo that.\n                results[j] = BulkItemResult(\n                    index=j,\n                    client_request_id=later.client_request_id,\n                    status=\"error\",\n                    error=\"canonical row for intra-batch duplicate did not persist\",\n                )\n                dup_count -= 1\n                error_count += 1\n                continue\n            results[j] = BulkItemResult(\n                index=j,\n                client_request_id=later.client_request_id,\n                status=\"duplicate_content\",\n                id=canonical.id,\n                duplicate_of=canonical.id,\n            )\n\n        # Bulk audit log — only for newly-inserted rows. Fire-and-forget\n        # so a parent ``asyncio.wait_for`` cancellation (e.g. the 90s\n        # bulk budget firing after storage commits but before the\n        # in-flight audit call returns) can't strand committed rows\n        # without their audit records: the retry sees those rows as\n        # ``duplicate_attempt`` and never re-enters this block, so the\n        # audit had to land on the original attempt or it's lost. The\n        # tasks reference ``data.tenant_id`` etc. by value, not the\n        # request-scoped ``db`` session (``log_action`` doesn't actually\n        # touch ``db`` — it calls ``sc.create_audit_log`` over HTTP),\n        # so a teardown of the request context after cancellation\n        # doesn't affect them.\n        _hooks = get_hooks()\n        if _hooks.audit_log:\n            for _orig_idx, mem_data, mem_id in resolved:\n                track_task(\n                    tracked_task(\n                        _hooks.audit_log(\n                            db,\n                            tenant_id=data.tenant_id,\n                            agent_id=data.agent_id,\n                            action=\"create\",\n                            resource_type=\"memory\",\n                            resource_id=mem_id,\n                            detail={\n                                \"memory_type\": mem_data[\"memory_type\"],\n                                \"title\": mem_data.get(\"title\"),\n                                \"content_length\": len(mem_data[\"content\"]),\n                                \"source\": \"bulk\",\n                            },\n                        ),\n                        \"audit_log\",\n                        mem_id,\n                        data.tenant_id,\n                    )\n                )\n\n        # Fire-and-forget async tasks for each newly-created memory.\n        # ``duplicate_attempt`` rows skip these — the original attempt\n        # already enqueued them (and re-running would double-bill the\n        # LLM provider for entity extraction + enrichment).\n        from core_api.services.contradiction_detector import detect_contradictions_async\n\n        # CAURA-595: per-row enrich publishes when deployment_mode is deferred.\n        defer_enrich_publish = (\n            not settings.inline_enrichment\n            and tenant_config.enrichment_enabled\n            and tenant_config.enrichment_provider != \"none\"\n        )\n\n        reembed_batch: list[tuple[UUID, str]] = []\n        for orig_idx, mem_data, mem_id in resolved:\n            if tenant_config.entity_extraction_enabled:\n                track_task(\n                    tracked_task(\n                        process_entity_extraction(\n                            mem_id,\n                            data.tenant_id,\n                            data.fleet_id,\n                            data.agent_id,\n                            items[orig_idx].content,\n                            mem_data[\"memory_type\"],\n                        ),\n                        \"entity_extraction\",","lineStart":990,"lineEnd":1459,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780727753151,"end":1780727753176}},"metadata":{"openai":{"itemId":"fc_014134f6ec7663c2016a23bfc906948191b43448fa2f9ba514"}},"id":"prt_e9ba529bd001O5E3JUez1TFUg1","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","messageID":"msg_e9ba4ff3f001CdUWYpPZelMsqi"}}
{"type":"tool_use","timestamp":1780727753178,"sessionID":"ses_1645cad2dffe08ToAptcWOhE23","part":{"type":"tool","tool":"read","callID":"call_4GmJfaWBHNa1LE5TQMZdxps5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"PostgreSQL service -- all database queries for core tables.\n2: \n3: Single point of DB access for the OSS core-storage-api.  Every query that\n4: was previously spread across eight repository classes now lives here, grouped\n5: by domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n6: \n7: Session management uses a module-level ``async_sessionmaker`` backed by the\n8: shared engine from ``core_storage_api.database.init.get_engine``.\n9: \"\"\"\n10: \n11: from __future__ import annotations\n12: \n13: import json\n14: import logging\n15: from collections import OrderedDict\n16: from collections.abc import AsyncIterator, Sequence\n17: from contextlib import asynccontextmanager\n18: from datetime import UTC, datetime, timedelta\n19: from types import SimpleNamespace\n20: from typing import Any\n21: from uuid import UUID\n22: \n23: from sqlalchemy import and_, case, delete, false, func, literal_column, or_, select, text, tuple_\n24: from sqlalchemy import update as sql_update\n25: from sqlalchemy.dialects.postgresql import insert as pg_insert\n26: from sqlalchemy.exc import IntegrityError\n27: from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker\n28: from sqlalchemy.orm import load_only\n29: \n30: from common.constants import (\n31:     CONTRADICTION_CANDIDATE_MAX,\n32:     CONTRADICTION_SIMILARITY_THRESHOLD,\n33:     DEFAULT_RELATION_TYPE_WEIGHT,\n34:     ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n35:     GRAPH_MAX_HOPS,\n36:     RECALL_BOOST_SCALE,\n37:     RELATION_TYPE_WEIGHTS,\n38:     SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n39:     SEMANTIC_DEDUP_THRESHOLD,\n40:     TYPE_DECAY_DAYS,\n41: )\n42: from common.events.lifecycle_purge_request import MEMORY_RETENTION_MAX_DAYS\n43: from common.models import (\n44:     Agent,\n45:     AuditLog,\n46:     BackgroundTaskLog,\n47:     CrystallizationReport,\n48:     DedupReview,\n49:     Document,\n50:     Entity,\n51:     FleetCommand,\n52:     FleetNode,\n53:     IdempotencyResponse,\n54:     LifecycleAudit,\n55:     Memory,\n56:     MemoryEntityLink,\n57:     Relation,\n58: )\n59: from core_storage_api.observability import db_measure\n60: \n61: logger = logging.getLogger(__name__)\n62: \n63: # ---------------------------------------------------------------------------\n64: # Session factories (singletons)\n65: # ---------------------------------------------------------------------------\n66: #\n67: # Two factories bound to two engines: writer (primary) and reader\n68: # (replica when ``read_database_url`` is set, else the primary). The\n69: # factories are lazy so tests can swap the underlying engines before\n70: # the first request without touching service-module state.\n71: \n72: _session_factory: async_sessionmaker[AsyncSession] | None = None\n73: _read_session_factory: async_sessionmaker[AsyncSession] | None = None\n74: \n75: \n76: def _get_session_factory() -> async_sessionmaker[AsyncSession]:\n77:     global _session_factory\n78:     if _session_factory is None:\n79:         from core_storage_api.database.init import get_engine\n80: \n81:         _session_factory = async_sessionmaker(\n82:             get_engine(),\n83:             expire_on_commit=False,\n84:         )\n85:     return _session_factory\n86: \n87: \n88: def _get_read_session_factory() -> async_sessionmaker[AsyncSession]:\n89:     global _read_session_factory\n90:     if _read_session_factory is None:\n91:         from core_storage_api.database.init import get_read_engine\n92: \n93:         _read_session_factory = async_sessionmaker(\n94:             get_read_engine(),\n95:             expire_on_commit=False,\n96:         )\n97:     return _read_session_factory\n98: \n99: \n100: @asynccontextmanager\n101: async def get_session() -> AsyncIterator[AsyncSession]:\n102:     \"\"\"Transactional writer session; commits on success, rolls back on error.\"\"\"\n103:     factory = _get_session_factory()\n104:     async with factory() as session:\n105:         async with session.begin():\n106:             yield session\n107: \n108: \n109: @asynccontextmanager\n110: async def get_read_session() -> AsyncIterator[AsyncSession]:\n111:     \"\"\"Reader session — no explicit transaction wrapper since these are\n112:     query-only paths. Routes to the replica engine when\n113:     ``settings.read_database_url`` is set; otherwise shares the primary\n114:     pool (OSS standalone — unchanged behavior).\n115: \n116:     Do NOT use for read-your-writes flows inside a single request; use\n117:     :func:`get_session` for those so the read sees the same transaction\n118:     scope as the write.\n119:     \"\"\"\n120:     factory = _get_read_session_factory()\n121:     async with factory() as session:\n122:         yield session\n123: \n124: \n125: # ---------------------------------------------------------------------------\n126: # Helpers\n127: # ---------------------------------------------------------------------------\n128: \n129: \n130: def _scope_sql(\n131:     tenant_id: str,\n132:     fleet_id: str | None,\n133:     table: str = \"m\",\n134: ) -> tuple[str, dict]:\n135:     \"\"\"Build a WHERE clause fragment for tenant + optional fleet scoping.\"\"\"\n136:     clause = f\"{table}.tenant_id = :tenant_id\"\n137:     params: dict = {\"tenant_id\": tenant_id}\n138:     if fleet_id is not None:\n139:         clause += f\" AND {table}.fleet_id = :fleet_id\"\n140:         params[\"fleet_id\"] = fleet_id\n141:     return clause, params\n142: \n143: \n144: def _relation_weight(relation_type: str, row_weight: float) -> float:\n145:     \"\"\"Compute effective weight for a relation edge.\"\"\"\n146:     type_w = RELATION_TYPE_WEIGHTS.get(\n147:         relation_type.lower(),\n148:         DEFAULT_RELATION_TYPE_WEIGHT,\n149:     )\n150:     return type_w * row_weight\n151: \n152: \n153: # Cached at import time so the per-row column-name filter on the bulk\n154: # write hot path (100 items x ~25 columns) doesn't pay the cost of\n155: # walking ``Memory.__table__.columns`` and ``__mapper__.column_attrs``\n156: # on every call. Both sets are static for the lifetime of the process.\n157: _MEMORY_VALID_FIELDS = frozenset(\n158:     {c.key for c in Memory.__table__.columns} | {a.key for a in Memory.__mapper__.column_attrs}\n159: )\n160: \n161: \n162: # ── Org hard-delete purge (CAURA-689) ──\n163: #\n164: # Tables wiped when an organization is permanently deleted. Ordered\n165: # children-before-parents so the per-table DELETEs never trip a foreign\n166: # key. Tables WITHOUT their own ``tenant_id`` column (``memory_entity_links``)\n167: # are not listed — they're removed by the ON DELETE CASCADE from\n168: # ``memories`` / ``entities``. ``relations`` and ``fleet_commands`` are\n169: # listed explicitly (ahead of their parents) so their per-table counts are\n170: # reported rather than hidden inside a cascade.\n171: _PURGE_TENANT_TABLES: tuple[str, ...] = (\n172:     \"relations\",\n173:     \"fleet_commands\",\n174:     \"memories\",\n175:     \"entities\",\n176:     \"agents\",\n177:     \"fleet_nodes\",\n178:     \"audit_log\",\n179:     \"documents\",\n180:     \"analysis_reports\",\n181:     \"dedup_reviews\",\n182:     \"background_task_log\",\n183:     \"idempotency_responses\",\n184: )\n185: # OSS keys these by ``org_id``, which equals the tenant id in the\n186: # single-key-per-tenant OSS model (CAURA-654). ``lifecycle_audit`` is\n187: # deliberately NOT purged: it's the operational audit trail (including\n188: # the hard-delete-org row itself), so wiping it would erase the record\n189: # of the very deletion being performed.\n190: _PURGE_ORG_KEYED_TABLES: tuple[str, ...] = (\n191:     \"organization_settings\",\n192:     \"organization_settings_audit\",\n193: )\n194: \n195: # ── Fleet-scoped hard-purge (test-tenant hygiene) ──\n196: #\n197: # The subset of ``_PURGE_TENANT_TABLES`` that carries its own ``fleet_id``\n198: # column, so a single fleet's footprint can be permanently removed from a\n199: # SHARED tenant without touching the rest of the tenant. Used by the\n200: # OpenClaw fleet-tester to clean up its run-scoped ``nightly-<run_id>-fleet-NN``\n201: # fleets at teardown (the dev tenant otherwise accumulates run data that\n202: # confounds isolation/trust tests). Ordered children-before-parents so the\n203: # per-table DELETEs never trip a foreign key.\n204: #\n205: # ``fleet_commands`` is intentionally NOT in this tuple — it has no\n206: # ``fleet_id`` of its own (it's keyed by ``node_id``); ``purge_fleet_data``\n207: # deletes it explicitly by the fleet's node ids before the nodes go, so its\n208: # count is reported rather than hidden inside the ``fleet_nodes`` ON DELETE\n209: # CASCADE. ``memory_entity_links`` (no ``fleet_id``) rides the CASCADE from\n210: # ``memories`` / ``entities``. Tenant-wide tables (``audit_log``,\n211: # ``background_task_log``, ``idempotency_responses``, ``organization_settings*``)\n212: # are excluded — they're tenant config or the retained audit trail, not\n213: # fleet-scoped run data.\n214: _PURGE_FLEET_TABLES: tuple[str, ...] = (\n215:     \"relations\",\n216:     \"memories\",\n217:     \"entities\",\n218:     \"agents\",\n219:     \"fleet_nodes\",\n220:     \"documents\",\n221:     \"analysis_reports\",\n222:     \"dedup_reviews\",\n223: )\n224: \n225: \n226: # ═══════════════════════════════════════════════════════════════════════════\n227: # PostgresService\n228: # ═══════════════════════════════════════════════════════════════════════════\n229: \n230: \n231: class PostgresService:\n232:     \"\"\"Single point of DB access for all core tables.\n233: \n234:     Every public method acquires its own session via ``get_session()``.\n235:     Callers never need to manage sessions or transactions.\n236:     \"\"\"\n237: \n238:     # ══════════════════════════════════════════════════════════════════════\n239:     #  MEMORIES\n240:     # ══════════════════════════════════════════════════════════════════════\n241: \n242:     # ------------------------------------------------------------------\n243:     # A) Core CRUD\n244:     # ------------------------------------------------------------------\n245: \n246:     async def memory_get_by_id(self, memory_id: UUID) -> Memory | None:\n247:         # Wrap the full session block so db_ms includes connection-pool\n248:         # wait time — a saturated pool shows up as slow \"DB\" here, which\n249:         # is exactly how we want to see it in Cloud Logging.\n250:         with db_measure():\n251:             async with get_read_session() as session:\n252:                 return await session.get(Memory, memory_id)\n253: \n254:     async def memory_get_by_id_for_tenant(\n255:         self,\n256:         memory_id: UUID,\n257:         tenant_id: str,\n258:     ) -> Memory | None:\n259:         with db_measure():\n260:             async with get_read_session() as session:\n\n(Showing lines 1-260 of 4754. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"PostgreSQL service -- all database queries for core tables.\n\nSingle point of DB access for the OSS core-storage-api.  Every query that\nwas previously spread across eight repository classes now lives here, grouped\nby domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n\nSession management uses a module-level ``async_sessionmaker`` backed by the\nshared engine from ``core_storage_api.database.init.get_engine``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nfrom collections import OrderedDict\nfrom collections.abc import AsyncIterator, Sequence\nfrom contextlib import asynccontextmanager\nfrom datetime import UTC, datetime, timedelta\nfrom types import SimpleNamespace\nfrom typing import Any","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"\"\"\"PostgreSQL service -- all database queries for core tables.\n\nSingle point of DB access for the OSS core-storage-api.  Every query that\nwas previously spread across eight repository classes now lives here, grouped\nby domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n\nSession management uses a module-level ``async_sessionmaker`` backed by the\nshared engine from ``core_storage_api.database.init.get_engine``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nfrom collections import OrderedDict\nfrom collections.abc import AsyncIterator, Sequence\nfrom contextlib import asynccontextmanager\nfrom datetime import UTC, datetime, timedelta\nfrom types import SimpleNamespace\nfrom typing import Any\nfrom uuid import UUID\n\nfrom sqlalchemy import and_, case, delete, false, func, literal_column, or_, select, text, tuple_\nfrom sqlalchemy import update as sql_update\nfrom sqlalchemy.dialects.postgresql import insert as pg_insert\nfrom sqlalchemy.exc import IntegrityError\nfrom sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker\nfrom sqlalchemy.orm import load_only\n\nfrom common.constants import (\n    CONTRADICTION_CANDIDATE_MAX,\n    CONTRADICTION_SIMILARITY_THRESHOLD,\n    DEFAULT_RELATION_TYPE_WEIGHT,\n    ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n    GRAPH_MAX_HOPS,\n    RECALL_BOOST_SCALE,\n    RELATION_TYPE_WEIGHTS,\n    SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n    SEMANTIC_DEDUP_THRESHOLD,\n    TYPE_DECAY_DAYS,\n)\nfrom common.events.lifecycle_purge_request import MEMORY_RETENTION_MAX_DAYS\nfrom common.models import (\n    Agent,\n    AuditLog,\n    BackgroundTaskLog,\n    CrystallizationReport,\n    DedupReview,\n    Document,\n    Entity,\n    FleetCommand,\n    FleetNode,\n    IdempotencyResponse,\n    LifecycleAudit,\n    Memory,\n    MemoryEntityLink,\n    Relation,\n)\nfrom core_storage_api.observability import db_measure\n\nlogger = logging.getLogger(__name__)\n\n# ---------------------------------------------------------------------------\n# Session factories (singletons)\n# ---------------------------------------------------------------------------\n#\n# Two factories bound to two engines: writer (primary) and reader\n# (replica when ``read_database_url`` is set, else the primary). The\n# factories are lazy so tests can swap the underlying engines before\n# the first request without touching service-module state.\n\n_session_factory: async_sessionmaker[AsyncSession] | None = None\n_read_session_factory: async_sessionmaker[AsyncSession] | None = None\n\n\ndef _get_session_factory() -> async_sessionmaker[AsyncSession]:\n    global _session_factory\n    if _session_factory is None:\n        from core_storage_api.database.init import get_engine\n\n        _session_factory = async_sessionmaker(\n            get_engine(),\n            expire_on_commit=False,\n        )\n    return _session_factory\n\n\ndef _get_read_session_factory() -> async_sessionmaker[AsyncSession]:\n    global _read_session_factory\n    if _read_session_factory is None:\n        from core_storage_api.database.init import get_read_engine\n\n        _read_session_factory = async_sessionmaker(\n            get_read_engine(),\n            expire_on_commit=False,\n        )\n    return _read_session_factory\n\n\n@asynccontextmanager\nasync def get_session() -> AsyncIterator[AsyncSession]:\n    \"\"\"Transactional writer session; commits on success, rolls back on error.\"\"\"\n    factory = _get_session_factory()\n    async with factory() as session:\n        async with session.begin():\n            yield session\n\n\n@asynccontextmanager\nasync def get_read_session() -> AsyncIterator[AsyncSession]:\n    \"\"\"Reader session — no explicit transaction wrapper since these are\n    query-only paths. Routes to the replica engine when\n    ``settings.read_database_url`` is set; otherwise shares the primary\n    pool (OSS standalone — unchanged behavior).\n\n    Do NOT use for read-your-writes flows inside a single request; use\n    :func:`get_session` for those so the read sees the same transaction\n    scope as the write.\n    \"\"\"\n    factory = _get_read_session_factory()\n    async with factory() as session:\n        yield session\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _scope_sql(\n    tenant_id: str,\n    fleet_id: str | None,\n    table: str = \"m\",\n) -> tuple[str, dict]:\n    \"\"\"Build a WHERE clause fragment for tenant + optional fleet scoping.\"\"\"\n    clause = f\"{table}.tenant_id = :tenant_id\"\n    params: dict = {\"tenant_id\": tenant_id}\n    if fleet_id is not None:\n        clause += f\" AND {table}.fleet_id = :fleet_id\"\n        params[\"fleet_id\"] = fleet_id\n    return clause, params\n\n\ndef _relation_weight(relation_type: str, row_weight: float) -> float:\n    \"\"\"Compute effective weight for a relation edge.\"\"\"\n    type_w = RELATION_TYPE_WEIGHTS.get(\n        relation_type.lower(),\n        DEFAULT_RELATION_TYPE_WEIGHT,\n    )\n    return type_w * row_weight\n\n\n# Cached at import time so the per-row column-name filter on the bulk\n# write hot path (100 items x ~25 columns) doesn't pay the cost of\n# walking ``Memory.__table__.columns`` and ``__mapper__.column_attrs``\n# on every call. Both sets are static for the lifetime of the process.\n_MEMORY_VALID_FIELDS = frozenset(\n    {c.key for c in Memory.__table__.columns} | {a.key for a in Memory.__mapper__.column_attrs}\n)\n\n\n# ── Org hard-delete purge (CAURA-689) ──\n#\n# Tables wiped when an organization is permanently deleted. Ordered\n# children-before-parents so the per-table DELETEs never trip a foreign\n# key. Tables WITHOUT their own ``tenant_id`` column (``memory_entity_links``)\n# are not listed — they're removed by the ON DELETE CASCADE from\n# ``memories`` / ``entities``. ``relations`` and ``fleet_commands`` are\n# listed explicitly (ahead of their parents) so their per-table counts are\n# reported rather than hidden inside a cascade.\n_PURGE_TENANT_TABLES: tuple[str, ...] = (\n    \"relations\",\n    \"fleet_commands\",\n    \"memories\",\n    \"entities\",\n    \"agents\",\n    \"fleet_nodes\",\n    \"audit_log\",\n    \"documents\",\n    \"analysis_reports\",\n    \"dedup_reviews\",\n    \"background_task_log\",\n    \"idempotency_responses\",\n)\n# OSS keys these by ``org_id``, which equals the tenant id in the\n# single-key-per-tenant OSS model (CAURA-654). ``lifecycle_audit`` is\n# deliberately NOT purged: it's the operational audit trail (including\n# the hard-delete-org row itself), so wiping it would erase the record\n# of the very deletion being performed.\n_PURGE_ORG_KEYED_TABLES: tuple[str, ...] = (\n    \"organization_settings\",\n    \"organization_settings_audit\",\n)\n\n# ── Fleet-scoped hard-purge (test-tenant hygiene) ──\n#\n# The subset of ``_PURGE_TENANT_TABLES`` that carries its own ``fleet_id``\n# column, so a single fleet's footprint can be permanently removed from a\n# SHARED tenant without touching the rest of the tenant. Used by the\n# OpenClaw fleet-tester to clean up its run-scoped ``nightly-<run_id>-fleet-NN``\n# fleets at teardown (the dev tenant otherwise accumulates run data that\n# confounds isolation/trust tests). Ordered children-before-parents so the\n# per-table DELETEs never trip a foreign key.\n#\n# ``fleet_commands`` is intentionally NOT in this tuple — it has no\n# ``fleet_id`` of its own (it's keyed by ``node_id``); ``purge_fleet_data``\n# deletes it explicitly by the fleet's node ids before the nodes go, so its\n# count is reported rather than hidden inside the ``fleet_nodes`` ON DELETE\n# CASCADE. ``memory_entity_links`` (no ``fleet_id``) rides the CASCADE from\n# ``memories`` / ``entities``. Tenant-wide tables (``audit_log``,\n# ``background_task_log``, ``idempotency_responses``, ``organization_settings*``)\n# are excluded — they're tenant config or the retained audit trail, not\n# fleet-scoped run data.\n_PURGE_FLEET_TABLES: tuple[str, ...] = (\n    \"relations\",\n    \"memories\",\n    \"entities\",\n    \"agents\",\n    \"fleet_nodes\",\n    \"documents\",\n    \"analysis_reports\",\n    \"dedup_reviews\",\n)\n\n\n# ═══════════════════════════════════════════════════════════════════════════\n# PostgresService\n# ═══════════════════════════════════════════════════════════════════════════\n\n\nclass PostgresService:\n    \"\"\"Single point of DB access for all core tables.\n\n    Every public method acquires its own session via ``get_session()``.\n    Callers never need to manage sessions or transactions.\n    \"\"\"\n\n    # ══════════════════════════════════════════════════════════════════════\n    #  MEMORIES\n    # ══════════════════════════════════════════════════════════════════════\n\n    # ------------------------------------------------------------------\n    # A) Core CRUD\n    # ------------------------------------------------------------------\n\n    async def memory_get_by_id(self, memory_id: UUID) -> Memory | None:\n        # Wrap the full session block so db_ms includes connection-pool\n        # wait time — a saturated pool shows up as slow \"DB\" here, which\n        # is exactly how we want to see it in Cloud Logging.\n        with db_measure():\n            async with get_read_session() as session:\n                return await session.get(Memory, memory_id)\n\n    async def memory_get_by_id_for_tenant(\n        self,\n        memory_id: UUID,\n        tenant_id: str,\n    ) -> Memory | None:\n        with db_measure():\n            async with get_read_session() as session:","lineStart":1,"lineEnd":260,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780727753154,"end":1780727753178}},"metadata":{"openai":{"itemId":"fc_014134f6ec7663c2016a23bfc9069c81919b92787d5080b32a"}},"id":"prt_e9ba529c0001o4E2jM6fYzKk43","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","messageID":"msg_e9ba4ff3f001CdUWYpPZelMsqi"}}
