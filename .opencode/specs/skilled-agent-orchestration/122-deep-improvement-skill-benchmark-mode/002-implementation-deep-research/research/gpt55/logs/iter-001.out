  2220	def _apply_memory_save_file_operation_cap(
  2490	    The formula distinguishes between queries that match explicit intent keywords
  2491	    (INTENT_BOOSTERS) versus those that only match description corpus terms.
  2492	
  2493	    With intent boost (keyword directly matched in INTENT_BOOSTERS):
  2494	        confidence = min(0.50 + score * 0.15, 0.95)
  2495	        Examples:
  2496	        - score=2.0 → 0.80 (meets 0.8 threshold)
  2497	        - score=3.0 → 0.95 (max)
  2498	        - score=4.0 → 0.95 (capped)
  2499	
  2500	    Without intent boost (corpus matching only):
  2501	        confidence = min(0.25 + score * 0.15, 0.95)
  2502	        Examples:
  2503	        - score=2.0 → 0.55 (below threshold)
  2504	        - score=3.0 → 0.70 (below threshold)
  2505	        - score=4.0 → 0.85 (meets threshold)
  2506	        - score=5.0 → 0.95 (capped)
  2507	
  2508	    The 0.8 threshold in Gate 2 means:
  2509	    - With intent boost: Only needs score >= 2.0 to trigger skill routing
  2510	    - Without intent boost: Needs score >= 4.0 to trigger skill routing
  2511	
  2512	    This design favors explicit domain keywords while remaining conservative
  2513	    for generic corpus matches that may be coincidental.
  2514	
  2515	    Args:
  2516	        score: Accumulated match score from corpus matching and intent boosters.
  2517	               Higher scores come from matching more terms or important keywords.
  2518	        has_intent_boost: Whether an INTENT_BOOSTER keyword was matched.
  2519	                         True enables the higher-confidence formula.
  2520	
  2521	    Returns:
  2522	        float: Confidence score between 0.0 and 0.95
  2523	    """
  2524	    if has_intent_boost:
  2525	        # Intent booster matched - higher confidence curve
  2526	        confidence = min(0.50 + score * 0.15, 0.95)
  2527	    else:
  2528	        # No explicit boosters - conservative (corpus matches only)
  2529	        confidence = min(0.25 + score * 0.15, 0.95)
  2530	
  2531	    return confidence
  2532	
  2533	
  2534	def calculate_uncertainty(num_matches: int, has_intent_boost: bool, num_ambiguous_matches: int) -> float:
  2535	    """
  2536	    Calculate uncertainty score for skill recommendation.
  2537	
  2538	    Uncertainty measures "how much we don't know" - separate from confidence.
  2539	    High confidence + high uncertainty = "confident ignorance" (dangerous state).
  2540	
  2541	    Formula factors:
  2542	    - Fewer matches = higher uncertainty (less evidence)
  2543	    - No intent boost = higher uncertainty (less clear intent)
  2544	    - More ambiguous matches = higher uncertainty (competing interpretations)
  2545	
  2546	    Examples:
  2547	    - 5 matches, intent boost, 0 ambiguous: 0.15 (LOW - proceed)
  2548	    - 3 matches, intent boost, 1 ambiguous: 0.35 (LOW - proceed)
  2549	    - 1 match, no intent boost, 0 ambiguous: 0.55 (MEDIUM - verify)
  2550	    - 1 match, no intent boost, 2 ambiguous: 0.75 (HIGH - clarify)
  2551	    - 0 matches, no intent boost, 0 ambiguous: 0.85 (HIGH - clarify)
  2552	
  2553	    Args:
  2554	        num_matches: Total number of keyword/corpus matches found.
  2555	        has_intent_boost: Whether an INTENT_BOOSTER keyword was matched.
  2556	        num_ambiguous_matches: Count of MULTI_SKILL_BOOSTER matches (ambiguous keywords).
  2557	
  2558	    Returns:
  2559	        float: Uncertainty score between 0.0 and 1.0
  2560	               <= 0.35: LOW (proceed)
  2561	               0.36-0.60: MEDIUM (verify first)
  2562	               > 0.60: HIGH (require clarification)
  2563	    """
  2564	    # Base uncertainty decreases with more matches
  2565	    if num_matches >= 5:
  2566	        base_uncertainty = 0.15
  2567	    elif num_matches >= 3:
  2568	        base_uncertainty = 0.20
  2569	    elif num_matches >= 1:
  2570	        base_uncertainty = 0.30
  2571	    else:
  2572	        base_uncertainty = 0.70
  2573	
  2574	    # No intent boost increases uncertainty (less clear intent)
  2575	    intent_penalty = 0.0 if has_intent_boost else 0.15
  2576	
  2577	    # Ambiguous matches increase uncertainty (competing interpretations)
  2578	    ambiguity_penalty = min(num_ambiguous_matches * 0.08, 0.24)
  2579	
  2580	    uncertainty = min(base_uncertainty + intent_penalty + ambiguity_penalty, 1.0)
  2581	    return round(uncertainty, 2)
  2582	
  2583	
  2584	def passes_dual_threshold(
  2585	    confidence: float,
  2586	    uncertainty: float,
  2587	    conf_threshold: float = 0.8,
  2588	    uncert_threshold: float = 0.35,
  2589	) -> bool:
  2590	    """
  2591	    Check if recommendation passes dual-threshold validation.
  2592	
  2593	    READINESS = (confidence >= threshold) AND (uncertainty <= uncert_threshold)
  2594	
  2595	    Note on thresholds:
  2596	    - AGENTS.md Gate 1 defines READINESS as: (confidence >= 0.70) AND (uncertainty <= 0.35)
  2597	    - Gate 2 skill routing typically uses conf_threshold=0.8 (stricter for routing decisions)
  2598	    - The uncertainty threshold of 0.35 matches AGENTS.md exactly
  2599	
  2600	    Args:
  2601	        confidence: Confidence score (0.0-1.0)
  2602	        uncertainty: Uncertainty score (0.0-1.0)
  2603	        conf_threshold: Minimum confidence required (default 0.8 for skill routing)
  2604	        uncert_threshold: Maximum uncertainty allowed (default 0.35 per AGENTS.md)
  2605	

