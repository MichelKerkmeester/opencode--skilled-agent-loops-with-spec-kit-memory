pencode/skills/system-code-graph/mcp_server/handlers/detect-changes.ts\",\n          \"sourceLine\": 28,\n          \"expectedTopK\": [\n            \"DetectChangesResult\",\n            \"AffectedSymbol\",\n            \"DetectChangesStatus\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/handlers/detect-changes.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-001\",\n          \"category\": \"regression-detection\",\n          \"query\": \"default code graph indexer config include exclude globs\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/lib/indexer-types.ts\",\n          \"sourceLine\": 132,\n          \"expectedTopK\": [\n            \"getDefaultConfig\",\n            \"IndexerConfig\",\n            \"detectLanguage\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/lib/indexer-types.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-002\",\n          \"category\": \"regression-detection\",\n          \"query\": \"index scope excludes code graph canonical roots\",\n          \"sourceFile\": \".opencode/skills/system-spec-kit/mcp_server/lib/utils/index-scope.ts\",\n          \"sourceLine\": 192,\n          \"expectedTopK\": [\n            \"EXCLUDED_FOR_CODE_GRAPH\",\n            \"shouldIndexForCodeGraph\",\n            \"matchesAnyPattern\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-spec-kit/mcp_server/lib/utils/index-scope.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-003\",\n          \"category\": \"regression-detection\",\n          \"query\": \"mk-code-index standalone tool schemas include code_graph_query code_graph_status\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/tool-schemas.ts\",\n          \"sourceLine\": 186,\n          \"expectedTopK\": [\n            \"CODE_GRAPH_TOOL_SCHEMAS\",\n            \"TOOL_DEFINITIONS\",\n            \"validateToolArgs\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/tool-schemas.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-004\",\n          \"category\": \"regression-detection\",\n          \"query\": \"code_graph_query relationship operations calls imports blast_radius\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/handlers/query.ts\",\n          \"sourceLine\": 1198,\n          \"expectedTopK\": [\n            \"QueryArgs\",\n            \"handleCodeGraphQuery\",\n            \"SUPPORTED_RELATIONSHIP_OPERATIONS\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/handlers/query.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-005\",\n          \"category\": \"regression-detection\",\n          \"query\": \"skill advisor scorer lanes explicit lexical graph causal derived semantic shadow\",\n          \"sourceFile\": \".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts\",\n          \"sourceLine\": 65,\n          \"expectedTopK\": [\n            \"scoreAdvisorPrompt\",\n            \"buildLaneScores\",\n            \"emptyLaneScores\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-006\",\n          \"category\": \"regression-detection\",\n          \"query\": \"skill graph query prepared statements relations\",\n          \"sourceFile\": \".opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts\",\n          \"sourceLine\": 83,\n          \"expectedTopK\": [\n            \"getPreparedStatements\",\n            \"dependsOn\",\n            \"transitivePath\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-007\",\n          \"category\": \"regression-detection\",\n          \"query\": \"detect_changes hard block stale graph false safe empty\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/handlers/detect-changes.ts\",\n          \"sourceLine\": 69,\n          \"expectedTopK\": [\n            \"handleDetectChanges\",\n            \"readinessRequiresBlock\",\n            \"blockedResponse\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/handlers/detect-changes.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-008\",\n          \"category\": \"regression-detection\",\n          \"query\": \"phase runner scan phases find candidates parse candidates finalize emit metrics\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/lib/phase-runner.ts\",\n          \"sourceLine\": 266,\n          \"expectedTopK\": [\n            \"runPhases\",\n            \"PhaseRunnerError\",\n            \"topologicalSort\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/lib/phase-runner.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        }\n      ]\n    },\n    \"verificationPassPolicy\": {\n      \"overall_pass_rate\": 0.9,\n      \"edge_focus_pass_rate\": 0.8\n    },\n    \"apply\": {\n      \"lastRunAt\": \"2026-06-13T08:06:41.872Z\",\n      \"lastResult\": \"aborted\",\n      \"batteryPassRate\": 0\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781755630471,"end":1781755632696}},"metadata":{"openai":{"itemId":"fc_0f63a3726814011a016a336eee5fa08191b99658431c7bd2c0"}},"id":"prt_ed8e9535b00147Q6VafzK01xj8","sessionID":"ses_12718501effeJJTfPZxos2yLxP","messageID":"msg_ed8e91832001FFw3YI8iMcX0TC"}}
