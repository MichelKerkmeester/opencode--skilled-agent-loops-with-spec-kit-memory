{
  "color": {
    "parchment": {
      "$value": "#f7f7f4",
      "$type": "color",
      "$description": "Parchment — Page background, primary canvas — warm cream that softens contrast and makes ink feel printed rather than digital"
    },
    "bone": {
      "$value": "#f2f1ed",
      "$type": "color",
      "$description": "Bone — Card surfaces and elevated containers — one step darker than canvas, creates paper-on-paper layering without borders"
