   254	def analyze_skill(skill_dir: Path) -> SkillResult:
   255	    skill_text = (skill_dir / "SKILL.md").read_text(encoding="utf-8")
   256	    router_text = find_router_block(skill_text)
   257	    variant = detect_variant(router_text)
   258	    referenced_paths = extract_resources(router_text, router_text)
   259	    always_paths = extract_always_paths(router_text)
   260	    missing_paths = [
   261	        resource for resource in referenced_paths
   262	        if not (skill_dir / resource).exists()
   263	    ]
   264	    tree_bytes = markdown_tree_bytes(skill_dir)
   265	    always_bytes = bytes_for_paths(skill_dir, always_paths)
   266	    ratio = always_bytes / tree_bytes if tree_bytes > 0 else 0.0
   267	
   268	    return SkillResult(
   269	        skill=skill_dir.name,
   270	        variant=variant,
   271	        referenced_paths=referenced_paths,
   272	        always_paths=always_paths,
   273	        missing_paths=missing_paths,
   274	        always_bytes=always_bytes,
   275	        tree_bytes=tree_bytes,
   276	        ratio=ratio,
   277	    )
   278	
   279	
   280	def iter_skill_dirs() -> list[Path]:
   281	    if not SKILL_ROOT.exists():
   282	        return []
   283	    return sorted(
   284	        path for path in SKILL_ROOT.iterdir()
   285	        if path.is_dir() and (path / "SKILL.md").is_file()
   286	    )
   287	
   288	
   289	def build_payload(results: list[SkillResult]) -> dict[str, object]:
   290	    errors = [
   291	        {"skill": result.skill, "missing_paths": result.missing_paths}
   292	        for result in results
   293	        if result.missing_paths
   294	    ]
   295	    warnings = [
   296	        {
   297	            "skill": result.skill,
   298	            "always_bytes": result.always_bytes,
   299	            "tree_bytes": result.tree_bytes,
   300	            "ratio": round(result.ratio, 4),
   301	        }
   302	        for result in results
   303	        if result.ratio > BLOAT_THRESHOLD
   304	    ]
   305	    return {"errors": errors, "warnings": warnings}
   306	
   307	
   308	def print_human(results: list[SkillResult], payload: dict[str, object]) -> None:
   309	    errors = payload["errors"]
   310	    warnings = payload["warnings"]
   311	    print(f"Smart-router check: {len(results)} top-level skills scanned")
