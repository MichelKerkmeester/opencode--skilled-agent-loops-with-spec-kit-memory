{"type":"tool_use","timestamp":1781761437308,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_zZo4cRebb9GwiZudOkPL4BeY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","offset":321,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts</path>\n<type>file</type>\n<content>\n321:   return { ...current, errors, updatedAt };\n322: }\n323: \n324: export async function requestCancel(jobId: string): Promise<void> {\n325:   // Set the in-process flag first so a running loop observes the cancel even if the\n326:   // durable write contends on the shared connection.\n327:   cancelledJobIds.add(jobId);\n328:   const db = requireDb();\n329:   await withBusyRetry(() =>\n330:     db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n331:       .run(nowIso(), jobId)\n332:   );\n333: }\n334: \n335: // Synchronous so the runner can poll it inline at batch/phase boundaries.\n336: export function isCancelRequested(jobId: string): boolean {\n337:   const db = requireDb();\n338:   const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n339:     .get(jobId) as { cancel_requested?: number } | undefined;\n340:   return !!row && row.cancel_requested === 1;\n341: }\n342: \n343: // Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n344: // mirror, so it is safe to call thousands of times during a scan without touching\n345: // the shared SQLite connection. Use isCancelRequested when durability across the\n346: // in-memory boundary matters (status responses, post-restart).\n347: export function isCancelRequestedFast(jobId: string): boolean {\n348:   return cancelledJobIds.has(jobId);\n349: }\n350: \n351: export async function completeJob(\n352:   jobId: string,\n353:   options: { state: JobLifecycleState; result?: unknown },\n354: ): Promise<MaintenanceJob> {\n355:   const db = requireDb();\n356:   const current = getMaintenanceJob(jobId);\n357:   if (!current) {\n358:     throw new Error(`Maintenance job not found: ${jobId}`);\n359:   }\n360: \n361:   if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n362:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n363:   }\n364: \n365:   const updatedAt = nowIso();\n366:   const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n367:   const completion = await withBusyRetry(() =>\n368:     db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n369:       .run(options.state, resultJson, updatedAt, jobId, current.state)\n370:   );\n371:   if (completion.changes === 0) {\n372:     // The row moved out from under the read-then-check; refuse to clobber a state\n373:     // another writer set rather than overwriting it from a stale read.\n374:     throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n375:   }\n376: \n377:   cancelledJobIds.delete(jobId);\n378:   return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n379: }\n380: \n381: // Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n382: // re-run fresh, so they are reset to 'failed' rather than re-enqueued.\n383: export function resetRunningJobsForKind(\n384:   kind: MaintenanceJobKind,\n385:   // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n386:   // target keeps a caller from persisting an illegal transition past the guard.\n387:   options: { to: 'failed' | 'cancelled' },\n388: ): string[] {\n389:   const db = requireDb();\n390:   const rows = db.prepare(`\n391:     SELECT id FROM maintenance_jobs\n392:     WHERE kind = ? AND state IN ('queued', 'running')\n393:   `).all(kind) as Array<{ id: string }>;\n394: \n395:   if (rows.length === 0) return [];\n396: \n397:   withBusyRetrySync(() =>\n398:     db.prepare(`\n399:       UPDATE maintenance_jobs\n400:       SET state = ?, updated_at = ?\n401:       WHERE kind = ? AND state IN ('queued', 'running')\n402:     `).run(options.to, nowIso(), kind)\n403:   );\n404: \n405:   for (const row of rows) {\n406:     cancelledJobIds.delete(row.id);\n407:   }\n408:   return rows.map((r) => r.id);\n409: }\n410: \n411: export function isTerminalJobState(state: JobLifecycleState): boolean {\n412:   return TERMINAL_STATES.has(state);\n413: }\n\n(End of file - total 413 lines)\n</content>","metadata":{"preview":"  return { ...current, errors, updatedAt };\n}\n\nexport async function requestCancel(jobId: string): Promise<void> {\n  // Set the in-process flag first so a running loop observes the cancel even if the\n  // durable write contends on the shared connection.\n  cancelledJobIds.add(jobId);\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n      .run(nowIso(), jobId)\n  );\n}\n\n// Synchronous so the runner can poll it inline at batch/phase boundaries.\nexport function isCancelRequested(jobId: string): boolean {\n  const db = requireDb();\n  const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n    .get(jobId) as { cancel_requested?: number } | undefined;\n  return !!row && row.cancel_requested === 1;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","text":"  return { ...current, errors, updatedAt };\n}\n\nexport async function requestCancel(jobId: string): Promise<void> {\n  // Set the in-process flag first so a running loop observes the cancel even if the\n  // durable write contends on the shared connection.\n  cancelledJobIds.add(jobId);\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n      .run(nowIso(), jobId)\n  );\n}\n\n// Synchronous so the runner can poll it inline at batch/phase boundaries.\nexport function isCancelRequested(jobId: string): boolean {\n  const db = requireDb();\n  const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n    .get(jobId) as { cancel_requested?: number } | undefined;\n  return !!row && row.cancel_requested === 1;\n}\n\n// Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n// mirror, so it is safe to call thousands of times during a scan without touching\n// the shared SQLite connection. Use isCancelRequested when durability across the\n// in-memory boundary matters (status responses, post-restart).\nexport function isCancelRequestedFast(jobId: string): boolean {\n  return cancelledJobIds.has(jobId);\n}\n\nexport async function completeJob(\n  jobId: string,\n  options: { state: JobLifecycleState; result?: unknown },\n): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n  }\n\n  const updatedAt = nowIso();\n  const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n  const completion = await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n      .run(options.state, resultJson, updatedAt, jobId, current.state)\n  );\n  if (completion.changes === 0) {\n    // The row moved out from under the read-then-check; refuse to clobber a state\n    // another writer set rather than overwriting it from a stale read.\n    throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n  }\n\n  cancelledJobIds.delete(jobId);\n  return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n}\n\n// Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n// re-run fresh, so they are reset to 'failed' rather than re-enqueued.\nexport function resetRunningJobsForKind(\n  kind: MaintenanceJobKind,\n  // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n  // target keeps a caller from persisting an illegal transition past the guard.\n  options: { to: 'failed' | 'cancelled' },\n): string[] {\n  const db = requireDb();\n  const rows = db.prepare(`\n    SELECT id FROM maintenance_jobs\n    WHERE kind = ? AND state IN ('queued', 'running')\n  `).all(kind) as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE kind = ? AND state IN ('queued', 'running')\n    `).run(options.to, nowIso(), kind)\n  );\n\n  for (const row of rows) {\n    cancelledJobIds.delete(row.id);\n  }\n  return rows.map((r) => r.id);\n}\n\nexport function isTerminalJobState(state: JobLifecycleState): boolean {\n  return TERMINAL_STATES.has(state);\n}","lineStart":321,"lineEnd":413,"totalLines":413,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","time":{"start":1781761437304,"end":1781761437307}},"metadata":{"openai":{"itemId":"fc_087685ccfbbbc036016a33859d45688191885d984732d76a1e"}},"id":"prt_ed941ee6c001uvo14Ecjg6A3ry","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed941d0a70014TP40nDL6zb01T"}}
{"type":"tool_use","timestamp":1781761437353,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_4BSAVAOitLZFJDziMVfWKyy3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":321,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n321:   const stack: string[] = [dirPath];\n322: \n323:   while (stack.length > 0) {\n324:     const current = stack.pop();\n325:     if (!current) continue;\n326: \n327:     const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n328:     for (const entry of entries) {\n329:       const fullPath = path.join(current, entry.name);\n330:       if (entry.isDirectory()) {\n331:         stack.push(fullPath);\n332:       } else if (entry.isFile()) {\n333:         files.push(fullPath);\n334:       }\n335:     }\n336:   }\n337: \n338:   return files;\n339: }\n340: \n341: function findPendingFiles(dirPath: string): string[] {\n342:   try {\n343:     if (!fs.existsSync(dirPath)) return [];\n344: \n345:     let files: string[];\n346:     try {\n347:       files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n348:     } catch {\n349:       // Node 18 compatibility fallback when recursive readdir is unavailable.\n350:       files = listFilesRecursive(dirPath);\n351:     }\n352: \n353:     return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n354:   } catch (error: unknown) {\n355:     const msg = error instanceof Error ? error.message : String(error);\n356:     console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n357:     return [];\n358:   }\n359: }\n360: \n361: /**\n362:  * Recover a single pending file by renaming to its original path.\n363:  */\n364: function recoverPendingFile(\n365:   pendingPath: string,\n366:   isCommittedInDb?: IsCommittedCheck,\n367:   databasePathOverride?: string\n368: ): RecoveryResult {\n369:   try {\n370:     // Guard: verify pending file still exists before attempting recovery\n371:     if (!fs.existsSync(pendingPath)) {\n372:       return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n373:     }\n374:     const pendingInfo = parsePendingPath(pendingPath);\n375:     if (!pendingInfo) {\n376:       return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n377:     }\n378: \n379:     const originalPath = pendingInfo.originalPath;\n380:     const originalExists = fs.existsSync(originalPath);\n381:     let committedInDb: boolean | null = null;\n382:     if (isCommittedInDb) {\n383:       const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n384:       if (!fs.existsSync(databasePath)) {\n385:         console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n386:         return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n387:       }\n388:       committedInDb = isCommittedInDb(originalPath);\n389:     }\n390: \n391:     // If original exists and is newer, delete pending\n392:     if (originalExists) {\n393:       const pendingStats = fs.statSync(pendingPath);\n394:       const originalStats = fs.statSync(originalPath);\n395:       if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n396:         fs.unlinkSync(pendingPath);\n397:         return { path: pendingPath, recovered: false, error: 'Original is newer' };\n398:       }\n399:     }\n400: \n401:     // Stale detection: if DB check is provided and row was never committed,\n402:     // Log and leave for manual review instead of renaming.\n403:     if (committedInDb === false) {\n404:       console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n405:       return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n406:     }\n407: \n408:     // Rename pending to original\n409:     fs.renameSync(pendingPath, originalPath);\n410:     metrics.totalRecoveries++;\n411:     metrics.lastOperationTime = new Date().toISOString();\n412: \n413:     return { path: pendingPath, recovered: true };\n414:   } catch (error: unknown) {\n415:     const msg = error instanceof Error ? error.message : String(error);\n416:     metrics.totalErrors++;\n417:     return { path: pendingPath, recovered: false, error: msg };\n418:   }\n419: }\n420: \n421: /**\n422:  * Recover all pending files in a directory.\n423:  */\n424: function recoverAllPendingFiles(\n425:   dirPath: string,\n426:   isCommittedInDb?: IsCommittedCheck,\n427:   databasePathOverride?: string\n428: ): RecoveryResult[] {\n429:   const pendingFiles = findPendingFiles(dirPath);\n430:   return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n431: }\n432: \n433: /* ───────────────────────────────────────────────────────────────\n434:    8. EXPORTS\n435: ----------------------------------------------------------------*/\n436: \n437: export {\n438:   PENDING_SUFFIX,\n439:   TEMP_SUFFIX,\n440: \n441:   // Metrics\n442:   getMetrics,\n443:   resetMetrics,\n444: \n445:   // Path helpers\n446:   getPendingPath,\n447:   isPendingFile,\n448:   getOriginalPath,\n449:   runInTransaction,\n450: \n451:   // Atomic operations\n452:   atomicWriteFile,\n453:   deleteFileIfExists,\n454:   executeAtomicSave,\n455: \n456:   // Recovery\n457:   findPendingFiles,\n458:   recoverPendingFile,\n459:   recoverAllPendingFiles,\n460: };\n461: \n462: /**\n463:  * Re-exports related public types.\n464:  */\n465: export type {\n466:   TransactionMetrics,\n467:   AtomicSaveResult,\n468:   RecoveryResult,\n469:   IsCommittedCheck,\n470: };\n\n(End of file - total 470 lines)\n</content>","metadata":{"preview":"  const stack: string[] = [dirPath];\n\n  while (stack.length > 0) {\n    const current = stack.pop();\n    if (!current) continue;\n\n    const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n    for (const entry of entries) {\n      const fullPath = path.join(current, entry.name);\n      if (entry.isDirectory()) {\n        stack.push(fullPath);\n      } else if (entry.isFile()) {\n        files.push(fullPath);\n      }\n    }\n  }\n\n  return files;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"  const stack: string[] = [dirPath];\n\n  while (stack.length > 0) {\n    const current = stack.pop();\n    if (!current) continue;\n\n    const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n    for (const entry of entries) {\n      const fullPath = path.join(current, entry.name);\n      if (entry.isDirectory()) {\n        stack.push(fullPath);\n      } else if (entry.isFile()) {\n        files.push(fullPath);\n      }\n    }\n  }\n\n  return files;\n}\n\nfunction findPendingFiles(dirPath: string): string[] {\n  try {\n    if (!fs.existsSync(dirPath)) return [];\n\n    let files: string[];\n    try {\n      files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n    } catch {\n      // Node 18 compatibility fallback when recursive readdir is unavailable.\n      files = listFilesRecursive(dirPath);\n    }\n\n    return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Recover a single pending file by renaming to its original path.\n */\nfunction recoverPendingFile(\n  pendingPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult {\n  try {\n    // Guard: verify pending file still exists before attempting recovery\n    if (!fs.existsSync(pendingPath)) {\n      return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n    }\n    const pendingInfo = parsePendingPath(pendingPath);\n    if (!pendingInfo) {\n      return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n    }\n\n    const originalPath = pendingInfo.originalPath;\n    const originalExists = fs.existsSync(originalPath);\n    let committedInDb: boolean | null = null;\n    if (isCommittedInDb) {\n      const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n      if (!fs.existsSync(databasePath)) {\n        console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n        return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n      }\n      committedInDb = isCommittedInDb(originalPath);\n    }\n\n    // If original exists and is newer, delete pending\n    if (originalExists) {\n      const pendingStats = fs.statSync(pendingPath);\n      const originalStats = fs.statSync(originalPath);\n      if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n        fs.unlinkSync(pendingPath);\n        return { path: pendingPath, recovered: false, error: 'Original is newer' };\n      }\n    }\n\n    // Stale detection: if DB check is provided and row was never committed,\n    // Log and leave for manual review instead of renaming.\n    if (committedInDb === false) {\n      console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n      return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n    }\n\n    // Rename pending to original\n    fs.renameSync(pendingPath, originalPath);\n    metrics.totalRecoveries++;\n    metrics.lastOperationTime = new Date().toISOString();\n\n    return { path: pendingPath, recovered: true };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n    return { path: pendingPath, recovered: false, error: msg };\n  }\n}\n\n/**\n * Recover all pending files in a directory.\n */\nfunction recoverAllPendingFiles(\n  dirPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult[] {\n  const pendingFiles = findPendingFiles(dirPath);\n  return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  PENDING_SUFFIX,\n  TEMP_SUFFIX,\n\n  // Metrics\n  getMetrics,\n  resetMetrics,\n\n  // Path helpers\n  getPendingPath,\n  isPendingFile,\n  getOriginalPath,\n  runInTransaction,\n\n  // Atomic operations\n  atomicWriteFile,\n  deleteFileIfExists,\n  executeAtomicSave,\n\n  // Recovery\n  findPendingFiles,\n  recoverPendingFile,\n  recoverAllPendingFiles,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  TransactionMetrics,\n  AtomicSaveResult,\n  RecoveryResult,\n  IsCommittedCheck,\n};","lineStart":321,"lineEnd":470,"totalLines":470,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781761437350,"end":1781761437352}},"metadata":{"openai":{"itemId":"fc_087685ccfbbbc036016a33859d457881919aa6a9f1d683b301"}},"id":"prt_ed941ee95001mBWN151wn3c39a","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed941d0a70014TP40nDL6zb01T"}}
{"type":"tool_use","timestamp":1781761437365,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_3ljZbFgCW7rV9bOk5NI5xH7s","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","offset":321,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts</path>\n<type>file</type>\n<content>\n321: \n322:   try {\n323:     const rows = hasCanonicalPathColumn()\n324:       ? (db.prepare(`\n325:           SELECT DISTINCT file_path, canonical_file_path\n326:           FROM memory_index\n327:           WHERE file_path IS NOT NULL AND file_path != ''\n328:         `) as Database.Statement).all() as IndexedPathRow[]\n329:       : (db.prepare(`\n330:           SELECT DISTINCT file_path\n331:           FROM memory_index\n332:           WHERE file_path IS NOT NULL AND file_path != ''\n333:         `) as Database.Statement).all() as IndexedPathRow[];\n334: \n335:     for (const row of rows) {\n336:       if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n337:         continue;\n338:       }\n339: \n340:       const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n341:         ? row.canonical_file_path\n342:         : getCanonicalPathKey(row.file_path);\n343: \n344:       if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n345:         continue;\n346:       }\n347: \n348:       const filePathExists = getFileMetadata(row.file_path).exists;\n349:       const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n350:         ? getFileMetadata(row.canonical_file_path).exists\n351:         : false;\n352: \n353:       if (!filePathExists && !canonicalPathExists) {\n354:         stalePaths.add(row.file_path);\n355:       }\n356:     }\n357:   } catch (error: unknown) {\n358:     const msg = error instanceof Error ? error.message : String(error);\n359:     console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n360:   }\n361: \n362:   return Array.from(stalePaths);\n363: }\n364: \n365: function listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n366:   if (!db || filePaths.length === 0) return [];\n367: \n368:   const ids = new Set<number>();\n369:   const seenLookupKeys = new Set<string>();\n370: \n371:   try {\n372:     for (const filePath of filePaths) {\n373:       if (typeof filePath !== 'string' || filePath.length === 0) {\n374:         continue;\n375:       }\n376: \n377:       const canonicalPath = getCanonicalPathKey(filePath);\n378:       const lookupKey = `${canonicalPath}::${filePath}`;\n379:       if (seenLookupKeys.has(lookupKey)) {\n380:         continue;\n381:       }\n382:       seenLookupKeys.add(lookupKey);\n383: \n384:       const rows = hasCanonicalPathColumn()\n385:         ? (db.prepare(`\n386:             SELECT id, file_path, canonical_file_path\n387:             FROM memory_index\n388:             WHERE canonical_file_path = ? OR file_path = ?\n389:           `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n390:         : (db.prepare(`\n391:             SELECT id, file_path\n392:             FROM memory_index\n393:             WHERE file_path = ?\n394:           `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n395: \n396:       for (const row of rows) {\n397:         if (!row || typeof row.id !== 'number') {\n398:           continue;\n399:         }\n400: \n401:         const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n402:           ? getFileMetadata(row.file_path).exists\n403:           : false;\n404:         const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n405:           ? getFileMetadata(row.canonical_file_path).exists\n406:           : false;\n407: \n408:         if (rowFileExists || rowCanonicalExists) {\n409:           continue;\n410:         }\n411: \n412:         ids.add(row.id);\n413:       }\n414:     }\n415:   } catch (error: unknown) {\n416:     const msg = error instanceof Error ? error.message : String(error);\n417:     console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n418:     return [];\n419:   }\n420: \n421:   return Array.from(ids).sort((a, b) => a - b);\n422: }\n423: \n424: function normalizeOrphanSweepLimit(limit?: number): number {\n425:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n426:     return DEFAULT_ORPHAN_SWEEP_LIMIT;\n427:   }\n428: \n429:   return Math.max(1, Math.floor(limit));\n430: }\n431: \n432: function indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n433:   const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n434:     ? getFileMetadata(row.file_path).exists\n435:     : false;\n436:   const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n437:     ? getFileMetadata(row.canonical_file_path).exists\n438:     : false;\n439: \n440:   return !rowFileExists && !rowCanonicalExists;\n441: }\n442: \n443: function sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n444:   if (!db) {\n445:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n446:   }\n447: \n448:   const limit = normalizeOrphanSweepLimit(options.limit);\n449:   const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n450:     ? Math.floor(options.cursor)\n451:     : 0;\n452: \n453:   try {\n454:     const rows = hasCanonicalPathColumn()\n455:       ? (db.prepare(`\n456:           SELECT id, file_path, canonical_file_path\n457:           FROM memory_index\n458:           WHERE id > ?\n459:             AND file_path IS NOT NULL\n460:             AND file_path != ''\n461:           ORDER BY id ASC\n462:           LIMIT ?\n463:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n464:       : (db.prepare(`\n465:           SELECT id, file_path\n466:           FROM memory_index\n467:           WHERE id > ?\n468:             AND file_path IS NOT NULL\n469:             AND file_path != ''\n470:           ORDER BY id ASC\n471:           LIMIT ?\n472:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n473: \n474:     const orphanRecordIds: number[] = [];\n475:     for (const row of rows) {\n476:       if (!row || typeof row.id !== 'number') {\n477:         continue;\n478:       }\n479:       if (indexedRecordIsAbsent(row)) {\n480:         orphanRecordIds.push(row.id);\n481:       }\n482:     }\n483: \n484:     return {\n485:       swept: orphanRecordIds.length,\n486:       nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n487:       scannedRows: rows.length,\n488:       orphanRecordIds,\n489:     };\n490:   } catch (error: unknown) {\n491:     const msg = error instanceof Error ? error.message : String(error);\n492:     console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n493:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n494:   }\n495: }\n496: \n497: /* ───────────────────────────────────────────────────────────────\n498:    7b. MOVE RECONCILIATION\n499: ----------------------------------------------------------------*/\n500: \n501: interface MoveReconcileCandidate {\n502:   oldPath: string;\n503:   newPath: string;\n504:   rowId: number;\n505:   docType: string;\n506: }\n507: \n508: interface ReconcileMovesResult {\n509:   reconciled: MoveReconcileCandidate[];\n510:   filteredToDelete: string[];\n511:   filteredToIndex: string[];\n512: }\n513: \n514: interface IncrementalChunkFingerprint {\n515:   chunkId: string;\n516:   chunkFingerprint: string;\n517: }\n518: \n519: interface MemoizedPlanningInput {\n520:   componentPath: string;\n521:   canonicalInput: unknown;\n522:   codeHash: string;\n523:   chunks?: IncrementalChunkFingerprint[];\n524: }\n525: \n526: interface MemoizedPlanningOptions {\n527:   invalidateDependents?: boolean;\n528: }\n529: \n530: interface MemoizedPlanningResult {\n531:   memoHits: number;\n532:   memoMisses: number;\n533:   chunkHits: number;\n534:   chunkMisses: number;\n535:   dependencyInvalidated: number;\n536:   changedComponentPaths: string[];\n537:   unchangedComponentPaths: string[];\n538:   invalidatedComponentPaths: string[];\n539: }\n540: \n541: function reconcileMoves(\n542:   toDelete: string[],\n543:   toIndex: string[],\n544: ): ReconcileMovesResult {\n545:   if (!db || toDelete.length === 0 || toIndex.length === 0) {\n546:     return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n547:   }\n548: \n549:   // Build a map: packet_id → [{newPath, docType, newGrandparent}] from the toIndex files.\n550:   // Reads graph-metadata.json from the NEW location only — the old one may be gone after a move.\n551:   const newByPacketId = new Map<string, Array<{ newPath: string; docType: string; newGrandparent: string }>>();\n552:   for (const newPath of toIndex) {\n553:     try {\n554:       const newSpecFolder = path.dirname(newPath);\n555:       const graphMetaPath = path.join(newSpecFolder, 'graph-metadata.json');\n556:       if (!fs.existsSync(graphMetaPath)) continue;\n557:       const raw = fs.readFileSync(graphMetaPath, 'utf-8');\n558:       const meta = JSON.parse(raw) as { packet_id?: string };\n559:       const packetId = meta?.packet_id;\n560:       if (typeof packetId !== 'string' || packetId.length === 0) continue;\n561:       const docType = path.basename(newPath, path.extname(newPath));\n562:       const newGrandparent = path.dirname(newSpecFolder);\n563:       if (!newByPacketId.has(packetId)) newByPacketId.set(packetId, []);\n564:       newByPacketId.get(packetId)!.push({ newPath, docType, newGrandparent });\n565:     } catch {\n566:       // skip unreadable or non-JSON graph-metadata\n567:     }\n568:   }\n569: \n570:   if (newByPacketId.size === 0) {\n571:     return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n572:   }\n573: \n574:   const reconciledOldPaths = new Set<string>();\n575:   const reconciledNewPaths = new Set<string>();\n576:   const reconciled: MoveReconcileCandidate[] = [];\n577: \n578:   // Iterate from the NEW side: for each new path whose folder still carries a packet_id,\n579:   // find the corresponding old path in toDelete by matching grandparent directory + basename\n580:   // (a sibling folder rename within the same parent). The packet_id only gates which new\n581:   // paths are eligible — the actual old→new pairing is grandparent + basename plus the\n582:   // DB uniqueness guards below; it does NOT match the old row by its packet_id (the old\n583:   // graph-metadata.json may be gone, and memory_index has no packet_id column). To avoid\n584:   // repointing across mismatched document kinds, the stored document_type is cross-checked\n585:   // against the doc type derived from the new path before the in-place update.\n586:   const docTypeAvailable = hasDocumentTypeColumn();\n587:   const selectSql = docTypeAvailable\n588:     ? `SELECT id, document_type FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`\n589:     : `SELECT id FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`;\n590:   for (const [, newCandidates] of newByPacketId) {\n591:     for (const { newPath, docType, newGrandparent } of newCandidates) {\n592:       if (reconciledNewPaths.has(newPath)) continue;\n593: \n594:       const newBasename = path.basename(newPath);\n595: \n596:       // Find toDelete paths that are sibling renames: same grandparent dir, same basename.\n597:       // A sibling rename means only the immediate spec folder name changed (e.g. 012-old → 012-new).\n598:       const siblingDeleted = toDelete.filter(oldPath =>\n599:         !reconciledOldPaths.has(oldPath) &&\n600:         path.basename(oldPath) === newBasename &&\n\n(Showing lines 321-600 of 817. Use offset=601 to continue.)\n</content>","metadata":{"preview":"\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT DISTINCT file_path, canonical_file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[]\n      : (db.prepare(`\n          SELECT DISTINCT file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[];\n\n    for (const row of rows) {\n      if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n        continue;\n      }\n\n      const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","text":"\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT DISTINCT file_path, canonical_file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[]\n      : (db.prepare(`\n          SELECT DISTINCT file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[];\n\n    for (const row of rows) {\n      if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n        continue;\n      }\n\n      const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? row.canonical_file_path\n        : getCanonicalPathKey(row.file_path);\n\n      if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n        continue;\n      }\n\n      const filePathExists = getFileMetadata(row.file_path).exists;\n      const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? getFileMetadata(row.canonical_file_path).exists\n        : false;\n\n      if (!filePathExists && !canonicalPathExists) {\n        stalePaths.add(row.file_path);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n  }\n\n  return Array.from(stalePaths);\n}\n\nfunction listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n  if (!db || filePaths.length === 0) return [];\n\n  const ids = new Set<number>();\n  const seenLookupKeys = new Set<string>();\n\n  try {\n    for (const filePath of filePaths) {\n      if (typeof filePath !== 'string' || filePath.length === 0) {\n        continue;\n      }\n\n      const canonicalPath = getCanonicalPathKey(filePath);\n      const lookupKey = `${canonicalPath}::${filePath}`;\n      if (seenLookupKeys.has(lookupKey)) {\n        continue;\n      }\n      seenLookupKeys.add(lookupKey);\n\n      const rows = hasCanonicalPathColumn()\n        ? (db.prepare(`\n            SELECT id, file_path, canonical_file_path\n            FROM memory_index\n            WHERE canonical_file_path = ? OR file_path = ?\n          `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n        : (db.prepare(`\n            SELECT id, file_path\n            FROM memory_index\n            WHERE file_path = ?\n          `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n\n      for (const row of rows) {\n        if (!row || typeof row.id !== 'number') {\n          continue;\n        }\n\n        const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n          ? getFileMetadata(row.file_path).exists\n          : false;\n        const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n          ? getFileMetadata(row.canonical_file_path).exists\n          : false;\n\n        if (rowFileExists || rowCanonicalExists) {\n          continue;\n        }\n\n        ids.add(row.id);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n    return [];\n  }\n\n  return Array.from(ids).sort((a, b) => a - b);\n}\n\nfunction normalizeOrphanSweepLimit(limit?: number): number {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return DEFAULT_ORPHAN_SWEEP_LIMIT;\n  }\n\n  return Math.max(1, Math.floor(limit));\n}\n\nfunction indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n  const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n    ? getFileMetadata(row.file_path).exists\n    : false;\n  const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n    ? getFileMetadata(row.canonical_file_path).exists\n    : false;\n\n  return !rowFileExists && !rowCanonicalExists;\n}\n\nfunction sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n  if (!db) {\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n\n  const limit = normalizeOrphanSweepLimit(options.limit);\n  const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n    ? Math.floor(options.cursor)\n    : 0;\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT id, file_path, canonical_file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n      : (db.prepare(`\n          SELECT id, file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n\n    const orphanRecordIds: number[] = [];\n    for (const row of rows) {\n      if (!row || typeof row.id !== 'number') {\n        continue;\n      }\n      if (indexedRecordIsAbsent(row)) {\n        orphanRecordIds.push(row.id);\n      }\n    }\n\n    return {\n      swept: orphanRecordIds.length,\n      nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n      scannedRows: rows.length,\n      orphanRecordIds,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7b. MOVE RECONCILIATION\n----------------------------------------------------------------*/\n\ninterface MoveReconcileCandidate {\n  oldPath: string;\n  newPath: string;\n  rowId: number;\n  docType: string;\n}\n\ninterface ReconcileMovesResult {\n  reconciled: MoveReconcileCandidate[];\n  filteredToDelete: string[];\n  filteredToIndex: string[];\n}\n\ninterface IncrementalChunkFingerprint {\n  chunkId: string;\n  chunkFingerprint: string;\n}\n\ninterface MemoizedPlanningInput {\n  componentPath: string;\n  canonicalInput: unknown;\n  codeHash: string;\n  chunks?: IncrementalChunkFingerprint[];\n}\n\ninterface MemoizedPlanningOptions {\n  invalidateDependents?: boolean;\n}\n\ninterface MemoizedPlanningResult {\n  memoHits: number;\n  memoMisses: number;\n  chunkHits: number;\n  chunkMisses: number;\n  dependencyInvalidated: number;\n  changedComponentPaths: string[];\n  unchangedComponentPaths: string[];\n  invalidatedComponentPaths: string[];\n}\n\nfunction reconcileMoves(\n  toDelete: string[],\n  toIndex: string[],\n): ReconcileMovesResult {\n  if (!db || toDelete.length === 0 || toIndex.length === 0) {\n    return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n  }\n\n  // Build a map: packet_id → [{newPath, docType, newGrandparent}] from the toIndex files.\n  // Reads graph-metadata.json from the NEW location only — the old one may be gone after a move.\n  const newByPacketId = new Map<string, Array<{ newPath: string; docType: string; newGrandparent: string }>>();\n  for (const newPath of toIndex) {\n    try {\n      const newSpecFolder = path.dirname(newPath);\n      const graphMetaPath = path.join(newSpecFolder, 'graph-metadata.json');\n      if (!fs.existsSync(graphMetaPath)) continue;\n      const raw = fs.readFileSync(graphMetaPath, 'utf-8');\n      const meta = JSON.parse(raw) as { packet_id?: string };\n      const packetId = meta?.packet_id;\n      if (typeof packetId !== 'string' || packetId.length === 0) continue;\n      const docType = path.basename(newPath, path.extname(newPath));\n      const newGrandparent = path.dirname(newSpecFolder);\n      if (!newByPacketId.has(packetId)) newByPacketId.set(packetId, []);\n      newByPacketId.get(packetId)!.push({ newPath, docType, newGrandparent });\n    } catch {\n      // skip unreadable or non-JSON graph-metadata\n    }\n  }\n\n  if (newByPacketId.size === 0) {\n    return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n  }\n\n  const reconciledOldPaths = new Set<string>();\n  const reconciledNewPaths = new Set<string>();\n  const reconciled: MoveReconcileCandidate[] = [];\n\n  // Iterate from the NEW side: for each new path whose folder still carries a packet_id,\n  // find the corresponding old path in toDelete by matching grandparent directory + basename\n  // (a sibling folder rename within the same parent). The packet_id only gates which new\n  // paths are eligible — the actual old→new pairing is grandparent + basename plus the\n  // DB uniqueness guards below; it does NOT match the old row by its packet_id (the old\n  // graph-metadata.json may be gone, and memory_index has no packet_id column). To avoid\n  // repointing across mismatched document kinds, the stored document_type is cross-checked\n  // against the doc type derived from the new path before the in-place update.\n  const docTypeAvailable = hasDocumentTypeColumn();\n  const selectSql = docTypeAvailable\n    ? `SELECT id, document_type FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`\n    : `SELECT id FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`;\n  for (const [, newCandidates] of newByPacketId) {\n    for (const { newPath, docType, newGrandparent } of newCandidates) {\n      if (reconciledNewPaths.has(newPath)) continue;\n\n      const newBasename = path.basename(newPath);\n\n      // Find toDelete paths that are sibling renames: same grandparent dir, same basename.\n      // A sibling rename means only the immediate spec folder name changed (e.g. 012-old → 012-new).\n      const siblingDeleted = toDelete.filter(oldPath =>\n        !reconciledOldPaths.has(oldPath) &&\n        path.basename(oldPath) === newBasename &&","lineStart":321,"lineEnd":600,"totalLines":817,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","time":{"start":1781761437361,"end":1781761437364}},"metadata":