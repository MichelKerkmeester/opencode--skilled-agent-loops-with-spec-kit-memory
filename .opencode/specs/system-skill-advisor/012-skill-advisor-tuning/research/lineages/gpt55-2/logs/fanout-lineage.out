: string,\n244:   amount: number,\n245:   evidence: string,\n246:   producerSkillId?: string,\n247: ): void {\n248:   const current = scores.get(skillId) ?? { score: 0, evidence: [], producerSkillIds: new Set<string>() };\n249:   current.score += amount;\n250:   current.evidence.push(evidence);\n251:   if (producerSkillId) {\n252:     current.producerSkillIds.add(producerSkillId);\n253:   }\n254:   scores.set(skillId, current);\n255: }\n256: \n257: export function scoreExplicitLane(\n258:   prompt: string,\n259:   projection: AdvisorProjection,\n260:   options: ExplicitLaneOptions = {},\n\n(Showing lines 1-260 of 350. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, skillNameVariants, tokenize } from '../text.js';\n\ninterface ExplicitLaneOptions {\n  readonly includeProducerIdentity?: boolean;\n}\n\ninterface ExplicitScoreEntry {\n  score: number;\n  readonly evidence: string[];\n  readonly producerSkillIds: Set<string>;\n}\n\nconst TOKEN_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  audit: [['sk-code', 0.75]],\n  branch: [['sk-git', 0.45]],","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, skillNameVariants, tokenize } from '../text.js';\n\ninterface ExplicitLaneOptions {\n  readonly includeProduce