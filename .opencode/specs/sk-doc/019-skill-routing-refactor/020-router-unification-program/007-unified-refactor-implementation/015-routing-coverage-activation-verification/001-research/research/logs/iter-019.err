   827	def validate_command_frontmatter(
   828	    content: str,
   829	    file_path: str,
   830	    doc_type_rules: Dict[str, Any],
   831	) -> List[Dict[str, Any]]:
   832	    """Validate a command file's YAML frontmatter (description budget + tool permissions).
   833	
   834	    Presence-conditional: files that resolve to the command type but carry no
   835	    frontmatter block — compiled contract artifacts, legacy bodies, folder READMEs —
   836	    are not command entry docs, so their own structural rules govern them and this
   837	    check stays silent. Only a real frontmatter block is inspected.
   838	
   839	    The description-budget, quote handling, and MCP-token rules are the same primitives
   840	    the sibling skill validator uses, so the two agree on any command frontmatter. The
   841	    command surface uses a comma-separated allowed-tools list and may carry <arg>
   842	    placeholder notation in its description; both are accepted here by design.
   843	    """
   844	    errors: List[Dict[str, Any]] = []
   845	
   846	    if not content.startswith('---'):
   847	        return errors
   848	
   849	    match = re.match(r'^---\n(.*?)\n---', content, re.DOTALL)
   850	    if not match:
   851	        errors.append({
   852	            'type': 'command_frontmatter_unclosed',
   853	            'severity': 'blocking',
   854	            'message': 'Command frontmatter is not closed (missing closing ---)',
   855	            'fix_hint': 'Close the frontmatter block with a trailing ---',
   856	        })
   857	        return errors
   858	
   859	    frontmatter = match.group(1)
   860	
   861	    required_fields = doc_type_rules.get('frontmatterFields', {}).get('required', ['description'])
   862	    for field in required_fields:
   863	        if not re.search(rf'^{re.escape(field)}:\s*\S', frontmatter, re.MULTILINE):
   864	            errors.append({
   865	                'type': 'command_frontmatter_missing_field',
   866	                'severity': 'blocking',
   867	                'message': f"Command frontmatter is missing required field '{field}'",
   868	                'fix_hint': f"Add a single-line '{field}:' entry to the frontmatter",
   869	            })
   870	
   871	    # Description: reject YAML multiline block form first, then measure the user-visible value.
   872	    if re.search(r'description:\s*\n\s+', frontmatter) or re.search(r'^description:\s*[|>]\s*$', frontmatter, flags=re.MULTILINE):
   873	        errors.append({
   874	            'type': 'command_description_multiline',
   875	            'severity': 'blocking',
   876	            'message': 'Command description uses YAML multiline block format (must be single line after colon)',
   877	            'fix_hint': 'Collapse the description onto one line after the colon',
   878	        })
   879	    else:
   880	        desc_match = re.search(r'description:\s*(.+)', frontmatter)
   881	        if desc_match:
   882	            description = _strip_matching_quotes(desc_match.group(1))
   883	            length_error, length_warning = _check_description_length(description, _DESC_SOFT_COMMAND)
   884	            if length_error:
   885	                errors.append({
   886	                    'type': 'command_description_over_hard_cap',
   887	                    'severity': 'blocking',
   888	                    'message': length_error,
   889	                    'fix_hint': 'Trim the description below the hard cap so the command registers',
   890	                })
   891	            elif length_warning:
   892	                errors.append({
   893	                    'type': 'command_description_over_soft_target',
   894	                    'severity': 'warning',
   895	                    'message': length_warning,
   896	                    'fix_hint': 'Trim the description toward the soft target',
   897	                })
   898	            if '<' in description or '>' in description:
   899	                errors.append({
   900	                    'type': 'command_description_angle_brackets',
   901	                    'severity': 'warning',
   902	                    'message': 'Command description contains angle brackets (< or >) — allowed as <arg> placeholder notation; confirm it is not stray markup',
   903	                    'fix_hint': 'If the brackets are not intentional <arg> notation, remove them',
   904	                })
   905	            if 'TODO' in description.upper():
   906	                errors.append({
   907	                    'type': 'command_description_todo',
   908	                    'severity': 'warning',
   909	                    'message': 'Command description contains a TODO placeholder — please complete it',
   910	                    'fix_hint': 'Replace the TODO with the real description',
   911	                })
   912	
   913	    # argument-hint budget: the hint summarizes the invocation shape, EXECUTION
   914	    # TARGETS enumerates the full flag surface. An over-budget hint is a soft
   915	    # signal to move detail into the router body, never a hard failure.
   916	    hint_match = re.search(r'^argument-hint:\s*(.+)$', frontmatter, re.MULTILINE)
   917	    if hint_match:
   918	        hint_value = _strip_matching_quotes(hint_match.group(1))
   919	        if len(hint_value) > _HINT_SOFT_BUDGET:
   920	            errors.append({
   921	                'type': 'command_argument_hint_over_budget',
   922	                'severity': 'warning',
   923	                'message': (
   924	                    f'argument-hint is {len(hint_value)} chars, over the soft budget of '
   925	                    f'{_HINT_SOFT_BUDGET} — the hint should summarize; EXECUTION TARGETS enumerates'
   926	                ),
   927	                'fix_hint': 'Summarize the invocation in the hint; move the full flag list into the router body',
   928	            })
   929	
   930	    # allowed-tools: any token in the mcp_ namespace must be a fully-qualified
   931	    # mcp__<server>__<tool> reference; a bare or server-only token is an
   932	    # under-specified permission. Native tools and non-namespaced plugin tools pass.
   933	    tools_match = re.search(r'^allowed-tools:\s*(.+)$', frontmatter, re.MULTILINE)
   934	    if tools_match:
   935	        for token in _iter_allowed_tools(tools_match.group(1)):
   936	            if _is_non_fq_mcp_token(token):
   937	                errors.append({
   938	                    'type': 'command_allowed_tools_non_fq_mcp',
   939	                    'severity': 'blocking',
   940	                    'message': f"allowed-tools entry '{token}' is a non-fully-qualified MCP tool token — use mcp__<server>__<tool>",
   941	                    'fix_hint': f"Replace '{token}' with its fully-qualified mcp__<server>__<tool> form",
   942	                })
   943	
   944	    # Ergonomics: a trailing `User request: $ARGUMENTS` raw-echo is a deprecated
   945	    # idiom. The command already receives $ARGUMENTS; echoing it verbatim adds no
   946	    # routing behavior and duplicates the argument surface the router resolves.
   947	    # Warn, never block — it is harmless, just legacy.
   948	    body = content[match.end():]
   949	    if re.search(r'^User request:\s*\$ARGUMENTS\s*$', body, re.MULTILINE):
   950	        errors.append({
   951	            'type': 'command_raw_argument_echo',
   952	            'severity': 'warning',
   953	            'message': 'Command carries the deprecated `User request: $ARGUMENTS` raw-echo — the command already receives $ARGUMENTS; the echo adds no routing behavior',
   954	            'fix_hint': 'Remove the raw-echo line; the router body resolves $ARGUMENTS directly',
   955	        })
   956	
   957	    return errors
   958	
   959	
   960	def validate_document(
   961	    file_path: str,
   962	    doc_type: Optional[str] = None,
   963	    rules: Optional[Dict[str, Any]] = None,
   964	    skip_exclusions: bool = False,
   965	) -> Dict[str, Any]:
   966	    """
   967	    Validate a markdown document against template rules.
   968	
   969	    Args:
   970	        file_path: Path to the markdown file
   971	        doc_type: Document type (readme, skill, etc.) - auto-detected if None
   972	        rules: Template rules dict - loaded from JSON if None
   973	        skip_exclusions: If True, validate even excluded paths
   974	
   975	    Returns:
   976	        dict: Validation result with errors, warnings, and summary
   977	    """
   978	    # Check path exclusions (unless explicitly skipped)
   979	    if not skip_exclusions:
   980	        excluded, reason = should_exclude_path(file_path)
   182	
   183	Invariants:
   184	
   185	- Root file is always `feature-catalog.md` in lowercase.
   186	- Category directories use descriptive kebab-case names such as `category-name` (no numeric prefix).
   187	- Per-feature files use kebab-case names such as `feature-name.md` without numeric prefixes.
   188	- One root entry maps to exactly one per-feature file.
   189	- Slugs should remain stable after publication.
   190	- Display order is owned by the root catalog index (`feature-catalog.md`), not the folder name.
   191	- Per-feature snippet order is defined by the root catalog listing order; filenames do not encode order.
   192	
   193	### Required Resources
   194	
   195	Use these packet resources while authoring:
   196	
   197	- `assets/feature-catalog-template.md` for the root catalog scaffold.
   198	- `assets/feature-catalog-snippet-template.md` for each per-feature file.
   199	- `../shared/references/quick-reference.md` and `../shared/references/validation.md` before delivery.
   200	- `../shared/references/frontmatter-versioning.md` when checking frontmatter version fields.
   201	- `references/README.md` to route the reference overflow — [`examples.md`](references/examples.md) (worked live-catalog walkthrough) and [`common-pitfalls.md`](references/common-pitfalls.md) (deep-dive pitfalls, template-versus-reference split) — only for depth beyond this inline workflow.
   202	
   203	The source assets keep the filenames `feature-catalog-template.md` and `feature-catalog-snippet-template.md` until their separate source-file migration. Those filenames are authoring inputs, not emitted package names.
   204	
   205	---
   206	
   207	## 4. HOW IT WORKS: CREATION WORKFLOW
   208	
   209	Follow this workflow in order.
   210	
   211	1. Read the target system docs, source files, command surfaces, MCP tool lists, tests, and existing README material before drafting the catalog.
   212	2. Decide whether a catalog is warranted; use a README summary instead when the feature surface is small, complete, stable, or too volatile for a maintained catalog.
   213	3. Decide the category taxonomy before writing prose.
   214	4. Stabilize category names, feature names, and feature slugs before polishing descriptions.
   215	5. Create `feature-catalog/feature-catalog.md` from `assets/feature-catalog-template.md`.
   216	6. Create one category folder per root section using a descriptive kebab-case slug such as `category-name`; the root catalog listing defines display order.
   217	7. Create one per-feature file for each root entry using `assets/feature-catalog-snippet-template.md`.
   218	8. Write concise root summaries and link each feature to its per-feature file.
   219	9. Fill each per-feature `## 2. HOW IT WORKS` section with current behavior.
   220	10. Use plain prose for short `HOW IT WORKS` sections and H3 subheadings for sections longer than three paragraphs.
   221	11. Fill implementation source tables and validation or test anchor tables for every feature claim.
   222	12. Fill `## 4. SOURCE METADATA`, including group, canonical file path, and related references.
   223	13. Validate the root catalog and each per-feature leaf file with shared validation (see §7).
   224	14. Manually verify feature-file links, root-entry parity, source anchors, and current-state wording.
   225	
   226	Authoring order matters:
   227	
   228	- Stabilize names and slugs before polishing prose.
   229	- Finish root taxonomy before expanding file-level detail.
   230	- Use implementation and test anchors to justify every feature summary.
   231	
   232	---
   233	
   234	## 5. ROOT CATALOG REQUIREMENTS
   235	
   236	The root catalog is the top-level inventory and navigation layer.
   237	
   238	It owns:
   239	
   240	- Frontmatter with title, description, trigger phrases, last updated date, and four-part version.
   241	- A short H1 intro describing the current feature surface.
   242	- `## 1. OVERVIEW`.
   243	- Numbered H2 capability sections by category.
   244	- H3 feature entries with concise descriptions.
   245	- Current-reality summaries.
   246	- Explicit links to per-feature files.
   247	
   248	Root summaries should answer:
   249	
   250	- What this feature does.
   251	- What its current reality is.
   252	- Where to find source-file and test detail.
   253	
   254	Package highlights for root catalogs:
   255	
   256	- Use frontmatter, including `trigger_phrases`.
   257	- Include a short H1 intro.
   258	- Do not include a Table of Contents.
   259	- Do not use `<!-- ANCHOR -->` navigation comments.
   260	- Start numbered H2 sections with `## 1. OVERVIEW`.
   261	
   262	Do not overload the root catalog with:
   263	
   264	- Exhaustive source-file tables.
   265	- Full scenario matrices.
   266	- Speculative future-state design.
   267	- Long implementation explanations.
   268	- Roadmap detail.
   269	
   270	That information belongs in per-feature files, playbooks, or specs.
   271	
   272	---
   273	
   274	## 6. PER-FEATURE FILE REQUIREMENTS
   275	
   276	Each per-feature file is the detailed reference entry for one catalog item.
   277	
   278	Required structure:
   279	
   280	1. `## 1. OVERVIEW`
   281	2. `## 2. HOW IT WORKS`
   282	3. `## 3. SOURCE FILES`
   283	4. `## 4. SOURCE METADATA`
   284	
   285	Each per-feature file must include:
   286	
   287	- Frontmatter with stable `title`, one-line `description`, `trigger_phrases`, and a four-part `version`.
   288	- At least three trigger phrases matching the H3 heading in the root catalog.
   289	- An H1 matching the feature, with a tool or command name in parentheses when relevant.
   290	- A concise overview of the feature.
   291	- A behavior-focused `HOW IT WORKS` section.
   292	- Implementation source tables with `File | Layer | Role` columns.
   293	- Validation or test anchors with `File | Type | Role` columns.
   294	- Metadata including group, canonical file path, and related references.
   295	
   296	`HOW IT WORKS` subheading rule:
   297	
   298	- Use plain prose when the section is three paragraphs or fewer.
   299	- Add H3 subheadings when the section exceeds three paragraphs.
   300	- Preferred H3 examples include `### Core Behavior`, `### Quality Gates`, `### Configuration`, `### Edge Cases`, and `### Async & Safety`.
   301	- Describe behavior from the caller or operator perspective, not the implementation perspective.
   302	
   303	Content rule:
   304	
   305	- Describe behavior that exists now.
   306	- If a rollout or compatibility layer is documented, label it explicitly.
   307	- Avoid roadmap or speculative wording unless the feature itself is a documented compatibility or feature-flag surface.
   308	
   309	---
   310	
   311	## 7. PLAYBOOK AND VALIDATION BOUNDARY
   312	
   313	Feature catalogs and manual testing playbooks serve different purposes.
   314	
   315	| Document | Primary Question |
   316	|---|---|
   317	| Feature catalog | What does the system do today? |
   318	| Manual testing playbook | How do we validate that behavior manually? |
   319	
   320	Cross-reference rule:
   321	
   322	- Playbooks should link back to the matching catalog entry when one exists.
   323	- Catalogs should stay focused on current behavior, not test execution detail.
   324	- Manual execution scenario matrices belong in playbooks, not catalogs.
   325	
   326	Validation workflow — run from the repo root so the validator resolves the `feature_catalog` doc type on per-feature leaves (leaf detection accepts the canonical `feature-catalog/<category>/` path during the bounded compatibility window):
   327	
   328	```bash
   329	# New-content naming guard. The staging root must contain only the newly authored
   330	# canonical feature-catalog package, never an ancestor with shipped legacy roots.
   331	python3 .opencode/skills/sk-doc/shared/scripts/check_no_hyphenated_catalog_content.py <new-content-staging-root>
   332	
   333	# Root catalog (detected as the readme doc type)
   334	python3 .opencode/skills/sk-doc/shared/scripts/validate_document.py <target-skill>/feature-catalog/feature-catalog.md
   335	python3 .opencode/skills/sk-doc/shared/scripts/extract_structure.py <target-skill>/feature-catalog/feature-catalog.md
   336	
   337	# Each per-feature leaf (detected as the feature_catalog doc type; validates the Validation And Tests table taxonomy)
   338	python3 .opencode/skills/sk-doc/shared/scripts/validate_document.py <target-skill>/feature-catalog/<category-name>/feature-name.md
   339	```
   340	
   341	The staging scope is mandatory until shipped underscore roots are migrated. Do not run this guard against `.opencode/skills` or another ancestor containing legacy `feature_catalog/` or `manual_testing_playbook/` trees.
   342	
   343	The validator machine-checks the root-catalog structure and each leaf's Validation And Tests table, but not cross-file link targets or source-anchor accuracy. Manually verify:
   344	
   345	- Every root entry links to an existing per-feature file.
     1	#!/usr/bin/env python3
     2	# ---------------------------------------------------------------------------
     3	# COMPONENT: Catalog Content Naming Guard
     4	# ---------------------------------------------------------------------------
     5	"""Enforce kebab-case for catalog and playbook content.
     6	
     7	Category folders and per-feature Markdown files must use kebab-case, matching the
     8	repo-wide filesystem-naming convention; an underscore in a content name is a
     9	violation. Root index files are outside the check because only content below a
    10	category folder is in scope. An underscore catalog/playbook ROOT is a hard error
    11	(the canonical roots are hyphenated) and is rejected before content is scanned.
    12	
    13	Usage:
    14	  check_no_hyphenated_catalog_content.py [ROOT]
    15	  check_no_hyphenated_catalog_content.py --json [ROOT]
    16	
    17	The historical --enforce-hyphen-target flag is accepted for backward
    18	compatibility but is now the default behavior.
    19	"""
    20	import json
    21	import sys
    22	from pathlib import Path
    23	
    24	
    25	sys.path.insert(0, str(Path(__file__).resolve().parent))
    26	from naming_root_resolver import ALL_ROOT_NAMES, find_unsupported_root_dirs  # type: ignore
    27	
    28	
    29	def find_underscored_content(root: Path):
    30	    """Return catalog/playbook content paths whose folder or Markdown name uses an underscore."""
    31	    offenders = []
    32	    for category_root in ALL_ROOT_NAMES:
    33	        for parent in root.rglob(category_root):
    34	            if not parent.is_dir():
    35	                continue
    36	            for category in parent.iterdir():
    37	                if not category.is_dir():
    38	                    continue
    39	                for candidate in [category, *category.rglob('*')]:
    40	                    if candidate.is_dir() and '_' in candidate.name:
    41	                        offenders.append(candidate)
    42	                    elif candidate.is_file() and candidate.suffix == '.md' and '_' in candidate.name:
    43	                        offenders.append(candidate)
    44	    return sorted(set(offenders))
    45	
    46	
    47	def main(argv) -> int:
    48	    # --enforce-hyphen-target is accepted but inert: enforcing kebab content is now the default.
    49	    flags = {'--json', '--enforce-hyphen-target'}
    50	    args = [argument for argument in argv if argument not in flags]
    51	    as_json = '--json' in argv
    52	    root = Path(args[0]) if args else Path('.opencode/skills')
    53	    if not root.exists():
    54	        print(f'ERROR: root not found: {root}', file=sys.stderr)
    55	        return 2
    56	
    57	    unsupported = find_unsupported_root_dirs(root)
    58	    if unsupported:
    59	        print(f'ERROR: unsupported catalog/playbook root: {unsupported[0]}', file=sys.stderr)
    60	        return 2
    61	
    62	    offenders = find_underscored_content(root)
    63	    paths = [str(path) for path in offenders]
    64	    if as_json:
    65	        print(json.dumps({'clean': not offenders, 'offenders': paths}, indent=2))
    66	    elif offenders:
    67	        print(f'FAIL: {len(offenders)} underscore catalog/playbook content path(s) found (use kebab-case):')
    68	        for offender in paths:
    69	            print(f'  - {offender}')
    70	    else:
    71	        print('PASS: catalog/playbook content is kebab-case.')
    72	    return 1 if offenders else 0
    73	
    74	
    75	if __name__ == '__main__':
    76	    sys.exit(main(sys.argv[1:]))

codex
The strongest new issue is not merely “catalogs are absent.” Six eligible hubs lack the canonical hub-root inventory entirely, so adding a lone compiled-routing leaf would falsely present a partial catalog as complete. A second template defect is confirmed: the per-feature scaffold says its `trigger_phrases` drive advisor routing, but the advisor harvest only walks `references/` and `assets/`, never `feature-catalog/`. I’m closing with the exact validation boundary and baseline results.
