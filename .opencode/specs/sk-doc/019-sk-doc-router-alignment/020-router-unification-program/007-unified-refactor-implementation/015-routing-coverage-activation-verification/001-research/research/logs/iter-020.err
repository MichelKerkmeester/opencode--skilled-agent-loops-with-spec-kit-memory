   274	  // mk-spec-memory's package root — not this advisor's own database. Compute
   275	  // the child's MEMORY_DB_PATH explicitly from the dedicated skill-advisor
   276	  // override var (never from a blindly-forwarded ambient MEMORY_DB_PATH — that
   277	  // name's repo-wide established meaning is mk-spec-memory's own database, so
   278	  // treating it as "already configured for skill-advisor" would silently
   279	  // reopen the exact leak this pointer exists to prevent).
   280	  const explicitOverride = typeof sourceEnv.MK_SKILL_ADVISOR_MEMORY_DB_PATH === 'string'
