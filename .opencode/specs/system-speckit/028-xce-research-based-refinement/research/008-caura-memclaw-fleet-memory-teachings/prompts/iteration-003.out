{"type":"tool_use","timestamp":1780727798920,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_9ghEGyt53uKrZj8TqhOmRiHA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/db/session.py","offset":1,"limit":95},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/db/session.py</path>\n<type>file</type>\n<content>\n1: import contextvars\n2: from collections.abc import AsyncGenerator\n3: \n4: from sqlalchemy import text\n5: from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker, create_async_engine\n6: \n7: from core_api.config import settings\n8: \n9: # asyncpg: enable SSL when the database requires it (default for managed\n10: # Postgres providers — required, e.g., on AlloyDB's ENCRYPTED_ONLY mode).\n11: _connect_args = {}\n12: if settings.postgres_require_ssl:\n13:     _connect_args[\"ssl\"] = \"require\"\n14:     if settings.postgres_use_iam_auth:\n15:         _connect_args[\"ssl\"] = True  # full verification for IAM auth\n16: \n17: engine = create_async_engine(\n18:     settings.database_url,\n19:     echo=False,\n20:     pool_size=int(getattr(settings, \"db_pool_size\", 50)),\n21:     max_overflow=int(getattr(settings, \"db_max_overflow\", 50)),\n22:     pool_timeout=120,\n23:     pool_recycle=1800,\n24:     pool_pre_ping=True,\n25:     connect_args=_connect_args,\n26: )\n27: async_session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)\n28: \n29: # Context variable for RLS: set by auth middleware before DB access\n30: _current_tenant_id: contextvars.ContextVar[str | None] = contextvars.ContextVar(\n31:     \"_current_tenant_id\", default=None\n32: )\n33: # Additional readable tenants (writes still go to ``_current_tenant_id``).\n34: # Set when the caller authenticated with a credential authorized for\n35: # cross-tenant reads. The list always includes the home tenant_id when\n36: # populated; an empty list means \"single-tenant key, no widening\".\n37: _readable_tenant_ids: contextvars.ContextVar[list[str] | None] = contextvars.ContextVar(\n38:     \"_readable_tenant_ids\", default=None\n39: )\n40: \n41: \n42: def set_current_tenant(tenant_id: str | None) -> None:\n43:     \"\"\"Set the tenant_id for RLS enforcement in the current request context.\"\"\"\n44:     _current_tenant_id.set(tenant_id)\n45: \n46: \n47: def get_current_tenant() -> str | None:\n48:     \"\"\"Get the tenant_id for the current request context.\"\"\"\n49:     return _current_tenant_id.get()\n50: \n51: \n52: def set_readable_tenants(tenant_ids: list[str] | None) -> None:\n53:     \"\"\"Set the set of tenants the current caller may READ from.\n54: \n55:     A single-tenant caller does not need to call this — reads default to\n56:     ``_current_tenant_id`` only. Cross-tenant credentials populate this\n57:     list so read paths and RLS policies can widen scope while writes\n58:     remain pinned to the home tenant_id.\n59:     \"\"\"\n60:     _readable_tenant_ids.set(list(tenant_ids) if tenant_ids else [])\n61: \n62: \n63: def get_readable_tenants() -> list[str]:\n64:     \"\"\"Get the cross-tenant read set for the current request context.\"\"\"\n65:     return _readable_tenant_ids.get() or []\n66: \n67: \n68: async def get_db() -> AsyncGenerator[AsyncSession]:\n69:     async with async_session() as session:\n70:         # Set RLS context variable for this session\n71:         tenant_id = _current_tenant_id.get()\n72:         if tenant_id:\n73:             await session.execute(\n74:                 text(\"SELECT set_config('app.tenant_id', :tid, true)\"),\n75:                 {\"tid\": tenant_id},\n76:             )\n77:         else:\n78:             await session.execute(text(\"SELECT set_config('app.tenant_id', '__admin__', true)\"))\n79:         # Plumb the readable-tenant set as a second GUC. Deployments that\n80:         # apply RLS may extend their policies to honor this for read paths;\n81:         # in OSS-default deployments it is informational only.\n82:         readable = _readable_tenant_ids.get() or []\n83:         await session.execute(\n84:             text(\"SELECT set_config('app.readable_tenant_ids', :csv, true)\"),\n85:             {\"csv\": \",\".join(readable) if readable else \"\"},\n86:         )\n87:         yield session\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"import contextvars\nfrom collections.abc import AsyncGenerator\n\nfrom sqlalchemy import text\nfrom sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker, create_async_engine\n\nfrom core_api.config import settings\n\n# asyncpg: enable SSL when the database requires it (default for managed\n# Postgres providers — required, e.g., on AlloyDB's ENCRYPTED_ONLY mode).\n_connect_args = {}\nif settings.postgres_require_ssl:\n    _connect_args[\"ssl\"] = \"require\"\n    if settings.postgres_use_iam_auth:\n        _connect_args[\"ssl\"] = True  # full verification for IAM auth\n\nengine = create_async_engine(\n    settings.database_url,\n    echo=False,\n    pool_size=int(getattr(settings, \"db_pool_size\", 50)),","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/db/session.py","text":"import contextvars\nfrom collections.abc import AsyncGenerator\n\nfrom sqlalchemy import text\nfrom sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker, create_async_engine\n\nfrom core_api.config import settings\n\n# asyncpg: enable SSL when the database requires it (default for managed\n# Postgres providers — required, e.g., on AlloyDB's ENCRYPTED_ONLY mode).\n_connect_args = {}\nif settings.postgres_require_ssl:\n    _connect_args[\"ssl\"] = \"require\"\n    if settings.postgres_use_iam_auth:\n        _connect_args[\"ssl\"] = True  # full verification for IAM auth\n\nengine = create_async_engine(\n    settings.database_url,\n    echo=False,\n    pool_size=int(getattr(settings, \"db_pool_size\", 50)),\n    max_overflow=int(getattr(settings, \"db_max_overflow\", 50)),\n    pool_timeout=120,\n    pool_recycle=1800,\n    pool_pre_ping=True,\n    connect_args=_connect_args,\n)\nasync_session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)\n\n# Context variable for RLS: set by auth middleware before DB access\n_current_tenant_id: contextvars.ContextVar[str | None] = contextvars.ContextVar(\n    \"_current_tenant_id\", default=None\n)\n# Additional readable tenants (writes still go to ``_current_tenant_id``).\n# Set when the caller authenticated with a credential authorized for\n# cross-tenant reads. The list always includes the home tenant_id when\n# populated; an empty list means \"single-tenant key, no widening\".\n_readable_tenant_ids: contextvars.ContextVar[list[str] | None] = contextvars.ContextVar(\n    \"_readable_tenant_ids\", default=None\n)\n\n\ndef set_current_tenant(tenant_id: str | None) -> None:\n    \"\"\"Set the tenant_id for RLS enforcement in the current request context.\"\"\"\n    _current_tenant_id.set(tenant_id)\n\n\ndef get_current_tenant() -> str | None:\n    \"\"\"Get the tenant_id for the current request context.\"\"\"\n    return _current_tenant_id.get()\n\n\ndef set_readable_tenants(tenant_ids: list[str] | None) -> None:\n    \"\"\"Set the set of tenants the current caller may READ from.\n\n    A single-tenant caller does not need to call this — reads default to\n    ``_current_tenant_id`` only. Cross-tenant credentials populate this\n    list so read paths and RLS policies can widen scope while writes\n    remain pinned to the home tenant_id.\n    \"\"\"\n    _readable_tenant_ids.set(list(tenant_ids) if tenant_ids else [])\n\n\ndef get_readable_tenants() -> list[str]:\n    \"\"\"Get the cross-tenant read set for the current request context.\"\"\"\n    return _readable_tenant_ids.get() or []\n\n\nasync def get_db() -> AsyncGenerator[AsyncSession]:\n    async with async_session() as session:\n        # Set RLS context variable for this session\n        tenant_id = _current_tenant_id.get()\n        if tenant_id:\n            await session.execute(\n                text(\"SELECT set_config('app.tenant_id', :tid, true)\"),\n                {\"tid\": tenant_id},\n            )\n        else:\n            await session.execute(text(\"SELECT set_config('app.tenant_id', '__admin__', true)\"))\n        # Plumb the readable-tenant set as a second GUC. Deployments that\n        # apply RLS may extend their policies to honor this for read paths;\n        # in OSS-default deployments it is informational only.\n        readable = _readable_tenant_ids.get() or []\n        await session.execute(\n            text(\"SELECT set_config('app.readable_tenant_ids', :csv, true)\"),\n            {\"csv\": \",\".join(readable) if readable else \"\"},\n        )\n        yield session","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/db/session.py","time":{"start":1780727798913,"end":1780727798916}},"metadata":{"openai":{"itemId":"fc_09d024be34609338016a23bff5663c819198e20e8dcfd7f330"}},"id":"prt_e9ba5d6aa001P3oMCuayVJUtMd","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba5ccc0001vVom6iyOLkwsP8"}}
