Scope(rawHydeCandidates, scopeFilter)\n\n  Line 1348:               ? filterRowsByScope(contextFilteredSummaryHits, scopeFilter)\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-governance.vitest.ts:\n  Line 10:   filterRowsByScope,\n\n  Line 34:     const filtered = filterRowsByScope([\n\n  Line 53:     const filtered = filterRowsByScope(rows, {});\n\n  Line 59:     const filtered = filterRowsByScope([\n\n  Line 272:     expect(filterRowsByScope(rows, {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/stage1-expansion.vitest.ts:\n  Line 161:   filterRowsByScope: (rows: Array<Record<string, unknown>>, scope: Record<string, unknown>) =>\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/community-search.vitest.ts:\n  Line 19: import { filterRowsByScope } from '../lib/governance/scope-governance';\n\n  Line 136: // member-row SELECT (now including scope columns) + filterRowsByScope step.\n\n  Line 204:     const scoped = filterRowsByScope(rows, { tenantId: 'A' });\n\n  Line 215:     // No scope -> handler skips filterRowsByScope entirely; rows are unchanged.\n\n  Line 227:     const scoped = filterRowsByScope(rows, { tenantId: 'A' });\n","metadata":{"matches":25,"truncated":false},"title":"function filterRowsByScope|export function filterRowsByScope|filterRowsByScope","time":{"start":1781762001298,"end":1781762001322}},"metadata":{"openai":{"itemId":"fc_04b1a8c76e7da141016a3387d0efa08191bb68d690dc6efd19"}},"id":"prt_ed94a8991001am9WLNTMSPo3AH","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a5471001hkTtDTRJeQO1ew"}}
