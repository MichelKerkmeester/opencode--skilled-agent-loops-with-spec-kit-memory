      effective_mode = data.metadata_mode or \"merge\"\n\n  Line 2385:         if effective_mode == \"replace\":\n\n  Line 2389:                 \"mode\": \"replace\",\n\n  Line 2401:                     \"metadata=null has no effect in merge mode; \"\n\n  Line 2402:                     'use metadata_mode=\"replace\" to clear the column'\n\n  Line 2406:             # Top-level JSONB ``||`` merge at the storage layer.\n\n  Line 2407:             # Nested objects are replaced, not recursively merged.\n\n  Line 2412:                 \"mode\": \"merge\",\n\n  Line 2415:         # else (empty dict in merge mode) → storage no-op, no audit\n\n  Line 2418:     # Entity links: replace if explicitly provided\n\n  Line 2425:             \"old\": \"replaced\",\n\n  Line 2435:     # merge-mode patches from contributing to ``patch`` / ``changes``;\n\n  Line 2438:     # ``{\"metadata\": null}`` request (or a ``metadata_mode``-only\n\n  Line 2449:                 resource_type=\"memory\",\n\n\n(Results truncated: showing 100 of 488 matches (388 hidden). Consider using a more specific path or pattern.)","metadata":{"matches":488,"truncated":true},"title":"manual|human|system-managed|overwrite|clobber|metadata_mode|merge|replace|created_by|source_uri|source","time":{"start":1780727786069,"end":1780727786101}},"metadata":{"openai":{"itemId":"fc_0cd04fcabb3e6098016a23bfe9f2e88191b5f5eef92755aa82"}},"id":"prt_e9ba5aa54001KN82nFZm9qit0c","sessionID":"ses_1645cad2dffe08ToAptcWOhE23","messageID":"msg_e9ba57813001D0TJQLwB0TjkkG"}}
