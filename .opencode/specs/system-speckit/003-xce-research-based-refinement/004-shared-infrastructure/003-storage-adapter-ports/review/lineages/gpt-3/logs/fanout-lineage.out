{"type":"tool_use","timestamp":1781144359458,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_aBjSsEUzs6DKRhta9tfnG5E0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: BFS Traversal\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type Database from 'better-sqlite3';\n6: \n7: type TraversalNode = number | string;\n8: \n9: const SQLITE_BINDING_CHUNK_SIZE = 900;\n10: \n11: /** Edge returned by a weighted graph reader. */\n12: export interface WeightedTraversalEdge<TNode extends TraversalNode> {\n13:   readonly from: TNode;\n14:   readonly to: TNode;\n15:   readonly weight: number;\n16:   readonly strength?: number;\n17: }\n18: \n19: /** Aggregated weighted walk output for one reached node. */\n20: export interface WeightedWalkResult<TNode extends TraversalNode> {\n21:   readonly nodeId: TNode;\n22:   readonly minHop: number;\n23:   readonly maxWalkScore: number;\n24: }\n25: \n26: /** Options for hop-capped weighted graph traversal. */\n27: export interface WeightedWalkOptions<TNode extends TraversalNode> {\n28:   readonly seeds: readonly TNode[];\n29:   readonly maxHops: number;\n30:   readonly readEdges: (nodeIds: readonly TNode[]) => readonly WeightedTraversalEdge<TNode>[];\n31: }\n32: \n33: /** Edge returned by a directed graph reader. */\n34: export interface DirectedTraversalEdge<TNode extends TraversalNode> {\n35:   readonly from: TNode;\n36:   readonly to: TNode;\n37: }\n38: \n39: /** Options for directed reachability traversal. */\n40: export interface DirectedReachabilityOptions<TNode extends TraversalNode> {\n41:   readonly roots: readonly TNode[];\n42:   readonly readEdges: (nodeIds: readonly TNode[]) => readonly DirectedTraversalEdge<TNode>[];\n43: }\n44: \n45: interface WeightedWalkState<TNode extends TraversalNode> {\n46:   readonly origin: TNode;\n47:   readonly nodeId: TNode;\n48:   readonly hop: number;\n49:   readonly walkScore: number;\n50: }\n51: \n52: interface CausalEdgeRow {\n53:   readonly source_id: string;\n54:   readonly target_id: string;\n55:   readonly relation: string;\n56:   readonly strength: number | null;\n57: }\n58: \n59: interface DependencyEdgeRow {\n60:   readonly parent_path: string;\n61:   readonly child_path: string;\n62: }\n63: \n64: function uniqueNodes<TNode extends TraversalNode>(nodeIds: readonly TNode[]): TNode[] {\n65:   return Array.from(new Set(nodeIds));\n66: }\n67: \n68: function sameNode<TNode extends TraversalNode>(left: TNode, right: TNode): boolean {\n69:   return left === right;\n70: }\n71: \n72: function stateKey<TNode extends TraversalNode>(state: WeightedWalkState<TNode>): string {\n73:   return `${String(state.origin)}\\u0000${String(state.nodeId)}\\u0000${state.hop}\\u0000${state.walkScore}`;\n74: }\n75: \n76: function groupWeightedEdges<TNode extends TraversalNode>(\n77:   edges: readonly WeightedTraversalEdge<TNode>[],\n78: ): Map<TNode, WeightedTraversalEdge<TNode>[]> {\n79:   const grouped = new Map<TNode, WeightedTraversalEdge<TNode>[]>();\n80:   for (const edge of edges) {\n81:     const group = grouped.get(edge.from) ?? [];\n82:     group.push(edge);\n83:     grouped.set(edge.from, group);\n84:   }\n85:   return grouped;\n86: }\n87: \n88: function placeholders(count: number): string {\n89:   return Array.from({ length: count }, () => '?').join(', ');\n90: }\n91: \n92: function chunks<T>(items: readonly T[], size: number): T[][] {\n93:   const result: T[][] = [];\n94:   for (let index = 0; index < items.length; index += size) {\n95:     result.push(items.slice(index, index + size));\n96:   }\n97:   return result;\n98: }\n99: \n100: function relationWeight(relation: string, relationWeights: Readonly<Record<string, number>>): number {\n101:   const multiplier = relationWeights[relation] ?? 1.0;\n102:   return Number.isFinite(multiplier) ? multiplier : 1.0;\n103: }\n104: \n105: function edgeStrength(value: number | null): number {\n106:   return typeof value === 'number' && Number.isFinite(value) ? value : 1.0;\n107: }\n108: \n109: function nextWalkScore<TNode extends TraversalNode>(\n110:   state: WeightedWalkState<TNode>,\n111:   edge: WeightedTraversalEdge<TNode>,\n112: ): number {\n113:   const weighted = state.walkScore * edge.weight;\n114:   return edge.strength === undefined ? weighted : weighted * edge.strength;\n115: }\n116: \n117: /**\n118:  * Run a hop-capped weighted walk and aggregate by reached node.\n119:  * The aggregation intentionally keeps min hop and max score independent.\n120:  */\n121: export function collectWeightedWalk<TNode extends TraversalNode>(\n122:   options: WeightedWalkOptions<TNode>,\n123: ): Map<TNode, WeightedWalkResult<TNode>> {\n124:   const maxHops = Math.max(0, Math.trunc(options.maxHops));\n125:   const seeds = uniqueNodes(options.seeds);\n126:   const seedSet = new Set(seeds);\n127:   const results = new Map<TNode, WeightedWalkResult<TNode>>();\n128:   if (seeds.length === 0 || maxHops === 0) {\n129:     return results;\n130:   }\n131: \n132:   let frontier: WeightedWalkState<TNode>[] = seeds.map((seed) => ({\n133:     origin: seed,\n134:     nodeId: seed,\n135:     hop: 0,\n136:     walkScore: 1.0,\n137:   }));\n138:   const seenStates = new Set<string>();\n139: \n140:   while (frontier.length > 0) {\n141:     const expandable = frontier.filter((state) => state.hop < maxHops);\n142:     if (expandable.length === 0) break;\n143: \n144:     const nodeIds = uniqueNodes(expandable.map((state) => state.nodeId));\n145:     const edgesByFrom = groupWeightedEdges(options.readEdges(nodeIds));\n146:     const nextFrontier: WeightedWalkState<TNode>[] = [];\n147: \n148:     for (const state of expandable) {\n149:       const edges = edgesByFrom.get(state.nodeId) ?? [];\n150:       for (const edge of edges) {\n151:         if (state.hop > 0 && sameNode(edge.to, state.origin)) {\n152:           continue;\n153:         }\n154: \n155:         const nextState: WeightedWalkState<TNode> = {\n156:           origin: state.origin,\n157:           nodeId: edge.to,\n158:           hop: state.hop + 1,\n159:           walkScore: nextWalkScore(state, edge),\n160:         };\n161:         const key = stateKey(nextState);\n162:         if (seenStates.has(key)) {\n163:           continue;\n164:         }\n165:         seenStates.add(key);\n166:         nextFrontier.push(nextState);\n167: \n168:         if (seedSet.has(nextState.nodeId)) {\n169:           continue;\n170:         }\n171: \n172:         const current = results.get(nextState.nodeId);\n173:         if (!current) {\n174:           results.set(nextState.nodeId, {\n175:             nodeId: nextState.nodeId,\n176:             minHop: nextState.hop,\n177:             maxWalkScore: nextState.walkScore,\n178:           });\n179:         } else {\n180:           results.set(nextState.nodeId, {\n181:             nodeId: nextState.nodeId,\n182:             minHop: Math.min(current.minHop, nextState.hop),\n183:             maxWalkScore: Math.max(current.maxWalkScore, nextState.walkScore),\n184:           });\n185:         }\n186:       }\n187:     }\n188: \n189:     frontier = nextFrontier;\n190:   }\n191: \n192:   return results;\n193: }\n194: \n195: /** Collect all nodes reachable from the given roots through directed edges. */\n196: export function collectDirectedReachability<TNode extends TraversalNode>(\n197:   options: DirectedReachabilityOptions<TNode>,\n198: ): TNode[] {\n199:   const roots = uniqueNodes(options.roots);\n200:   if (roots.length === 0) {\n201:     return [];\n202:   }\n203: \n204:   const rootSet = new Set(roots);\n205:   const visited = new Set<TNode>();\n206:   const reached: TNode[] = [];\n207:   let frontier = roots;\n208: \n209:   while (frontier.length > 0) {\n210:     const nextFrontier: TNode[] = [];\n211:     const edges = options.readEdges(frontier);\n212: \n213:     for (const edge of edges) {\n214:       if (visited.has(edge.to)) {\n215:         continue;\n216:       }\n217:       visited.add(edge.to);\n218:       if (!rootSet.has(edge.to)) {\n219:         reached.push(edge.to);\n220:       }\n\n(Showing lines 1-220 of 332. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: BFS Traversal\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype TraversalNode = number | string;\n\nconst SQLITE_BINDING_CHUNK_SIZE = 900;\n\n/** Edge returned by a weighted graph reader. */\nexport interface WeightedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n  readonly weight: number;\n  readonly strength?: number;\n}\n\n/** Aggregated weighted walk output for one reached node. */\nexport interface WeightedWalkResult<TNode extends TraversalNode> {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: BFS Traversal\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype TraversalNode = number | string;\n\nconst SQLITE_BINDING_CHUNK_SIZE = 900;\n\n/** Edge returned by a weighted graph reader. */\nexport interface WeightedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n  readonly weight: number;\n  readonly strength?: number;\n}\n\n/** Aggregated weighted walk output for one reached node. */\nexport interface WeightedWalkResult<TNode extends TraversalNode> {\n  readonly nodeId: TNode;\n  readonly minHop: number;\n  readonly maxWalkScore: number;\n}\n\n/** Options for hop-capped weighted graph traversal. */\nexport interface WeightedWalkOptions<TNode extends TraversalNode> {\n  readonly seeds: readonly TNode[];\n  readonly maxHops: number;\n  readonly readEdges: (nodeIds: readonly TNode[]) => readonly WeightedTraversalEdge<TNode>[];\n}\n\n/** Edge returned by a directed graph reader. */\nexport interface DirectedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n}\n\n/** Options for directed reachability traversal. */\nexport interface DirectedReachabilityOptions<TNode extends TraversalNode> {\n  readonly roots: readonly TNode[];\n  readonly readEdges: (nodeIds: readonly TNode[]) => readonly DirectedTraversalEdge<TNode>[];\n}\n\ninterface WeightedWalkState<TNode extends TraversalNode> {\n  readonly origin: TNode;\n  readonly nodeId: TNode;\n  readonly hop: number;\n  readonly walkScore: number;\n}\n\ninterface CausalEdgeRow {\n  readonly source_id: string;\n  readonly target_id: string;\n  readonly relation: string;\n  readonly strength: number | null;\n}\n\ninterface DependencyEdgeRow {\n  readonly parent_path: string;\n  readonly child_path: string;\n}\n\nfunction uniqueNodes<TNode extends TraversalNode>(nodeIds: readonly TNode[]): TNode[] {\n  return Array.from(new Set(nodeIds));\n}\n\nfunction sameNode<TNode extends TraversalNode>(left: TNode, right: TNode): boolean {\n  return left === right;\n}\n\nfunction stateKey<TNode extends TraversalNode>(state: WeightedWalkState<TNode>): string {\n  return `${String(state.origin)}\\u0000${String(state.nodeId)}\\u0000${state.hop}\\u0000${state.walkScore}`;\n}\n\nfunction groupWeightedEdges<TNode extends TraversalNode>(\n  edges: readonly WeightedTraversalEdge<TNode>[],\n): Map<TNode, WeightedTraversalEdge<TNode>[]> {\n  const grouped = new Map<TNode, WeightedTraversalEdge<TNode>[]>();\n  for (const edge of edges) {\n    const group = grouped.get(edge.from) ?? [];\n    group.push(edge);\n    grouped.set(edge.from, group);\n  }\n  return grouped;\n}\n\nfunction placeholders(count: number): string {\n  return Array.from({ length: count }, () => '?').join(', ');\n}\n\nfunction chunks<T>(items: readonly T[], size: number): T[][] {\n  const result: T[][] = [];\n  for (let index = 0; index < items.length; index += size) {\n    result.push(items.slice(index, index + size));\n  }\n  return result;\n}\n\nfunction relationWeight(relation: string, relationWeights: Readonly<Record<string, number>>): number {\n  const multiplier = relationWeights[relation] ?? 1.0;\n  return Number.isFinite(multiplier) ? multiplier : 1.0;\n}\n\nfunction edgeStrength(value: number | null): number {\n  return typeof value === 'number' && Number.isFinite(value) ? value : 1.0;\n}\n\nfunction nextWalkScore<TNode extends TraversalNode>(\n  state: WeightedWalkState<TNode>,\n  edge: WeightedTraversalEdge<TNode>,\n): number {\n  const weighted = state.walkScore * edge.weight;\n  return edge.strength === undefined ? weighted : weighted * edge.strength;\n}\n\n/**\n * Run a hop-capped weighted walk and aggregate by reached node.\n * The aggregation intentionally keeps min hop and max score independent.\n */\nexport function collectWeightedWalk<TNode extends TraversalNode>(\n  options: WeightedWalkOptions<TNode>,\n): Map<TNode, WeightedWalkResult<TNode>> {\n  const maxHops = Math.max(0, Math.trunc(options.maxHops));\n  const seeds = uniqueNodes(options.seeds);\n  const seedSet = new Set(seeds);\n  const results = new Map<TNode, WeightedWalkResult<TNode>>();\n  if (seeds.length === 0 || maxHops === 0) {\n    return results;\n  }\n\n  let frontier: WeightedWalkState<TNode>[] = seeds.map((seed) => ({\n    origin: seed,\n    nodeId: seed,\n    hop: 0,\n    walkScore: 1.0,\n  }));\n  const seenStates = new Set<string>();\n\n  while (frontier.length > 0) {\n    const expandable = frontier.filter((state) => state.hop < maxHops);\n    if (expandable.length === 0) break;\n\n    const nodeIds = uniqueNodes(expandable.map((state) => state.nodeId));\n    const edgesByFrom = groupWeightedEdges(options.readEdges(nodeIds));\n    const nextFrontier: WeightedWalkState<TNode>[] = [];\n\n    for (const state of expandable) {\n      const edges = edgesByFrom.get(state.nodeId) ?? [];\n      for (const edge of edges) {\n        if (state.hop > 0 && sameNode(edge.to, state.origin)) {\n          continue;\n        }\n\n        const nextState: WeightedWalkState<TNode> = {\n          origin: state.origin,\n          nodeId: edge.to,\n          hop: state.hop + 1,\n          walkScore: nextWalkScore(state, edge),\n        };\n        const key = stateKey(nextState);\n        if (seenStates.has(key)) {\n          continue;\n        }\n        seenStates.add(key);\n        nextFrontier.push(nextState);\n\n        if (seedSet.has(nextState.nodeId)) {\n          continue;\n        }\n\n        const current = results.get(nextState.nodeId);\n        if (!current) {\n          results.set(nextState.nodeId, {\n            nodeId: nextState.nodeId,\n            minHop: nextState.hop,\n            maxWalkScore: nextState.walkScore,\n          });\n        } else {\n          results.set(nextState.nodeId, {\n            nodeId: nextState.nodeId,\n            minHop: Math.min(current.minHop, nextState.hop),\n            maxWalkScore: Math.max(current.maxWalkScore, nextState.walkScore),\n          });\n        }\n      }\n    }\n\n    frontier = nextFrontier;\n  }\n\n  return results;\n}\n\n/** Collect all nodes reachable from the given roots through directed edges. */\nexport function collectDirectedReachability<TNode extends TraversalNode>(\n  options: DirectedReachabilityOptions<TNode>,\n): TNode[] {\n  const roots = uniqueNodes(options.roots);\n  if (roots.length === 0) {\n    return [];\n  }\n\n  const rootSet = new Set(roots);\n  const visited = new Set<TNode>();\n  const reached: TNode[] = [];\n  let frontier = roots;\n\n  while (frontier.length > 0) {\n    const nextFrontier: TNode[] = [];\n    const edges = options.readEdges(frontier);\n\n    for (const edge of edges) {\n      if (visited.has(edge.to)) {\n        continue;\n      }\n      visited.add(edge.to);\n      if (!rootSet.has(edge.to)) {\n        reached.push(edge.to);\n      }","lineStart":1,"lineEnd":220,"totalLines":332,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","time":{"start":1781144359451,"end":1781144359456}},"metadata":{"openai":{"itemId":"fc_009241286761af1b016a2a1b26d88c8191a18adb33179790ca"}},"id":"prt_eb47a0fc50013JqrGh2o7EHa48","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb479fca6001LDBcTIZ2npear0"}}
