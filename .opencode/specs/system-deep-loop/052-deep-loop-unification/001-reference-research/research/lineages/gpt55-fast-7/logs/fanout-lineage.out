ok', 1.2], ['sk-doc', 0.2]],\n104:   '/memory:save': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n105:   '/deep:start-research-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n106:   '/deep:start-review-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n107:   '/deep:start-model-benchmark-loop': [['deep-model-benchmark', 1.6], ['command-spec-kit', 0.45]],\n108:   '/deep:start-agent-improvement-loop': [['deep-loop-workflows', 1.6], ['command-spec-kit', 0.45]],\n109:   '/speckit:resume': [['system-spec-kit', 0.9], ['command-spec-kit', 0.75]],\n110:   'auto review release readiness': [['deep-loop-workflows', 1]],\n111:   // Colon-command syntax (\":review:auto\") is a deep-review LOOP invocation,\n112:   // distinct from natural-language \"auto review this PR\" (which routes to\n113:   // sk-code's code-review mode). Strong direct-evidence anchor + a bounded\n114:   // penalty on the single-pass skill so the loop skill wins the rank.\n115:   ':review:auto': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n116:   ':review:confirm': [['deep-loop-workflows', 1.6], ['sk-code', -0.6]],\n117:   // Domain phrase anchors (multi-token, so they lift confidence via the direct\n118:   // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n119:   'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n120:   'cms collection': [['mcp-code-mode', 1.4]],\n121:   'structural search': [['system-code-graph', 1.5]],\n122:   'code graph search': [['system-code-graph', 1.5]],\n123:   'find code that': [['system-code-graph', 1.4]],\n124:   'code that handles': [['system-code-graph', 1.4]],\n125:   '5d scoring': [['deep-loop-workflows', 1.5]],\n126:   '5-dimension agent scoring': [['deep-loop-workflows', 1.6]],\n127:   'integration scan': [['deep-loop-workflows', 1.5]],\n128:   'dynamic profile': [['deep-loop-workflows', 1.5]],\n129:   // Lane B (model-benchmark) command anchors. Th