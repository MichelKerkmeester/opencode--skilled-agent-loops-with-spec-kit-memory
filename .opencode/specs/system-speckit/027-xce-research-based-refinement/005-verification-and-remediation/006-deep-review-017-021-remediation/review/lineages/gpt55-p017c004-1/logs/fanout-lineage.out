{"type":"tool_use","timestamp":1781757828969,"sessionID":"ses_126f83aa0ffeGn1t6D6Ful5ZsW","part":{"type":"tool","tool":"read","callID":"call_s8rpze6fcL1XuJZYVp1Mza7Q","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","offset":421,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts</path>\n<type>file</type>\n<content>\n421: \n422:   // A sufficiently strong top hit is citable on its own, regardless of the tail.\n423:   if (topScore >= TOP_DOMINANT_THRESHOLD) {\n424:     return { requestQuality: { label: 'good' } };\n425:   }\n426:   // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n427:   // OR the top hit clearly dominates the runner-up.\n428:   if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n429:     return { requestQuality: { label: 'good' } };\n430:   }\n431:   // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n432:   // genuinely low-signal queries.\n433:   if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n434:     return { requestQuality: { label: 'weak' } };\n435:   }\n436:   return { requestQuality: { label: 'gap' } };\n437: }\n438: \n439: /**\n440:  * Check whether the per-result confidence feature flag is enabled.\n441:  * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n442:  */\n443: export { isResultConfidenceEnabled } from './search-flags.js';\n\n(End of file - total 443 lines)\n</content>","metadata":{"preview":"\n  // A sufficiently strong top hit is citable on its own, regardless of the tail.\n  if (topScore >= TOP_DOMINANT_THRESHOLD) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n  // OR the top hit clearly dominates the runner-up.\n  if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n  // genuinely low-signal queries.\n  if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n    return { requestQuality: { label: 'weak' } };\n  }\n  return { requestQuality: { label: 'gap' } };\n}\n\n/**\n * Check whether the per-result confidence feature flag is enabled.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","text":"\n  // A sufficiently strong top hit is citable on its own, regardless of the tail.\n  if (topScore >= TOP_DOMINANT_THRESHOLD) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n  // OR the top hit clearly dominates the runner-up.\n  if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n  // genuinely low-signal queries.\n  if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n    return { requestQuality: { label: 'weak' } };\n  }\n  return { requestQuality: { label: 'gap' } };\n}\n\n/**\n * Check whether the per-result confidence feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n */\nexport { isResultConfidenceEnabled } from './search-flags.js';","lineStart":421,"lineEnd":443,"totalLines":443,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","time":{"start":1781757828961,"end":1781757828968}},"metadata":{"openai":{"itemId":"fc_040ec3f5c6aab830016a337784e0b88191872f8ff4dbe11cc2"}},"id":"prt_ed90adf3b001kUYkv6ewyH6Jqy","sessionID":"ses_126f83aa0ffeGn1t6D6Ful5ZsW","messageID":"msg_ed90a7f3d001ryFZQCvs5rivYM"}}
{"type":"tool_use","timestamp":1781757828995,"sessionID":"ses_126f83aa0ffeGn1t6D6Ful5ZsW","part":{"type":"tool","tool":"read","callID":"call_85StdH27dxcMNlKRcBC5wBmN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","offset":700,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts</path>\n<type>file</type>\n<content>\n700: /**\n701:  * Mode-aware response profile formatting.\n702:  * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n703:  */\n704: export function isResponseProfileEnabled(): boolean {\n705:   return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n706: }\n707: \n708: /* ───────────────────────────────────────────────────────────────\n709:    14. PHASE B GRAPH RETRIEVAL FLAGS\n710: ──────────────────────────────────────────────────────────────── */\n711: \n712: /**\n713:  * Query concept expansion for hybrid search.\n714:  * When concept routing matches aliases, expands query with related terms.\n715:  * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n716:  */\n717: export function isQueryConceptExpansionEnabled(): boolean {\n718:   return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n719: }\n720: \n721: /**\n722:  * Graph-expanded fallback on zero/weak results.\n723:  * Queries causal_edges for neighbor titles when recovery triggers.\n724:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_FALLBACK=false to disable.\n725:  */\n726: export function isGraphFallbackEnabled(): boolean {\n727:   return isFeatureEnabled('SPECKIT_GRAPH_FALLBACK');\n728: }\n729: \n730: /**\n731:  * Always-on graph context injection.\n732:  * Runs concept routing + graph neighbor lookup even without seed results.\n733:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONTEXT_INJECTION=false to disable.\n734:  */\n735: export function isGraphContextInjectionEnabled(): boolean {\n736:   return isFeatureEnabled('SPECKIT_GRAPH_CONTEXT_INJECTION');\n737: }\n738: \n739: /**\n740:  * Result provenance — include graph evidence metadata in search results.\n741:  * When enabled, search results include graphEvidence with contributing edges,\n742:  * communities, and boost factors for transparency and debuggability.\n743:  * Default: TRUE (enabled). Set SPECKIT_RESULT_PROVENANCE=false to disable.\n744:  */\n745: export function isResultProvenanceEnabled(): boolean {\n746:   return isFeatureEnabled('SPECKIT_RESULT_PROVENANCE');\n747: }\n748: \n749: /**\n750:  * Temporal validity tracking for causal edges.\n751:  * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_EDGES=false to disable.\n752:  */\n753: export function isTemporalEdgesEnabled(): boolean {\n754:   return isFeatureEnabled('SPECKIT_TEMPORAL_EDGES');\n755: }\n756: \n757: /**\n758:  * Usage-weighted ranking signal.\n759:  * Default: TRUE (graduated). Set SPECKIT_USAGE_RANKING=false to disable.\n760:  */\n761: export function isUsageRankingEnabled(): boolean {\n762:   return isFeatureEnabled('SPECKIT_USAGE_RANKING');\n763: }\n764: \n765: /**\n766:  * Ontology-guided extraction validation hooks.\n767:  * Default: TRUE (graduated). Set SPECKIT_ONTOLOGY_HOOKS=false to disable.\n768:  */\n769: export function isOntologyHooksEnabled(): boolean {\n770:   return isFeatureEnabled('SPECKIT_ONTOLOGY_HOOKS');\n771: }\n772: \n773: /**\n774:  * Community-level search as fallback channel.\n775:  * When primary search returns weak/no results, searches community summaries\n776:  * and injects matching community members as candidates.\n777:  * Default: TRUE (graduated). Set SPECKIT_COMMUNITY_SEARCH_FALLBACK=false to disable.\n778:  */\n779: export function isCommunitySearchFallbackEnabled(): boolean {\n780:   return isFeatureEnabled('SPECKIT_COMMUNITY_SEARCH_FALLBACK');\n781: }\n782: \n783: /**\n784:  * Dual-level retrieval mode.\n785:  * Adds retrievalLevel parameter: 'local' (entity), 'global' (community), 'auto' (local + fallback).\n786:  * Default: TRUE (graduated). Set SPECKIT_DUAL_RETRIEVAL=false to disable.\n787:  */\n788: export function isDualRetrievalEnabled(): boolean {\n789:   return isFeatureEnabled('SPECKIT_DUAL_RETRIEVAL');\n790: }\n791: \n792: /**\n793:  * Phase C: Intent-to-profile auto-routing.\n794:  * When enabled, classifyIntent() results automatically select a response profile\n795:  * (quick, research, resume, debug) when no explicit profile is specified by the caller.\n796:  * Default: TRUE (graduated). Set SPECKIT_INTENT_AUTO_PROFILE=false to disable.\n797:  */\n798: export function isIntentAutoProfileEnabled(): boolean {\n799:   return isFeatureEnabled('SPECKIT_INTENT_AUTO_PROFILE');\n800: }\n\n(End of file - total 800 lines)\n</content>","metadata":{"preview":"/**\n * Mode-aware response profile formatting.\n * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n */\nexport function isResponseProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   14. PHASE B GRAPH RETRIEVAL FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Query concept expansion for hybrid search.\n * When concept routing matches aliases, expands query with related terms.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n */\nexport function isQueryConceptExpansionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","text":"/**\n * Mode-aware response profile formatting.\n * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n */\nexport function isResponseProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   14. PHASE B GRAPH RETRIEVAL FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Query concept expansion for hybrid search.\n * When concept routing matches aliases, expands query with related terms.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n */\nexport function isQueryConceptExpansionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n}\n\n/**\n * Graph-expanded fallback on zero/weak results.\n * Queries causal_edges for neighbor titles when recovery triggers.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_FALLBACK=false to disable.\n */\nexport function isGraphFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_FALLBACK');\n}\n\n/**\n * Always-on graph context injection.\n * Runs concept routing + graph neighbor lookup even without seed results.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONTEXT_INJECTION=false to disable.\n */\nexport function isGraphContextInjectionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CONTEXT_INJECTION');\n}\n\n/**\n * Result provenance — include graph evidence metadata in search results.\n * When enabled, search results include graphEvidence with contributing edges,\n * communities, and boost factors for transparency and debuggability.\n * Default: TRUE (enabled). Set SPECKIT_RESULT_PROVENANCE=false to disable.\n */\nexport function isResultProvenanceEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_PROVENANCE');\n}\n\n/**\n * Temporal validity tracking for causal edges.\n * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_EDGES=false to disable.\n */\nexport function isTemporalEdgesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TEMPORAL_EDGES');\n}\n\n/**\n * Usage-weighted ranking signal.\n * Default: TRUE (graduated). Set SPECKIT_USAGE_RANKING=false to disable.\n */\nexport function isUsageRankingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_USAGE_RANKING');\n}\n\n/**\n * Ontology-guided extraction validation hooks.\n * Default: TRUE (graduated). Set SPECKIT_ONTOLOGY_HOOKS=false to disable.\n */\nexport function isOntologyHooksEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ONTOLOGY_HOOKS');\n}\n\n/**\n * Community-level search as fallback channel.\n * When primary search returns weak/no results, searches community summaries\n * and injects matching community members as candidates.\n * Default: TRUE (graduated). Set SPECKIT_COMMUNITY_SEARCH_FALLBACK=false to disable.\n */\nexport function isCommunitySearchFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_SEARCH_FALLBACK');\n}\n\n/**\n * Dual-level retrieval mode.\n * Adds retrievalLevel parameter: 'local' (entity), 'global' (community), 'auto' (local + fallback).\n * Default: TRUE (graduated). Set SPECKIT_DUAL_RETRIEVAL=false to disable.\n */\nexport function isDualRetrievalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DUAL_RETRIEVAL');\n}\n\n/**\n * Phase C: Intent-to-profile auto-routing.\n * When enabled, classifyIntent() results automatically select a response profile\n * (quick, research, resume, debug) when no explicit profile is specified by the caller.\n * Default: TRUE (graduated). Set SPECKIT_INTENT_AUTO_PROFILE=false to disable.\n */\nexport function isIntentAutoProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_INTENT_AUTO_PROFILE');\n}","lineStart":700,"lineEnd":800,"totalLines":800,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","time":{"start":1781757828989,"end":1781757828994}},"metadata":{"openai":{"itemId":"fc_040ec3f5c6aab830016a337784e0d881919fe2cbbff9964850"}},"id":"prt_ed90adf7c001JbgqWImv6zYXUw","sessionID":"ses_126f83aa0ffeGn1t6D6Ful5ZsW","messageID":"msg_ed90a7f3d001ryFZQCvs5rivYM"}}
