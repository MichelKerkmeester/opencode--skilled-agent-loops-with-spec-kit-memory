 delete a\n1250:           // live successor lock. A losing racer's rename throws ENOENT and falls through to\n1251:           // the outer retry.\n1252:           const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n1253:           fs.renameSync(lockDir, staleClaim);\n1254:           fs.rmSync(staleClaim, { recursive: true, force: true });\n1255:           continue;\n1256:         }\n1257:       } catch (statErr) {\n1258:         // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n1259:         if (statErr.code === 'ENOENT') continue;\n1260:         if (statErr.code === 'ENOTEMPTY') continue;\n1261:         throw statErr;\n1262:       }\n1263:       if (artifactsReady() && !requireLock) {\n1264:         return false;\n1265:       }\n1266:       if (Date.now() > deadline) {\n1267:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n1268:       }\n1269:       await sleep(1000);\n1270:     }\n1271:   }\n1272: }\n1273: \n1274: function launchServer() {\n1275:   if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n1276:     log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n1277:     return false;\n1278:   }\n1279:   if (shouldSkipLaunch(childProcess)) {\n1280:     log('launchServer skipped: a context-server child is already running in this launcher process');\n1281:     return false;\n1282:   }\n1283:   if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n1284:   if (supervisorRelaunchTimer) {\n1285:     clearTimeout(supervisorRelaunchTimer);\n1286:     supervisorRelaunchTimer = null;\n1287:   }\n1288:   const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n1289:   const nodeArgs = getContextServerNodeArgs();\n1290:   const reelectionEnabled = daemonReelectionEnabled();\n1291:   const spawnIo = contextServerSpawnIo(reelectionEnabled);\n1292:   childProcess = spawn(process.execPath, [...nodeArgs, server], {\n1293:     cwd: root,\n1294:     env: {\n1295:       ...process.env,\n1296:       SPECKIT_BACKEND_ONLY: '1',\n1297:     },\n1298:     stdio: spawnIo.stdio,\n1299:     detached: spawnIo.detached,\n1300:   });\n1301:   // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n1302:   if (reelectionEnabled) childProcess.unref();\n1303:   const childPid = childProcess.pid;\n1304:   const refreshed = refreshOwnerLeaseFile(process.pid);\n1305:   if (!refreshed) {\n1306:     log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n1307:   }\n1308:   startOwnerLeaseHeartbeat(process.pid);\n1309:   writeLeaseFile(childPid);\n1310:   startRssWatchdog(childPid);\n1311: \n1312:   childProcess.on('exit', (code, signal) => {\n1313:     if (launcherShutdownInProgress) {\n1314:       return;\n1315:     }\n1316:     const result = superviseChildExit(\n1317:       { code, signal, childPid, intentional: false },\n1318:       {\n1319:         crashLoopGuard,\n1320:         clearLease: clearAllLeaseFiles,\n1321:         reapProcessGroup: reapProcessTreeGroups,\n1322:         mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n1323:         exit: (exitCode) => process.exit(exitCode),\n1324:         scheduleRelaunch: (backoffMs) => {\n1325:           log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n1326:           supervisorRelaunchTimer = setTimeout(() => {\n1327:             // Owner-disposal race guard: by the time the backoff fires, re-check that this\n1328:             // launcher is still live AND its owning runtime is still present. Respawning the\n1329:             // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n1330:             // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n1331:             // unaffected — both run with the owning runtime alive and no shutdown in progress.\n1332:             if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n1333:               log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n1334:               clearAllLeaseFiles();\n1335:               process.exit(0);\n1336:               return;\n1337:             }\n1338:             launchServer();\n1339:           }, backoffMs);\n1340:           supervisorRelaunchTimer.unref?.();\n1341:         },\n1342:       },\n1343:     );\n1344:     if (result.action === 'give-up') {\n1345:       log(`context-server crash loop detected after ${result.deathsInWindow} deaths; clearing lease and mirroring child exit`);\n1346:     }\n1347:   });\n1348: \n1349:   childProcess.on('error', (error) => {\n1350:     log(error.stack || error.message);\n1351:     process.exit(1);\n1352:   });\n1353:   if (rssBreachSelfExitInProgress) {\n1354:     rssBreachSelfExitInProgress = false;\n1355:   }\n1356:   return true;\n1357: }\n1358: \n1359: async function shutdownLauncherForSignal(signal) {\n1360:   if (launcherShutdownInProgress) return;\n1361:   launcherShutdownInProgress = true;\n1362:   if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n1363:   if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1364:   clearOwnerLeaseHeartbeat();\n1365:   hfControl.clearTimers();\n1366:   await hfControl.stopDemandListener();\n1367: \n1368:   // Re-election release path (default off): release the detached context-server for a live secondary to adopt\n1369:   // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n1370:   // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n1371:   // flag is off this branch is skipped and the original kill path below runs unchanged.\n1372:   if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n1373:     const releasedModelServer = hfControl.getChild();\n1374:     if (isChildRunning(releasedModelServer)) {\n1375:       hfControl.reapProcessTree(releasedModelServer.pid);\n1376:       releasedModelServer.kill(signal);\n1377:     }\n1378:     log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n1379:     // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n1380:     // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n1381:     process.removeListener('exit', clearAllLeaseFiles);\n1382:     clearOwnerLeaseFile();\n1383:     process.exit(0);\n1384:     return;\n1385:   }\n1386: \n1387:   const children = [];\n1388:   if (isChildRunning(childProcess)) {\n1389:     children.push({ child: childProcess, label: 'context-server' });\n1390:   }\n1391:   const modelServerChild = hfControl.getChild();\n1392:   if (isChildRunning(modelServerChild)) {\n1393:     children.push({ child: modelServerChild, label: 'hf-model-server' });\n1394:   }\n1395: \n1396:   if (children.length === 0) {\n1397:     clearAllLeaseFiles();\n1398:     process.exit(128);\n1399:     return;\n1400:   }\n1401: \n1402:   for (const { child, label } of children) {\n1403:     if (label === 'hf-model-server') {\n1404:       hfControl.reapProcessTree(child.pid);\n1405:     }\n1406:     child.kill(signal);\n1407:   }\n1408: \n1409:   const exited = await Promise.race([\n1410:     Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n1411:     sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n1412:   ]);\n1413:   if (!exited) {\n1414:     for (const { child } of children) {\n1415:       if (isChildRunning(child)) child.kill('SIGKILL');\n1416:     }\n1417:   }\n1418:   clearAllLeaseFiles();\n1419:   process.exit(128);\n1420: }\n1421: \n1422: function installSignalHandlers() {\n1423:   for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n1424:     process.on(signal, () => {\n1425:       void shutdownLauncherForSignal(signal).catch((error) => {\n1426:         log(error.stack || error.message);\n1427:         clearAllLeaseFiles();\n1428:         process.exit(128);\n1429:       });\n1430:     });\n1431:   }\n1432:   process.on('uncaughtException', (err) => {\n1433:     try {\n1434:       clearAllLeaseFiles();\n1435:     } catch {\n1436:       // Preserve default uncaughtException crash behavior.\n1437:     }\n1438:     throw err;\n1439:   });\n1440: }\n1441: \n1442: async function main() {\n1443:   loadProjectEnvFiles();\n1444:   const started = now();\n1445:   const actions = [];\n1446:   let lockHeld = false;\n1447: \n1448:   try {\n1449:     installSignalHandlers();\n1450:     // Lease cleanup runs unconditionally regardless of child termination path.\n1451:     process.on('exit', clearAllLeaseFiles);\n1452:     refreshPaths();\n1453: \n1454:     const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SPEC_MEMORY_STRICT_SINGLE_WRITER);\n1455:     ownerLeaseRequired = strictSingleWriter;\n1456:     if (strictSingleWriter) {\n1457:       const legacyLeaseResult = isLeaseHeld();\n1458:       if (legacyLeaseResult.held && legacyLeaseResult.legacyPath && !legacyLeaseResult.staleReclaimable) {\n1459:         await bridgeOrReportLeaseHeldAndExit(legacyLeaseResult);\n1460:         return;\n1461:       }\n1462:     }\n1463: \n1464:     ensureLayout(actions);\n1465:     refreshPaths();\n1466:     enforceStandaloneCodeGraphDb(actions);\n1467: \n1468:     if (strictSingleWriter) {\n1469:       const ownerLeaseResult = acquireOwnerLeaseFile();\n1470:       if (!ownerLeaseResult.acquired) {\n1471:         log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n1472:         await bridgeOrReportLeaseHeldAndExit(leaseResultForOwnerLease(ownerLeaseResult.holder));\n1473:         return;\n1474:       }\n1475: \n1476:       const leaseResult = isLeaseHeld();\n1477:       if (leaseResult.held && !leaseResult.staleReclaimable) {\n1478:         clearOwnerLeaseFile();\n1479:         await bridgeOrReportLeaseHeldAndExit(leaseResult);\n1480:         return;\n1481:       }\n1482:       if (leaseResult.staleReclaimable) {\n1483:         log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n1484:         // A re-election daemon released by a disposing owner stays alive under this stale\n1485:         // (dead-owner) lease, which records the live daemon as childPid. Reap that child before\n1486:         // spawning a replacement, or two daemons hold the same WAL database open until the\n1487:         // orphan's idle timeout. The owner-lease O_EXCL acquisition above is the spawn mutex, so\n1488:         // only the winning fresh launcher reaches here. Mirrors the dead-socket respawn reap.\n1489:         const staleLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n1490:         const orphanChildPid = staleLease?.childPid;\n1491:         if (Number.isInteger(orphanChildPid) && orphanChildPid > 0) {\n1492:           const reap = await reapLeaseChildBeforeRespawn(orphanChildPid);\n1493:           if (!reap.allowed) {\n1494:             // Cannot confirm the released daemon is gone (e.g. EPERM); spawning now would create a\n1495:             // second writer, so report the lease as held and let the host reconnect instead.\n1496:             log(`stale-reclaim aborted: ${reap.reason} for childPid=${orphanChildPid}; reporting lease held`);\n1497:             clearOwnerLeaseFile();\n1498:             writeLeaseHeldJsonRpcError(leaseResult, reap.reason);\n1499:             process.exit(0);\n1500:           }\n1501:         }\n1502:       }\n1503:     } else {\n1504:       log('MK_SPEC_MEMORY_STRICT_SINGLE_WRITER is disabled; skipping lease check');\n1505:     }\n1506: \n1507:     lockHeld = await acquireBootstrapLock();\n1508:     if (lockHeld) {\n1509:       buildIfNeeded(actions);\n1510:       writeState({\n1511:         command: 'mk-spec-memory-launcher',\n1512:         start: started,\n1513:         end: now(),\n1514:         status: 'ready',\n1515:         actions,\n1516:         server: rel(path.join(kitDir, 'mcp_server', 'dist', 'context-server.js')),\n1517:       });\n1518:       fs.rmSync(lockDir, { recursive: true, force: true });\n1519:       lockHeld = false;\n1520:     }\n1521: \n1522:     writeLeaseFile();\n1523:     const reprobe = readLeaseFile();\n1524:     if (!reprobe || reprobe.pid !== process.pid) {\n1525:       const startedAt = reprobe?.startedAt ?? new Date(0).toISOString();\n1526:       clearOwnerLeaseFile();\n1527:       writeLeaseHeldJsonRpcError({ ownerPid: reprobe ? reprobe.pid : 'unknown', startedAt }, 'lease-reprobe-lost');\n1528:       process.exit(0);\n1529:     }\n1530:     const launched = launchServer();\n1531:     if (!launched) return;\n1532:     if (launched) {\n1533:       const sessionProxy = createSessionProxy({\n1534:         socketPath: resolveSessionProxySocketPath(),\n1535:         stdin: process.stdin,\n1536:         stdout: process.stdout,\n1537:         log,\n\n(Showing lines 1218-1537 of 1612. Use offset=1538 to continue.)\n</content>","metadata":{"preview":"  return hfControl.launch();\n}\n\nfunction startModelServerDemandListener(options = {}) {\n  return hfControl.startDemandListener(options);\n}\n\nfunction stopModelServerDemandListener() {\n  return hfControl.stopDemandListener();\n}\n\nasync function acquireBootstrapLock(options = {}) {\n  const requireLock = options.requireLock === true;\n  fs.mkdirSync(dbDir, { recursive: true });\n  const deadline = Date.now() + 120000;\n  while (true) {\n    try {\n      fs.mkdirSync(lockDir);\n      return true;\n    } catch (error) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"  return hfControl.launch();\n}\n\nfunction startModelServerDemandListener(options = {}) {\n  return hfControl.startDemandListener(options);\n}\n\nfunction stopModelServerDemandListener() {\n  return hfControl.stopDemandListener();\n}\n\nasync function acquireBootstrapLock(options = {}) {\n  const requireLock = options.requireLock === true;\n  fs.mkdirSync(dbDir, { recursive: true });\n  const deadline = Date.now() + 120000;\n  while (true) {\n    try {\n      fs.mkdirSync(lockDir);\n      return true;\n    } catch (error) {\n      if (error.code !== 'EEXIST') {\n        throw error;\n      }\n      // Reclaim a stale lockdir left by a SIGKILL'd launcher (mtime-based; the lockdir records no pid),\n      // so a crashed holder cannot block a requireLock respawn for the full 120s deadline.\n      try {\n        const ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n        if (ageMs > BOOTSTRAP_LOCK_STALE_MS) {\n          log(`reclaiming stale bootstrap lock ${rel(lockDir)} (age ${Math.round(ageMs / 1000)}s)`);\n          // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n          // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n          // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n          // live successor lock. A losing racer's rename throws ENOENT and falls through to\n          // the outer retry.\n          const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n          fs.renameSync(lockDir, staleClaim);\n          fs.rmSync(staleClaim, { recursive: true, force: true });\n          continue;\n        }\n      } catch (statErr) {\n        // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n        if (statErr.code === 'ENOENT') continue;\n        if (statErr.code === 'ENOTEMPTY') continue;\n        throw statErr;\n      }\n      if (artifactsReady() && !requireLock) {\n        return false;\n      }\n      if (Date.now() > deadline) {\n        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n      }\n      await sleep(1000);\n    }\n  }\n}\n\nfunction launchServer() {\n  if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n    log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n    return false;\n  }\n  if (shouldSkipLaunch(childProcess)) {\n    log('launchServer skipped: a context-server child is already running in this launcher process');\n    return false;\n  }\n  if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n  if (supervisorRelaunchTimer) {\n    clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = null;\n  }\n  const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n  const nodeArgs = getContextServerNodeArgs();\n  const reelectionEnabled = daemonReelectionEnabled();\n  const spawnIo = contextServerSpawnIo(reelectionEnabled);\n  childProcess = spawn(process.execPath, [...nodeArgs, server], {\n    cwd: root,\n    env: {\n      ...process.env,\n      SPECKIT_BACKEND_ONLY: '1',\n    },\n    stdio: spawnIo.stdio,\n    detached: spawnIo.detached,\n  });\n  // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n  if (reelectionEnabled) childProcess.unref();\n  const childPid = childProcess.pid;\n  const refreshed = refreshOwnerLeaseFile(process.pid);\n  if (!refreshed) {\n    log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n  }\n  startOwnerLeaseHeartbeat(process.pid);\n  writeLeaseFile(childPid);\n  startRssWatchdog(childPid);\n\n  childProcess.on('exit', (code, signal) => {\n    if (launcherShutdownInProgress) {\n      return;\n    }\n    const result = superviseChildExit(\n      { code, signal, childPid, intentional: false },\n      {\n        crashLoopGuard,\n        clearLease: clearAllLeaseFiles,\n        reapProcessGroup: reapProcessTreeGroups,\n        mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n        exit: (exitCode) => process.exit(exitCode),\n        scheduleRelaunch: (backoffMs) => {\n          log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n          supervisorRelaunchTimer = setTimeout(() => {\n            // Owner-disposal race guard: by the time the backoff fires, re-check that this\n            // launcher is still live AND its owning runtime is still present. Respawning the\n            // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n            // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n            // unaffected — both run with the owning runtime alive and no shutdown in progress.\n            if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n              log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n              clearAllLeaseFiles();\n              process.exit(0);\n              return;\n            }\n            launchServer();\n          }, backoffMs);\n          supervisorRelaunchTimer.unref?.();\n        },\n      },\n    );\n    if (result.action === 'give-up') {\n      log(`context-server crash loop detected after ${result.deathsInWindow} deaths; clearing lease and mirroring child exit`);\n    }\n  });\n\n  childProcess.on('error', (error) => {\n    log(error.stack || error.message);\n    process.exit(1);\n  });\n  if (rssBreachSelfExitInProgress) {\n    rssBreachSelfExitInProgress = false;\n  }\n  return true;\n}\n\nasync function shutdownLauncherForSignal(signal) {\n  if (launcherShutdownInProgress) return;\n  launcherShutdownInProgress = true;\n  if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n  if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n  clearOwnerLeaseHeartbeat();\n  hfControl.clearTimers();\n  await hfControl.stopDemandListener();\n\n  // Re-election release path (default off): release the detached context-server for a live secondary to adopt\n  // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n  // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n  // flag is off this branch is skipped and the original kill path below runs unchanged.\n  if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n    const releasedModelServer = hfControl.getChild();\n    if (isChildRunning(releasedModelServer)) {\n      hfControl.reapProcessTree(releasedModelServer.pid);\n      releasedModelServer.kill(signal);\n    }\n    log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n    // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n    // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n    process.removeListener('exit', clearAllLeaseFiles);\n    clearOwnerLeaseFile();\n    process.exit(0);\n    return;\n  }\n\n  const children = [];\n  if (isChildRunning(childProcess)) {\n    children.push({ child: childProcess, label: 'context-server' });\n  }\n  const modelServerChild = hfControl.getChild();\n  if (isChildRunning(modelServerChild)) {\n    children.push({ child: modelServerChild, label: 'hf-model-server' });\n  }\n\n  if (children.length === 0) {\n    clearAllLeaseFiles();\n    process.exit(128);\n    return;\n  }\n\n  for (const { child, label } of children) {\n    if (label === 'hf-model-server') {\n      hfControl.reapProcessTree(child.pid);\n    }\n    child.kill(signal);\n  }\n\n  const exited = await Promise.race([\n    Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n    sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n  ]);\n  if (!exited) {\n    for (const { child } of children) {\n      if (isChildRunning(child)) child.kill('SIGKILL');\n    }\n  }\n  clearAllLeaseFiles();\n  process.exit(128);\n}\n\nfunction installSignalHandlers() {\n  for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n    process.on(signal, () => {\n      void shutdownLauncherForSignal(signal).catch((error) => {\n        log(error.stack || error.message);\n        clearAllLeaseFiles();\n        process.exit(128);\n      });\n    });\n  }\n  process.on('uncaughtException', (err) => {\n    try {\n      clearAllLeaseFiles();\n    } catch {\n      // Preserve default uncaughtException crash behavior.\n    }\n    throw err;\n  });\n}\n\nasync function main() {\n  loadProjectEnvFiles();\n  const started = now();\n  const actions = [];\n  let lockHeld = false;\n\n  try {\n    installSignalHandlers();\n    // Lease cleanup runs unconditionally regardless of child termination path.\n    process.on('exit', clearAllLeaseFiles);\n    refreshPaths();\n\n    const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SPEC_MEMORY_STRICT_SINGLE_WRITER);\n    ownerLeaseRequired = strictSingleWriter;\n    if (strictSingleWriter) {\n      const legacyLeaseResult = isLeaseHeld();\n      if (legacyLeaseResult.held && legacyLeaseResult.legacyPath && !legacyLeaseResult.staleReclaimable) {\n        await bridgeOrReportLeaseHeldAndExit(legacyLeaseResult);\n        return;\n      }\n    }\n\n    ensureLayout(actions);\n    refreshPaths();\n    enforceStandaloneCodeGraphDb(actions);\n\n    if (strictSingleWriter) {\n      const ownerLeaseResult = acquireOwnerLeaseFile();\n      if (!ownerLeaseResult.acquired) {\n        log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n        await bridgeOrReportLeaseHeldAndExit(leaseResultForOwnerLease(ownerLeaseResult.holder));\n        return;\n      }\n\n      const leaseResult = isLeaseHeld();\n      if (leaseResult.held && !leaseResult.staleReclaimable) {\n        clearOwnerLeaseFile();\n        await bridgeOrReportLeaseHeldAndExit(leaseResult);\n        return;\n      }\n      if (leaseResult.staleReclaimable) {\n        log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n        // A re-election daemon released by a disposing owner stays alive under this stale\n        // (dead-owner) lease, which records the live daemon as childPid. Reap that child before\n        // spawning a replacement, or two daemons hold the same WAL database open until the\n        // orphan's idle timeout. The owner-lease O_EXCL acquisition above is the spawn mutex, so\n        // only the winning fresh launcher reaches here. Mirrors the dead-socket respawn reap.\n        const staleLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n        const orphanChildPid = staleLease?.childPid;\n        if (Number.isInteger(orphanChildPid) && orphanChildPid > 0) {\n          const reap = await reapLeaseChildBeforeRespawn(orphanChildPid);\n          if (!reap.allowed) {\n            // Cannot confirm the released daemon is gone (e.g. EPERM); spawning now would create a\n            // second writer, so report the lease as held and let the host reconnect instead.\n            log(`stale-reclaim aborted: ${reap.reason} for childPid=${orphanChildPid}; reporting lease held`);\n            clearOwnerLeaseFile();\n            writeLeaseHeldJsonRpcError(leaseResult, reap.reason);\n            process.exit(0);\n          }\n        }\n      }\n    } else {\n      log('MK_SPEC_MEMORY_STRICT_SINGLE_WRITER is disabled; skipping lease check');\n    }\n\n    lockHeld = await acquireBootstrapLock();\n    if (lockHeld) {\n      buildIfNeeded(actions);\n      writeState({\n        command: 'mk-spec-memory-launcher',\n        start: started,\n        end: now(),\n        status: 'ready',\n        actions,\n        server: rel(path.join(kitDir, 'mcp_server', 'dist', 'context-server.js')),\n      });\n      fs.rmSync(lockDir, { recursive: true, force: true });\n      lockHeld = false;\n    }\n\n    writeLeaseFile();\n    const reprobe = readLeaseFile();\n    if (!reprobe || reprobe.pid !== process.pid) {\n      const startedAt = reprobe?.startedAt ?? new Date(0).toISOString();\n      clearOwnerLeaseFile();\n      writeLeaseHeldJsonRpcError({ ownerPid: reprobe ? reprobe.pid : 'unknown', startedAt }, 'lease-reprobe-lost');\n      process.exit(0);\n    }\n    const launched = launchServer();\n    if (!launched) return;\n    if (launched) {\n      const sessionProxy = createSessionProxy({\n        socketPath: resolveSessionProxySocketPath(),\n        stdin: process.stdin,\n        stdout: process.stdout,\n        log,","lineStart":1218,"lineEnd":1537,"totalLines":1612,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780907076308,"end":1780907076312}},"metadata":{"openai":{"itemId":"fc_07dfbd0c09fb7632016a267c43c68c8191840eebbac7a46d93"}},"id":"prt_ea6556ac2001VDnED038tjt47n","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea6553782001xQp6wJJvGN6Ikw"}}
{"type":"step_finish","timestamp":1780907076577,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"id":"prt_ea6556bdf001sYKCHQ4Xilp3KV","reason":"tool-calls","snapshot":"95fe7661c62e0524cfdacb747507913c7185287d","messageID":"msg_ea6553782001xQp6wJJvGN6Ikw","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","type":"step-finish","tokens":{"total":198297,"input":7821,"output":334,"reasoning":190,"cache":{"write":0,"read":189952}},"cost":0}}
{"type":"step_start","timestamp":1780907079306,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"id":"prt_ea6557687001V33ZNtq9wiEK6J","messageID":"msg_ea6556cc30014ww7qRQLgKoXB1","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","snapshot":"95fe7661c62e0524cfdacb747507913c7185287d","type":"step-start"}}
{"type":"tool_use","timestamp":1780907088358,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_pDt0swQGuKkqJ5sUDPNLQOlG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // The sibling release-integration test proves the OS-level release-vs-kill\n6: // DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n7: // feature actually promises: with the flag ON, when an OWNER session disposes the\n8: // shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n9: // flag OFF the daemon DIES with its owner and the secondary loses transport.\n10: //\n11: // It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n12: // isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n13: // SIGTERM (what a host does on session end), and observes the shared daemon's pid\n14: // and the secondary's next call.\n15: //\n16: // SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n17: // launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n18: // the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n19: // guard resolves to the fake root, never the production tree); node_modules and\n20: // scripts are symlinked; the IPC socket lives in a short isolated dir. No\n21: // production lease, DB, or socket is read or written. Only processes this test\n22: // starts are signalled, tracked by pid, and force-reaped in teardown.\n23: \n24: import { spawn, execSync, type ChildProcess } from 'node:child_process';\n25: import { cpSync, copyFileSync, existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync } from 'node:fs';\n26: import { tmpdir } from 'node:os';\n27: import { dirname, join, resolve } from 'node:path';\n28: import { fileURLToPath } from 'node:url';\n29: \n30: import { afterEach, describe, expect, it } from 'vitest';\n31: \n32: // stress_test/durability/<file> -> repo root is six levels up.\n33: const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\n34: const realBin = join(repoRoot, '.opencode/bin');\n35: const realKit = join(repoRoot, '.opencode/skills/system-spec-kit');\n36: const realMcp = join(realKit, 'mcp_server');\n37: \n38: const trackedPids = new Set<number>();\n39: const tempDirs = new Set<string>();\n40: \n41: function track(pid: number | undefined): void {\n42:   if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n43: }\n44: function isAlive(pid: number): boolean {\n45:   try { process.kill(pid, 0); return true; }\n46:   catch (e) { return (e as NodeJS.ErrnoException).code === 'EPERM'; }\n47: }\n48: function delay(ms: number): Promise<void> { return new Promise((r) => setTimeout(r, ms)); }\n49: \n50: function pgrepContains(needle: string): number[] {\n51:   try {\n52:     const out = execSync(`pgrep -f \"${needle}\" || true`).toString().trim();\n53:     return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n54:   } catch { return []; }\n55: }\n56: \n57: // Distinct pids holding any *.sqlite* file open under dbDir. One = single writer.\n58: function sqliteOpenerPids(dbDir: string): number[] {\n59:   try {\n60:     const out = execSync(\n61:       `lsof +D \"${dbDir}\" 2>/dev/null | awk 'NR>1 && ($9 ~ /\\\\.(db|sqlite|sqlite3)/) {print $2}' | sort -u`,\n62:     ).toString().trim();\n63:     return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n64:   } catch { return []; }\n65: }\n66: \n67: // Build an isolated fake-root: real-copied launcher + daemon dist, symlinked deps,\n68: // fresh lease/db dir. Returns the paths the two sessions share.\n69: function buildFakeRoot(): { base: string; sockDir: string; dbDir: string; launcher: string } {\n70:   const base = mkdtempSync(join(tmpdir(), 'rladopt.'));\n71:   tempDirs.add(base);\n72:   const fbin = join(base, '.opencode/bin');\n73:   const fkit = join(base, '.opencode/skills/system-spec-kit');\n74:   const fmcp = join(fkit, 'mcp_server');\n75:   mkdirSync(fbin, { recursive: true });\n76:   mkdirSync(fmcp, { recursive: true });\n77:   copyFileSync(join(realBin, 'mk-spec-memory-launcher.cjs'), join(fbin, 'mk-spec-memory-launcher.cjs'));\n78:   symlinkSync(join(realBin, 'lib'), join(fbin, 'lib'));\n79:   cpSync(join(realMcp, 'dist'), join(fmcp, 'dist'), { recursive: true });\n80:   symlinkSync(join(realMcp, 'node_modules'), join(fmcp, 'node_modules'));\n81:   if (existsSync(join(realKit, 'node_modules'))) symlinkSync(join(realKit, 'node_modules'), join(fkit, 'node_modules'));\n82:   symlinkSync(join(realMcp, 'package.json'), join(fmcp, 'package.json'));\n83:   symlinkSync(join(realKit, 'scripts'), join(fkit, 'scripts'));\n84:   const dbDir = join(fmcp, 'database');\n85:   mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n86:   const sockDir = mkdtempSync(join(tmpdir(), 'rladsk.'));\n87:   tempDirs.add(sockDir);\n88:   return { base, sockDir, dbDir, launcher: join(fbin, 'mk-spec-memory-launcher.cjs') };\n89: }\n90: \n91: type RpcResponse = { result?: unknown; error?: unknown; id?: number | null };\n92: \n93: // A minimal newline-delimited MCP JSON-RPC client over a launcher's stdio.\n94: function makeClient(child: ChildProcess) {\n95:   let buf = '';\n96:   const pending = new Map<number, (m: RpcResponse) => void>();\n97:   child.stdout!.setEncoding('utf8');\n98:   child.stdout!.on('data', (chunk: string) => {\n99:     buf += chunk;\n100:     let nl: number;\n101:     while ((nl = buf.indexOf('\\n')) >= 0) {\n102:       const line = buf.slice(0, nl).trim();\n103:       buf = buf.slice(nl + 1);\n104:       if (!line) continue;\n105:       let msg: RpcResponse;\n106:       try { msg = JSON.parse(line); } catch { continue; }\n107:       if (msg.id != null && pending.has(msg.id)) { pending.get(msg.id)!(msg); pending.delete(msg.id); }\n108:     }\n109:   });\n110:   child.stderr!.setEncoding('utf8');\n111:   child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n112:   let nextId = 1;\n113:   function request(method: string, params: unknown, timeoutMs = 30_000): Promise<RpcResponse> {\n114:     const id = nextId++;\n115:     return new Promise((resolveReq, rejectReq) => {\n116:       const timer = setTimeout(() => { pending.delete(id); rejectReq(new Error(`${method} timed out`)); }, timeoutMs);\n117:       pending.set(id, (m) => { clearTimeout(timer); resolveReq(m); });\n118:       try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', id, method, params }) + '\\n'); }\n119:       catch (e) { clearTimeout(timer); pending.delete(id); rejectReq(e as Error); }\n120:     });\n121:   }\n122:   function notify(method: string, params: unknown): void {\n123:     try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n124:   }\n125:   return { request, notify };\n126: }\n127: \n128: async function startSession(\n129:   paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n130:   enabled: boolean,\n131: ): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n132:   const child = spawn(process.execPath, [paths.launcher], {\n133:     cwd: paths.base,\n134:     env: {\n135:       ...process.env,\n136:       SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n137:       SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n138:       SPEC_KIT_DB_DIR: paths.dbDir,\n139:       SPECKIT_LAUNCHER_LOG: '1',\n140:       AI_SESSION_CHILD: '1',\n141:     },\n142:     stdio: ['pipe', 'pipe', 'pipe'],\n143:   });\n144:   track(child.pid);\n145:   const client = makeClient(child);\n146:   const init = await client.request('initialize', {\n147:     protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n148:   }, 30_000);\n149:   if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n150:   client.notify('notifications/initialized', {});\n151:   return { child, client };\n152: }\n153: \n154: function leaseDaemonPid(base: string): number | null {\n155:   const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n156:   try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n157: }\n158: async function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n159:   try {\n160:     const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n161:     return !r.error;\n162:   } catch { return false; }\n163: }\n164: async function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n165:   const deadline = Date.now() + timeoutMs;\n166:   while (isAlive(pid) && Date.now() < deadline) await delay(50);\n167: }\n168: \n169: afterEach(async () => {\n170:   for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n171:   await delay(150);\n172:   // Sweep any detached daemon / embed sidecar that reparented to init.\n173:   for (const dir of tempDirs) {\n174:     for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n175:   }\n176:   await delay(150);\n177:   trackedPids.clear();\n178:   for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n179:   tempDirs.clear();\n180: });\n181: \n182: describe('daemon re-election: live two-session adoption', () => {\n183:   it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n184:     const paths = buildFakeRoot();\n185: \n186:     const owner = await startSession(paths, true);\n187:     expect(await statsOk(owner.client)).toBe(true);\n188:     const daemonPid = leaseDaemonPid(paths.base);\n189:     expect(daemonPid).toBeTypeOf('number');\n190:     track(daemonPid!);\n191:     expect(isAlive(daemonPid!)).toBe(true);\n192: \n193:     // Secondary joins while the owner holds the lease and the socket is live.\n194:     const secondary = await startSession(paths, true);\n195:     expect(await statsOk(secondary.client)).toBe(true);\n196:     // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n197:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n198: \n199:     // Dispose the owner.\n200:     owner.child.kill('SIGTERM');\n201:     await waitForExit(owner.child.pid!, 8_000);\n202:     expect(isAlive(owner.child.pid!)).toBe(false);\n203:     await delay(1_200);\n204: \n205:     // The released daemon outlives its owner and the secondary keeps transport.\n206:     expect(isAlive(daemonPid!)).toBe(true);\n207:     expect(await statsOk(secondary.client)).toBe(true);\n208:   });\n209: \n210:   it('flag ON: a FRESH session after owner disposal reaps the released daemon (single writer)', async () => {\n211:     const paths = buildFakeRoot();\n212: \n213:     const owner = await startSession(paths, true);\n214:     expect(await statsOk(owner.client)).toBe(true);\n215:     const orphanPid = leaseDaemonPid(paths.base);\n216:     expect(orphanPid).toBeTypeOf('number');\n217:     track(orphanPid!);\n218: \n219:     // Dispose the owner: the daemon is RELEASED (survives), not killed.\n220:     owner.child.kill('SIGTERM');\n221:     await waitForExit(owner.child.pid!, 8_000);\n222:     await delay(1_200);\n223:     expect(isAlive(orphanPid!)).toBe(true);\n224: \n225:     // A brand-new session starts AFTER disposal. Without the reap-before-respawn fix it\n226:     // reclaims the stale lease and spawns a SECOND daemon on the same DB (double writer);\n227:     // with the fix it reaps the orphan first, so exactly one daemon writes the DB.\n228:     const fresh = await startSession(paths, true);\n229:     expect(await statsOk(fresh.client)).toBe(true);\n230:     const newPid = leaseDaemonPid(paths.base);\n231:     expect(newPid).toBeTypeOf('number');\n232:     track(newPid!);\n233:     await delay(800);\n234: \n235:     // Single-writer invariant: the orphan is reaped and only the new daemon survives.\n236:     expect(isAlive(orphanPid!)).toBe(false);\n237:     expect(newPid).not.toBe(orphanPid);\n238:     expect(isAlive(newPid!)).toBe(true);\n239: \n240:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n241:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n242:     expect(dbWriters.length).toBe(1);\n243:   });\n244: \n245:   it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n246:     const paths = buildFakeRoot();\n247: \n248:     const owner = await startSession(paths, false);\n249:     expect(await statsOk(owner.client)).toBe(true);\n250:     const daemonPid = leaseDaemonPid(paths.base);\n251:     expect(daemonPid).toBeTypeOf('number');\n252:     track(daemonPid!);\n253:     expect(isAlive(daemonPid!)).toBe(true);\n254: \n255:     const secondary = await startSession(paths, false);\n256:     expect(await statsOk(secondary.client)).toBe(true);\n257:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n258: \n259:     owner.child.kill('SIGTERM');\n260:     await waitForExit(owner.child.pid!, 8_000);\n261:     expect(isAlive(owner.child.pid!)).toBe(false);\n262:     await delay(1_200);\n263: \n264:     // With the flag off, the daemon dies with its owner and the secondary's next\n265:     // call fails (no surviving daemon to serve it) within a short window.\n266:     expect(isAlive(daemonPid!)).toBe(false);\n267:     expect(await statsOk(secondary.client, 6_000)).toBe(false);\n268:   });\n269: });\n\n(End of file - total 269 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n// ───────────────────────────────────────────────────────────────\n//\n// The sibling release-integration test proves the OS-level release-vs-kill\n// DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n// feature actually promises: with the flag ON, when an OWNER session disposes the\n// shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n// flag OFF the daemon DIES with its owner and the secondary loses transport.\n//\n// It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n// isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n// SIGTERM (what a host does on session end), and observes the shared daemon's pid\n// and the secondary's next call.\n//\n// SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n// launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n// the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n// guard resolves to the fake root, never the production tree); node_modules and\n// scripts are symlinked; the IPC socket lives in a short isolated dir. No","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n// ───────────────────────────────────────────────────────────────\n//\n// The sibling release-integration test proves the OS-level release-vs-kill\n// DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n// feature actually promises: with the flag ON, when an OWNER session disposes the\n// shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n// flag OFF the daemon DIES with its owner and the secondary loses transport.\n//\n// It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n// isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n// SIGTERM (what a host does on session end), and observes the shared daemon's pid\n// and the secondary's next call.\n//\n// SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n// launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n// the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n// guard resolves to the fake root, never the production tree); node_modules and\n// scripts are symlinked; the IPC socket lives in a short isolated dir. No\n// production lease, DB, or socket is read or written. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, execSync, type ChildProcess } from 'node:child_process';\nimport { cpSync, copyFileSync, existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { afterEach, describe, expect, it } from 'vitest';\n\n// stress_test/durability/<file> -> repo root is six levels up.\nconst repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\nconst realBin = join(repoRoot, '.opencode/bin');\nconst realKit = join(repoRoot, '.opencode/skills/system-spec-kit');\nconst realMcp = join(realKit, 'mcp_server');\n\nconst trackedPids = new Set<number>();\nconst tempDirs = new Set<string>();\n\nfunction track(pid: number | undefined): void {\n  if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n}\nfunction isAlive(pid: number): boolean {\n  try { process.kill(pid, 0); return true; }\n  catch (e) { return (e as NodeJS.ErrnoException).code === 'EPERM'; }\n}\nfunction delay(ms: number): Promise<void> { return new Promise((r) => setTimeout(r, ms)); }\n\nfunction pgrepContains(needle: string): number[] {\n  try {\n    const out = execSync(`pgrep -f \"${needle}\" || true`).toString().trim();\n    return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n  } catch { return []; }\n}\n\n// Distinct pids holding any *.sqlite* file open under dbDir. One = single writer.\nfunction sqliteOpenerPids(dbDir: string): number[] {\n  try {\n    const out = execSync(\n      `lsof +D \"${dbDir}\" 2>/dev/null | awk 'NR>1 && ($9 ~ /\\\\.(db|sqlite|sqlite3)/) {print $2}' | sort -u`,\n    ).toString().trim();\n    return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n  } catch { return []; }\n}\n\n// Build an isolated fake-root: real-copied launcher + daemon dist, symlinked deps,\n// fresh lease/db dir. Returns the paths the two sessions share.\nfunction buildFakeRoot(): { base: string; sockDir: string; dbDir: string; launcher: string } {\n  const base = mkdtempSync(join(tmpdir(), 'rladopt.'));\n  tempDirs.add(base);\n  const fbin = join(base, '.opencode/bin');\n  const fkit = join(base, '.opencode/skills/system-spec-kit');\n  const fmcp = join(fkit, 'mcp_server');\n  mkdirSync(fbin, { recursive: true });\n  mkdirSync(fmcp, { recursive: true });\n  copyFileSync(join(realBin, 'mk-spec-memory-launcher.cjs'), join(fbin, 'mk-spec-memory-launcher.cjs'));\n  symlinkSync(join(realBin, 'lib'), join(fbin, 'lib'));\n  cpSync(join(realMcp, 'dist'), join(fmcp, 'dist'), { recursive: true });\n  symlinkSync(join(realMcp, 'node_modules'), join(fmcp, 'node_modules'));\n  if (existsSync(join(realKit, 'node_modules'))) symlinkSync(join(realKit, 'node_modules'), join(fkit, 'node_modules'));\n  symlinkSync(join(realMcp, 'package.json'), join(fmcp, 'package.json'));\n  symlinkSync(join(realKit, 'scripts'), join(fkit, 'scripts'));\n  const dbDir = join(fmcp, 'database');\n  mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  const sockDir = mkdtempSync(join(tmpdir(), 'rladsk.'));\n  tempDirs.add(sockDir);\n  return { base, sockDir, dbDir, launcher: join(fbin, 'mk-spec-memory-launcher.cjs') };\n}\n\ntype RpcResponse = { result?: unknown; error?: unknown; id?: number | null };\n\n// A minimal newline-delimited MCP JSON-RPC client over a launcher's stdio.\nfunction makeClient(child: ChildProcess) {\n  let buf = '';\n  const pending = new Map<number, (m: RpcResponse) => void>();\n  child.stdout!.setEncoding('utf8');\n  child.stdout!.on('data', (chunk: string) => {\n    buf += chunk;\n    let nl: number;\n    while ((nl = buf.indexOf('\\n')) >= 0) {\n      const line = buf.slice(0, nl).trim();\n      buf = buf.slice(nl + 1);\n      if (!line) continue;\n      let msg: RpcResponse;\n      try { msg = JSON.parse(line); } catch { continue; }\n      if (msg.id != null && pending.has(msg.id)) { pending.get(msg.id)!(msg); pending.delete(msg.id); }\n    }\n  });\n  child.stderr!.setEncoding('utf8');\n  child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n  let nextId = 1;\n  function request(method: string, params: unknown, timeoutMs = 30_000): Promise<RpcResponse> {\n    const id = nextId++;\n    return new Promise((resolveReq, rejectReq) => {\n      const timer = setTimeout(() => { pending.delete(id); rejectReq(new Error(`${method} timed out`)); }, timeoutMs);\n      pending.set(id, (m) => { clearTimeout(timer); resolveReq(m); });\n      try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', id, method, params }) + '\\n'); }\n      catch (e) { clearTimeout(timer); pending.delete(id); rejectReq(e as Error); }\n    });\n  }\n  function notify(method: string, params: unknown): void {\n    try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n  }\n  return { request, notify };\n}\n\nasync function startSession(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  enabled: boolean,\n): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',\n      AI_SESSION_CHILD: '1',\n    },\n    stdio: ['pipe', 'pipe', 'pipe'],\n  });\n  track(child.pid);\n  const client = makeClient(child);\n  const init = await client.request('initialize', {\n    protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n  }, 30_000);\n  if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n  client.notify('notifications/initialized', {});\n  return { child, client };\n}\n\nfunction leaseDaemonPid(base: string): number | null {\n  const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n  try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n}\nasync function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n  try {\n    const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n    return !r.error;\n  } catch { return false; }\n}\nasync function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  while (isAlive(pid) && Date.now() < deadline) await delay(50);\n}\n\nafterEach(async () => {\n  for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  await delay(150);\n  // Sweep any detached daemon / embed sidecar that reparented to init.\n  for (const dir of tempDirs) {\n    for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  }\n  await delay(150);\n  trackedPids.clear();\n  for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n  tempDirs.clear();\n});\n\ndescribe('daemon re-election: live two-session adoption', () => {\n  it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    // Secondary joins while the owner holds the lease and the socket is live.\n    const secondary = await startSession(paths, true);\n    expect(await statsOk(secondary.client)).toBe(true);\n    // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    // Dispose the owner.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // The released daemon outlives its owner and the secondary keeps transport.\n    expect(isAlive(daemonPid!)).toBe(true);\n    expect(await statsOk(secondary.client)).toBe(true);\n  });\n\n  it('flag ON: a FRESH session after owner disposal reaps the released daemon (single writer)', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // A brand-new session starts AFTER disposal. Without the reap-before-respawn fix it\n    // reclaims the stale lease and spawns a SECOND daemon on the same DB (double writer);\n    // with the fix it reaps the orphan first, so exactly one daemon writes the DB.\n    const fresh = await startSession(paths, true);\n    expect(await statsOk(fresh.client)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n    await delay(800);\n\n    // Single-writer invariant: the orphan is reaped and only the new daemon survives.\n    expect(isAlive(orphanPid!)).toBe(false);\n    expect(newPid).not.toBe(orphanPid);\n    expect(isAlive(newPid!)).toBe(true);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  });\n\n  it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, false);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    const secondary = await startSession(paths, false);\n    expect(await statsOk(secondary.client)).toBe(true);\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // With the flag off, the daemon dies with its owner and the secondary's next\n    // call fails (no surviving daemon to serve it) within a short window.\n    expect(isAlive(daemonPid!)).toBe(false);\n    expect(await statsOk(secondary.client, 6_000)).toBe(false);\n  });\n});","lineStart":1,"lineEnd":269,"totalLines":269,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","time":{"start":1780907088349,"end":1780907088355}},"metadata":{"openai":{"itemId":"fc_0a708120d7e9a389016a267c5025f48198a2237a2e5c97a38a"}},"id":"prt_ea6559998001aBRNzhRCMertJT","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea6556cc30014ww7qRQLgKoXB1"}}
{"type":"tool_use","timestamp":1780907088514,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_pkd1HqeCwGKKJx1LxstbUfiK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // DURABILITY: daemon re-election RELEASE-vs-KILL (real OS-level integration)\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // Validates the OS-level contract the re-election feature depends on: with the\n6: // flag ON, when the OWNER disposes (SIGTERM) it RELEASES the detached daemon\n7: // (leaves it alive for a secondary to adopt); with the flag OFF it KILLS the\n8: // daemon. It uses the REAL exported production decision functions from the\n9: // launcher — contextServerSpawnIo() and shouldReleaseDaemonForReelection() —\n10: // driving a real detached child and real SIGTERM/reparent semantics.\n11: //\n12: // SAFETY: this never imports config, never opens any sqlite, and never reads\n13: // or writes a lease file or the IPC socket. The launcher's lease/socket dir is\n14: // hardcoded relative to its own script location with no env override, so spawning\n15: // the real repo launcher would bridge to (or clobber) the LIVE owner. Instead a\n16: // throwaway \"owner\" harness in an OS temp dir spawns a trivial sleeper \"daemon\"\n17: // stand-in using the real spawn-io the feature produces. Only processes this test\n18: // starts are signalled, tracked by pid, and force-reaped in teardown.\n19: \n20: import { spawn, type ChildProcess } from 'node:child_process';\n21: import { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\n22: import { createRequire } from 'node:module';\n23: import { tmpdir } from 'node:os';\n24: import { dirname, join, resolve } from 'node:path';\n25: import { fileURLToPath } from 'node:url';\n26: \n27: import { afterAll, afterEach, beforeAll, describe, expect, it } from 'vitest';\n28: \n29: const require = createRequire(import.meta.url);\n30: // stress_test/durability/<file> -> repo root is six levels up.\n31: const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\n32: const launcherPath = join(repoRoot, '.opencode/bin/mk-spec-memory-launcher.cjs');\n33: \n34: // The real production primitives under test. require() is side-effect-free here:\n35: // the launcher only runs main() under `require.main === module`, never on import.\n36: const launcher = require(launcherPath) as {\n37:   daemonReelectionEnabled: (env?: Record<string, string | undefined>) => boolean;\n38:   contextServerSpawnIo: (enabled: boolean) => { detached: boolean; stdio: [string, string, string] };\n39:   shouldReleaseDaemonForReelection: (a?: { enabled?: boolean; hasLiveDaemon?: boolean }) => boolean;\n40: };\n41: \n42: // A throwaway owner harness. It requires the REAL launcher, computes spawn-io and\n43: // the release-vs-kill decision from the production functions, spawns a trivial\n44: // long-lived \"daemon\" (a sleeper), prints its pid, and stays alive until SIGTERM.\n45: // On SIGTERM it applies the real decision: release (don't kill) or kill.\n46: const OWNER_HARNESS = String.raw`\n47: 'use strict';\n48: const { spawn } = require('node:child_process');\n49: const launcher = require(process.env.LAUNCHER_PATH);\n50: \n51: const enabled = launcher.daemonReelectionEnabled(process.env);\n52: const io = launcher.contextServerSpawnIo(enabled);\n53: \n54: // Trivial daemon stand-in: a sleeper that keeps its own event loop alive.\n55: const daemon = spawn(process.execPath, ['-e', 'setInterval(() => {}, 2147483647)'], {\n56:   detached: io.detached,\n57:   stdio: io.stdio,\n58: });\n59: // Re-election only: don't keep the detached daemon tethered to the owner (mirrors the launcher's unref()).\n60: if (enabled) daemon.unref();\n61: \n62: // Keep the owner alive and \"owning\" until it is disposed, independent of the daemon ref.\n63: const keepAlive = setInterval(() => {}, 2147483647);\n64: \n65: let shuttingDown = false;\n66: function shutdown() {\n67:   if (shuttingDown) return;\n68:   shuttingDown = true;\n69:   clearInterval(keepAlive);\n70:   const hasLiveDaemon = daemon.exitCode === null && daemon.signalCode === null && typeof daemon.pid === 'number';\n71:   if (launcher.shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon })) {\n72:     // RELEASE: leave the detached daemon alive for a secondary to adopt; just exit.\n73:     process.stdout.write('RELEASED\\n', () => process.exit(0));\n74:   } else {\n75:     // KILL: tear the daemon down, matching the non-reelection shutdown path.\n76:     try { daemon.kill('SIGTERM'); } catch (_) {}\n77:     process.stdout.write('KILLED\\n', () => process.exit(0));\n78:   }\n79: }\n80: for (const s of ['SIGTERM', 'SIGINT']) process.on(s, shutdown);\n81: \n82: // Announce readiness only once the daemon is live and handlers are installed.\n83: process.stdout.write('DAEMON_PID:' + daemon.pid + '\\n');\n84: `;\n85: \n86: const BOOT_TIMEOUT_MS = 15_000;\n87: const DEATH_TIMEOUT_MS = 8_000;\n88: const SURVIVAL_CONFIRM_MS = 2_000;\n89: \n90: let workDir: string;\n91: let harnessPath: string;\n92: const trackedPids = new Set<number>();\n93: \n94: function track(pid: number | undefined): void {\n95:   if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n96: }\n97: \n98: function isAlive(pid: number): boolean {\n99:   try {\n100:     process.kill(pid, 0);\n101:     return true;\n102:   } catch (err) {\n103:     // EPERM = the process exists but we may not signal it -> still alive.\n104:     return (err as NodeJS.ErrnoException).code === 'EPERM';\n105:   }\n106: }\n107: \n108: function delay(ms: number): Promise<void> {\n109:   return new Promise((r) => setTimeout(r, ms));\n110: }\n111: \n112: async function waitForDeath(pid: number, timeoutMs: number): Promise<boolean> {\n113:   const deadline = Date.now() + timeoutMs;\n114:   while (Date.now() < deadline) {\n115:     if (!isAlive(pid)) return true;\n116:     await delay(50);\n117:   }\n118:   return !isAlive(pid);\n119: }\n120: \n121: function waitForOwnerExit(owner: ChildProcess, timeoutMs: number): Promise<void> {\n122:   return new Promise((resolveExit, rejectExit) => {\n123:     if (owner.exitCode !== null || owner.signalCode !== null) return resolveExit();\n124:     const timer = setTimeout(() => rejectExit(new Error('owner did not exit in time')), timeoutMs);\n125:     owner.once('exit', () => {\n126:       clearTimeout(timer);\n127:       resolveExit();\n128:     });\n129:   });\n130: }\n131: \n132: // Spawn the owner harness and resolve with { owner, daemonPid } once it prints DAEMON_PID.\n133: function spawnOwner(enabled: boolean): Promise<{ owner: ChildProcess; daemonPid: number }> {\n134:   const owner = spawn(process.execPath, [harnessPath], {\n135:     cwd: workDir,\n136:     env: {\n137:       ...process.env,\n138:       LAUNCHER_PATH: launcherPath,\n139:       SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n140:     },\n141:     stdio: ['ignore', 'pipe', 'pipe'],\n142:   });\n143:   track(owner.pid);\n144: \n145:   return new Promise((resolveSpawn, rejectSpawn) => {\n146:     let stdout = '';\n147:     let stderr = '';\n148:     const timer = setTimeout(() => {\n149:       rejectSpawn(new Error(`owner never reported DAEMON_PID in ${BOOT_TIMEOUT_MS}ms; stderr: ${stderr}`));\n150:     }, BOOT_TIMEOUT_MS);\n151: \n152:     owner.stdout!.setEncoding('utf8');\n153:     owner.stderr!.setEncoding('utf8');\n154:     owner.stderr!.on('data', (chunk) => { stderr += chunk; });\n155:     owner.stdout!.on('data', (chunk) => {\n156:       stdout += chunk;\n157:       const m = stdout.match(/DAEMON_PID:(\\d+)/);\n158:       if (m) {\n159:         clearTimeout(timer);\n160:         const daemonPid = Number(m[1]);\n161:         track(daemonPid);\n162:         resolveSpawn({ owner, daemonPid });\n163:       }\n164:     });\n165:     owner.once('error', (err) => { clearTimeout(timer); rejectSpawn(err); });\n166:   });\n167: }\n168: \n169: beforeAll(() => {\n170:   workDir = mkdtempSync(join(tmpdir(), 'speckit-reelect-'));\n171:   harnessPath = join(workDir, 'owner-harness.cjs');\n172:   writeFileSync(harnessPath, OWNER_HARNESS, 'utf8');\n173: });\n174: \n175: afterEach(async () => {\n176:   // Force-reap ONLY processes this test started (owner + daemon stand-in). The\n177:   // detached flag-ON daemon has reparented to init, so SIGKILL by pid is required.\n178:   for (const pid of trackedPids) {\n179:     try { process.kill(pid, 'SIGKILL'); } catch (_) { /* already gone */ }\n180:   }\n181:   // Give the OS a moment to release the reaped pids before the next case.\n182:   await delay(100);\n183:   trackedPids.clear();\n184: });\n185: \n186: afterAll(() => {\n187:   rmSync(workDir, { recursive: true, force: true });\n188: });\n189: \n190: describe('daemon re-election: real release-vs-kill integration', () => {\n191:   it('uses the real exported production primitives (not a mock)', () => {\n192:     expect(typeof launcher.contextServerSpawnIo).toBe('function');\n193:     expect(typeof launcher.shouldReleaseDaemonForReelection).toBe('function');\n194:     expect(launcher.daemonReelectionEnabled({ SPECKIT_DAEMON_REELECTION: '1' })).toBe(true);\n195:     expect(launcher.contextServerSpawnIo(true)).toEqual({ detached: true, stdio: ['ignore', 'ignore', 'ignore'] });\n196:     expect(launcher.contextServerSpawnIo(false)).toEqual({ detached: false, stdio: ['ignore', 'ignore', 'inherit'] });\n197:   });\n198: \n199:   it('flag ON: owner SIGTERM RELEASES the detached daemon (it survives)', async () => {\n200:     const { owner, daemonPid } = await spawnOwner(true);\n201:     expect(isAlive(daemonPid)).toBe(true);\n202: \n203:     owner.kill('SIGTERM');\n204:     await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n205: \n206:     // The released daemon must outlive its owner. Confirm it stays alive across a window.\n207:     await delay(SURVIVAL_CONFIRM_MS);\n208:     expect(isAlive(daemonPid)).toBe(true);\n209:     expect(isAlive(owner.pid!)).toBe(false);\n210:   });\n211: \n212:   it('flag OFF: owner SIGTERM KILLS the daemon (it dies)', async () => {\n213:     const { owner, daemonPid } = await spawnOwner(false);\n214:     expect(isAlive(daemonPid)).toBe(true);\n215: \n216:     owner.kill('SIGTERM');\n217:     await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n218: \n219:     const died = await waitForDeath(daemonPid, DEATH_TIMEOUT_MS);\n220:     expect(died).toBe(true);\n221:     expect(isAlive(owner.pid!)).toBe(false);\n222:   });\n223: });\n\n(End of file - total 223 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election RELEASE-vs-KILL (real OS-level integration)\n// ───────────────────────────────────────────────────────────────\n//\n// Validates the OS-level contract the re-election feature depends on: with the\n// flag ON, when the OWNER disposes (SIGTERM) it RELEASES the detached daemon\n// (leaves it alive for a secondary to adopt); with the flag OFF it KILLS the\n// daemon. It uses the REAL exported production decision functions from the\n// launcher — contextServerSpawnIo() and shouldReleaseDaemonForReelection() —\n// driving a real detached child and real SIGTERM/reparent semantics.\n//\n// SAFETY: this never imports config, never opens any sqlite, and never reads\n// or writes a lease file or the IPC socket. The launcher's lease/socket dir is\n// hardcoded relative to its own script location with no env override, so spawning\n// the real repo launcher would bridge to (or clobber) the LIVE owner. Instead a\n// throwaway \"owner\" harness in an OS temp dir spawns a trivial sleeper \"daemon\"\n// stand-in using the real spawn-io the feature produces. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, type ChildProcess } from 'node:child_process';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election RELEASE-vs-KILL (real OS-level integration)\n// ───────────────────────────────────────────────────────────────\n//\n// Validates the OS-level contract the re-election feature depends on: with the\n// flag ON, when the OWNER disposes (SIGTERM) it RELEASES the detached daemon\n// (leaves it alive for a secondary to adopt); with the flag OFF it KILLS the\n// daemon. It uses the REAL exported production decision functions from the\n// launcher — contextServerSpawnIo() and shouldReleaseDaemonForReelection() —\n// driving a real detached child and real SIGTERM/reparent semantics.\n//\n// SAFETY: this never imports config, never opens any sqlite, and never reads\n// or writes a lease file or the IPC socket. The launcher's lease/socket dir is\n// hardcoded relative to its own script location with no env override, so spawning\n// the real repo launcher would bridge to (or clobber) the LIVE owner. Instead a\n// throwaway \"owner\" harness in an OS temp dir spawns a trivial sleeper \"daemon\"\n// stand-in using the real spawn-io the feature produces. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, type ChildProcess } from 'node:child_process';\nimport { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\nimport { createRequire } from 'node:module';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { afterAll, afterEach, beforeAll, describe, expect, it } from 'vitest';\n\nconst require = createRequire(import.meta.url);\n// stress_test/durability/<file> -> repo root is six levels up.\nconst repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\nconst launcherPath = join(repoRoot, '.opencode/bin/mk-spec-memory-launcher.cjs');\n\n// The real production primitives under test. require() is side-effect-free here:\n// the launcher only runs main() under `require.main === module`, never on import.\nconst launcher = require(launcherPath) as {\n  daemonReelectionEnabled: (env?: Record<string, string | undefined>) => boolean;\n  contextServerSpawnIo: (enabled: boolean) => { detached: boolean; stdio: [string, string, string] };\n  shouldReleaseDaemonForReelection: (a?: { enabled?: boolean; hasLiveDaemon?: boolean }) => boolean;\n};\n\n// A throwaway owner harness. It requires the REAL launcher, computes spawn-io and\n// the release-vs-kill decision from the production functions, spawns a trivial\n// long-lived \"daemon\" (a sleeper), prints its pid, and stays alive until SIGTERM.\n// On SIGTERM it applies the real decision: release (don't kill) or kill.\nconst OWNER_HARNESS = String.raw`\n'use strict';\nconst { spawn } = require('node:child_process');\nconst launcher = require(process.env.LAUNCHER_PATH);\n\nconst enabled = launcher.daemonReelectionEnabled(process.env);\nconst io = launcher.contextServerSpawnIo(enabled);\n\n// Trivial daemon stand-in: a sleeper that keeps its own event loop alive.\nconst daemon = spawn(process.execPath, ['-e', 'setInterval(() => {}, 2147483647)'], {\n  detached: io.detached,\n  stdio: io.stdio,\n});\n// Re-election only: don't keep the detached daemon tethered to the owner (mirrors the launcher's unref()).\nif (enabled) daemon.unref();\n\n// Keep the owner alive and \"owning\" until it is disposed, independent of the daemon ref.\nconst keepAlive = setInterval(() => {}, 2147483647);\n\nlet shuttingDown = false;\nfunction shutdown() {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  clearInterval(keepAlive);\n  const hasLiveDaemon = daemon.exitCode === null && daemon.signalCode === null && typeof daemon.pid === 'number';\n  if (launcher.shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon })) {\n    // RELEASE: leave the detached daemon alive for a secondary to adopt; just exit.\n    process.stdout.write('RELEASED\\n', () => process.exit(0));\n  } else {\n    // KILL: tear the daemon down, matching the non-reelection shutdown path.\n    try { daemon.kill('SIGTERM'); } catch (_) {}\n    process.stdout.write('KILLED\\n', () => process.exit(0));\n  }\n}\nfor (const s of ['SIGTERM', 'SIGINT']) process.on(s, shutdown);\n\n// Announce readiness only once the daemon is live and handlers are installed.\nprocess.stdout.write('DAEMON_PID:' + daemon.pid + '\\n');\n`;\n\nconst BOOT_TIMEOUT_MS = 15_000;\nconst DEATH_TIMEOUT_MS = 8_000;\nconst SURVIVAL_CONFIRM_MS = 2_000;\n\nlet workDir: string;\nlet harnessPath: string;\nconst trackedPids = new Set<number>();\n\nfunction track(pid: number | undefined): void {\n  if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n}\n\nfunction isAlive(pid: number): boolean {\n  try {\n    process.kill(pid, 0);\n    return true;\n  } catch (err) {\n    // EPERM = the process exists but we may not signal it -> still alive.\n    return (err as NodeJS.ErrnoException).code === 'EPERM';\n  }\n}\n\nfunction delay(ms: number): Promise<void> {\n  return new Promise((r) => setTimeout(r, ms));\n}\n\nasync function waitForDeath(pid: number, timeoutMs: number): Promise<boolean> {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() < deadline) {\n    if (!isAlive(pid)) return true;\n    await delay(50);\n  }\n  return !isAlive(pid);\n}\n\nfunction waitForOwnerExit(owner: ChildProcess, timeoutMs: number): Promise<void> {\n  return new Promise((resolveExit, rejectExit) => {\n    if (owner.exitCode !== null || owner.signalCode !== null) return resolveExit();\n    const timer = setTimeout(() => rejectExit(new Error('owner did not exit in time')), timeoutMs);\n    owner.once('exit', () => {\n      clearTimeout(timer);\n      resolveExit();\n    });\n  });\n}\n\n// Spawn the owner harness and resolve with { owner, daemonPid } once it prints DAEMON_PID.\nfunction spawnOwner(enabled: boolean): Promise<{ owner: ChildProcess; daemonPid: number }> {\n  const owner = spawn(process.execPath, [harnessPath], {\n    cwd: workDir,\n    env: {\n      ...process.env,\n      LAUNCHER_PATH: launcherPath,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n    },\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n  track(owner.pid);\n\n  return new Promise((resolveSpawn, rejectSpawn) => {\n    let stdout = '';\n    let stderr = '';\n    const timer = setTimeout(() => {\n      rejectSpawn(new Error(`owner never reported DAEMON_PID in ${BOOT_TIMEOUT_MS}ms; stderr: ${stderr}`));\n    }, BOOT_TIMEOUT_MS);\n\n    owner.stdout!.setEncoding('utf8');\n    owner.stderr!.setEncoding('utf8');\n    owner.stderr!.on('data', (chunk) => { stderr += chunk; });\n    owner.stdout!.on('data', (chunk) => {\n      stdout += chunk;\n      const m = stdout.match(/DAEMON_PID:(\\d+)/);\n      if (m) {\n        clearTimeout(timer);\n        const daemonPid = Number(m[1]);\n        track(daemonPid);\n        resolveSpawn({ owner, daemonPid });\n      }\n    });\n    owner.once('error', (err) => { clearTimeout(timer); rejectSpawn(err); });\n  });\n}\n\nbeforeAll(() => {\n  workDir = mkdtempSync(join(tmpdir(), 'speckit-reelect-'));\n  harnessPath = join(workDir, 'owner-harness.cjs');\n  writeFileSync(harnessPath, OWNER_HARNESS, 'utf8');\n});\n\nafterEach(async () => {\n  // Force-reap ONLY processes this test started (owner + daemon stand-in). The\n  // detached flag-ON daemon has reparented to init, so SIGKILL by pid is required.\n  for (const pid of trackedPids) {\n    try { process.kill(pid, 'SIGKILL'); } catch (_) { /* already gone */ }\n  }\n  // Give the OS a moment to release the reaped pids before the next case.\n  await delay(100);\n  trackedPids.clear();\n});\n\nafterAll(() => {\n  rmSync(workDir, { recursive: true, force: true });\n});\n\ndescribe('daemon re-election: real release-vs-kill integration', () => {\n  it('uses the real exported production primitives (not a mock)', () => {\n    expect(typeof launcher.contextServerSpawnIo).toBe('function');\n    expect(typeof launcher.shouldReleaseDaemonForReelection).toBe('function');\n    expect(launcher.daemonReelectionEnabled({ SPECKIT_DAEMON_REELECTION: '1' })).toBe(true);\n    expect(launcher.contextServerSpawnIo(true)).toEqual({ detached: true, stdio: ['ignore', 'ignore', 'ignore'] });\n    expect(launcher.contextServerSpawnIo(false)).toEqual({ detached: false, stdio: ['ignore', 'ignore', 'inherit'] });\n  });\n\n  it('flag ON: owner SIGTERM RELEASES the detached daemon (it survives)', async () => {\n    const { owner, daemonPid } = await spawnOwner(true);\n    expect(isAlive(daemonPid)).toBe(true);\n\n    owner.kill('SIGTERM');\n    await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n\n    // The released daemon must outlive its owner. Confirm it stays alive across a window.\n    await delay(SURVIVAL_CONFIRM_MS);\n    expect(isAlive(daemonPid)).toBe(true);\n    expect(isAlive(owner.pid!)).toBe(false);\n  });\n\n  it('flag OFF: owner SIGTERM KILLS the daemon (it dies)', async () => {\n    const { owner, daemonPid } = await spawnOwner(false);\n    expect(isAlive(daemonPid)).toBe(true);\n\n    owner.kill('SIGTERM');\n    await waitForOwnerExit(owner, DEATH_TIMEOUT_MS);\n\n    const died = await waitForDeath(daemonPid, DEATH_TIMEOUT_MS);\n    expect(died).toBe(true);\n    expect(isAlive(owner.pid!)).toBe(false);\n  });\n});","lineStart":1,"lineEnd":223,"totalLines":223,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-release-integration.vitest.ts","time":{"start":1780907088502,"end":1780907088512}},"metadata":{"openai":{"itemId":"fc_0a708120d7e9a389016a267c5026048198bdd0245de6ba8dd7"}},"id":"prt_ea6559a130012SnktN4khTOW2Z","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea6556cc30014ww7qRQLgKoXB1"}}
{"type":"tool_use","timestamp":1780907088591,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_jlTHy4JXWKBrEKjqzPd76ziJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh","offset":140,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh</path>\n<type>file</type>\n<content>\n140:             if comment_index >= 0:\n141:                 return raw_line[comment_index:].strip()\n142: \n143:         return \"\"\n144: \n145:     # --- Allowed-class patterns (these suppress violation detection) ---\n146:     # Order: check these BEFORE violation patterns.\n147:     ALLOWED_PATTERNS = [\n148:         re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n149:         re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n150:         re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n151:         re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n152:         re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n153:         re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n154:         re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n155:         re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n156:     ]\n157: \n158:     # --- Violation patterns ---\n159:     # Each is (pattern, description) for clear reporting.\n160:     # F-notation is intentionally excluded: repo comments use it heavily for function keys,\n161:     # figures, and field references, so genuine finding labels stay review-owned.\n162:     VIOLATION_PATTERNS = [\n163:         (re.compile(r'\\b\\d{3}/\\d{3}\\b'),                            \"packet/phase reference\"),\n164:         (re.compile(r'\\bRC-\\d+\\b'),                                  \"RC reference\"),\n165:         (re.compile(r'\\bADR-\\d+\\b'),                                \"ADR reference\"),\n166:         (re.compile(r'\\bREQ-\\d+\\b'),                                \"REQ reference\"),\n167:         (re.compile(r'\\bCHK-\\d+\\b'),                                \"CHK reference\"),\n168:         (re.compile(r'\\bT\\d{3,4}\\b'),                               \"task ID reference\"),\n169:         (re.compile(r'\\bpacket\\s+\\d+\\b', re.IGNORECASE),            \"packet number reference\"),\n170:         (re.compile(r'\\bphase[\\s-]\\d{3}\\b', re.IGNORECASE),          \"3-digit phase reference\"),\n171:         (re.compile(r'specs/[a-z0-9]+-[a-z0-9-]*/'),               \"spec path reference\"),\n172:         (re.compile(r'\\bWS-\\d+-\\d+\\b'),                             \"worktree session reference\"),\n173:         (re.compile(r'\\bDR-\\d+(?:-\\d+)?\\b'),                        \"deep review reference\"),\n174:         (re.compile(r'\\bP\\d+-Seat\\d+\\b'),                           \"council seat reference\"),\n175:         (re.compile(r'\\breview\\s+finding\\b', re.IGNORECASE),        \"review finding reference\"),\n176:         (re.compile(r'\\bchecklist\\s+item\\s+\\d+\\b', re.IGNORECASE), \"checklist item reference\"),\n177:         (re.compile(r'\\b[Pp]\\d-finding[-\\s]\\d+\\b'),                 \"finding id reference\"),\n178:         (re.compile(r'\\bfinding\\s+#\\d+\\b', re.IGNORECASE),         \"finding id reference\"),\n179:     ]\n180: \n181:     violations = []\n182: \n183:     for lineno, raw_line in enumerate(lines, start=1):\n184:         comment_text = extract_comment_text(raw_line, lang)\n185: \n186:         if not comment_text:\n187:             continue\n188: \n189:         # Hygiene-ok escape: skip this line entirely\n190:         if \"hygiene-ok\" in comment_text:\n191:             continue\n192: \n193:         # Check allowed-class patterns first — if any match, skip violation check\n194:         if any(pat.search(comment_text) for pat in ALLOWED_PATTERNS):\n195:             continue\n196: \n197:         # Check violation patterns\n198:         for vpat, _desc in VIOLATION_PATTERNS:\n199:             m = vpat.search(comment_text)\n200:             if m:\n201:                 excerpt = raw_line.rstrip()\n202:                 violations.append(f\"{filepath}:{lineno}: {excerpt}\")\n203:                 break  # One violation per line is enough\n204: \n205:     if violations:\n206:         for v in violations:\n207:             print(v)\n208:         sys.exit(1)\n209: \n\n(Showing lines 140-209 of 214. Use offset=210 to continue.)\n</content>","metadata":{"preview":"            if comment_index >= 0:\n                return raw_line[comment_index:].strip()\n\n        return \"\"\n\n    # --- Allowed-class patterns (these suppress violation detection) ---\n    # Order: check these BEFORE violation patterns.\n    ALLOWED_PATTERNS = [\n        re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n        re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n        re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n        re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n        re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n        re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n        re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n        re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n    ]\n\n    # --- Violation patterns ---\n    # Each is (pattern, description) for clear reporting.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh","text":"            if comment_index >= 0:\n                return raw_line[comment_index:].strip()\n\n        return \"\"\n\n    # --- Allowed-class patterns (these suppress violation detection) ---\n    # Order: check these BEFORE violation patterns.\n    ALLOWED_PATTERNS = [\n        re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n        re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n        re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n        re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n        re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n        re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n        re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n        re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n    ]\n\n    # --- Violation patterns ---\n    # Each is (pattern, description) for clear reporting.\n    # F-notation is intentionally excluded: repo comments use it heavily for function keys,\n    # figures, and field references, so genuine finding labels stay review-owned.\n    VIOLATION_PATTERNS = [\n        (re.compile(r'\\b\\d{3}/\\d{3}\\b'),                            \"packet/phase reference\"),\n        (re.compile(r'\\bRC-\\d+\\b'),                                  \"RC reference\"),\n        (re.compile(r'\\bADR-\\d+\\b'),                                \"ADR reference\"),\n        (re.compile(r'\\bREQ-\\d+\\b'),                                \"REQ reference\"),\n        (re.compile(r'\\bCHK-\\d+\\b'),                                \"CHK reference\"),\n        (re.compile(r'\\bT\\d{3,4}\\b'),                               \"task ID reference\"),\n        (re.compile(r'\\bpacket\\s+\\d+\\b', re.IGNORECASE),            \"packet number reference\"),\n        (re.compile(r'\\bphase[\\s-]\\d{3}\\b', re.IGNORECASE),          \"3-digit phase reference\"),\n        (re.compile(r'specs/[a-z0-9]+-[a-z0-9-]*/'),               \"spec path reference\"),\n        (re.compile(r'\\bWS-\\d+-\\d+\\b'),                             \"worktree session reference\"),\n        (re.compile(r'\\bDR-\\d+(?:-\\d+)?\\b'),                        \"deep review reference\"),\n        (re.compile(r'\\bP\\d+-Seat\\d+\\b'),                           \"council seat reference\"),\n        (re.compile(r'\\breview\\s+finding\\b', re.IGNORECASE),        \"review finding reference\"),\n        (re.compile(r'\\bchecklist\\s+item\\s+\\d+\\b', re.IGNORECASE), \"checklist item reference\"),\n        (re.compile(r'\\b[Pp]\\d-finding[-\\s]\\d+\\b'),                 \"finding id reference\"),\n        (re.compile(r'\\bfinding\\s+#\\d+\\b', re.IGNORECASE),         \"finding id reference\"),\n    ]\n\n    violations = []\n\n    for lineno, raw_line in enumerate(lines, start=1):\n        comment_text = extract_comment_text(raw_line, lang)\n\n        if not comment_text:\n            continue\n\n        # Hygiene-ok escape: skip this line entirely\n        if \"hygiene-ok\" in comment_text:\n            continue\n\n        # Check allowed-class patterns first — if any match, skip violation check\n        if any(pat.search(comment_text) for pat in ALLOWED_PATTERNS):\n            continue\n\n        # Check violation patterns\n        for vpat, _desc in VIOLATION_PATTERNS:\n            m = vpat.search(comment_text)\n            if m:\n                excerpt = raw_line.rstrip()\n                violations.append(f\"{filepath}:{lineno}: {excerpt}\")\n                break  # One violation per line is enough\n\n    if violations:\n        for v in violations:\n            print(v)\n        sys.exit(1)\n","lineStart":140,"lineEnd":209,"totalLines":214,"truncated":true}},"title":".opencode/skills/sk-code/scripts/check-comment-hygiene.sh","time":{"start":1780907088585,"end":1780907088589}},"metadata":{"openai":{"itemId":"fc_0a708120d7e9a389016a267c50263481988e2dd49ac1841c1f"}},"id":"prt_ea6559a82001eDbTb2AdHBW5rO","sessionID":"ses_159adeef9ff