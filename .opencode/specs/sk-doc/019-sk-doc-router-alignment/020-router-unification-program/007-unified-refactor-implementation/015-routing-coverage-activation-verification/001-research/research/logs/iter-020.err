  1176	// ─────────────────────────────────────────────────────────────────────────────
  1177	// 13. BOOTSTRAP LOCK HELPERS
  1178	// ─────────────────────────────────────────────────────────────────────────────
  1179	
  1180	const BOOTSTRAP_LOCK_OWNER_FILE = 'owner.pid';
  1181	
  1182	// Returns the pid recorded inside the lock dir, or null when no readable pid
  1183	// stamp exists (legacy lock dirs, or a holder that died before stamping).
  1184	function readBootstrapLockOwnerPid() {
  1185	  try {
  1186	    const raw = fs.readFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), 'utf8').trim();
  1187	    const pid = Number.parseInt(raw, 10);
  1188	    return Number.isInteger(pid) && pid > 0 ? pid : null;
  1189	  } catch {
  1190	    return null;
  1191	  }
  1192	}
  1193	
  1194	function removeStaleBootstrapLock(staleMs = BOOTSTRAP_LOCK_STALE_MS) {
  1195	  if (!exists(lockDir)) {
  1196	    return false;
  1197	  }
  1198	  let ageMs;
  1199	  try {
  1200	    ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;
  1201	  } catch (error) {
  1202	    if (error.code === 'ENOENT') return false;
  1203	    throw error;
  1204	  }
  1205	  // A lock dir is reclaimable as soon as its recorded holder is provably dead —
  1206	  // an mtime TTL alone would otherwise wedge every new session for up to staleMs
  1207	  // after a launcher is SIGKILLed or crashes while holding the lock. The mtime
  1208	  // age stays as the fallback for lock dirs with no readable pid stamp (legacy
  1209	  // dirs) and for a holder whose liveness cannot be determined.
  1210	  const ownerPid = readBootstrapLockOwnerPid();
  1211	  const ownerDead = ownerPid !== null && processLiveness(ownerPid) === 'dead';
  1212	  if (!ownerDead && ageMs <= staleMs) {
  1213	    return false;
  1214	  }
  1215	  const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;
  1216	  try {
  1217	    fs.renameSync(lockDir, staleClaim);
  1218	    fs.rmSync(staleClaim, { recursive: true, force: true });
  1219	    const reason = ownerDead ? `dead holder pid=${ownerPid}` : `${Math.round(ageMs / 1000)}s old`;
  1220	    log(`reclaimed stale bootstrap lock at ${rel(lockDir)} (${reason})`);
  1221	    return true;
  1222	  } catch (error) {
  1223	    if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;
  1224	    throw error;
  1225	  }
  1226	}
  1227	
  1228	async function acquireBootstrapLock(options = {}) {
  1229	  fs.mkdirSync(dbDir, { recursive: true });
  1230	  const deadline = Date.now() + (options.timeoutMs ?? BOOTSTRAP_LOCK_TIMEOUT_MS);
  1231	  const staleMs = options.staleMs ?? BOOTSTRAP_LOCK_STALE_MS;
  1232	  const retrySleepMs = options.retrySleepMs ?? 1000;
  1233	  while (true) {
  1234	    try {
  1235	      fs.mkdirSync(lockDir);
  1236	      // Stamp the holder pid so a later launcher can reclaim this lock the
  1237	      // instant we die, instead of waiting out the mtime TTL. Best-effort: a
  1238	      // failed stamp degrades to the TTL path, never blocks acquisition.
  1239	      try {
  1240	        fs.writeFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), String(process.pid), { mode: 0o600 });
  1241	      } catch { /* TTL fallback covers an unstamped lock */ }
  1242	      return true;
  1243	    } catch (error) {
  1244	      if (error.code !== 'EEXIST') {
  1245	        throw error;
  1246	      }
  1247	      if (removeStaleBootstrapLock(staleMs)) {
  1248	        continue;
  1249	      }
  1250	      if (Date.now() > deadline) {
  1251	        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);
  1252	      }
  1253	      await sleep(retrySleepMs);
  1254	    }
  1255	  }
  1256	}
