ndex.ts\",\n      \"mcp_server/lib/providers/retry-manager.ts\",\n      \"mcp_server/tests/maintenance-marker.vitest.ts\",\n      \"spec.md\",\n      \"plan.md\",\n      \"implementation-summary.md\",\n      \"tasks.md\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"retry-manager.ts\",\n        \"kind\": \"code\",\n        \"path\": \"lib/providers/retry-manager.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"maintenance-marker.ts\",\n        \"kind\": \"code\",\n        \"path\": \"lib/storage/maintenance-marker.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"memory-index.ts\",\n        \"kind\": \"code\",\n        \"path\": \"handlers/memory-index.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"maintenance-marker.vitest.ts\",\n        \"kind\": \"test\",\n        \"path\": \"tests/maintenance-marker.vitest.ts\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"spec.md\",\n        \"kind\": \"doc\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"plan.md\",\n        \"kind\": \"doc\",\n        \"path\": \"plan.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"implementation-summary.md\",\n        \"kind\": \"doc\",\n        \"path\": \"implementation-summary.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"tasks.md\",\n        \"kind\": \"doc\",\n        \"path\": \"tasks.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Feature Specification\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Parent Spec\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Handoff Criteria\",\n        \"kind\": \"proper_noun\",\n  