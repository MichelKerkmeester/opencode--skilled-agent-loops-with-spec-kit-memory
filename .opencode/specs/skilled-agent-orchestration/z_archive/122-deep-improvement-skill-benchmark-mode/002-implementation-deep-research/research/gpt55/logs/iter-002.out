.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2486:def calculate_confidence(score: float, has_intent_boost: bool) -> float:
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2488:    Calculate confidence score using two-tiered formula.
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2490:    The formula distinguishes between queries that match explicit intent keywords
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2494:        confidence = min(0.50 + score * 0.15, 0.95)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2496:        - score=2.0 → 0.80 (meets 0.8 threshold)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2501:        confidence = min(0.25 + score * 0.15, 0.95)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2503:        - score=2.0 → 0.55 (below threshold)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2504:        - score=3.0 → 0.70 (below threshold)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2505:        - score=4.0 → 0.85 (meets threshold)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2508:    The 0.8 threshold in Gate 2 means:
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2512:    This design favors explicit domain keywords while remaining conservative
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2519:                         True enables the higher-confidence formula.
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2525:        # Intent booster matched - higher confidence curve
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2526:        confidence = min(0.50 + score * 0.15, 0.95)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2528:        # No explicit boosters - conservative (corpus matches only)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2529:        confidence = min(0.25 + score * 0.15, 0.95)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2531:    return confidence
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2534:def calculate_uncertainty(num_matches: int, has_intent_boost: bool, num_ambiguous_matches: int) -> float:
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2536:    Calculate uncertainty score for skill recommendation.
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2538:    Uncertainty measures "how much we don't know" - separate from confidence.
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2539:    High confidence + high uncertainty = "confident ignorance" (dangerous state).
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2542:    - Fewer matches = higher uncertainty (less evidence)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2543:    - No intent boost = higher uncertainty (less clear intent)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2544:    - More ambiguous matches = higher uncertainty (competing interpretations)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2564:    # Base uncertainty decreases with more matches
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2566:        base_uncertainty = 0.15
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2568:        base_uncertainty = 0.20
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2570:        base_uncertainty = 0.30
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2572:        base_uncertainty = 0.70
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2574:    # No intent boost increases uncertainty (less clear intent)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2577:    # Ambiguous matches increase uncertainty (competing interpretations)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2580:    uncertainty = min(base_uncertainty + intent_penalty + ambiguity_penalty, 1.0)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2581:    return round(uncertainty, 2)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2584:def passes_dual_threshold(
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2585:    confidence: float,
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2586:    uncertainty: float,
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2587:    conf_threshold: float = 0.8,
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2588:    uncert_threshold: float = 0.35,
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2591:    Check if recommendation passes dual-threshold validation.
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2593:    READINESS = (confidence >= threshold) AND (uncertainty <= uncert_threshold)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2595:    Note on thresholds:
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2596:    - AGENTS.md Gate 1 defines READINESS as: (confidence >= 0.70) AND (uncertainty <= 0.35)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2597:    - Gate 2 skill routing typically uses conf_threshold=0.8 (stricter for routing decisions)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2598:    - The uncertainty threshold of 0.35 matches AGENTS.md exactly
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2601:        confidence: Confidence score (0.0-1.0)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2602:        uncertainty: Uncertainty score (0.0-1.0)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2603:        conf_threshold: Minimum confidence required (default 0.8 for skill routing)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2604:        uncert_threshold: Maximum uncertainty allowed (default 0.35 per AGENTS.md)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2607:        bool: True if both thresholds pass
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2609:    return confidence >= conf_threshold and uncertainty <= uncert_threshold
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2612:def refresh_passes_threshold(
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2614:    conf_threshold: float = DEFAULT_CONFIDENCE_THRESHOLD,
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2615:    uncert_threshold: float = DEFAULT_UNCERTAINTY_THRESHOLD,
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2617:    """Recompute threshold state after score or uncertainty mutators run."""
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2619:        recommendation["passes_threshold"] = passes_dual_threshold(
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2620:            recommendation["confidence"],
