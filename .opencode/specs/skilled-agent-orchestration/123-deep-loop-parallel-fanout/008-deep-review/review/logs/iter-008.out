   404	export function upsertNode(node: CoverageNode): string {
   405	  const d = getDb();
   406	  const now = new Date().toISOString();
   407	  const metadataStr = node.metadata ? JSON.stringify(node.metadata) : null;
   408	
   409	  const existing = prepareStatement(
