": false\n164:       },\n165:       {\n166:         \"id\": \"q36\",\n167:         \"prompt\": \"audit the routing quality and the recommendations it makes\",\n168:         \"gold\": \"sk-code-review\",\n169:         \"guardOff\": \"sk-code-review\",\n170:         \"guardOn\": \"sk-code-review\",\n171:         \"moved\": false\n172:       },\n173:       {\n174:         \"id\": \"q37\",\n175:         \"prompt\": \"audit the recommendation quality of the skill router and rate it\",\n176:         \"gold\": \"sk-code-review\",\n177:         \"guardOff\": \"sk-code-review\",\n178:         \"guardOn\": \"sk-code-review\",\n179:         \"moved\": false\n180:       }\n181:     ]\n182:   },\n183:   \"conflictDifferential\": {\n184:     \"band\": \"conflict\",\n185:     \"total\": 5,\n186:     \"overlayEdges\": 5,\n187:     \"top1Moved\": 1,\n188:     \"correctNoOverlay\": 4,\n189:     \"correctOverlay\": 5,\n190:     \"showsSignal\": true,\n191:     \"rows\": [\n192:       {\n193:         \"id\": \"q38\",\n194:         \"prompt\": \"find the structural impact of this code change across callers\",\n195:         \"gold\": \"system-code-graph\",\n196:         \"noOverlay\": \"sk-code\",\n197:         \"overlay\": \"system-code-graph\",\n198:         \"moved\": true\n199:       },\n200:       {\n201:         \"id\": \"q39\",\n202:         \"prompt\": \"review this code change for quality and correctness\",\n203:         \"gold\": \"sk-code-review\",\n204:         \"noOverlay\": \"sk-code-review\",\n205:         \"overlay\": \"sk-code-review\",\n206:         \"moved\": false\n207:       },\n208:       {\n209:         \"id\": \"q40\",\n210:         \"prompt\": \"do a code review pass over the implementation\",\n211:         \"gold\": \"sk-code-review\",\n212:         \"noOverlay\": \"sk-code-review\",\n213:         \"overlay\": \"sk-code-review\",\n214:         \"moved\": false\n215:       },\n216:       {\n217:         \"id\": \"q41\",\n218:         \"prompt\": \"set up a git worktree for this code change\",\n219:         \"gold\": \"sk-git\",\n220:         \"noOverlay\": \"sk-git\",\n221:         \"overlay\": \"sk-git\",\n222:         \"moved\": false\n223:       },\n224:       {\n225:         \"id\": \"q42\",\n226:         \"prompt\": \"save the session context into the spec folder\",\n227:         \"gold\": \"system-spec-kit\",\n228:         \"noOverlay\": \"system-spec-kit\",\n229:         \"overlay\": \"system-spec-kit\",\n230:         \"moved\": false\n231:       }\n232:     ]\n233:   },\n234:   \"determinism\": {\n235:     \"baseline\": {\n236:       \"runToRunStable\": true\n237:     },\n238:     \"rrf\": {\n239:       \"runToRunStable\": true\n240:     },\n241:     \"rrf_guard\": {\n242:       \"runToRunStable\": true\n243:     }\n244:   },\n245:   \"byteIdentity\": {\n246:     \"byteIdentical\": true,\n247:     \"checkedPrompts\": 42,\n248:     \"overlayChangesOffTop1\": false,\n249:     \"overlayChangesOffHash\": true,\n250:     \"overlayOffNote\": \"the conflict overlay does not change the default-off top-1, the lower-rank hash difference is the native weighted-sum graph-causal conflict handling, not a flag leak\"\n251:   },\n252:   \"perPrompt\": [\n253:     {\n254:       \"id\": \"q01\",\n255:       \"band\": \"exact\",\n256:       \"prompt\": \"claude code cli orchestration\",\n257:       \"gold\": \"cli-claude-code\",\n258:       \"top\": {\n259:         \"baseline\": \"cli-claude-code\",\n260:         \"rrf\": \"cli-claude-code\",\n\n(Showing lines 1-260 of 716. Use offset=261 to continue.)\n</content>","metadata":{"preview":"{\n  \"generatedAt\": \"2026-06-24T05:32:26.454Z\",\n  \"question\": \"Does advisor RRF fusion plus the guards beat the weighted-sum baseline on routing top-1 correctness, and do the self-recommendation guard and the conflict-rerank seam show signal on a set built to trigger them, on the production path against a read-only projection copy?\",\n  \"method\": {\n    \"scorer\": \"production scoreAdvisor