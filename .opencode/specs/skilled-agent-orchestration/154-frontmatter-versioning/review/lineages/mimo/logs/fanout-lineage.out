{"type":"tool_use","timestamp":1782211171885,"sessionID":"ses_10bf585e9fferjmNcR8To5cw5o","part":{"type":"tool","tool":"read","callID":"call_8d1bd34bc37a4f2f828fd9cf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/scripts/quick_validate.py","offset":0,"limit":50},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/scripts/quick_validate.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: # ───────────────────────────────────────────────────────────────\n3: # COMPONENT: SKILL VALIDATOR\n4: # ───────────────────────────────────────────────────────────────\n5: \n6: \"\"\"\n7: Quick validation script for skills - enhanced version\n8: \n9: Validates:\n10: - SKILL.md exists\n11: - YAML frontmatter present and valid\n12: - Required fields: name, description, version (skills only; 4-part X.Y.Z.W -- see references/frontmatter_versioning.md)\n13: - Optional fields: allowed-tools\n14: - Name format: hyphen-case\n15: - Description: single line (no YAML block format)\n16: - Description length within budget (packet 086): soft warn at 130/110, hard fail at 1536\n17: - allowed-tools (if present): array format [Tool1, Tool2]\n18: - No angle brackets in description\n19: - No TODO placeholders in description\n20: \n21: Output formats:\n22: - Human-readable (default)\n23: - JSON (with --json flag)\n24: \n25: Description budget reference: see\n26: .opencode/skills/sk-doc/assets/frontmatter_templates.md\n27: § \"Description Budget & Trim Style\". Constants below are the single source of\n28: truth for the python validators; doc-side constants live in the markdown file.\n29: \"\"\"\n30: \n31: import argparse\n32: import sys\n33: import json\n34: import re\n35: from pathlib import Path\n36: from typing import Any, Dict, List, Optional, Tuple, Union\n37: \n38: \n39: # ───────────────────────────────────────────────────────────────\n40: # Description budget constants\n41: # ───────────────────────────────────────────────────────────────\n42: # Soft targets are project conventions (warn, do not block).\n43: # Hard cap is the Claude Code internal limit on combined description+when_to_use.\n44: DESCRIPTION_SOFT_TARGET_SKILL = 130\n45: DESCRIPTION_SOFT_TARGET_COMMAND = 110\n46: DESCRIPTION_HARD_CAP = 1536\n47: \n48: \n49: def _detect_target_kind(skill_path: Path) -> str:\n50:     \"\"\"Detect whether the validated artifact is a skill or a command from its path.\n\n(Showing lines 1-50 of 272. Use offset=51 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n# ───────────────────────────────────────────────────────────────\n# COMPONENT: SKILL VALIDATOR\n# ───────────────────────────────────────────────────────────────\n\n\"\"\"\nQuick validation script for skills - enhanced version\n\nValidates:\n- SKILL.md exists\n- YAML frontmatter present and valid\n- Required fields: name, description, version (skills only; 4-part X.Y.Z.W -- see references/frontmatter_versioning.md)\n- Optional fields: allowed-tools\n- Name format: hyphen-case\n- Description: single line (no YAML block format)\n- Description length within budget (packet 086): soft warn at 130/110, hard fail at 1536\n- allowed-tools (if present): array format [Tool1, Tool2]\n- No angle brackets in description\n- No TODO placeholders in description\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/scripts/quick_validate.py","text":"#!/usr/bin/env python3\n# ───────────────────────────────────────────────────────────────\n# COMPONENT: SKILL VALIDATOR\n# ───────────────────────────────────────────────────────────────\n\n\"\"\"\nQuick validation script for skills - enhanced version\n\nValidates:\n- SKILL.md exists\n- YAML frontmatter present and valid\n- Required fields: name, description, version (skills only; 4-part X.Y.Z.W -- see references/frontmatter_versioning.md)\n- Optional fields: allowed-tools\n- Name format: hyphen-case\n- Description: single line (no YAML block format)\n- Description length within budget (packet 086): soft warn at 130/110, hard fail at 1536\n- allowed-tools (if present): array format [Tool1, Tool2]\n- No angle brackets in description\n- No TODO placeholders in description\n\nOutput formats:\n- Human-readable (default)\n- JSON (with --json flag)\n\nDescription budget reference: see\n.opencode/skills/sk-doc/assets/frontmatter_templates.md\n§ \"Description Budget & Trim Style\". Constants below are the single source of\ntruth for the python validators; doc-side constants live in the markdown file.\n\"\"\"\n\nimport argparse\nimport sys\nimport json\nimport re\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Tuple, Union\n\n\n# ───────────────────────────────────────────────────────────────\n# Description budget constants\n# ───────────────────────────────────────────────────────────────\n# Soft targets are project conventions (warn, do not block).\n# Hard cap is the Claude Code internal limit on combined description+when_to_use.\nDESCRIPTION_SOFT_TARGET_SKILL = 130\nDESCRIPTION_SOFT_TARGET_COMMAND = 110\nDESCRIPTION_HARD_CAP = 1536\n\n\ndef _detect_target_kind(skill_path: Path) -> str:\n    \"\"\"Detect whether the validated artifact is a skill or a command from its path.","lineStart":1,"lineEnd":50,"totalLines":272,"truncated":true}},"title":".opencode/skills/sk-doc/scripts/quick_validate.py","time":{"start":1782211171879,"end":1782211171883}},"id":"prt_ef41056240011rtieZfKw5qz3s","sessionID":"ses_10bf585e9fferjmNcR8To5cw5o","messageID":"msg_ef4103e970014lrR5gaZ097PHZ"}}
