{"type":"tool_use","timestamp":1781764137477,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"grep","callID":"call_X0UkNLqR7ZlaXHtU6XFU3t6b","state":{"status":"completed","input":{"pattern":"includeArchived|archived|memory_state|ARCHIVED","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search","include":"*.ts"},"output":"Found 67 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:\n  Line 97:   includeArchived?: boolean;\n\n  Line 145: type HardExclusionSource = 'archived-tier' | 'deprecated-tier';\n\n  Line 159:     id: 'includeArchived-default',\n\n  Line 160:     source: 'archived-tier',\n\n  Line 162:     predicate: 'includeArchived defaults to false',\n\n  Line 191:     id: 'structural-deprecated-archived-tier',\n\n  Line 194:     predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n\n  Line 530:         // only drop them when archived retrieval is disabled.\n\n  Line 594:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n\n  Line 599:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n\n  Line 606:   const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n\n  Line 613:     const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n\n  Line 633:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n\n  Line 638:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n\n  Line 707:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n\n  Line 723:     // them below hot memories); the hard exclusion only applies when archived\n\n  Line 1161:     includeArchived = false,\n\n  Line 1174:         includeArchived,\n\n  Line 1192:     const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n\n  Line 1376:           includeArchived: options.includeArchived || false,\n\n  Line 2206:     // Exclude archived rows unless explicitly requested\n\n  Line 2208:       `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-types.ts:\n  Line 164:   includeArchived?: boolean;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts:\n  Line 28:   includeArchived?: boolean;\n\n  Line 158:  * @param options - Search options (limit, specFolder, includeArchived)\n\n  Line 170:   const { limit = 20, specFolder, includeArchived = false } = options;\n\n  Line 171:   // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n\n  Line 173:   const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts:\n  Line 377:     includeArchived = false\n\n  Line 407:     constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n\n  Line 425:     // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n\n  Line 479:   options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n\n  Line 482:   const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n\n  Line 484:   let results = get_constitutional_memories(database, specFolder, includeArchived);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts:\n  Line 1751:   includeArchived: boolean,\n\n  Line 1754:   return `${db_scope}::${spec_folder || 'global'}:${includeArchived ? 'arch' : 'noarch'}`;\n\n  Line 1920:  * @param includeArchived - Whether archived memories should be included.\n\n  Line 1926:   includeArchived = false\n\n  Line 1928:   // Scope cache entries to the active DB path as well as the archived filter.\n\n  Line 1929:   const cache_key = build_constitutional_cache_key(spec_folder, includeArchived);\n\n  Line 1992:     const scoped_suffix_archived = `::${spec_folder}:arch`;\n\n  Line 1995:       if (key.endsWith(scoped_suffix_archived) || key.endsWith(scoped_suffix_live)) {\n\n  Line 2000:       if (key.endsWith(scoped_suffix_archived) || key.endsWith(scoped_suffix_live)) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts:\n  Line 134:   _includeArchived: boolean\n\n  Line 578:     includeArchived,\n\n  Line 589:     includeArchived,\n\n  Line 989:             includeArchived,\n\n  Line 1029:       includeArchived,\n\n  Line 1341:             const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts:\n  Line 41:   includeArchived: boolean;\n\n  Line 154:   includeArchived,\n\n  Line 196:     includeArchived,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts:\n  Line 155:   includeArchived: boolean;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts:\n  Line 1166:           `SELECT id, memory_state FROM memory_index WHERE id IN (${placeholders})`\n\n  Line 1167:         ).all(...injectedIds) as Array<{ id: number; memory_state?: string }>;\n\n  Line 1168:         const stateMap = new Map(stateRows.map((row) => [row.id, row.memory_state]));\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts:\n  Line 647:  * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n\n  Line 655:  * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n\n  Line 659:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n\n  Line 663:  * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n\n  Line 669:  * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n\n  Line 673:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts:\n  Line 61:   ARCHIVED: 1,\n\n  Line 73:   ARCHIVED: 5,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts:\n  Line 3112:       -- DEPRECATED post-026.018 cleanup: archived-tier removed. Column kept to\n\n  Line 3113:       -- DEPRECATED schema stability: new rows always have is_archived = 0 and\n\n  Line 3115:       is_archived INTEGER DEFAULT 0, -- DEPRECATED schema stability\n","metadata":{"matches":67,"truncated":false},"title":"includeArchived|archived|memory_state|ARCHIVED","time":{"start":1781764137457,"end":1781764137475}},"metadata":{"openai":{"itemId":"fc_0dc95707430729cd016a3390295cac8191ac9e5e9192f88e97"}},"id":"prt_ed96b21ee001EQGnlwMv7AVwqD","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96af490001ycHPE2mRkjSR0j"}}
{"type":"tool_use","timestamp":1781764137477,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_RLsN8vIfSp4SbRwiIobo0Icf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Sqlite Fts\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Semantic and lexical search (memory_search)\n5: // Weighted BM25 scoring for FTS5 full-text search.\n6: // Extracted from hybrid-search.ts ftsSearch() for independent\n7: // Testing and future delegation.\n8: \n9: import { BM25_FTS5_WEIGHTS } from './bm25-index.js';\n10: import { specFolderLikePattern } from './vector-index-types.js';\n11: import { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\n12: import { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\n13: import type Database from 'better-sqlite3';\n14: \n15: // ───────────────────────────────────────────────────────────────\n16: // 2. INTERFACES\n17: \n18: // ───────────────────────────────────────────────────────────────\n19: interface FtsBm25Result {\n20:   id: number;\n21:   fts_score: number;\n22:   [key: string]: unknown;\n23: }\n24: \n25: interface FtsBm25Options {\n26:   limit?: number;\n27:   specFolder?: string;\n28:   includeArchived?: boolean;\n29: }\n30: \n31: type LexicalPath = 'fts5' | 'like' | 'unavailable';\n32: type FallbackState =\n33:   | 'ok'\n34:   | 'compile_probe_miss'\n35:   | 'missing_table'\n36:   | 'no_such_module_fts5'\n37:   | 'bm25_runtime_failure';\n38: \n39: interface LexicalCapabilitySnapshot {\n40:   lexicalPath: LexicalPath;\n41:   fallbackState: FallbackState;\n42: }\n43: \n44: let lastLexicalCapabilitySnapshot: LexicalCapabilitySnapshot | null = null;\n45: \n46: function cloneLexicalCapabilitySnapshot(\n47:   snapshot: LexicalCapabilitySnapshot | null\n48: ): LexicalCapabilitySnapshot | null {\n49:   return snapshot ? { ...snapshot } : null;\n50: }\n51: \n52: function setLastLexicalCapabilitySnapshot(snapshot: LexicalCapabilitySnapshot): void {\n53:   lastLexicalCapabilitySnapshot = { ...snapshot };\n54: }\n55: \n56: function getLastLexicalCapabilitySnapshot(): LexicalCapabilitySnapshot | null {\n57:   return cloneLexicalCapabilitySnapshot(lastLexicalCapabilitySnapshot);\n58: }\n59: \n60: function resetLastLexicalCapabilitySnapshot(): void {\n61:   lastLexicalCapabilitySnapshot = null;\n62: }\n63: \n64: function toErrorMessage(error: unknown): string {\n65:   return error instanceof Error ? error.message : String(error);\n66: }\n67: \n68: function readCompileOptionValue(row: unknown): string | null {\n69:   if (typeof row === 'string') {\n70:     return row;\n71:   }\n72:   if (!row || typeof row !== 'object') {\n73:     return null;\n74:   }\n75: \n76:   const record = row as Record<string, unknown>;\n77:   const direct = record.compile_options;\n78:   if (typeof direct === 'string') {\n79:     return direct;\n80:   }\n81: \n82:   const firstString = Object.values(record).find((value) => typeof value === 'string');\n83:   return typeof firstString === 'string' ? firstString : null;\n84: }\n85: \n86: function isNoSuchModuleFts5Error(error: unknown): boolean {\n87:   return toErrorMessage(error).toLowerCase().includes('no such module: fts5');\n88: }\n89: \n90: function isBm25RuntimeFailure(error: unknown): boolean {\n91:   const message = toErrorMessage(error).toLowerCase();\n92:   return message.includes('bm25');\n93: }\n94: \n95: function probeFts5Capability(db: Database.Database): LexicalCapabilitySnapshot {\n96:   try {\n97:     const compileRows = (db.prepare('PRAGMA compile_options') as Database.Statement).all() as unknown[];\n98:     const hasFts5CompileFlag = compileRows\n99:       .map(readCompileOptionValue)\n100:       .some((value) => typeof value === 'string' && value.toUpperCase().includes('ENABLE_FTS5'));\n101: \n102:     if (!hasFts5CompileFlag) {\n103:       return {\n104:         lexicalPath: 'unavailable',\n105:         fallbackState: 'compile_probe_miss',\n106:       };\n107:     }\n108:   } catch {\n109:     return {\n110:       lexicalPath: 'unavailable',\n111:       fallbackState: 'compile_probe_miss',\n112:     };\n113:   }\n114: \n115:   try {\n116:     const result = (db.prepare(\n117:       `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n118:     ) as Database.Statement).get() as { name: string } | undefined;\n119: \n120:     if (!result) {\n121:       return {\n122:         lexicalPath: 'unavailable',\n123:         fallbackState: 'missing_table',\n124:       };\n125:     }\n126:   } catch (error: unknown) {\n127:     if (isNoSuchModuleFts5Error(error)) {\n128:       return {\n129:         lexicalPath: 'unavailable',\n130:         fallbackState: 'no_such_module_fts5',\n131:       };\n132:     }\n133:     return {\n134:       lexicalPath: 'unavailable',\n135:       fallbackState: 'missing_table',\n136:     };\n137:   }\n138: \n139:   return {\n140:     lexicalPath: 'fts5',\n141:     fallbackState: 'ok',\n142:   };\n143: }\n144: \n145: // ───────────────────────────────────────────────────────────────\n146: // 3. CORE FUNCTION\n147: \n148: // ───────────────────────────────────────────────────────────────\n149: /**\n150:  * Execute a weighted BM25 FTS5 search against memory_fts.\n151:  *\n152:  * Uses SQLite FTS5's built-in bm25() ranking function with\n153:  * per-column weights instead of the default `rank` pseudo-column.\n154:  * This gives title matches 10x weight, trigger_phrases 5x, etc.\n155:  *\n156:  * @param db - SQLite database connection\n157:  * @param query - Raw search query (will be sanitized)\n158:  * @param options - Search options (limit, specFolder, includeArchived)\n159:  * @returns Array of results with BM25 scores (higher = better)\n160:  * @example\n161:  * ```ts\n162:  * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n163:  * ```\n164:  */\n165: function fts5Bm25Search(\n166:   db: Database.Database,\n167:   query: string,\n168:   options: FtsBm25Options = {}\n169: ): FtsBm25Result[] {\n170:   const { limit = 20, specFolder, includeArchived = false } = options;\n171:   // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n172:   // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n173:   const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n174: \n175:   // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n176:   const sanitized = normalizeLexicalQueryTokens(query).fts;\n177: \n178:   if (!sanitized) {\n179:     setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n180:     return [];\n181:   }\n182: \n183:   const folderFilter = specFolder\n184:     ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n185:     : '';\n186:   const deprecatedTierFilter = includeCold\n187:     ? ''\n188:     : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n189: \n190:   const params: (string | number)[] = specFolder\n191:     ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n192:     : [sanitized, limit];\n193: \n194:   // Bm25() returns negative scores (lower = better), so we negate\n195:   // To produce positive scores where higher = better match.\n196:   const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n197:   const sql = `\n198:     SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n199:     FROM memory_fts\n200:     JOIN memory_index m ON m.id = memory_fts.rowid\n201:     WHERE memory_fts MATCH ?\n202:       ${folderFilter}\n203:       ${deprecatedTierFilter}\n204:     ORDER BY fts_score DESC\n205:     LIMIT ?\n206:   `;\n207: \n208:   const capability = probeFts5Capability(db);\n209:   setLastLexicalCapabilitySnapshot(capability);\n210:   if (capability.fallbackState !== 'ok') {\n211:     console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n212:     return [];\n213:   }\n214: \n215:   try {\n216:     const rows = (db.prepare(sql) as Database.Statement).all(\n217:       ...params\n218:     ) as Array<Record<string, unknown>>;\n219: \n220:     const normalizedRows = rows.map(row => ({\n221:       ...row,\n222:       id: row.id as number,\n223:       fts_score: (row.fts_score as number) || 0,\n224:     }));\n225:     setLastLexicalCapabilitySnapshot({\n226:       lexicalPath: 'fts5',\n227:       fallbackState: 'ok',\n228:     });\n229:     return normalizedRows;\n230:   } catch (error: unknown) {\n231:     const msg = error instanceof Error ? error.message : String(error);\n232:     const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n233:       ? {\n234:           lexicalPath: 'unavailable',\n235:           fallbackState: 'no_such_module_fts5',\n236:         }\n237:       : isBm25RuntimeFailure(error)\n238:         ? {\n239:             lexicalPath: 'unavailable',\n240:             fallbackState: 'bm25_runtime_failure',\n241:           }\n242:         : msg.toLowerCase().includes('no such table: memory_fts')\n243:           ? {\n244:               lexicalPath: 'unavailable',\n245:               fallbackState: 'missing_table',\n246:             }\n247:           : {\n248:               lexicalPath: 'unavailable',\n249:               fallbackState: 'bm25_runtime_failure',\n250:             };\n251:     setLastLexicalCapabilitySnapshot(failureSnapshot);\n252:     console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n253:     return [];\n254:   }\n255: }\n256: \n257: /**\n258:  * Check if the memory_fts FTS5 virtual table exists in the database.\n259:  *\n260:  * Used as a feature-detect before calling fts5Bm25Search, since FTS5\n\n(Showing lines 1-260 of 299. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Sqlite Fts\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Semantic and lexical search (memory_search)\n// Weighted BM25 scoring for FTS5 full-text search.\n// Extracted from hybrid-search.ts ftsSearch() for independent\n// Testing and future delegation.\n\nimport { BM25_FTS5_WEIGHTS } from './bm25-index.js';\nimport { specFolderLikePattern } from './vector-index-types.js';\nimport { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\nimport { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\nimport type Database from 'better-sqlite3';\n\n// ───────────────────────────────────────────────────────────────\n// 2. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface FtsBm25Result {\n  id: number;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Sqlite Fts\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Semantic and lexical search (memory_search)\n// Weighted BM25 scoring for FTS5 full-text search.\n// Extracted from hybrid-search.ts ftsSearch() for independent\n// Testing and future delegation.\n\nimport { BM25_FTS5_WEIGHTS } from './bm25-index.js';\nimport { specFolderLikePattern } from './vector-index-types.js';\nimport { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\nimport { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\nimport type Database from 'better-sqlite3';\n\n// ───────────────────────────────────────────────────────────────\n// 2. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface FtsBm25Result {\n  id: number;\n  fts_score: number;\n  [key: string]: unknown;\n}\n\ninterface FtsBm25Options {\n  limit?: number;\n  specFolder?: string;\n  includeArchived?: boolean;\n}\n\ntype LexicalPath = 'fts5' | 'like' | 'unavailable';\ntype FallbackState =\n  | 'ok'\n  | 'compile_probe_miss'\n  | 'missing_table'\n  | 'no_such_module_fts5'\n  | 'bm25_runtime_failure';\n\ninterface LexicalCapabilitySnapshot {\n  lexicalPath: LexicalPath;\n  fallbackState: FallbackState;\n}\n\nlet lastLexicalCapabilitySnapshot: LexicalCapabilitySnapshot | null = null;\n\nfunction cloneLexicalCapabilitySnapshot(\n  snapshot: LexicalCapabilitySnapshot | null\n): LexicalCapabilitySnapshot | null {\n  return snapshot ? { ...snapshot } : null;\n}\n\nfunction setLastLexicalCapabilitySnapshot(snapshot: LexicalCapabilitySnapshot): void {\n  lastLexicalCapabilitySnapshot = { ...snapshot };\n}\n\nfunction getLastLexicalCapabilitySnapshot(): LexicalCapabilitySnapshot | null {\n  return cloneLexicalCapabilitySnapshot(lastLexicalCapabilitySnapshot);\n}\n\nfunction resetLastLexicalCapabilitySnapshot(): void {\n  lastLexicalCapabilitySnapshot = null;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction readCompileOptionValue(row: unknown): string | null {\n  if (typeof row === 'string') {\n    return row;\n  }\n  if (!row || typeof row !== 'object') {\n    return null;\n  }\n\n  const record = row as Record<string, unknown>;\n  const direct = record.compile_options;\n  if (typeof direct === 'string') {\n    return direct;\n  }\n\n  const firstString = Object.values(record).find((value) => typeof value === 'string');\n  return typeof firstString === 'string' ? firstString : null;\n}\n\nfunction isNoSuchModuleFts5Error(error: unknown): boolean {\n  return toErrorMessage(error).toLowerCase().includes('no such module: fts5');\n}\n\nfunction isBm25RuntimeFailure(error: unknown): boolean {\n  const message = toErrorMessage(error).toLowerCase();\n  return message.includes('bm25');\n}\n\nfunction probeFts5Capability(db: Database.Database): LexicalCapabilitySnapshot {\n  try {\n    const compileRows = (db.prepare('PRAGMA compile_options') as Database.Statement).all() as unknown[];\n    const hasFts5CompileFlag = compileRows\n      .map(readCompileOptionValue)\n      .some((value) => typeof value === 'string' && value.toUpperCase().includes('ENABLE_FTS5'));\n\n    if (!hasFts5CompileFlag) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'compile_probe_miss',\n      };\n    }\n  } catch {\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'compile_probe_miss',\n    };\n  }\n\n  try {\n    const result = (db.prepare(\n      `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n    ) as Database.Statement).get() as { name: string } | undefined;\n\n    if (!result) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'missing_table',\n      };\n    }\n  } catch (error: unknown) {\n    if (isNoSuchModuleFts5Error(error)) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'no_such_module_fts5',\n      };\n    }\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'missing_table',\n    };\n  }\n\n  return {\n    lexicalPath: 'fts5',\n    fallbackState: 'ok',\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. CORE FUNCTION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Execute a weighted BM25 FTS5 search against memory_fts.\n *\n * Uses SQLite FTS5's built-in bm25() ranking function with\n * per-column weights instead of the default `rank` pseudo-column.\n * This gives title matches 10x weight, trigger_phrases 5x, etc.\n *\n * @param db - SQLite database connection\n * @param query - Raw search query (will be sanitized)\n * @param options - Search options (limit, specFolder, includeArchived)\n * @returns Array of results with BM25 scores (higher = better)\n * @example\n * ```ts\n * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n * ```\n */\nfunction fts5Bm25Search(\n  db: Database.Database,\n  query: string,\n  options: FtsBm25Options = {}\n): FtsBm25Result[] {\n  const { limit = 20, specFolder, includeArchived = false } = options;\n  // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n  // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n  const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n\n  // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n  const sanitized = normalizeLexicalQueryTokens(query).fts;\n\n  if (!sanitized) {\n    setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n    return [];\n  }\n\n  const folderFilter = specFolder\n    ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n    : '';\n  const deprecatedTierFilter = includeCold\n    ? ''\n    : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n\n  const params: (string | number)[] = specFolder\n    ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n    : [sanitized, limit];\n\n  // Bm25() returns negative scores (lower = better), so we negate\n  // To produce positive scores where higher = better match.\n  const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n  const sql = `\n    SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n    FROM memory_fts\n    JOIN memory_index m ON m.id = memory_fts.rowid\n    WHERE memory_fts MATCH ?\n      ${folderFilter}\n      ${deprecatedTierFilter}\n    ORDER BY fts_score DESC\n    LIMIT ?\n  `;\n\n  const capability = probeFts5Capability(db);\n  setLastLexicalCapabilitySnapshot(capability);\n  if (capability.fallbackState !== 'ok') {\n    console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n    return [];\n  }\n\n  try {\n    const rows = (db.prepare(sql) as Database.Statement).all(\n      ...params\n    ) as Array<Record<string, unknown>>;\n\n    const normalizedRows = rows.map(row => ({\n      ...row,\n      id: row.id as number,\n      fts_score: (row.fts_score as number) || 0,\n    }));\n    setLastLexicalCapabilitySnapshot({\n      lexicalPath: 'fts5',\n      fallbackState: 'ok',\n    });\n    return normalizedRows;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n      ? {\n          lexicalPath: 'unavailable',\n          fallbackState: 'no_such_module_fts5',\n        }\n      : isBm25RuntimeFailure(error)\n        ? {\n            lexicalPath: 'unavailable',\n            fallbackState: 'bm25_runtime_failure',\n          }\n        : msg.toLowerCase().includes('no such table: memory_fts')\n          ? {\n              lexicalPath: 'unavailable',\n              fallbackState: 'missing_table',\n            }\n          : {\n              lexicalPath: 'unavailable',\n              fallbackState: 'bm25_runtime_failure',\n            };\n    setLastLexicalCapabilitySnapshot(failureSnapshot);\n    console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check if the memory_fts FTS5 virtual table exists in the database.\n *\n * Used as a feature-detect before calling fts5Bm25Search, since FTS5","lineStart":1,"lineEnd":260,"totalLines":299,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","time":{"start":1781764137463,"end":1781764137476}},"metadata":{"openai":{"itemId":"fc_0dc95707430729cd016a3390295cc8819190eca6549f9e5a7d"}},"id":"prt_ed96b21f6001B4IKjU265pqI0Y","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96af490001ycHPE2mRkjSR0j"}}
{"type":"tool_use","timestamp":1781764137478,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_qhVkaCnWT4w1w8t18DdjItOo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1320,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1320:     }\n1321: \n1322:     const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n1323: \n1324:     if (skippedChannels.length > 0) {\n1325:       s3meta.routing = {\n1326:         tier: routeResult.tier,\n1327:         channels: routeResult.channels,\n1328:         skippedChannels,\n1329:         featureFlagEnabled: isComplexityRouterEnabled(),\n1330:         confidence: routeResult.classification.confidence,\n1331:         features: routeResult.classification.features as Record<string, unknown>,\n1332:       };\n1333:     }\n1334: \n1335:     // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n1336:     // Compute tier-aware budget early so it's available for downstream truncation.\n1337:     // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n1338:     // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n1339:     const lowSignalQuery =\n1340:       routeResult.classification.confidence === 'low' ||\n1341:       routeResult.classification.confidence === 'fallback';\n1342:     const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n1343:       lowSignal: lowSignalQuery,\n1344:     });\n1345:     if (budgetResult.applied && !evaluationMode) {\n1346:       s3meta.tokenBudget = {\n1347:         tier: budgetResult.tier,\n1348:         budget: budgetResult.budget,\n1349:         applied: budgetResult.applied,\n1350:         featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n1351:         configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n1352:         // headerOverhead and adjustedBudget are patched in below after they are computed\n1353:         headerOverhead: 0,\n1354:         adjustedBudget: budgetResult.budget,\n1355:       };\n1356:     }\n1357: \n1358:     // Channel results collected independently, merged after all complete\n1359:     let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n1360:     let ftsChannelResults: HybridSearchResult[] = [];\n1361:     let bm25ChannelResults: HybridSearchResult[] = [];\n1362:     let triggerChannelResults: HybridSearchResult[] = [];\n1363:     const vectorEmbeddingCache = new Map<number, Float32Array>();\n1364: \n1365:     // All channels use synchronous better-sqlite3; sequential execution\n1366:     // Is correct — Promise.all adds overhead without parallelism.\n1367: \n1368:     // Vector channel — gated by query-complexity routing\n1369:     if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n1370:       try {\n1371:         const vectorResults = vectorSearchFn(embedding, {\n1372:           limit: options.limit || DEFAULT_LIMIT,\n1373:           specFolder: options.specFolder,\n1374:           minSimilarity: options.minSimilarity || 0,\n1375:           includeConstitutional: false,\n1376:           includeArchived: options.includeArchived || false,\n1377:           includeEmbeddings: true,\n1378:         });\n1379:         semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n1380:           ...r,\n1381:           id: r.id as number | string,\n1382:           source: 'vector',\n1383:         }));\n1384:         for (const result of semanticResults) {\n1385:           if (typeof result.id !== 'number') continue;\n1386:           const embeddingCandidate = toEmbeddingBufferView(\n1387:             (result as Record<string, unknown>).embedding\n1388:             ?? (result as Record<string, unknown>).embeddingBuffer\n1389:           );\n1390:           if (embeddingCandidate) {\n1391:             vectorEmbeddingCache.set(result.id, embeddingCandidate);\n1392:           }\n1393:         }\n1394:         lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n1395:       } catch (_err: unknown) {\n1396:         // Non-critical — vector channel failure does not block pipeline\n1397:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1398:       }\n1399:     }\n1400: \n1401:     // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n1402:     if (activeChannels.has('fts')) {\n1403:       ftsChannelResults = ftsSearch(query, options);\n1404:       if (ftsChannelResults.length > 0) {\n1405:         // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n1406:         // flooding top-K with noisy lexical matches despite its exact-match value.\n1407:         lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n1408:       }\n1409:     }\n1410: \n1411:     // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n1412:     if (activeChannels.has('bm25')) {\n1413:       bm25ChannelResults = bm25Search(query, options);\n1414:       if (bm25ChannelResults.length > 0) {\n1415:         // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n1416:         // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n1417:         lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n1418:       }\n1419:     }\n1420: \n1421:     triggerChannelResults = exactTriggerSearch(query, options);\n1422:     if (triggerChannelResults.length > 0) {\n1423:       lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n1424:     }\n1425: \n1426:     // Graph channel — gated by query-complexity routing\n1427:     const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n1428:     if (useGraph && graphSearchFn) {\n1429:       try {\n1430:         graphMetrics.totalQueries++; // counted only if channel executes\n1431:         const graphResults = graphSearchFn(query, {\n1432:           limit: options.limit || DEFAULT_LIMIT,\n1433:           specFolder: options.specFolder,\n1434:           intent: options.intent,\n1435:         });\n1436:         if (graphResults.length > 0) {\n1437:           graphMetrics.graphHits++;\n1438:           graphMetrics.graphResultCount += graphResults.length;\n1439:           lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n1440:             ...r,\n1441:             id: r.id as number | string,\n1442:           })), weight: 0.5 });\n1443:         }\n1444:       } catch (_err: unknown) {\n1445:         // Non-critical — graph channel failure does not block pipeline\n1446:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1447:       }\n1448:     }\n1449: \n1450:     // Degree channel re-ranks based on causal-edge connectivity.\n1451:     // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n1452:     // Degree channel — also gated by query-complexity routing\n1453:     if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n1454:       try {\n1455:         graphMetrics.degreeQueries++;\n1456:         // Collect all numeric IDs from existing channels\n1457:         const allResultIds = new Set<number>();\n1458:         for (const list of lists) {\n1459:           for (const r of list.results) {\n1460:             const id = r.id;\n1461:             if (typeof id === 'number') allResultIds.add(id);\n1462:           }\n1463:         }\n1464: \n1465:         if (allResultIds.size > 0) {\n1466:           const degreeScores = computeDegreeScores(db, Array.from(allResultIds));\n1467: \n1468:           // Build a ranked list sorted by degree score (highest first)\n1469:           const degreeItems: Array<{ id: number; degreeScore: number }> = [];\n1470:           for (const [idStr, score] of degreeScores) {\n1471:             const numId = Number(idStr);\n1472:             if (score > 0 && !isNaN(numId)) {\n1473:               degreeItems.push({ id: numId, degreeScore: score });\n1474:             }\n1475:           }\n1476:           degreeItems.sort((a, b) => b.degreeScore - a.degreeScore);\n1477: \n1478:           if (degreeItems.length > 0) {\n1479:             graphMetrics.degreeHits++;\n1480:             graphMetrics.degreeResultCount += degreeItems.length;\n1481:             lists.push({\n1482:               source: 'degree',\n1483:               results: degreeItems.map(item => ({\n1484:                 id: item.id,\n1485:                 degreeScore: item.degreeScore,\n1486:               })),\n1487:               weight: DEGREE_CHANNEL_WEIGHT,\n1488:             });\n1489:           }\n1490:         }\n1491:       } catch (_err: unknown) {\n1492:         // Non-critical — degree channel failure does not block pipeline\n1493:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1494:       }\n1495:     }\n1496: \n1497:     // Merge keyword results after all channels complete\n1498:     const keywordResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [\n1499:       ...ftsChannelResults,\n1500:       ...bm25ChannelResults,\n1501:     ];\n1502: \n1503:     if (options.skipFusion) {\n1504:       return {\n1505:         evaluationMode,\n1506:         intent: options.intent || classifyIntent(query).intent,\n1507:         lists,\n1508:         routeResult,\n1509:         budgetResult,\n1510:         s3meta,\n1511:         vectorEmbeddingCache,\n1512:         fusedResults: collectCandidatesFromLists(\n1513:           lists.filter((list) => list.source !== 'degree'),\n1514:           options.limit ?? DEFAULT_LIMIT\n1515:         ),\n1516:       };\n1517:     }\n1518: \n1519:     if (lists.length === 0) {\n1520:       return null;\n1521:     }\n1522: \n1523:     // Track multi-source and graph-only results\n1524:     const sourceMap = new Map<string, Set<string>>();\n1525:     for (const list of lists) {\n1526:       for (const r of list.results) {\n1527:         const key = canonicalResultId(r.id);\n1528:         if (!sourceMap.has(key)) sourceMap.set(key, new Set());\n1529:         sourceMap.get(key)!.add(list.source); // non-null safe: has() guard above guarantees entry exists\n1530:       }\n1531:     }\n1532:     for (const [, sources] of sourceMap) {\n1533:       if (sources.size > 1) graphMetrics.multiSourceResults++;\n1534:       if (sources.size > 1 && sources.has('graph')) graphMetrics.graphMultiSourceResults++;\n1535:       if (sources.size === 1 && sources.has('graph')) graphMetrics.graphOnlyResults++;\n1536:     }\n1537: \n1538:     // Build weighted fusion lists once from lightweight adaptive\n1539:     // weights, avoiding the heavier hybridAdaptiveFuse() standard-first path.\n1540:     const detectedIntent = classifyIntent(query).intent;\n1541:     const intent = resolveFusionIntentContract({\n1542:       detectedIntent,\n1543:       adaptiveFusionIntent: options.intent ?? null,\n1544:       query,\n1545:     })\n1546:       ?? detectedIntent;\n1547:     const adaptiveEnabled = isAdaptiveFusionEnabled();\n1548:     const documentType = resolveAdaptiveDocumentType(lists.map((list) => ({\n1549:       results: list.results as Array<Record<string, unknown>>,\n1550:     })));\n1551:     const fusionWeights = adaptiveEnabled\n1552:       ? getAdaptiveWeights(intent, documentType)\n1553:       : { semanticWeight: 1.0, keywordWeight: 1.0, recencyWeight: 0 };\n1554: 