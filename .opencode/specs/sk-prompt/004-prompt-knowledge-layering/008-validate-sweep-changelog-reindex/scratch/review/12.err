const fs = require('fs');
const path = require('path');
const root = '/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public';
const files = [
  '.opencode/skills/sk-prompt-models/references/models/swe-1.6.md',
  '.opencode/skills/sk-prompt-models/references/models/minimax-2.7.md',
  '.opencode/skills/sk-prompt-models/references/models/kimi-k2.6.md',
  '.opencode/skills/sk-prompt-models/references/models/qwen3.6.md',
  '.opencode/skills/sk-prompt-models/references/models/deepseek-v4-pro.md',
  '.opencode/skills/sk-prompt-models/references/models/glm-5.1.md',
  '.opencode/skills/sk-prompt-models/references/models/mimo-v2.5-pro.md',
  '.opencode/skills/sk-prompt-models/references/models/minimax-m3.md',
  '.opencode/skills/sk-prompt-models/references/models/_index.md',
  '.opencode/skills/sk-prompt-models/references/pattern-index.md',
];
function stripDest(raw) {
  let dest = raw.trim();
  if ((dest.startsWith('<') && dest.endsWith('>')) || (dest.startsWith('"') && dest.endsWith('"'))) dest = dest.slice(1, -1);
  const hash = dest.indexOf('#');
  if (hash >= 0) dest = dest.slice(0, hash);
  const q = dest.indexOf('?');
  if (q >= 0) dest = dest.slice(0, q);
  return decodeURIComponent(dest);
}
function isRelative(raw) {
  const dest = raw.trim();
  return dest && !dest.startsWith('#') && !/^[a-z][a-z0-9+.-]*:/i.test(dest) && !dest.startsWith('/');
}
function extractLinks(line) {
  const links = [];
  const inline = /!?(?<!\\)\[[^\]]*\]\(([^)\s]+(?:\s+"[^"]*")?)\)/g;
  for (const m of line.matchAll(inline)) {
    const target = m[1].split(/\s+/)[0];
    links.push({ target, raw: m[0] });
  }
  const ref = /^\s*\[[^\]]+\]:\s*(\S+)/g;
  for (const m of line.matchAll(ref)) links.push({ target: m[1], raw: m[0] });
  return links;
}
let total = 0;
let broken = [];
for (const rel of files) {
  const abs = path.join(root, rel);
  const text = fs.readFileSync(abs, 'utf8');
  const lines = text.split(/\r?\n/);
  let inFence = false;
  let fileCount = 0;
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    if (/^\s*```/.test(line)) { inFence = !inFence; continue; }
    if (inFence) continue;
    for (const link of extractLinks(line)) {
      if (!isRelative(link.target)) continue;
      const target = stripDest(link.target);
      if (!target) continue;
      total++;
      fileCount++;
      const resolved = path.resolve(path.dirname(abs), target);
      const exists = fs.existsSync(resolved);
      if (!exists) broken.push({ file: rel, line: i + 1, target: link.target, resolved: path.relative(root, resolved) });
    }
  }
  console.log(`${rel}: ${fileCount} relative links`);
}
console.log(`TOTAL_RELATIVE_LINKS ${total}`);
console.log(`BROKEN_LINKS ${broken.length}`);
for (const b of broken) console.log(`${b.file}:${b.line}: ${b.target} -> ${b.resolved}`);
