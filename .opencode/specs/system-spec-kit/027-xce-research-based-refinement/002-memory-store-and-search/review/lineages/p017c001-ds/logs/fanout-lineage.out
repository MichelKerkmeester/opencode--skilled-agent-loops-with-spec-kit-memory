{"type":"tool_use","timestamp":1781722683189,"sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","part":{"type":"tool","tool":"read","callID":"call_00_uTeiztmmMdUnTAviMXGa5059","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":2827},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n2827:       budgetLimit: effectiveBudget,\n2828:       truncatedToCount: 1,\n2829:       timestamp: new Date().toISOString(),\n2830:     };\n2831:     console.warn(\n2832:       `[hybrid-search] Token budget overflow (single-result fallback): ` +\n2833:       `${totalTokens} tokens > ${effectiveBudget} budget`\n2834:     );\n2835:     return { results: [outputResult], truncated: true, overflow };\n2836:   }\n2837: \n2838:   // Skip-and-continue accumulation: take highest-scoring results that fit, but\n2839:   // skip (don't break on) a too-large result so smaller lower-ranked results\n2840:   // still get a chance to fit. A single large top memory must not starve the tail.\n2841:   const accepted: HybridSearchResult[] = [];\n2842:   const overflowRemainder: HybridSearchResult[] = [];\n2843:   let accumulated = 0;\n2844: \n2845:   for (const result of sorted) {\n2846:     const tokens = getTokenEstimate(result);\n2847:     if (accumulated + tokens > effectiveBudget) {\n2848:       overflowRemainder.push(result);\n2849:       continue;\n2850:     }\n2851:     accepted.push(result);\n2852:     accumulated += tokens;\n2853:   }\n2854: \n2855:   // Floor the detailed count at min(limit, DEFAULT_MIN_RESULTS): promote the\n2856:   // highest-scoring skipped results as token-cheap summaries so an overflowing\n2857:   // search still surfaces a usable set instead of collapsing to one result.\n2858:   // Summary-first applies regardless of includeContent — the common\n2859:   // metadata-only call would otherwise discard the remainder entirely.\n2860:   // The floor is defined against the caller's limit; with no limit there is\n2861:   // nothing to floor against, so fall back to the historical ≥1 guarantee.\n2862:   const floorTarget = options?.limit !== undefined\n2863:     ? Math.max(1, Math.min(options.limit, DEFAULT_MIN_RESULTS))\n2864:     : 1;\n2865:   while (accepted.length < floorTarget && overflowRemainder.length > 0) {\n2866:     accepted.push(createSummaryFallback(overflowRemainder.shift()!, effectiveBudget));\n2867:   }\n2868: \n2869:   // Re-establish highest-score-first ordering: a promoted summary may outrank\n2870:   // an already-accepted full result.\n2871:   accepted.sort((a, b) => b.score - a.score);\n2872: \n2873:   // Route whatever still did not fit through progressive disclosure (summary +\n2874:   // first snippet page + continuation cursor) rather than discarding it.\n2875:   const progressive: ProgressiveResponse | undefined = overflowRemainder.length > 0\n2876:     ? buildProgressiveResponse(\n2877:         overflowRemainder as unknown as DisclosureResult[],\n2878:         DEFAULT_PAGE_SIZE,\n2879:         query,\n2880:       )\n2881:     : undefined;\n2882: \n2883:   const overflow: OverflowLogEntry = {\n2884:     queryId,\n2885:     candidateCount: results.length,\n2886:     totalTokens,\n2887:     budgetLimit: effectiveBudget,\n2888:     truncatedToCount: accepted.length,\n2889:     timestamp: new Date().toISOString(),\n2890:   };\n2891: \n2892:   console.warn(\n2893:     `[hybrid-search] Token budget overflow: ${totalTokens} tokens > ${effectiveBudget} budget, ` +\n2894:     `truncated ${results.length} → ${accepted.length} results` +\n2895:     (progressive ? ` (${overflowRemainder.length} deferred to progressive disclosure)` : '')\n2896:   );\n2897: \n2898:   return {\n2899:     results: accepted,\n2900:     truncated: true,\n2901:     overflow,\n2902:     ...(progressive ? { progressive } : {}),\n2903:   };\n2904: }\n2905: \n2906: // 15. EXPORTS\n2907: \n2908: export const __testables = {\n2909:   canonicalResultId,\n2910:   getHardExclusionPredicates,\n2911:   truncateChars,\n2912:   extractSpecSegments,\n2913:   injectContextualTree,\n2914:   applyResultLimit,\n2915:   reorderTopNByCosine,\n2916:   COSINE_TOPN_REORDER_DEPTH,\n2917:   calibrateTier3Scores,\n2918:   checkDegradation,\n2919:   mergeResults,\n2920:   mergeRawCandidate,\n2921:   setEnrichFusedResultsObserver(observer: (() => void) | null): void {\n2922:     enrichFusedResultsObserver = observer;\n2923:   },\n2924: };\n2925: \n2926: export {\n2927:   init,\n2928:   bm25Search,\n2929:   isBm25Available,\n2930:   combinedLexicalSearch,\n2931:   collectRawCandidates,\n2932:   isFtsAvailable,\n2933:   ftsSearch,\n2934:   hybridSearch,\n2935:   hybridSearchEnhanced,\n2936:   searchWithFallback,\n2937:   getHardExclusionPredicates,\n2938:   getGraphMetrics,\n2939:   resetGraphMetrics,\n2940:   // Token budget validation\n2941:   estimateTokenCount,\n2942:   estimateResultTokens,\n2943:   truncateToBudget,\n2944:   getTokenBudget,\n2945:   DEFAULT_TOKEN_BUDGET,\n2946:   SUMMARY_MAX_CHARS,\n2947:   // Re-exported module functions for caller access\n2948:   routeQuery,\n2949:   getDynamicTokenBudget,\n2950:   isDynamicTokenBudgetEnabled,\n2951:   // PI-A2: Tiered fallback exports\n2952:   structuralSearch,\n2953:   DEGRADATION_QUALITY_THRESHOLD,\n2954:   DEGRADATION_MIN_RESULTS,\n2955: };\n2956: \n2957: export type {\n2958:   HybridSearchOptions,\n2959:   HybridSearchResult,\n2960:   HardExclusionClassification,\n2961:   HardExclusionPredicate,\n2962:   HardExclusionSource,\n2963:   VectorSearchFn,\n2964:   // Token budget types\n2965:   OverflowLogEntry,\n2966:   TruncateToBudgetResult,\n2967:   // Pipeline metadata type\n2968:   Sprint3PipelineMeta,\n2969:   // PI-A2: Degradation types\n2970:   DegradationEvent,\n2971:   FallbackTier,\n2972: };\n\n(End of file - total 2972 lines)\n</content>","metadata":{"preview":"      budgetLimit: effectiveBudget,\n      truncatedToCount: 1,\n      timestamp: new Date().toISOString(),\n    };\n    console.warn(\n      `[hybrid-search] Token budget overflow (single-result fallback): ` +\n      `${totalTokens} tokens > ${effectiveBudget} budget`\n    );\n    return { results: [outputResult], truncated: true, overflow };\n  }\n\n  // Skip-and-continue accumulation: take highest-scoring results that fit, but\n  // skip (don't break on) a too-large result so smaller lower-ranked results\n  // still get a chance to fit. A single large top memory must not starve the tail.\n  const accepted: HybridSearchResult[] = [];\n  const overflowRemainder: HybridSearchResult[] = [];\n  let accumulated = 0;\n\n  for (const result of sorted) {\n    const tokens = getTokenEstimate(result);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"      budgetLimit: effectiveBudget,\n      truncatedToCount: 1,\n      timestamp: new Date().toISOString(),\n    };\n    console.warn(\n      `[hybrid-search] Token budget overflow (single-result fallback): ` +\n      `${totalTokens} tokens > ${effectiveBudget} budget`\n    );\n    return { results: [outputResult], truncated: true, overflow };\n  }\n\n  // Skip-and-continue accumulation: take highest-scoring results that fit, but\n  // skip (don't break on) a too-large result so smaller lower-ranked results\n  // still get a chance to fit. A single large top memory must not starve the tail.\n  const accepted: HybridSearchResult[] = [];\n  const overflowRemainder: HybridSearchResult[] = [];\n  let accumulated = 0;\n\n  for (const result of sorted) {\n    const tokens = getTokenEstimate(result);\n    if (accumulated + tokens > effectiveBudget) {\n      overflowRemainder.push(result);\n      continue;\n    }\n    accepted.push(result);\n    accumulated += tokens;\n  }\n\n  // Floor the detailed count at min(limit, DEFAULT_MIN_RESULTS): promote the\n  // highest-scoring skipped results as token-cheap summaries so an overflowing\n  // search still surfaces a usable set instead of collapsing to one result.\n  // Summary-first applies regardless of includeContent — the common\n  // metadata-only call would otherwise discard the remainder entirely.\n  // The floor is defined against the caller's limit; with no limit there is\n  // nothing to floor against, so fall back to the historical ≥1 guarantee.\n  const floorTarget = options?.limit !== undefined\n    ? Math.max(1, Math.min(options.limit, DEFAULT_MIN_RESULTS))\n    : 1;\n  while (accepted.length < floorTarget && overflowRemainder.length > 0) {\n    accepted.push(createSummaryFallback(overflowRemainder.shift()!, effectiveBudget));\n  }\n\n  // Re-establish highest-score-first ordering: a promoted summary may outrank\n  // an already-accepted full result.\n  accepted.sort((a, b) => b.score - a.score);\n\n  // Route whatever still did not fit through progressive disclosure (summary +\n  // first snippet page + continuation cursor) rather than discarding it.\n  const progressive: ProgressiveResponse | undefined = overflowRemainder.length > 0\n    ? buildProgressiveResponse(\n        overflowRemainder as unknown as DisclosureResult[],\n        DEFAULT_PAGE_SIZE,\n        query,\n      )\n    : undefined;\n\n  const overflow: OverflowLogEntry = {\n    queryId,\n    candidateCount: results.length,\n    totalTokens,\n    budgetLimit: effectiveBudget,\n    truncatedToCount: accepted.length,\n    timestamp: new Date().toISOString(),\n  };\n\n  console.warn(\n    `[hybrid-search] Token budget overflow: ${totalTokens} tokens > ${effectiveBudget} budget, ` +\n    `truncated ${results.length} → ${accepted.length} results` +\n    (progressive ? ` (${overflowRemainder.length} deferred to progressive disclosure)` : '')\n  );\n\n  return {\n    results: accepted,\n    truncated: true,\n    overflow,\n    ...(progressive ? { progressive } : {}),\n  };\n}\n\n// 15. EXPORTS\n\nexport const __testables = {\n  canonicalResultId,\n  getHardExclusionPredicates,\n  truncateChars,\n  extractSpecSegments,\n  injectContextualTree,\n  applyResultLimit,\n  reorderTopNByCosine,\n  COSINE_TOPN_REORDER_DEPTH,\n  calibrateTier3Scores,\n  checkDegradation,\n  mergeResults,\n  mergeRawCandidate,\n  setEnrichFusedResultsObserver(observer: (() => void) | null): void {\n    enrichFusedResultsObserver = observer;\n  },\n};\n\nexport {\n  init,\n  bm25Search,\n  isBm25Available,\n  combinedLexicalSearch,\n  collectRawCandidates,\n  isFtsAvailable,\n  ftsSearch,\n  hybridSearch,\n  hybridSearchEnhanced,\n  searchWithFallback,\n  getHardExclusionPredicates,\n  getGraphMetrics,\n  resetGraphMetrics,\n  // Token budget validation\n  estimateTokenCount,\n  estimateResultTokens,\n  truncateToBudget,\n  getTokenBudget,\n  DEFAULT_TOKEN_BUDGET,\n  SUMMARY_MAX_CHARS,\n  // Re-exported module functions for caller access\n  routeQuery,\n  getDynamicTokenBudget,\n  isDynamicTokenBudgetEnabled,\n  // PI-A2: Tiered fallback exports\n  structuralSearch,\n  DEGRADATION_QUALITY_THRESHOLD,\n  DEGRADATION_MIN_RESULTS,\n};\n\nexport type {\n  HybridSearchOptions,\n  HybridSearchResult,\n  HardExclusionClassification,\n  HardExclusionPredicate,\n  HardExclusionSource,\n  VectorSearchFn,\n  // Token budget types\n  OverflowLogEntry,\n  TruncateToBudgetResult,\n  // Pipeline metadata type\n  Sprint3PipelineMeta,\n  // PI-A2: Degradation types\n  DegradationEvent,\n  FallbackTier,\n};","lineStart":2827,"lineEnd":2972,"totalLines":2972,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781722683183,"end":1781722683188}},"id":"prt_ed6f29545001zwrzneX7Q4G2uM","sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","messageID":"msg_ed6f28378001f0LhYCw2gyCeBC"}}
