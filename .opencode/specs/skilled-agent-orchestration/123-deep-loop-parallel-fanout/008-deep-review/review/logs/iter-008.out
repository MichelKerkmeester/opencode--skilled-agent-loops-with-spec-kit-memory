   310	// ───── HELPERS ─────
   311	
   312	function prepareStatement(sql: string): Database.Statement {
   313	  const currentDb = getDb();
   314	  if (statementDb !== currentDb) {
   315	    preparedStatements.clear();
   316	    statementDb = currentDb;
   317	  }
   318	
   319	  let statement = preparedStatements.get(sql);
   320	  if (!statement) {
   321	    statement = currentDb.prepare(sql);
   322	    preparedStatements.set(sql, statement);
   323	  }
   324	  return statement;
   325	}
