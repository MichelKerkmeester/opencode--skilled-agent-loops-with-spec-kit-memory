    85	function materializeFixtureInput(fixture, entry) {
    86	  const input = JSON.parse(JSON.stringify(entry));
    87	  const fixtureId = input.certificateFixture;
    88	  const certificateState = input.certificateState || 'live';
    89	  delete input.certificateFixture;
    90	  delete input.certificateState;
    91	  if (!fixtureId) return input;
    92	  const certificate = sealCertificate(fixture.certificates[fixtureId]);
    93	  input.certificateHandle = {
    94	    state: certificateState,
    95	    activeCertificateId: certificate.certificateId,
    96	    certificate,
    97	  };
    98	  return input;
    99	}
