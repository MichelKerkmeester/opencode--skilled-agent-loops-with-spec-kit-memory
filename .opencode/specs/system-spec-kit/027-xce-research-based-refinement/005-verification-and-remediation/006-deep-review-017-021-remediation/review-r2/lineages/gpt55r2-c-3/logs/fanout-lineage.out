yHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n\n  Line 473:     retryHealthSnapshot.failed++;\n\n  Line 478:   retryHealthSnapshot.pending = stats.pending;\n\n  Line 479:   retryHealthSnapshot.failed = stats.failed;\n\n  Line 480:   retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n\n  Line 481:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n\n  Line 482:   retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n\n  Line 483:   retryHealthSnapshot.queueDepth = stats.queue_size;\n\n  Line 497:   // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n\n  Line 505:     WHERE embedding_status IN ('pending', 'retry')\n\n  Line 506:       AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n\n  Line 507:       AND COALESCE(last_retry_at, created_at, updated_at) < ?\n\n  Line 512:     WHERE embedding_status IN ('pending', 'retry')\n\n  Line 513:       AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n\n  Line 514:     ORDER BY COALESCE(last_retry_at, created_at, updated_at) ASC, id ASC\n\n  Line 526:         AND embedding_status IN ('pending', 'retry')\n\n  Line 527:         AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n\n  Line 538:     console.warn(`[retry-manager] Retention pruned expired=${expired}, overflow=${overflow}`);\n\n  Line 552:     console.warn('[retry-manager] Database not initialized. Server may still be starting up.');\n\n  Line 560:     WHERE embedding_status IN ('pending', 'retry')\n\n  Line 561:       AND retry_count < ?\n\n  Line 564:       retry_count ASC,\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"retry|timeout|abort|fetch|process\\.env|API|key|provider|failover|health|dimension|validate","time":{"start":1781761999787,"end":1781761999798}},"metadata":{"openai":{"itemId":"fc_04273f40e4c1f8a3016a3387cf6e648191b407af8032bb8149"}},"id":"prt_ed