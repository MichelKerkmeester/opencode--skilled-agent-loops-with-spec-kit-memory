{"type":"tool_use","timestamp":1781761487445,"sessionID":"ses_126bff004ffeidXJpk4781In70","part":{"type":"tool","tool":"read","callID":"call_Cyd7AZgA8qic2CVIhAXeuc4V","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25 Index\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: import { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\n6: import {\n7:   normalizeLexicalQueryTokens,\n8:   sanitizeFTS5Query,\n9:   sanitizeQueryTokens,\n10:   simpleStem,\n11:   STOP_WORDS,\n12:   tokenize,\n13: } from './lexical-normalizer.js';\n14: import type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\n15: import { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n16: \n17: // ───────────────────────────────────────────────────────────────\n18: // 1. INTERFACES\n19: \n20: // ───────────────────────────────────────────────────────────────\n21: interface BM25SearchResult {\n22:   id: string;\n23:   /**\n24:    * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n25:    * Higher = better lexical match. Not directly comparable to vector similarity\n26:    * scores; use min-max normalization or RRF when combining with other methods.\n27:    */\n28:   score: number;\n29: }\n30: \n31: interface BM25Stats {\n32:   documentCount: number;\n33:   termCount: number;\n34:   avgDocLength: number;\n35: }\n36: \n37: interface BM25DocumentSource {\n38:   title?: string | null;\n39:   content_text?: string | null;\n40:   trigger_phrases?: string | string[] | null;\n41:   file_path?: string | null;\n42: }\n43: \n44: /* ───────────────────────────────────────────────────────────────\n45:    1B. CONSTANTS & FEATURE FLAG\n46:    ──────────────────────────────────────────────────────────────── */\n47: \n48: const DEFAULT_K1 = 1.2;\n49: const DEFAULT_B = 0.75;\n50: const BM25_WARMUP_BATCH_SIZE = 250;\n51: const PACKED_POSTING_CHUNK_SIZE = 128;\n52: const PACKED_POSTING_FIELD_WIDTH = 4;\n53: const PACKED_POSTING_MAX_BYTE_TF = 0xff;\n54: const PACKED_POSTING_MAX_NARROW_TF = 0xffff;\n55: const PACKED_POSTING_MAX_NARROW_DOC_ID = 0xffff;\n56: const PACKED_POSTING_MAX_NARROW_TERM_ID = 0xffff;\n57: const PACKED_POSTING_TITLE_OFFSET = 0;\n58: const PACKED_POSTING_TRIGGER_OFFSET = 1;\n59: const PACKED_POSTING_PATH_OFFSET = 2;\n60: const PACKED_POSTING_BODY_OFFSET = 3;\n61: const BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n62: const BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\n63: const BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\n64: type Bm25Engine = typeof BM25_ENGINE_VALUES[number];\n65: type InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\n66: type BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n67: \n68: const BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\n69: const BM25_ENGINE_LOGGED = new Set<string>();\n70: \n71: /**\n72:  * Field weight multipliers for weighted BM25 scoring.\n73:  * When indexing a document composed of multiple fields, multiply\n74:  * each field's token scores by the appropriate weight before\n75:  * accumulating the total document score.\n76:  *\n77:  * These weights are shared by the FTS5 path and the packed in-memory\n78:  * fallback so both lexical lanes preserve the same field-priority intent.\n79:  *\n80:  * title:           10.0 — exact title matches are the strongest signal\n81:  * trigger_phrases:  5.0 — curated keywords next most important\n82:  * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n83:  * body:             1.0 — baseline weight for full body / content_text\n84:  */\n85: const BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n86: \n87: const BM25_FIELD_WEIGHTS: Record<string, number> = {\n88:   title: BM25_FTS5_WEIGHTS[0],\n89:   trigger_phrases: BM25_FTS5_WEIGHTS[1],\n90:   content_generic: BM25_FTS5_WEIGHTS[2],\n91:   body: BM25_FTS5_WEIGHTS[3],\n92: };\n93: \n94: type BM25FieldWeights = Record<BM25FieldName, number>;\n95: \n96: interface BM25DocumentFields {\n97:   title?: string | null;\n98:   trigger_phrases?: string | string[] | null;\n99:   content_generic?: string | null;\n100:   body?: string | null;\n101: }\n102: \n103: interface BM25SearchOptions {\n104:   fieldWeights?: Partial<BM25FieldWeights>;\n105: }\n106: \n107: interface LegacyDocumentRecord {\n108:   tokens: string[];\n109:   termFreq: Map<string, number>;\n110: }\n111: \n112: interface PackedDocumentRecord {\n113:   numericId: number;\n114:   id: string;\n115:   length: number;\n116:   termIds: Uint16Array | Uint32Array;\n117: }\n118: \n119: type PackedFieldTfWidth = 1 | 2 | 4;\n120: \n121: interface PackedPostingStore {\n122:   docIdChunks: Array<Uint16Array | Uint32Array>;\n123:   fieldTfChunks: Array<Uint8Array | Uint16Array | Uint32Array>;\n124:   length: number;\n125:   sorted: boolean;\n126:   wideDocIds: boolean;\n127:   fieldTfWidth: PackedFieldTfWidth;\n128: }\n129: \n130: type PackedPostingMutable = PackedPostingStore;\n131: type PackedPostingList = PackedPostingStore;\n132: \n133: interface PackedPostingEntry {\n134:   docId: number;\n135:   titleTf: number;\n136:   triggerTf: number;\n137:   pathTf: number;\n138:   bodyTf: number;\n139: }\n140: \n141: type Bm25TokenInterns = Map<number, string[]>;\n142: \n143: /**\n144:  * Check whether the in-memory BM25 index is enabled.\n145:  *\n146:  * @returns `true` when BM25 indexing/search is enabled for the current process.\n147:  * @example\n148:  * ```ts\n149:  * if (isBm25Enabled()) {\n150:  *   getIndex();\n151:  * }\n152:  * ```\n153:  */\n154: function isBm25Enabled(): boolean {\n155:   const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n156:   if (!value) return true; // enabled by default\n157:   if (BM25_DISABLED_VALUES.has(value)) return false;\n158:   return BM25_ENABLED_VALUES.has(value);\n159: }\n160: \n161: // ───────────────────────────────────────────────────────────────\n162: // 2. HELPERS\n163: \n164: // ───────────────────────────────────────────────────────────────\n165: /**\n166:  * Count token frequency occurrences for BM25 scoring.\n167:  *\n168:  * @param tokens - Normalized tokens produced by {@link tokenize}.\n169:  * @returns A frequency map keyed by token text.\n170:  * @example\n171:  * ```ts\n172:  * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n173:  * // 2\n174:  * ```\n175:  */\n176: function getTermFrequencies(tokens: string[]): Map<string, number> {\n177:   const freq = new Map<string, number>();\n178:   for (const token of tokens) {\n179:     freq.set(token, (freq.get(token) || 0) + 1);\n180:   }\n181:   return freq;\n182: }\n183: \n184: function stemNormalizedToken(word: string): string {\n185:   let stem = word;\n186:   let suffixRemoved = false;\n187: \n188:   if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n189:   else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n190:   else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n191:   else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n192:   else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n193:   else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n194: \n195:   if (suffixRemoved && stem.length >= 3) {\n196:     const last = stem[stem.length - 1];\n197:     if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n198:       stem = stem.slice(0, -1);\n199:     }\n200:   }\n201: \n202:   return stem;\n203: }\n204: \n205: function bm25ContentNeedsNormalization(content: string): boolean {\n206:   return (\n207:     content.trim() !== content ||\n208:     content.startsWith('---') ||\n209:     content.includes('<!--') ||\n210:     content.includes('```') ||\n211:     content.includes('|') ||\n212:     /(?:^|\\n)\\s*(?:[-*]\\s+|\\d+\\.\\s+|#{1,6}\\s+)/.test(content) ||\n213:     /\\n{3,}/.test(content)\n214:   );\n215: }\n216: \n217: function normalizeContentForBM25IfNeeded(content: string): string {\n218:   return bm25ContentNeedsNormalization(content) ? normalizeContentForBM25(content) : content;\n219: }\n220: \n221: function hashBm25TokenSpan(text: string, start: number, end: number): number {\n222:   let hash = 2166136261;\n223:   for (let i = start; i < end; i += 1) {\n224:     let code = text.charCodeAt(i);\n225:     if (code >= 65 && code <= 90) {\n226:       code += 32;\n227:     }\n228:     hash ^= code;\n229:     hash = Math.imul(hash, 16777619);\n230:   }\n231:   return hash >>> 0;\n232: }\n233: \n234: function equalsBm25TokenSpan(candidate: string, text: string, start: number, end: number): boolean {\n235:   if (candidate.length !== end - start) {\n236:     return false;\n237:   }\n238: \n239:   for (let i = start; i < end; i += 1) {\n240:     let code = text.charCodeAt(i);\n241:     if (code >= 65 && code <= 90) {\n242:       code += 32;\n243:     }\n244:     if (candidate.charCodeAt(i - start) !== code) {\n245:       return false;\n246:     }\n247:   }\n248: \n249:   return true;\n250: }\n251: \n252: function internBm25Token(\n253:   text: string,\n254:   start: number,\n255:   end: number,\n256:   hasUppercase: boolean,\n257:   interns?: Bm25TokenInterns\n258: ): string {\n259:   if (!interns) {\n260:     return hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n261:   }\n262: \n263:   const hash = hashBm25TokenSpan(text, start, end);\n264:   const bucket = interns.get(hash);\n265:   if (bucket) {\n266:     for (const candidate of bucket) {\n267:       if (equalsBm25TokenSpan(candidate, text, start, end)) {\n268:         return candidate;\n269:       }\n270:     }\n271:   }\n272: \n273:   const token = hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n274:   if (bucket) {\n275:     bucket.push(token);\n276:   } else {\n277:     interns.set(hash, [token]);\n278:   }\n279:   return token;\n280: }\n281: \n282: function visitBm25Tokens(text: string, visitor: (token: string) => void, interns?: Bm25TokenInterns): void {\n283:   if (!text || typeof text !== 'string') return;\n284: \n285:   let tokenStart = -1;\n286:   let hasUppercase = false;\n287:   const flush = (tokenEnd: number) => {\n288:     if (tokenStart < 0) return;\n289:     if (tokenEnd - tokenStart >= 2) {\n290:       const token = internBm25Token(text, tokenStart, tokenEnd, hasUppercase, interns);\n291:       if (!STOP_WORDS.has(token)) {\n292:         visitor(stemNormalizedToken(token));\n293:       }\n294:     }\n295:     tokenStart = -1;\n296:     hasUppercase = false;\n297:   };\n298: \n299:   for (let i = 0; i < text.length; i += 1) {\n300:     const code = text.charCodeAt(i);\n301:     if (code >= 65 && code <= 90) {\n302:       if (tokenStart < 0) tokenStart = i;\n303:       hasUppercase = true;\n304:     } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n305:       if (tokenStart < 0) tokenStart = i;\n306:     } else if (tokenStart >= 0) {\n307:       flush(i);\n308:     }\n309:   }\n310: \n311:   flush(text.length);\n312: }\n313: \n314: function visitBm25FieldValue(\n315:   value: BM25DocumentFields[BM25FieldName],\n316:   visitor: (token: string) => void,\n317:   interns?: Bm25TokenInterns\n318: ): void {\n319:   if (Array.isArray(value)) {\n320:     for (const entry of value) {\n321:       visitBm25Tokens(entry, visitor, interns);\n322:     }\n323:     return;\n324:   }\n325: \n326:   visitBm25Tokens(value ?? '', visitor, interns);\n327: }\n328: \n329: function hasBm25DocumentText(fields: BM25DocumentFields): boolean {\n330:   for (const fieldName of BM25_FIELD_NAMES) {\n331:     const value = fields[fieldName];\n332:     if (Array.isArray(value)) {\n333:       if (value.some((entry) => typeof entry === 'string' && entry.trim().length > 0)) {\n334:         return true;\n335:       }\n336:     } else if (typeof value === 'string' && value.trim().length > 0) {\n337:       return true;\n338:     }\n339:   }\n340:   return false;\n341: }\n342: \n343: function normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n344:   if (Array.isArray(triggerPhrases)) {\n345:     return triggerPhrases\n346:       .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n347:       .join(' ');\n348:   }\n349: \n350:   if (typeof triggerPhrases !== 'string') {\n351:     return '';\n352:   }\n353: \n354:   const trimmed = triggerPhrases.trim();\n355:   if (!trimmed) {\n356:     return '';\n357:   }\n358: \n359:   try {\n360:     const parsed = JSON.parse(trimmed) as unknown;\n361:     if (Array.isArray(parsed)) {\n362:       return parsed\n363:         .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n364:         .join(' ');\n365:     }\n366:   } catch {\n367:     // Fall back to raw string when the database value is not JSON.\n368:   }\n369: \n370:   return trimmed;\n371: }\n372: \n373: function resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n374:   return {\n375:     title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n376:     trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n377:     content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n378:     body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n379:   };\n380: }\n381: \n382: function emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n383:   const key = `${engine}:${reason}`;\n384:   if (BM25_ENGINE_LOGGED.has(key)) {\n385:     return;\n386:   }\n387:   BM25_ENGINE_LOGGED.add(key);\n388:   // stderr keeps stdout clean for JSON-RPC frames under stdio transport.\n389:   console.warn(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n390: }\n391: \n392: function resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n393:   const configured = resolveBm25Engine();\n394:   if (configured === 'legacy-inmemory') {\n395:     emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n396:     return 'legacy-inmemory';\n397:   }\n398: \n399:   if (configured === 'sqlite') {\n400:     emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n401:     return 'packed-inmemory';\n402:   }\n403: \n404:   if (configured === 'packed-inmemory') {\n405:     emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n406:     return 'packed-inmemory';\n407:   }\n408: \n409:   emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n410:   return 'packed-inmemory';\n411: }\n412: \n413: function buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n414:   return {\n415:     title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n416:     body: typeof row.content_text === 'string' && row.content_text.trim()\n417:       ? normalizeContentForBM25IfNeeded(row.content_text)\n418:       : '',\n419:     trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n420:     content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n421:   };\n422: }\n423: \n424: function buildBm25DocumentText(row: BM25DocumentSource): string {\n425:   const textParts: string[] = [];\n426: \n427:   if (typeof row.title === 'string' && row.title.trim()) {\n428:     textParts.push(row.title.trim());\n429:   }\n430: \n431:   if (typeof row.content_text === 'string' && row.content_text.trim()) {\n432:     textParts.push(normalizeContentForBM25IfNeeded(row.content_text));\n433:   }\n434: \n435:   const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n436:   if (triggerPhrases) {\n437:     textParts.push(triggerPhrases);\n438:   }\n439: \n440:   if (typeof row.file_path === 'string' && row.file_path.trim()) {\n441:     textParts.push(row.file_path.trim());\n442:   }\n443: \n444:   return textParts.join(' ').trim();\n445: }\n446: \n447: // ───────────────────────────────────────────────────────────────\n448: // 3. BM25 INDEX CLASS\n449: \n450: // ───────────────────────────────────────────────────────────────\n451: class BM25Index {\n452:   private k1: number;\n453:   private b: number;\n454:   private engine: InMemoryBm25Engine;\n455:   private documents: Map<string, LegacyDocumentRecord>;\n456:   private packedDocuments: Map<string, PackedDocumentRecord>;\n457:   private packedDocIds: Array<string | undefined>;\n458:   private packedFreeNumericIds: number[];\n459:   private packedDocNumbersById: Map<string, number>;\n460:   private packedMutablePostings: Map<string, PackedPostingMutable>;\n461:   private packedPostings: Map<string, PackedPostingList>;\n462:   private packedDirtyTerms: Set<string>;\n463:   private packedTokenInterns: Bm25TokenInterns;\n464:   private packedTermIdsByToken: Map<string, number>;\n465:   private packedTermsById: string[];\n466:   private packedScratchPositions: Int32Array;\n467:   private packedScratchTermIds: number[];\n468:   private packedScratchTotalTfs: number[];\n469:   private packedScratchTitleTfs: number[];\n470:   private packedScratchTriggerTfs: number[];\n471:   private packedScratchPathTfs: number[];\n472:   private packedScratchBodyTfs: number[];\n473:   private documentFreq: Map<string, number>;\n474:   private totalDocLength: number;\n475:   private warmupHandle: ReturnType<typeof setTimeout> | null;\n476:   private warmupGeneration: number;\n477: \n478:   constructor(\n479:     k1: number = DEFAULT_K1,\n480:     b: number = DEFAULT_B,\n481:     engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n482:   ) {\n483:     this.k1 = k1;\n484:     this.b = b;\n485:     this.engine = engine;\n486:     this.documents = new Map();\n487:     this.packedDocuments = new Map();\n488:     this.packedDocIds = [];\n489:     this.packedFreeNumericIds = [];\n490:     this.packedDocNumbersById = new Map();\n491:     this.packedMutablePostings = new Map();\n492:     this.packedPostings = new Map();\n493:     this.packedDirtyTerms = new Set();\n494:     this.packedTokenInterns = new Map();\n495:     this.packedTermIdsByToken = new Map();\n496:     this.packedTermsById = [];\n497:     this.packedScratchPositions = new Int32Array(16_384);\n498:     this.packedScratchPositions.fill(-1);\n499:     this.packedScratchTermIds = [];\n500:     this.packedScratchTotalTfs = [];\n501:     this.packedScratchTitleTfs = [];\n502:     this.packedScratchTriggerTfs = [];\n503:     this.packedScratchPathTfs = [];\n504:     this.packedScratchBodyTfs = [];\n505:     this.documentFreq = new Map();\n506:     this.totalDocLength = 0;\n507:     this.warmupHandle = null;\n508:     this.warmupGeneration = 0;\n509:   }\n510: \n511:   addDocument(id: string, text: string): void {\n512:     if (this.engine === 'packed-inmemory') {\n513:       this.addDocumentFields(id, { body: text });\n514:       return;\n515:     }\n516: \n517:     const tokens = tokenize(text);\n518:     const termFreq = getTermFrequencies(tokens);\n519: \n520:     if (this.documents.has(id)) {\n521:       this.removeDocument(id);\n522:     }\n523: \n524:     this.documents.set(id, { tokens, termFreq });\n525:     this.totalDocLength += tokens.length;\n526: \n527:     // Update document frequency\n528:     for (const term of termFreq.keys()) {\n529:       this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n530:     }\n531:   }\n532: \n533:   addDocumentFields(id: string, fields: BM25DocumentFields): void {\n534:     if (this.engine === 'legacy-inmemory') {\n535:       this.addDocument(id, this.joinDocumentFields(fields));\n536:       return;\n537:     }\n538: \n539:     if (this.packedDocuments.has(id)) {\n540:       this.removeDocument(id);\n541:     }\n542: \n543:     this.collectPackedTermFrequencies(fields);\n544:     try {\n545:       let length = 0;\n546:       for (const totalTf of this.packedScratchTotalTfs) {\n547:         length += totalTf;\n548:       }\n549:       if (length === 0) {\n550:         return;\n551:       }\n552: \n553:       const numericId = this.getPackedNumericId(id);\n554:       this.packedDocuments.set(id, {\n555:         numericId,\n556:         id,\n557:         length,\n558:         termIds: this.createPackedDocumentTermIds(),\n559:       });\n560:       this.totalDocLength += length;\n561: \n562:       for (let i = 0; i < this.packedScratchTermIds.length; i += 1) {\n563:         const term = this.packedTermsById[this.packedScratchTermIds[i]];\n564:         const postings = this.ensurePackedMutablePostings(term);\n565:         this.setPackedMutablePosting(\n566:           postings,\n567:           numericId,\n568:           this.packedScratchTitleTfs[i],\n569:           this.packedScratchTriggerTfs[i],\n570:           this.packedScratchPathTfs[i],\n571:           this.packedScratchBodyTfs[i]\n572:         );\n573:         this.packedDirtyTerms.add(term);\n574:         this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n575:       }\n576:     } finally {\n577:       this.clearPackedFrequencyScratch();\n578:     }\n579:   }\n580: \n581:   removeDocument(id: string): boolean {\n582:     if (this.engine === 'packed-inmemory') {\n583:       return this.removePackedDocument(id);\n584:     }\n585: \n586:     const doc = this.documents.get(id);\n587:     if (!doc) return false;\n588: \n589:     this.totalDocLength -= doc.tokens.length;\n590: \n591:     for (const term of doc.termFreq.keys()) {\n592:       const count = this.documentFreq.get(term) || 0;\n593:       if (count <= 1) {\n594:         this.documentFreq.delete(term);\n595:       } else {\n596:         this.documentFreq.set(term, count - 1);\n597:       }\n598:     }\n599: \n600:     this.documents.delete(id);\n601:     return true;\n602:   }\n603: \n604:   calculateIdf(term: string): number {\n605:     const n = this.getDocumentCount();\n606:     const df = this.documentFreq.get(term) || 0;\n607:     if (df === 0 || n === 0) return 0;\n608:     return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n609:   }\n610: \n611:   calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n612:     if (this.engine === 'packed-inmemory') {\n613:       return this.calculatePackedScore(queryTokens, docId, options);\n614:     }\n615: \n616:     const doc = this.documents.get(docId);\n617:     if (!doc) return 0;\n618: \n619:     const avgDl = this.getAverageDocumentLength();\n620:     const dl = doc.tokens.length;\n621: \n622:     let score = 0;\n623:     for (const term of queryTokens) {\n624:       const tf = doc.termFreq.get(term) || 0;\n625:       if (tf === 0) continue;\n626: \n627:       const idf = this.calculateIdf(term);\n628:       const numerator = tf * (this.k1 + 1);\n629:       const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n630:       score += idf * (numerator / denominator);\n631:     }\n632: \n633:     return score;\n634:   }\n635: \n636:   search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n637:     const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n638:     if (queryTokens.length === 0) return [];\n639: \n640:     if (this.engine === 'packed-inmemory') {\n641:       return this.searchPacked(queryTokens, limit, options);\n642:     }\n643: \n644:     const results: BM25SearchResult[] = [];\n645: \n646:     for (const [id] of this.documents) {\n647:       const score = this.calculateScore(queryTokens, id);\n648:       if (score > 0) {\n649:         results.push({ id, score });\n650:       }\n651:     }\n652: \n653:     return results\n654:       .sort((a, b) => b.score - a.score)\n655:       .slice(0, limit);\n656:   }\n657: \n658:   getStats(): BM25Stats {\n659:     return {\n660:       documentCount: this.getDocumentCount(),\n661:       termCount: this.documentFreq.size,\n662:       avgDocLength: this.getAverageDocumentLength(),\n663:     };\n664:   }\n665: \n666:   clear(): void {\n667:     this.cancelWarmup();\n668:     this.documents.clear();\n669:     this.packedDocuments.clear();\n670:     this.packedDocIds = [];\n671:     this.packedFreeNumericIds = [];\n672:     this.packedDocNumbersById.clear();\n673:     this.packedMutablePostings.clear();\n674:     this.packedPostings.clear();\n675:     this.packedDirtyTerms.clear();\n676:     this.packedTokenInterns.clear();\n677:     this.packedTermIdsByToken.clear();\n678:     this.packedTermsById = [];\n679:     this.packedScratchPositions.fill(-1);\n680:     this.clearPackedFrequencyScratch();\n681:     this.documentFreq.clear();\n682:     this.totalDocLength = 0;\n683:   }\n684: \n685:   addDocuments(docs: Array<{ id: string; text: string }>): void {\n686:     for (const doc of docs) {\n687:       this.addDocument(doc.id, doc.text);\n688:     }\n689:   }\n690: \n691:   finalizePackedPostings(): void {\n692:     if (this.engine === 'legacy-inmemory') {\n693:       return;\n694:     }\n695: \n696:     for (const term of Array.from(this.packedDirtyTerms)) {\n697:       this.getPackedPosting(term);\n698:     }\n699:     this.packedMutablePostings.clear();\n700:   }\n701: \n702:   /**\n703:    * Incrementally synchronize changed rows from the database into the in-memory index.\n704:    */\n705:   syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n706:     const normalizedIds = Array.from(\n707:       new Set(\n708:         rowIds\n709:           .map((rowId) => Number(rowId))\n710:           .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n711:       )\n712:     );\n713: \n714:     if (normalizedIds.length === 0) {\n715:       return 0;\n716:     }\n717: \n718:     try {\n719:       const placeholders = normalizedIds.map(() => '?').join(', ');\n720:       const rows = (database.prepare(\n721:         `SELECT id, title, content_text, trigger_phrases, file_path\n722:          FROM memory_index\n723:          WHERE id IN (${placeholders})`\n724:       ) as Database.Statement).all(...normalizedIds) as Array<{\n725:         id: number;\n726:         title: string | null;\n727:         content_text: string | null;\n728:         trigger_phrases: string | null;\n729:         file_path: string | null;\n730:       }>;\n731: \n732:       const activeRowMap = new Map<number, typeof rows[number]>();\n733:       for (const row of rows) {\n734:         activeRowMap.set(row.id, row);\n735:       }\n736: \n737:       for (const rowId of normalizedIds) {\n738:         const row = activeRowMap.get(rowId);\n739:         if (!row) {\n740:           this.removeDocument(String(rowId));\n741:           continue;\n742:         }\n743: \n744:         const fields = buildBm25DocumentFields(row);\n745:         if (hasBm25DocumentText(fields)) {\n746:           this.addDocumentFields(String(row.id), fields);\n747:         } else {\n748:           this.removeDocument(String(row.id));\n749:         }\n750:       }\n751: \n752:       return normalizedIds.length;\n753:     } catch (error: unknown) {\n754:       const msg = error instanceof Error ? error.message : String(error);\n755:       console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n756:       return 0;\n757:     }\n758:   }\n759: \n760:   /**\n761:    * Defer full startup warmup into batched row-ID syncs so process\n762:    * initialization is not blocked by a monolithic in-memory rebuild.\n763:    */\n764:   rebuildFromDatabase(database: Database.Database): number {\n765:     this.clear();\n766: \n767:     try {\n768:       const rows = (database.prepare(\n769:         `SELECT id\n770:          FROM memory_index\n771:          ORDER BY id`\n772:       ) as Database.Statement).all() as Array<{ id: number }>;\n773: \n774:       const pendingIds = rows.map((row) => row.id);\n775:       if (pendingIds.length === 0) {\n776:         return 0;\n777:       }\n778: \n779:       const warmupGeneration = ++this.warmupGeneration;\n780:       const processBatch = () => {\n781:         if (warmupGeneration !== this.warmupGeneration) {\n782:           return;\n783:         }\n784: \n785:         const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n786:         if (batchIds.length === 0) {\n787:           this.finalizePackedPostings();\n788:           this.warmupHandle = null;\n789:           return;\n790:         }\n791: \n792:         this.syncChangedRows(database, batchIds);\n793: \n794:         if (pendingIds.length > 0) {\n795:           this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n796:         } else {\n797:           // The queue drains on the last non-empty batch, so the empty-batch\n798:           // finalize above never runs on this path. Finalize here too, or the\n799:           // whole corpus stays in mutable number[] postings and the packed\n800:           // engine's RAM bound is lost until every term is searched.\n801:           this.finalizePackedPostings();\n802:           this.warmupHandle = null;\n803:         }\n804:       };\n805: \n806:       this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n807:       return pendingIds.length;\n808:     } catch (error: unknown) {\n809:       const msg = error instanceof Error ? error.message : String(error);\n810:       console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n811:       return 0;\n812:     }\n813:   }\n814: \n815:   cancelWarmup(): void {\n816:     this.warmupGeneration += 1;\n817:     if (this.warmupHandle) {\n818:       clearRegisteredTimer(this.warmupHandle);\n819:       this.warmupHandle = null;\n820:     }\n821:   }\n822: \n823:   private getDocumentCount(): number {\n824:     return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n825:   }\n826: \n827:   private getAverageDocumentLength(): number {\n828:     const documentCount = this.getDocumentCount();\n829:     return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n830:   }\n831: \n832:   private joinDocumentFields(fields: BM25DocumentFields): string {\n833:     const parts: string[] = [];\n834:     for (const fieldName of BM25_FIELD_NAMES) {\n835:       const value = fields[fieldName];\n836:       if (Array.isArray(value)) {\n837:         parts.push(value.join(' '));\n838:       } else if (typeof value === 'string' && value.trim()) {\n839:         parts.push(value.trim());\n840:       }\n841:     }\n842:     return parts.join(' ').trim();\n843:   }\n844: \n845:   private getPackedNumericId(id: string): number {\n846:     const existing = this.packedDocNumbersById.get(id);\n847:     if (existing !== undefined) {\n848:       return existing;\n849:     }\n850: \n851:     // Reuse a slot freed by a prior removal before extending, so packedDocIds is\n852:     // bounded by the live document count rather than cumulative write volume.\n853:     const recycled = this.packedFreeNumericIds.pop();\n854:     const numericId = recycled ?? this.packedDocIds.length;\n855:     this.packedDocIds[numericId] = id;\n856:     this.packedDocNumbersById.set(id, numericId);\n857:     return numericId;\n858:   }\n859: \n860:   private collectPackedTermFrequencies(fields: BM25DocumentFields): void {\n861:     for (const fieldName of BM25_FIELD_NAMES) {\n862:       visitBm25FieldValue(\n863:         fields[fieldName],\n864:         (token) => this.recordPackedTokenFrequency(token, fieldName),\n865:         this.packedTokenInterns\n866:       );\n867:     }\n868:   }\n869: \n870:   private recordPackedTokenFrequency(token: string, fieldName: BM25FieldName): void {\n871:     const termId = this.getPackedTermId(token);\n872:     let scratchIndex = this.packedScratchPositions[termId];\n873:     if (scratchIndex < 0) {\n874:       scratchIndex = this.packedScratchTermIds.length;\n875:       this.packedScratchPositions[termId] = scratchIndex;\n876:       this.packedScratchTermIds.push(termId);\n877:       this.packedScratchTotalTfs.push(0);\n878:       this.packedScratchTitleTfs.push(0);\n879:       this.packedScratchTriggerTfs.push(0);\n880:       this.packedScratchPathTfs.push(0);\n881:       this.packedScratchBodyTfs.push(0);\n882:     }\n883: \n884:     this.packedScratchTotalTfs[scratchIndex] += 1;\n885:     if (fieldName === 'title') this.packedScratchTitleTfs[scratchIndex] += 1;\n886:     else if (fieldName === 'trigger_phrases') this.packedScratchTriggerTfs[scratchIndex] += 1;\n887:     else if (fieldName === 'content_generic') this.packedScratchPathTfs[scratchIndex] += 1;\n888:     else this.packedScratchBodyTfs[scratchIndex] += 1;\n889:   }\n890: \n891:   private getPackedTermId(token: string): number {\n892:     const existing = this.packedTermIdsByToken.get(token);\n893:     if (existing !== undefined) {\n894:       return existing;\n895:     }\n896: \n897:     const termId = this.packedTermsById.length;\n898:     this.packedTermIdsByToken.set(token, termId);\n899:     this.packedTermsById.push(token);\n900:     this.ensurePackedScratchPositionCapacity(termId + 1);\n\n(Showing lines 1-900 of 1558. Use offset=901 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface BM25SearchResult {\n  id: string;\n  /**\n   * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n   * Higher = better lexical match. Not directly comparable to vector similarity\n   * scores; use min-max normalization or RRF when combining with other methods.\n   */\n  score: number;\n}\n\ninterface BM25Stats {\n  documentCount: number;\n  termCount: number;\n  avgDocLength: number;\n}\n\ninterface BM25DocumentSource {\n  title?: string | null;\n  content_text?: string | null;\n  trigger_phrases?: string | string[] | null;\n  file_path?: string | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1B. CONSTANTS & FEATURE FLAG\n   ──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_K1 = 1.2;\nconst DEFAULT_B = 0.75;\nconst BM25_WARMUP_BATCH_SIZE = 250;\nconst PACKED_POSTING_CHUNK_SIZE = 128;\nconst PACKED_POSTING_FIELD_WIDTH = 4;\nconst PACKED_POSTING_MAX_BYTE_TF = 0xff;\nconst PACKED_POSTING_MAX_NARROW_TF = 0xffff;\nconst PACKED_POSTING_MAX_NARROW_DOC_ID = 0xffff;\nconst PACKED_POSTING_MAX_NARROW_TERM_ID = 0xffff;\nconst PACKED_POSTING_TITLE_OFFSET = 0;\nconst PACKED_POSTING_TRIGGER_OFFSET = 1;\nconst PACKED_POSTING_PATH_OFFSET = 2;\nconst PACKED_POSTING_BODY_OFFSET = 3;\nconst BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\nconst BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\nconst BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\ntype Bm25Engine = typeof BM25_ENGINE_VALUES[number];\ntype InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\ntype BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n\nconst BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\nconst BM25_ENGINE_LOGGED = new Set<string>();\n\n/**\n * Field weight multipliers for weighted BM25 scoring.\n * When indexing a document composed of multiple fields, multiply\n * each field's token scores by the appropriate weight before\n * accumulating the total document score.\n *\n * These weights are shared by the FTS5 path and the packed in-memory\n * fallback so both lexical lanes preserve the same field-priority intent.\n *\n * title:           10.0 — exact title matches are the strongest signal\n * trigger_phrases:  5.0 — curated keywords next most important\n * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n * body:             1.0 — baseline weight for full body / content_text\n */\nconst BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n\nconst BM25_FIELD_WEIGHTS: Record<string, number> = {\n  title: BM25_FTS5_WEIGHTS[0],\n  trigger_phrases: BM25_FTS5_WEIGHTS[1],\n  content_generic: BM25_FTS5_WEIGHTS[2],\n  body: BM25_FTS5_WEIGHTS[3],\n};\n\ntype BM25FieldWeights = Record<BM25FieldName, number>;\n\ninterface BM25DocumentFields {\n  title?: string | null;\n  trigger_phrases?: string | string[] | null;\n  content_generic?: string | null;\n  body?: string | null;\n}\n\ninterface BM25SearchOptions {\n  fieldWeights?: Partial<BM25FieldWeights>;\n}\n\ninterface LegacyDocumentRecord {\n  tokens: string[];\n  termFreq: Map<string, number>;\n}\n\ninterface PackedDocumentRecord {\n  numericId: number;\n  id: string;\n  length: number;\n  termIds: Uint16Array | Uint32Array;\n}\n\ntype PackedFieldTfWidth = 1 | 2 | 4;\n\ninterface PackedPostingStore {\n  docIdChunks: Array<Uint16Array | Uint32Array>;\n  fieldTfChunks: Array<Uint8Array | Uint16Array | Uint32Array>;\n  length: number;\n  sorted: boolean;\n  wideDocIds: boolean;\n  fieldTfWidth: PackedFieldTfWidth;\n}\n\ntype PackedPostingMutable = PackedPostingStore;\ntype PackedPostingList = PackedPostingStore;\n\ninterface PackedPostingEntry {\n  docId: number;\n  titleTf: number;\n  triggerTf: number;\n  pathTf: number;\n  bodyTf: number;\n}\n\ntype Bm25TokenInterns = Map<number, string[]>;\n\n/**\n * Check whether the in-memory BM25 index is enabled.\n *\n * @returns `true` when BM25 indexing/search is enabled for the current process.\n * @example\n * ```ts\n * if (isBm25Enabled()) {\n *   getIndex();\n * }\n * ```\n */\nfunction isBm25Enabled(): boolean {\n  const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n  if (!value) return true; // enabled by default\n  if (BM25_DISABLED_VALUES.has(value)) return false;\n  return BM25_ENABLED_VALUES.has(value);\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. HELPERS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Count token frequency occurrences for BM25 scoring.\n *\n * @param tokens - Normalized tokens produced by {@link tokenize}.\n * @returns A frequency map keyed by token text.\n * @example\n * ```ts\n * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n * // 2\n * ```\n */\nfunction getTermFrequencies(tokens: string[]): Map<string, number> {\n  const freq = new Map<string, number>();\n  for (const token of tokens) {\n    freq.set(token, (freq.get(token) || 0) + 1);\n  }\n  return freq;\n}\n\nfunction stemNormalizedToken(word: string): string {\n  let stem = word;\n  let suffixRemoved = false;\n\n  if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n  else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n  else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n\n  if (suffixRemoved && stem.length >= 3) {\n    const last = stem[stem.length - 1];\n    if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n      stem = stem.slice(0, -1);\n    }\n  }\n\n  return stem;\n}\n\nfunction bm25ContentNeedsNormalization(content: string): boolean {\n  return (\n    content.trim() !== content ||\n    content.startsWith('---') ||\n    content.includes('<!--') ||\n    content.includes('```') ||\n    content.includes('|') ||\n    /(?:^|\\n)\\s*(?:[-*]\\s+|\\d+\\.\\s+|#{1,6}\\s+)/.test(content) ||\n    /\\n{3,}/.test(content)\n  );\n}\n\nfunction normalizeContentForBM25IfNeeded(content: string): string {\n  return bm25ContentNeedsNormalization(content) ? normalizeContentForBM25(content) : content;\n}\n\nfunction hashBm25TokenSpan(text: string, start: number, end: number): number {\n  let hash = 2166136261;\n  for (let i = start; i < end; i += 1) {\n    let code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      code += 32;\n    }\n    hash ^= code;\n    hash = Math.imul(hash, 16777619);\n  }\n  return hash >>> 0;\n}\n\nfunction equalsBm25TokenSpan(candidate: string, text: string, start: number, end: number): boolean {\n  if (candidate.length !== end - start) {\n    return false;\n  }\n\n  for (let i = start; i < end; i += 1) {\n    let code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      code += 32;\n    }\n    if (candidate.charCodeAt(i - start) !== code) {\n      return false;\n    }\n  }\n\n  return true;\n}\n\nfunction internBm25Token(\n  text: string,\n  start: number,\n  end: number,\n  hasUppercase: boolean,\n  interns?: Bm25TokenInterns\n): string {\n  if (!interns) {\n    return hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n  }\n\n  const hash = hashBm25TokenSpan(text, start, end);\n  const bucket = interns.get(hash);\n  if (bucket) {\n    for (const candidate of bucket) {\n      if (equalsBm25TokenSpan(candidate, text, start, end)) {\n        return candidate;\n      }\n    }\n  }\n\n  const token = hasUppercase ? text.slice(start, end).toLowerCase() : text.slice(start, end);\n  if (bucket) {\n    bucket.push(token);\n  } else {\n    interns.set(hash, [token]);\n  }\n  return token;\n}\n\nfunction visitBm25Tokens(text: string, visitor: (token: string) => void, interns?: Bm25TokenInterns): void {\n  if (!text || typeof text !== 'string') return;\n\n  let tokenStart = -1;\n  let hasUppercase = false;\n  const flush = (tokenEnd: number) => {\n    if (tokenStart < 0) return;\n    if (tokenEnd - tokenStart >= 2) {\n      const token = internBm25Token(text, tokenStart, tokenEnd, hasUppercase, interns);\n      if (!STOP_WORDS.has(token)) {\n        visitor(stemNormalizedToken(token));\n      }\n    }\n    tokenStart = -1;\n    hasUppercase = false;\n  };\n\n  for (let i = 0; i < text.length; i += 1) {\n    const code = text.charCodeAt(i);\n    if (code >= 65 && code <= 90) {\n      if (tokenStart < 0) tokenStart = i;\n      hasUppercase = true;\n    } else if ((code >= 97 && code <= 122) || (code >= 48 && code <= 57) || code === 45 || code === 95) {\n      if (tokenStart < 0) tokenStart = i;\n    } else if (tokenStart >= 0) {\n      flush(i);\n    }\n  }\n\n  flush(text.length);\n}\n\nfunction visitBm25FieldValue(\n  value: BM25DocumentFields[BM25FieldName],\n  visitor: (token: string) => void,\n  interns?: Bm25TokenInterns\n): void {\n  if (Array.isArray(value)) {\n    for (const entry of value) {\n      visitBm25Tokens(entry, visitor, interns);\n    }\n    return;\n  }\n\n  visitBm25Tokens(value ?? '', visitor, interns);\n}\n\nfunction hasBm25DocumentText(fields: BM25DocumentFields): boolean {\n  for (const fieldName of BM25_FIELD_NAMES) {\n    const value = fields[fieldName];\n    if (Array.isArray(value)) {\n      if (value.some((entry) => typeof entry === 'string' && entry.trim().length > 0)) {\n        return true;\n      }\n    } else if (typeof value === 'string' && value.trim().length > 0) {\n      return true;\n    }\n  }\n  return false;\n}\n\nfunction normalizeTriggerPhrasesForBM25(triggerPhrases: string | string[] | null | undefined): string {\n  if (Array.isArray(triggerPhrases)) {\n    return triggerPhrases\n      .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n      .join(' ');\n  }\n\n  if (typeof triggerPhrases !== 'string') {\n    return '';\n  }\n\n  const trimmed = triggerPhrases.trim();\n  if (!trimmed) {\n    return '';\n  }\n\n  try {\n    const parsed = JSON.parse(trimmed) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed\n        .filter((phrase): phrase is string => typeof phrase === 'string' && phrase.trim().length > 0)\n        .join(' ');\n    }\n  } catch {\n    // Fall back to raw string when the database value is not JSON.\n  }\n\n  return trimmed;\n}\n\nfunction resolveBm25FieldWeights(overrides: Partial<BM25FieldWeights> = {}): BM25FieldWeights {\n  return {\n    title: overrides.title ?? BM25_FIELD_WEIGHTS.title,\n    trigger_phrases: overrides.trigger_phrases ?? BM25_FIELD_WEIGHTS.trigger_phrases,\n    content_generic: overrides.content_generic ?? BM25_FIELD_WEIGHTS.content_generic,\n    body: overrides.body ?? BM25_FIELD_WEIGHTS.body,\n  };\n}\n\nfunction emitBm25EngineSelection(engine: Bm25Engine | InMemoryBm25Engine, reason: string): void {\n  const key = `${engine}:${reason}`;\n  if (BM25_ENGINE_LOGGED.has(key)) {\n    return;\n  }\n  BM25_ENGINE_LOGGED.add(key);\n  // stderr keeps stdout clean for JSON-RPC frames under stdio transport.\n  console.warn(`[bm25-index] BM25 engine selected: ${engine} (${reason})`);\n}\n\nfunction resolveInMemoryBm25Engine(): InMemoryBm25Engine {\n  const configured = resolveBm25Engine();\n  if (configured === 'legacy-inmemory') {\n    emitBm25EngineSelection('legacy-inmemory', 'explicit legacy in-memory flag');\n    return 'legacy-inmemory';\n  }\n\n  if (configured === 'sqlite') {\n    emitBm25EngineSelection('packed-inmemory', 'sqlite mode requested an in-memory fallback instance');\n    return 'packed-inmemory';\n  }\n\n  if (configured === 'packed-inmemory') {\n    emitBm25EngineSelection('packed-inmemory', 'explicit packed in-memory flag');\n    return 'packed-inmemory';\n  }\n\n  emitBm25EngineSelection('packed-inmemory', 'auto mode fallback');\n  return 'packed-inmemory';\n}\n\nfunction buildBm25DocumentFields(row: BM25DocumentSource): BM25DocumentFields {\n  return {\n    title: typeof row.title === 'string' && row.title.trim() ? row.title.trim() : '',\n    body: typeof row.content_text === 'string' && row.content_text.trim()\n      ? normalizeContentForBM25IfNeeded(row.content_text)\n      : '',\n    trigger_phrases: normalizeTriggerPhrasesForBM25(row.trigger_phrases),\n    content_generic: typeof row.file_path === 'string' && row.file_path.trim() ? row.file_path.trim() : '',\n  };\n}\n\nfunction buildBm25DocumentText(row: BM25DocumentSource): string {\n  const textParts: string[] = [];\n\n  if (typeof row.title === 'string' && row.title.trim()) {\n    textParts.push(row.title.trim());\n  }\n\n  if (typeof row.content_text === 'string' && row.content_text.trim()) {\n    textParts.push(normalizeContentForBM25IfNeeded(row.content_text));\n  }\n\n  const triggerPhrases = normalizeTriggerPhrasesForBM25(row.trigger_phrases);\n  if (triggerPhrases) {\n    textParts.push(triggerPhrases);\n  }\n\n  if (typeof row.file_path === 'string' && row.file_path.trim()) {\n    textParts.push(row.file_path.trim());\n  }\n\n  return textParts.join(' ').trim();\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. BM25 INDEX CLASS\n\n// ───────────────────────────────────────────────────────────────\nclass BM25Index {\n  private k1: number;\n  private b: number;\n  private engine: InMemoryBm25Engine;\n  private documents: Map<string, LegacyDocumentRecord>;\n  private packedDocuments: Map<string, PackedDocumentRecord>;\n  private packedDocIds: Array<string | undefined>;\n  private packedFreeNumericIds: number[];\n  private packedDocNumbersById: Map<string, number>;\n  private packedMutablePostings: Map<string, PackedPostingMutable>;\n  private packedPostings: Map<string, PackedPostingList>;\n  private packedDirtyTerms: Set<string>;\n  private packedTokenInterns: Bm25TokenInterns;\n  private packedTermIdsByToken: Map<string, number>;\n  private packedTermsById: string[];\n  private packedScratchPositions: Int32Array;\n  private packedScratchTermIds: number[];\n  private packedScratchTotalTfs: number[];\n  private packedScratchTitleTfs: number[];\n  private packedScratchTriggerTfs: number[];\n  private packedScratchPathTfs: number[];\n  private packedScratchBodyTfs: number[];\n  private documentFreq: Map<string, number>;\n  private totalDocLength: number;\n  private warmupHandle: ReturnType<typeof setTimeout> | null;\n  private warmupGeneration: number;\n\n  constructor(\n    k1: number = DEFAULT_K1,\n    b: number = DEFAULT_B,\n    engine: InMemoryBm25Engine = resolveInMemoryBm25Engine()\n  ) {\n    this.k1 = k1;\n    this.b = b;\n    this.engine = engine;\n    this.documents = new Map();\n    this.packedDocuments = new Map();\n    this.packedDocIds = [];\n    this.packedFreeNumericIds = [];\n    this.packedDocNumbersById = new Map();\n    this.packedMutablePostings = new Map();\n    this.packedPostings = new Map();\n    this.packedDirtyTerms = new Set();\n    this.packedTokenInterns = new Map();\n    this.packedTermIdsByToken = new Map();\n    this.packedTermsById = [];\n    this.packedScratchPositions = new Int32Array(16_384);\n    this.packedScratchPositions.fill(-1);\n    this.packedScratchTermIds = [];\n    this.packedScratchTotalTfs = [];\n    this.packedScratchTitleTfs = [];\n    this.packedScratchTriggerTfs = [];\n    this.packedScratchPathTfs = [];\n    this.packedScratchBodyTfs = [];\n    this.documentFreq = new Map();\n    this.totalDocLength = 0;\n    this.warmupHandle = null;\n    this.warmupGeneration = 0;\n  }\n\n  addDocument(id: string, text: string): void {\n    if (this.engine === 'packed-inmemory') {\n      this.addDocumentFields(id, { body: text });\n      return;\n    }\n\n    const tokens = tokenize(text);\n    const termFreq = getTermFrequencies(tokens);\n\n    if (this.documents.has(id)) {\n      this.removeDocument(id);\n    }\n\n    this.documents.set(id, { tokens, termFreq });\n    this.totalDocLength += tokens.length;\n\n    // Update document frequency\n    for (const term of termFreq.keys()) {\n      this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n    }\n  }\n\n  addDocumentFields(id: string, fields: BM25DocumentFields): void {\n    if (this.engine === 'legacy-inmemory') {\n      this.addDocument(id, this.joinDocumentFields(fields));\n      return;\n    }\n\n    if (this.packedDocuments.has(id)) {\n      this.removeDocument(id);\n    }\n\n    this.collectPackedTermFrequencies(fields);\n    try {\n      let length = 0;\n      for (const totalTf of this.packedScratchTotalTfs) {\n        length += totalTf;\n      }\n      if (length === 0) {\n        return;\n      }\n\n      const numericId = this.getPackedNumericId(id);\n      this.packedDocuments.set(id, {\n        numericId,\n        id,\n        length,\n        termIds: this.createPackedDocumentTermIds(),\n      });\n      this.totalDocLength += length;\n\n      for (let i = 0; i < this.packedScratchTermIds.length; i += 1) {\n        const term = this.packedTermsById[this.packedScratchTermIds[i]];\n        const postings = this.ensurePackedMutablePostings(term);\n        this.setPackedMutablePosting(\n          postings,\n          numericId,\n          this.packedScratchTitleTfs[i],\n          this.packedScratchTriggerTfs[i],\n          this.packedScratchPathTfs[i],\n          this.packedScratchBodyTfs[i]\n        );\n        this.packedDirtyTerms.add(term);\n        this.documentFreq.set(term, (this.documentFreq.get(term) || 0) + 1);\n      }\n    } finally {\n      this.clearPackedFrequencyScratch();\n    }\n  }\n\n  removeDocument(id: string): boolean {\n    if (this.engine === 'packed-inmemory') {\n      return this.removePackedDocument(id);\n    }\n\n    const doc = this.documents.get(id);\n    if (!doc) return false;\n\n    this.totalDocLength -= doc.tokens.length;\n\n    for (const term of doc.termFreq.keys()) {\n      const count = this.documentFreq.get(term) || 0;\n      if (count <= 1) {\n        this.documentFreq.delete(term);\n      } else {\n        this.documentFreq.set(term, count - 1);\n      }\n    }\n\n    this.documents.delete(id);\n    return true;\n  }\n\n  calculateIdf(term: string): number {\n    const n = this.getDocumentCount();\n    const df = this.documentFreq.get(term) || 0;\n    if (df === 0 || n === 0) return 0;\n    return Math.log((n - df + 0.5) / (df + 0.5) + 1);\n  }\n\n  calculateScore(queryTokens: string[], docId: string, options: BM25SearchOptions = {}): number {\n    if (this.engine === 'packed-inmemory') {\n      return this.calculatePackedScore(queryTokens, docId, options);\n    }\n\n    const doc = this.documents.get(docId);\n    if (!doc) return 0;\n\n    const avgDl = this.getAverageDocumentLength();\n    const dl = doc.tokens.length;\n\n    let score = 0;\n    for (const term of queryTokens) {\n      const tf = doc.termFreq.get(term) || 0;\n      if (tf === 0) continue;\n\n      const idf = this.calculateIdf(term);\n      const numerator = tf * (this.k1 + 1);\n      const denominator = tf + this.k1 * (1 - this.b + this.b * (dl / Math.max(avgDl, 1)));\n      score += idf * (numerator / denominator);\n    }\n\n    return score;\n  }\n\n  search(query: string, limit: number = 10, options: BM25SearchOptions = {}): BM25SearchResult[] {\n    const queryTokens = normalizeLexicalQueryTokens(query).bm25;\n    if (queryTokens.length === 0) return [];\n\n    if (this.engine === 'packed-inmemory') {\n      return this.searchPacked(queryTokens, limit, options);\n    }\n\n    const results: BM25SearchResult[] = [];\n\n    for (const [id] of this.documents) {\n      const score = this.calculateScore(queryTokens, id);\n      if (score > 0) {\n        results.push({ id, score });\n      }\n    }\n\n    return results\n      .sort((a, b) => b.score - a.score)\n      .slice(0, limit);\n  }\n\n  getStats(): BM25Stats {\n    return {\n      documentCount: this.getDocumentCount(),\n      termCount: this.documentFreq.size,\n      avgDocLength: this.getAverageDocumentLength(),\n    };\n  }\n\n  clear(): void {\n    this.cancelWarmup();\n    this.documents.clear();\n    this.packedDocuments.clear();\n    this.packedDocIds = [];\n    this.packedFreeNumericIds = [];\n    this.packedDocNumbersById.clear();\n    this.packedMutablePostings.clear();\n    this.packedPostings.clear();\n    this.packedDirtyTerms.clear();\n    this.packedTokenInterns.clear();\n    this.packedTermIdsByToken.clear();\n    this.packedTermsById = [];\n    this.packedScratchPositions.fill(-1);\n    this.clearPackedFrequencyScratch();\n    this.documentFreq.clear();\n    this.totalDocLength = 0;\n  }\n\n  addDocuments(docs: Array<{ id: string; text: string }>): void {\n    for (const doc of docs) {\n      this.addDocument(doc.id, doc.text);\n    }\n  }\n\n  finalizePackedPostings(): void {\n    if (this.engine === 'legacy-inmemory') {\n      return;\n    }\n\n    for (const term of Array.from(this.packedDirtyTerms)) {\n      this.getPackedPosting(term);\n    }\n    this.packedMutablePostings.clear();\n  }\n\n  /**\n   * Incrementally synchronize changed rows from the database into the in-memory index.\n   */\n  syncChangedRows(database: Database.Database, rowIds: Array<number | string>): number {\n    const normalizedIds = Array.from(\n      new Set(\n        rowIds\n          .map((rowId) => Number(rowId))\n          .filter((rowId) => Number.isInteger(rowId) && rowId > 0)\n      )\n    );\n\n    if (normalizedIds.length === 0) {\n      return 0;\n    }\n\n    try {\n      const placeholders = normalizedIds.map(() => '?').join(', ');\n      const rows = (database.prepare(\n        `SELECT id, title, content_text, trigger_phrases, file_path\n         FROM memory_index\n         WHERE id IN (${placeholders})`\n      ) as Database.Statement).all(...normalizedIds) as Array<{\n        id: number;\n        title: string | null;\n        content_text: string | null;\n        trigger_phrases: string | null;\n        file_path: string | null;\n      }>;\n\n      const activeRowMap = new Map<number, typeof rows[number]>();\n      for (const row of rows) {\n        activeRowMap.set(row.id, row);\n      }\n\n      for (const rowId of normalizedIds) {\n        const row = activeRowMap.get(rowId);\n        if (!row) {\n          this.removeDocument(String(rowId));\n          continue;\n        }\n\n        const fields = buildBm25DocumentFields(row);\n        if (hasBm25DocumentText(fields)) {\n          this.addDocumentFields(String(row.id), fields);\n        } else {\n          this.removeDocument(String(row.id));\n        }\n      }\n\n      return normalizedIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to sync BM25 rows: ${msg}`);\n      return 0;\n    }\n  }\n\n  /**\n   * Defer full startup warmup into batched row-ID syncs so process\n   * initialization is not blocked by a monolithic in-memory rebuild.\n   */\n  rebuildFromDatabase(database: Database.Database): number {\n    this.clear();\n\n    try {\n      const rows = (database.prepare(\n        `SELECT id\n         FROM memory_index\n         ORDER BY id`\n      ) as Database.Statement).all() as Array<{ id: number }>;\n\n      const pendingIds = rows.map((row) => row.id);\n      if (pendingIds.length === 0) {\n        return 0;\n      }\n\n      const warmupGeneration = ++this.warmupGeneration;\n      const processBatch = () => {\n        if (warmupGeneration !== this.warmupGeneration) {\n          return;\n        }\n\n        const batchIds = pendingIds.splice(0, BM25_WARMUP_BATCH_SIZE);\n        if (batchIds.length === 0) {\n          this.finalizePackedPostings();\n          this.warmupHandle = null;\n          return;\n        }\n\n        this.syncChangedRows(database, batchIds);\n\n        if (pendingIds.length > 0) {\n          this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n        } else {\n          // The queue drains on the last non-empty batch, so the empty-batch\n          // finalize above never runs on this path. Finalize here too, or the\n          // whole corpus stays in mutable number[] postings and the packed\n          // engine's RAM bound is lost until every term is searched.\n          this.finalizePackedPostings();\n          this.warmupHandle = null;\n        }\n      };\n\n      this.warmupHandle = registerTimeout(processBatch, 0, { unref: true });\n      return pendingIds.length;\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[bm25-index] Failed to schedule BM25 warmup: ${msg}`);\n      return 0;\n    }\n  }\n\n  cancelWarmup(): void {\n    this.warmupGeneration += 1;\n    if (this.warmupHandle) {\n      clearRegisteredTimer(this.warmupHandle);\n      this.warmupHandle = null;\n    }\n  }\n\n  private getDocumentCount(): number {\n    return this.engine === 'packed-inmemory' ? this.packedDocuments.size : this.documents.size;\n  }\n\n  private getAverageDocumentLength(): number {\n    const documentCount = this.getDocumentCount();\n    return documentCount > 0 ? this.totalDocLength / documentCount : 0;\n  }\n\n  private joinDocumentFields(fields: BM25DocumentFields): string {\n    const parts: string[] = [];\n    for (const fieldName of BM25_FIELD_NAMES) {\n      const value = fields[fieldName];\n      if (Array.isArray(value)) {\n        parts.push(value.join(' '));\n      } else if (typeof value === 'string' && value.trim()) {\n        parts.push(value.trim());\n      }\n    }\n    return parts.join(' ').trim();\n  }\n\n  private getPackedNumericId(id: string): number {\n    const existing = this.packedDocNumbersById.get(id);\n    if (existing !== undefined) {\n      return existing;\n    }\n\n    // Reuse a slot freed by a prior removal before extending, so packedDocIds is\n    // bounded by the live document count rather than cumulative write volume.\n    const recycled = this.packedFreeNumericIds.pop();\n    const numericId = recycled ?? this.packedDocIds.length;\n    this.packedDocIds[numericId] = id;\n    this.packedDocNumbersById.set(id, numericId);\n    return numericId;\n  }\n\n  private collectPackedTermFrequencies(fields: BM25DocumentFields): void {\n    for (const fieldName of BM25_FIELD_NAMES) {\n      visitBm25FieldValue(\n        fields[fieldName],\n        (token) => this.recordPackedTokenFrequency(token, fieldName),\n        this.packedTokenInterns\n      );\n    }\n  }\n\n  private recordPackedTokenFrequency(token: string, fieldName: BM25FieldName): void {\n    const termId = this.getPackedTermId(token);\n    let scratchIndex = this.packedScratchPositions[termId];\n    if (scratchIndex < 0) {\n      scratchIndex = this.packedScratchTermIds.length;\n      this.packedScratchPositions[termId] = scratchIndex;\n      this.packedScratchTermIds.push(termId);\n      this.packedScratchTotalTfs.push(0);\n      this.packedScratchTitleTfs.push(0);\n      this.packedScratchTriggerTfs.push(0);\n      this.packedScratchPathTfs.push(0);\n      this.packedScratchBodyTfs.push(0);\n    }\n\n    this.packedScratchTotalTfs[scratchIndex] += 1;\n    if (fieldName === 'title') this.packedScratchTitleTfs[scratchIndex] += 1;\n    else if (fieldName === 'trigger_phrases') this.packedScratchTriggerTfs[scratchIndex] += 1;\n    else if (fieldName === 'content_generic') this.packedScratchPathTfs[scratchIndex] += 1;\n    else this.packedScratchBodyTfs[scratchIndex] += 1;\n  }\n\n  private getPackedTermId(token: string): number {\n    const existing = this.packedTermIdsByToken.get(token);\n    if (existing !== undefined) {\n      return existing;\n    }\n\n    const termId = this.packedTermsById.length;\n    this.packedTermIdsByToken.set(token, termId);\n    this.packedTermsById.push(token);\n    this.ensurePackedScratchPositionCapacity(termId + 1);","lineStart":1,"lineEnd":900,"totalLines":1558,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781761487436,"end":1781761487443}},"metadata":{"openai":{"itemId":"fc_089eeb51a47770d7016a3385cf039881919383eba4a92c74e7"}},"id":"prt_ed942b0b9001VWkRQa9Prsn1Ky","sessionID":"ses_126bff004ffeidXJpk4781In70","messageID":"msg_ed9427726001IKzU5HcSJre2H0"}}
