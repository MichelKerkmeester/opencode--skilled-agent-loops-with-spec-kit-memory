lt\",\n    \"stopPolicy\": \"max-iterations\",\n    \"divergent\": {}\n  },\n  \"stuckThreshold\": 3,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,\n  \"specFolder\": \".opencode/specs/sk-doc/019-sk-doc-router-alignment/021-default-mode-policy-research\",\n  \"resource_map_present\": false,\n  \"resource_map\": {\n    \"emit\": true\n  },\n  \"createdAt\": \"2026-07-17T18:42:58.447Z\",\n  \"status\": \"initialized\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"cli-opencode\",\n    \"model\": \"openai/gpt-5.6-sol-fast\",\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900\n  },\n  \"lineage\": {\n    \"sessionId\": \"fanout-sol-ultra-1784313510669-wn3vsj\",\n    \"parentSessionId\": null,\n    \"lineageMode\": \"new\",\n    \"generation\": 1,\n    \"continuedFromRun\": null\n  },\n  \"fanout_lineage_artifact_dir\": \".opencode/specs/sk-doc/019-sk-doc-router-alignment/021-default-mode-policy-research/research/lineages/sol-ultra\",\n  \"nextRunAt\": null,\n  \"remainingDelayMs\": null\n}","lineStart":1,"lineEnd":44,"totalLines":44,"truncated":false}},"title":".opencode/specs/sk-doc/019-sk-doc-router-alignment/021-default-mode-policy-research/research/lineages/sol-ultra/deep-research-config.json","time":{"start":1784315531921,"end":1784315531923}},"metadata":{"openai":{"itemId":"fc_072cc8b6be191dda016a5a7e8b76c48191b005d01cfd0da8bf"}},"id":"prt_f717e5239001zKqkOrc4u6p0p5","sessionID":"ses_08ea082c9ffe7l0Exu0UkBOne2","messageID":"msg_f717df5c1001rS7akVkY03uBGu"}}
