     1	// ───────────────────────────────────────────────────────────────
     2	// MODULE: Advisor Ambiguity
     3	// ───────────────────────────────────────────────────────────────
     4	
     5	import type { AdvisorScoredRecommendation } from './types.js';
     6	
     7	export const AMBIGUITY_MARGIN = 0.05;
     8	export const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;
     9	
    10	// F-012-C2-04: Compute ambiguity from ranking `score` so the cluster aligns
    11	// with the score-based fusion ranking (top-two-by-confidence may not match
    12	// top-two-by-score).
    13	//
    14	// Packet 084 (SAD-002 fix): also compute on `confidence` and union the two
    15	// clusters. Score-margin keeps ranking alignment; confidence-margin restores
    16	// the feature-catalog-documented "0.05 confidence window" and catches
    17	// cross-domain prompts where confidence is near-tied (user-visible signal)
    18	// even when score gaps just exceed the score margin. A candidate is in the
    19	// ambiguity cluster when EITHER gap is within its respective 0.05 margin —
    20	// "outside both margins" is required to be unambiguously ranked.
    21	
    22	function ambiguousCluster(
    23	  recommendations: readonly AdvisorScoredRecommendation[],
    24	): AdvisorScoredRecommendation[] {
    25	  const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);
    26	  const [top] = passing;
    27	  if (!top) return [];
    28	  return passing.filter((recommendation) => {
    29	    const scoreGap = Math.abs(top.score - recommendation.score);
    30	    const confidenceGap = Math.abs(top.confidence - recommendation.confidence);
    31	    return (
    32	      scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON
    33	      || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON
    34	    );
    35	  });
    36	}
    37	
    38	export function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {
    39	  // Name preserved for back-compat with existing call sites; semantics are
    40	  // now "is the passing top a member of an ambiguity cluster of size >= 2".
    41	  return ambiguousCluster(recommendations).length >= 2;
    42	}
    43	
    44	export function applyAmbiguity(
    45	  recommendations: readonly AdvisorScoredRecommendation[],
    46	): AdvisorScoredRecommendation[] {
    47	  const cluster = ambiguousCluster(recommendations);
    48	  if (cluster.length < 2) return [...recommendations];
    49	  const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));
    50	  return recommendations.map((recommendation) => (
    51	    ambiguousSet.has(recommendation.skill)
    52	      ? {
    53	        ...recommendation,
    54	        ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),
    55	      }
    56	      : recommendation
    57	  ));
    58	}

