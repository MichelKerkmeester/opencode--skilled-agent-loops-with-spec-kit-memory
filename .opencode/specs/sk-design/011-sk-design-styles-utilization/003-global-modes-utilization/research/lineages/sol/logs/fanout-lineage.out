{"type":"tool_use","timestamp":1784377910506,"sessionID":"ses_08acc7a6affeS35KntG0P1wx2Z","part":{"type":"tool","tool":"read","callID":"call_qWmyqteW5aHVoycNhkI3vsRy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":1576,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n1576:           - current_iteration: \"iteration_count + 1\"\n1577:           - current_segment: \"Latest segment_start event segment, else 1\"\n1578:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n1579:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n1580:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n1581:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n1582:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n1583:           - answered_count: \"Count answered questions from strategy.md\"\n1584:           - total_questions: \"Count total questions tracked in strategy.md\"\n1585:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n1586:           - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n1587:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1588: \n1589:       step_read_all_iterations:\n1590:         action: \"Read all iteration files and strategy\"\n1591:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1592:         read_also: \"{state_paths.strategy}\"\n1593: \n1594:       step_emit_resource_map:\n1595:         action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n1596:         command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1597:         read:\n1598:           - \"{state_paths.config}\"\n1599:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1600:         write:\n1601:           - \"{state_paths.resource_map_output}\"\n1602:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1603: \n1604:       step_compile_research:\n1605:         action: \"Compile or finalize research/research.md\"\n1606:         instructions: |\n1607:           If research/research.md exists (progressive synthesis was active):\n1608:             1. Read current research/research.md\n1609:             2. Consolidate and deduplicate findings across all iterations\n1610:             3. Fill any empty sections with findings from iteration files\n1611:             4. Remove redundancy while preserving all unique findings\n1612:             5. Add convergence report as appendix\n1613:             6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1614:             7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n1615: \n1616:           If research/research.md does not exist:\n1617:             1. Create research/research.md following 17-section template\n1618:             2. Populate sections from iteration files\n1619:             3. Add citations from original sources\n1620:             4. Note unanswered questions in Open Questions section\n1621:             5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1622:             6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n1623:           Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n1624:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n1625:         output: \"{state_paths.research_output}\"\n1626: \n1627:       step_convergence_report:\n1628:         action: \"Generate and append convergence report\"\n1629:         report: |\n1630:           ## Convergence Report\n1631:           - Stop reason: {reason}\n1632:           - Total iterations: {iteration_count}\n1633:           - Questions answered: {answered_count} / {total_questions}\n1634:           - Remaining questions: {remaining_questions}\n1635:           - Last 3 iteration summaries: {last_3_summaries}\n1636:           - Convergence threshold: {convergence_threshold}\n1637:           - Divergence summary: {divergence_summary}\n1638:           - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n1639:         command: |\n1640:           node --input-type=module <<'EOF'\n1641:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1642: \n1643:           const paths = {\n1644:             stateLog: String.raw`{state_paths.state_log}`,\n1645:             registry: String.raw`{state_paths.registry}`,\n1646:             research: String.raw`{state_paths.research_output}`,\n1647:             dashboard: String.raw`{state_paths.dashboard}`,\n1648:           };\n1649: \n1650:           function hasFile(filePath) {\n1651:             try {\n1652:               return existsSync(filePath) && statSync(filePath).isFile();\n1653:             } catch {\n1654:               return false;\n1655:             }\n1656:           }\n1657: \n1658:           function readJson(filePath) {\n1659:             try {\n1660:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1661:             } catch {\n1662:               return null;\n1663:             }\n1664:           }\n1665: \n1666:           function readJsonl(filePath) {\n1667:             if (!hasFile(filePath)) return [];\n1668:             return readFileSync(filePath, 'utf8')\n1669:               .split(/\\r?\\n/)\n1670:               .map((line) => line.trim())\n1671:               .filter(Boolean)\n1672:               .flatMap((line) => {\n1673:                 try {\n1674:                   return [JSON.parse(line)];\n1675:                 } catch {\n1676:                   return [];\n1677:                 }\n1678:               });\n1679:           }\n1680: \n1681:           function countIterationFindings(record) {\n1682:             if (!record || record.type !== 'iteration') return 0;\n1683:             const numeric = Number(record.findingsCount);\n1684:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1685:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1686:             if (Array.isArray(record.findings)) return record.findings.length;\n1687:             return 0;\n1688:           }\n1689: \n1690:           function normalizeFindingKey(value) {\n1691:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1692:           }\n1693: \n1694:           function findingKeys(candidate) {\n1695:             if (typeof candidate === 'string') {\n1696:               const key = normalizeFindingKey(candidate);\n1697:               return key ? [key] : [];\n1698:             }\n1699:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1700:             return [...new Set([\n1701:               candidate.id,\n1702:               candidate.title,\n1703:               candidate.summary,\n1704:               candidate.text,\n1705:               candidate.finding,\n1706:               candidate.description,\n1707:             ].map(normalizeFindingKey).filter(Boolean))];\n1708:           }\n1709: \n1710:           function collectIterationFindingGroups(record) {\n1711:             if (!record || record.type !== 'iteration') return [];\n1712:             const structured = [record.keyFindings, record.findings]\n1713:               .find((value) => Array.isArray(value) && value.length > 0);\n1714:             if (!Array.isArray(structured)) return [];\n1715:             return structured\n1716:               .map(findingKeys)\n1717:               .filter((keys) => keys.length > 0);\n1718:           }\n1719: \n1720:           function collectRegistryFindingKeys(registry) {\n1721:             if (!Array.isArray(registry?.keyFindings)) return [];\n1722:             return registry.keyFindings\n1723:               .flatMap(findingKeys);\n1724:           }\n1725: \n1726:           function appendEvent(event) {\n1727:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1728:           }\n1729: \n1730:           const registry = readJson(paths.registry);\n1731:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1732:           const stateRecords = readJsonl(paths.stateLog);\n1733:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1734:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1735:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1736:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1737:           const identifiableFindingCount = identifiableFindingGroups.length;\n1738:           const missingArtifacts = [\n1739:             ['registry', paths.registry],\n1740:             ['research', paths.research],\n1741:             ['dashboard', paths.dashboard],\n1742:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1743:           const invariantFailures = [];\n1744:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1745:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1746:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1747:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1748:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1749: \n1750:           if (invariantFailures.length > 0) {\n1751:             appendEvent({\n1752:               type: 'event',\n1753:               event: 'synthesis_incomplete',\n1754:               mode: 'research',\n1755:               severity: 'warning',\n1756:               totalIterations: Number('{iteration_count}'),\n1757:               answeredCount: Number('{answered_count}'),\n1758:               totalQuestions: Number('{total_questions}'),\n1759:               stopReason: '{reason}',\n1760:               reason: 'synthesis_artifact_invariant_failed',\n1761:               invariantFailures,\n1762:               missingArtifacts,\n1763:               registryFindingCount,\n1764:               iterationFindingCount,\n1765:               identifiableFindingCount,\n1766:               missingStructuredFindingCount,\n1767:               timestamp: '{ISO_8601_NOW}',\n1768:             });\n1769:           } else {\n1770:             appendEvent({\n1771:               type: 'event',\n1772:               event: 'synthesis_complete',\n1773:               totalIterations: Number('{iteration_count}'),\n1774:               answeredCount: Number('{answered_count}'),\n1775:               totalQuestions: Number('{total_questions}'),\n1776:               stopReason: '{reason}',\n1777:               timestamp: '{ISO_8601_NOW}',\n1778:             });\n1779:           }\n1780:           EOF\n1781: \n1782:       step_writeback_spec_findings:\n1783:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1784:         edit: \"{spec_folder}/spec.md\"\n1785:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1786:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1787:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1788:         fail_closed_conflict_check:\n1789:           if_existing_generated_fence_present:\n1790:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1791:             on_manual_edit_conflict:\n1792:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1793:               halt: true\n1794:         instructions:\n1795:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1796:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1797:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1798:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1799:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1800:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1801: \n1802:       step_validate_post_synthesis_spec_doc:\n1803:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1804:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1805:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1806: \n1807:       step_update_config_status:\n1808:         action: \"Mark config as complete\"\n1809:         edit: \"{state_paths.config}\"\n1810:         set_field: { status: \"complete\" }\n1811: \n1812:       step_telemetry_heartbeat_terminal:\n1813:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1814:         skip_when: \"config.fanout is present\"\n1815:         terminal_events: [completed, failed, stopped]\n1816:         command: |\n1817:           node --experimental-strip-types --input-type=module <<'EOF'\n1818:           import { existsSync, readFileSync } from 'node:fs';\n1819: \n1820:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n1821:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n1822: \n1823:           const { appendObservabilityEvent } = observabilityEvents;\n1824:           const stateLogPath = '{state_paths.state_log}';\n1825:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1826:           const timestamp = '{ISO_8601_NOW}';\n1827:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1828:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1829:           const reason = '{reason}';\n1830:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1831: \n1832:           function readRecords(path) {\n1833:             if (!existsSync(path)) return [];\n1834:             return readFileSync(path, 'utf8')\n1835:               .split(/\\r?\\n/)\n1836:               .map((line) => line.trim())\n1837:               .filter(Boolean)\n1838:               .map((line) => JSON.parse(line));\n1839:           }\n1840: \n1841:           function elapsedSince(value) {\n1842:             const startedAtMs = Date.parse(String(value ?? ''));\n1843:             const nowMs = Date.parse(timestamp);\n1844:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1845:             return Math.max(0, nowMs - startedAtMs);\n1846:           }\n1847: \n1848:           function terminalEvent(stopReason) {\n1849:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1850:             if (stopReason === 'error') return 'failed';\n1851:             return 'completed';\n1852:           }\n1853: \n1854:           const records = readRecords(stateLogPath);\n1855:           const iterations = records.filter((record) => record.type === 'iteration');\n1856:           const latest = iterations.at(-1) ?? {};\n1857:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1858:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1859:             ?? timestamp;\n1860:           const elapsedMs = elapsedSince(startedAt);\n1861:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1862:           const event = terminalEvent(reason);\n1863:           const row = {\n1864:             event,\n1865:             label: 'single',\n1866:             terminal: true,\n1867:             reason,\n1868:             at: timestamp,\n1869:             duration_ms: elapsedMs,\n1870:             loop_type: 'research',\n1871:             sessionId,\n1872:             generation,\n1873:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1874:           };\n1875: \n1876:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1877:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1878:             diffField: 'state_hash',\n1879:           });\n1880:           if (appended) {\n1881:             try {\n1882:               appendObservabilityEvent(observabilityPath, row, {\n1883:                 producer: 'deep-research-auto',\n1884:                 stream: 'single-loop-telemetry',\n1885:                 subject: { label: row.label, sessionId, generation, reason },\n1886:                 event,\n1887:                 status: event,\n1888:               });\n1889:             } catch {}\n1890:           }\n1891:           EOF\n1892:         working_directory: \"{repo_root}\"\n1893:         outputs:\n1894:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1895: \n1896:       step_stage_artifact_dir:\n1897:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1898:         command: \"git add {state_paths.packet_dir}\"\n1899:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1900:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1901: \n1902:   # ═══════════════════════════════════════════════════════════════\n1903:   # PHASE 4: SAVE\n1904:   # ═══════════════════════════════════════════════════════════════\n1905:   phase_save:\n1906:     purpose: Preserve research context to memory system\n1907:     steps:\n1908: \n1909:       step_compose_save_payload:\n1910:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1911:         output: \"/tmp/save-context-data-<session-id>.json\"\n1912:         requirements:\n1913:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1914:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1915:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1916:         example_payload: |\n1917:           {\n1918:             \"specFolder\": \"{spec_folder}\",\n1919:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n1920:             \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n1921:             \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n1922:             \"exchanges\": [],\n1923:             \"toolCalls\": []\n1924:           }\n1925: \n1926:       step_generate_context:\n1927:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1928:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1929:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1930: \n1931:       step_index_memory:\n1932:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1933:         mcp_tool: memory_save\n1934:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1935:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1936: \n1937:       step_verify_save:\n1938:         action: \"Verify canonical save routed content into the correct spec document\"\n1939:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1940:         on_fail: \"Log warning but do not block completion\"\n1941: \n1942:       step_release_lock:\n1943:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1944:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1945:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1946: \n1947:   # ═══════════════════════════════════════════════════════════════\n1948:   # COMPLETION\n1949:   # ═══════════════════════════════════════════════════════════════\n1950:   completion:\n1951:     message: |\n1952:       Deep research complete.\n1953:       Iterations: {iteration_count} | Stop reason: {reason}\n1954:       Questions answered: {answered_count}/{total_questions}\n1955: \n1956:       Artifacts:\n1957:         - research/research.md (compiled from {iteration_count} iterations)\n1958:         - {iteration_count} iteration files in research/\n1959:         - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n1960:         - Memory context saved\n1961: \n1962:       STATUS=OK PATH={spec_folder}\n1963:     next_steps:\n1964:       - \"/speckit:plan [feature-description]\"\n1965:       - \"/deep:research [new-topic] (for related deep research)\"\n1966:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1967: \n1968: # ─────────────────────────────────────────────────────────────────\n1969: # ERROR RECOVERY\n1970: # ─────────────────────────────────────────────────────────────────\n1971: error_recovery:\n1972:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n1973:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1974:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1975:   memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n1976: \n1977: # ─────────────────────────────────────────────────────────────────\n1978: # RULES\n1979: # ─────────────────────────────────────────────────────────────────\n1980: rules:\n1981:   ALWAYS:\n1982:     - follow_workflow_phases_in_order\n1983:     - dispatch_deep_research_agent_per_iteration\n1984:     - check_convergence_before_each_iteration\n1985:     - write_all_state_to_files\n1986:     - upsert_iteration_memory_after_reducer\n1987:     - refresh_memory_context_before_next_prompt\n1988:     - save_memory_context_after_synthesis\n1989:     - respect_max_iterations_cap\n1990:   NEVER:\n1991:     - skip_convergence_check\n1992:     - dispatch_non_leaf_agents\n1993:     - hold_iteration_findings_in_memory_only\n1994:     - modify_config_after_initialization\n1995:     - overwrite_jsonl_state_log\n1996:     - proceed_without_state_file_verification\n1997: \n1998: # ─────────────────────────────────────────────────────────────────\n1999: # REFERENCE-ONLY APPENDIX\n2000: # ─────────────────────────────────────────────────────────────────\n2001: reference_only_appendix:\n2002:   checkpoint_commit:\n2003:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n2004:     commands:\n2005:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n2006:       - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n2007:   wave_orchestration:\n2008:     note: \"Wave execution is intentionally excluded from workflow.steps.\"\n2009:     summary:\n2010:       - \"Check whether 3+ independent unanswered questions justify a wave.\"\n2011:       - \"Dispatch up to 3 parallel agents on distinct questions.\"\n2012:       - \"Score wave results by median newInfoRatio and promote top branches.\"\n\n(End of file - total 2012 lines)\n</content>","metadata":{"preview":"          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_compile_research:\n        action: \"Compile or finalize research/research.md\"\n        instructions: |\n          If research/research.md exists (progressive synthesis was active):\n            1. Read current research/research.md\n            2. Consolidate and deduplicate findings across all iterations\n            3. Fill any empty sections with findings from iteration files\n            4. Remove redundancy while preserving all unique findings\n            5. Add convergence report as appendix\n            6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n\n          If research/research.md does not exist:\n            1. Create research/research.md following 17-section template\n            2. Populate sections from iteration files\n            3. Add citations from original sources\n            4. Note unanswered questions in Open Questions section\n            5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n          Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n        output: \"{state_paths.research_output}\"\n\n      step_convergence_report:\n        action: \"Generate and append convergence report\"\n        report: |\n          ## Convergence Report\n          - Stop reason: {reason}\n          - Total iterations: {iteration_count}\n          - Questions answered: {answered_count} / {total_questions}\n          - Remaining questions: {remaining_questions}\n          - Last 3 iteration summaries: {last_3_summaries}\n          - Convergence threshold: {convergence_threshold}\n          - Divergence summary: {divergence_summary}\n          - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.registry}`,\n            research: String.raw`{state_paths.research_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n            \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n            \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep research complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Questions answered: {answered_count}/{total_questions}\n\n      Artifacts:\n        - research/research.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in research/\n        - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [feature-description]\"\n      - \"/deep:research [new-topic] (for related deep research)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_research_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - upsert_iteration_memory_after_reducer\n    - refresh_memory_context_before_next_prompt\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n      - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n  wave_orchestration:\n    note: \"Wave execution is intentionally excluded from workflow.steps.\"\n    summary:\n      - \"Check whether 3+ independent unanswered questions justify a wave.\"\n      - \"Dispatch up to 3 parallel agents on distinct questions.\"\n      - \"Score wave results by median newInfoRatio and promote top branches.\"","lineStart":1576,"lineEnd":2012,"totalLines":2012,"truncated":false}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1784377910496,"end":1784377910500}},"metadata":{"openai":{"itemId":"fc_09033041fb6a389c016a5b72365914819190b9d9112783c72a"}},"id":"prt_f753624dd001U0ysrQgkiJxlLi","sessionID":"ses_08acc7a6affeS35KntG0P1wx2Z","messageID":"msg_f7535f1fa001EWDEFhU3iBrS3C"}}
