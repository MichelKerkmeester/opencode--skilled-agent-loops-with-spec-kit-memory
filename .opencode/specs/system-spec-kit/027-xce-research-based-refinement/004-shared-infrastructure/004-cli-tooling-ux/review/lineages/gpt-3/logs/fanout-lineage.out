{"type":"tool_use","timestamp":1781145032823,"sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","part":{"type":"tool","tool":"read","callID":"call_bNb6CH1QUs6KH43qzf36EHs7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Finalize Dist                                                           ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import crypto from 'node:crypto';\n8: import { fileURLToPath } from 'node:url';\n9: \n10: const serverDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');\n11: const distDir = path.join(serverDir, 'dist');\n12: const staleDistRoots = [\n13:   'system-spec-kit',\n14:   'system-skill-advisor',\n15:   'system-code-graph',\n16:   'tests',\n17:   'database',\n18: ];\n19: const requiredArtifacts = [\n20:   'context-server.js',\n21:   'api/index.js',\n22:   'hooks/codex/session-start.js',\n23: ];\n24: const cliSourceFiles = [\n25:   'spec-memory-cli.ts',\n26:   'tool-schemas.ts',\n27:   'schemas/tool-input-schemas.ts',\n28: ];\n29: const cliSourceHashState = path.join(distDir, '.spec-memory-cli-source-hash.json');\n30: \n31: function copyJsonFiles(sourceDir, targetDir) {\n32:   if (!fs.existsSync(sourceDir)) {\n33:     return;\n34:   }\n35: \n36:   fs.mkdirSync(targetDir, { recursive: true });\n37:   for (const entry of fs.readdirSync(sourceDir, { withFileTypes: true })) {\n38:     const sourcePath = path.join(sourceDir, entry.name);\n39:     const targetPath = path.join(targetDir, entry.name);\n40:     if (entry.isDirectory()) {\n41:       copyJsonFiles(sourcePath, targetPath);\n42:     } else if (entry.isFile() && entry.name.endsWith('.json')) {\n43:       fs.copyFileSync(sourcePath, targetPath);\n44:     }\n45:   }\n46: }\n47: \n48: function removeStaleDistRoots() {\n49:   for (const root of staleDistRoots) {\n50:     fs.rmSync(path.join(distDir, root), { recursive: true, force: true });\n51:   }\n52: }\n53: \n54: function assertRequiredArtifacts() {\n55:   const missing = requiredArtifacts.filter((artifact) => !fs.existsSync(path.join(distDir, artifact)));\n56:   if (missing.length > 0) {\n57:     throw new Error(`Missing expected dist artifact(s): ${missing.join(', ')}`);\n58:   }\n59: }\n60: \n61: function assertNoStaleDistRoots() {\n62:   const stale = staleDistRoots.filter((root) => fs.existsSync(path.join(distDir, root)));\n63:   if (stale.length > 0) {\n64:     throw new Error(`Stale dist root(s) still present: ${stale.join(', ')}`);\n65:   }\n66: }\n67: \n68: function writeCliSourceHash() {\n69:   const existingSources = cliSourceFiles\n70:     .map((filePath) => path.join(serverDir, filePath))\n71:     .filter((filePath) => fs.existsSync(filePath));\n72:   if (existingSources.length === 0) return;\n73: \n74:   const hash = crypto.createHash('sha256');\n75:   for (const filePath of existingSources.sort()) {\n76:     hash.update(path.relative(serverDir, filePath));\n77:     hash.update('\\0');\n78:     hash.update(fs.readFileSync(filePath));\n79:     hash.update('\\0');\n80:   }\n81:   fs.writeFileSync(cliSourceHashState, `${JSON.stringify({ version: 1, sourceHash: hash.digest('hex') })}\\n`);\n82: }\n83: \n84: copyJsonFiles(path.join(serverDir, 'lib', 'eval', 'data'), path.join(distDir, 'lib', 'eval', 'data'));\n85: copyJsonFiles(path.join(serverDir, 'lib', 'routing'), path.join(distDir, 'lib', 'routing'));\n86: \n87: removeStaleDistRoots();\n88: assertRequiredArtifacts();\n89: assertNoStaleDistRoots();\n90: writeCliSourceHash();\n\n(End of file - total 90 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Finalize Dist                                                           ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport crypto from 'node:crypto';\nimport { fileURLToPath } from 'node:url';\n\nconst serverDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');\nconst distDir = path.join(serverDir, 'dist');\nconst staleDistRoots = [\n  'system-spec-kit',\n  'system-skill-advisor',\n  'system-code-graph',\n  'tests',\n  'database',\n];\nconst requiredArtifacts = [\n  'context-server.js',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Finalize Dist                                                           ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport crypto from 'node:crypto';\nimport { fileURLToPath } from 'node:url';\n\nconst serverDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');\nconst distDir = path.join(serverDir, 'dist');\nconst staleDistRoots = [\n  'system-spec-kit',\n  'system-skill-advisor',\n  'system-code-graph',\n  'tests',\n  'database',\n];\nconst requiredArtifacts = [\n  'context-server.js',\n  'api/index.js',\n  'hooks/codex/session-start.js',\n];\nconst cliSourceFiles = [\n  'spec-memory-cli.ts',\n  'tool-schemas.ts',\n  'schemas/tool-input-schemas.ts',\n];\nconst cliSourceHashState = path.join(distDir, '.spec-memory-cli-source-hash.json');\n\nfunction copyJsonFiles(sourceDir, targetDir) {\n  if (!fs.existsSync(sourceDir)) {\n    return;\n  }\n\n  fs.mkdirSync(targetDir, { recursive: true });\n  for (const entry of fs.readdirSync(sourceDir, { withFileTypes: true })) {\n    const sourcePath = path.join(sourceDir, entry.name);\n    const targetPath = path.join(targetDir, entry.name);\n    if (entry.isDirectory()) {\n      copyJsonFiles(sourcePath, targetPath);\n    } else if (entry.isFile() && entry.name.endsWith('.json')) {\n      fs.copyFileSync(sourcePath, targetPath);\n    }\n  }\n}\n\nfunction removeStaleDistRoots() {\n  for (const root of staleDistRoots) {\n    fs.rmSync(path.join(distDir, root), { recursive: true, force: true });\n  }\n}\n\nfunction assertRequiredArtifacts() {\n  const missing = requiredArtifacts.filter((artifact) => !fs.existsSync(path.join(distDir, artifact)));\n  if (missing.length > 0) {\n    throw new Error(`Missing expected dist artifact(s): ${missing.join(', ')}`);\n  }\n}\n\nfunction assertNoStaleDistRoots() {\n  const stale = staleDistRoots.filter((root) => fs.existsSync(path.join(distDir, root)));\n  if (stale.length > 0) {\n    throw new Error(`Stale dist root(s) still present: ${stale.join(', ')}`);\n  }\n}\n\nfunction writeCliSourceHash() {\n  const existingSources = cliSourceFiles\n    .map((filePath) => path.join(serverDir, filePath))\n    .filter((filePath) => fs.existsSync(filePath));\n  if (existingSources.length === 0) return;\n\n  const hash = crypto.createHash('sha256');\n  for (const filePath of existingSources.sort()) {\n    hash.update(path.relative(serverDir, filePath));\n    hash.update('\\0');\n    hash.update(fs.readFileSync(filePath));\n    hash.update('\\0');\n  }\n  fs.writeFileSync(cliSourceHashState, `${JSON.stringify({ version: 1, sourceHash: hash.digest('hex') })}\\n`);\n}\n\ncopyJsonFiles(path.join(serverDir, 'lib', 'eval', 'data'), path.join(distDir, 'lib', 'eval', 'data'));\ncopyJsonFiles(path.join(serverDir, 'lib', 'routing'), path.join(distDir, 'lib', 'routing'));\n\nremoveStaleDistRoots();\nassertRequiredArtifacts();\nassertNoStaleDistRoots();\nwriteCliSourceHash();","lineStart":1,"lineEnd":90,"totalLines":90,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs","time":{"start":1781145032813,"end":1781145032821}},"metadata":{"openai":{"itemId":"fc_0161bc09e9317985016a2a1dc886748191a998e2c66f11c75b"}},"id":"prt_eb4845759001m3XeDOmR2aV18P","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb484136b0017neToIjKV6zugr"}}
