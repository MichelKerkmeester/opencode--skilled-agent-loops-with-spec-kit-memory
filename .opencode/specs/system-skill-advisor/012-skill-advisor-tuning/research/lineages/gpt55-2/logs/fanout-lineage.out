\"interface design\",\n109:         \"frontend design\",\n110:         \"visual design\",\n111:         \"visual identity\",\n112:         \"make it look good\",\n113:         \"looks templated\",\n114:         \"redesign the ui\",\n115:         \"hero section\",\n116:         \"landing page direction\",\n117:         \"hero redesign\",\n118:         \"ui build\",\n119:         \"design variations\",\n120:         \"less generic\",\n121:         \"custom not templated\",\n122:         \"visual direction\",\n123:         \"bolder\",\n124:         \"quieter\",\n125:         \"distill\",\n126:         \"clarify\",\n127:         \"delight\"\n128:       ]\n129:     },\n130:     \"interface-taste\": {\n131:       \"keywords\": [\n132:         \"interface-design\",\n133:         \"frontend-design\",\n134:         \"visual-design\",\n135:         \"visual-identity\",\n136:         \"make-it-look-good\",\n137:         \"looks-templated\",\n138:         \"distinctive-interface\",\n139:         \"intentional-design\",\n140:         \"polished-ui\",\n141:         \"refined-ui\",\n142:         \"custom-not-templated\",\n143:         \"premium-ui\",\n144:         \"aesthetic\",\n145:         \"design-taste\",\n146:         \"visual-direction\",\n147:         \"craft\",\n148:         \"make-it-beautiful\",\n149:         \"less-generic\",\n150:         \"redesign-distinctive\",\n151:         \"custom not templated\",\n152:         \"premium ui\",\n153:         \"make it beautiful\",\n154:         \"less generic\",\n155:         \"visual direction\"\n156:       ]\n157:     },\n158:     \"interface-build\": {\n159:       \"keywords\": [\n160:         \"redesign-the-ui\",\n161:         \"hero-section\",\n162:         \"ui-build\",\n163:         \"ux-quality-checklist\",\n164:         \"design-variations\",\n165:         \"redesign the hero\"\n166:       ]\n167:     },\n168:     \"foundations-aliases\": {\n169:       \"keywords\": [\n170:         \"foundations\",\n171:         \"design