{"type":"tool_use","timestamp":1781762474976,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_x6QBq93jFPg39jry8Z4NMrps","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","offset":421,"limit":460},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs</path>\n<type>file</type>\n<content>\n421:     // The backpressure 'drain' wait was bound to this now-discarded socket and its\n422:     // handler short-circuits once the socket is swapped, so it can never reset the\n423:     // flag. Clear it here (and drop the listener) or the next socket's pump stays\n424:     // blocked forever — a silent hang when backpressure coincides with a recycle.\n425:     socketDrainWaiting = false;\n426:     oldSocket.removeAllListeners?.('data');\n427:     oldSocket.removeAllListeners?.('error');\n428:     oldSocket.removeAllListeners?.('close');\n429:     oldSocket.removeAllListeners?.('drain');\n430:     if (destroy) oldSocket.destroy?.();\n431:   }\n432: \n433:   function finishIfClientEndedAndIdle() {\n434:     if (!clientEnded || stopped) return;\n435:     if (queuedClientFrames.length > 0 || socketWriteQueue.length > 0 || tracker.pendingRequests.size > 0) return;\n436:     requestOutputEnd();\n437:   }\n438: \n439:   function halfCloseSocketIfReady() {\n440:     if (!clientEnded || !socket || state !== 'CONNECTED' || socketHalfClosed) return;\n441:     if (socketDrainWaiting || socketWriteQueue.length > 0) return;\n442:     socketHalfClosed = true;\n443:     socket.end?.();\n444:     finishIfClientEndedAndIdle();\n445:   }\n446: \n447:   function stop() {\n448:     if (stopped) return;\n449:     stopped = true;\n450:     input.off?.('data', onInputData);\n451:     input.off?.('end', onInputEnd);\n452:     input.off?.('close', onInputClose);\n453:     output.off?.('error', onOutputError);\n454:     detachSocket(true);\n455:   }\n456: \n457:   function pumpOutputQueue() {\n458:     if (outputDrainWaiting) return;\n459:     while (outputWriteQueue.length > 0) {\n460:       const frame = outputWriteQueue[0];\n461:       const accepted = writeFrame(output, frame);\n462:       outputWriteQueue.shift();\n463:       if (!accepted) {\n464:         outputDrainWaiting = true;\n465:         socket?.pause?.();\n466:         output.once?.('drain', () => {\n467:           outputDrainWaiting = false;\n468:           socket?.resume?.();\n469:           pumpOutputQueue();\n470:         });\n471:         return;\n472:       }\n473:     }\n474:     if (outputEndRequested) {\n475:       output.end?.();\n476:       stop();\n477:     }\n478:   }\n479: \n480:   function enqueueOutputFrame(frame) {\n481:     outputWriteQueue.push(frame);\n482:     pumpOutputQueue();\n483:   }\n484: \n485:   function requestOutputEnd() {\n486:     outputEndRequested = true;\n487:     pumpOutputQueue();\n488:   }\n489: \n490:   function failPendingAndEndWith(makeErrorFrame) {\n491:     const failedIds = new Set();\n492:     for (const id of tracker.pendingRequests.keys()) {\n493:       failedIds.add(JSON.stringify(id));\n494:       enqueueOutputFrame(makeErrorFrame(id));\n495:     }\n496:     tracker.pendingRequests.clear();\n497:     while (queuedClientFrames.length > 0) {\n498:       const frame = queuedClientFrames.shift();\n499:       const parsed = parseFrame(frame);\n500:       if (!hasRequestId(parsed)) continue;\n501:       const key = JSON.stringify(parsed.id);\n502:       if (failedIds.has(key)) continue;\n503:       failedIds.add(key);\n504:       enqueueOutputFrame(makeErrorFrame(parsed.id));\n505:     }\n506:     requestOutputEnd();\n507:   }\n508: \n509:   function failPendingAndEnd() {\n510:     failPendingAndEndWith(retryableErrorFrame);\n511:   }\n512: \n513:   function failPendingAndEndProtocolMismatch() {\n514:     failPendingAndEndWith(protocolMismatchErrorFrame);\n515:   }\n516: \n517:   function failOldestQueuedClientFrame() {\n518:     while (queuedClientFrames.length > maxQueuedClientFrames) {\n519:       const frame = queuedClientFrames.shift();\n520:       const parsed = parseFrame(frame);\n521:       if (hasRequestId(parsed)) {\n522:         enqueueOutputFrame(retryableErrorFrame(parsed.id));\n523:         tracker.pendingRequests.delete(parsed.id);\n524:       }\n525:     }\n526:   }\n527: \n528:   function queueClientFrame(frame) {\n529:     queuedClientFrames.push(frame);\n530:     failOldestQueuedClientFrame();\n531:   }\n532: \n533:   function pumpSocketQueue() {\n534:     if (!socket || state !== 'CONNECTED' || socketDrainWaiting) return;\n535:     while (socketWriteQueue.length > 0 && socket && state === 'CONNECTED') {\n536:       const activeSocket = socket;\n537:       const frame = socketWriteQueue[0];\n538:       const accepted = writeFrame(activeSocket, frame);\n539:       socketWriteQueue.shift();\n540:       if (!accepted) {\n541:         socketDrainWaiting = true;\n542:         pauseClientInput();\n543:         activeSocket.once?.('drain', () => {\n544:           if (activeSocket !== socket) return;\n545:           socketDrainWaiting = false;\n546:           resumeClientInputIfReady();\n547:           pumpSocketQueue();\n548:         });\n549:         return;\n550:       }\n551:     }\n552:     halfCloseSocketIfReady();\n553:     resumeClientInputIfReady();\n554:   }\n555: \n556:   function enqueueSocketFrame(frame) {\n557:     socketWriteQueue.push(frame);\n558:     pumpSocketQueue();\n559:   }\n560: \n561:   function sendKeepalive() {\n562:     if (!socket || state !== 'CONNECTED' || pendingKeepaliveId !== null) return;\n563:     if (Date.now() - lastBackendActivity < keepaliveIntervalMs) return;\n564:     pendingKeepaliveId = `${PROXY_PRIVATE_ID_PREFIX}${keepaliveId += 1}`;\n565:     enqueueSocketFrame(JSON.stringify({ jsonrpc: '2.0', id: pendingKeepaliveId, method: 'ping' }));\n566:     keepaliveTimer = setTimeout(() => {\n567:       keepaliveTimer = null;\n568:       if (pendingKeepaliveId === null) return;\n569:       pendingKeepaliveId = null;\n570:       handleBackendFailure('keepalive-timeout');\n571:     }, keepaliveTimeoutMs);\n572:     keepaliveTimer.unref?.();\n573:   }\n574: \n575:   function startKeepalive() {\n576:     stopKeepalive();\n577:     lastBackendActivity = Date.now();\n578:     keepaliveInterval = setInterval(sendKeepalive, keepaliveIntervalMs);\n579:     keepaliveInterval.unref?.();\n580:   }\n581: \n582:   function forwardClientFrame(frame) {\n583:     tracker.handleClientFrame(frame);\n584:     if (!socket || state !== 'CONNECTED') {\n585:       queueClientFrame(frame);\n586:       return;\n587:     }\n588:     enqueueSocketFrame(frame);\n589:   }\n590: \n591:   function flushQueuedClientFrames() {\n592:     while (queuedClientFrames.length > 0 && socket && state === 'CONNECTED') {\n593:       forwardClientFrame(queuedClientFrames.shift());\n594:     }\n595:   }\n596: \n597:   function handleClientFrame(frame) {\n598:     const parsedClient = parseFrame(frame);\n599:     if (parsedClient\n600:         && parsedClient.method !== undefined\n601:         && typeof parsedClient.id === 'string'\n602:         && parsedClient.id.startsWith(PROXY_PRIVATE_ID_PREFIX)) {\n603:       // This id prefix is reserved for the proxy's private keepalive pings. A\n604:       // client request carrying a colliding id would have its backend response\n605:       // silently swallowed by the keepalive interceptor in handleBackendFrame,\n606:       // hanging the request. Reject the reserved id rather than forward it.\n607:       enqueueOutputFrame(JSON.stringify({\n608:         jsonrpc: '2.0',\n609:         id: parsedClient.id,\n610:         error: { code: -32600, message: 'Request id uses a reserved prefix' },\n611:       }));\n612:       return;\n613:     }\n614:     if (state !== 'CONNECTED' || !socket) {\n615:       queueClientFrame(frame);\n616:       return;\n617:     }\n618:     forwardClientFrame(frame);\n619:   }\n620: \n621:   function handleBackendFrame(frame) {\n622:     lastBackendActivity = Date.now();\n623:     const parsed = parseFrame(frame);\n624:     if (pendingKeepaliveId !== null && isResponseFrame(parsed) && parsed.id === pendingKeepaliveId) {\n625:       pendingKeepaliveId = null;\n626:       if (keepaliveTimer !== null) {\n627:         clearTimeout(keepaliveTimer);\n628:         keepaliveTimer = null;\n629:       }\n630:       return;\n631:     }\n632:     const cachedInitializeId = tracker.getCachedInitializeId();\n633:     if (!tracker.hasObservedProtocolVersion()\n634:         && cachedInitializeId !== null\n635:         && isResponseFrame(parsed)\n636:         && parsed.id === cachedInitializeId) {\n637:       // Record the protocol version negotiated on the first initialize so an internal\n638:       // re-handshake to a swapped backend can fail closed on a version change rather\n639:       // than silently serve the client a protocol it never negotiated.\n640:       tracker.recordNegotiatedProtocolVersion(\n641:         parsed.result && typeof parsed.result === 'object' ? parsed.result.protocolVersion : undefined,\n642:       );\n643:     }\n644:     tracker.handleBackendFrame(frame);\n645:     enqueueOutputFrame(frame);\n646:     finishIfClientEndedAndIdle();\n647:   }\n648: \n649:   function replaySnapshot(snapshot) {\n650:     const cachedInitializeId = tracker.getCachedInitializeId();\n651:     for (const [id, entry] of snapshot) {\n652:       if (!tracker.pendingRequests.has(id)) continue;\n653:       // internalHandshake already re-sent (and consumed the reply for) the cached\n654:       // initialize on the fresh socket. Replaying it here too would deliver a second\n655:       // initialize to the backend, so the handshake path owns the initialize replay.\n656:       if (cachedInitializeId !== null && id === cachedInitializeId) continue;\n657:       if (entry.replayable) {\n658:         enqueueSocketFrame(entry.frame);\n659:         continue;\n660:       }\n661:       enqueueOutputFrame(retryableErrorFrame(id));\n662:       tracker.pendingRequests.delete(id);\n663:     }\n664:   }\n665: \n666:   async function attachFreshSocket({ replaySnapshotEntries = [] } = {}) {\n667:     const freshSocket = await connectSocket(connect, socketPath);\n668:     let handshake;\n669:     try {\n670:       handshake = await internalHandshake(freshSocket, tracker.getCachedInitialize());\n671:     } catch (error) {\n672:       freshSocket.destroy?.();\n673:       throw error;\n674:     }\n675:     const expectedProtocolVersion = tracker.getNegotiatedProtocolVersion();\n676:     if (handshake.handshakeObserved\n677:         && expectedProtocolVersion !== null\n678:         && (handshake.protocolVersion ?? null) !== expectedProtocolVersion) {\n679:       // A backend build swap can re-handshake with a different negotiated protocol\n680:       // version. Serving it would silently break the client's protocol contract, so\n681:       // end the session with a non-retryable error instead of attaching the socket.\n682:       // CLOSED is terminal: the reattach loop must not retry a version-mismatched backend.\n683:       log(`backend protocol version drift: expected ${expectedProtocolVersion}, got ${handshake.protocolVersion ?? 'none'}; failing closed`);\n684:       freshSocket.destroy?.();\n685:       state = 'CLOSED';\n686:       failPendingAndEndProtocolMismatch();\n687:       return;\n688:     }\n689:     socket = freshSocket;\n690:     socketHalfClosed = false;\n691:     backendSplitter = createFrameSplitter(handleBackendFrame);\n692:     if (handshake.residual.length > 0) backendSplitter.push(handshake.residual);\n693:     socket.on('data', (chunk) => backendSplitter.push(chunk));\n694:     socket.once('error', (error) => {\n695:       log(`socket proxy error: ${error instanceof Error ? error.message : String(error)}`);\n696:       handleBackendFailure('error');\n697:     });\n698:     socket.once('close', () => {\n699:       handleBackendFailure('close');\n700:     });\n701:     state = 'CONNECTED';\n702:     startKeepalive();\n703:     // The fresh backend may have died after receiving the client's initialize but before\n704:     // answering it on the old socket, leaving initialize pending. internalHandshake just\n705:     // re-sent and answered it; forward that single answer to the client and clear it from\n706:     // pending so replaySnapshot does not send a duplicate initialize to the backend.\n707:     const cachedInitializeId = tracker.getCachedInitializeId();\n708:     if (handshake.handshakeObserved\n709:         && handshake.initializeResponse\n710:         && cachedInitializeId !== null\n711:         && tracker.pendingRequests.has(cachedInitializeId)) {\n712:       tracker.pendingRequests.delete(cachedInitializeId);\n713:       enqueueOutputFrame(handshake.initializeResponse);\n714:     }\n715:     replaySnapshot(replaySnapshotEntries);\n716:     flushQueuedClientFrames();\n717:     pumpSocketQueue();\n718:     if (clientEnded) {\n719:       halfCloseSocketIfReady();\n720:       return;\n721:     }\n722:     resumeClientInputIfReady();\n723:   }\n724: \n725:   async function reattach() {\n726:     for (let attempt = 0; attempt < maxReattachAttempts && !stopped; attempt += 1) {\n727:       const ready = await waitForDaemonReady(socketPath, probe, connect, log, { maxAttempts: 1 });\n728:       if (ready.status === 'alive') {\n729:         try {\n730:           const snapshot = Array.from(tracker.pendingRequests.entries());\n731:           await attachFreshSocket({ replaySnapshotEntries: snapshot });\n732:           if (state === 'CONNECTED' || state === 'CLOSED' || stopped) return;\n733:           log('reattach observed nested backend failure; retrying');\n734:           continue;\n735:         } catch (error) {\n736:           if (state === 'REATTACHING') {\n737:             log(`reattach attach interrupted: ${error instanceof Error ? error.message : String(error)}`);\n738:             continue;\n739:           }\n740:           log(`reattach handshake failed: ${error instanceof Error ? error.message : String(error)}`);\n741:         }\n742:       }\n743:       const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n744:       await sleep(delayMs);\n745:     }\n746:     if (!stopped) {\n747:       // Mark the session terminal at give-up. failPendingAndEnd defers stop() under output\n748:       // backpressure, so leaving state='REATTACHING' would let the ensureReattachRunning\n749:       // guard restart a fresh 40-attempt loop. CLOSED is terminal and blocks that restart.\n750:       state = 'CLOSED';\n751:       failPendingAndEnd();\n752:     }\n753:   }\n754: \n755:   function ensureReattachRunning(reason) {\n756:     if (reattachRunning || stopped || clientEnded) return;\n757:     reattachRunning = true;\n758:     reattach()\n759:       .catch((error) => {\n760:         log(`reattach failed: ${error instanceof Error ? error.message : String(error)}`);\n761:         if (!stopped) failPendingAndEnd();\n762:       })\n763:       .finally(() => {\n764:         reattachRunning = false;\n765:         if (!stopped && state === 'REATTACHING' && !clientEnded) {\n766:           log('reattach loop guard restarting');\n767:           ensureReattachRunning('guard');\n768:         }\n769:       });\n770:     log(`backend socket ${reason}; reattaching`);\n771:   }\n772: \n773:   function handleBackendFailure(reason) {\n774:     if (stopped) return;\n775:     if (state === 'REATTACHING') {\n776:       ensureReattachRunning(reason);\n777:       return;\n778:     }\n779:     if (clientEnded) {\n780:       if (tracker.pendingRequests.size > 0) {\n781:         failPendingAndEnd();\n782:       } else {\n783:         requestOutputEnd();\n784:       }\n785:       return;\n786:     }\n787:     state = 'REATTACHING';\n788:     pauseClientInput();\n789:     backendSplitter.discard();\n790:     detachSocket(true);\n791:     ensureReattachRunning(reason);\n792:   }\n793: \n794:   function onInputData(chunk) {\n795:     clientSplitter.push(chunk);\n796:   }\n797: \n798:   function onInputEnd() {\n799:     clientEnded = true;\n800:     halfCloseSocketIfReady();\n801:     finishIfClientEndedAndIdle();\n802:   }\n803: \n804:   function onInputClose() {\n805:     clientEnded = true;\n806:     halfCloseSocketIfReady();\n807:     finishIfClientEndedAndIdle();\n808:   }\n809: \n810:   function onOutputError() {\n811:     stop();\n812:   }\n813: \n814:   async function start() {\n815:     const ready = await waitForDaemonReady(socketPath, probe, connect, log, { maxAttempts: maxColdStartAttempts });\n816:     if (stopped) return;\n817:     if (ready.status !== 'alive') {\n818:       enqueueOutputFrame(JSON.stringify({\n819:         jsonrpc: '2.0',\n820:         id: null,\n821:         error: {\n822:           code: -32001,\n823:           message: `backend unavailable: ${ready.reason ?? 'startup-timeout'}`,\n824:           data: { retryable: true },\n825:         },\n826:       }));\n827:       requestOutputEnd();\n828:       return;\n829:     }\n830: \n831:     input.on('data', onInputData);\n832:     input.once('end', onInputEnd);\n833:     input.once('close', onInputClose);\n834:     output.once('error', onOutputError);\n835: \n836:     await attachFreshSocket();\n837:   }\n838: \n839:   return { start, stop };\n840: }\n841: \n842: module.exports = {\n843:   createClassifyFrame,\n844:   createSessionProxy,\n845:   __testing: {\n846:     classifyFrame,\n847:     createClassifyFrame,\n848:     createFrameSplitter,\n849:     createPendingRequestsTracker,\n850:     parseFrame,\n851:     resolveColdStartAttempts,\n852:   },\n853: };\n\n(End of file - total 853 lines)\n</content>","metadata":{"preview":"    // The backpressure 'drain' wait was bound to this now-discarded socket and its\n    // handler short-circuits once the socket is swapped, so it can never reset the\n    // flag. Clear it here (and drop the listener) or the next socket's pump stays\n    // blocked forever — a silent hang when backpressure coincides with a recycle.\n    socketDrainWaiting = false;\n    oldSocket.removeAllListeners?.('data');\n    oldSocket.removeAllListeners?.('error');\n    oldSocket.removeAllListeners?.('close');\n    oldSocket.removeAllListeners?.('drain');\n    if (destroy) oldSocket.destroy?.();\n  }\n\n  function finishIfClientEndedAndIdle() {\n    if (!clientEnded || stopped) return;\n    if (queuedClientFrames.length > 0 || socketWriteQueue.length > 0 || tracker.pendingRequests.size > 0) return;\n    requestOutputEnd();\n  }\n\n  function halfCloseSocketIfReady() {\n    if (!clientEnded || !socket || state !== 'CONNECTED' || socketHalfClosed) return;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","text":"    // The backpressure 'drain' wait was bound to this now-discarded socket and its\n    // handler short-circuits once the socket is swapped, so it can never reset the\n    // flag. Clear it here (and drop the listener) or the next socket's pump stays\n    // blocked forever — a silent hang when backpressure coincides with a recycle.\n    socketDrainWaiting = false;\n    oldSocket.removeAllListeners?.('data');\n    oldSocket.removeAllListeners?.('error');\n    oldSocket.removeAllListeners?.('close');\n    oldSocket.removeAllListeners?.('drain');\n    if (destroy) oldSocket.destroy?.();\n  }\n\n  function finishIfClientEndedAndIdle() {\n    if (!clientEnded || stopped) return;\n    if (queuedClientFrames.length > 0 || socketWriteQueue.length > 0 || tracker.pendingRequests.size > 0) return;\n    requestOutputEnd();\n  }\n\n  function halfCloseSocketIfReady() {\n    if (!clientEnded || !socket || state !== 'CONNECTED' || socketHalfClosed) return;\n    if (socketDrainWaiting || socketWriteQueue.length > 0) return;\n    socketHalfClosed = true;\n    socket.end?.();\n    finishIfClientEndedAndIdle();\n  }\n\n  function stop() {\n    if (stopped) return;\n    stopped = true;\n    input.off?.('data', onInputData);\n    input.off?.('end', onInputEnd);\n    input.off?.('close', onInputClose);\n    output.off?.('error', onOutputError);\n    detachSocket(true);\n  }\n\n  function pumpOutputQueue() {\n    if (outputDrainWaiting) return;\n    while (outputWriteQueue.length > 0) {\n      const frame = outputWriteQueue[0];\n      const accepted = writeFrame(output, frame);\n      outputWriteQueue.shift();\n      if (!accepted) {\n        outputDrainWaiting = true;\n        socket?.pause?.();\n        output.once?.('drain', () => {\n          outputDrainWaiting = false;\n          socket?.resume?.();\n          pumpOutputQueue();\n        });\n        return;\n      }\n    }\n    if (outputEndRequested) {\n      output.end?.();\n      stop();\n    }\n  }\n\n  function enqueueOutputFrame(frame) {\n    outputWriteQueue.push(frame);\n    pumpOutputQueue();\n  }\n\n  function requestOutputEnd() {\n    outputEndRequested = true;\n    pumpOutputQueue();\n  }\n\n  function failPendingAndEndWith(makeErrorFrame) {\n    const failedIds = new Set();\n    for (const id of tracker.pendingRequests.keys()) {\n      failedIds.add(JSON.stringify(id));\n      enqueueOutputFrame(makeErrorFrame(id));\n    }\n    tracker.pendingRequests.clear();\n    while (queuedClientFrames.length > 0) {\n      const frame = queuedClientFrames.shift();\n      const parsed = parseFrame(frame);\n      if (!hasRequestId(parsed)) continue;\n      const key = JSON.stringify(parsed.id);\n      if (failedIds.has(key)) continue;\n      failedIds.add(key);\n      enqueueOutputFrame(makeErrorFrame(parsed.id));\n    }\n    requestOutputEnd();\n  }\n\n  function failPendingAndEnd() {\n    failPendingAndEndWith(retryableErrorFrame);\n  }\n\n  function failPendingAndEndProtocolMismatch() {\n    failPendingAndEndWith(protocolMismatchErrorFrame);\n  }\n\n  function failOldestQueuedClientFrame() {\n    while (queuedClientFrames.length > maxQueuedClientFrames) {\n      const frame = queuedClientFrames.shift();\n      const parsed = parseFrame(frame);\n      if (hasRequestId(parsed)) {\n        enqueueOutputFrame(retryableErrorFrame(parsed.id));\n        tracker.pendingRequests.delete(parsed.id);\n      }\n    }\n  }\n\n  function queueClientFrame(frame) {\n    queuedClientFrames.push(frame);\n    failOldestQueuedClientFrame();\n  }\n\n  function pumpSocketQueue() {\n    if (!socket || state !== 'CONNECTED' || socketDrainWaiting) return;\n    while (socketWriteQueue.length > 0 && socket && state === 'CONNECTED') {\n      const activeSocket = socket;\n      const frame = socketWriteQueue[0];\n      const accepted = writeFrame(activeSocket, frame);\n      socketWriteQueue.shift();\n      if (!accepted) {\n        socketDrainWaiting = true;\n        pauseClientInput();\n        activeSocket.once?.('drain', () => {\n          if (activeSocket !== socket) return;\n          socketDrainWaiting = false;\n          resumeClientInputIfReady();\n          pumpSocketQueue();\n        });\n        return;\n      }\n    }\n    halfCloseSocketIfReady();\n    resumeClientInputIfReady();\n  }\n\n  function enqueueSocketFrame(frame) {\n    socketWriteQueue.push(frame);\n    pumpSocketQueue();\n  }\n\n  function sendKeepalive() {\n    if (!socket || state !== 'CONNECTED' || pendingKeepaliveId !== null) return;\n    if (Date.now() - lastBackendActivity < keepaliveIntervalMs) return;\n    pendingKeepaliveId = `${PROXY_PRIVATE_ID_PREFIX}${keepaliveId += 1}`;\n    enqueueSocketFrame(JSON.stringify({ jsonrpc: '2.0', id: pendingKeepaliveId, method: 'ping' }));\n    keepaliveTimer = setTimeout(() => {\n      keepaliveTimer = null;\n      if (pendingKeepaliveId === null) return;\n      pendingKeepaliveId = null;\n      handleBackendFailure('keepalive-timeout');\n    }, keepaliveTimeoutMs);\n    keepaliveTimer.unref?.();\n  }\n\n  function startKeepalive() {\n    stopKeepalive();\n    lastBackendActivity = Date.now();\n    keepaliveInterval = setInterval(sendKeepalive, keepaliveIntervalMs);\n    keepaliveInterval.unref?.();\n  }\n\n  function forwardClientFrame(frame) {\n    tracker.handleClientFrame(frame);\n    if (!socket || state !== 'CONNECTED') {\n      queueClientFrame(frame);\n      return;\n    }\n    enqueueSocketFrame(frame);\n  }\n\n  function flushQueuedClientFrames() {\n    while (queuedClientFrames.length > 0 && socket && state === 'CONNECTED') {\n      forwardClientFrame(queuedClientFrames.shift());\n    }\n  }\n\n  function handleClientFrame(frame) {\n    const parsedClient = parseFrame(frame);\n    if (parsedClient\n        && parsedClient.method !== undefined\n        && typeof parsedClient.id === 'string'\n        && parsedClient.id.startsWith(PROXY_PRIVATE_ID_PREFIX)) {\n      // This id prefix is reserved for the proxy's private keepalive pings. A\n      // client request carrying a colliding id would have its backend response\n      // silently swallowed by the keepalive interceptor in handleBackendFrame,\n      // hanging the request. Reject the reserved id rather than forward it.\n      enqueueOutputFrame(JSON.stringify({\n        jsonrpc: '2.0',\n        id: parsedClient.id,\n        error: { code: -32600, message: 'Request id uses a reserved prefix' },\n      }));\n      return;\n    }\n    if (state !== 'CONNECTED' || !socket) {\n      queueClientFrame(frame);\n      return;\n    }\n    forwardClientFrame(frame);\n  }\n\n  function handleBackendFrame(frame) {\n    lastBackendActivity = Date.now();\n    const parsed = parseFrame(frame);\n    if (pendingKeepaliveId !== null && isResponseFrame(parsed) && parsed.id === pendingKeepaliveId) {\n      pendingKeepaliveId = null;\n      if (keepaliveTimer !== null) {\n        clearTimeout(keepaliveTimer);\n        keepaliveTimer = null;\n      }\n      return;\n    }\n    const cachedInitializeId = tracker.getCachedInitializeId();\n    if (!tracker.hasObservedProtocolVersion()\n        && cachedInitializeId !== null\n        && isResponseFrame(parsed)\n        && parsed.id === cachedInitializeId) {\n      // Record the protocol version negotiated on the first initialize so an internal\n      // re-handshake to a swapped backend can fail closed on a version change rather\n      // than silently serve the client a protocol it never negotiated.\n      tracker.recordNegotiatedProtocolVersion(\n        parsed.result && typeof parsed.result === 'object' ? parsed.result.protocolVersion : undefined,\n      );\n    }\n    tracker.handleBackendFrame(frame);\n    enqueueOutputFrame(frame);\n    finishIfClientEndedAndIdle();\n  }\n\n  function replaySnapshot(snapshot) {\n    const cachedInitializeId = tracker.getCachedInitializeId();\n    for (const [id, entry] of snapshot) {\n      if (!tracker.pendingRequests.has(id)) continue;\n      // internalHandshake already re-sent (and consumed the reply for) the cached\n      // initialize on the fresh socket. Replaying it here too would deliver a second\n      // initialize to the backend, so the handshake path owns the initialize replay.\n      if (cachedInitializeId !== null && id === cachedInitializeId) continue;\n      if (entry.replayable) {\n        enqueueSocketFrame(entry.frame);\n        continue;\n      }\n      enqueueOutputFrame(retryableErrorFrame(id));\n      tracker.pendingRequests.delete(id);\n    }\n  }\n\n  async function attachFreshSocket({ replaySnapshotEntries = [] } = {}) {\n    const freshSocket = await connectSocket(connect, socketPath);\n    let handshake;\n    try {\n      handshake = await internalHandshake(freshSocket, tracker.getCachedInitialize());\n    } catch (error) {\n      freshSocket.destroy?.();\n      throw error;\n    }\n    const expectedProtocolVersion = tracker.getNegotiatedProtocolVersion();\n    if (handshake.handshakeObserved\n        && expectedProtocolVersion !== null\n        && (handshake.protocolVersion ?? null) !== expectedProtocolVersion) {\n      // A backend build swap can re-handshake with a different negotiated protocol\n      // version. Serving it would silently break the client's protocol contract, so\n      // end the session with a non-retryable error instead of attaching the socket.\n      // CLOSED is terminal: the reattach loop must not retry a version-mismatched backend.\n      log(`backend protocol version drift: expected ${expectedProtocolVersion}, got ${handshake.protocolVersion ?? 'none'}; failing closed`);\n      freshSocket.destroy?.();\n      state = 'CLOSED';\n      failPendingAndEndProtocolMismatch();\n      return;\n    }\n    socket = freshSocket;\n    socketHalfClosed = false;\n    backendSplitter = createFrameSplitter(handleBackendFrame);\n    if (handshake.residual.length > 0) backendSplitter.push(handshake.residual);\n    socket.on('data', (chunk) => backendSplitter.push(chunk));\n    socket.once('error', (error) => {\n      log(`socket proxy error: ${error instanceof Error ? error.message : String(error)}`);\n      handleBackendFailure('error');\n    });\n    socket.once('close', () => {\n      handleBackendFailure('close');\n    });\n    state = 'CONNECTED';\n    startKeepalive();\n    // The fresh backend may have died after receiving the client's initialize but before\n    // answering it on the old socket, leaving initialize pending. internalHandshake just\n    // re-sent and answered it; forward that single answer to the client and clear it from\n    // pending so replaySnapshot does not send a duplicate initialize to the backend.\n    const cachedInitializeId = tracker.getCachedInitializeId();\n    if (handshake.handshakeObserved\n        && handshake.initializeResponse\n        && cachedInitializeId !== null\n        && tracker.pendingRequests.has(cachedInitializeId)) {\n      tracker.pendingRequests.delete(cachedInitializeId);\n      enqueueOutputFrame(handshake.initializeResponse);\n    }\n    replaySnapshot(replaySnapshotEntries);\n    flushQueuedClientFrames();\n    pumpSocketQueue();\n    if (clientEnded) {\n      halfCloseSocketIfReady();\n      return;\n    }\n    resumeClientInputIfReady();\n  }\n\n  async function reattach() {\n    for (let attempt = 0; attempt < maxReattachAttempts && !stopped; attempt += 1) {\n      const ready = await waitForDaemonReady(socketPath, probe, connect, log, { maxAttempts: 1 });\n      if (ready.status === 'alive') {\n        try {\n          const snapshot = Array.from(tracker.pendingRequests.entries());\n          await attachFreshSocket({ replaySnapshotEntries: snapshot });\n          if (state === 'CONNECTED' || state === 'CLOSED' || stopped) return;\n          log('reattach observed nested backend failure; retrying');\n          continue;\n        } catch (error) {\n          if (state === 'REATTACHING') {\n            log(`reattach attach interrupted: ${error instanceof Error ? error.message : String(error)}`);\n            continue;\n          }\n          log(`reattach handshake failed: ${error instanceof Error ? error.message : String(error)}`);\n        }\n      }\n      const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n      await sleep(delayMs);\n    }\n    if (!stopped) {\n      // Mark the session terminal at give-up. failPendingAndEnd defers stop() under output\n      // backpressure, so leaving state='REATTACHING' would let the ensureReattachRunning\n      // guard restart a fresh 40-attempt loop. CLOSED is terminal and blocks that restart.\n      state = 'CLOSED';\n      failPendingAndEnd();\n    }\n  }\n\n  function ensureReattachRunning(reason) {\n    if (reattachRunning || stopped || clientEnded) return;\n    reattachRunning = true;\n    reattach()\n      .catch((error) => {\n        log(`reattach failed: ${error instanceof Error ? error.message : String(error)}`);\n        if (!stopped) failPendingAndEnd();\n      })\n      .finally(() => {\n        reattachRunning = false;\n        if (!stopped && state === 'REATTACHING' && !clientEnded) {\n          log('reattach loop guard restarting');\n          ensureReattachRunning('guard');\n        }\n      });\n    log(`backend socket ${reason}; reattaching`);\n  }\n\n  function handleBackendFailure(reason) {\n    if (stopped) return;\n    if (state === 'REATTACHING') {\n      ensureReattachRunning(reason);\n      return;\n    }\n    if (clientEnded) {\n      if (tracker.pendingRequests.size > 0) {\n        failPendingAndEnd();\n      } else {\n        requestOutputEnd();\n      }\n      return;\n    }\n    state = 'REATTACHING';\n    pauseClientInput();\n    backendSplitter.discard();\n    detachSocket(true);\n    ensureReattachRunning(reason);\n  }\n\n  function onInputData(chunk) {\n    clientSplitter.push(chunk);\n  }\n\n  function onInputEnd() {\n    clientEnded = true;\n    halfCloseSocketIfReady();\n    finishIfClientEndedAndIdle();\n  }\n\n  function onInputClose() {\n    clientEnded = true;\n    halfCloseSocketIfReady();\n    finishIfClientEndedAndIdle();\n  }\n\n  function onOutputError() {\n    stop();\n  }\n\n  async function start() {\n    const ready = await waitForDaemonReady(socketPath, probe, connect, log, { maxAttempts: maxColdStartAttempts });\n    if (stopped) return;\n    if (ready.status !== 'alive') {\n      enqueueOutputFrame(JSON.stringify({\n        jsonrpc: '2.0',\n        id: null,\n        error: {\n          code: -32001,\n          message: `backend unavailable: ${ready.reason ?? 'startup-timeout'}`,\n          data: { retryable: true },\n        },\n      }));\n      requestOutputEnd();\n      return;\n    }\n\n    input.on('data', onInputData);\n    input.once('end', onInputEnd);\n    input.once('close', onInputClose);\n    output.once('error', onOutputError);\n\n    await attachFreshSocket();\n  }\n\n  return { start, stop };\n}\n\nmodule.exports = {\n  createClassifyFrame,\n  createSessionProxy,\n  __testing: {\n    classifyFrame,\n    createClassifyFrame,\n    createFrameSplitter,\n    createPendingRequestsTracker,\n    parseFrame,\n    resolveColdStartAttempts,\n  },\n};","lineStart":421,"lineEnd":853,"totalLines":853,"truncated":false}},"title":".opencode/bin/lib/launcher-session-proxy.cjs","time":{"start":1781762474971,"end":1781762474975}},"metadata":{"openai":{"itemId":"fc_0cca643c2d3862c5016a3389aa42ec819198a5d869eecfdd56"}},"id":"prt_ed951c316001Xna7MvbugFAQKA","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed951871d0016kbaZZmtLBSEr4"}}
{"type":"tool_use","timestamp":1781762475328,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_wIXwqoLbWbCUAdOYaadQBpVY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/post-insert.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/post-insert.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Post Insert\n3: // ───────────────────────────────────────────────────────────────\n4: import type BetterSqlite3 from 'better-sqlite3';\n5: import type * as memoryParser from '../../lib/parsing/memory-parser.js';\n6: \n7: import * as embeddings from '../../lib/providers/embeddings.js';\n8: import { processCausalLinks } from '../causal-links-processor.js';\n9: import {\n10:   isAutoEntitiesEnabled,\n11:   isMemorySummariesEnabled,\n12:   isEntityLinkingEnabled,\n13:   isPostInsertEnrichmentEnabled,\n14:   type SavePlannerMode,\n15: } from '../../lib/search/search-flags.js';\n16: import {\n17:   extractEntities,\n18:   filterEntities,\n19:   refreshAutoEntitiesForMemory,\n20: } from '../../lib/extraction/entity-extractor.js';\n21: import { generateAndStoreSummary } from '../../lib/search/memory-summaries.js';\n22: import { runEntityLinkingForMemory } from '../../lib/search/entity-linker.js';\n23: import { onIndex, isGraphRefreshEnabled, type OnIndexSkipReason } from '../../lib/search/graph-lifecycle.js';\n24: import {\n25:   clearBudget,\n26:   emitRetryTelemetry,\n27:   getRetryBudgetEntry,\n28:   recordFailure,\n29:   shouldRetry,\n30: } from '../../lib/enrichment/retry-budget.js';\n31: import { assertNever } from '../../lib/utils/exhaustiveness.js';\n32: import { toErrorMessage } from '../../utils/index.js';\n33: \n34: // Feature catalog: Memory indexing (memory_save)\n35: // Feature catalog: Duplicate-save no-op feedback hardening\n36: \n37: \n38: interface CausalLinksResult {\n39:   processed: number;\n40:   inserted: number;\n41:   resolved: number;\n42:   unresolved: { type: string; reference: string }[];\n43:   errors: { type: string; reference: string; error: string }[];\n44: }\n45: \n46: // Per-step enum status refactor.\n47: // Replaces boolean-valued record that collapsed success / feature-disabled skip /\n48: // nothing-to-do skip / deferral / density-guard skip / partial failure into `true`.\n49: export type EnrichmentStepStatus = 'ran' | 'skipped' | 'failed' | 'deferred' | 'partial';\n50: \n51: export type EnrichmentSkipReason =\n52:   | 'feature_disabled'\n53:   | 'nothing_to_do'\n54:   | 'planner_first_mode'\n55:   | 'density_guard'\n56:   | 'graph_lifecycle_no_op'\n57:   | 'graph_refresh_disabled'\n58:   | 'entity_linking_disabled'\n59:   | 'empty_content'\n60:   | 'extraction_not_ran'\n61:   | 'summary_not_stored'\n62:   | 'async_background';\n63: \n64: export type EnrichmentFailureReason =\n65:   | 'causal_links_exception'\n66:   | 'entity_extraction_exception'\n67:   | 'summary_exception'\n68:   | 'entity_linking_exception'\n69:   | 'graph_lifecycle_exception'\n70:   | 'partial_causal_link_unresolved'\n71:   | 'partial_causal_link_errors';\n72: \n73: export interface EnrichmentStepResult {\n74:   status: EnrichmentStepStatus;\n75:   reason?: EnrichmentSkipReason | EnrichmentFailureReason;\n76:   warnings?: string[];\n77: }\n78: \n79: export interface EnrichmentStatus {\n80:   causalLinks: EnrichmentStepResult;\n81:   entityExtraction: EnrichmentStepResult;\n82:   summaries: EnrichmentStepResult;\n83:   entityLinking: EnrichmentStepResult;\n84:   graphLifecycle: EnrichmentStepResult;\n85: }\n86: \n87: export type EnrichmentStepName = keyof EnrichmentStatus;\n88: \n89: export type PostInsertExecutionReason =\n90:   | 'planner-first-mode'\n91:   | 'async-background'\n92:   | 'enrichment_step_failed'\n93:   | 'enrichment_step_partial';\n94: \n95: export interface PostInsertExecutionStatus {\n96:   // An exception-driven step failure must NOT be reported\n97:   // as `ran`.  When any step reports `failed`, execution status rolls up to\n98:   // `failed`; when any step reports `partial`, it rolls up to `partial`.\n99:   status: 'ran' | 'deferred' | 'failed' | 'partial';\n100:   reason?: PostInsertExecutionReason;\n101:   followUpAction?: 'runEnrichmentBackfill';\n102:   failedSteps?: Array<keyof EnrichmentStatus>;\n103:   partialSteps?: Array<keyof EnrichmentStatus>;\n104: }\n105: \n106: export interface PostInsertEnrichmentResult {\n107:   causalLinksResult: CausalLinksResult | null;\n108:   enrichmentStatus: EnrichmentStatus;\n109:   executionStatus: PostInsertExecutionStatus;\n110: }\n111: \n112: export interface PostInsertEnrichmentOptions {\n113:   plannerMode?: SavePlannerMode;\n114: }\n115: \n116: const ON_INDEX_SKIP_REASON_TO_ENRICHMENT_SKIP_REASON = {\n117:   graph_refresh_disabled: 'graph_refresh_disabled',\n118:   entity_linking_disabled: 'entity_linking_disabled',\n119:   empty_content: 'empty_content',\n120:   onindex_exception: 'graph_lifecycle_no_op',\n121: } satisfies Record<OnIndexSkipReason, EnrichmentSkipReason>;\n122: \n123: const CAUSAL_LINK_RETRY_STEP = 'causal_links';\n124: const CAUSAL_LINK_RETRY_REASON = 'partial_causal_link_unresolved';\n125: \n126: function emitCausalLinkRetryTelemetry(\n127:   memoryId: number,\n128:   attempt: number,\n129:   outcome: 'retry' | 'give_up' | 'resolved',\n130:   timestamp: string,\n131: ): void {\n132:   emitRetryTelemetry({\n133:     type: 'event',\n134:     event: 'retry_attempt',\n135:     memoryId: String(memoryId),\n136:     step: CAUSAL_LINK_RETRY_STEP,\n137:     reason: CAUSAL_LINK_RETRY_REASON,\n138:     attempt,\n139:     outcome,\n140:     timestamp,\n141:   });\n142: }\n143: \n144: export function shouldRunPostInsertEnrichment(plannerMode: SavePlannerMode = 'plan-only'): boolean {\n145:   return plannerMode === 'full-auto' || isPostInsertEnrichmentEnabled();\n146: }\n147: \n148: function normalizeEnrichmentSkipReason(reason: EnrichmentSkipReason): EnrichmentSkipReason {\n149:   switch (reason) {\n150:     case 'feature_disabled':\n151:     case 'nothing_to_do':\n152:     case 'planner_first_mode':\n153:     case 'density_guard':\n154:     case 'graph_lifecycle_no_op':\n155:     case 'graph_refresh_disabled':\n156:     case 'entity_linking_disabled':\n157:     case 'empty_content':\n158:     case 'extraction_not_ran':\n159:     case 'summary_not_stored':\n160:     case 'async_background':\n161:       return reason;\n162:     default:\n163:       return assertNever(reason, 'enrichment-skip-reason');\n164:   }\n165: }\n166: \n167: function normalizeEnrichmentFailureReason(reason: EnrichmentFailureReason): EnrichmentFailureReason {\n168:   switch (reason) {\n169:     case 'causal_links_exception':\n170:     case 'entity_extraction_exception':\n171:     case 'summary_exception':\n172:     case 'entity_linking_exception':\n173:     case 'graph_lifecycle_exception':\n174:     case 'partial_causal_link_unresolved':\n175:     case 'partial_causal_link_errors':\n176:       return reason;\n177:     default:\n178:       return assertNever(reason, 'enrichment-failure-reason');\n179:   }\n180: }\n181: \n182: function makeSkipped(reason: EnrichmentSkipReason): EnrichmentStepResult {\n183:   return { status: 'skipped', reason: normalizeEnrichmentSkipReason(reason) };\n184: }\n185: \n186: function makeDeferred(reason: EnrichmentSkipReason = 'planner_first_mode'): EnrichmentStepResult {\n187:   return { status: 'deferred', reason: normalizeEnrichmentSkipReason(reason) };\n188: }\n189: \n190: function makeFailed(reason: EnrichmentFailureReason, warnings?: string[]): EnrichmentStepResult {\n191:   return {\n192:     status: 'failed',\n193:     reason: normalizeEnrichmentFailureReason(reason),\n194:     ...(warnings && warnings.length > 0 ? { warnings } : {}),\n195:   };\n196: }\n197: \n198: function deriveFailureReason(name: EnrichmentStepName): EnrichmentFailureReason {\n199:   switch (name) {\n200:     case 'causalLinks':\n201:       return 'causal_links_exception';\n202:     case 'entityExtraction':\n203:       return 'entity_extraction_exception';\n204:     case 'summaries':\n205:       return 'summary_exception';\n206:     case 'entityLinking':\n207:       return 'entity_linking_exception';\n208:     case 'graphLifecycle':\n209:       return 'graph_lifecycle_exception';\n210:     default:\n211:       return assertNever(name, 'enrichment-step-name');\n212:   }\n213: }\n214: \n215: function getEnrichmentFailureLogPrefix(name: EnrichmentStepName): string {\n216:   switch (name) {\n217:     case 'causalLinks':\n218:       return '[memory-save] Causal links processing failed';\n219:     case 'entityExtraction':\n220:       return '[memory-save] R10 entity extraction failed';\n221:     case 'summaries':\n222:       return '[memory-save] R8 summary generation failed';\n223:     case 'entityLinking':\n224:       return '[memory-save] S5 entity linking failed';\n225:     case 'graphLifecycle':\n226:       return '[memory-save] D3 graph-lifecycle enrichment failed';\n227:     default:\n228:       return assertNever(name, 'enrichment-step-log-prefix');\n229:   }\n230: }\n231: \n232: /**\n233:  * Run one enrichment lane with shared flag gating, error classification, and\n234:  * typed success/skip/failure output.\n235:  */\n236: export async function runEnrichmentStep<T>(\n237:   name: EnrichmentStepName,\n238:   isEnabled: () => boolean,\n239:   runner: () => Promise<T>,\n240:   successHandler: (result: T) => EnrichmentStepResult,\n241:   options?: { skipReason?: EnrichmentSkipReason },\n242: ): Promise<EnrichmentStepResult> {\n243:   if (!isEnabled()) {\n244:     return makeSkipped(options?.skipReason ?? 'feature_disabled');\n245:   }\n246: \n247:   try {\n248:     const result = await runner();\n249:     return successHandler(result);\n250:   } catch (err: unknown) {\n251:     const message = toErrorMessage(err);\n252:     console.warn(`${getEnrichmentFailureLogPrefix(name)}: ${message}`);\n253:     return makeFailed(deriveFailureReason(name), [message]);\n254:   }\n255: }\n256: \n257: interface CausalLinksStepState {\n258:   result: CausalLinksResult | null;\n259:   retryAttempts: number | null;\n260:   shouldRetry: boolean;\n261: }\n262: \n263: function buildCausalLinksStepResult(\n264:   id: number,\n265:   result: CausalLinksResult,\n266:   state: CausalLinksStepState,\n267: ): EnrichmentStepResult {\n268:   if (result.inserted > 0) {\n269:     console.error(`[causal-links] Processed ${result.inserted} causal edges for memory #${id}`);\n270:   }\n271:   if (result.unresolved.length > 0) {\n272:     console.warn(`[causal-links] ${result.unresolved.length} references could not be resolved`);\n273:   }\n274: \n275:   const warnings: string[] = [];\n276:   if (result.unresolved.length > 0) {\n277:     warnings.push(`${result.unresolved.length} causal reference(s) unresolved`);\n278:   }\n279:   if (result.errors.length > 0) {\n280:     warnings.push(`${result.errors.length} causal reference(s) errored`);\n281:   }\n282:   if (warnings.length === 0) {\n283:     return { status: 'ran' };\n284:   }\n285: \n286:   const reason: EnrichmentFailureReason = result.errors.length > 0\n287:     ? 'partial_causal_link_errors'\n288:     : 'partial_causal_link_unresolved';\n289:   if (reason === CAUSAL_LINK_RETRY_REASON) {\n290:     state.shouldRetry = shouldRetry(id, CAUSAL_LINK_RETRY_STEP, reason);\n291:     const retryEntry = recordFailure(id, CAUSAL_LINK_RETRY_STEP, reason);\n292:     state.retryAttempts = retryEntry.attempts;\n293:     emitCausalLinkRetryTelemetry(\n294:       id,\n295:       retryEntry.attempts - 1,\n296:       state.shouldRetry ? 'retry' : 'give_up',\n297:       retryEntry.lastFailedAt,\n298:     );\n299:   }\n300:   return { status: 'partial', reason, warnings };\n301: }\n302: \n303: async function runCausalLinksStep(\n304:   database: BetterSqlite3.Database,\n305:   id: number,\n306:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n307:   state: CausalLinksStepState,\n308: ): Promise<EnrichmentStepResult> {\n309:   return runEnrichmentStep(\n310:     'causalLinks',\n311:     () => parsed.hasCausalLinks && Boolean(parsed.causalLinks),\n312:     async () => {\n313:       state.result = processCausalLinks(database, id, parsed.causalLinks!);\n314:       return state.result;\n315:     },\n316:     (result) => buildCausalLinksStepResult(id, result, state),\n317:     { skipReason: 'nothing_to_do' },\n318:   );\n319: }\n320: \n\n(Showing lines 1-320 of 627. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Post Insert\n// ───────────────────────────────────────────────────────────────\nimport type BetterSqlite3 from 'better-sqlite3';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\n\nimport * as embeddings from '../../lib/providers/embeddings.js';\nimport { processCausalLinks } from '../causal-links-processor.js';\nimport {\n  isAutoEntitiesEnabled,\n  isMemorySummariesEnabled,\n  isEntityLinkingEnabled,\n  isPostInsertEnrichmentEnabled,\n  type SavePlannerMode,\n} from '../../lib/search/search-flags.js';\nimport {\n  extractEntities,\n  filterEntities,\n  refreshAutoEntitiesForMemory,\n} from '../../lib/extraction/entity-extractor.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/post-insert.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Post Insert\n// ───────────────────────────────────────────────────────────────\nimport type BetterSqlite3 from 'better-sqlite3';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\n\nimport * as embeddings from '../../lib/providers/embeddings.js';\nimport { processCausalLinks } from '../causal-links-processor.js';\nimport {\n  isAutoEntitiesEnabled,\n  isMemorySummariesEnabled,\n  isEntityLinkingEnabled,\n  isPostInsertEnrichmentEnabled,\n  type SavePlannerMode,\n} from '../../lib/search/search-flags.js';\nimport {\n  extractEntities,\n  filterEntities,\n  refreshAutoEntitiesForMemory,\n} from '../../lib/extraction/entity-extractor.js';\nimport { generateAndStoreSummary } from '../../lib/search/memory-summaries.js';\nimport { runEntityLinkingForMemory } from '../../lib/search/entity-linker.js';\nimport { onIndex, isGraphRefreshEnabled, type OnIndexSkipReason } from '../../lib/search/graph-lifecycle.js';\nimport {\n  clearBudget,\n  emitRetryTelemetry,\n  getRetryBudgetEntry,\n  recordFailure,\n  shouldRetry,\n} from '../../lib/enrichment/retry-budget.js';\nimport { assertNever } from '../../lib/utils/exhaustiveness.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Duplicate-save no-op feedback hardening\n\n\ninterface CausalLinksResult {\n  processed: number;\n  inserted: number;\n  resolved: number;\n  unresolved: { type: string; reference: string }[];\n  errors: { type: string; reference: string; error: string }[];\n}\n\n// Per-step enum status refactor.\n// Replaces boolean-valued record that collapsed success / feature-disabled skip /\n// nothing-to-do skip / deferral / density-guard skip / partial failure into `true`.\nexport type EnrichmentStepStatus = 'ran' | 'skipped' | 'failed' | 'deferred' | 'partial';\n\nexport type EnrichmentSkipReason =\n  | 'feature_disabled'\n  | 'nothing_to_do'\n  | 'planner_first_mode'\n  | 'density_guard'\n  | 'graph_lifecycle_no_op'\n  | 'graph_refresh_disabled'\n  | 'entity_linking_disabled'\n  | 'empty_content'\n  | 'extraction_not_ran'\n  | 'summary_not_stored'\n  | 'async_background';\n\nexport type EnrichmentFailureReason =\n  | 'causal_links_exception'\n  | 'entity_extraction_exception'\n  | 'summary_exception'\n  | 'entity_linking_exception'\n  | 'graph_lifecycle_exception'\n  | 'partial_causal_link_unresolved'\n  | 'partial_causal_link_errors';\n\nexport interface EnrichmentStepResult {\n  status: EnrichmentStepStatus;\n  reason?: EnrichmentSkipReason | EnrichmentFailureReason;\n  warnings?: string[];\n}\n\nexport interface EnrichmentStatus {\n  causalLinks: EnrichmentStepResult;\n  entityExtraction: EnrichmentStepResult;\n  summaries: EnrichmentStepResult;\n  entityLinking: EnrichmentStepResult;\n  graphLifecycle: EnrichmentStepResult;\n}\n\nexport type EnrichmentStepName = keyof EnrichmentStatus;\n\nexport type PostInsertExecutionReason =\n  | 'planner-first-mode'\n  | 'async-background'\n  | 'enrichment_step_failed'\n  | 'enrichment_step_partial';\n\nexport interface PostInsertExecutionStatus {\n  // An exception-driven step failure must NOT be reported\n  // as `ran`.  When any step reports `failed`, execution status rolls up to\n  // `failed`; when any step reports `partial`, it rolls up to `partial`.\n  status: 'ran' | 'deferred' | 'failed' | 'partial';\n  reason?: PostInsertExecutionReason;\n  followUpAction?: 'runEnrichmentBackfill';\n  failedSteps?: Array<keyof EnrichmentStatus>;\n  partialSteps?: Array<keyof EnrichmentStatus>;\n}\n\nexport interface PostInsertEnrichmentResult {\n  causalLinksResult: CausalLinksResult | null;\n  enrichmentStatus: EnrichmentStatus;\n  executionStatus: PostInsertExecutionStatus;\n}\n\nexport interface PostInsertEnrichmentOptions {\n  plannerMode?: SavePlannerMode;\n}\n\nconst ON_INDEX_SKIP_REASON_TO_ENRICHMENT_SKIP_REASON = {\n  graph_refresh_disabled: 'graph_refresh_disabled',\n  entity_linking_disabled: 'entity_linking_disabled',\n  empty_content: 'empty_content',\n  onindex_exception: 'graph_lifecycle_no_op',\n} satisfies Record<OnIndexSkipReason, EnrichmentSkipReason>;\n\nconst CAUSAL_LINK_RETRY_STEP = 'causal_links';\nconst CAUSAL_LINK_RETRY_REASON = 'partial_causal_link_unresolved';\n\nfunction emitCausalLinkRetryTelemetry(\n  memoryId: number,\n  attempt: number,\n  outcome: 'retry' | 'give_up' | 'resolved',\n  timestamp: string,\n): void {\n  emitRetryTelemetry({\n    type: 'event',\n    event: 'retry_attempt',\n    memoryId: String(memoryId),\n    step: CAUSAL_LINK_RETRY_STEP,\n    reason: CAUSAL_LINK_RETRY_REASON,\n    attempt,\n    outcome,\n    timestamp,\n  });\n}\n\nexport function shouldRunPostInsertEnrichment(plannerMode: SavePlannerMode = 'plan-only'): boolean {\n  return plannerMode === 'full-auto' || isPostInsertEnrichmentEnabled();\n}\n\nfunction normalizeEnrichmentSkipReason(reason: EnrichmentSkipReason): EnrichmentSkipReason {\n  switch (reason) {\n    case 'feature_disabled':\n    case 'nothing_to_do':\n    case 'planner_first_mode':\n    case 'density_guard':\n    case 'graph_lifecycle_no_op':\n    case 'graph_refresh_disabled':\n    case 'entity_linking_disabled':\n    case 'empty_content':\n    case 'extraction_not_ran':\n    case 'summary_not_stored':\n    case 'async_background':\n      return reason;\n    default:\n      return assertNever(reason, 'enrichment-skip-reason');\n  }\n}\n\nfunction normalizeEnrichmentFailureReason(reason: EnrichmentFailureReason): EnrichmentFailureReason {\n  switch (reason) {\n    case 'causal_links_exception':\n    case 'entity_extraction_exception':\n    case 'summary_exception':\n    case 'entity_linking_exception':\n    case 'graph_lifecycle_exception':\n    case 'partial_causal_link_unresolved':\n    case 'partial_causal_link_errors':\n      return reason;\n    default:\n      return assertNever(reason, 'enrichment-failure-reason');\n  }\n}\n\nfunction makeSkipped(reason: EnrichmentSkipReason): EnrichmentStepResult {\n  return { status: 'skipped', reason: normalizeEnrichmentSkipReason(reason) };\n}\n\nfunction makeDeferred(reason: EnrichmentSkipReason = 'planner_first_mode'): EnrichmentStepResult {\n  return { status: 'deferred', reason: normalizeEnrichmentSkipReason(reason) };\n}\n\nfunction makeFailed(reason: EnrichmentFailureReason, warnings?: string[]): EnrichmentStepResult {\n  return {\n    status: 'failed',\n    reason: normalizeEnrichmentFailureReason(reason),\n    ...(warnings && warnings.length > 0 ? { warnings } : {}),\n  };\n}\n\nfunction deriveFailureReason(name: EnrichmentStepName): EnrichmentFailureReason {\n  switch (name) {\n    case 'causalLinks':\n      return 'causal_links_exception';\n    case 'entityExtraction':\n      return 'entity_extraction_exception';\n    case 'summaries':\n      return 'summary_exception';\n    case 'entityLinking':\n      return 'entity_linking_exception';\n    case 'graphLifecycle':\n      return 'graph_lifecycle_exception';\n    default:\n      return assertNever(name, 'enrichment-step-name');\n  }\n}\n\nfunction getEnrichmentFailureLogPrefix(name: EnrichmentStepName): string {\n  switch (name) {\n    case 'causalLinks':\n      return '[memory-save] Causal links processing failed';\n    case 'entityExtraction':\n      return '[memory-save] R10 entity extraction failed';\n    case 'summaries':\n      return '[memory-save] R8 summary generation failed';\n    case 'entityLinking':\n      return '[memory-save] S5 entity linking failed';\n    case 'graphLifecycle':\n      return '[memory-save] D3 graph-lifecycle enrichment failed';\n    default:\n      return assertNever(name, 'enrichment-step-log-prefix');\n  }\n}\n\n/**\n * Run one enrichment lane with shared flag gating, error classification, and\n * typed success/skip/failure output.\n */\nexport async function runEnrichmentStep<T>(\n  name: EnrichmentStepName,\n  isEnabled: () => boolean,\n  runner: () => Promise<T>,\n  successHandler: (result: T) => EnrichmentStepResult,\n  options?: { skipReason?: EnrichmentSkipReason },\n): Promise<EnrichmentStepResult> {\n  if (!isEnabled()) {\n    return makeSkipped(options?.skipReason ?? 'feature_disabled');\n  }\n\n  try {\n    const result = await runner();\n    return successHandler(result);\n  } catch (err: unknown) {\n    const message = toErrorMessage(err);\n    console.warn(`${getEnrichmentFailureLogPrefix(name)}: ${message}`);\n    return makeFailed(deriveFailureReason(name), [message]);\n  }\n}\n\ninterface CausalLinksStepState {\n  result: CausalLinksResult | null;\n  retryAttempts: number | null;\n  shouldRetry: boolean;\n}\n\nfunction buildCausalLinksStepResult(\n  id: number,\n  result: CausalLinksResult,\n  state: CausalLinksStepState,\n): EnrichmentStepResult {\n  if (result.inserted > 0) {\n    console.error(`[causal-links] Processed ${result.inserted} causal edges for memory #${id}`);\n  }\n  if (result.unresolved.length > 0) {\n    console.warn(`[causal-links] ${result.unresolved.length} references could not be resolved`);\n  }\n\n  const warnings: string[] = [];\n  if (result.unresolved.length > 0) {\n    warnings.push(`${result.unresolved.length} causal reference(s) unresolved`);\n  }\n  if (result.errors.length > 0) {\n    warnings.push(`${result.errors.length} causal reference(s) errored`);\n  }\n  if (warnings.length === 0) {\n    return { status: 'ran' };\n  }\n\n  const reason: EnrichmentFailureReason = result.errors.length > 0\n    ? 'partial_causal_link_errors'\n    : 'partial_causal_link_unresolved';\n  if (reason === CAUSAL_LINK_RETRY_REASON) {\n    state.shouldRetry = shouldRetry(id, CAUSAL_LINK_RETRY_STEP, reason);\n    const retryEntry = recordFailure(id, CAUSAL_LINK_RETRY_STEP, reason);\n    state.retryAttempts = retryEntry.attempts;\n    emitCausalLinkRetryTelemetry(\n      id,\n      retryEntry.attempts - 1,\n      state.shouldRetry ? 'retry' : 'give_up',\n      retryEntry.lastFailedAt,\n    );\n  }\n  return { status: 'partial', reason, warnings };\n}\n\nasync function runCausalLinksStep(\n  database: BetterSqlite3.Database,\n  id: number,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  state: CausalLinksStepState,\n): Promise<EnrichmentStepResult> {\n  return runEnrichmentStep(\n    'causalLinks',\n    () => parsed.hasCausalLinks && Boolean(parsed.causalLinks),\n    async () => {\n      state.result = processCausalLinks(database, id, parsed.causalLinks!);\n      return state.result;\n    },\n    (result) => buildCausalLinksStepResult(id, result, state),\n    { skipReason: 'nothing_to_do' },\n  );\n}\n","lineStart":1,"lineEnd":320,"totalLines":627,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/post-insert.ts","time":{"start":1781762475319,"end":1781762475326}},"metadata":{"openai":{"itemId":"fc_0cca643c2d3862c5016a3389aa430c81918353003d12609cd4"}},"id":"prt_ed951c426001w9BkzbmnL5bj7s","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed951871d0016kbaZZmtLBSEr4"}}
{"type":"tool_use","timestamp":1781762475525,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_uA8wLehWpIIrjzeS4X8tWQhP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Atomic Index Memory\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import { randomUUID } from 'node:crypto';\n8: \n9: import * as transactionManager from '../../lib/storage/transaction-manager.js';\n10: \n11: import type {\n12:   AtomicSaveOptions,\n13:   AtomicSaveParams,\n14:   AtomicSaveResult,\n15:   IndexResult,\n16: } from './types.js';\n17: import { withSpecFolderLock } from './spec-folder-mutex.js';\n18: \n19: // Feature catalog: Memory indexing (memory_save)\n20: // Feature catalog: Atomic-save parity and partial-indexing hints\n21: \n22: interface AtomicIndexOriginalState {\n23:   existed: boolean;\n24:   content: string | null;\n25: }\n26: \n27: interface AtomicIndexPendingCleanupResult {\n28:   cleaned: boolean;\n29:   existed: boolean;\n30:   error?: string;\n31: }\n32: \n33: interface AtomicIndexRestoreResult {\n34:   restored: boolean;\n35:   error?: string;\n36: }\n37: \n38: export interface AtomicIndexReady<TPrepared = unknown> {\n39:   status: 'ready';\n40:   prepared: TPrepared;\n41:   specFolder: string;\n42:   persistedContent?: string;\n43:   persistedFilePath?: string;\n44: }\n45: \n46: export interface AtomicIndexTerminal {\n47:   status: 'abort' | 'rejected';\n48:   result: AtomicSaveResult;\n49: }\n50: \n51: export type AtomicIndexPreparation<TPrepared = unknown> =\n52:   | AtomicIndexReady<TPrepared>\n53:   | AtomicIndexTerminal;\n54: \n55: export interface AtomicIndexAttemptContext {\n56:   attempt: number;\n57:   force: boolean;\n58: }\n59: \n60: export interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n61:   params: AtomicSaveParams;\n62:   ready: AtomicIndexReady<TPrepared>;\n63:   specFolderLockAlreadyHeld: true;\n64: }\n65: \n66: export interface AtomicIndexDependencies<TPrepared = unknown> {\n67:   prepare: (\n68:     params: AtomicSaveParams,\n69:     context: AtomicIndexAttemptContext,\n70:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n71:   prepareLocked?: (\n72:     context: AtomicIndexLockedContext<TPrepared>,\n73:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n74:   indexPrepared: (\n75:     context: AtomicIndexLockedContext<TPrepared>,\n76:   ) => Promise<IndexResult> | IndexResult;\n77:   mapSuccessResult?: (\n78:     indexResult: IndexResult,\n79:     context: AtomicIndexLockedContext<TPrepared>,\n80:   ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n81:   maxIndexAttempts?: number;\n82:   getPendingPath?: (filePath: string) => string;\n83:   withSpecFolderLock?: typeof withSpecFolderLock;\n84:   captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n85:   restoreOriginalState?: (\n86:     filePath: string,\n87:     originalState: AtomicIndexOriginalState,\n88:   ) => AtomicIndexRestoreResult;\n89:   cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n90:   writePendingFile?: (pendingPath: string, content: string) => void;\n91:   promotePendingFile?: (pendingPath: string, filePath: string) => void;\n92: }\n93: \n94: function toErrorMessage(error: unknown): string {\n95:   return error instanceof Error ? error.message : String(error);\n96: }\n97: \n98: function deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n99:   const existed = fs.existsSync(filePath);\n100:   if (!existed) {\n101:     return { deleted: false, existed: false };\n102:   }\n103: \n104:   try {\n105:     fs.unlinkSync(filePath);\n106:     return { deleted: true, existed: true };\n107:   } catch (error: unknown) {\n108:     return {\n109:       deleted: false,\n110:       existed: true,\n111:       error: toErrorMessage(error),\n112:     };\n113:   }\n114: }\n115: \n116: function captureOriginalState(filePath: string): AtomicIndexOriginalState {\n117:   if (!fs.existsSync(filePath)) {\n118:     return { existed: false, content: null };\n119:   }\n120: \n121:   return {\n122:     existed: true,\n123:     content: fs.readFileSync(filePath, 'utf-8'),\n124:   };\n125: }\n126: \n127: function restoreOriginalState(\n128:   filePath: string,\n129:   originalState: AtomicIndexOriginalState,\n130: ): AtomicIndexRestoreResult {\n131:   try {\n132:     if (!originalState.existed) {\n133:       const deleteResult = deleteFileIfPresent(filePath);\n134:       if (!deleteResult.existed || deleteResult.deleted) {\n135:         return { restored: true };\n136:       }\n137:       return {\n138:         restored: false,\n139:         error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n140:       };\n141:     }\n142: \n143:     if (typeof originalState.content !== 'string') {\n144:       return { restored: false, error: 'Original file content is unavailable for rollback' };\n145:     }\n146: \n147:     fs.mkdirSync(path.dirname(filePath), { recursive: true });\n148:     fs.writeFileSync(filePath, originalState.content, 'utf-8');\n149:     return { restored: true };\n150:   } catch (error: unknown) {\n151:     return {\n152:       restored: false,\n153:       error: toErrorMessage(error),\n154:     };\n155:   }\n156: }\n157: \n158: function cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n159:   const deleteResult = deleteFileIfPresent(pendingPath);\n160:   if (!deleteResult.existed || deleteResult.deleted) {\n161:     return {\n162:       cleaned: true,\n163:       existed: deleteResult.existed,\n164:     };\n165:   }\n166:   return {\n167:     cleaned: false,\n168:     existed: deleteResult.existed,\n169:     error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n170:   };\n171: }\n172: \n173: function writePendingFile(pendingPath: string, content: string): void {\n174:   fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n175:   fs.writeFileSync(pendingPath, content, 'utf-8');\n176: }\n177: \n178: function promotePendingFile(pendingPath: string, filePath: string): void {\n179:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n180:   fs.renameSync(pendingPath, filePath);\n181: }\n182: \n183: function defaultPendingPath(filePath: string): string {\n184:   const basePendingPath = transactionManager.getPendingPath(filePath);\n185:   return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n186: }\n187: \n188: function buildRejectedResult(\n189:   filePath: string,\n190:   indexResult: IndexResult,\n191:   rollbackSucceeded: boolean,\n192:   errorMetadata: Record<string, string> | null,\n193: ): AtomicSaveResult {\n194:   return {\n195:     success: false,\n196:     filePath,\n197:     status: 'rejected',\n198:     id: indexResult.id,\n199:     specFolder: indexResult.specFolder,\n200:     title: indexResult.title,\n201:     summary: rollbackSucceeded\n202:       ? 'Atomic index rejected before file promotion'\n203:       : 'Atomic index rejected but pending file cleanup failed',\n204:     message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n205:     embeddingStatus: indexResult.embeddingStatus,\n206:     hints: [\n207:       rollbackSucceeded\n208:         ? 'Pending file was removed because the save was rejected before promotion'\n209:         : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n210:     ],\n211:     ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n212:     ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n213:   };\n214: }\n215: \n216: function buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n217:   const message = indexResult.message ?? (\n218:     indexResult.status === 'duplicate'\n219:       ? 'Memory skipped (duplicate content)'\n220:       : `Memory ${indexResult.status} successfully`\n221:   );\n222: \n223:   const hints: string[] = [];\n224:   if (indexResult.embeddingStatus === 'pending') {\n225:     hints.push('Memory will be fully indexed when embedding provider becomes available');\n226:   }\n227:   if (indexResult.embeddingStatus === 'partial') {\n228:     hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n229:   }\n230: \n231:   const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n232: \n233:   return {\n234:     success: true,\n235:     filePath,\n236:     status: indexResult.status,\n237:     id: indexResult.id,\n238:     specFolder: indexResult.specFolder,\n239:     title: indexResult.title,\n240:     summary: message,\n241:     message,\n242:     embeddingStatus: indexResult.embeddingStatus,\n243:     ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n244:       ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n245:       : {}),\n246:     ...(hints.length > 0 ? { hints } : {}),\n247:   };\n248: }\n249: \n250: function buildRetryFailureResult(\n251:   filePath: string,\n252:   indexError: Error | null,\n253:   rollbackSucceeded: boolean,\n254:   errorMetadata: Record<string, string> | null,\n255: ): AtomicSaveResult {\n256:   const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n257:   const finalErrorMetadata = errorMetadata ?? {};\n258: \n259:   return {\n260:     success: false,\n261:     filePath,\n262:     status: 'error',\n263:     summary: rollbackSucceeded\n264:       ? 'Atomic index failed after retry and restored original file state'\n265:       : 'Atomic index failed after retry and rollback was incomplete',\n266:     message: indexError?.message ?? 'Indexing failed after retry',\n267:     hints: [\n268:       rollbackSucceeded\n269:         ? 'Original file content was preserved or restored because indexing failed before completion'\n270:         : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n271:       'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n272:     ],\n273:     error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n274:     ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n275:   };\n276: }\n277: \n278: export async function atomicIndexMemory<TPrepared = unknown>(\n279:   params: AtomicSaveParams,\n280:   options: AtomicSaveOptions = {},\n281:   dependencies: AtomicIndexDependencies<TPrepared>,\n282: ): Promise<AtomicSaveResult> {\n283:   const { file_path, content } = params;\n284:   const { force = false } = options;\n285: \n286:   const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n287: \n288:   let indexResult: IndexResult | null = null;\n289:   let indexError: Error | null = null;\n290:   let restoredOriginalAfterFailure = false;\n291:   let anyPromotionAttempted = false;\n292:   let errorMetadata: Record<string, string> | null = null;\n293:   let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n294:   let lastEffectiveFilePath = file_path;\n295:   let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n296: \n297:   const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n298:     if (!entry) {\n299:       return;\n300:     }\n301:     errorMetadata = {\n302:       ...(errorMetadata ?? {}),\n303:       ...entry,\n304:     };\n305:   };\n306: \n307:   for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n308:     let promotedToFinalPath = false;\n309:     let handledFailureWhileLocked = false;\n310:     let rollbackSucceededAfterRejectedSave = false;\n311:     let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n312: \n313:     try {\n314:       const prepared = await dependencies.prepare(params, { attempt, force });\n315:       if (prepared.status !== 'ready') {\n316:         return prepared.result;\n317:       }\n318: \n319:       const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n320:       const lockedResult = await runWithLock(prepared.specFolder, async () => {\n\n(Showing lines 1-320 of 462. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\ninterface AtomicIndexOriginalState {\n  existed: boolean;\n  content: string | null;\n}\n\ninterface AtomicIndexPendingCleanupResult {\n  cleaned: boolean;\n  existed: boolean;\n  error?: string;\n}\n\ninterface AtomicIndexRestoreResult {\n  restored: boolean;\n  error?: string;\n}\n\nexport interface AtomicIndexReady<TPrepared = unknown> {\n  status: 'ready';\n  prepared: TPrepared;\n  specFolder: string;\n  persistedContent?: string;\n  persistedFilePath?: string;\n}\n\nexport interface AtomicIndexTerminal {\n  status: 'abort' | 'rejected';\n  result: AtomicSaveResult;\n}\n\nexport type AtomicIndexPreparation<TPrepared = unknown> =\n  | AtomicIndexReady<TPrepared>\n  | AtomicIndexTerminal;\n\nexport interface AtomicIndexAttemptContext {\n  attempt: number;\n  force: boolean;\n}\n\nexport interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n  params: AtomicSaveParams;\n  ready: AtomicIndexReady<TPrepared>;\n  specFolderLockAlreadyHeld: true;\n}\n\nexport interface AtomicIndexDependencies<TPrepared = unknown> {\n  prepare: (\n    params: AtomicSaveParams,\n    context: AtomicIndexAttemptContext,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  prepareLocked?: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  indexPrepared: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<IndexResult> | IndexResult;\n  mapSuccessResult?: (\n    indexResult: IndexResult,\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n  maxIndexAttempts?: number;\n  getPendingPath?: (filePath: string) => string;\n  withSpecFolderLock?: typeof withSpecFolderLock;\n  captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n  restoreOriginalState?: (\n    filePath: string,\n    originalState: AtomicIndexOriginalState,\n  ) => AtomicIndexRestoreResult;\n  cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n  writePendingFile?: (pendingPath: string, content: string) => void;\n  promotePendingFile?: (pendingPath: string, filePath: string) => void;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n  const existed = fs.existsSync(filePath);\n  if (!existed) {\n    return { deleted: false, existed: false };\n  }\n\n  try {\n    fs.unlinkSync(filePath);\n    return { deleted: true, existed: true };\n  } catch (error: unknown) {\n    return {\n      deleted: false,\n      existed: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction captureOriginalState(filePath: string): AtomicIndexOriginalState {\n  if (!fs.existsSync(filePath)) {\n    return { existed: false, content: null };\n  }\n\n  return {\n    existed: true,\n    content: fs.readFileSync(filePath, 'utf-8'),\n  };\n}\n\nfunction restoreOriginalState(\n  filePath: string,\n  originalState: AtomicIndexOriginalState,\n): AtomicIndexRestoreResult {\n  try {\n    if (!originalState.existed) {\n      const deleteResult = deleteFileIfPresent(filePath);\n      if (!deleteResult.existed || deleteResult.deleted) {\n        return { restored: true };\n      }\n      return {\n        restored: false,\n        error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n      };\n    }\n\n    if (typeof originalState.content !== 'string') {\n      return { restored: false, error: 'Original file content is unavailable for rollback' };\n    }\n\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, originalState.content, 'utf-8');\n    return { restored: true };\n  } catch (error: unknown) {\n    return {\n      restored: false,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n  const deleteResult = deleteFileIfPresent(pendingPath);\n  if (!deleteResult.existed || deleteResult.deleted) {\n    return {\n      cleaned: true,\n      existed: deleteResult.existed,\n    };\n  }\n  return {\n    cleaned: false,\n    existed: deleteResult.existed,\n    error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n  };\n}\n\nfunction writePendingFile(pendingPath: string, content: string): void {\n  fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n  fs.writeFileSync(pendingPath, content, 'utf-8');\n}\n\nfunction promotePendingFile(pendingPath: string, filePath: string): void {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.renameSync(pendingPath, filePath);\n}\n\nfunction defaultPendingPath(filePath: string): string {\n  const basePendingPath = transactionManager.getPendingPath(filePath);\n  return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n}\n\nfunction buildRejectedResult(\n  filePath: string,\n  indexResult: IndexResult,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  return {\n    success: false,\n    filePath,\n    status: 'rejected',\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: rollbackSucceeded\n      ? 'Atomic index rejected before file promotion'\n      : 'Atomic index rejected but pending file cleanup failed',\n    message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n    embeddingStatus: indexResult.embeddingStatus,\n    hints: [\n      rollbackSucceeded\n        ? 'Pending file was removed because the save was rejected before promotion'\n        : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n    ],\n    ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n    ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n  };\n}\n\nfunction buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n  const message = indexResult.message ?? (\n    indexResult.status === 'duplicate'\n      ? 'Memory skipped (duplicate content)'\n      : `Memory ${indexResult.status} successfully`\n  );\n\n  const hints: string[] = [];\n  if (indexResult.embeddingStatus === 'pending') {\n    hints.push('Memory will be fully indexed when embedding provider becomes available');\n  }\n  if (indexResult.embeddingStatus === 'partial') {\n    hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n  }\n\n  const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n\n  return {\n    success: true,\n    filePath,\n    status: indexResult.status,\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: message,\n    message,\n    embeddingStatus: indexResult.embeddingStatus,\n    ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n      ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n      : {}),\n    ...(hints.length > 0 ? { hints } : {}),\n  };\n}\n\nfunction buildRetryFailureResult(\n  filePath: string,\n  indexError: Error | null,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n  const finalErrorMetadata = errorMetadata ?? {};\n\n  return {\n    success: false,\n    filePath,\n    status: 'error',\n    summary: rollbackSucceeded\n      ? 'Atomic index failed after retry and restored original file state'\n      : 'Atomic index failed after retry and rollback was incomplete',\n    message: indexError?.message ?? 'Indexing failed after retry',\n    hints: [\n      rollbackSucceeded\n        ? 'Original file content was preserved or restored because indexing failed before completion'\n        : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n      'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n    ],\n    error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n    ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n  };\n}\n\nexport async function atomicIndexMemory<TPrepared = unknown>(\n  params: AtomicSaveParams,\n  options: AtomicSaveOptions = {},\n  dependencies: AtomicIndexDependencies<TPrepared>,\n): Promise<AtomicSaveResult> {\n  const { file_path, content } = params;\n  const { force = false } = options;\n\n  const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n\n  let indexResult: IndexResult | null = null;\n  let indexError: Error | null = null;\n  let restoredOriginalAfterFailure = false;\n  let anyPromotionAttempted = false;\n  let errorMetadata: Record<string, string> | null = null;\n  let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n  let lastEffectiveFilePath = file_path;\n  let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n\n  const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n    if (!entry) {\n      return;\n    }\n    errorMetadata = {\n      ...(errorMetadata ?? {}),\n      ...entry,\n    };\n  };\n\n  for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n    let promotedToFinalPath = false;\n    let handledFailureWhileLocked = false;\n    let rollbackSucceededAfterRejectedSave = false;\n    let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n\n    try {\n      const prepared = await dependencies.prepare(params, { attempt, force });\n      if (prepared.status !== 'ready') {\n        return prepared.result;\n      }\n\n      const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n      const lockedResult = await runWithLock(prepared.specFolder, async () => {","lineStart":1,"lineEnd":320,"totalLines":462,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","time":{"start":1781762475508,"end":1781762475523}},"metadata":{"openai":{"itemId":"fc_0cca643c2d3862c5016a3389aa43148191843b9c7097b5f789"}},"id":"prt_ed951c573001BD8C6uNQz6aqAI","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed951871d0016kbaZZmtLBSEr4"}}
