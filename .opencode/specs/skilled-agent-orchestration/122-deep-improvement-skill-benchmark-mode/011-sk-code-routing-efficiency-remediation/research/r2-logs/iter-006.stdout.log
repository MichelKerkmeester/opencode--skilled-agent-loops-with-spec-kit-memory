cenarioId\": \"SD-003\",\n286:       \"tier\": \"playbook\",\n287:       \"dims\": {\n288:         \"d1intra\": {\n289:           \"score\": 0,\n290:           \"intentRecall\": null,\n291:           \"resourceRecall\": 1,\n292:           \"negative\": true\n293:         },\n294:         \"d2\": {\n295:           \"score\": 0,\n296:           \"proxy\": \"router-replay-recall\",\n297:           \"note\": \"Mode A proxy; live-mode replaces with observed-load Hit@k/Recall@k/MRR\"\n298:         },\n299:         \"d3\": {\n300:           \"score\": 0,\n301:           \"routedCount\": 4,\n302:           \"wastedCount\": 4,\n303:           \"proxy\": \"negative-activation\",\n304:           \"note\": \"negative scenario: D3 tracks the suppression outcome, not over-routing\"\n\n(Showing lines 193-304 of 1010. Use offset=305 to continue.)\n</content>","metadata":{"preview":"  \"scenarioRows\": [\n    {\n      \"scenarioId\": \"SD-001\",\n      \"tier\": \"playbook\",\n      \"dims\": {\n        \"d1intra\": {\n          \"score\": 0.6727272727272727,\n          \"intentRecall\": null,\n          \"resourceRecall\": 0.45454545454545453,\n          \"negative\": false\n        },\n        \"d2\": {\n          \"score\": 0.45454545454545453,\n          \"proxy\": \"router-replay-recall\",\n          \"note\": \"Mode A proxy; live-mode replaces with observed-load Hit@k/Recall@k/MRR\"\n        },\n        \"d3\": {\n          \"score\": 0.8333333333333334,\n          \"routedCount\": 6,\n          \"wastedCount\": 1,","truncated":true,"loaded":[]},"title":".opencode/skills/sk-code/benchmark/router-final/skill-benchmark-report.json","time":{"start":1780373220495,"end":1780373220506}},"metadata":{"openai":{"itemId":"fc_09a9b9916711aa46016a1e56e460688191a26d46782216fd81"}},"id":"prt_e86836c8d001suf8PK4lxEjIXv","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e86834d69001oEsdWJ2nAH0OBm"}}
