          gauges: latestGauges,\n1867:         });\n1868:         const failure = new Error(\n1869:           `lineage ${lineage.label} exceeds configured budget cap: `\n1870:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1871:         );\n1872:         failure.label = lineage.label;\n1873:         failure.exitCode = null;\n1874:         failure.timedOut = false;\n1875:         failure.budgetCap = budgetDecision;\n1876:         throw failure;\n1877:       }\n1878: \n1879:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1880:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1881:         convergenceThreshold,\n1882:         stopPolicy,\n1883:       });\n1884: \n1885:       // Sandbox resolution stays write-capable by default even for review lineages:\n1886:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1887:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1888:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1889:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1890:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1891:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1892:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1893:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1894: \n1895:       const effectiveSandbox = resolvedSandbox;\n1896:       const effectivePermission = resolvedPermission;\n1897: \n1898:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1899:         lineage,\n1900:         prompt,\n1901:         effectiveSandbox,\n1902:         effectivePermission,\n1903:         {\n1904:           loopType,\n1905:           specFolder,\n1906:           lineageDir,\n1907:           sessionId,\n1908:           convergenceThreshold,\n1909:           stopPolicy,\n1910:           researchTopic,\n1911:         },\n1912:       );\n1913: \n1914:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1915:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1916:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1917:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1918:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1919:       // is deliberately avoided here because relocating the home breaks credential/auth\n1920:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1921:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1922:       const extraEnv = {\n1923:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1924:         // A fan-out lineage is an orchestrated sub-session running an autonomous\n1925:         // workflow: it has no user turn to answer Gate 3, so the spec-gate must be\n1926:         // fully inert. ENFORCE=0 alone is NOT enough — that only stops the deny, while\n1927:         // the classify step still injects the Gate-3 question, which a cli-opencode\n1928:         // child then answers instead of doing its work. DISABLED makes both classify\n1929:         // and enforce no-ops; AI_SESSION_CHILD lets the worktree wrapper exec in place.\n1930:         // buildExecutorDispatchEnv filters these keys (outside the per-kind allowlist),\n1931:         // so they are re-injected here to reach the child. Harmless for the codex path.\n1932:         MK_SPEC_GATE_DISABLED: '1',\n1933:         AI_SESSION_CHILD: '1',\n1934:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1935:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1936:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1937:           : {}),\n1938:       };\n1939: \n1940:       // Recursion guard (fail closed): the executor stack can already name the hosting\n1941:       // runtime before the first detached fan-out spawn. The lineage marker is added only\n1942:       // to a spawned seat, so both signals are required to prove that a seat is trying to\n1943:       // fan out its own executor kind again.\n1944:       const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n1945:       const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n1946:         && inheritedLineageId.trim() !== '';\n1947:       if (\n1948:         isInsideFanoutLineage\n1949:         && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n1950:       ) {\n1951:         throw new Error(\n1952:           `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n1953:         );\n1954:       }\n1955: \n1956:       // Stamp the dispatch stack with this lineage's executor kind so a seat that\n1957:       // tries to recursively launch the same kind is detectable by the runtime\n1958:       // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n1959:       // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n1960:       // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n1961:       // preserve the per-replica lockfile isolation they provide.\n1962:       const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n1963: \n1964:       const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n1965:       let lastLineageEventAtMs = Date.now();\n1966:       const markLineageEvent = () => {\n1967:         lastLineageEventAtMs = Date.now();\n1968:       };\n1969:       const stopStallWatchdog = startLineageStallWatchdog({\n1970:         thresholdMs: stallWatchdogMs,\n1971:         label: lineage.label,\n1972:         ledgerPath,\n1973:         getLastEventAtMs: () => lastLineageEventAtMs,\n1974:         getGauges: () => latestGauges,\n1975:       });\n1976: \n1977:       const stopProgressHeartbeat = startLineageProgressHeartbeat({\n1978:         cadenceMs: progressHeartbeatMs,\n1979:         label: lineage.label,\n1980:         ledgerPath,\n1981:         getGauges: () => latestGauges,\n1982:       });\n1983:       let result;\n1984:       try {\n1985:         result = await runLineageProcess(command, cmdArgs, {\n1986:           cwd: process.cwd(),\n1987:           timeoutMs,\n1988:           env: dispatchEnv,\n1989:           maxBuffer: 20 * 1024 * 1024,\n1990:           abortSignal: context.signal,\n1991:           onOutput: markLineageEvent,\n1992:           onSpawn: ({ pid }) => {\n1993:             lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n1994:           },\n1995:           onExit: ({ pid, exitedAtMs }) => {\n1996:             lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n1997:           },\n1998:           ...(typeof input === 'string' ? { input } : {}),\n1999:         });\n2000:       } finally {\n2001:         stopProgressHeartbeat();\n2002:         stopStallWatchdog();\n2003:       }\n2004: \n2005:       // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n2006:       const logsDir = path.join(lineageDir, 'logs');\n2007:       fs.mkdirSync(logsDir, { recursive: true });\n2008:       const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n2009:       fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n2010: \n2011:       // Recover missing iteration files from captured stdout when possible. Runs\n2012:       // BEFORE the failure throw below so iteration recovery is never lost.\n2013:       const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n2014:       const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n2015:       lineageSlotAccounting.set(lineage.label, slotAccounting);\n2016: \n2017:       const exitCode = result.status ?? (result.error ? 1 : 0);\n2018:       const timedOut = result.signal === 'SIGTERM';\n2019:       // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n2020:       // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n2021:       // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n2022:       const killedBySignal = result.signal != null;\n2023:       const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n2024:       const stateRead = readLineageStateRecords(loopType, lineageDir);\n2025:       const stopPolicyViolation = findMaxIterationsPolicyViolation({\n2026:         loopType,\n2027:         stateRead,\n2028:         lineage,\n2029:         stopPolicy,\n2030:       });\n2031: \n2032:       // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n2033:       // not a success. Throw so the pool settles this item as rejected and counts it\n2034:       // in summary.failed/all_failed, which drives the process exit code. Returning a\n2035:       // plain object here would let the pool record any completed worker as fulfilled\n2036:       // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n2037:       if (timedOut || killedBySignal || exitCode !== 0) {\n2038:         const reason = timedOut\n2039:           ? 'timed out'\n2040:           : killedBySignal\n2041:             ? `killed by signal ${result.signal}`\n2042:             : `exited with code ${exitCode}`;\n2043:         const failure = new Error(`lineage ${lineage.label} ${reason}`);\n2044:         failure.label = lineage.label;\n2045:         failure.exitCode = exitCode;\n2046:         failure.timedOut = timedOut;\n2047:         failure.killedBySignal = killedBySignal;\n2048:         failure.salvage = salvage;\n2049:         throw failure;\n2050:       }\n2051: \n2052:       if (missingArtifacts.length > 0) {\n2053:         const failure = new Error(\n2054:           `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n2055:         );\n2056:         failure.label = lineage.label;\n2057:         failure.exitCode = exitCode;\n2058:         failure.timedOut = false;\n2059:         failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n2060:         failure.missingArtifacts = missingArtifacts;\n2061:         throw failure;\n2062:       }\n2063: \n2064:       if (stopPolicyViolation) {\n2065:         const failure = new Error(\n2066:           `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n2067:         );\n2068:         failure.label = lineage.label;\n2069:         failure.exitCode = exitCode;\n2070:         failure.timedOut = false;\n2071:         failure.salvage = salvage;\n2072:         failure.stopPolicyViolation = stopPolicyViolation;\n2073:         throw failure;\n2074:       }\n2075: \n2076:       // An exit-0 lineage whose salvage sweep could not recover every iteration\n2077:       // markdown is NOT fulfilled, even when the top-level report exists. Returning\n2078:       // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n2079:       // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n2080:       // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n2081:       if (salvage && salvage.failed > 0) {\n2082:         const failure = new Error(\n2083:           `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n2084:         );\n2085:         failure.label = lineage.label;\n2086:         failure.exitCode = exitCode;\n2087:         failure.timedOut = false;\n2088:         failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n2089:         failure.missingArtifacts = [];\n2090:         throw failure;\n2091:       }\n2092: \n2093:       const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n2094:       if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n2095:         const slotWindowEndIso = new Date().toISOString();\n2096:         try {\n2097:           const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n2098:             windowStart: slotWindowStartIso,\n2099:             windowEnd: slotWindowEndIso,\n\n(Showing lines 1840-2099 of 2189. Use offset=2100 to continue.)\n</content>","metadata":{"preview":"      if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n      appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n    },\n    worker: async (lineage, context) => {\n      const slotWindowStartIso = new Date().toISOString();\n      const hrStart = process.hrtime();\n      const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n      const livenessKey = `${lineage.label}:${attempt}`;\n      const lineageDir = path.join(lineagesDir, lineage.label);\n      const stateDir = path.join(lineageDir, '.executor-state');\n      fs.mkdirSync(lineageDir, { recursive: true });\n      fs.mkdirSync(stateDir, { recursive: true });\n\n      const budgetDecision = evaluateLineageBudgetCap({\n        lineage,\n        guards: lineageBudgetGuards,\n        maxRetries: fanoutConfig.maxRetries,\n      });\n      if (!budgetDecision.continue_allowed) {\n        appendFanoutStatusLedger(ledgerPath, {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-