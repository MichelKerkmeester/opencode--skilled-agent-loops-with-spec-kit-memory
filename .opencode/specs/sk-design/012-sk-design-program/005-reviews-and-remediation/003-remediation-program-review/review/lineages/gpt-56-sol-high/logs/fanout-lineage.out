{"type":"tool_use","timestamp":1784655855460,"sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","part":{"type":"tool","tool":"read","callID":"call_m218I9SSpohVNO6Y4Fdj2KJk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs","offset":90,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs</path>\n<type>file</type>\n<content>\n90: \n91: function requireString(flags, key) {\n92:   const value = flags[key];\n93:   if (typeof value !== 'string' || !value) {\n94:     throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n95:   }\n96:   return value;\n97: }\n98: \n99: function resolveOwnerPid(flags) {\n100:   if (flags.ownerPid === undefined) {\n101:     return process.pid;\n102:   }\n103:   const pid = Number(flags.ownerPid);\n104:   if (!Number.isInteger(pid) || pid <= 0) {\n105:     throw inputError('--owner-pid must be a positive integer');\n106:   }\n107:   return pid;\n108: }\n109: \n110: // Nonce is optional on the CLI: nonce-less legacy locks still refresh/release\n111: // on pid match alone, so callers that never captured a nonce keep working.\n112: function resolveOptionalNonce(flags) {\n113:   if (flags.nonce === undefined) {\n114:     return undefined;\n115:   }\n116:   if (typeof flags.nonce !== 'string' || !flags.nonce) {\n117:     throw inputError('--nonce must be a non-empty string when provided');\n118:   }\n119:   return flags.nonce;\n120: }\n121: \n122: function jsonOut(payload) {\n123:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n124: }\n125: \n126: // Map the snake_case on-disk lock record to the camelCase LoopLockData shape so\n127: // status can run it through the same staleness check the library uses.\n128: function readDiskLock(lockPath) {\n129:   let raw;\n130:   try {\n131:     raw = JSON.parse(fs.readFileSync(lockPath, 'utf8'));\n132:   } catch {\n133:     return null;\n134:   }\n135:   if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {\n136:     return null;\n137:   }\n138:   return {\n139:     ownerPid: raw.owner_pid,\n140:     startedAtIso: raw.started_at_iso,\n141:     ttlMs: raw.ttl_ms,\n142:     lastHeartbeatIso: raw.last_heartbeat_iso,\n143:     packetId: raw.packet_id,\n144:     runtimeKind: raw.runtime_kind,\n145:   };\n146: }\n147: \n148: // ─────────────────────────────────────────────────────────────────────────────\n149: // 5. CORE LOGIC\n150: // ─────────────────────────────────────────────────────────────────────────────\n151: \n152: async function main() {\n153:   const argv = process.argv.slice(2);\n154:   const subcommand = argv[0];\n155:   if (!subcommand || subcommand.startsWith('--')) {\n156:     throw inputError('A subcommand is required: acquire | status | refresh | release');\n157:   }\n158:   const flags = parseFlags(argv.slice(1));\n159: \n160:   const lib = await import('../lib/deep-loop/loop-lock.ts');\n161: \n162:   if (subcommand === 'acquire') {\n163:     const lockPath = requireString(flags, 'lockPath');\n164:     const packetId = requireString(flags, 'packetId');\n165:     const ttlMs = flags.ttlMs === undefined ? 300000 : Number(flags.ttlMs);\n166:     if (!Number.isFinite(ttlMs) || ttlMs < 0) {\n167:       throw inputError('--ttl-ms must be a non-negative number');\n168:     }\n169:     const runtimeKind = typeof flags.runtimeKind === 'string' && flags.runtimeKind\n170:       ? flags.runtimeKind\n171:       : 'main';\n172:     const ownerPid = resolveOwnerPid(flags);\n173:     const now = new Date().toISOString();\n174:     const result = lib.acquireLoopLock(lockPath, {\n175:       ownerPid,\n176:       startedAtIso: now,\n177:       ttlMs,\n178:       lastHeartbeatIso: now,\n179:       packetId,\n180:       runtimeKind,\n181:     });\n182:     jsonOut({ command: 'acquire', ...result });\n183:     return;\n184:   }\n185: \n186:   if (subcommand === 'status') {\n187:     const lockPath = requireString(flags, 'lockPath');\n188:     const holder = fs.existsSync(lockPath) ? readDiskLock(lockPath) : null;\n189:     if (!holder) {\n190:       jsonOut({ command: 'status', exists: false, stale: false, alive: false, holder: null });\n191:       return;\n192:     }\n193:     const stale = lib.isStaleLoopLock(holder);\n194:     const alive = lib.processAlive(holder.ownerPid);\n195:     jsonOut({ command: 'status', exists: true, held: !stale, stale, alive, holder });\n196:     return;\n197:   }\n198: \n199:   if (subcommand === 'refresh') {\n200:     const lockPath = requireString(flags, 'lockPath');\n201:     const ownerPid = resolveOwnerPid(flags);\n202:     const acquireNonce = resolveOptionalNonce(flags);\n203:     const refreshed = lib.refreshLoopLock(lockPath, ownerPid, new Date(), { acquireNonce });\n204:     jsonOut({ command: 'refresh', refreshed });\n205:     return;\n206:   }\n207: \n208:   if (subcommand === 'release') {\n209:     const lockPath = requireString(flags, 'lockPath');\n210:     const ownerPid = resolveOwnerPid(flags);\n211:     const acquireNonce = resolveOptionalNonce(flags);\n212:     const released = lib.releaseLoopLock(lockPath, ownerPid, acquireNonce);\n213:     jsonOut({ command: 'release', released });\n214:     return;\n215:   }\n216: \n217:   throw inputError(`Unknown subcommand \"${subcommand}\": expected acquire | status | refresh | release`);\n218: }\n219: \n\n(Showing lines 90-219 of 228. Use offset=220 to continue.)\n</content>","metadata":{"preview":"\nfunction requireString(flags, key) {\n  const value = flags[key];\n  if (typeof value !== 'string' || !value) {\n    throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n  }\n  return value;\n}\n\nfunction resolveOwnerPid(flags) {\n  if (flags.ownerPid === undefined) {\n    return process.pid;\n  }\n  const pid = Number(flags.ownerPid);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    throw inputError('--owner-pid must be a positive integer');\n  }\n  return pid;\n}\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs","text":"\nfunction requireString(flags, key) {\n  const value = flags[key];\n  if (typeof value !== 'string' || !value) {\n    throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n  }\n  return value;\n}\n\nfunction resolveOwnerPid(flags) {\n  if (flags.ownerPid === undefined) {\n    return process.pid;\n  }\n  const pid = Number(flags.ownerPid);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    throw inputError('--owner-pid must be a positive integer');\n  }\n  return pid;\n}\n\n// Nonce is optional on the CLI: nonce-less legacy locks still refresh/release\n// on pid match alone, so callers that never captured a nonce keep working.\nfunction resolveOptionalNonce(flags) {\n  if (flags.nonce === undefined) {\n    return undefined;\n  }\n  if (typeof flags.nonce !== 'string' || !flags.nonce) {\n    throw inputError('--nonce must be a non-empty string when provided');\n  }\n  return flags.nonce;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\n// Map the snake_case on-disk lock record to the camelCase LoopLockData shape so\n// status can run it through the same staleness check the library uses.\nfunction readDiskLock(lockPath) {\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(lockPath, 'utf8'));\n  } catch {\n    return null;\n  }\n  if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {\n    return null;\n  }\n  return {\n    ownerPid: raw.owner_pid,\n    startedAtIso: raw.started_at_iso,\n    ttlMs: raw.ttl_ms,\n    lastHeartbeatIso: raw.last_heartbeat_iso,\n    packetId: raw.packet_id,\n    runtimeKind: raw.runtime_kind,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const argv = process.argv.slice(2);\n  const subcommand = argv[0];\n  if (!subcommand || subcommand.startsWith('--')) {\n    throw inputError('A subcommand is required: acquire | status | refresh | release');\n  }\n  const flags = parseFlags(argv.slice(1));\n\n  const lib = await import('../lib/deep-loop/loop-lock.ts');\n\n  if (subcommand === 'acquire') {\n    const lockPath = requireString(flags, 'lockPath');\n    const packetId = requireString(flags, 'packetId');\n    const ttlMs = flags.ttlMs === undefined ? 300000 : Number(flags.ttlMs);\n    if (!Number.isFinite(ttlMs) || ttlMs < 0) {\n      throw inputError('--ttl-ms must be a non-negative number');\n    }\n    const runtimeKind = typeof flags.runtimeKind === 'string' && flags.runtimeKind\n      ? flags.runtimeKind\n      : 'main';\n    const ownerPid = resolveOwnerPid(flags);\n    const now = new Date().toISOString();\n    const result = lib.acquireLoopLock(lockPath, {\n      ownerPid,\n      startedAtIso: now,\n      ttlMs,\n      lastHeartbeatIso: now,\n      packetId,\n      runtimeKind,\n    });\n    jsonOut({ command: 'acquire', ...result });\n    return;\n  }\n\n  if (subcommand === 'status') {\n    const lockPath = requireString(flags, 'lockPath');\n    const holder = fs.existsSync(lockPath) ? readDiskLock(lockPath) : null;\n    if (!holder) {\n      jsonOut({ command: 'status', exists: false, stale: false, alive: false, holder: null });\n      return;\n    }\n    const stale = lib.isStaleLoopLock(holder);\n    const alive = lib.processAlive(holder.ownerPid);\n    jsonOut({ command: 'status', exists: true, held: !stale, stale, alive, holder });\n    return;\n  }\n\n  if (subcommand === 'refresh') {\n    const lockPath = requireString(flags, 'lockPath');\n    const ownerPid = resolveOwnerPid(flags);\n    const acquireNonce = resolveOptionalNonce(flags);\n    const refreshed = lib.refreshLoopLock(lockPath, ownerPid, new Date(), { acquireNonce });\n    jsonOut({ command: 'refresh', refreshed });\n    return;\n  }\n\n  if (subcommand === 'release') {\n    const lockPath = requireString(flags, 'lockPath');\n    const ownerPid = resolveOwnerPid(flags);\n    const acquireNonce = resolveOptionalNonce(flags);\n    const released = lib.releaseLoopLock(lockPath, ownerPid, acquireNonce);\n    jsonOut({ command: 'release', released });\n    return;\n  }\n\n  throw inputError(`Unknown subcommand \"${subcommand}\": expected acquire | status | refresh | release`);\n}\n","lineStart":90,"lineEnd":219,"totalLines":228,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs","time":{"start":1784655855449,"end":1784655855458}},"metadata":{"openai":{"itemId":"fc_0ef94a54e2ff1596016a5fafedfcc88191a7074670db444928"}},"id":"prt_f85c739bc001InrlNkhAN9j3as","sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","messageID":"msg_f85c705bb0019RJbq7zQSZ3qge"}}
