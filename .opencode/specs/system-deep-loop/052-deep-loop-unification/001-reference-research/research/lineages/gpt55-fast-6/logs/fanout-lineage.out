{"type":"tool_use","timestamp":1783486586707,"sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","part":{"type":"tool","tool":"read","callID":"call_uTAW5j14pYSoCJt7XYCrhFN2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":1385,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n1385: \n1386:           function readJson(filePath) {\n1387:             try {\n1388:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1389:             } catch {\n1390:               return null;\n1391:             }\n1392:           }\n1393: \n1394:           function readJsonl(filePath) {\n1395:             if (!hasFile(filePath)) return [];\n1396:             return readFileSync(filePath, 'utf8')\n1397:               .split(/\\r?\\n/)\n1398:               .map((line) => line.trim())\n1399:               .filter(Boolean)\n1400:               .flatMap((line) => {\n1401:                 try {\n1402:                   return [JSON.parse(line)];\n1403:                 } catch {\n1404:                   return [];\n1405:                 }\n1406:               });\n1407:           }\n1408: \n1409:           function countIterationFindings(record) {\n1410:             if (!record || record.type !== 'iteration') return 0;\n1411:             const numeric = Number(record.findingsCount);\n1412:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1413:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1414:             if (Array.isArray(record.findings)) return record.findings.length;\n1415:             return 0;\n1416:           }\n1417: \n1418:           function normalizeFindingKey(value) {\n1419:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1420:           }\n1421: \n1422:           function findingKeys(candidate) {\n1423:             if (typeof candidate === 'string') {\n1424:               const key = normalizeFindingKey(candidate);\n1425:               return key ? [key] : [];\n1426:             }\n1427:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1428:             return [...new Set([\n1429:               candidate.id,\n1430:               candidate.title,\n1431:               candidate.summary,\n1432:               candidate.text,\n1433:               candidate.finding,\n1434:               candidate.description,\n1435:             ].map(normalizeFindingKey).filter(Boolean))];\n1436:           }\n1437: \n1438:           function collectIterationFindingGroups(record) {\n1439:             if (!record || record.type !== 'iteration') return [];\n1440:             const structured = [record.keyFindings, record.findings]\n1441:               .find((value) => Array.isArray(value) && value.length > 0);\n1442:             if (!Array.isArray(structured)) return [];\n1443:             return structured\n1444:               .map(findingKeys)\n1445:               .filter((keys) => keys.length > 0);\n1446:           }\n1447: \n1448:           function collectRegistryFindingKeys(registry) {\n1449:             if (!Array.isArray(registry?.keyFindings)) return [];\n1450:             return registry.keyFindings\n1451:               .flatMap(findingKeys);\n1452:           }\n1453: \n1454:           function appendEvent(event) {\n1455:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1456:           }\n1457: \n1458:           const registry = readJson(paths.registry);\n1459:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1460:           const stateRecords = readJsonl(paths.stateLog);\n1461:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1462:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1463:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1464:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1465:           const identifiableFindingCount = identifiableFindingGroups.length;\n1466:           const missingArtifacts = [\n1467:             ['registry', paths.registry],\n1468:             ['research', paths.research],\n1469:             ['dashboard', paths.dashboard],\n1470:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1471:           const invariantFailures = [];\n1472:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1473:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1474:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1475:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1476:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1477: \n1478:           if (invariantFailures.length > 0) {\n1479:             appendEvent({\n1480:               type: 'event',\n1481:               event: 'synthesis_incomplete',\n1482:               mode: 'research',\n1483:               severity: 'warning',\n1484:               totalIterations: Number('{iteration_count}'),\n1485:               answeredCount: Number('{answered_count}'),\n1486:               totalQuestions: Number('{total_questions}'),\n1487:               stopReason: '{reason}',\n1488:               reason: 'synthesis_artifact_invariant_failed',\n1489:               invariantFailures,\n1490:               missingArtifacts,\n1491:               registryFindingCount,\n1492:               iterationFindingCount,\n1493:               identifiableFindingCount,\n1494:               missingStructuredFindingCount,\n1495:               timestamp: '{ISO_8601_NOW}',\n1496:             });\n1497:           } else {\n1498:             appendEvent({\n1499:               type: 'event',\n1500:               event: 'synthesis_complete',\n1501:               totalIterations: Number('{iteration_count}'),\n1502:               answeredCount: Number('{answered_count}'),\n1503:               totalQuestions: Number('{total_questions}'),\n1504:               stopReason: '{reason}',\n1505:               timestamp: '{ISO_8601_NOW}',\n1506:             });\n1507:           }\n1508:           EOF\n1509: \n1510:       step_writeback_spec_findings:\n1511:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1512:         edit: \"{spec_folder}/spec.md\"\n1513:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1514:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1515:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1516:         fail_closed_conflict_check:\n1517:           if_existing_generated_fence_present:\n1518:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1519:             on_manual_edit_conflict:\n1520:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1521:               halt: true\n1522:         instructions:\n1523:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1524:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1525:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1526:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1527:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1528:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1529: \n1530:       step_validate_post_synthesis_spec_doc:\n1531:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1532:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1533:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1534: \n1535:       step_update_config_status:\n1536:         action: \"Mark config as complete\"\n1537:         edit: \"{state_paths.config}\"\n1538:         set_field: { status: \"complete\" }\n1539: \n1540:       step_telemetry_heartbeat_terminal:\n1541:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1542:         skip_when: \"config.fanout is present\"\n1543:         terminal_events: [completed, failed, stopped]\n1544:         command: |\n1545:           node --experimental-strip-types --input-type=module <<'EOF'\n1546:           import { existsSync, readFileSync } from 'node:fs';\n1547: \n1548:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n1549:           import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n1550: \n1551:           const { appendObservabilityEvent } = observabilityEvents;\n1552:           const stateLogPath = '{state_paths.state_log}';\n1553:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1554:           const timestamp = '{ISO_8601_NOW}';\n1555:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1556:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1557:           const reason = '{reason}';\n1558:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1559: \n1560:           function readRecords(path) {\n1561:             if (!existsSync(path)) return [];\n1562:             return readFileSync(path, 'utf8')\n1563:               .split(/\\r?\\n/)\n1564:               .map((line) => line.trim())\n1565:               .filter(Boolean)\n1566:               .map((line) => JSON.parse(line));\n1567:           }\n1568: \n1569:           function elapsedSince(value) {\n1570:             const startedAtMs = Date.parse(String(value ?? ''));\n1571:             const nowMs = Date.parse(timestamp);\n1572:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1573:             return Math.max(0, nowMs - startedAtMs);\n1574:           }\n1575: \n1576:           function terminalEvent(stopReason) {\n1577:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1578:             if (stopReason === 'error') return 'failed';\n1579:             return 'completed';\n1580:           }\n1581: \n1582:           const records = readRecords(stateLogPath);\n1583:           const iterations = records.filter((record) => record.type === 'iteration');\n1584:           const latest = iterations.at(-1) ?? {};\n1585:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1586:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1587:             ?? timestamp;\n1588:           const elapsedMs = elapsedSince(startedAt);\n1589:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1590:           const event = terminalEvent(reason);\n1591:           const row = {\n1592:             event,\n1593:             label: 'single',\n1594:             terminal: true,\n1595:             reason,\n1596:             at: timestamp,\n1597:             duration_ms: elapsedMs,\n1598:             loop_type: 'research',\n1599:             sessionId,\n1600:             generation,\n1601:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1602:           };\n1603: \n1604:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1605:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1606:             diffField: 'state_hash',\n1607:           });\n1608:           if (appended) {\n1609:             try {\n1610:               appendObservabilityEvent(observabilityPath, row, {\n1611:                 producer: 'deep-research-auto',\n1612:                 stream: 'single-loop-telemetry',\n1613:                 subject: { label: row.label, sessionId, generation, reason },\n1614:                 event,\n1615:                 status: event,\n1616:               });\n1617:             } catch {}\n1618:           }\n1619:           EOF\n1620:         working_directory: \"{repo_root}\"\n1621:         outputs:\n1622:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1623: \n1624:       step_stage_artifact_dir:\n1625:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1626:         command: \"git add {state_paths.packet_dir}\"\n1627:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1628:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1629: \n1630:   # ═══════════════════════════════════════════════════════════════\n1631:   # PHASE 4: SAVE\n1632:   # ═══════════════════════════════════════════════════════════════\n1633:   phase_save:\n1634:     purpose: Preserve research context to memory system\n1635:     steps:\n1636: \n1637:       step_compose_save_payload:\n1638:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1639:         output: \"/tmp/save-context-data-<session-id>.json\"\n1640:         requirements:\n1641:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1642:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1643:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1644:         example_payload: |\n1645:           {\n1646:             \"specFolder\": \"{spec_folder}\",\n1647:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n1648:             \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n1649:             \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n1650:             \"exchanges\": [],\n1651:             \"toolCalls\": []\n1652:           }\n1653: \n1654:       step_generate_context:\n1655:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1656:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1657:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1658: \n1659:       step_index_memory:\n1660:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1661:         mcp_tool: memory_save\n1662:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1663:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1664: \n1665:       step_verify_save:\n1666:         action: \"Verify canonical save routed content into the correct spec document\"\n1667:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1668:         on_fail: \"Log warning but do not block completion\"\n1669: \n1670:       step_release_lock:\n1671:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1672:         command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1673:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1674: \n1675:   # ═══════════════════════════════════════════════════════════════\n1676:   # COMPLETION\n1677:   # ═══════════════════════════════════════════════════════════════\n1678:   completion:\n1679:     message: |\n1680:       Deep research complete.\n1681:       Iterations: {iteration_count} | Stop reason: {reason}\n1682:       Questions answered: {answered_count}/{total_questions}\n1683: \n1684:       Artifacts:\n1685:         - research/research.md (compiled from {iteration_count} iterations)\n1686:         - {iteration_count} iteration files in research/\n1687:         - State files: config.json, state.jsonl, strategy.md, deep-research-findings-registry.json, dashboard.md\n1688:         - Memory context saved\n1689: \n1690:       STATUS=OK PATH={spec_folder}\n1691:     next_steps:\n1692:       - \"/speckit:plan [feature-description]\"\n1693:       - \"/deep:research [new-topic] (for related deep research)\"\n1694:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1695: \n1696: # ─────────────────────────────────────────────────────────────────\n1697: # ERROR RECOVERY\n1698: # ─────────────────────────────────────────────────────────────────\n1699: error_recovery:\n1700:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n1701:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1702:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1703:   memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n1704: \n1705: # ─────────────────────────────────────────────────────────────────\n1706: # RULES\n1707: # ─────────────────────────────────────────────────────────────────\n1708: rules:\n1709:   ALWAYS:\n1710:     - follow_workflow_phases_in_order\n1711:     - dispatch_deep_research_agent_per_iteration\n1712:     - check_convergence_before_each_iteration\n1713:     - write_all_state_to_files\n1714:     - upsert_iteration_memory_after_reducer\n1715:     - refresh_memory_context_before_next_prompt\n1716:     - save_memory_context_after_synthesis\n1717:     - respect_max_iterations_cap\n1718:   NEVER:\n1719:     - skip_convergence_check\n1720:     - dispatch_non_leaf_agents\n1721:     - hold_iteration_findings_in_memory_only\n1722:     - modify_config_after_initialization\n1723:     - overwrite_jsonl_state_log\n1724:     - proceed_without_state_file_verification\n1725: \n1726: # ─────────────────────────────────────────────────────────────────\n1727: # REFERENCE-ONLY APPENDIX\n1728: # ─────────────────────────────────────────────────────────────────\n1729: reference_only_appendix:\n1730:   checkpoint_commit:\n1731:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n1732:     commands:\n1733:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n1734:       - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n1735:   wave_orchestration:\n1736:     note: \"Wave execution is intentionally excluded from workflow.steps.\"\n1737:     summary:\n1738:       - \"Check whether 3+ independent unanswered questions justify a wave.\"\n1739:       - \"Dispatch up to 3 parallel agents on distinct questions.\"\n1740:       - \"Score wave results by median newInfoRatio and promote top branches.\"\n\n(End of file - total 1740 lines)\n</content>","metadata":{"preview":"\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n            \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n            \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep research complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Questions answered: {answered_count}/{total_questions}\n\n      Artifacts:\n        - research/research.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in research/\n        - State files: config.json, state.jsonl, strategy.md, deep-research-findings-registry.json, dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [feature-description]\"\n      - \"/deep:research [new-topic] (for related deep research)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_research_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - upsert_iteration_memory_after_reducer\n    - refresh_memory_context_before_next_prompt\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n      - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n  wave_orchestration:\n    note: \"Wave execution is intentionally excluded from workflow.steps.\"\n    summary:\n      - \"Check whether 3+ independent unanswered questions justify a wave.\"\n      - \"Dispatch up to 3 parallel agents on distinct questions.\"\n      - \"Score wave results by median newInfoRatio and promote top branches.\"","lineStart":1385,"lineEnd":1740,"totalLines":1740,"truncated":false}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1783486586694,"end":1783486586705}},"metadata":{"openai":{"itemId":"fc_00b3422903209c59016a4dd879b6e48191b60e4439a984f696"}},"id":"prt_f40159b77001tzAFuPrRoZ3K44","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f4015934d001u7OLj1FH30RlfI"}}
