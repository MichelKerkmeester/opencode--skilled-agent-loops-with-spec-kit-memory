.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/002-implementation-deep-research/research/deltas/iter-006.jsonl:16:{"type":"finding","id":"f-iter006-015","severity":"P3","label":"EC-4: Concurrent loop-host execution — state log appends are uncoordinated; use run-specific state log paths","iteration":6}
.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/002-implementation-deep-research/research/deltas/iter-006.jsonl:17:{"type":"finding","id":"f-iter006-016","severity":"P1","label":"EC-5: materialize-benchmark-fixtures failure produces all-zero scores silently; caller must detect non-zero exit and propagate","iteration":6}
.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/002-implementation-deep-research/research/deltas/iter-006.jsonl:18:{"type":"finding","id":"f-iter006-017","severity":"P2","label":"EC-6: Score cache SHA256 key includes baselineContent; not applicable for model-benchmark; cache key must differ by mode to prevent cross-mode hits","iteration":6}
.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/002-implementation-deep-research/research/deltas/iter-006.jsonl:19:{"type":"finding","id":"f-iter006-018","severity":"P1","label":"EC-7: score-candidate infra_failure records currently lack evaluationMode/mode fields; build must add them","iteration":6}
.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/002-implementation-deep-research/research/deltas/iter-006.jsonl:20:{"type":"finding","id":"f-iter006-019","severity":"P1","label":"EC-8: promote-candidate expects score.status === 'scored'; for model-benchmark must check score.status === 'benchmark-complete' instead","iteration":6}
