\\",\\\"iteration\\\":1,\\\"id\\\":\\\"frozen-history\\\",\\\"summary\\\":\\\"Changelog and completed spec references retain legacy names as historical evidence and are not migration consumers.\\\",\\\"evidence\\\":[\\\".opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:56-64\\\",\\\".opencode/skills/sk-design/changelog/v1.6.0.0.md:14-20\\\"]}\\n+{\\\"type\\\":\\\"finding\\\",\\\"iteration\\\":1,\\\"id\\\":\\\"manifest-role-boundary\\\",\\\"summary\\\":\\\"The crawl manifest is capture lifecycle state; the retrieval manifest is a versioned enriched generation that records generationHash and crawlManifestHash, so schema richness alone does not establish canonical ownership.\\\",\\\"evidence\\\":[\\\".opencode/skills/sk-design/styles/_manifest.json:1-10\\\",\\\".opencode/skills/sk-design/styles/_retrieval-manifest.json:1-6\\\"]}\\n+{\\\"type\\\":\\\"finding\\\",\\\"iteration\\\":1,\\\"id\\\":\\\"cutover-sequence\\\",\\\"summary\\\":\\\"Use an atomic dependency-closure naming cutover with before/after parity, then perform manifest consolidation as a separate schema-bearing change.\\\",\\\"evidence\\\":[\\\"INFERENCE: complete direct-reference inventory plus independent naming and schema change dimensions\\\"]}\\n+{\\\"type\\\":\\\"ruled_out\\\",\\\"iteration\\\":1,\\\"direction\\\":\\\"Treat leading-underscore backend paths as exempt\\\",\\\"reason\\\":\\\"They are authored JavaScript and JSON filesystem names outside every canon exemption.\\\",\\\"evidence\\\":[\\\".opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:34-46\\\"]}\\n+{\\\"type\\\":\\\"ruled_out\\\",\\\"iteration\\\":1,\\\"direction\\\":\\\"Rewrite frozen history\\\",\\\"reason\\\":\\\"The canon requires changelogs and completed spec-folder history to retain historical names.\\\",\\\"evidence\\\":[\\\".opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:56-64\\\"]}\\n+{\\\"type\\\":\\\"ruled_out\\\",\\\"iteration\\\":1,\\\"direction\\\":\\\