   203	function renderAdvisorBrief(result, options = {}) {
   204	  if (result.status !== 'ok') return null;
   205	  if (result.freshness !== 'live' && result.freshness !== 'stale') return null;
   206	
   207	  const tokenCap = Math.min(Math.max(1, positiveInt(result.metrics?.tokenCap ?? options.tokenCap, 80)), 120);
   208	  const thresholdConfig = options.thresholdConfig ?? {};
   209	  const recommendations = Array.isArray(result.recommendations)
   210	    ? result.recommendations.filter((recommendation) => (
   211	      recommendation.passes_threshold === true
   212	      || (
   213	        recommendation.confidence >= (thresholdConfig.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)
   214	        && (
   215	          thresholdConfig.confidenceOnly === true
   216	          || recommendation.uncertainty <= (thresholdConfig.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD)
   217	        )
   218	      )
   219	    ))
   220	    : [];
   221	  const top = recommendations[0];
   222	  if (!top) return null;
   223	
   224	  const topLabel = sanitizeLabel(result.sharedPayload?.metadata?.skillLabel ?? top.skill);
   225	  if (!topLabel) return null;
   226	  const text = `Advisor: ${result.freshness}; use ${topLabel} ${formatScore(top.confidence)}/${formatScore(top.uncertainty)} pass.`;
   227	  const charCap = Math.min(tokenCap, 80) * 4;
   228	  return text.length <= charCap ? text : `${text.slice(0, Math.max(1, charCap - 3)).trimEnd()}...`;
   229	}
