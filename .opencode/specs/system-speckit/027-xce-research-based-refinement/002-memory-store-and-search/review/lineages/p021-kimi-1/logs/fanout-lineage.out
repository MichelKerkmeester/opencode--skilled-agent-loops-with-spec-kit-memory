= orphanChildPid) {\n            log('stale-reclaim deferred: lease childPid changed after acquiring respawn lock (replacement already present); reporting lease held');\n            releaseRespawnLockFile(staleRespawnLock);","lineStart":1670,"lineEnd":1719,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781717022562,"end":1781717022568}},"id":"prt_ed69c3353001qPsu3qn22F15tW","sessionID":"ses_129657aeaffeQXa5gHc4AV883g","messageID":"msg_ed69c0f430015KoMbQNRrzdJ0i"}}
