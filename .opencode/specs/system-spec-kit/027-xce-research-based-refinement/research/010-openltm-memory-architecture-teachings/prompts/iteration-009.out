.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts:\n  Line 51: const REQUIRED_TABLES: readonly string[] = ['memory_index', 'schema_version'];\n\n  Line 206:     ALTER TABLE embedding_cache RENAME TO embedding_cache_legacy_dimensions;\n\n  Line 255:     throw new Error(`${context}: expected index \"${indexName}\" to exist after migration`);\n\n  Line 331:   database.exec('ALTER TABLE memory_conflicts RENAME TO memory_conflicts_legacy');\n\n  Line 419: // Schema version for migration tracking\n\n  Line 438: // V23: One-time spec_folder re-canonicalization + session_state migration\n\n  Line 441: /** Current schema version for vector-index migrations. */\n\n  Line 449:  * index over those rows throws, and since all migrations share one transaction, the\n\n  Line 534: // Run schema migrations from one version to another\n\n  Line 535: // Each migration is idempotent - safe to run multiple times\n\n  Line 536: // BUG-019 FIX: Wrap migrations in transaction for atomicity\n\n  Line 538:  * Runs schema migrations between two schema versions.\n\n  Line 544: export function run_migrations(database: Database.Database, from_version: number, to_version: number): void {\n\n  Line 545:   const migrations: Record<number, () => void> = {\n\n  Line 563:         database.exec('ALTER TABLE memory_index ADD COLUMN related_memories TEXT');\n\n  Line 575:         { name: 'stability', sql: 'ALTER TABLE memory_index ADD COLUMN stability REAL DEFAULT 1.0' },\n\n  Line 576:         { name: 'difficulty', sql: 'ALTER TABLE memory_index ADD COLUMN difficulty REAL DEFAULT 5.0' },\n\n  Line 577:         { name: 'last_review', sql: 'ALTER TABLE memory_index ADD COLUMN last_review TEXT' },\n\n  Line 578:         { name: 'review_count', sql: 'ALTER TABLE memory_index ADD COLUMN review_count INTEGER DEFAULT 0' }\n\n  Line 621:           ALTER TABLE memory_index ADD COLUMN memory_type TEXT DEFAULT 'declarative'\n\n  Line 635:         database.exec('ALTER TABLE memory_index A