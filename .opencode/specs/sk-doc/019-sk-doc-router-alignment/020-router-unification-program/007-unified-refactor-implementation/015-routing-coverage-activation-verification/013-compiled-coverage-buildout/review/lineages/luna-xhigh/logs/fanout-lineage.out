{"type":"tool_use","timestamp":1784693203865,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_T60Vf3XCllC6jDB7VCr684AO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-routing-foundation.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-routing-foundation.vitest.ts</path>\n<type>file</type>\n<content>\n1: // Foundation invariants for compiled skill-routing:\n2: //   - eligibility (advisor hub set) never diverges from the engine-dispatch map\n3: //   - the tri-state flag is parsed identically at both runtime read sites\n4: //   - the resolver's per-hub default-on cohort covers all 7 promoted hubs (unset\n5: //     => compiled for those); the advisor's own enrichment cohort mirrors it\n6: //     exactly (same 7 hubs, unset => compiledRoute attached for those)\n7: //   - the status probe's causeCode separates drift from breakage\n8: //   - the promoted serving path reads nothing under .opencode/specs\n9: //   - a future spec-tree import is blocked by the durable guard\n10: \n11: import { fileURLToPath } from 'node:url';\n12: import { createRequire } from 'node:module';\n13: import { dirname, join } from 'node:path';\n14: import { mkdtempSync, mkdirSync, writeFileSync, rmSync } from 'node:fs';\n15: import { tmpdir } from 'node:os';\n16: import { execFileSync } from 'node:child_process';\n17: \n18: import {\n19:   COMPILED_ROUTING_HUBS,\n20:   DEFAULT_ON_HUBS as ADVISOR_DEFAULT_ON_HUBS,\n21:   parseCompiledRoutingFlagMode,\n22: } from '../skills/system-skill-advisor/mcp-server/lib/compiled-routing-flag';\n23: \n24: const requireCjs = createRequire(import.meta.url);\n25: const HERE = dirname(fileURLToPath(import.meta.url));\n26: const RUNTIME = join(HERE, 'lib', 'compiled-routing');\n27: \n28: const resolver = requireCjs(join(RUNTIME, '011-runtime-engine', 'lib', 'resolve.cjs'));\n29: const engine = requireCjs(join(RUNTIME, '011-runtime-engine', 'lib', 'compiled-route.cjs'));\n30: const status = requireCjs(join(HERE, 'compiled-route-status.cjs'));\n31: const scanner = requireCjs(join(HERE, 'check-no-spec-imports.cjs'));\n32: \n33: const FLAG = 'SPECKIT_COMPILED_ROUTING';\n34: function clearFlag() { delete process.env[FLAG]; }\n35: function setFlag(v: string) { process.env[FLAG] = v; }\n36: afterEach(() => clearFlag());\n37: \n38: describe('eligibility vs engine-dispatch split (cross-check)', () => {\n39:   it('sort(COMPILED_ROUTING_HUBS) === sort(keys(HUB_CHILD)); diverging hub named', () => {\n40:     const advisorHubs = [...COMPILED_ROUTING_HUBS].sort();\n41:     const engineHubs = Object.keys(engine.HUB_CHILD).sort();\n42:     const onlyInAdvisor = advisorHubs.filter((h) => !engineHubs.includes(h));\n43:     const onlyInEngine = engineHubs.filter((h) => !advisorHubs.includes(h));\n44:     // On divergence this reports exactly which hub is missing from which side.\n45:     expect({ onlyInAdvisor, onlyInEngine }).toEqual({ onlyInAdvisor: [], onlyInEngine: [] });\n46:     expect(advisorHubs).toEqual(engineHubs);\n47:   });\n48: });\n49: \n50: describe('flag tri-state truth-table (both read sites agree)', () => {\n51:   const table: Array<[string | undefined, string]> = [\n52:     [undefined, 'default'],\n53:     ['', 'default'],\n54:     ['1', 'force-on'],\n55:     ['0', 'force-legacy'],\n56:     ['false', 'force-legacy'],\n57:     ['off', 'force-legacy'],\n58:     ['2', 'invalid'],\n59:     ['yes', 'invalid'],\n60:     ['true', 'invalid'],\n61:     ['on', 'invalid'],\n62:   ];\n63:   for (const [raw, expected] of table) {\n64:     it(`flag=${JSON.stringify(raw)} => ${expected} in resolver and advisor`, () => {\n65:       expect(resolver.parseFlagMode(raw)).toBe(expected);\n66:       expect(parseCompiledRoutingFlagMode(raw)).toBe(expected);\n67:     });\n68:   }\n69: \n70:   it('resolver default-on cohort covers all 7 promoted hubs; advisor cohort mirrors it exactly', () => {\n71:     expect(resolver.DEFAULT_ON_HUBS.size).toBe(7);\n72:     expect(ADVISOR_DEFAULT_ON_HUBS.size).toBe(7);\n73:     expect([...ADVISOR_DEFAULT_ON_HUBS].sort()).toEqual([...resolver.DEFAULT_ON_HUBS].sort());\n74:   });\n75: \n76:   it('unset resolves to a compiled decision for every default-on hub — promoted-cohort default', () => {\n77:     clearFlag();\n78:     for (const hub of Object.keys(engine.HUB_CHILD)) {\n79:       const route = resolver.resolveRoute(hub, 'do the thing');\n80:       expect(route).not.toBeNull();\n81:       expect(route.hubId).toBe(hub);\n82:     }\n83:   });\n84: \n85:   it('kill-switch and invalid values also resolve legacy for every hub', () => {\n86:     for (const value of ['0', 'false', 'off', '2', 'yes']) {\n87:       setFlag(value);\n88:       for (const hub of Object.keys(engine.HUB_CHILD)) {\n89:         expect(resolver.resolveRoute(hub, 'do the thing')).toBeNull();\n90:       }\n91:     }\n92:   });\n93: \n94:   it('force-on serves a compiled decision for a real hub', () => {\n95:     setFlag('1');\n96:     const route = resolver.resolveRoute('sk-code', 'quality review of the code');\n97:     expect(route).not.toBeNull();\n98:     expect(route.hubId).toBe('sk-code');\n99:   });\n100: });\n101: \n102: describe('status causeCode matrix (drift vs breakage)', () => {\n103:   let tmp: string;\n104: \n105:   beforeAll(() => {\n106:     tmp = mkdtempSync(join(tmpdir(), 'cr-status-'));\n107:     const mk = (hub: string, manifest: unknown, fence: number) => {\n108:       const dir = join(tmp, hub);\n109:       mkdirSync(dir, { recursive: true });\n110:       writeFileSync(join(dir, 'manifest.json'), JSON.stringify(manifest));\n111:       writeFileSync(join(dir, 'fence-state.json'), JSON.stringify({ fencingEpoch: fence, schemaVersion: 'V1' }));\n112:     };\n113:     mk('legacy-hub', { schemaVersion: 'V1', selectedPolicy: { generation: 1 }, servingAuthority: 'legacy', shadowOnly: true }, 1);\n114:     mk('broken-hub', { schemaVersion: 'V1', selectedPolicy: { generation: 1, effectivePolicyHash: 'deadbeef' }, servingAuthority: 'compiled', shadowOnly: false }, 2);\n115:   });\n116: \n117:   afterAll(() => rmSync(tmp, { recursive: true, force: true }));\n118: \n119:   it(\"missing-manifest => legacy (expected drift)\", () => {\n120:     setFlag('1');\n121:     const r = status.computeHubStatus('ghost-hub', { activationRoot: tmp, probeEngine: true });\n122:     expect(r.causeCode).toBe('missing-manifest');\n123:     expect(r.servingAuthority).toBe('legacy');\n124:   });\n125: \n126:   it('legacy-authority => legacy (expected drift)', () => {\n127:     setFlag('1');\n128:     const r = status.computeHubStatus('legacy-hub', { activationRoot: tmp, probeEngine: true });\n129:     expect(r.causeCode).toBe('legacy-authority');\n130:     expect(r.servingAuthority).toBe('legacy');\n131:   });\n132: \n133:   it('flag-off => legacy (expected drift) when compiled manifest but flag not permitting', () => {\n134:     clearFlag();\n135:     const r = status.computeHubStatus('broken-hub', { activationRoot: tmp, probeEngine: false });\n136:     expect(r.causeCode).toBe('flag-off');\n137:     expect(r.servingAuthority).toBe('legacy');\n138:   });\n139: \n140:   it('engine-throw => legacy (BREAKAGE) when compiled+flag but the engine cannot route', () => {\n141:     setFlag('1');\n142:     const r = status.computeHubStatus('broken-hub', { activationRoot: tmp, probeEngine: true });\n143:     expect(r.causeCode).toBe('engine-throw');\n144:     expect(r.servingAuthority).toBe('legacy');\n145:   });\n146: \n147:   it('compiled-serving => compiled for a real promoted hub under force-on', () => {\n148:     setFlag('1');\n149:     const r = status.computeHubStatus('sk-code', { probeEngine: true });\n150:     expect(r.causeCode).toBe('compiled-serving');\n151:     expect(r.servingAuthority).toBe('compiled');\n152:     expect(typeof r.manifestFingerprint).toBe('string');\n153:     expect(r.selectedPolicy).toHaveProperty('generation');\n154:   });\n155: \n156:   it('--all default state reports every hub as compiled-serving, none broken', () => {\n157:     clearFlag();\n158:     const rows = status.computeAllStatus({ probeEngine: false });\n159:     expect(rows.length).toBe(Object.keys(engine.HUB_CHILD).length);\n160:     expect(rows.every((r: { causeCode: string }) => r.causeCode === 'compiled-serving')).toBe(true);\n161:     expect(rows.some((r: { causeCode: string }) => r.causeCode === 'engine-throw')).toBe(false);\n162:   });\n163: });\n164: \n165: describe('move-simulation: no runtime read under .opencode/specs', () => {\n166:   it('sync --verify reports all hubs resolve with 0 spec reads', () => {\n167:     const out = execFileSync(process.execPath, [join(HERE, 'compiled-route-sync.cjs'), '--verify'], { encoding: 'utf8' });\n168:     expect(out).toContain('0 reads under .opencode/specs');\n169:   });\n170: });\n171: \n172: describe('durable no-spec-import guard', () => {\n173:   it('flags the seeded spec-import fixture', () => {\n174:     const v = scanner.scanFile(join(HERE, 'tests', 'fixtures', 'no-spec-import', 'positive', 'seeded-spec-import.cjs'));\n175:     expect(v.length).toBeGreaterThan(0);\n176:   });\n177: \n178:   it('passes the clean runtime fixture', () => {\n179:     const v = scanner.scanFile(join(HERE, 'tests', 'fixtures', 'no-spec-import', 'negative', 'clean-runtime.cjs'));\n180:     expect(v).toEqual([]);\n181:   });\n182: });\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"// Foundation invariants for compiled skill-routing:\n//   - eligibility (advisor hub set) never diverges from the engine-dispatch map\n//   - the tri-state flag is parsed identically at both runtime read sites\n//   - the resolver's per-hub default-on cohort covers all 7 promoted hubs (unset\n//     => compiled for those); the advisor's own enrichment cohort mirrors it\n//     exactly (same 7 hubs, unset => compiledRoute attached for those)\n//   - the status probe's causeCode separates drift from breakage\n//   - the promoted serving path reads nothing under .opencode/specs\n//   - a future spec-tree import is blocked by the durable guard\n\nimport { fileURLToPath } from 'node:url';\nimport { createRequire } from 'node:module';\nimport { dirname, join } from 'node:path';\nimport { mkdtempSync, mkdirSync, writeFileSync, rmSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { execFileSync } from 'node:child_process';\n\nimport {\n  COMPILED_ROUTING_HUBS,\n  DEFAULT_ON_HUBS as ADVISOR_DEFAULT_ON_HUBS,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-routing-foundation.vitest.ts","text":"// Foundation invariants for compiled skill-routing:\n//   - eligibility (advisor hub set) never diverges from the engine-dispatch map\n//   - the tri-state flag is parsed identically at both runtime read sites\n//   - the resolver's per-hub default-on cohort covers all 7 promoted hubs (unset\n//     => compiled for those); the advisor's own enrichment cohort mirrors it\n//     exactly (same 7 hubs, unset => compiledRoute attached for those)\n//   - the status probe's causeCode separates drift from breakage\n//   - the promoted serving path reads nothing under .opencode/specs\n//   - a future spec-tree import is blocked by the durable guard\n\nimport { fileURLToPath } from 'node:url';\nimport { createRequire } from 'node:module';\nimport { dirname, join } from 'node:path';\nimport { mkdtempSync, mkdirSync, writeFileSync, rmSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { execFileSync } from 'node:child_process';\n\nimport {\n  COMPILED_ROUTING_HUBS,\n  DEFAULT_ON_HUBS as ADVISOR_DEFAULT_ON_HUBS,\n  parseCompiledRoutingFlagMode,\n} from '../skills/system-skill-advisor/mcp-server/lib/compiled-routing-flag';\n\nconst requireCjs = createRequire(import.meta.url);\nconst HERE = dirname(fileURLToPath(import.meta.url));\nconst RUNTIME = join(HERE, 'lib', 'compiled-routing');\n\nconst resolver = requireCjs(join(RUNTIME, '011-runtime-engine', 'lib', 'resolve.cjs'));\nconst engine = requireCjs(join(RUNTIME, '011-runtime-engine', 'lib', 'compiled-route.cjs'));\nconst status = requireCjs(join(HERE, 'compiled-route-status.cjs'));\nconst scanner = requireCjs(join(HERE, 'check-no-spec-imports.cjs'));\n\nconst FLAG = 'SPECKIT_COMPILED_ROUTING';\nfunction clearFlag() { delete process.env[FLAG]; }\nfunction setFlag(v: string) { process.env[FLAG] = v; }\nafterEach(() => clearFlag());\n\ndescribe('eligibility vs engine-dispatch split (cross-check)', () => {\n  it('sort(COMPILED_ROUTING_HUBS) === sort(keys(HUB_CHILD)); diverging hub named', () => {\n    const advisorHubs = [...COMPILED_ROUTING_HUBS].sort();\n    const engineHubs = Object.keys(engine.HUB_CHILD).sort();\n    const onlyInAdvisor = advisorHubs.filter((h) => !engineHubs.includes(h));\n    const onlyInEngine = engineHubs.filter((h) => !advisorHubs.includes(h));\n    // On divergence this reports exactly which hub is missing from which side.\n    expect({ onlyInAdvisor, onlyInEngine }).toEqual({ onlyInAdvisor: [], onlyInEngine: [] });\n    expect(advisorHubs).toEqual(engineHubs);\n  });\n});\n\ndescribe('flag tri-state truth-table (both read sites agree)', () => {\n  const table: Array<[string | undefined, string]> = [\n    [undefined, 'default'],\n    ['', 'default'],\n    ['1', 'force-on'],\n    ['0', 'force-legacy'],\n    ['false', 'force-legacy'],\n    ['off', 'force-legacy'],\n    ['2', 'invalid'],\n    ['yes', 'invalid'],\n    ['true', 'invalid'],\n    ['on', 'invalid'],\n  ];\n  for (const [raw, expected] of table) {\n    it(`flag=${JSON.stringify(raw)} => ${expected} in resolver and advisor`, () => {\n      expect(resolver.parseFlagMode(raw)).toBe(expected);\n      expect(parseCompiledRoutingFlagMode(raw)).toBe(expected);\n    });\n  }\n\n  it('resolver default-on cohort covers all 7 promoted hubs; advisor cohort mirrors it exactly', () => {\n    expect(resolver.DEFAULT_ON_HUBS.size).toBe(7);\n    expect(ADVISOR_DEFAULT_ON_HUBS.size).toBe(7);\n    expect([...ADVISOR_DEFAULT_ON_HUBS].sort()).toEqual([...resolver.DEFAULT_ON_HUBS].sort());\n  });\n\n  it('unset resolves to a compiled decision for every default-on hub — promoted-cohort default', () => {\n    clearFlag();\n    for (const hub of Object.keys(engine.HUB_CHILD)) {\n      const route = resolver.resolveRoute(hub, 'do the thing');\n      expect(route).not.toBeNull();\n      expect(route.hubId).toBe(hub);\n    }\n  });\n\n  it('kill-switch and invalid values also resolve legacy for every hub', () => {\n    for (const value of ['0', 'false', 'off', '2', 'yes']) {\n      setFlag(value);\n      for (const hub of Object.keys(engine.HUB_CHILD)) {\n        expect(resolver.resolveRoute(hub, 'do the thing')).toBeNull();\n      }\n    }\n  });\n\n  it('force-on serves a compiled decision for a real hub', () => {\n    setFlag('1');\n    const route = resolver.resolveRoute('sk-code', 'quality review of the code');\n    expect(route).not.toBeNull();\n    expect(route.hubId).toBe('sk-code');\n  });\n});\n\ndescribe('status causeCode matrix (drift vs breakage)', () => {\n  let tmp: string;\n\n  beforeAll(() => {\n    tmp = mkdtempSync(join(tmpdir(), 'cr-status-'));\n    const mk = (hub: string, manifest: unknown, fence: number) => {\n      const dir = join(tmp, hub);\n      mkdirSync(dir, { recursive: true });\n      writeFileSync(join(dir, 'manifest.json'), JSON.stringify(manifest));\n      writeFileSync(join(dir, 'fence-state.json'), JSON.stringify({ fencingEpoch: fence, schemaVersion: 'V1' }));\n    };\n    mk('legacy-hub', { schemaVersion: 'V1', selectedPolicy: { generation: 1 }, servingAuthority: 'legacy', shadowOnly: true }, 1);\n    mk('broken-hub', { schemaVersion: 'V1', selectedPolicy: { generation: 1, effectivePolicyHash: 'deadbeef' }, servingAuthority: 'compiled', shadowOnly: false }, 2);\n  });\n\n  afterAll(() => rmSync(tmp, { recursive: true, force: true }));\n\n  it(\"missing-manifest => legacy (expected drift)\", () => {\n    setFlag('1');\n    const r = status.computeHubStatus('ghost-hub', { activationRoot: tmp, probeEngine: true });\n    expect(r.causeCode).toBe('missing-manifest');\n    expect(r.servingAuthority).toBe('legacy');\n  });\n\n  it('legacy-authority => legacy (expected drift)', () => {\n    setFlag('1');\n    const r = status.computeHubStatus('legacy-hub', { activationRoot: tmp, probeEngine: true });\n    expect(r.causeCode).toBe('legacy-authority');\n    expect(r.servingAuthority).toBe('legacy');\n  });\n\n  it('flag-off => legacy (expected drift) when compiled manifest but flag not permitting', () => {\n    clearFlag();\n    const r = status.computeHubStatus('broken-hub', { activationRoot: tmp, probeEngine: false });\n    expect(r.causeCode).toBe('flag-off');\n    expect(r.servingAuthority).toBe('legacy');\n  });\n\n  it('engine-throw => legacy (BREAKAGE) when compiled+flag but the engine cannot route', () => {\n    setFlag('1');\n    const r = status.computeHubStatus('broken-hub', { activationRoot: tmp, probeEngine: true });\n    expect(r.causeCode).toBe('engine-throw');\n    expect(r.servingAuthority).toBe('legacy');\n  });\n\n  it('compiled-serving => compiled for a real promoted hub under force-on', () => {\n    setFlag('1');\n    const r = status.computeHubStatus('sk-code', { probeEngine: true });\n    expect(r.causeCode).toBe('compiled-serving');\n    expect(r.servingAuthority).toBe('compiled');\n    expect(typeof r.manifestFingerprint).toBe('string');\n    expect(r.selectedPolicy).toHaveProperty('generation');\n  });\n\n  it('--all default state reports every hub as compiled-serving, none broken', () => {\n    clearFlag();\n    const rows = status.computeAllStatus({ probeEngine: false });\n    expect(rows.length).toBe(Object.keys(engine.HUB_CHILD).length);\n    expect(rows.every((r: { causeCode: string }) => r.causeCode === 'compiled-serving')).toBe(true);\n    expect(rows.some((r: { causeCode: string }) => r.causeCode === 'engine-throw')).toBe(false);\n  });\n});\n\ndescribe('move-simulation: no runtime read under .opencode/specs', () => {\n  it('sync --verify reports all hubs resolve with 0 spec reads', () => {\n    const out = execFileSync(process.execPath, [join(HERE, 'compiled-route-sync.cjs'), '--verify'], { encoding: 'utf8' });\n    expect(out).toContain('0 reads under .opencode/specs');\n  });\n});\n\ndescribe('durable no-spec-import guard', () => {\n  it('flags the seeded spec-import fixture', () => {\n    const v = scanner.scanFile(join(HERE, 'tests', 'fixtures', 'no-spec-import', 'positive', 'seeded-spec-import.cjs'));\n    expect(v.length).toBeGreaterThan(0);\n  });\n\n  it('passes the clean runtime fixture', () => {\n    const v = scanner.scanFile(join(HERE, 'tests', 'fixtures', 'no-spec-import', 'negative', 'clean-runtime.cjs'));\n    expect(v).toEqual([]);\n  });\n});","lineStart":1,"lineEnd":182,"totalLines":182,"truncated":false}},"title":".opencode/bin/compiled-routing-foundation.vitest.ts","time":{"start":1784693203856,"end":1784693203863}},"metadata":{"openai":{"itemId":"fc_058e02c9679192ec016a6041d3098c8191bda30e037d7e2c3f"}},"id":"prt_f8801206f001e11aEXxUpYYpkd","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f88010987001tQEcQFSgcBkt6Y"}}
