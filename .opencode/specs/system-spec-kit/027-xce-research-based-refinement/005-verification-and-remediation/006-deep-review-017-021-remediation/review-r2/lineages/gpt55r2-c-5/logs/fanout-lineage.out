{"type":"tool_use","timestamp":1781762639965,"sessionID":"ses_126ae8584ffeIHNv72WQpy5bXJ","part":{"type":"tool","tool":"read","callID":"call_yIfBIrkeEFk2pRgULVmDKk5y","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ---------------------------------------------------------------\n3: // MODULE: Spec Memory CLI\n4: // ---------------------------------------------------------------\n5: // Daemon-backed command line client for the mk-spec-memory tool\n6: // surface. The CLI is intentionally IPC-only: all persistence remains\n7: // owned by the already-running context server daemon.\n8: \n9: import { spawn } from 'node:child_process';\n10: import { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\n11: import net from 'node:net';\n12: import { createRequire } from 'node:module';\n13: import path from 'node:path';\n14: import { StringDecoder } from 'node:string_decoder';\n15: import { fileURLToPath } from 'node:url';\n16: \n17: import {\n18:   TOOL_DEFINITIONS,\n19:   type ToolDefinition,\n20:   ToolSchemaValidationError,\n21:   validateToolArgs,\n22: } from './tool-schemas.js';\n23: \n24: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n25: const DEFAULT_TIMEOUT_MS = 30_000;\n26: const DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\n27: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n28: const RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n29: \n30: const EXIT_SUCCESS = 0;\n31: const EXIT_RUNTIME = 1;\n32: const EXIT_USAGE = 64;\n33: const EXIT_PROTOCOL = 69;\n34: const EXIT_RETRYABLE = 75;\n35: \n36: type OutputFormat = 'json' | 'text' | 'jsonl';\n37: type ToolListMode = 'full' | 'compact' | 'names-only';\n38: type CompletionShell = 'bash' | 'zsh';\n39: \n40: interface ParsedCommand {\n41:   readonly command: string;\n42:   readonly format: OutputFormat;\n43:   readonly timeoutMs: number;\n44:   readonly sessionId?: string;\n45:   readonly warmOnly: boolean;\n46:   readonly toolListMode: ToolListMode;\n47:   readonly completionShell?: CompletionShell;\n48:   readonly args: Record<string, unknown>;\n49:   readonly help: boolean;\n50:   readonly version: boolean;\n51: }\n52: \n53: interface CliIo {\n54:   readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n55:   readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n56: }\n57: \n58: interface RepoPaths {\n59:   readonly opencodeDir: string;\n60:   readonly repoRoot: string;\n61:   readonly launcherPath: string;\n62:   readonly bridgePath: string;\n63:   readonly dbDir: string;\n64:   readonly packageJsonPath: string;\n65: }\n66: \n67: interface BridgeProbeResult {\n68:   readonly status: string;\n69:   readonly reason?: string;\n70: }\n71: \n72: interface BridgeModule {\n73:   readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n74:   readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n75:   readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n76: }\n77: \n78: interface JsonRpcResponse {\n79:   readonly jsonrpc?: string;\n80:   readonly id?: unknown;\n81:   readonly result?: unknown;\n82:   readonly error?: {\n83:     readonly code?: number;\n84:     readonly message?: string;\n85:     readonly data?: unknown;\n86:   };\n87: }\n88: \n89: interface InitializeResult {\n90:   readonly protocolVersion?: string;\n91: }\n92: \n93: interface ToolResult {\n94:   readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n95:   readonly isError?: boolean;\n96: }\n97: \n98: class CliUsageError extends Error {\n99:   constructor(message: string) {\n100:     super(message);\n101:     this.name = 'CliUsageError';\n102:   }\n103: }\n104: \n105: class CliRetryableError extends Error {\n106:   constructor(message: string) {\n107:     super(message);\n108:     this.name = 'CliRetryableError';\n109:   }\n110: }\n111: \n112: class CliProtocolError extends Error {\n113:   constructor(message: string) {\n114:     super(message);\n115:     this.name = 'CliProtocolError';\n116:   }\n117: }\n118: \n119: class JsonRpcError extends Error {\n120:   public readonly code?: number;\n121:   public readonly data?: unknown;\n122: \n123:   constructor(error: NonNullable<JsonRpcResponse['error']>) {\n124:     super(error.message ?? 'JSON-RPC request failed');\n125:     this.name = 'JsonRpcError';\n126:     this.code = error.code;\n127:     this.data = error.data;\n128:   }\n129: }\n130: \n131: // Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n132: // write followed by process.exit() truncates large payloads at the pipe\n133: // buffer boundary (observed as exactly 64KB on darwin). Streams without\n134: // emitter methods (test fakes) resolve immediately.\n135: async function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n136:   const flushed = stream.write(`${value}\\n`);\n137:   if (flushed) return;\n138:   const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n139:   if (typeof drainable.once !== 'function') return;\n140:   await new Promise<void>((resolve) => {\n141:     const settle = (): void => {\n142:       drainable.off?.('drain', settle);\n143:       drainable.off?.('error', settle);\n144:       drainable.off?.('close', settle);\n145:       resolve();\n146:     };\n147:     drainable.once?.('drain', settle);\n148:     drainable.once?.('error', settle);\n149:     drainable.once?.('close', settle);\n150:   });\n151: }\n152: \n153: function currentModulePath(): string {\n154:   return fileURLToPath(import.meta.url);\n155: }\n156: \n157: function findRepoPaths(startFile = currentModulePath()): RepoPaths {\n158:   let current = path.dirname(startFile);\n159: \n160:   while (true) {\n161:     const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n162:     const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n163:     const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n164:     if (existsSync(launcherPath) && existsSync(bridgePath)) {\n165:       const repoRoot = path.dirname(directOpencodeDir);\n166:       return {\n167:         opencodeDir: directOpencodeDir,\n168:         repoRoot,\n169:         launcherPath,\n170:         bridgePath,\n171:         dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n172:         packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n173:       };\n174:     }\n175: \n176:     const parent = path.dirname(current);\n177:     if (parent === current) {\n178:       throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n179:     }\n180:     current = parent;\n181:   }\n182: }\n183: \n184: function loadBridge(paths: RepoPaths): BridgeModule {\n185:   const require = createRequire(import.meta.url);\n186:   return require(paths.bridgePath) as BridgeModule;\n187: }\n188: \n189: function readCliVersion(paths: RepoPaths): string {\n190:   const require = createRequire(import.meta.url);\n191:   const pkg = require(paths.packageJsonPath) as { version?: unknown };\n192:   return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n193: }\n194: \n195: function toKebabCommand(name: string): string {\n196:   return name.replace(/_/g, '-');\n197: }\n198: \n199: function toCamelCommand(name: string): string {\n200:   return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n201: }\n202: \n203: function commandAliases(name: string): string[] {\n204:   return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n205: }\n206: \n207: function usageText(command?: string): string {\n208:   const tool = command ? getToolDefinition(command) : null;\n209:   if (tool) {\n210:     return `spec-memory ${tool.name}\n211: \n212: Description:\n213:   ${tool.description}\n214: \n215: Aliases:\n216:   ${commandAliases(tool.name).join(', ')}\n217: \n218: Input schema:\n219: ${JSON.stringify(tool.inputSchema, null, 2)}`;\n220:   }\n221: \n222:   return `spec-memory - daemon-backed CLI for mk-spec-memory\n223: \n224: Usage:\n225:   spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n226:   spec-memory completion bash|zsh\n227:   spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n228:   spec-memory <tool_name> --param value [--another-param value]\n229: \n230: Examples:\n231:   spec-memory list-tools --format text\n232:   spec-memory list-tools --compact\n233:   spec-memory completion zsh\n234:   spec-memory memory_stats --format json\n235:   spec-memory memory_search --query \"gold query battery\" --limit 3\n236:   spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n237: \n238: Exit codes:\n239:   0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n240: \n241: Exit 69 recovery:\n242:   - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n243:     - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n244:     - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n245: }\n246: \n247: function parseCompletionShell(raw: string): CompletionShell {\n248:   if (raw === 'bash' || raw === 'zsh') return raw;\n249:   throw new CliUsageError('completion shell must be one of: bash, zsh');\n250: }\n251: \n252: function normalizeName(value: string): string {\n253:   return value.replace(/[-_]/g, '').toLowerCase();\n254: }\n255: \n256: function toCamelCaseFlag(value: string): string {\n257:   return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n258: }\n259: \n260: function commandMap(): Map<string, ToolDefinition> {\n261:   const map = new Map<string, ToolDefinition>();\n262:   for (const tool of TOOL_DEFINITIONS) {\n263:     for (const alias of commandAliases(tool.name)) {\n264:       const existing = map.get(alias);\n265:       if (existing && existing.name !== tool.name) {\n266:         throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n267:       }\n268:       map.set(alias, tool);\n269:     }\n270:   }\n271:   return map;\n272: }\n273: \n274: function getToolDefinition(command: string): ToolDefinition | null {\n275:   return commandMap().get(command) ?? null;\n276: }\n277: \n278: function inputPropertyNames(tool: ToolDefinition): string[] {\n279:   const schema = tool.inputSchema;\n280:   const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n281:     ? (schema as { readonly properties?: unknown }).properties\n282:     : null;\n283:   if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n284:   return Object.keys(properties);\n285: }\n286: \n287: function resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n288:   const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n289:   if (exact) return exact;\n290: \n291:   const normalized = normalizeName(rawFlag);\n292:   const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n293:   if (matched) return matched;\n294: \n295:   return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n296: }\n297: \n298: function parseValue(raw: string): unknown {\n299:   const trimmed = raw.trim();\n300:   if (trimmed === 'true') return true;\n301:   if (trimmed === 'false') return false;\n302:   if (trimmed === 'null') return null;\n303:   if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n304:     try {\n305:       return JSON.parse(trimmed) as unknown;\n306:     } catch (error: unknown) {\n307:       const message = error instanceof Error ? error.message : String(error);\n308:       throw new CliUsageError(`Invalid JSON value: ${message}`);\n309:     }\n310:   }\n311:   return raw;\n312: }\n313: \n314: function parsePositiveInteger(raw: string, flagName: string): number {\n315:   if (!/^\\d+$/.test(raw)) {\n316:     throw new CliUsageError(`${flagName} must be a positive integer`);\n317:   }\n318:   const value = Number.parseInt(raw, 10);\n319:   if (!Number.isFinite(value) || value <= 0) {\n320:     throw new CliUsageError(`${flagName} must be a positive integer`);\n321:   }\n322:   return value;\n323: }\n324: \n325: function parseFormat(raw: string): OutputFormat {\n326:   if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n327:   throw new CliUsageError('--format must be one of: json, text, jsonl');\n328: }\n329: \n330: function parseInlineBoolean(raw: string, flagName: string): boolean {\n331:   if (raw === 'true' || raw === '1') return true;\n332:   if (raw === 'false' || raw === '0') return false;\n333:   throw new CliUsageError(`${flagName} must be true or false`);\n334: }\n335: \n336: function readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n337:   const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n338:   if (inline) return { value: inline[1], nextIndex: index + 1 };\n339:   const value = tokens[index + 1];\n340:   if (value === undefined) {\n341:     throw new CliUsageError(`${flagName} requires a value`);\n342:   }\n343:   return { value, nextIndex: index + 2 };\n344: }\n345: \n346: function parseJsonObject(raw: string): Record<string, unknown> {\n347:   let parsed: unknown;\n348:   try {\n349:     parsed = JSON.parse(raw) as unknown;\n350:   } catch (error: unknown) {\n351:     const message = error instanceof Error ? error.message : String(error);\n352:     throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n353:   }\n354:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n355:     throw new CliUsageError('--json must be a JSON object');\n356:   }\n357:   return parsed as Record<string, unknown>;\n358: }\n359: \n360: function envFlagEnabled(name: string): boolean {\n361:   const raw = process.env[name];\n362:   if (raw === undefined || raw === null) return false;\n363:   return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n364: }\n365: \n366: function defaultWarmOnly(): boolean {\n367:   return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n368:     || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n369:     || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n370:     || envFlagEnabled('OPENCODE_PROMPT_TIME')\n371:     || envFlagEnabled('CODEX_PROMPT_TIME')\n372:     || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n373: }\n374: \n375: export function parseCliArgs(argv: string[]): ParsedCommand {\n376:   const command = argv[0];\n377:   const warmOnlyDefault = defaultWarmOnly();\n378:   if (!command || command === '--help' || command === '-h') {\n379:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n380:   }\n381:   if (command === '--version' || command === '-v') {\n382:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n383:   }\n384: \n385:   let format: OutputFormat = 'json';\n386:   let timeoutMs = DEFAULT_TIMEOUT_MS;\n387:   let sessionId: string | undefined;\n388:   let warmOnly = warmOnlyDefault;\n389:   let toolListMode: ToolListMode = 'full';\n390:   let completionShell: CompletionShell | undefined;\n391:   let jsonPayload: Record<string, unknown> | null = null;\n392:   const tool = getToolDefinition(command);\n393:   const parsedArgs: Record<string, unknown> = {};\n394:   const tokens = argv.slice(1);\n395:   let index = 0;\n396: \n397:   while (index < tokens.length) {\n398:     const token = tokens[index];\n399:     if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n400:       completionShell = parseCompletionShell(token);\n401:       index += 1;\n402:       continue;\n403:     }\n404:     if (!token.startsWith('--')) {\n405:       throw new CliUsageError(`Unexpected positional argument: ${token}`);\n406:     }\n407:     const rawFlag = token.slice(2).split('=', 1)[0];\n408:     const option = `--${rawFlag}`;\n409: \n410:     if (rawFlag === 'help' || rawFlag === 'h') {\n411:       return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n412:     }\n413:     if (rawFlag === 'format') {\n414:       const read = readOptionValue(tokens, index, option);\n415:       format = parseFormat(read.value);\n416:       index = read.nextIndex;\n417:       continue;\n418:     }\n419:     if (rawFlag === 'timeout-ms') {\n420:       const read = readOptionValue(tokens, index, option);\n421:       timeoutMs = parsePositiveInteger(read.value, option);\n422:       index = read.nextIndex;\n423:       continue;\n424:     }\n425:     if (rawFlag === 'session-id') {\n426:       const read = readOptionValue(tokens, index, option);\n427:       sessionId = read.value;\n428:       index = read.nextIndex;\n429:       continue;\n430:     }\n431:     if (rawFlag === 'warm-only') {\n432:       const inline = token.match(/^--[^=]+=(.*)$/);\n433:       warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n434:       index += 1;\n435:       continue;\n436:     }\n437:     if (rawFlag === 'no-warm-only') {\n438:       warmOnly = false;\n439:       index += 1;\n440:       continue;\n441:     }\n442:     if (rawFlag === 'compact') {\n443:       toolListMode = 'compact';\n444:       index += 1;\n445:       continue;\n446:     }\n447:     if (rawFlag === 'names-only') {\n448:       toolListMode = 'names-only';\n449:       index += 1;\n450:       continue;\n451:     }\n452:     if (rawFlag === 'json') {\n453:       const read = readOptionValue(tokens, index, option);\n454:       jsonPayload = parseJsonObject(read.value);\n455:       index = read.nextIndex;\n456:       continue;\n457:     }\n458: \n459:     if (!tool) {\n460:       throw new CliUsageError(`Unknown command: ${command}`);\n461:     }\n462: \n463:     const propertyName = resolvePropertyName(rawFlag, tool);\n464:     const inline = token.match(/^--[^=]+=(.*)$/);\n465:     if (inline) {\n466:       parsedArgs[propertyName] = parseValue(inline[1]);\n467:       index += 1;\n468:       continue;\n469:     }\n470: \n471:     const next = tokens[index + 1];\n472:     if (next === undefined || next.startsWith('--')) {\n473:       parsedArgs[propertyName] = true;\n474:       index += 1;\n475:       continue;\n476:     }\n477:     parsedArgs[propertyName] = parseValue(next);\n478:     index += 2;\n479:   }\n480: \n481:   if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n482:     throw new CliUsageError('--json cannot be combined with per-parameter flags');\n483:   }\n484: \n485:   return {\n486:     command,\n487:     format,\n488:     timeoutMs,\n489:     sessionId,\n490:     warmOnly,\n491:     toolListMode,\n492:     completionShell,\n493:     args: jsonPayload ?? parsedArgs,\n494:     help: false,\n495:     version: false,\n496:   };\n497: }\n498: \n499: function validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n500:   if (RESERVED_COMMANDS.has(parsed.command)) return null;\n501:   const tool = getToolDefinition(parsed.command);\n502:   if (!tool) {\n503:     throw new CliUsageError(`Unknown command: ${parsed.command}`);\n504:   }\n505: \n506:   const args = { ...parsed.args };\n507:   const properties = new Set(inputPropertyNames(tool));\n508:   if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n509:     args.sessionId = parsed.sessionId;\n510:   } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n511:     args.session_id = parsed.sessionId;\n512:   }\n513: \n514:   return {\n515:     tool,\n516:     args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n517:   };\n518: }\n519: \n520: function renderJson(value: unknown, format: OutputFormat): string {\n521:   if (format === 'jsonl') return JSON.stringify(value);\n522:   return JSON.stringify(value, null, 2);\n523: }\n524: \n525: function compactTool(tool: ToolDefinition): Record<string, unknown> {\n526:   return {\n527:     name: tool.name,\n528:     command: tool.name,\n529:     kebabCommand: toKebabCommand(tool.name),\n530:     camelCommand: toCamelCommand(tool.name),\n531:     aliases: commandAliases(tool.name),\n532:     description: tool.description,\n533:   };\n534: }\n535: \n536: function renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n537:   const payload = {\n538:     status: 'ok',\n539:     data: {\n540:       count: TOOL_DEFINITIONS.length,\n541:       mode,\n542:       tools: TOOL_DEFINITIONS.map((tool) => ({\n543:         name: tool.name,\n544:         command: tool.name,\n545:         kebabCommand: toKebabCommand(tool.name),\n546:         camelCommand: toCamelCommand(tool.name),\n547:         aliases: commandAliases(tool.name),\n548:         description: tool.description,\n549:         inputSchema: tool.inputSchema,\n550:       })),\n551:     },\n552:   };\n553:   const compactPayload = {\n554:     status: 'ok',\n555:     data: {\n556:       count: TOOL_DEFINITIONS.length,\n557:       mode,\n558:       tools: TOOL_DEFINITIONS.map(compactTool),\n559:     },\n560:   };\n561:   const namesOnlyPayload = {\n562:     status: 'ok',\n563:     data: {\n564:       count: TOOL_DEFINITIONS.length,\n565:       mode,\n566:       names: TOOL_DEFINITIONS.map((tool) => tool.name),\n567:     },\n568:   };\n569: \n570:   if (format === 'text') {\n571:     return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n572:   }\n573:   if (mode === 'compact') return renderJson(compactPayload, format);\n574:   if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n575:   return renderJson(payload, format);\n576: }\n577: \n578: function completionWords(): string[] {\n579:   return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n580: }\n581: \n582: function shellWords(words: readonly string[]): string {\n583:   return words.join(' ');\n584: }\n585: \n586: function renderBashCompletion(): string {\n587:   const commands = shellWords(completionWords());\n588:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n589:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n590:   return `_spec_memory_completion() {\n591:   local cur\n592:   COMPREPLY=()\n593:   cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n594:   if [[ \\${COMP_CWORD} -eq 1 ]]; then\n595:     COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n596:     return 0\n597:   fi\n598:   case \"\\${COMP_WORDS[1]}\" in\n599:     completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n600:     list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n601:     *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n602:   esac\n603: }\n604: complete -F _spec_memory_completion spec-memory`;\n605: }\n606: \n607: function renderZshCompletion(): string {\n608:   const commands = shellWords(completionWords());\n609:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n610:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n611:   return `#compdef spec-memory\n612: _spec_memory() {\n613:   local -a commands common_flags list_flags shells\n614:   commands=(${commands})\n615:   common_flags=(${commonFlags})\n616:   list_flags=(${listFlags})\n617:   shells=(bash zsh)\n618:   if (( CURRENT == 2 )); then\n619:     _describe 'commands' commands\n620:     return\n621:   fi\n622:   case \\${words[2]} in\n623:     completion) _describe 'shells' shells ;;\n624:     list-tools) _describe 'flags' list_flags ;;\n625:     *) _describe 'flags' common_flags ;;\n626:   esac\n627: }\n628: _spec_memory \"$@\"`;\n629: }\n630: \n631: function renderCompletion(shell: CompletionShell): string {\n632:   return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n633: }\n634: \n635: function isErrorPayload(payload: unknown): boolean {\n636:   return Boolean(payload)\n637:     && typeof payload === 'object'\n638:     && !Array.isArray(payload)\n639:     && (payload as { readonly status?: unknown }).status === 'error';\n640: }\n641: \n642: function extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n643:   const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n644:   const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n645:   if (firstText) {\n646:     try {\n647:       return {\n648:         payload: JSON.parse(firstText) as unknown,\n649:         isError: toolResult?.isError === true,\n650:       };\n651:     } catch {\n652:       return {\n653:         payload: {\n654:           status: toolResult?.isError ? 'error' : 'ok',\n655:           tool: toolName,\n656:           text: firstText,\n657:         },\n658:         isError: toolResult?.isError === true,\n659:       };\n660:     }\n661:   }\n662:   return {\n663:     payload: {\n664:       status: toolResult?.isError ? 'error' : 'ok',\n665:       tool: toolName,\n666:       result,\n667:     },\n668:     isError: toolResult?.isError === true,\n669:   };\n670: }\n671: \n672: function renderPayload(payload: unknown, format: OutputFormat): string {\n673:   if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n674:   if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n675:     const record = payload as Record<string, unknown>;\n676:     if (typeof record.summary === 'string') return record.summary;\n677:     if (typeof record.error === 'string') return record.error;\n678:     if (typeof record.message === 'string') return record.message;\n679:   }\n680:   return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n681: }\n682: \n683: function isProtocolMismatch(error: unknown): boolean {\n684:   if (error instanceof JsonRpcError && error.code === -32002) return true;\n685:   const message = error instanceof Error ? error.message : String(error);\n686:   return /protocol.*(mismatch|changed|version)/i.test(message);\n687: }\n688: \n689: function isRetryableError(error: unknown): boolean {\n690:   if (error instanceof CliRetryableError) return true;\n691:   if (error instanceof JsonRpcError && error.code === -32001) return true;\n692:   const message = error instanceof Error ? error.message : String(error);\n693:   return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n694: }\n695: \n696: function exitCodeForError(error: unknown): number {\n697:   if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n698:   if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n699:   if (isRetryableError(error)) return EXIT_RETRYABLE;\n700:   if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n701:   return EXIT_RUNTIME;\n702: }\n703: \n704: function levenshteinDistance(left: string, right: string): number {\n705:   const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n706:   const current = new Array<number>(right.length + 1);\n707: \n708:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n709:     current[0] = leftIndex;\n710:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n711:       const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n712:       current[rightIndex] = Math.min(\n713:         current[rightIndex - 1] + 1,\n714:         previous[rightIndex] + 1,\n715:         previous[rightIndex - 1] + cost,\n716:       );\n717:     }\n718:     previous.splice(0, previous.length, ...current);\n719:   }\n720: \n721:   return previous[right.length];\n722: }\n723: \n724: function closestCommand(command: string): string | undefined {\n725:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n726:   targets.set('completion', 'completion');\n727:   for (const tool of TOOL_DEFINITIONS) {\n728:     for (const alias of commandAliases(tool.name)) {\n729:       targets.set(alias, tool.name);\n730:     }\n731:   }\n732: \n733:   let best: { readonly command: string; readonly distance: number } | null = null;\n734:   for (const [alias, canonical] of targets) {\n735:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n736:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n737:       best = { command: canonical, distance };\n738:     }\n739:   }\n740: \n741:   if (!best) return undefined;\n742:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n743:   return best.distance <= threshold ? best.command : undefined;\n744: }\n745: \n746: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n747:   const match = message.match(/^Unknown command: (.+)$/);\n748:   if (!match) return null;\n749:   return {\n750:     hint: 'Try `list-tools` to see available commands.',\n751:     suggestion: closestCommand(match[1]),\n752:   };\n753: }\n754: \n755: function socketPathTooLong(socketPath: string): boolean {\n756:   if (socketPath.startsWith('tcp://')) return false;\n757:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n758: }\n759: \n760: // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n761: // (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n762: // mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n763: // a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n764: // symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\n765: function assertSocketPerimeter(socketDir: string): void {\n766:   const dirLink = lstatSync(socketDir);\n767:   if (dirLink.isSymbolicLink()) {\n768:     throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n769:   }\n770:   const dirStat = statSync(socketDir);\n771:   const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n772:   if (uid !== null && dirStat.uid !== uid) {\n773:     throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n774:   }\n775:   if ((dirStat.mode & 0o022) !== 0) {\n776:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n777:   }\n778:   const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n779:   let nodeLink;\n780:   try {\n781:     nodeLink = lstatSync(socketPath);\n782:   } catch (error: unknown) {\n783:     const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n784:     if (code === 'ENOENT') return;\n785:     throw error;\n786:   }\n787:   if (nodeLink.isSymbolicLink()) {\n788:     throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n789:   }\n790:   if (uid !== null && nodeLink.uid !== uid) {\n791:     throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n792:   }\n793: }\n794: \n795: function ensureSocketEnvironment(): void {\n796:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n797:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n798:   }\n799:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n800:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n801:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n802:   assertSocketPerimeter(socketDir);\n803: }\n804: \n805: function sleep(ms: number): Promise<void> {\n806:   return new Promise((resolve) => setTimeout(resolve, ms));\n807: }\n808: \n809: function spawnLauncher(paths: RepoPaths): void {\n810:   const child = spawn(process.execPath, [paths.launcherPath], {\n811:     cwd: paths.repoRoot,\n812:     env: process.env,\n813:     detached: true,\n814:     stdio: 'ignore',\n815:   });\n816:   child.unref();\n817: }\n818: \n819: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n820:   const deadline = Date.now() + timeoutMs;\n821:   let lastReason = 'not probed';\n822: \n823:   while (Date.now() <= deadline) {\n824:     const remaining = Math.max(1, deadline - Date.now());\n825:     const probe = await bridge.probeDaemon(socketPath, {\n826:       timeoutMs: Math.min(remaining, 5000),\n827:       deepProbe: true,\n828:     });\n829:     if (probe.status === 'alive') return;\n830:     lastReason = probe.reason ?? probe.status;\n831:     await sleep(100);\n832:   }\n833: \n834:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n835: }\n836: \n837: class JsonRpcSocketClient {\n838:   private nextId = 1;\n839:   private readonly decoder = new StringDecoder('utf8');\n840: \n841:   private constructor(\n842:     private readonly socket: net.Socket,\n843:   ) {}\n844: \n845:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n846:     return new Promise((resolve, reject) => {\n847:       let socket: net.Socket;\n848:       let settled = false;\n849:       const finish = (error?: Error): void => {\n850:         if (settled) return;\n851:         settled = true;\n852:         clearTimeout(timer);\n853:         socket.off?.('connect', onConnect);\n854:         socket.off?.('error', onError);\n855:         if (error) {\n856:           socket.destroy?.();\n857:           reject(error);\n858:           return;\n859:         }\n860:         resolve(new JsonRpcSocketClient(socket));\n861:       };\n862:       const onConnect = (): void => finish();\n863:       const onError = (error: Error): void => finish(error);\n864:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n865:       timer.unref?.();\n866: \n867:       try {\n868:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n869:         socket = typeof connectionOptions === 'string'\n870:           ? net.createConnection(connectionOptions)\n871:           : net.createConnection(connectionOptions);\n872:       } catch (error: unknown) {\n873:         clearTimeout(timer);\n874:         reject(error instanceof Error ? error : new Error(String(error)));\n875:         return;\n876:       }\n877:       socket.once('connect', onConnect);\n878:       socket.once('error', onError);\n879:     });\n880:   }\n881: \n882:   notify(method: string, params?: unknown): void {\n883:     const frame = params === undefined\n884:       ? { jsonrpc: '2.0', method }\n885:       : { jsonrpc: '2.0', method, params };\n886:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n887:   }\n888: \n889:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n890:     const id = this.nextId++;\n891:     const request = { jsonrpc: '2.0', id, method, params };\n892:     return new Promise((resolve, reject) => {\n893:       let buffer = '';\n894:       let settled = false;\n895: \n896:       const cleanup = (): void => {\n897:         clearTimeout(timer);\n898:         this.socket.off('data', onData);\n899:         this.socket.off('error', onError);\n900:         this.socket.off('close', onClose);\n901:       };\n902:       const finish = (error: unknown, value?: unknown): void => {\n903:         if (settled) return;\n904:         settled = true;\n905:         cleanup();\n906:         if (error) {\n907:           reject(error);\n908:           return;\n909:         }\n910:         resolve(value);\n911:       };\n912:       const onData = (chunk: Buffer | string): void => {\n913:         buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n914:         let newlineIndex = buffer.indexOf('\\n');\n915:         while (newlineIndex !== -1) {\n916:           const line = buffer.slice(0, newlineIndex).trim();\n917:           buffer = buffer.slice(newlineIndex + 1);\n918:           newlineIndex = buffer.indexOf('\\n');\n919:           if (!line) continue;\n920:           let parsed: JsonRpcResponse;\n921:           try {\n922:             parsed = JSON.parse(line) as JsonRpcResponse;\n923:           } catch {\n924:             continue;\n925:           }\n926:           if (parsed.id !== id) continue;\n927:           if (parsed.error) {\n928:             finish(new JsonRpcError(parsed.error));\n929:             return;\n930:           }\n931:           finish(null, parsed.result);\n932:           return;\n933:         }\n934:       };\n935:       const onError = (error: Error): void => finish(error);\n936:       const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n937:       const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n938:       timer.unref?.();\n939: \n940:       this.socket.on('data', onData);\n941:       this.socket.once('error', onError);\n942:       this.socket.once('close', onClose);\n943:       this.socket.write(`${JSON.stringify(request)}\\n`);\n944:     });\n945:   }\n946: \n947:   close(): void {\n948:     this.socket.end();\n949:     this.socket.destroy();\n950:   }\n951: }\n952: \n953: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n954:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n955:   if (initialProbe.status === 'alive') return;\n956:   if (warmOnly) {\n957:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n958:   }\n959:   spawnLauncher(paths);\n960:   await waitForDaemon(socketPath, bridge, timeoutMs);\n961: }\n962: \n963: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n964:   ensureSocketEnvironment();\n965:   const paths = findRepoPaths();\n966:   const bridge = loadBridge(paths);\n967:   const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n968:   if (socketPathTooLong(socketPath)) {\n969:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n970:   }\n971: \n972:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n973: \n974:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n975:   try {\n976:     const initialize = await client.request('initialize', {\n977:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n978:       capabilities: {},\n979:       clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n980:     }, timeoutMs) as InitializeResult;\n981:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n982:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n983:     }\n984:     client.notify('notifications/initialized');\n985:     return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n986:   } finally {\n987:     client.close();\n988:   }\n989: }\n990: \n991: export async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n992:   try {\n993:     const parsed = parseCliArgs(argv);\n994:     if (parsed.help) {\n995:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n996:       return EXIT_SUCCESS;\n997:     }\n998:     if (parsed.version) {\n999:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n1000:       return EXIT_SUCCESS;\n1001:     }\n1002:     if (parsed.command === 'list-tools') {\n1003:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n1004:       return EXIT_SUCCESS;\n1005:     }\n1006:     if (parsed.command === 'completion') {\n1007:       if (!parsed.completionShell) {\n1008:         throw new CliUsageError('completion requires a shell: bash or zsh');\n1009:       }\n1010:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n1011:       return EXIT_SUCCESS;\n1012:     }\n1013: \n1014:     const validated = validateCommand(parsed);\n1015:     if (!validated) {\n1016:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n1017:     }\n1018:     const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n1019:     const { payload, isError } = extractToolPayload(validated.tool.name, result);\n1020:     await writeLine(io.stdout, renderPayload(payload, parsed.format));\n1021:     return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n1022:   } catch (error: unknown) {\n1023:     const exitCode = exitCodeForError(error);\n1024:     const message = error instanceof Error ? error.message : String(error);\n1025:     const unknownCommand = unknownCommandContext(message);\n1026:     const payload = {\n1027:       status: 'error',\n1028:       error: message,\n1029:       exitCode,\n1030:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n1031:       ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n1032:     };\n1033:     const format = (() => {\n1034:       try {\n1035:         return parseCliArgs(argv).format;\n1036:       } catch {\n1037:         return 'text' as OutputFormat;\n1038:       }\n1039:     })();\n1040:     if (format === 'json' || format === 'jsonl') {\n1041:       await writeLine(io.stderr, renderJson(payload, format));\n1042:     } else {\n1043:       await writeLine(io.stderr, [\n1044:         `ERROR: ${message}`,\n1045:         unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n1046:         unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n1047:       ].filter((line): line is string => Boolean(line)).join('\\n'));\n1048:     }\n1049:     return exitCode;\n1050:   }\n1051: }\n1052: \n1053: function isCliEntrypoint(): boolean {\n1054:   const invoked = process.argv[1];\n1055:   if (!invoked) return false;\n1056:   return path.resolve(invoked) === path.resolve(currentModulePath());\n1057: }\n1058: \n1059: export const __testing = {\n1060:   DEFAULT_SOCKET_DIR,\n1061:   EXIT_PROTOCOL,\n1062:   EXIT_RETRYABLE,\n1063:   EXIT_RUNTIME,\n1064:   EXIT_USAGE,\n1065:   commandMap,\n1066:   commandAliases,\n1067:   assertSocketPerimeter,\n1068:   ensureSocketEnvironment,\n1069:   exitCodeForError,\n1070:   findRepoPaths,\n1071:   isErrorPayload,\n1072:   closestCommand,\n1073:   renderCompletion,\n1074:   renderToolList,\n1075:   resolvePropertyName,\n1076: };\n1077: \n1078: if (isCliEntrypoint()) {\n1079:   // Natural exit via process.exitCode: a hard process.exit() drops any\n1080:   // stdout bytes still queued behind the kernel pipe buffer, truncating\n1081:   // large payloads. Pending pipe writes keep the event loop alive until\n1082:   // they flush; all sockets and timers are closed or unref'd by here.\n1083:   process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n1084: }\n\n(End of file - total 1084 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ---------------------------------------------------------------\n// MODULE: Spec Memory CLI\n// ---------------------------------------------------------------\n// Daemon-backed command line client for the mk-spec-memory tool\n// surface. The CLI is intentionally IPC-only: all persistence remains\n// owned by the already-running context server daemon.\n\nimport { spawn } from 'node:child_process';\nimport { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"#!/usr/bin/env node\n// ---------------------------------------------------------------\n// MODULE: Spec Memory CLI\n// ---------------------------------------------------------------\n// Daemon-backed command line client for the mk-spec-memory tool\n// surface. The CLI is intentionally IPC-only: all persistence remains\n// owned by the already-running context server daemon.\n\nimport { spawn } from 'node:child_process';\nimport { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,\n  validateToolArgs,\n} from './tool-schemas.js';\n\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst DEFAULT_TIMEOUT_MS = 30_000;\nconst DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n\nconst EXIT_SUCCESS = 0;\nconst EXIT_RUNTIME = 1;\nconst EXIT_USAGE = 64;\nconst EXIT_PROTOCOL = 69;\nconst EXIT_RETRYABLE = 75;\n\ntype OutputFormat = 'json' | 'text' | 'jsonl';\ntype ToolListMode = 'full' | 'compact' | 'names-only';\ntype CompletionShell = 'bash' | 'zsh';\n\ninterface ParsedCommand {\n  readonly command: string;\n  readonly format: OutputFormat;\n  readonly timeoutMs: number;\n  readonly sessionId?: string;\n  readonly warmOnly: boolean;\n  readonly toolListMode: ToolListMode;\n  readonly completionShell?: CompletionShell;\n  readonly args: Record<string, unknown>;\n  readonly help: boolean;\n  readonly version: boolean;\n}\n\ninterface CliIo {\n  readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n  readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n}\n\ninterface RepoPaths {\n  readonly opencodeDir: string;\n  readonly repoRoot: string;\n  readonly launcherPath: string;\n  readonly bridgePath: string;\n  readonly dbDir: string;\n  readonly packageJsonPath: string;\n}\n\ninterface BridgeProbeResult {\n  readonly status: string;\n  readonly reason?: string;\n}\n\ninterface BridgeModule {\n  readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n  readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n  readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n}\n\ninterface JsonRpcResponse {\n  readonly jsonrpc?: string;\n  readonly id?: unknown;\n  readonly result?: unknown;\n  readonly error?: {\n    readonly code?: number;\n    readonly message?: string;\n    readonly data?: unknown;\n  };\n}\n\ninterface InitializeResult {\n  readonly protocolVersion?: string;\n}\n\ninterface ToolResult {\n  readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n  readonly isError?: boolean;\n}\n\nclass CliUsageError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliUsageError';\n  }\n}\n\nclass CliRetryableError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliRetryableError';\n  }\n}\n\nclass CliProtocolError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliProtocolError';\n  }\n}\n\nclass JsonRpcError extends Error {\n  public readonly code?: number;\n  public readonly data?: unknown;\n\n  constructor(error: NonNullable<JsonRpcResponse['error']>) {\n    super(error.message ?? 'JSON-RPC request failed');\n    this.name = 'JsonRpcError';\n    this.code = error.code;\n    this.data = error.data;\n  }\n}\n\n// Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n// write followed by process.exit() truncates large payloads at the pipe\n// buffer boundary (observed as exactly 64KB on darwin). Streams without\n// emitter methods (test fakes) resolve immediately.\nasync function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n  const flushed = stream.write(`${value}\\n`);\n  if (flushed) return;\n  const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n  if (typeof drainable.once !== 'function') return;\n  await new Promise<void>((resolve) => {\n    const settle = (): void => {\n      drainable.off?.('drain', settle);\n      drainable.off?.('error', settle);\n      drainable.off?.('close', settle);\n      resolve();\n    };\n    drainable.once?.('drain', settle);\n    drainable.once?.('error', settle);\n    drainable.once?.('close', settle);\n  });\n}\n\nfunction currentModulePath(): string {\n  return fileURLToPath(import.meta.url);\n}\n\nfunction findRepoPaths(startFile = currentModulePath()): RepoPaths {\n  let current = path.dirname(startFile);\n\n  while (true) {\n    const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n    const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n    const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n    if (existsSync(launcherPath) && existsSync(bridgePath)) {\n      const repoRoot = path.dirname(directOpencodeDir);\n      return {\n        opencodeDir: directOpencodeDir,\n        repoRoot,\n        launcherPath,\n        bridgePath,\n        dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n        packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n      };\n    }\n\n    const parent = path.dirname(current);\n    if (parent === current) {\n      throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n    }\n    current = parent;\n  }\n}\n\nfunction loadBridge(paths: RepoPaths): BridgeModule {\n  const require = createRequire(import.meta.url);\n  return require(paths.bridgePath) as BridgeModule;\n}\n\nfunction readCliVersion(paths: RepoPaths): string {\n  const require = createRequire(import.meta.url);\n  const pkg = require(paths.packageJsonPath) as { version?: unknown };\n  return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n}\n\nfunction toKebabCommand(name: string): string {\n  return name.replace(/_/g, '-');\n}\n\nfunction toCamelCommand(name: string): string {\n  return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandAliases(name: string): string[] {\n  return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n}\n\nfunction usageText(command?: string): string {\n  const tool = command ? getToolDefinition(command) : null;\n  if (tool) {\n    return `spec-memory ${tool.name}\n\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  return `spec-memory - daemon-backed CLI for mk-spec-memory\n\nUsage:\n  spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n  spec-memory completion bash|zsh\n  spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n  spec-memory <tool_name> --param value [--another-param value]\n\nExamples:\n  spec-memory list-tools --format text\n  spec-memory list-tools --compact\n  spec-memory completion zsh\n  spec-memory memory_stats --format json\n  spec-memory memory_search --query \"gold query battery\" --limit 3\n  spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n\nExit codes:\n  0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n\nExit 69 recovery:\n  - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n    - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n    - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n}\n\nfunction parseCompletionShell(raw: string): CompletionShell {\n  if (raw === 'bash' || raw === 'zsh') return raw;\n  throw new CliUsageError('completion shell must be one of: bash, zsh');\n}\n\nfunction normalizeName(value: string): string {\n  return value.replace(/[-_]/g, '').toLowerCase();\n}\n\nfunction toCamelCaseFlag(value: string): string {\n  return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandMap(): Map<string, ToolDefinition> {\n  const map = new Map<string, ToolDefinition>();\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      const existing = map.get(alias);\n      if (existing && existing.name !== tool.name) {\n        throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n      }\n      map.set(alias, tool);\n    }\n  }\n  return map;\n}\n\nfunction getToolDefinition(command: string): ToolDefinition | null {\n  return commandMap().get(command) ?? null;\n}\n\nfunction inputPropertyNames(tool: ToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly properties?: unknown }).properties\n    : null;\n  if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n  return Object.keys(properties);\n}\n\nfunction resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n  const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n  if (exact) return exact;\n\n  const normalized = normalizeName(rawFlag);\n  const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n  if (matched) return matched;\n\n  return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n}\n\nfunction parseValue(raw: string): unknown {\n  const trimmed = raw.trim();\n  if (trimmed === 'true') return true;\n  if (trimmed === 'false') return false;\n  if (trimmed === 'null') return null;\n  if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n    try {\n      return JSON.parse(trimmed) as unknown;\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      throw new CliUsageError(`Invalid JSON value: ${message}`);\n    }\n  }\n  return raw;\n}\n\nfunction parsePositiveInteger(raw: string, flagName: string): number {\n  if (!/^\\d+$/.test(raw)) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  const value = Number.parseInt(raw, 10);\n  if (!Number.isFinite(value) || value <= 0) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  return value;\n}\n\nfunction parseFormat(raw: string): OutputFormat {\n  if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n  throw new CliUsageError('--format must be one of: json, text, jsonl');\n}\n\nfunction parseInlineBoolean(raw: string, flagName: string): boolean {\n  if (raw === 'true' || raw === '1') return true;\n  if (raw === 'false' || raw === '0') return false;\n  throw new CliUsageError(`${flagName} must be true or false`);\n}\n\nfunction readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n  const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n  if (inline) return { value: inline[1], nextIndex: index + 1 };\n  const value = tokens[index + 1];\n  if (value === undefined) {\n    throw new CliUsageError(`${flagName} requires a value`);\n  }\n  return { value, nextIndex: index + 2 };\n}\n\nfunction parseJsonObject(raw: string): Record<string, unknown> {\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw) as unknown;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw new CliUsageError('--json must be a JSON object');\n  }\n  return parsed as Record<string, unknown>;\n}\n\nfunction envFlagEnabled(name: string): boolean {\n  const raw = process.env[name];\n  if (raw === undefined || raw === null) return false;\n  return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n}\n\nfunction defaultWarmOnly(): boolean {\n  return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n    || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n    || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n    || envFlagEnabled('OPENCODE_PROMPT_TIME')\n    || envFlagEnabled('CODEX_PROMPT_TIME')\n    || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n}\n\nexport function parseCliArgs(argv: string[]): ParsedCommand {\n  const command = argv[0];\n  const warmOnlyDefault = defaultWarmOnly();\n  if (!command || command === '--help' || command === '-h') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n  }\n  if (command === '--version' || command === '-v') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n  }\n\n  let format: OutputFormat = 'json';\n  let timeoutMs = DEFAULT_TIMEOUT_MS;\n  let sessionId: string | undefined;\n  let warmOnly = warmOnlyDefault;\n  let toolListMode: ToolListMode = 'full';\n  let completionShell: CompletionShell | undefined;\n  let jsonPayload: Record<string, unknown> | null = null;\n  const tool = getToolDefinition(command);\n  const parsedArgs: Record<string, unknown> = {};\n  const tokens = argv.slice(1);\n  let index = 0;\n\n  while (index < tokens.length) {\n    const token = tokens[index];\n    if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n      completionShell = parseCompletionShell(token);\n      index += 1;\n      continue;\n    }\n    if (!token.startsWith('--')) {\n      throw new CliUsageError(`Unexpected positional argument: ${token}`);\n    }\n    const rawFlag = token.slice(2).split('=', 1)[0];\n    const option = `--${rawFlag}`;\n\n    if (rawFlag === 'help' || rawFlag === 'h') {\n      return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n    }\n    if (rawFlag === 'format') {\n      const read = readOptionValue(tokens, index, option);\n      format = parseFormat(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'timeout-ms') {\n      const read = readOptionValue(tokens, index, option);\n      timeoutMs = parsePositiveInteger(read.value, option);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'session-id') {\n      const read = readOptionValue(tokens, index, option);\n      sessionId = read.value;\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'warm-only') {\n      const inline = token.match(/^--[^=]+=(.*)$/);\n      warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'no-warm-only') {\n      warmOnly = false;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'compact') {\n      toolListMode = 'compact';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'names-only') {\n      toolListMode = 'names-only';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'json') {\n      const read = readOptionValue(tokens, index, option);\n      jsonPayload = parseJsonObject(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n\n    if (!tool) {\n      throw new CliUsageError(`Unknown command: ${command}`);\n    }\n\n    const propertyName = resolvePropertyName(rawFlag, tool);\n    const inline = token.match(/^--[^=]+=(.*)$/);\n    if (inline) {\n      parsedArgs[propertyName] = parseValue(inline[1]);\n      index += 1;\n      continue;\n    }\n\n    const next = tokens[index + 1];\n    if (next === undefined || next.startsWith('--')) {\n      parsedArgs[propertyName] = true;\n      index += 1;\n      continue;\n    }\n    parsedArgs[propertyName] = parseValue(next);\n    index += 2;\n  }\n\n  if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n    throw new CliUsageError('--json cannot be combined with per-parameter flags');\n  }\n\n  return {\n    command,\n    format,\n    timeoutMs,\n    sessionId,\n    warmOnly,\n    toolListMode,\n    completionShell,\n    args: jsonPayload ?? parsedArgs,\n    help: false,\n    version: false,\n  };\n}\n\nfunction validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n  if (RESERVED_COMMANDS.has(parsed.command)) return null;\n  const tool = getToolDefinition(parsed.command);\n  if (!tool) {\n    throw new CliUsageError(`Unknown command: ${parsed.command}`);\n  }\n\n  const args = { ...parsed.args };\n  const properties = new Set(inputPropertyNames(tool));\n  if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n    args.sessionId = parsed.sessionId;\n  } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n    args.session_id = parsed.sessionId;\n  }\n\n  return {\n    tool,\n    args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n  };\n}\n\nfunction renderJson(value: unknown, format: OutputFormat): string {\n  if (format === 'jsonl') return JSON.stringify(value);\n  return JSON.stringify(value, null, 2);\n}\n\nfunction compactTool(tool: ToolDefinition): Record<string, unknown> {\n  return {\n    name: tool.name,\n    command: tool.name,\n    kebabCommand: toKebabCommand(tool.name),\n    camelCommand: toCamelCommand(tool.name),\n    aliases: commandAliases(tool.name),\n    description: tool.description,\n  };\n}\n\nfunction renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n  const payload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      tools: TOOL_DEFINITIONS.map((tool) => ({\n        name: tool.name,\n        command: tool.name,\n        kebabCommand: toKebabCommand(tool.name),\n        camelCommand: toCamelCommand(tool.name),\n        aliases: commandAliases(tool.name),\n        description: tool.description,\n        inputSchema: tool.inputSchema,\n      })),\n    },\n  };\n  const compactPayload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      tools: TOOL_DEFINITIONS.map(compactTool),\n    },\n  };\n  const namesOnlyPayload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      names: TOOL_DEFINITIONS.map((tool) => tool.name),\n    },\n  };\n\n  if (format === 'text') {\n    return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n  }\n  if (mode === 'compact') return renderJson(compactPayload, format);\n  if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n  return renderJson(payload, format);\n}\n\nfunction completionWords(): string[] {\n  return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n}\n\nfunction shellWords(words: readonly string[]): string {\n  return words.join(' ');\n}\n\nfunction renderBashCompletion(): string {\n  const commands = shellWords(completionWords());\n  const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n  const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n  return `_spec_memory_completion() {\n  local cur\n  COMPREPLY=()\n  cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n  if [[ \\${COMP_CWORD} -eq 1 ]]; then\n    COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n    return 0\n  fi\n  case \"\\${COMP_WORDS[1]}\" in\n    completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n    list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n    *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n  esac\n}\ncomplete -F _spec_memory_completion spec-memory`;\n}\n\nfunction renderZshCompletion(): string {\n  const commands = shellWords(completionWords());\n  const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n  const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n  return `#compdef spec-memory\n_spec_memory() {\n  local -a commands common_flags list_flags shells\n  commands=(${commands})\n  common_flags=(${commonFlags})\n  list_flags=(${listFlags})\n  shells=(bash zsh)\n  if (( CURRENT == 2 )); then\n    _describe 'commands' commands\n    return\n  fi\n  case \\${words[2]} in\n    completion) _describe 'shells' shells ;;\n    list-tools) _describe 'flags' list_flags ;;\n    *) _describe 'flags' common_flags ;;\n  esac\n}\n_spec_memory \"$@\"`;\n}\n\nfunction renderCompletion(shell: CompletionShell): string {\n  return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n}\n\nfunction isErrorPayload(payload: unknown): boolean {\n  return Boolean(payload)\n    && typeof payload === 'object'\n    && !Array.isArray(payload)\n    && (payload as { readonly status?: unknown }).status === 'error';\n}\n\nfunction extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n  const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n  const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n  if (firstText) {\n    try {\n      return {\n        payload: JSON.parse(firstText) as unknown,\n        isError: toolResult?.isError === true,\n      };\n    } catch {\n      return {\n        payload: {\n          status: toolResult?.isError ? 'error' : 'ok',\n          tool: toolName,\n          text: firstText,\n        },\n        isError: toolResult?.isError === true,\n      };\n    }\n  }\n  return {\n    payload: {\n      status: toolResult?.isError ? 'error' : 'ok',\n      tool: toolName,\n      result,\n    },\n    isError: toolResult?.isError === true,\n  };\n}\n\nfunction renderPayload(payload: unknown, format: OutputFormat): string {\n  if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n  if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n    const record = payload as Record<string, unknown>;\n    if (typeof record.summary === 'string') return record.summary;\n    if (typeof record.error === 'string') return record.error;\n    if (typeof record.message === 'string') return record.message;\n  }\n  return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n}\n\nfunction isProtocolMismatch(error: unknown): boolean {\n  if (error instanceof JsonRpcError && error.code === -32002) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /protocol.*(mismatch|changed|version)/i.test(message);\n}\n\nfunction isRetryableError(error: unknown): boolean {\n  if (error instanceof CliRetryableError) return true;\n  if (error instanceof JsonRpcError && error.code === -32001) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n}\n\nfunction exitCodeForError(error: unknown): number {\n  if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n  if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n  if (isRetryableError(error)) return EXIT_RETRYABLE;\n  if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n  return EXIT_RUNTIME;\n}\n\nfunction levenshteinDistance(left: string, right: string): number {\n  const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n  const current = new Array<number>(right.length + 1);\n\n  for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n    current[0] = leftIndex;\n    for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n      const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n      current[rightIndex] = Math.min(\n        current[rightIndex - 1] + 1,\n        previous[rightIndex] + 1,\n        previous[rightIndex - 1] + cost,\n      );\n    }\n    previous.splice(0, previous.length, ...current);\n  }\n\n  return previous[right.length];\n}\n\nfunction closestCommand(command: string): string | undefined {\n  const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n  targets.set('completion', 'completion');\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      targets.set(alias, tool.name);\n    }\n  }\n\n  let best: { readonly command: string; readonly distance: number } | null = null;\n  for (const [alias, canonical] of targets) {\n    const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n    if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n      best = { command: canonical, distance };\n    }\n  }\n\n  if (!best) return undefined;\n  const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n  return best.distance <= threshold ? best.command : undefined;\n}\n\nfunction unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n  const match = message.match(/^Unknown command: (.+)$/);\n  if (!match) return null;\n  return {\n    hint: 'Try `list-tools` to see available commands.',\n    suggestion: closestCommand(match[1]),\n  };\n}\n\nfunction socketPathTooLong(socketPath: string): boolean {\n  if (socketPath.startsWith('tcp://')) return false;\n  return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n}\n\n// `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n// (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n// mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n// a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n// symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\nfunction assertSocketPerimeter(socketDir: string): void {\n  const dirLink = lstatSync(socketDir);\n  if (dirLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n  }\n  const dirStat = statSync(socketDir);\n  const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n  if (uid !== null && dirStat.uid !== uid) {\n    throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n  }\n  if ((dirStat.mode & 0o022) !== 0) {\n    throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n  }\n  const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n  let nodeLink;\n  try {\n    nodeLink = lstatSync(socketPath);\n  } catch (error: unknown) {\n    const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n    if (code === 'ENOENT') return;\n    throw error;\n  }\n  if (nodeLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n  }\n  if (uid !== null && nodeLink.uid !== uid) {\n    throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n  }\n}\n\nfunction ensureSocketEnvironment(): void {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (!socketDir || socketDir.startsWith('tcp://')) return;\n  mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  assertSocketPerimeter(socketDir);\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction spawnLauncher(paths: RepoPaths): void {\n  const child = spawn(process.execPath, [paths.launcherPath], {\n    cwd: paths.repoRoot,\n    env: process.env,\n    detached: true,\n    stdio: 'ignore',\n  });\n  child.unref();\n}\n\nasync function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  let lastReason = 'not probed';\n\n  while (Date.now() <= deadline) {\n    const remaining = Math.max(1, deadline - Date.now());\n    const probe = await bridge.probeDaemon(socketPath, {\n      timeoutMs: Math.min(remaining, 5000),\n      deepProbe: true,\n    });\n    if (probe.status === 'alive') return;\n    lastReason = probe.reason ?? probe.status;\n    await sleep(100);\n  }\n\n  throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n}\n\nclass JsonRpcSocketClient {\n  private nextId = 1;\n  private readonly decoder = new StringDecoder('utf8');\n\n  private constructor(\n    private readonly socket: net.Socket,\n  ) {}\n\n  static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n    return new Promise((resolve, reject) => {\n      let socket: net.Socket;\n      let settled = false;\n      const finish = (error?: Error): void => {\n        if (settled) return;\n        settled = true;\n        clearTimeout(timer);\n        socket.off?.('connect', onConnect);\n        socket.off?.('error', onError);\n        if (error) {\n          socket.destroy?.();\n          reject(error);\n          return;\n        }\n        resolve(new JsonRpcSocketClient(socket));\n      };\n      const onConnect = (): void => finish();\n      const onError = (error: Error): void => finish(error);\n      const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n      timer.unref?.();\n\n      try {\n        const connectionOptions = bridge.toConnectionOptions(socketPath);\n        socket = typeof connectionOptions === 'string'\n          ? net.createConnection(connectionOptions)\n          : net.createConnection(connectionOptions);\n      } catch (error: unknown) {\n        clearTimeout(timer);\n        reject(error instanceof Error ? error : new Error(String(error)));\n        return;\n      }\n      socket.once('connect', onConnect);\n      socket.once('error', onError);\n    });\n  }\n\n  notify(method: string, params?: unknown): void {\n    const frame = params === undefined\n      ? { jsonrpc: '2.0', method }\n      : { jsonrpc: '2.0', method, params };\n    this.socket.write(`${JSON.stringify(frame)}\\n`);\n  }\n\n  request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n    const id = this.nextId++;\n    const request = { jsonrpc: '2.0', id, method, params };\n    return new Promise((resolve, reject) => {\n      let buffer = '';\n      let settled = false;\n\n      const cleanup = (): void => {\n        clearTimeout(timer);\n        this.socket.off('data', onData);\n        this.socket.off('error', onError);\n        this.socket.off('close', onClose);\n      };\n      const finish = (error: unknown, value?: unknown): void => {\n        if (settled) return;\n        settled = true;\n        cleanup();\n        if (error) {\n          reject(error);\n          return;\n        }\n        resolve(value);\n      };\n      const onData = (chunk: Buffer | string): void => {\n        buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n        let newlineIndex = buffer.indexOf('\\n');\n        while (newlineIndex !== -1) {\n          const line = buffer.slice(0, newlineIndex).trim();\n          buffer = buffer.slice(newlineIndex + 1);\n          newlineIndex = buffer.indexOf('\\n');\n          if (!line) continue;\n          let parsed: JsonRpcResponse;\n          try {\n            parsed = JSON.parse(line) as JsonRpcResponse;\n          } catch {\n            continue;\n          }\n          if (parsed.id !== id) continue;\n          if (parsed.error) {\n            finish(new JsonRpcError(parsed.error));\n            return;\n          }\n          finish(null, parsed.result);\n          return;\n        }\n      };\n      const onError = (error: Error): void => finish(error);\n      const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n      const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n      timer.unref?.();\n\n      this.socket.on('data', onData);\n      this.socket.once('error', onError);\n      this.socket.once('close', onClose);\n      this.socket.write(`${JSON.stringify(request)}\\n`);\n    });\n  }\n\n  close(): void {\n    this.socket.end();\n    this.socket.destroy();\n  }\n}\n\nasync function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n  const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n  if (initialProbe.status === 'alive') return;\n  if (warmOnly) {\n    throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n  }\n  spawnLauncher(paths);\n  await waitForDaemon(socketPath, bridge, timeoutMs);\n}\n\nasync function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n  ensureSocketEnvironment();\n  const paths = findRepoPaths();\n  const bridge = loadBridge(paths);\n  const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n  if (socketPathTooLong(socketPath)) {\n    throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n  }\n\n  await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n\n  const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n  try {\n    const initialize = await client.request('initialize', {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n    }, timeoutMs) as InitializeResult;\n    if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n      throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n    }\n    client.notify('notifications/initialized');\n    return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n  } finally {\n    client.close();\n  }\n}\n\nexport async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n  try {\n    const parsed = parseCliArgs(argv);\n    if (parsed.help) {\n      await writeLine(io.stdout, usageText(parsed.command || undefined));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.version) {\n      await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'list-tools') {\n      await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'completion') {\n      if (!parsed.completionShell) {\n        throw new CliUsageError('completion requires a shell: bash or zsh');\n      }\n      await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n      return EXIT_SUCCESS;\n    }\n\n    const validated = validateCommand(parsed);\n    if (!validated) {\n      throw new CliUsageError(`Unknown command: ${parsed.command}`);\n    }\n    const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n    const { payload, isError } = extractToolPayload(validated.tool.name, result);\n    await writeLine(io.stdout, renderPayload(payload, parsed.format));\n    return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n  } catch (error: unknown) {\n    const exitCode = exitCodeForError(error);\n    const message = error instanceof Error ? error.message : String(error);\n    const unknownCommand = unknownCommandContext(message);\n    const payload = {\n      status: 'error',\n      error: message,\n      exitCode,\n      ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n      ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n    };\n    const format = (() => {\n      try {\n        return parseCliArgs(argv).format;\n      } catch {\n        return 'text' as OutputFormat;\n      }\n    })();\n    if (format === 'json' || format === 'jsonl') {\n      await writeLine(io.stderr, renderJson(payload, format));\n    } else {\n      await writeLine(io.stderr, [\n        `ERROR: ${message}`,\n        unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n        unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n      ].filter((line): line is string => Boolean(line)).join('\\n'));\n    }\n    return exitCode;\n  }\n}\n\nfunction isCliEntrypoint(): boolean {\n  const invoked = process.argv[1];\n  if (!invoked) return false;\n  return path.resolve(invoked) === path.resolve(currentModulePath());\n}\n\nexport const __testing =