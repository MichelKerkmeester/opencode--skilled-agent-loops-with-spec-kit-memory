{"type":"tool_use","timestamp":1780205038181,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_b4fws1ondttb_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/router-replay.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/router-replay.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * router-replay.cjs — Mode A deterministic in-skill smart-router replay.\n6:  *\n7:  * The converged design needs the intra-skill router replayed deterministically\n8:  * (zero leakage, CI-friendly) as the D1-intra signal and the D2 discovery proxy.\n9:  * The router lives as INTENT_SIGNALS + RESOURCE_MAP inside a fenced block in the\n10:  * target SKILL.md; it is documentation, not an importable module, so this script\n11:  * extracts the dictionaries and reproduces the exact substring-scoring semantics:\n12:  * lowercase the task, score each intent by whether each keyword is a substring,\n13:  * keep intents within an ambiguity delta of the top score, then union the default\n14:  * resource + RESOURCE_MAP[intent] for the selected intents.\n15:  *\n16:  * Exit: 0 on a successful replay (even with zero intents), 2 on unparseable router.\n17:  */\n18: \n19: const fs = require('fs');\n20: const path = require('path');\n21: \n22: const AMBIGUITY_DELTA = 1; // mirror the in-skill router: keep near-tied intents\n23: \n24: function readSkillMd(skillRoot) {\n25:   const p = path.join(skillRoot, 'SKILL.md');\n26:   if (!fs.existsSync(p)) throw new Error(`SKILL.md not found under ${skillRoot}`);\n27:   return fs.readFileSync(p, 'utf8');\n28: }\n29: \n30: // Pull the {...}-balanced body that follows `NAME = {` from the SKILL.md text.\n31: function extractDictBody(text, name) {\n32:   const start = text.indexOf(`${name} = {`);\n33:   if (start === -1) return null;\n34:   let i = text.indexOf('{', start);\n35:   let depth = 0;\n36:   for (let j = i; j < text.length; j += 1) {\n37:     const ch = text[j];\n38:     if (ch === '{') depth += 1;\n39:     else if (ch === '}') {\n40:       depth -= 1;\n41:       if (depth === 0) return text.slice(i + 1, j);\n42:     }\n43:   }\n44:   return null;\n45: }\n46: \n47: function quotedStrings(segment) {\n48:   const out = [];\n49:   const re = /\"([^\"]*)\"|'([^']*)'/g;\n50:   let m;\n51:   while ((m = re.exec(segment)) !== null) out.push(m[1] !== undefined ? m[1] : m[2]);\n52:   return out;\n53: }\n54: \n55: // INTENT_SIGNALS = { \"KEY\": {\"weight\": N, \"keywords\": [\"a\",\"b\"]}, ... }\n56: function parseIntentSignals(body) {\n57:   const signals = {};\n58:   if (!body) return signals;\n59:   const entryRe = /[\"']([A-Z0-9_]+)[\"']\\s*:\\s*\\{([^}]*)\\}/g;\n60:   let m;\n61:   while ((m = entryRe.exec(body)) !== null) {\n62:     const key = m[1];\n63:     const inner = m[2];\n64:     const weightMatch = /[\"']weight[\"']\\s*:\\s*(\\d+(?:\\.\\d+)?)/.exec(inner);\n65:     const kwMatch = /[\"']keywords[\"']\\s*:\\s*\\[([^\\]]*)\\]/.exec(inner);\n66:     signals[key] = {\n67:       weight: weightMatch ? Number(weightMatch[1]) : 1,\n68:       keywords: kwMatch ? quotedStrings(kwMatch[1]).map((k) => k.toLowerCase()) : [],\n69:     };\n70:   }\n71:   return signals;\n72: }\n73: \n74: // RESOURCE_MAP = { \"KEY\": [\"path/a.md\", \"path/b.md\"], ... }\n75: function parseResourceMap(body) {\n76:   const map = {};\n77:   if (!body) return map;\n78:   const entryRe = /[\"']([A-Z0-9_]+)[\"']\\s*:\\s*\\[([^\\]]*)\\]/g;\n79:   let m;\n80:   while ((m = entryRe.exec(body)) !== null) map[m[1]] = quotedStrings(m[2]);\n81:   return map;\n82: }\n83: \n84: function parseDefaultResource(text) {\n85:   const m = /DEFAULT_RESOURCE\\s*=\\s*[\"']([^\"']+)[\"']/.exec(text);\n86:   return m ? m[1] : null;\n87: }\n88: \n89: function parseRouter(skillMdText) {\n90:   const intentSignals = parseIntentSignals(extractDictBody(skillMdText, 'INTENT_SIGNALS'));\n91:   const resourceMap = parseResourceMap(extractDictBody(skillMdText, 'RESOURCE_MAP'));\n92:   const defaultResource = parseDefaultResource(skillMdText);\n93:   const parseable = Object.keys(intentSignals).length > 0 || Object.keys(resourceMap).length > 0;\n94:   return { intentSignals, resourceMap, defaultResource, parseable };\n95: }\n96: \n97: function scoreIntents(taskLower, intentSignals) {\n98:   const scores = [];\n99:   for (const [key, sig] of Object.entries(intentSignals)) {\n100:     let score = 0;\n101:     for (const kw of sig.keywords) {\n102:       if (kw && taskLower.includes(kw)) score += sig.weight;\n103:     }\n104:     if (score > 0) scores.push({ intent: key, score });\n105:   }\n106:   scores.sort((a, b) => b.score - a.score);\n107:   return scores;\n108: }\n109: \n110: function selectIntents(scores) {\n111:   if (scores.length === 0) return [];\n112:   const top = scores[0].score;\n113:   return scores.filter((s) => top - s.score <= AMBIGUITY_DELTA).map((s) => s.intent);\n114: }\n115: \n116: /**\n117:  * @returns {{ parseable: boolean, intents: string[], resources: string[],\n118:  *   missingResources: string[], scores: Array<{intent:string,score:number}> }}\n119:  */\n120: function routeSkillResources({ skillRoot, taskText }) {\n121:   const skillMd = readSkillMd(skillRoot);\n122:   const router = parseRouter(skillMd);\n123:   if (!router.parseable) {\n124:     return { parseable: false, intents: [], resources: [], missingResources: [], scores: [] };\n125:   }\n126:   const scores = scoreIntents(String(taskText || '').toLowerCase(), router.intentSignals);\n127:   const intents = selectIntents(scores);\n128:   const resourceSet = new Set();\n129:   if (router.defaultResource) resourceSet.add(router.defaultResource);\n130:   for (const intent of intents) {\n131:     for (const r of router.resourceMap[intent] || []) resourceSet.add(r);\n132:   }\n133:   const resources = [...resourceSet];\n134:   const missingResources = resources.filter((r) => !fs.existsSync(path.join(skillRoot, r)));\n135:   return { parseable: true, intents, resources, missingResources, scores };\n136: }\n137: \n138: module.exports = { routeSkillResources, parseRouter, scoreIntents, selectIntents };\n139: \n140: if (require.main === module) {\n141:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n142:   if (!args.skill || !args.task) {\n143:     process.stderr.write('usage: router-replay.cjs --skill <skill-root> --task \"<task text>\"\\n');\n144:     process.exit(2);\n145:   }\n146:   try {\n147:     const result = routeSkillResources({ skillRoot: args.skill, taskText: args.task });\n148:     process.stdout.write(JSON.stringify(result, null, 2) + '\\n');\n149:     process.exit(result.parseable ? 0 : 2);\n150:   } catch (err) {\n151:     process.stderr.write(`router-replay: ${err.message}\\n`);\n152:     process.exit(2);\n153:   }\n154: }\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * router-replay.cjs — Mode A deterministic in-skill smart-router replay.\n *\n * The converged design needs the intra-skill router replayed deterministically\n * (zero leakage, CI-friendly) as the D1-intra signal and the D2 discovery proxy.\n * The router lives as INTENT_SIGNALS + RESOURCE_MAP inside a fenced block in the\n * target SKILL.md; it is documentation, not an importable module, so this script\n * extracts the dictionaries and reproduces the exact substring-scoring semantics:\n * lowercase the task, score each intent by whether each keyword is a substring,\n * keep intents within an ambiguity delta of the top score, then union the default\n * resource + RESOURCE_MAP[intent] for the selected intents.\n *\n * Exit: 0 on a successful replay (even with zero intents), 2 on unparseable router.\n */\n\nconst fs = require('fs');\nconst path = require('path');","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/router-replay.cjs","time":{"start":1780205038166,"end":1780205038179}},"id":"prt_e7c7d28a9001Hh2JWQoZ3Y9Tj0","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7d0598001wS8zjK5Nrhz8nF"}}
{"type":"tool_use","timestamp":1780205038622,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_b4fws1ondttb_2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * run-skill-benchmark.cjs — Lane C orchestrator (loop-host --mode=skill-benchmark).\n6:  *\n7:  * Post-run join: private gold never crosses the dispatch boundary. Sequence:\n8:  *   1. resolve the target skill root (path or bare id under .opencode/skills/)\n9:  *   2. D5 static connectivity scan (the hard gate) — runs first, before any dispatch\n10:  *   3. load public/private fixture pairs\n11:  *   4. per scenario: contamination-lint the PUBLIC prompt (a leak is a fixture\n12:  *      failure), then router-replay (Mode A), then join with private gold to score\n13:  *   5. aggregate -> write report.json, then render report.md FROM it\n14:  *\n15:  * Mode A (router-replay) is the deterministic default and the CI gate. Live\n16:  * dispatch (Mode B) + D1-inter advisor scoring + D4 ablation are follow-on; this\n17:  * orchestrator emits a complete, honest Mode A report today.\n18:  */\n19: \n20: const fs = require('fs');\n21: const path = require('path');\n22: const { routeSkillResources } = require('./router-replay.cjs');\n23: const { buildBannedVocab, lintFixture } = require('./contamination-lint.cjs');\n24: const { scanConnectivity } = require('./d5-connectivity.cjs');\n25: const { scoreScenario, aggregate } = require('./score-skill-benchmark.cjs');\n26: const { probeAdvisor } = require('./advisor-probe.cjs');\n27: const { renderReport } = require('./build-report.cjs');\n28: \n29: const SKILLS_DIR = path.resolve(__dirname, '..', '..', '..'); // .opencode/skills\n30: \n31: function resolveSkillRoot(skillArg) {\n32:   if (skillArg.includes('/') || skillArg.startsWith('.')) return path.resolve(skillArg);\n33:   return path.join(SKILLS_DIR, skillArg);\n34: }\n35: \n36: function resolveSkillId(skillRoot) {\n37:   return path.basename(skillRoot);\n38: }\n39: \n40: // Fixtures: assets/skill-benchmark/fixtures/<skill-id>/ with <id>.public.json +\n41: // <id>.private.json pairs. Falls back to the --fixtures-dir override.\n42: function loadFixtures(fixturesDir) {\n43:   const out = [];\n44:   if (!fs.existsSync(fixturesDir)) return out;\n45:   const publics = fs.readdirSync(fixturesDir).filter((f) => f.endsWith('.public.json'));\n46:   for (const pf of publics) {\n47:     const id = pf.replace(/\\.public\\.json$/, '');\n48:     // A malformed fixture is operator error this tool exists to surface, not a\n49:     // reason to crash the whole run. Degrade: record a load error and skip.\n50:     let pub; let priv;\n51:     try {\n52:       pub = JSON.parse(fs.readFileSync(path.join(fixturesDir, pf), 'utf8'));\n53:       const privPath = path.join(fixturesDir, `${id}.private.json`);\n54:       priv = fs.existsSync(privPath) ? JSON.parse(fs.readFileSync(privPath, 'utf8')) : { expected: {} };\n55:     } catch (err) {\n56:       out.push({ scenarioId: id, loadError: err.message });\n57:       continue;\n58:     }\n59:     out.push({ scenarioId: pub.scenarioId || id, tier: pub.tier || 'T1', public: pub.public || {}, expected: priv.expected || {}, rubric: priv.rubric });\n60:   }\n61:   return out;\n62: }\n63: \n64: function run(args) {\n65:   const skillRoot = resolveSkillRoot(args.skill);\n66:   const skillId = resolveSkillId(skillRoot);\n67:   const outputsDir = path.resolve(args['outputs-dir']);\n68:   fs.mkdirSync(outputsDir, { recursive: true });\n69:   // D1-inter advisor probing is opt-in so the pure-router default stays fast +\n70:   // dependency-free. --advisor-mode=python enables the deterministic probe.\n71:   const advisorMode = args['advisor-mode'] || 'off';\n72: \n73:   if (!fs.existsSync(path.join(skillRoot, 'SKILL.md'))) {\n74:     process.stderr.write(`run-skill-benchmark: no SKILL.md at ${skillRoot}\\n`);\n75:     return 2;\n76:   }\n77: \n78:   // 2. D5 hard gate first.\n79:   const connectivity = scanConnectivity({ skillRoot });\n80: \n81:   // 3. fixtures.\n82:   const fixturesDir = args['fixtures-dir']\n83:     ? path.resolve(args['fixtures-dir'])\n84:     : path.join(skillRoot, 'assets', 'skill-benchmark', 'fixtures', skillId);\n85:   const fixtures = loadFixtures(fixturesDir);\n86: \n87:   // 4. per-scenario.\n88:   const scenarioRows = [];\n89:   for (const fx of fixtures) {\n90:     if (fx.loadError) {\n91:       scenarioRows.push({\n92:         scenarioId: fx.scenarioId, tier: 'unknown', modeAScore: 0,\n93:         firstFailingStage: 'unparseable-fixture',\n94:         dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },\n95:         loadError: fx.loadError,\n96:       });\n97:       continue;\n98:     }\n99:     const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: fx.expected });\n100:     const lint = lintFixture({ publicText: fx.public.prompt || '', bannedVocab });\n101:     if (!lint.passed) {\n102:       scenarioRows.push({\n103:         scenarioId: fx.scenarioId, tier: fx.tier, modeAScore: 0,\n104:         firstFailingStage: 'contaminated-fixture',\n105:         dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },\n106:         contamination: lint.hardLeaks,\n107:       });\n108:       continue;\n109:     }\n110:     const routerResult = routeSkillResources({ skillRoot, taskText: fx.public.prompt || '' });\n111:     // D1-inter (opt-in): probe the advisor out-of-band with the public prompt.\n112:     // Deterministic (the Python advisor reads SQLite), so it stays in Mode A.\n113:     const advisorResult = advisorMode === 'python'\n114:       ? probeAdvisor({ prompt: fx.public.prompt || '' })\n115:       : undefined;\n116:     scenarioRows.push(scoreScenario({ scenarioId: fx.scenarioId, tier: fx.tier, routerResult, expected: fx.expected, advisorResult }));\n117:   }\n118: \n119:   // 5. aggregate + emit.\n120:   const report = aggregate({ skillId, skillRoot, scenarioRows, connectivity, traceMode: args['trace-mode'] || 'router' });\n121:   const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');\n122:   const reportMdPath = reportJsonPath.replace(/\\.json$/, '.md');\n123:   fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));\n124:   fs.writeFileSync(reportMdPath, renderReport(report));\n125: \n126:   process.stdout.write(`skill-benchmark: ${skillId} verdict=${report.verdict} aggregate=${report.aggregateScore} scenarios=${scenarioRows.length}\\n`);\n127:   process.stdout.write(`  report.json -> ${reportJsonPath}\\n  report.md   -> ${reportMdPath}\\n`);\n128:   return 0;\n129: }\n130: \n131: module.exports = { run, resolveSkillRoot, loadFixtures };\n132: \n133: if (require.main === module) {\n134:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n135:   if (!args.skill || !args['outputs-dir']) {\n136:     process.stderr.write('usage: run-skill-benchmark.cjs --skill <root-or-id> --outputs-dir <path> [--fixtures-dir <path>] [--output <report.json>] [--trace-mode router|live]\\n');\n137:     process.exit(2);\n138:   }\n139:   process.exit(run(args));\n140: }\n\n(End of file - total 140 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * run-skill-benchmark.cjs — Lane C orchestrator (loop-host --mode=skill-benchmark).\n *\n * Post-run join: private gold never crosses the dispatch boundary. Sequence:\n *   1. resolve the target skill root (path or bare id under .opencode/skills/)\n *   2. D5 static connectivity scan (the hard gate) — runs first, before any dispatch\n *   3. load public/private fixture pairs\n *   4. per scenario: contamination-lint the PUBLIC prompt (a leak is a fixture\n *      failure), then router-replay (Mode A), then join with private gold to score\n *   5. aggregate -> write report.json, then render report.md FROM it\n *\n * Mode A (router-replay) is the deterministic default and the CI gate. Live\n * dispatch (Mode B) + D1-inter advisor scoring + D4 ablation are follow-on; this\n * orchestrator emits a complete, honest Mode A report today.\n */\n\nconst fs = require('fs');","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs","time":{"start":1780205038608,"end":1780205038621}},"id":"prt_e7c7d2a5a0013OaZj6sPgCmkYP","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7d0598001wS8zjK5Nrhz8nF"}}
