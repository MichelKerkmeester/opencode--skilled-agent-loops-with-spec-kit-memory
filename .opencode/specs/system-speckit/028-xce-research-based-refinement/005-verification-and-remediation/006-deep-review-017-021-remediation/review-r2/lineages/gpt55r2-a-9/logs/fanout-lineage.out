{"type":"tool_use","timestamp":1781764413119,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_2F8eioaem8hDv7lZkk0HWZ9e","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Adaptive Fusion\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: // Local\n6: import { fuseResultsMulti } from './rrf-fusion.js';\n7: \n8: // Type-only\n9: import type { RrfItem, FusionResult, RankedList } from './rrf-fusion.js';\n10: \n11: // Feature catalog: Hybrid search pipeline\n12: // Feature catalog: Adaptive shadow ranking, bounded proposals, and rollback\n13: \n14: \n15: /* --- 1. INTERFACES --- */\n16: \n17: /** Represents fusion weights. */\n18: export interface FusionWeights {\n19:   /** Weight for semantic/vector search results (0-1) */\n20:   semanticWeight: number;\n21:   /** Weight for keyword/lexical search results (0-1) */\n22:   keywordWeight: number;\n23:   /** Weight for recency-based scoring (0-1) */\n24:   recencyWeight: number;\n25:   /** Weight for graph channel results (0-1). Only used when graph channel active. */\n26:   graphWeight?: number;\n27:   /** Bias toward causal-edge signals within graph-assisted ranking (0-1). */\n28:   graphCausalBias?: number;\n29: }\n30: \n31: /** Represents degraded mode contract. */\n32: export interface DegradedModeContract {\n33:   /** What failed */\n34:   failureMode: string;\n35:   /** What was used instead */\n36:   fallbackMode: string;\n37:   /** Impact on result confidence (0-1, where 0 = no impact, 1 = total loss) */\n38:   confidenceImpact: number;\n39:   /** Retry guidance for callers and typed trace contracts */\n40:   retryRecommendation: 'immediate' | 'delayed' | 'none';\n41: }\n42: \n43: /** Represents adaptive fusion result. */\n44: export interface AdaptiveFusionResult {\n45:   results: FusionResult[];\n46:   weights: FusionWeights;\n47:   degraded?: DegradedModeContract;\n48:   darkRunDiff?: DarkRunDiff;\n49: }\n50: \n51: /** Represents dark run diff. */\n52: export interface DarkRunDiff {\n53:   standardCount: number;\n54:   adaptiveCount: number;\n55:   orderDifferences: number;\n56:   topResultChanged: boolean;\n57: }\n58: \n59: export interface AdaptiveFuseOptions {\n60:   graphResults?: RrfItem[];\n61:   additionalLists?: RankedList[];\n62: }\n63: \n64: /* --- 2. WEIGHT PROFILES --- */\n65: \n66: const INTENT_WEIGHT_PROFILES: Record<string, FusionWeights> = {\n67:   understand:      { semanticWeight: 0.7, keywordWeight: 0.2, recencyWeight: 0.1, graphWeight: 0.15, graphCausalBias: 0.10 },\n68:   find_spec:       { semanticWeight: 0.7, keywordWeight: 0.2, recencyWeight: 0.1, graphWeight: 0.30, graphCausalBias: 0.10 },\n69:   fix_bug:         { semanticWeight: 0.4, keywordWeight: 0.4, recencyWeight: 0.2, graphWeight: 0.10, graphCausalBias: 0.15 },\n70:   add_feature:     { semanticWeight: 0.5, keywordWeight: 0.3, recencyWeight: 0.2, graphWeight: 0.20, graphCausalBias: 0.15 },\n71:   refactor:        { semanticWeight: 0.6, keywordWeight: 0.3, recencyWeight: 0.1, graphWeight: 0.15, graphCausalBias: 0.10 },\n72:   security_audit:  { semanticWeight: 0.3, keywordWeight: 0.5, recencyWeight: 0.2, graphWeight: 0.15, graphCausalBias: 0.10 },\n73:   find_decision:   { semanticWeight: 0.3, keywordWeight: 0.2, recencyWeight: 0.1, graphWeight: 0.50, graphCausalBias: 0.15 },\n74:   continuity:      { semanticWeight: 0.52, keywordWeight: 0.18, recencyWeight: 0.07, graphWeight: 0.23, graphCausalBias: 0.15 },\n75: };\n76: \n77: const DEFAULT_WEIGHTS: FusionWeights = {\n78:   semanticWeight: 0.5,\n79:   keywordWeight: 0.3,\n80:   recencyWeight: 0.2,\n81:   graphWeight: 0.15,\n82:   graphCausalBias: 0.10,\n83: };\n84: \n85: /* --- 3. FEATURE FLAG --- */\n86: \n87: const FEATURE_FLAG = 'SPECKIT_ADAPTIVE_FUSION';\n88: \n89: /** Proportional weight shift factor applied per document type to fine-tune intent weights.\n90:  *  Multiplied against the base weight (20% shift) so small weights aren't disproportionately affected.\n91:  *  Env-tunable via SPECKIT_DOC_TYPE_WEIGHT_FACTOR (default 1.2 = 20% proportional shift). */\n92: const DOC_TYPE_WEIGHT_FACTOR = parseFloat(process.env.SPECKIT_DOC_TYPE_WEIGHT_FACTOR || '') || 1.2;\n93: \n94: /** Scaling factor applied to recency freshness before adding to RRF score. */\n95: const RECENCY_BOOST_SCALE = 0.1;\n96: \n97: function isFeatureEnabled(flagName: string, identity?: string): boolean {\n98:   const rawFlag = process.env[flagName]?.toLowerCase();\n99:   if (rawFlag === 'false') return false;\n100: \n101:   const flagEnabled = rawFlag === undefined || rawFlag.trim().length === 0 || rawFlag === 'true';\n102:   if (!flagEnabled) return false;\n103: \n104:   const rawRollout = process.env.SPECKIT_ROLLOUT_PERCENT;\n105:   const rolloutPercent = typeof rawRollout === 'string' && rawRollout.trim().length > 0\n106:     ? Number.parseInt(rawRollout, 10)\n107:     : 100;\n108:   const clampedRollout = Number.isFinite(rolloutPercent)\n109:     ? Math.max(0, Math.min(100, rolloutPercent))\n110:     : 100;\n111: \n112:   if (clampedRollout >= 100) return true;\n113:   if (clampedRollout <= 0) return false;\n114:   if (!identity || identity.trim().length === 0) return false;\n115: \n116:   let hash = 0;\n117:   for (let i = 0; i < identity.length; i += 1) {\n118:     hash = (hash * 31 + identity.charCodeAt(i)) >>> 0;\n119:   }\n120:   return (hash % 100) < clampedRollout;\n121: }\n122: \n123: /**\n124:  * Check whether adaptive fusion is enabled via the feature flag and rollout policy.\n125:  *\n126:  * @param identity - Optional identity string for rollout targeting\n127:  * @returns True if adaptive fusion is enabled\n128:  */\n129: export function isAdaptiveFusionEnabled(identity?: string): boolean {\n130:   return isFeatureEnabled(FEATURE_FLAG, identity);\n131: }\n132: \n133: /* --- 4. WEIGHT COMPUTATION --- */\n134: \n135: /**\n136:  * Compute adaptive fusion weights based on intent and optional document type.\n137:  * Document type can shift weights: e.g., 'decision' docs favour keywords,\n138:  * 'implementation' docs favour recency.\n139:  *\n140:  * @param intent - Classified query intent type\n141:  * @param documentType - Optional document type for weight adjustment\n142:  * @returns Computed fusion weights\n143:  */\n144: export function getAdaptiveWeights(\n145:   intent: string,\n146:   documentType?: string\n147: ): FusionWeights {\n148:   const base = INTENT_WEIGHT_PROFILES[intent] ?? { ...DEFAULT_WEIGHTS };\n149:   const weights: FusionWeights = { ...base };\n150: \n151:   // Document-type adjustments (proportional shifts, keep sum <= 1.0)\n152:   // Uses DOC_TYPE_WEIGHT_FACTOR (default 1.2 = 20% proportional shift) so\n153:   // small weights aren't disproportionately affected by flat additive shifts.\n154:   if (documentType) {\n155:     const inverseFactor = 2 - DOC_TYPE_WEIGHT_FACTOR; // e.g. 0.8 when factor is 1.2\n156:     switch (documentType) {\n157:       case 'decision':\n158:         // Decisions are best found by exact keyword matches\n159:         weights.keywordWeight = Math.min(1.0, weights.keywordWeight * DOC_TYPE_WEIGHT_FACTOR);\n160:         weights.semanticWeight = Math.max(0, weights.semanticWeight * inverseFactor);\n161:         break;\n162:       case 'implementation':\n163:         // Implementation docs: recency matters more\n164:         weights.recencyWeight = Math.min(1.0, weights.recencyWeight * DOC_TYPE_WEIGHT_FACTOR);\n165:         weights.semanticWeight = Math.max(0, weights.semanticWeight * inverseFactor);\n166:         break;\n167:       case 'research':\n168:         // Research docs: semantic similarity is paramount\n169:         weights.semanticWeight = Math.min(1.0, weights.semanticWeight * DOC_TYPE_WEIGHT_FACTOR);\n170:         weights.keywordWeight = Math.max(0, weights.keywordWeight * inverseFactor);\n171:         break;\n172:       // No default adjustment needed\n173:     }\n174:   }\n175: \n176:   const activeGraphWeight = typeof weights.graphWeight === 'number' && Number.isFinite(weights.graphWeight) && weights.graphWeight > 0\n177:     ? weights.graphWeight\n178:     : 0;\n179:   const activeSum =\n180:     weights.semanticWeight +\n181:     weights.keywordWeight +\n182:     weights.recencyWeight +\n183:     activeGraphWeight;\n184:   if (activeSum > 0 && Math.abs(activeSum - 1.0) > 0.001) {\n185:     weights.semanticWeight /= activeSum;\n186:     weights.keywordWeight /= activeSum;\n187:     weights.recencyWeight /= activeSum;\n188:     if (activeGraphWeight > 0) {\n189:       weights.graphWeight = activeGraphWeight / activeSum;\n190:     }\n191:   }\n192: \n193:   return weights;\n194: }\n195: \n196: /* --- 5. ADAPTIVE FUSION --- */\n197: \n198: /**\n199:  * Weighted RRF fusion. Applies FusionWeights to source lists before\n200:  * passing to `fuseResultsMulti`. The semanticWeight/keywordWeight map\n201:  * to vector/lexical list weights; recencyWeight is applied as a\n202:  * post-fusion boost based on item timestamps.\n203:  *\n204:  * @param semanticResults - Results from vector/semantic search\n205:  * @param keywordResults - Results from keyword/lexical search\n206:  * @param weights - Fusion weights for each channel\n207:  * @returns Fused and scored results sorted by RRF score\n208:  */\n209: export function adaptiveFuse(\n210:   semanticResults: RrfItem[],\n211:   keywordResults: RrfItem[],\n212:   weights: FusionWeights,\n213:   options: AdaptiveFuseOptions = {},\n214: ): FusionResult[] {\n215:   const { graphResults = [], additionalLists = [] } = options;\n216:   const lists: RankedList[] = [];\n217: \n218:   if (semanticResults.length > 0 && weights.semanticWeight > 0) {\n219:     lists.push({\n220:       source: 'vector',\n221:       results: semanticResults,\n222:       weight: weights.semanticWeight,\n223:     });\n224:   }\n225: \n226:   if (keywordResults.length > 0 && weights.keywordWeight > 0) {\n227:     lists.push({\n228:       source: 'keyword',\n229:       results: keywordResults,\n230:       weight: weights.keywordWeight,\n231:     });\n232:   }\n233: \n234:   if (graphResults.length > 0 && typeof weights.graphWeight === 'number' && weights.graphWeight > 0) {\n235:     lists.push({\n236:       source: 'graph',\n237:       results: graphResults,\n238:       weight: weights.graphWeight,\n239:     });\n240:   }\n241: \n242:   for (const list of additionalLists) {\n243:     if (!list || !Array.isArray(list.results) || list.results.length === 0) {\n244:       continue;\n245:     }\n246:     const weight = typeof list.weight === 'number' && Number.isFinite(list.weight)\n247:       ? list.weight\n248:       : 1;\n249:     if (weight <= 0) {\n250:       continue;\n251:     }\n252:     lists.push({\n253:       ...list,\n254:       weight,\n255:     });\n256:   }\n257: \n258:   if (lists.length === 0) {\n259:     // AI: Fix F3 — return empty on all-zero weights.\n260:     return [];\n\n(Showing lines 1-260 of 470. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Adaptive Fusion\n// ───────────────────────────────────────────────────────────────────\n\n// Local\nimport { fuseResultsMulti } from './rrf-fusion.js';\n\n// Type-only\nimport type { RrfItem, FusionResult, RankedList } from './rrf-fusion.js';\n\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: Adaptive shadow ranking, bounded proposals, and rollback\n\n\n/* --- 1. INTERFACES --- */\n\n/** Represents fusion weights. */\nexport interface FusionWeights {\n  /** Weight for semantic/vector search results (0-1) */\n  semanticWeight: number;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Adaptive Fusion\n// ───────────────────────────────────────────────────────────────────\n\n// Local\nimport { fuseResultsMulti } from './rrf-fusion.js';\n\n// Type-only\nimport type { RrfItem, FusionResult, RankedList } from './rrf-fusion.js';\n\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: Adaptive shadow ranking, bounded proposals, and rollback\n\n\n/* --- 1. INTERFACES --- */\n\n/** Represents fusion weights. */\nexport interface FusionWeights {\n  /** Weight for semantic/vector search results (0-1) */\n  semanticWeight: number;\n  /** Weight for keyword/lexical search results (0-1) */\n  keywordWeight: number;\n  /** Weight for recency-based scoring (0-1) */\n  recencyWeight: number;\n  /** Weight for graph channel results (0-1). Only used when graph channel active. */\n  graphWeight?: number;\n  /** Bias toward causal-edge signals within graph-assisted ranking (0-1). */\n  graphCausalBias?: number;\n}\n\n/** Represents degraded mode contract. */\nexport interface DegradedModeContract {\n  /** What failed */\n  failureMode: string;\n  /** What was used instead */\n  fallbackMode: string;\n  /** Impact on result confidence (0-1, where 0 = no impact, 1 = total loss) */\n  confidenceImpact: number;\n  /** Retry guidance for callers and typed trace contracts */\n  retryRecommendation: 'immediate' | 'delayed' | 'none';\n}\n\n/** Represents adaptive fusion result. */\nexport interface AdaptiveFusionResult {\n  results: FusionResult[];\n  weights: FusionWeights;\n  degraded?: DegradedModeContract;\n  darkRunDiff?: DarkRunDiff;\n}\n\n/** Represents dark run diff. */\nexport interface DarkRunDiff {\n  standardCount: number;\n  adaptiveCount: number;\n  orderDifferences: number;\n  topResultChanged: boolean;\n}\n\nexport interface AdaptiveFuseOptions {\n  graphResults?: RrfItem[];\n  additionalLists?: RankedList[];\n}\n\n/* --- 2. WEIGHT PROFILES --- */\n\nconst INTENT_WEIGHT_PROFILES: Record<string, FusionWeights> = {\n  understand:      { semanticWeight: 0.7, keywordWeight: 0.2, recencyWeight: 0.1, graphWeight: 0.15, graphCausalBias: 0.10 },\n  find_spec:       { semanticWeight: 0.7, keywordWeight: 0.2, recencyWeight: 0.1, graphWeight: 0.30, graphCausalBias: 0.10 },\n  fix_bug:         { semanticWeight: 0.4, keywordWeight: 0.4, recencyWeight: 0.2, graphWeight: 0.10, graphCausalBias: 0.15 },\n  add_feature:     { semanticWeight: 0.5, keywordWeight: 0.3, recencyWeight: 0.2, graphWeight: 0.20, graphCausalBias: 0.15 },\n  refactor:        { semanticWeight: 0.6, keywordWeight: 0.3, recencyWeight: 0.1, graphWeight: 0.15, graphCausalBias: 0.10 },\n  security_audit:  { semanticWeight: 0.3, keywordWeight: 0.5, recencyWeight: 0.2, graphWeight: 0.15, graphCausalBias: 0.10 },\n  find_decision:   { semanticWeight: 0.3, keywordWeight: 0.2, recencyWeight: 0.1, graphWeight: 0.50, graphCausalBias: 0.15 },\n  continuity:      { semanticWeight: 0.52, keywordWeight: 0.18, recencyWeight: 0.07, graphWeight: 0.23, graphCausalBias: 0.15 },\n};\n\nconst DEFAULT_WEIGHTS: FusionWeights = {\n  semanticWeight: 0.5,\n  keywordWeight: 0.3,\n  recencyWeight: 0.2,\n  graphWeight: 0.15,\n  graphCausalBias: 0.10,\n};\n\n/* --- 3. FEATURE FLAG --- */\n\nconst FEATURE_FLAG = 'SPECKIT_ADAPTIVE_FUSION';\n\n/** Proportional weight shift factor applied per document type to fine-tune intent weights.\n *  Multiplied against the base weight (20% shift) so small weights aren't disproportionately affected.\n *  Env-tunable via SPECKIT_DOC_TYPE_WEIGHT_FACTOR (default 1.2 = 20% proportional shift). */\nconst DOC_TYPE_WEIGHT_FACTOR = parseFloat(process.env.SPECKIT_DOC_TYPE_WEIGHT_FACTOR || '') || 1.2;\n\n/** Scaling factor applied to recency freshness before adding to RRF score. */\nconst RECENCY_BOOST_SCALE = 0.1;\n\nfunction isFeatureEnabled(flagName: string, identity?: string): boolean {\n  const rawFlag = process.env[flagName]?.toLowerCase();\n  if (rawFlag === 'false') return false;\n\n  const flagEnabled = rawFlag === undefined || rawFlag.trim().length === 0 || rawFlag === 'true';\n  if (!flagEnabled) return false;\n\n  const rawRollout = process.env.SPECKIT_ROLLOUT_PERCENT;\n  const rolloutPercent = typeof rawRollout === 'string' && rawRollout.trim().length > 0\n    ? Number.parseInt(rawRollout, 10)\n    : 100;\n  const clampedRollout = Number.isFinite(rolloutPercent)\n    ? Math.max(0, Math.min(100, rolloutPercent))\n    : 100;\n\n  if (clampedRollout >= 100) return true;\n  if (clampedRollout <= 0) return false;\n  if (!identity || identity.trim().length === 0) return false;\n\n  let hash = 0;\n  for (let i = 0; i < identity.length; i += 1) {\n    hash = (hash * 31 + identity.charCodeAt(i)) >>> 0;\n  }\n  return (hash % 100) < clampedRollout;\n}\n\n/**\n * Check whether adaptive fusion is enabled via the feature flag and rollout policy.\n *\n * @param identity - Optional identity string for rollout targeting\n * @returns True if adaptive fusion is enabled\n */\nexport function isAdaptiveFusionEnabled(identity?: string): boolean {\n  return isFeatureEnabled(FEATURE_FLAG, identity);\n}\n\n/* --- 4. WEIGHT COMPUTATION --- */\n\n/**\n * Compute adaptive fusion weights based on intent and optional document type.\n * Document type can shift weights: e.g., 'decision' docs favour keywords,\n * 'implementation' docs favour recency.\n *\n * @param intent - Classified query intent type\n * @param documentType - Optional document type for weight adjustment\n * @returns Computed fusion weights\n */\nexport function getAdaptiveWeights(\n  intent: string,\n  documentType?: string\n): FusionWeights {\n  const base = INTENT_WEIGHT_PROFILES[intent] ?? { ...DEFAULT_WEIGHTS };\n  const weights: FusionWeights = { ...base };\n\n  // Document-type adjustments (proportional shifts, keep sum <= 1.0)\n  // Uses DOC_TYPE_WEIGHT_FACTOR (default 1.2 = 20% proportional shift) so\n  // small weights aren't disproportionately affected by flat additive shifts.\n  if (documentType) {\n    const inverseFactor = 2 - DOC_TYPE_WEIGHT_FACTOR; // e.g. 0.8 when factor is 1.2\n    switch (documentType) {\n      case 'decision':\n        // Decisions are best found by exact keyword matches\n        weights.keywordWeight = Math.min(1.0, weights.keywordWeight * DOC_TYPE_WEIGHT_FACTOR);\n        weights.semanticWeight = Math.max(0, weights.semanticWeight * inverseFactor);\n        break;\n      case 'implementation':\n        // Implementation docs: recency matters more\n        weights.recencyWeight = Math.min(1.0, weights.recencyWeight * DOC_TYPE_WEIGHT_FACTOR);\n        weights.semanticWeight = Math.max(0, weights.semanticWeight * inverseFactor);\n        break;\n      case 'research':\n        // Research docs: semantic similarity is paramount\n        weights.semanticWeight = Math.min(1.0, weights.semanticWeight * DOC_TYPE_WEIGHT_FACTOR);\n        weights.keywordWeight = Math.max(0, weights.keywordWeight * inverseFactor);\n        break;\n      // No default adjustment needed\n    }\n  }\n\n  const activeGraphWeight = typeof weights.graphWeight === 'number' && Number.isFinite(weights.graphWeight) && weights.graphWeight > 0\n    ? weights.graphWeight\n    : 0;\n  const activeSum =\n    weights.semanticWeight +\n    weights.keywordWeight +\n    weights.recencyWeight +\n    activeGraphWeight;\n  if (activeSum > 0 && Math.abs(activeSum - 1.0) > 0.001) {\n    weights.semanticWeight /= activeSum;\n    weights.keywordWeight /= activeSum;\n    weights.recencyWeight /= activeSum;\n    if (activeGraphWeight > 0) {\n      weights.graphWeight = activeGraphWeight / activeSum;\n    }\n  }\n\n  return weights;\n}\n\n/* --- 5. ADAPTIVE FUSION --- */\n\n/**\n * Weighted RRF fusion. Applies FusionWeights to source lists before\n * passing to `fuseResultsMulti`. The semanticWeight/keywordWeight map\n * to vector/lexical list weights; recencyWeight is applied as a\n * post-fusion boost based on item timestamps.\n *\n * @param semanticResults - Results from vector/semantic search\n * @param keywordResults - Results from keyword/lexical search\n * @param weights - Fusion weights for each channel\n * @returns Fused and scored results sorted by RRF score\n */\nexport function adaptiveFuse(\n  semanticResults: RrfItem[],\n  keywordResults: RrfItem[],\n  weights: FusionWeights,\n  options: AdaptiveFuseOptions = {},\n): FusionResult[] {\n  const { graphResults = [], additionalLists = [] } = options;\n  const lists: RankedList[] = [];\n\n  if (semanticResults.length > 0 && weights.semanticWeight > 0) {\n    lists.push({\n      source: 'vector',\n      results: semanticResults,\n      weight: weights.semanticWeight,\n    });\n  }\n\n  if (keywordResults.length > 0 && weights.keywordWeight > 0) {\n    lists.push({\n      source: 'keyword',\n      results: keywordResults,\n      weight: weights.keywordWeight,\n    });\n  }\n\n  if (graphResults.length > 0 && typeof weights.graphWeight === 'number' && weights.graphWeight > 0) {\n    lists.push({\n      source: 'graph',\n      results: graphResults,\n      weight: weights.graphWeight,\n    });\n  }\n\n  for (const list of additionalLists) {\n    if (!list || !Array.isArray(list.results) || list.results.length === 0) {\n      continue;\n    }\n    const weight = typeof list.weight === 'number' && Number.isFinite(list.weight)\n      ? list.weight\n      : 1;\n    if (weight <= 0) {\n      continue;\n    }\n    lists.push({\n      ...list,\n      weight,\n    });\n  }\n\n  if (lists.length === 0) {\n    // AI: Fix F3 — return empty on all-zero weights.\n    return [];","lineStart":1,"lineEnd":260,"totalLines":470,"truncated":true}},"title":".opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","time":{"start":1781764413110,"end":1781764413117}},"metadata":{"openai":{"itemId":"fc_0cd6d06a8bfac3ef016a33913bc9008191895efe6fbbf57deb"}},"id":"prt_ed96f51aa001CHE7SWvBvGybVe","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96f3fa1001LKWCC66Wsnb1ij"}}
{"type":"step_finish","timestamp":1781764413462,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"id":"prt_ed96f5815001zlMkk1ambx3MAs","reason":"tool-calls","snapshot":"7568198349df1e5b29dd888955f210c316b90e4f","messageID":"msg_ed96f3fa1001LKWCC66Wsnb1ij","sessionID":"ses_126974374fferlHj5CU2Guj68V","type":"step-finish","tokens":{"total":219529,"input":846,"output":59,"reasoning":0,"cache":{"write":0,"read":218624}},"cost":0}}
{"type":"step_start","timestamp":1781764417092,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"id":"prt_ed96f6641001AvzXpAeEiCYBwp","messageID":"msg_ed96f5921001734UJeBYzPELR5","sessionID":"ses_126974374fferlHj5CU2Guj68V","snapshot":"7568198349df1e5b29dd888955f210c316b90e4f","type":"step-start"}}
{"type":"tool_use","timestamp":1781764427254,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_lDlVioMh45oJBVa2SfEXXQnd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","offset":261,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts</path>\n<type>file</type>\n<content>\n261:   }\n262: \n263:   const fused = fuseResultsMulti(lists);\n264: \n265:   // Apply recency boost if recencyWeight > 0, then re-normalize to [0,1]\n266:   // Boost MUST be followed by normalization to keep scores in [0,1]\n267:   if (weights.recencyWeight > 0) {\n268:     applyRecencyBoost(fused, weights.recencyWeight);\n269: \n270:     const maxScore = fused.reduce((mx, r) => Math.max(mx, r.rrfScore), 0);\n271:     if (maxScore > 1.0) {\n272:       for (const r of fused) {\n273:         r.rrfScore /= maxScore;\n274:       }\n275:     }\n276:   }\n277: \n278:   // Re-sort after recency boost\n279:   fused.sort((a, b) => b.rrfScore - a.rrfScore);\n280: \n281:   return fused;\n282: }\n283: \n284: /**\n285:  * Apply a recency boost to fused results. Items with a `created_at`\n286:  * timestamp receive a bonus proportional to how recent they are.\n287:  * Falls back gracefully when no timestamps are present.\n288:  */\n289: function applyRecencyBoost(results: FusionResult[], recencyWeight: number): void {\n290:   const now = Date.now();\n291:   const ONE_DAY_MS = 86_400_000;\n292:   const MAX_AGE_DAYS = 365;\n293: \n294:   for (const r of results) {\n295:     const createdAt = r.created_at as string | undefined;\n296:     if (!createdAt) continue;\n297: \n298:     try {\n299:       const ts = new Date(createdAt).getTime();\n300:       if (Number.isNaN(ts)) continue;\n301: \n302:       const ageDays = Math.max(0, (now - ts) / ONE_DAY_MS);\n303:       // Exponential decay: recent items get higher boost\n304:       const freshness = Math.exp(-ageDays / MAX_AGE_DAYS);\n305:       r.rrfScore += freshness * recencyWeight * RECENCY_BOOST_SCALE;\n306:     } catch (_err: unknown) {\n307:       if (_err instanceof Error) {\n308:         void _err.message;\n309:       }\n310:       /* AI-GUARD: Skip items with invalid dates — never fail the fusion pipeline */\n311:     }\n312:   }\n313: }\n314: \n315: /* --- 6. STANDARD FALLBACK --- */\n316: \n317: /**\n318:  * Standard RRF fusion without adaptive weighting (deterministic fallback).\n319:  * Uses equal weights for all sources.\n320:  *\n321:  * @param semanticResults - Results from vector/semantic search\n322:  * @param keywordResults - Results from keyword/lexical search\n323:  * @returns Fused results with equal-weight RRF scores\n324:  */\n325: export function standardFuse(\n326:   semanticResults: RrfItem[],\n327:   keywordResults: RrfItem[]\n328: ): FusionResult[] {\n329:   const lists: RankedList[] = [];\n330: \n331:   if (semanticResults.length > 0) {\n332:     lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n333:   }\n334: \n335:   if (keywordResults.length > 0) {\n336:     lists.push({ source: 'keyword', results: keywordResults, weight: 1.0 });\n337:   }\n338: \n339:   if (lists.length === 0) return [];\n340: \n341:   return fuseResultsMulti(lists);\n342: }\n343: \n344: /* --- 7. DARK-RUN MODE --- */\n345: \n346: function computeDarkRunDiff(\n347:   standardResults: FusionResult[],\n348:   adaptiveResults: FusionResult[]\n349: ): DarkRunDiff {\n350:   let orderDifferences = 0;\n351:   const maxLen = Math.max(standardResults.length, adaptiveResults.length);\n352: \n353:   for (let i = 0; i < maxLen; i++) {\n354:     const stdId = standardResults[i]?.id;\n355:     const adpId = adaptiveResults[i]?.id;\n356:     if (stdId !== adpId) {\n357:       orderDifferences++;\n358:     }\n359:   }\n360: \n\n(Showing lines 261-360 of 470. Use offset=361 to continue.)\n</content>","metadata":{"preview":"  }\n\n  const fused = fuseResultsMulti(lists);\n\n  // Apply recency boost if recencyWeight > 0, then re-normalize to [0,1]\n  // Boost MUST be followed by normalization to keep scores in [0,1]\n  if (weights.recencyWeight > 0) {\n    applyRecencyBoost(fused, weights.recencyWeight);\n\n    const maxScore = fused.reduce((mx, r) => Math.max(mx, r.rrfScore), 0);\n    if (maxScore > 1.0) {\n      for (const r of fused) {\n        r.rrfScore /= maxScore;\n      }\n    }\n  }\n\n  // Re-sort after recency boost\n  fused.sort((a, b) => b.rrfScore - a.rrfScore);\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","text":"  }\n\n  const fused = fuseResultsMulti(lists);\n\n  // Apply recency boost if recencyWeight > 0, then re-normalize to [0,1]\n  // Boost MUST be followed by normalization to keep scores in [0,1]\n  if (weights.recencyWeight > 0) {\n    applyRecencyBoost(fused, weights.recencyWeight);\n\n    const maxScore = fused.reduce((mx, r) => Math.max(mx, r.rrfScore), 0);\n    if (maxScore > 1.0) {\n      for (const r of fused) {\n        r.rrfScore /= maxScore;\n      }\n    }\n  }\n\n  // Re-sort after recency boost\n  fused.sort((a, b) => b.rrfScore - a.rrfScore);\n\n  return fused;\n}\n\n/**\n * Apply a recency boost to fused results. Items with a `created_at`\n * timestamp receive a bonus proportional to how recent they are.\n * Falls back gracefully when no timestamps are present.\n */\nfunction applyRecencyBoost(results: FusionResult[], recencyWeight: number): void {\n  const now = Date.now();\n  const ONE_DAY_MS = 86_400_000;\n  const MAX_AGE_DAYS = 365;\n\n  for (const r of results) {\n    const createdAt = r.created_at as string | undefined;\n    if (!createdAt) continue;\n\n    try {\n      const ts = new Date(createdAt).getTime();\n      if (Number.isNaN(ts)) continue;\n\n      const ageDays = Math.max(0, (now - ts) / ONE_DAY_MS);\n      // Exponential decay: recent items get higher boost\n      const freshness = Math.exp(-ageDays / MAX_AGE_DAYS);\n      r.rrfScore += freshness * recencyWeight * RECENCY_BOOST_SCALE;\n    } catch (_err: unknown) {\n      if (_err instanceof Error) {\n        void _err.message;\n      }\n      /* AI-GUARD: Skip items with invalid dates — never fail the fusion pipeline */\n    }\n  }\n}\n\n/* --- 6. STANDARD FALLBACK --- */\n\n/**\n * Standard RRF fusion without adaptive weighting (deterministic fallback).\n * Uses equal weights for all sources.\n *\n * @param semanticResults - Results from vector/semantic search\n * @param keywordResults - Results from keyword/lexical search\n * @returns Fused results with equal-weight RRF scores\n */\nexport function standardFuse(\n  semanticResults: RrfItem[],\n  keywordResults: RrfItem[]\n): FusionResult[] {\n  const lists: RankedList[] = [];\n\n  if (semanticResults.length > 0) {\n    lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n  }\n\n  if (keywordResults.length > 0) {\n    lists.push({ source: 'keyword', results: keywordResults, weight: 1.0 });\n  }\n\n  if (lists.length === 0) return [];\n\n  return fuseResultsMulti(lists);\n}\n\n/* --- 7. DARK-RUN MODE --- */\n\nfunction computeDarkRunDiff(\n  standardResults: FusionResult[],\n  adaptiveResults: FusionResult[]\n): DarkRunDiff {\n  let orderDifferences = 0;\n  const maxLen = Math.max(standardResults.length, adaptiveResults.length);\n\n  for (let i = 0; i < maxLen; i++) {\n    const stdId = standardResults[i]?.id;\n    const adpId = adaptiveResults[i]?.id;\n    if (stdId !== adpId) {\n      orderDifferences++;\n    }\n  }\n","lineStart":261,"lineEnd":360,"totalLines":470,"truncated":true}},"title":".opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","time":{"start":1781764427249,"end":1781764427252}},"metada