{"type":"tool_use","timestamp":1782919253158,"sessionID":"ses_0e1c04adcffe04QJWsDQQqIgY4","part":{"type":"tool","tool":"read","callID":"call_vJk4Put0GTfNhXuyrEkGOSi5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n5: // ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n6: // ║          declared mode disagrees with mode-registry.json's entry for    ║\n7: // ║          the actual subagent_type being dispatched.                     ║\n8: // ╚══════════════════════════════════════════════════════════════════════════╝\n9: 'use strict';\n10: \n11: // ─────────────────────────────────────────────────────────────────────────────\n12: // 1. IMPORTS\n13: // ─────────────────────────────────────────────────────────────────────────────\n14: \n15: import { readFileSync } from 'node:fs';\n16: import { join } from 'node:path';\n17: \n18: // ─────────────────────────────────────────────────────────────────────────────\n19: // 2. CONSTANTS\n20: // ─────────────────────────────────────────────────────────────────────────────\n21: \n22: const REGISTRY_RELATIVE_PATH = '.opencode/skills/deep-loop-workflows/mode-registry.json';\n23: const REJECT_MODE_ENV = 'MK_DEEP_LOOP_GUARD_REJECT';\n24: \n25: // ─────────────────────────────────────────────────────────────────────────────\n26: // 3. HELPERS\n27: // ─────────────────────────────────────────────────────────────────────────────\n28: \n29: function loadRegistryAgents(registryPath) {\n30:   try {\n31:     const raw = readFileSync(registryPath, 'utf8');\n32:     const data = JSON.parse(raw);\n33:     const map = new Map();\n34:     for (const mode of data.modes || []) {\n35:       if (mode.agent) map.set(mode.agent, mode);\n36:     }\n37:     return map;\n38:   } catch (_) {\n39:     return null;\n40:   }\n41: }\n42: \n43: function declaredModeFromPrompt(promptText) {\n44:   const match = /mode=([a-z0-9-]+)/i.exec(promptText || '');\n45:   return match ? match[1] : null;\n46: }\n47: \n48: function mismatchDetail(subagentType, registryMode, declaredMode) {\n49:   return [\n50:     'mk-deep-loop-guard: Deep Route mode mismatch --',\n51:     `dispatch targets subagent_type=\"${subagentType}\"`,\n52:     `(registry mode=\"${registryMode}\")`,\n53:     `but the prompt declares mode=\"${declaredMode}\"`,\n54:   ].join(' ');\n55: }\n56: \n57: // ─────────────────────────────────────────────────────────────────────────────\n58: // 4. PLUGIN FACTORY\n59: // ─────────────────────────────────────────────────────────────────────────────\n60: \n61: /**\n62:  * Create the mk-deep-loop-guard OpenCode plugin hooks.\n63:  *\n64:  * Hard limits (by design, not oversight):\n65:  * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n66:  * - Does not catch a schema-valid, route-matched artifact that internally\n67:  *   does semantically wrong-mode work.\n68:  * - Fails open on its own errors (missing/unreadable registry, unexpected\n69:  *   arg shapes) so a bug here never blocks unrelated, correctly-routed work.\n70:  *\n71:  * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n72:  * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n73:  */\n74: export default async function MkDeepLoopGuardPlugin(ctx) {\n75:   const projectDir = ctx?.directory || process.cwd();\n76:   const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n77: \n78:   return {\n79:     async 'tool.execute.before'(input, output) {\n80:       try {\n81:         if (!input || input.tool !== 'task') return;\n82:         const args = output && output.args;\n83:         if (!args || typeof args !== 'object') return;\n84: \n85:         const subagentType = args.subagent_type || args.subagentType;\n86:         if (!subagentType) return;\n87: \n88:         const registry = loadRegistryAgents(registryPath);\n89:         if (!registry) return;\n90: \n91:         const entry = registry.get(subagentType);\n92:         if (!entry) return;\n93: \n94:         const declaredMode = declaredModeFromPrompt(args.prompt);\n95:         if (!declaredMode || declaredMode === entry.workflowMode) return;\n96: \n97:         const detail = mismatchDetail(subagentType, entry.workflowMode, declaredMode);\n98: \n99:         if (process.env[REJECT_MODE_ENV] === '1') {\n100:           throw new Error(detail);\n101:         }\n102:         console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n103:       } catch (err) {\n104:         if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n105:         // Fail open on any unexpected internal error -- never block unrelated dispatches.\n106:       }\n107:     },\n108:   };\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n// ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n// ║          declared mode disagrees with mode-registry.json's entry for    ║\n// ║          the actual subagent_type being dispatched.                     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nimport { readFileSync } from 'node:fs';\nimport { join } from 'node:path';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n// ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n// ║          declared mode disagrees with mode-registry.json's entry for    ║\n// ║          the actual subagent_type being dispatched.                     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nimport { readFileSync } from 'node:fs';\nimport { join } from 'node:path';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst REGISTRY_RELATIVE_PATH = '.opencode/skills/deep-loop-workflows/mode-registry.json';\nconst REJECT_MODE_ENV = 'MK_DEEP_LOOP_GUARD_REJECT';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction loadRegistryAgents(registryPath) {\n  try {\n    const raw = readFileSync(registryPath, 'utf8');\n    const data = JSON.parse(raw);\n    const map = new Map();\n    for (const mode of data.modes || []) {\n      if (mode.agent) map.set(mode.agent, mode);\n    }\n    return map;\n  } catch (_) {\n    return null;\n  }\n}\n\nfunction declaredModeFromPrompt(promptText) {\n  const match = /mode=([a-z0-9-]+)/i.exec(promptText || '');\n  return match ? match[1] : null;\n}\n\nfunction mismatchDetail(subagentType, registryMode, declaredMode) {\n  return [\n    'mk-deep-loop-guard: Deep Route mode mismatch --',\n    `dispatch targets subagent_type=\"${subagentType}\"`,\n    `(registry mode=\"${registryMode}\")`,\n    `but the prompt declares mode=\"${declaredMode}\"`,\n  ].join(' ');\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. PLUGIN FACTORY\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Create the mk-deep-loop-guard OpenCode plugin hooks.\n *\n * Hard limits (by design, not oversight):\n * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n * - Does not catch a schema-valid, route-matched artifact that internally\n *   does semantically wrong-mode work.\n * - Fails open on its own errors (missing/unreadable registry, unexpected\n *   arg shapes) so a bug here never blocks unrelated, correctly-routed work.\n *\n * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n */\nexport default async function MkDeepLoopGuardPlugin(ctx) {\n  const projectDir = ctx?.directory || process.cwd();\n  const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n\n  return {\n    async 'tool.execute.before'(input, output) {\n      try {\n        if (!input || input.tool !== 'task') return;\n        const args = output && output.args;\n        if (!args || typeof args !== 'object') return;\n\n        const subagentType = args.subagent_type || args.subagentType;\n        if (!subagentType) return;\n\n        const registry = loadRegistryAgents(registryPath);\n        if (!registry) return;\n\n        const entry = registry.get(subagentType);\n        if (!entry) return;\n\n        const declaredMode = declaredModeFromPrompt(args.prompt);\n        if (!declaredMode || declaredMode === entry.workflowMode) return;\n\n        const detail = mismatchDetail(subagentType, entry.workflowMode, declaredMode);\n\n        if (process.env[REJECT_MODE_ENV] === '1') {\n          throw new Error(detail);\n        }\n        console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n      } catch (err) {\n        if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n        // Fail open on any unexpected internal error -- never block unrelated dispatches.\n      }\n    },\n  };\n}","lineStart":1,"lineEnd":109,"totalLines":109,"truncated":false}},"title":".opencode/plugins/mk-deep-loop-guard.js","time":{"start":1782919253150,"end":1782919253156}},"metadata":{"openai":{"itemId":"fc_0c681677c7f87e99016a453055018c8191b864a18477c0857d"}},"id":"prt_f1e44cc98001L1aBLnNK91xEmU","sessionID":"ses_0e1c04adcffe04QJWsDQQqIgY4","messageID":"msg_f1e4479af001WEObKcXrNjJn6f"}}
