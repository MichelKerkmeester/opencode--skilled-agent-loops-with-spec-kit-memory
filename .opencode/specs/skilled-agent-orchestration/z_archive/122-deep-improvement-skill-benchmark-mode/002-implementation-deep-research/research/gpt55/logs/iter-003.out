   224	  return {
   225	    id: fixture.id,
   226	    outputPath,
   227	    score,
   228	    maxScore: 100,
   229	    passed: failureModes.length === 0,
   230	    missingHeadings,
   231	    missingPatterns,
   232	    forbiddenMatches,
