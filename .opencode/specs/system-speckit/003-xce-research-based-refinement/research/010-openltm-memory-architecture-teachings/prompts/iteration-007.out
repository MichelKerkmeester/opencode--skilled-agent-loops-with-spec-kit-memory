    \"liveWeightsFrozen\": true,\n      \"recommendations\": [\n        {\n          \"skillId\": \"system-spec-kit\",\n          \"liveScore\": 0.653842,\n          \"shadowScore\": 0.617507,\n          \"delta\": -0.036335,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"sk-code-review\",\n          \"liveScore\": 0.484458,\n          \"shadowScore\": 0.454717,\n          \"delta\": -0.029741,\n          \"dominantShadowLane\": \"explicit_author\"\n        }\n      ]\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1780925615367,"end":1780925615630}},"metadata":{"openai":{"itemId":"fc_0c28219f1d8aee5a016a26c4aefce08191adeda7655ca555bb"}},"id":"prt_ea7704bd3001CKJZ9NQxKtOh5b","sessionID":"ses_158903c2bffeCx3bRrBHJwKOQa","messageID":"msg_ea7703159001yCrRyjtmdXObKG"}}
