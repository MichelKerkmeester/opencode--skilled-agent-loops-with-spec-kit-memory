{"type":"tool_use","timestamp":1784389939406,"sessionID":"ses_08a55b97affezjS590Sxu4oUZ9","part":{"type":"tool","tool":"read","callID":"call_1tENm302uiUilasrUFyUgmLR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":1427,"limit":850},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n1427:             - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n1428:         post_dispatch_validate:\n1429:           validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1430:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1431:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1432:           assert_exists: \"{state_paths.iteration_pattern}\"\n1433:           assert_appended: \"{state_paths.state_log}\"\n1434:           assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n1435:           route_proof:\n1436:             mode: review\n1437:             target_agent: deep-review\n1438:             agent_definition_loaded: true\n1439:             resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n1440:           dispatchReceipt:\n1441:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1442:             dispatchId: \"review-i{current_iteration}-g{generation}\"\n1443:           assert_canonical_type: \"iteration\"\n1444:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1445:           assert_delta_file_has_iteration_record: true\n1446:           failure_reasons:\n1447:             - iteration_file_missing\n1448:             - iteration_file_empty\n1449:             - jsonl_not_appended\n1450:             - jsonl_missing_fields\n1451:             - jsonl_parse_error\n1452:             - jsonl_wrong_type\n1453:             - delta_file_missing\n1454:             - delta_file_empty\n1455:             - delta_file_missing_iteration_record\n1456:             - executor_missing\n1457:             - dispatch_failure_logged\n1458:             - v2_missing_ledger\n1459:             - v2_uncited_ledger_row\n1460:             - v2_broken_linked_finding\n1461:             - v2_shallow_finding_details\n1462:             - delta_iteration_id_mismatch\n1463:             - state_delta_iteration_mismatch\n1464:             - route_proof_missing\n1465:             - route_proof_mismatch\n1466:           warning_surface:\n1467:             source: \"result.warnings\"\n1468:             action: \"emit schema_advisory canonical conflict event\"\n1469:             severity: \"advisory\"\n1470:             event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1471:             note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n1472:           on_failure:\n1473:             action: \"emit schema_mismatch canonical conflict event\"\n1474:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n1475:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1476:         record_executor_audit:\n1477:           skip_when: \"config.executor.kind == 'native'\"\n1478:           target: \"{state_paths.state_log}\"\n1479:           field: \"executor\"\n1480:           value:\n1481:             kind: \"{config.executor.kind}\"\n1482:             model: \"{config.executor.model}\"\n1483:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1484:             serviceTier: \"{config.executor.serviceTier}\"\n1485: \n1486:       step_evaluate_results:\n1487:         action: \"Verify iteration outputs and extract metrics\"\n1488:         verify:\n1489:           - file_exists: \"{state_paths.iteration_pattern}\"\n1490:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1491:           - strategy_updated: \"Strategy.md has been modified\"\n1492:         extract:\n1493:           - newFindingsRatio: \"From latest JSONL iteration record\"\n1494:           - findings_count: \"From latest JSONL iteration record\"\n1495:           - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n1496:           - dimensions: \"From latest JSONL iteration record\"\n1497:           - files_reviewed: \"From latest JSONL iteration record\"\n1498:           - status: \"From latest JSONL iteration record\"\n1499:           - reviewed_artifacts: \"From latest JSONL iteration record\"\n1500:           - traceability_checks: \"From latest JSONL iteration record when present\"\n1501:         on_missing_outputs:\n1502:           action: \"Mark iteration as 'error', continue to next\"\n1503:           # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n1504:           # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1505:           append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n1506: \n1507:       step_post_iteration_claim_adjudication:\n1508:         action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n1509:         verify:\n1510:           - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n1511:           - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n1512:           - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n1513:         on_pass:\n1514:           set:\n1515:             claim_adjudication_passed: true\n1516:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1517:           log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n1518:         on_fail:\n1519:           action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n1520:           set:\n1521:             claim_adjudication_passed: false\n1522:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1523:           log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n1524: \n1525:       step_reduce_review_state:\n1526:         action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n1527:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n1528:         read:\n1529:           - \"{state_paths.state_log}\"\n1530:           - \"{state_paths.iteration_pattern}\"\n1531:           - \"{state_paths.findings_registry}\"\n1532:           - \"{state_paths.strategy}\"\n1533:         write:\n1534:           - \"{state_paths.findings_registry}\"\n1535:           - \"{state_paths.dashboard}\"\n1536:           - \"{state_paths.strategy}\"\n1537:         failure_modes:\n1538:           malformed_delta: \"skip + warn\"\n1539:           missing_iteration_file: \"no-op + error\"\n1540:           schema_mismatch: \"reject + conflict event\"\n1541:         guarantee: \"Idempotent for identical inputs\"\n1542:         note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n1543: \n1544:       step_graph_upsert:\n1545:         action: \"Project canonical review coverage plus optional graphEvents into graph nodes and edges, then upsert it\"\n1546:         read:\n1547:           - \"{state_paths.config}\"\n1548:           - \"{state_paths.state_log}\"\n1549:           - \"{state_paths.findings_registry}\"\n1550:         transform: |\n1551:           1. Read the latest iteration JSONL record after reducer completion.\n1552:           2. Seed one stable DIMENSION node for every configured review dimension, falling back to correctness, security, traceability, and maintainability.\n1553:           3. Seed one stable FILE node for every latest-record filesReviewed entry and emit a COVERS edge from each latest-record dimension to each reviewed file.\n1554:           4. Merge optional graphEvents nodes after normalizing type = uppercase(event.kind || event.nodeKind || event.type); keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n1555:           5. Merge optional graphEvents edges after normalizing relation = uppercase(event.relation); keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n1556:           6. Emit nodes as { id, type, name, iteration, metadata } and edges as { id, relation, sourceId, targetId, metadata }, deduplicated by id.\n1557:           7. Discard malformed or unknown optional events without discarding canonical dimension and file coverage.\n1558:         bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n1559:         note: \"Invoke the runtime script directly. Canonical iteration fields provide baseline coverage; graphEvents add richer evidence.\"\n1560:         outputs:\n1561:           - graph_nodes_json: \"JSON array of canonical and optional review graph nodes\"\n1562:           - graph_edges_json: \"JSON array of canonical and optional review graph edges\"\n1563: \n1564:       step_generate_dashboard:\n1565:         action: \"Generate or refresh the review dashboard\"\n1566:         read:\n1567:           - \"{state_paths.state_log}\"\n1568:           - \"{state_paths.findings_registry}\"\n1569:           - \"{state_paths.strategy}\"\n1570:         content: |\n1571:           # Deep Review Dashboard - Session Overview\n1572: \n1573:           Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n1574: \n1575:           ## Status\n1576:           - Review Target: {review_target} ({review_target_type})\n1577:           - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n1578:           - Iteration: {current_iteration} of {max_iterations}\n1579:           - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n1580:           - hasAdvisories: {has_advisories}\n1581: \n1582:           ## Findings Summary\n1583:           | Severity | Count | Trend |\n1584:           |----------|------:|-------|\n1585:           | P0 (Blockers) | {p0_count} | {p0_trend} |\n1586:           | P1 (Required) | {p1_count} | {p1_trend} |\n1587:           | P2 (Suggestions) | {p2_count} | {p2_trend} |\n1588: \n1589:           ## Dimension Coverage\n1590:           | Dimension | Status | Iteration | Findings |\n1591:           |-----------|--------|-----------|----------|\n1592:           | [per dimension from strategy + JSONL] |\n1593: \n1594:           ## Traceability Coverage\n1595:           | Protocol | Level | Status | Findings |\n1596:           |----------|-------|--------|----------|\n1597:           | [per protocol from traceabilityChecks] |\n1598: \n1599:           ## Progress\n1600:           | # | Dimension | Ratio | P0/P1/P2 | Status |\n1601:           |---|-----------|-------|----------|--------|\n1602:           | [per iteration from JSONL] |\n1603: \n1604:           ## Trend\n1605:           - Last 3 ratios: [{ratios}] [{trend}]\n1606:           - Stuck count: {stuck_count}\n1607:           - Gate violations: {guard_violations}\n1608: \n1609:           ## Next Focus\n1610:           {next_dimension}\n1611:         output: \"{state_paths.dashboard}\"\n1612:         note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n1613: \n1614:       step_update_tracking:\n1615:         action: \"Update loop tracking variables\"\n1616:         set:\n1617:           current_iteration: \"{current_iteration + 1}\"\n1618:           p0_count: \"Accumulate from severity_counts\"\n1619:           p1_count: \"Accumulate from severity_counts\"\n1620:           p2_count: \"Accumulate from severity_counts\"\n1621:           stuck_count: |\n1622:             if status == 'thought': unchanged (skip)\n1623:             if status == 'insight': 0 (reset)\n1624:             if newFindingsRatio <= 0.05: stuck_count + 1\n1625:             else: 0\n1626:         log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n1627: \n1628:       step_loop_decision:\n1629:         action: \"Return to step_read_state for next iteration\"\n1630:         goto: step_read_state\n1631: \n1632:   # ═══════════════════════════════════════════════════════════════\n1633:   # PHASE 3: SYNTHESIS\n1634:   # ═══════════════════════════════════════════════════════════════\n1635:   phase_synthesis:\n1636:     purpose: Compile all iteration findings into review/review-report.md\n1637:     steps:\n1638: \n1639:       step_fanout_merge:\n1640:         description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n1641:         skip_when: \"config.fanout is absent\"\n1642:         command: |\n1643:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n1644:             --loop-type review \\\n1645:             --artifact-dir {artifact_dir}\n1646:         working_directory: \"{repo_root}\"\n1647:         wait_for_completion: true\n1648:         bind_from_output:\n1649:           p0_count: \"active_p0\"\n1650:           p1_count: \"active_p1\"\n1651:           p2_count: \"active_p2\"\n1652: \n1653:       step_hydrate_summary_metrics:\n1654:         action: \"Hydrate summary metrics before synthesis\"\n1655:         read:\n1656:           - \"{state_paths.config}\"\n1657:           - \"{state_paths.state_log}\"\n1658:           - \"{state_paths.findings_registry}\"\n1659:           - \"{state_paths.strategy}\"\n1660:         extract:\n1661:           - iteration_count: \"Count lines where type === 'iteration'\"\n1662:           - p0_count: \"Total P0 findings across all iterations (deduped)\"\n1663:           - p1_count: \"Total P1 findings across all iterations (deduped)\"\n1664:           - p2_count: \"Total P2 findings across all iterations (deduped)\"\n1665:           - dimensions_covered: \"List of reviewed dimensions\"\n1666:           - dimension_coverage: \"covered / total\"\n1667:           - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n1668:           - last_3_summaries: \"Summarize the latest 3 iteration records\"\n1669:           - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1670: \n1671:       # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n1672:       # - PASS: no P0 or P1 findings (P2-only or clean)\n1673:       # - CONDITIONAL: any P1 findings (no P0)\n1674:       # - FAIL: any P0 findings\n1675:       # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n1676:       step_derive_verdict:\n1677:         action: \"Derive review verdict from accumulated findings\"\n1678:         algorithm: |\n1679:           if p0_count > 0:\n1680:             verdict = \"FAIL\"\n1681:           elif p1_count > 0:\n1682:             verdict = \"CONDITIONAL\"\n1683:           else:\n1684:             verdict = \"PASS\"\n1685:           has_advisories = (verdict == \"PASS\" and p2_count > 0)\n1686:           ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n1687:         outputs:\n1688:           - verdict: \"PASS | CONDITIONAL | FAIL\"\n1689:           - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n1690:           - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n1691:         contract: |\n1692:           Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n1693:           Downstream automation parses this final line via exact string match — do not vary the format.\n1694: \n1695:       step_read_all_iterations:\n1696:         action: \"Read all iteration files and strategy\"\n1697:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1698:         read_also: \"{state_paths.strategy}\"\n1699: \n1700:       step_build_finding_registry:\n1701:         action: \"Build deduplicated finding registry from all iterations\"\n1702:         algorithm: |\n1703:           1. Extract all findings from iteration JSONL delta files\n1704:           2. Compute content_hash for each finding (emission requirement):\n1705:              content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n1706:              Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n1707:           3. Two-tier dedup:\n1708:              PRIMARY: group by content_hash field\n1709:                - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n1710:                - Keep highest severity on duplicates\n1711:              FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n1712:                - Same file:line, multiple dimensions → single finding, multiple dimension tags\n1713:                - Keep highest severity on duplicates\n1714:           4. Track finding lifecycle:\n1715:              - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n1716:              - Record first_seen, upgraded_in, previous_severity for severity changes\n1717:              - Record dimensions array reflecting all dimensions that emitted this finding\n1718:           5. Resolve contradictions:\n1719:              - Findings marked contested across iterations → referee pass\n1720:              - Determine final severity and status\n1721:           6. Count only 'active' findings for totals\n1722:         outputs:\n1723:           - finding_registry: \"Deduplicated list of all findings with metadata\"\n1724:           - active_p0: \"Count of active P0 findings\"\n1725:           - active_p1: \"Count of active P1 findings\"\n1726:           - active_p2: \"Count of active P2 findings\"\n1727: \n1728:       step_adversarial_selfcheck:\n1729:         action: \"Final adversarial self-check on all P0 and P1 findings\"\n1730:         algorithm: |\n1731:           For each active P0/P1 finding:\n1732:             1. Hunter: Re-verify finding against source code (re-read file:line)\n1733:             2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n1734:             3. Referee: Final call — confirm, downgrade, or mark false_positive\n1735:           Update finding_registry with adjudicated results.\n1736: \n1737:       step_emit_resource_map:\n1738:         action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n1739:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg} --emit-resource-map\"\n1740:         read:\n1741:           - \"{state_paths.config}\"\n1742:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1743:         write:\n1744:           - \"{state_paths.resource_map_output}\"\n1745:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1746: \n1747:       step_resource_map_coverage_gate:\n1748:         action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n1749:         note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n1750: \n1751:       step_compile_review_report:\n1752:         action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n1753:         instructions: |\n1754:           Create review/review-report.md with the following sections:\n1755: \n1756:           1. **Executive Summary**\n1757:              - Overall verdict: PASS | CONDITIONAL | FAIL\n1758:              - hasAdvisories: true when PASS carries active P2 items\n1759:              - P0/P1/P2 counts (active only)\n1760:              - Review scope summary\n1761: \n1762:           2. **Planning Trigger**\n1763:              - State whether `/speckit:plan` is required\n1764:              - Include a fenced `json` block labeled `Planning Packet`\n1765:              - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n1766:              - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n1767: \n1768:           3. **Active Finding Registry**\n1769:              - Unified registry for active P0/P1/P2 findings\n1770:              - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n1771: \n1772:           4. **Remediation Workstreams**\n1773:              - Ordered action groups: P0 first, then P1, with P2 advisories separated\n1774: \n1775:           5. **Spec Seed**\n1776:              - Concrete seed bullets for follow-on spec updates\n1777: \n1778:           6. **Plan Seed**\n1779:              - Concrete starter tasks for `/speckit:plan`\n1780: \n1781:            7. **Traceability Status**\n1782:               - Summarize required core protocols first, then applicable overlay protocols\n1783:               - Include status, evidence, and any unresolved drift per protocol\n1784:               - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n1785: \n1786:           If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n1787:              - `Entries touched`: count of resource-map paths that appear in applied reports\n1788:              - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n1789:              - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n1790: \n1791:           8. **Deferred Items**\n1792:              - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n1793: \n1794:           **Dimension Expansion Map**\n1795:              - Insert `## Dimension Expansion Map` after Deferred Items and before Search Ledger.\n1796:              - Render reducer-owned `divergence.saturatedDirections`, completed pivots, failed pivots, audited overrides, Council artifact references, selected review directions, and remaining frontier.\n1797:              - This section records breadth only. It cannot alter the Executive Summary verdict, hasAdvisories, finding registry, or adversarial self-check results.\n1798: \n1799:           9. **Search Ledger**\n1800:              - Always include this section before the appendix.\n1801:              - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n1802:              - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n1803:              - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n1804: \n1805:           10. **Audit Appendix**\n1806:              - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n1807:              - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n1808: \n1809:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n1810:         output: \"{state_paths.review_output}\"\n1811: \n1812:       step_convergence_report:\n1813:         action: \"Append convergence report to JSONL\"\n1814:         command: |\n1815:           node --input-type=module <<'EOF'\n1816:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1817: \n1818:           const paths = {\n1819:             stateLog: String.raw`{state_paths.state_log}`,\n1820:             registry: String.raw`{state_paths.findings_registry}`,\n1821:             review: String.raw`{state_paths.review_output}`,\n1822:             dashboard: String.raw`{state_paths.dashboard}`,\n1823:           };\n1824: \n1825:           function hasFile(filePath) {\n1826:             try {\n1827:               return existsSync(filePath) && statSync(filePath).isFile();\n1828:             } catch {\n1829:               return false;\n1830:             }\n1831:           }\n1832: \n1833:           function readJson(filePath) {\n1834:             try {\n1835:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1836:             } catch {\n1837:               return null;\n1838:             }\n1839:           }\n1840: \n1841:           function readJsonl(filePath) {\n1842:             if (!hasFile(filePath)) return [];\n1843:             return readFileSync(filePath, 'utf8')\n1844:               .split(/\\r?\\n/)\n1845:               .map((line) => line.trim())\n1846:               .filter(Boolean)\n1847:               .flatMap((line) => {\n1848:                 try {\n1849:                   return [JSON.parse(line)];\n1850:                 } catch {\n1851:                   return [];\n1852:                 }\n1853:               });\n1854:           }\n1855: \n1856:           function countIterationFindings(record) {\n1857:             if (!record || record.type !== 'iteration') return 0;\n1858:             const numeric = Number(record.findingsCount);\n1859:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1860:             if (Array.isArray(record.findingDetails)) return record.findingDetails.length;\n1861:             return 0;\n1862:           }\n1863: \n1864:           function normalizeFindingKey(value) {\n1865:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1866:           }\n1867: \n1868:           function findingKeys(candidate) {\n1869:             if (typeof candidate === 'string') {\n1870:               const key = normalizeFindingKey(candidate);\n1871:               return key ? [key] : [];\n1872:             }\n1873:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1874:             return [...new Set([\n1875:               candidate.id,\n1876:               candidate.findingId,\n1877:               candidate.title,\n1878:               candidate.summary,\n1879:               candidate.text,\n1880:               candidate.finding,\n1881:               candidate.description,\n1882:             ].map(normalizeFindingKey).filter(Boolean))];\n1883:           }\n1884: \n1885:           function collectIterationFindingGroups(record) {\n1886:             if (!record || record.type !== 'iteration' || !Array.isArray(record.findingDetails)) return [];\n1887:             return record.findingDetails\n1888:               .map(findingKeys)\n1889:               .filter((keys) => keys.length > 0);\n1890:           }\n1891: \n1892:           function collectRegistryFindingKeys(registry) {\n1893:             return [registry?.openFindings, registry?.resolvedFindings, registry?.repeatedFindings]\n1894:               .filter(Array.isArray)\n1895:               .flatMap((findings) => findings)\n1896:               .flatMap(findingKeys);\n1897:           }\n1898: \n1899:           function appendEvent(event) {\n1900:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1901:           }\n1902: \n1903:           const registry = readJson(paths.registry);\n1904:           const openCount = Array.isArray(registry?.openFindings) ? registry.openFindings.length : null;\n1905:           const resolvedCount = Array.isArray(registry?.resolvedFindings) ? registry.resolvedFindings.length : 0;\n1906:           const repeatedCount = Array.isArray(registry?.repeatedFindings) ? registry.repeatedFindings.length : 0;\n1907:           const registryFindingCount = openCount === null ? null : openCount + resolvedCount + repeatedCount;\n1908:           const stateRecords = readJsonl(paths.stateLog);\n1909:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1910:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1911:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1912:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1913:           const identifiableFindingCount = identifiableFindingGroups.length;\n1914:           const missingArtifacts = [\n1915:             ['registry', paths.registry],\n1916:             ['review', paths.review],\n1917:             ['dashboard', paths.dashboard],\n1918:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1919:           const invariantFailures = [];\n1920:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1921:           if (registryFindingCount === null) invariantFailures.push('registry_missing_openFindings');\n1922:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1923:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1924:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1925: \n1926:           if (invariantFailures.length > 0) {\n1927:             appendEvent({\n1928:               type: 'event',\n1929:               event: 'synthesis_incomplete',\n1930:               mode: 'review',\n1931:               severity: 'warning',\n1932:               totalIterations: Number('{iteration_count}'),\n1933:               activeP0: Number('{active_p0}'),\n1934:               activeP1: Number('{active_p1}'),\n1935:               activeP2: Number('{active_p2}'),\n1936:               dimensionCoverage: Number('{dimension_coverage}'),\n1937:               verdict: '{verdict}',\n1938:               releaseReadinessState: '{release_readiness_state}',\n1939:               stopReason: '{reason}',\n1940:               reason: 'synthesis_artifact_invariant_failed',\n1941:               invariantFailures,\n1942:               missingArtifacts,\n1943:               registryFindingCount,\n1944:               iterationFindingCount,\n1945:               identifiableFindingCount,\n1946:               missingStructuredFindingCount,\n1947:               timestamp: '{ISO_8601_NOW}',\n1948:             });\n1949:           } else {\n1950:             appendEvent({\n1951:               type: 'event',\n1952:               event: 'synthesis_complete',\n1953:               mode: 'review',\n1954:               totalIterations: Number('{iteration_count}'),\n1955:               activeP0: Number('{active_p0}'),\n1956:               activeP1: Number('{active_p1}'),\n1957:               activeP2: Number('{active_p2}'),\n1958:               dimensionCoverage: Number('{dimension_coverage}'),\n1959:               verdict: '{verdict}',\n1960:               releaseReadinessState: '{release_readiness_state}',\n1961:               stopReason: '{reason}',\n1962:               timestamp: '{ISO_8601_NOW}',\n1963:             });\n1964:           }\n1965:           EOF\n1966:         note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n1967: \n1968:       step_update_config_status:\n1969:         action: \"Mark config as complete\"\n1970:         edit: \"{state_paths.config}\"\n1971:         set_field: { status: \"complete\" }\n1972: \n1973:       step_leave_artifacts_unstaged:\n1974:         action: \"Leave all synthesized artifacts unstaged for explicit operator review\"\n1975:         note: \"Synthesis must not mutate the shared Git index. The operator retains staging and commit authority after reviewing the complete artifact directory.\"\n1976: \n1977:   # ═══════════════════════════════════════════════════════════════\n1978:   # PHASE 4: SAVE\n1979:   # ═══════════════════════════════════════════════════════════════\n1980:   phase_save:\n1981:     purpose: Preserve review context to memory system\n1982:     steps:\n1983: \n1984:       step_compose_save_payload:\n1985:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1986:         output: \"/tmp/save-context-data-<session-id>.json\"\n1987:         requirements:\n1988:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1989:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed review loop.\"\n1990:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1991:         example_payload: |\n1992:           {\n1993:             \"specFolder\": \"{spec_folder}\",\n1994:             \"sessionSummary\": \"Deep review completed; see review/review-report.md for verdict, findings, and workstreams.\",\n1995:             \"observations\": [\"Summarize the active findings, verdict, and remediation guidance.\"],\n1996:             \"recent_context\": [\"Point to the generated review artifacts and next action.\"],\n1997:             \"exchanges\": [],\n1998:             \"toolCalls\": []\n1999:           }\n2000: \n2001:       step_generate_context:\n2002:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n2003:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n2004:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n2005: \n2006:       step_index_memory:\n2007:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n2008:         mcp_tool: memory_save\n2009:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n2010:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n2011: \n2012:       step_verify_save:\n2013:         action: \"Verify canonical save routed content into the correct spec document\"\n2014:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n2015:         on_fail: \"Log warning but do not block completion\"\n2016: \n2017:       step_release_lock:\n2018:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n2019:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n2020:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n2021: \n2022:   # ═══════════════════════════════════════════════════════════════\n2023:   # COMPLETION\n2024:   # ═══════════════════════════════════════════════════════════════\n2025:   completion:\n2026:     message: |\n2027:       Deep review complete.\n2028:       Iterations: {iteration_count} | Stop reason: {reason}\n2029:       Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n2030:       Verdict: {verdict} | hasAdvisories={has_advisories}\n2031: \n2032:       Artifacts:\n2033:         - review/review-report.md (compiled from {iteration_count} iterations)\n2034:         - {iteration_count} iteration files in review/iterations/\n2035:         - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n2036:         - Memory context saved\n2037: \n2038:       STATUS=OK PATH={spec_folder}\n2039:     next_steps:\n2040:       - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n2041:       - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n2042:       - \"/deep:review [target] (for another review)\"\n2043:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n2044: \n2045: # ─────────────────────────────────────────────────────────────────\n2046: # ERROR RECOVERY\n2047: # ─────────────────────────────────────────────────────────────────\n2048: error_recovery:\n2049:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer files per iteration). If second timeout, mark as 'timeout' and continue.\"\n2050:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n2051:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n2052:   memory_save_failure: \"Preserve the review packet in review/ as backup. Log warning.\"\n2053: \n2054: # ─────────────────────────────────────────────────────────────────\n2055: # RULES\n2056: # ─────────────────────────────────────────────────────────────────\n2057: rules:\n2058:   ALWAYS:\n2059:     - follow_workflow_phases_in_order\n2060:     - dispatch_deep_review_agent_per_iteration\n2061:     - check_convergence_before_each_iteration\n2062:     - write_all_state_to_files\n2063:     - save_memory_context_after_synthesis\n2064:     - respect_max_iterations_cap\n2065:     - treat_review_target_as_read_only\n2066:     - deduplicate_findings_before_synthesis\n2067:     - run_adversarial_selfcheck_on_p0_p1\n2068:   NEVER:\n2069:     - skip_convergence_check\n2070:     - dispatch_non_leaf_agents\n2071:     - hold_iteration_findings_in_memory_only\n2072:     - modify_config_after_initialization\n2073:     - overwrite_jsonl_state_log\n2074:     - proceed_without_state_file_verification\n2075:     - modify_files_under_review\n2076:     - report_p0_without_file_line_evidence\n2077: \n2078: # ─────────────────────────────────────────────────────────────────\n2079: # REFERENCE-ONLY APPENDIX\n2080: # ─────────────────────────────────────────────────────────────────\n2081: reference_only_appendix:\n2082:   checkpoint_commit:\n2083:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n2084:     commands:\n2085:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.findings_registry} {state_paths.strategy} {state_paths.review_output}\"\n2086:       - 'git commit -m \"chore(deep-review): iteration {NNN} complete\"'\n2087:   severity_weights:\n2088:     note: \"Severity weights for newFindingsRatio calculation\"\n2089:     weights:\n2090:       P0: 10.0\n2091:       P1: 5.0\n2092:       P2: 1.0\n2093:     p0_override: \"If ANY new P0 discovered → newFindingsRatio = max(calculated, 0.50). A single new P0 blocks convergence.\"\n2094:     clean_pass: \"If total_findings == 0 (clean pass) → newFindingsRatio = 0.0\"\n2095:   review_dimensions:\n2096:     note: \"All 4 default review dimensions with priority ordering\"\n2097:     dimensions:\n2098:       - { priority: 1, name: \"correctness\", checks: \"Logic, state flow, edge cases, error handling\" }\n2099:       - { priority: 2, name: \"security\", checks: \"Auth, input/output safety, data exposure, permissions\" }\n2100:       - { priority: 3, name: \"traceability\", checks: \"Spec/checklist alignment, cross-reference integrity, evidence coverage\" }\n2101:       - { priority: 4, name: \"maintainability\", checks: \"Patterns, documentation quality, safe follow-on change clarity\" }\n2102:   cross_reference_protocols:\n2103:     note: \"Cross-reference verification protocols split into core and overlay classes\"\n2104:     core_protocols:\n2105:       - { check: \"Spec vs Code\", source: \"spec.md claims\", target: \"implementation\" }\n2106:       - { check: \"Checklist vs Evidence\", source: \"[x] items\", target: \"cited evidence\" }\n2107:     overlay_protocols:\n2108:       - { check: \"SKILL.md vs Agent\", source: \"Skill contracts\", target: \"agent files\" }\n2109:       - { check: \"Agent Cross-Runtime\", source: \".claude\", target: \".opencode/.agents\" }\n2110:       - { check: \"Feature Catalog vs Code\", source: \"Catalog claims\", target: \"implementation\" }\n2111:       - { check: \"Playbook vs Support\", source: \"Scenario preconditions\", target: \"actual support\" }\n\n(End of file - total 2111 lines)\n</content>","metadata":{"preview":"            - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          route_proof:\n            mode: review\n            target_agent: deep-review\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"review-i{current_iteration}-g{generation}\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"            - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          route_proof:\n            mode: review\n            target_agent: deep-review\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"review-i{current_iteration}-g{generation}\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:\n            - iteration_file_missing\n            - iteration_file_empty\n            - jsonl_not_appended\n            - jsonl_missing_fields\n            - jsonl_parse_error\n            - jsonl_wrong_type\n            - delta_file_missing\n            - delta_file_empty\n            - delta_file_missing_iteration_record\n            - executor_missing\n            - dispatch_failure_logged\n            - v2_missing_ledger\n            - v2_uncited_ledger_row\n            - v2_broken_linked_finding\n            - v2_shallow_finding_details\n            - delta_iteration_id_mismatch\n            - state_delta_iteration_mismatch\n            - route_proof_missing\n            - route_proof_mismatch\n          warning_surface:\n            source: \"result.warnings\"\n            action: \"emit schema_advisory canonical conflict event\"\n            severity: \"advisory\"\n            event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n        record_executor_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.kind}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Strategy.md has been modified\"\n        extract:\n          - newFindingsRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n          - dimensions: \"From latest JSONL iteration record\"\n          - files_reviewed: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - reviewed_artifacts: \"From latest JSONL iteration record\"\n          - traceability_checks: \"From latest JSONL iteration record when present\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n          # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n\n      step_post_iteration_claim_adjudication:\n        action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n        verify:\n          - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n          - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n          - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n        on_pass:\n          set:\n            claim_adjudication_passed: true\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n        on_fail:\n          action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n          set:\n            claim_adjudication_passed: false\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n\n      step_reduce_review_state:\n        action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.iteration_pattern}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        write:\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n        guarantee: \"Idempotent for identical inputs\"\n        note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n\n      step_graph_upsert:\n        action: \"Project canonical review coverage plus optional graphEvents into graph nodes and edges, then upsert it\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Read the latest iteration JSONL record after reducer completion.\n          2. Seed one stable DIMENSION node for every configured review dimension, falling back to correctness, security, traceability, and maintainability.\n          3. Seed one stable FILE node for every latest-record filesReviewed entry and emit a COVERS edge from each latest-record dimension to each reviewed file.\n          4. Merge optional graphEvents nodes after normalizing type = uppercase(event.kind || event.nodeKind || event.type); keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n          5. Merge optional graphEvents edges after normalizing relation = uppercase(event.relation); keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n          6. Emit nodes as { id, type, name, iteration, metadata } and edges as { id, relation, sourceId, targetId, metadata }, deduplicated by id.\n          7. Discard malformed or unknown optional events without discarding canonical dimension and file coverage.\n        bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n        note: \"Invoke the runtime script directly. Canonical iteration fields provide baseline coverage; graphEvents add richer evidence.\"\n        outputs:\n          - graph_nodes_json: \"JSON array of canonical and optional review graph nodes\"\n          - graph_edges_json: \"JSON array of canonical and optional review graph edges\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the review dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        content: |\n          # Deep Review Dashboard - Session Overview\n\n          Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n\n          ## Status\n          - Review Target: {review_target} ({review_target_type})\n          - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n          - Iteration: {current_iteration} of {max_iterations}\n          - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n          - hasAdvisories: {has_advisories}\n\n          ## Findings Summary\n          | Severity | Count | Trend |\n          |----------|------:|-------|\n          | P0 (Blockers) | {p0_count} | {p0_trend} |\n          | P1 (Required) | {p1_count} | {p1_trend} |\n          | P2 (Suggestions) | {p2_count} | {p2_trend} |\n\n          ## Dimension Coverage\n          | Dimension | Status | Iteration | Findings |\n          |-----------|--------|-----------|----------|\n          | [per dimension from strategy + JSONL] |\n\n          ## Traceability Coverage\n          | Protocol | Level | Status | Findings |\n          |----------|-------|--------|----------|\n          | [per protocol from traceabilityChecks] |\n\n          ## Progress\n          | # | Dimension | Ratio | P0/P1/P2 | Status |\n          |---|-----------|-------|----------|--------|\n          | [per iteration from JSONL] |\n\n          ## Trend\n          - Last 3 ratios: [{ratios}] [{trend}]\n          - Stuck count: {stuck_count}\n          - Gate violations: {guard_violations}\n\n          ## Next Focus\n          {next_dimension}\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          p0_count: \"Accumulate from severity_counts\"\n          p1_count: \"Accumulate from severity_counts\"\n          p2_count: \"Accumulate from severity_counts\"\n          stuck_count: |\n            if status == 'thought': unchanged (skip)\n            if status == 'insight': 0 (reset)\n            if newFindingsRatio <= 0.05: stuck_count + 1\n            else: 0\n        log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into review/review-report.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n            --loop-type review \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n        bind_from_output:\n          p0_count: \"active_p0\"\n          p1_count: \"active_p1\"\n          p2_count: \"active_p2\"\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - p0_count: \"Total P0 findings across all iterations (deduped)\"\n          - p1_count: \"Total P1 findings across all iterations (deduped)\"\n          - p2_count: \"Total P2 findings across all iterations (deduped)\"\n          - dimensions_covered: \"List of reviewed dimensions\"\n          - dimension_coverage: \"covered / total\"\n          - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records\"\n          - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n      # - PASS: no P0 or P1 findings (P2-only or clean)\n      # - CONDITIONAL: any P1 findings (no P0)\n      # - FAIL: any P0 findings\n      # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n      step_derive_verdict:\n        action: \"Derive review verdict from accumulated findings\"\n        algorithm: |\n          if p0_count > 0:\n            verdict = \"FAIL\"\n          elif p1_count > 0:\n            verdict = \"CONDITIONAL\"\n          else:\n            verdict = \"PASS\"\n          has_advisories = (verdict == \"PASS\" and p2_count > 0)\n          ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n        outputs:\n          - verdict: \"PASS | CONDITIONAL | FAIL\"\n          - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n          - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n        contract: |\n          Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n          Downstream automation parses this final line via exact string match — do not vary the format.\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_build_finding_registry:\n        action: \"Build deduplicated finding registry from all iterations\"\n        algorithm: |\n          1. Extract all findings from iteration JSONL delta files\n          2. Compute content_hash for each finding (emission requirement):\n             content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n             Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n          3. Two-tier dedup:\n             PRIMARY: group by content_hash field\n               - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n               - Keep highest severity on duplicates\n             FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n               - Same file:line, multiple dimensions → single finding, multiple dimension tags\n               - Keep highest severity on duplicates\n          4. Track finding lifecycle:\n             - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n             - Record first_seen, upgraded_in, previous_severity for severity changes\n             - Record dimensions array reflecting all dimensions that emitted this finding\n          5. Resolve contradictions:\n             - Findings marked contested across iterations → referee pass\n             - Determine final severity and status\n          6. Count only 'active' findings for totals\n        outputs:\n          - finding_registry: \"Deduplicated list of all findings with metadata\"\n          - active_p0: \"Count of active P0 findings\"\n          - active_p1: \"Count of active P1 findings\"\n          - active_p2: \"Count of active P2 findings\"\n\n      step_adversarial_selfcheck:\n        action: \"Final adversarial self-check on all P0 and P1 findings\"\n        algorithm: |\n          For each active P0/P1 finding:\n            1. Hunter: Re-verify finding against source code (re-read file:line)\n            2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n            3. Referee: Final call — confirm, downgrade, or mark false_positive\n          Update finding_registry with adjudicated results.\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_resource_map_coverage_gate:\n        action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n        note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n\n      step_compile_review_report:\n        action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n        instructions: |\n          Create review/review-report.md with the following sections:\n\n          1. **Executive Summary**\n             - Overall verdict: PASS | CONDITIONAL | FAIL\n             - hasAdvisories: true when PASS carries active P2 items\n             - P0/P1/P2 counts (active only)\n             - Review scope summary\n\n          2. **Planning Trigger**\n             - State whether `/speckit:plan` is required\n             - Include a fenced `json` block labeled `Planning Packet`\n             - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n             - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n\n          3. **Active Finding Registry**\n             - Unified registry for active P0/P1/P2 findings\n             - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n\n          4. **Remediation Workstreams**\n             - Ordered action groups: P0 first, then P1, with P2 advisories separated\n\n          5. **Spec Seed**\n             - Concrete seed bullets for follow-on spec updates\n\n          6. **Plan Seed**\n             - Concrete starter tasks for `/speckit:plan`\n\n           7. **Traceability Status**\n              - Summarize required core protocols first, then applicable overlay protocols\n              - Include status, evidence, and any unresolved drift per protocol\n              - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n\n          If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n             - `Entries touched`: count of resource-map paths that appear in applied reports\n             - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n             - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n\n          8. **Deferred Items**\n             - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n\n          **Dimension Expansion Map**\n             - Insert `## Dimension Expansion Map` after Deferred Items and before Search Ledger.\n             - Render reducer-owned `divergence.saturatedDirections`, completed pivots, failed pivots, audited overrides, Council artifact references, selected review directions, and remaining frontier.\n             - This section records breadth only. It cannot alter the Executive Summary verdict, hasAdvisories, finding registry, or adversarial self-check results.\n\n          9. **Search Ledger**\n             - Always include this section before the appendix.\n             - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n             - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n             - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n\n          10. **Audit Appendix**\n             - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n             - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n        output: \"{state_paths.review_output}\"\n\n      step_convergence_report:\n        action: \"Append convergence report to JSONL\"\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.findings_registry}`,\n            review: String.raw`{state_paths.review_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.findingDetails)) return record.findingDetails.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.findingId,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration' || !Array.isArray(record.findingDetails)) return [];\n            return record.findingDetails\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            return [registry?.openFindings, registry?.resolvedFindings, registry?.repeatedFindings]\n              .filter(Array.isArray)\n              .flatMap((findings) => findings)\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const openCount = Array.isArray(registry?.openFindings) ? registry.openFindings.length : null;\n          const resolvedCount = Array.isArray(registry?.resolvedFindings) ? registry.resolvedFindings.length : 0;\n          const repeatedCount = Array.isArray(registry?.repeatedFindings) ? registry.repeatedFindings.length : 0;\n          const registryFindingCount = openCount === null ? null : openCount + resolvedCount + repeatedCount;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['review', paths.review],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_openFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'review',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              activeP0: Number('{active_p0}'),\n              activeP1: Number('{active_p1}'),\n              activeP2: Number('{active_p2}'),\n              dimensionCoverage: Number('{dimension_coverage}'),\n              verdict: '{verdict}',\n              releaseReadinessState: '{release_readiness_state}',\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              mode: 'review',\n              totalIterations: Number('{iteration_count}'),\n              activeP0: Number('{active_p0}'),\n              activeP1: Number('{active_p1}'),\n              activeP2: Number('{active_p2}'),\n              dimensionCoverage: Number('{dimension_coverage}'),\n              verdict: '{verdict}',\n              releaseReadinessState: '{release_readiness_state}',\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n        note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_leave_artifacts_unstaged:\n        action: \"Leave all synthesized artifacts unstaged for explicit operator review\"\n        note: \"Synthesis must not mutate the shared Git index. The operator retains staging and commit authority after reviewing the complete artifact directory.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve review context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed review loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep review completed; see review/review-report.md for verdict, findings, and workstreams.\",\n            \"observations\": [\"Summarize the active findings, verdict, and remediation guidance.\"],\n            \"recent_context\": [\"Point to the generated review artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep review complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n      Verdict: {verdict} | hasAdvisories={has_advisories}\n\n      Artifacts:\n        - review/review-report.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in review/iterations/\n        - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n      - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n      - \"/deep:review [target] (for another review)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer files per iteration). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the review packet in review/ as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_review_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n    - treat_review_target_as_read_only\n    - deduplicate_findings_before_synthesis\n    - run_adversarial_selfcheck_on_p0_p1\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n    - modify_files_under_review\n    - report_p0_without_file_line_evidence\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.findings_registry} {state_paths.strategy} {state_paths.review_output}\"\n      - 'git commit -m \"chore(deep-review): iteration {NNN} complete\"'\n  severity_weights:\n    note: \"Severity weights for newFindingsRatio calculation\"\n    weights:\n      P0: 10.0\n      P1: 5.0\n      P2: 1.0\n    p0_override: \"If ANY new P0 discovered → newFindingsRatio = max(calculated, 0.50). A single new P0 blocks convergence.\"\n    clean_pass: \"If total_findings == 0 (clean pass) → newFindingsRatio = 0.0\"\n  review_dimensions:\n    note: \"All 4 default review dimensions with priority ordering\"\n    dimensions:\n      - { priority: 1, name: \"correctness\", checks: \"Logic, state flow, edge cases, error handling\" }\n      - { priority: 2, name: \"security\", checks: \"Auth, input/output safety, data exposure, permissions\" }\n      - { priority: 3, name: \"traceability\", checks: \"Spec/checklist alignment, cross-reference integrity, evidence coverage\" }\n      - { priority: 4, name: \"maintainability\", checks: \"Patterns, documentation quality, safe follow-on change clarity\" }\n  cross_reference_protocols:\n    note: \"Cross-reference verification protocols split into core and overlay classes\"\n    core_protocols:\n      - { check: \"Spec vs Code\", source: \"spec.md claims\", target: \"implementation\" }\n      - { check: \"Checklist vs Evidence\", source: \"[x] items\", target: \"cited evidence\" }\n    overlay_protocols:\n      - { check: \"SKILL.md vs Agent\", source: \"Skill contracts\", target: \"agent files\" }\n      - { check: \"Agent Cross-Runtime\", source: \".claude\", target: \".opencode/.agents\" }\n      - { check: \"Feature Catalog vs Code\", source: \"Catalog claims\", target: \"implementation\" }\n      - { check: \"Playbook vs Support\", source: \"Scenario preconditions\", target: \"actual support\" }","lineStart":1427,"lineEnd":2111,"totalLines":2111,"truncated":false}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1784389939395,"end":1784389939403}},"metadata":{"openai":{"itemId":"fc_077813f84165f48f016a5ba1320b2481919eff776f9dd3eaee"}},"id":"prt_f75edabb8001qlk36IN3vOxtyM","sessionID":"ses_08a55b97affezjS590Sxu4oUZ9","messageID":"msg_f75ed7c6e001Wq36gWkIqo5tGw"}}
