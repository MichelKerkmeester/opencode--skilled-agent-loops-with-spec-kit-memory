ked modes and improvement-host/external-adapter modes distinct.\",\n.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/tests/orchestrate-session.vitest.ts:9:const { createSessionState, createRoundState } = require('../../../../deep-loop-runtime/lib/council/session-state-hierarchy.cjs') as {\n.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/tests/orchestrate-session.vitest.ts:13:const { readRoundStateRecords } = require('../../../../deep-loop-runtime/lib/council/round-state-jsonl.cjs') as {\n.opencode/skills/deep-loop-workflows/mode-registry.json:7:    \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n.opencode/skills/deep-loop-workflows/mode-registry.json:8:    \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n.opencode/skills/deep-loop-workflows/mode-registry.json:20:      \"description\": \"Declares the runtime-loop backend: modes with backendKind 'runtime-loop-type' converge over deep-loop-runtime, keyed by runtimeLoopType (research|review|council). runtimeLoopType is explicit null for improvement-host and external-adapter modes and is never inferred from workflowMode.\",\n.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/tests/persist-artifacts.vitest.ts:60:- Extend deep-loop-runtime with council primitives\n.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/tests/persist-artifacts.vitest.ts:93:    expect(parsed.recommendedPlan).toContain('Extend deep-loop-runtime');\n.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/tests/persist-artifacts.vitest.ts:117:    expect(payload.decisions).toContain('Extend deep-lo