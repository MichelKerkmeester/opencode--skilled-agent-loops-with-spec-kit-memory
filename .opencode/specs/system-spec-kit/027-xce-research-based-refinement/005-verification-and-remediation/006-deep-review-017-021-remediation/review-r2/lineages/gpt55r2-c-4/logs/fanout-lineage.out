\n174:     CREATE INDEX IF NOT EXISTS idx_access_importance ON memory_index(access_count DESC, importance_weight DESC);\n175:     CREATE INDEX IF NOT EXISTS idx_memories_scope ON memory_index(spec_folder, session_id, context_type);\n176:     CREATE INDEX IF NOT EXISTS idx_channel ON memory_index(channel);\n177: \n178:     CREATE INDEX IF NOT EXISTS idx_file_path ON memory_index(file_path);\n179:     CREATE INDEX IF NOT EXISTS idx_content_hash ON memory_index(content_hash);\n180:     CREATE INDEX IF NOT EXISTS idx_last_accessed ON memory_index(last_accessed DESC);\n181:     CREATE INDEX IF NOT EXISTS idx_file_mtime ON memory_index(file_mtime_ms);\n182:     CREATE INDEX IF NOT EXISTS idx_document_type ON memory_index(document_type);\n183:     CREATE INDEX IF NOT EXISTS idx_doc_type_folder ON memory_index(document_type, spec_folder);\n184:     CREATE INDEX IF NOT EXISTS idx_quality_score ON memory_index(quality_score);\n185: \n186:     CREATE INDEX IF NOT EXISTS idx_stability ON memory_index(stability DESC);\n187:     CREATE INDEX IF NOT EXISTS idx_last_review ON memory_index(last_review);\n188:     CREATE INDEX IF NOT EXISTS idx_fsrs_retrieval ON memory_index(stability, difficulty, last_review);\n189: \n190:     CREATE INDEX IF NOT EXISTS idx_memory_type ON memory_index(memory_type);\n191:     CREATE INDEX IF NOT EXISTS idx_memory_type_decay ON memory_index(memory_type, half_life_days);\n192: \n193:     CREATE INDEX IF NOT EXISTS idx_embedding_pending\n194:       ON memory_index(embedding_status)\n195:       WHERE embedding_status IN ('pending', 'partial', 'retry');\n196: \n197:     CREATE INDEX IF NOT EXISTS idx_fts_fallback\n198:       ON memory_index(spec_folder, embedding_status)\n199:       WHERE embedding_status IN ('pending', 'failed', 'retry');\n200:   `);\n201: }\n202: \n203: function createFtsArtifacts(database: Database.Database): void {\n204:   database.exec(`\n205:     CREATE VIRTUAL TABLE IF NOT EXISTS memory_fts USING fts5(\n206:       title, trigger_phrases, file_path, content_text,\n207:       content='memory_index', content_rowid='id'\n208:     )\n209:   `);\n210: \n211:   database.exec(`\n212:     CREATE TRIGGER IF NOT EXISTS memory_fts_insert AFTER INSERT ON memory_index BEGIN\n213:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n214:       VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n215:     END\n216:   `);\n217: \n218:   database.exec(`\n219:     CREATE TRIGGER IF NOT EXISTS memory_fts_update AFTER UPDATE ON memory_index BEGIN\n220:       INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n221:       VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n222:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n223:       VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n224:     END\n225:   `);\n226: \n227:   database.exec(`\n228:     CREATE TRIGGER IF NOT EXISTS memory_fts_delete AFTER DELETE ON memory_index BEGIN\n229:       INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n230:       VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n231:     END\n232:   `);\n233: \n234:   database.exec(`INSERT INTO memory_fts(memory_fts) VALUES('rebuild')`);\n235: }\n236: \n237: /* ───────────────────────────────────────────────────────────────\n238:    4. MAIN API\n239: ──────────────────────────────────────────────────────────────── */\n240: \n241: function downgradeSchemaV16ToV15(\n242:   database: Database.Database,\n243:   options: SchemaDowngradeOptions = {}\n244: ): SchemaDowngradeResult {\n245:   const currentVersion = getCurrentSchemaVersion(database);\n246:   if (currentVersion !== TARGET_FROM_VERSION) {\n247:     throw new Error(`Downgrade supports only v${TARGET_FROM_VERSION} -> v${TARGET_TO_VERSION}. Current schema is v${currentVersion}.`);\n248:   }\n249: \n250:   ensureColumnsExist(database, OLLAMA);\n251: \n252:   const checkpointName = options.checkpointName || `pre-schema-downgrade-v16-to-v15-${nowTimestampForName()}`;\n253:   const checkpoint = checkpoints.createCheckpoint({\n254:     name: checkpointName,\n255:     specFolder: options.specFolder || null,\n256:     metadata: {\n257:       reason: 'schema downgrade v16->v15',\n258:       fromVersion: TARGET_FROM_VERSION,\n259:       toVersion: TARGET_TO_VERSION,\n260:       removedColumns: [...OLLAMA],\n261:     },\n262:   });\n263: \n264:   if (!checkpoint) {\n265:     throw new Error('Failed to create pre-downgrade checkpoint');\n266:   }\n267: \n268:   database.pragma('foreign_keys = OFF');\n269:   try {\n270:     const run = database.transaction(() => {\n271:       database.exec(`\n272:         DROP TRIGGER IF EXISTS memory_fts_insert;\n273:         DROP TRIGGER IF EXISTS memory_fts_update;\n274:         DROP TRIGGER IF EXISTS memory_fts_delete;\n275:         DROP TABLE IF EXISTS memory_fts;\n276:       `);\n277: \n278:       database.exec(`ALTER TABLE memory_index RENAME TO memory_index_v16_backup`);\n279: \n280:       createMemoryIndexV15(database);\n281: \n282:       const columnsCsv = V15_COLUMNS.join(', ');\n283:       database.exec(`\n284:         INSERT INTO memory_index (${columnsCsv})\n285:         SELECT ${columnsCsv}\n286:         FROM memory_index_v16_backup\n287:       `);\n288: \n289:       // Drop backup table to release index names before re-creating v15 indexes.\n290:       database.exec(`DROP TABLE memory_index_v16_backup`);\n291: \n292:       createV15Indexes(database);\n293:       createFtsArtifacts(database);\n294: \n295:       database.prepare(`\n296:         INSERT OR REPLACE INTO schema_version (id, version, updated_at)\n297:         VALUES (1, ?, datetime('now'))\n298:       `).run(TARGET_TO_VERSION);\n299:     });\n300: \n301:     run();\n302:   } finally {\n303:     database.pragma('foreign_keys = ON');\n304:   }\n305: \n306:   const row = database.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number };\n307:   return {\n308:     fromVersion: TARGET_FROM_VERSION,\n309:     toVersion: TARGET_TO_VERSION,\n\n(Showing lines 150-309 of 326. Use offset=310 to continue.)\n</content>","metadata":{"preview":"      memory_type TEXT DEFAULT 'declarative'\n        CHECK(memory_type IN ('working', 'episodic', 'prospective', 'implicit', 'declarative', 'procedural', 'semantic', 'autobiographical', 'meta-cognitive')),\n      half_life_days REAL,\n      type_inference_source TEXT DEFAULT 'default'\n        CHECK(type_inference_source IN ('frontmatter_explicit', 'importance_tier', 'file_path', 'keywords', 'default', 'manual')),\n      document_type TEXT DEFAULT 'memory',\n      spec_level INTEGER,\n      content_text TEXT,\n      quality_score REAL DEFAULT 0,\n      quality_flags TEXT\n      -- Preserve append-only lineage rows that can share the same path and anchor.\n    )\n  `);\n}\n\nfunction createV15Indexes(database: Database.Database): void {\n  database.exec(`\n    CREATE INDEX IF NOT EXISTS idx_spec_folder ON memory_index(spec_folder);\n    CREATE INDEX IF NOT EXISTS idx_created_at ON memory_index(created_at);\n    CREATE INDEX IF NOT EXISTS idx_importance ON memory_index(importance_weight DESC);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/schema-downgrade.ts","text":"      memory_type TEXT DEFAULT 'declarative'\n        CHECK(memory_type IN ('working', 'episodic', 'prospective', 'implicit', 'declarative', 'procedural', 'semantic', 'autobiographical', 'meta-cognitive')),\n      half_life_days REAL,\n      type_inference_source TEXT DEFAULT 'default'\n        CHECK(type_inference_source IN ('frontmatter_explicit', 'importance_tier', 'file_path', 'keywords', 'default', 'manual')),\n      document_type TEXT DEFAULT 'memory',\n      spec_level INTEGER,\n      content_text TEXT,\n      quality_score REAL DEFAULT 0,\n      quality_flags TEXT\n      -- Preserve append-only lineage rows that can share the same path and anchor.\n    )\n  `);\n}\n\nfunction createV15Indexes(database: Database.Database): void {\n  database.exec(`\n    CREATE INDEX IF NOT EXISTS idx_spec_folder ON memory_index(spec_folder);\n    CREATE INDEX IF NOT EXISTS idx_created_at ON memory_index(created_at);\n    CREATE INDEX IF NOT EXISTS idx_importance ON memory_index(importance_weight DESC);\n    CREATE INDEX IF NOT EXISTS idx_embedding_status ON memory_index(embedding_status);\n    CREATE INDEX IF NOT EXISTS idx_retry_eligible ON memory_index(embedding_status, retry_count, last_retry_at);\n\n    CREATE INDEX IF NOT EXISTS idx_importance_tier ON memory_index(importance_tier);\n    CREATE INDEX IF NOT EXISTS idx_access_importance ON memory_index(access_count DESC, importance_weight DESC);\n    CREATE INDEX IF NOT EXISTS idx_memories_scope ON memory_index(spec_folder, session_id, context_type);\n    CREATE INDEX IF NOT EXISTS idx_channel ON memory_index(channel);\n\n    CREATE INDEX IF NOT EXISTS idx_file_path ON memory_index(file_path);\n    CREATE INDEX IF NOT EXISTS idx_content_hash ON memory_index(content_hash);\n    CREATE INDEX IF NOT EXISTS idx_last_accessed ON memory_index(last_accessed DESC);\n    CREATE INDEX IF NOT EXISTS idx_file_mtime ON memory_index(file_mtime_ms);\n    CREATE INDEX IF NOT EXISTS idx_document_type ON memory_index(document_type);\n    CREATE INDEX IF NOT EXISTS idx_doc_type_folder ON memory_index(document_type, spec_folder);\n    CREATE INDEX IF NOT EXISTS idx_quality_score ON memory_index(quality_score);\n\n    CREATE INDEX IF NOT EXISTS idx_stability ON memory_index(stability DESC);\n    CREATE INDEX IF NOT EXISTS idx_last_review ON memory_index(last_review);\n    CREATE INDEX IF NOT EXISTS idx_fsrs_retrieval ON memory_index(stability, difficulty, last_review);\n\n    CREATE INDEX IF NOT EXISTS idx_memory_type ON memory_index(memory_type);\n    CREATE INDEX IF NOT EXISTS idx_memory_type_decay ON memory_index(memory_type, half_life_days);\n\n    CREATE INDEX IF NOT EXISTS idx_embedding_pending\n      ON memory_index(embedding_status)\n      WHERE embedding_status IN ('pending', 'partial', 'retry');\n\n    CREATE INDEX IF NOT EXISTS idx_fts_fallback\n      ON memory_index(spec_folder, embedding_status)\n      WHERE embedding_status IN ('pending', 'failed', 'retry');\n  `);\n}\n\nfunction createFtsArtifacts(database: Database.Database): void {\n  database.exec(`\n    CREATE VIRTUAL TABLE IF NOT EXISTS memory_fts USING fts5(\n      title, trigger_phrases, file_path, content_text,\n      content='memory_index', content_rowid='id'\n    )\n  `);\n\n  database.exec(`\n    CREATE TRIGGER IF NOT EXISTS memory_fts_insert AFTER INSERT ON memory_index BEGIN\n      INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n      VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n    END\n  `);\n\n  database.exec(`\n    CREATE TRIGGER IF NOT EXISTS memory_fts_update AFTER UPDATE ON memory_index BEGIN\n      INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n      VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n      INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n      VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n    END\n  `);\n\n  database.exec(`\n    CREATE TRIGGER IF NOT EXISTS memory_fts_delete AFTER DELETE ON memory_index BEGIN\n      INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n      VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n    END\n  `);\n\n  database.exec(`INSERT INTO memory_fts(memory_fts) VALUES('rebuild')`);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. MAIN API\n──────────────────────────────────────────────────────────────── */\n\nfunction downgradeSchemaV16ToV15(\n  database: Database.Database,\n  options: SchemaDowngradeOptions = {}\n): SchemaDowngradeResult {\n  const currentVersion = getCurrentSchemaVersion(database);\n  if (currentVersion !== TARGET_FROM_VERSION) {\n    throw new Error(`Downgrade supports only v${TARGET_FROM_VERSION} -> v${TARGET_TO_VERSION}. Current schema is v${currentVersion}.`);\n  }\n\n  ensureColumnsExist(database, OLLAMA);\n\n  const checkpointName = options.checkpointName || `pre-schema-downgrade-v16-to-v15-${nowTimestampForName()}`;\n  const checkpoint = checkpoints.createCheckpoint({\n    name: checkpointName,\n    specFolder: options.specFolder || null,\n    metadata: {\n      reason: 'schema downgrade v16->v15',\n      fromVersion: TARGET_FROM_VERSION,\n      toVersion: TARGET_TO_VERSION,\n      removedColumns: [...OLLAMA],\n    },\n  });\n\n  if (!checkpoint) {\n    throw new Error('Failed to create pre-downgrade checkpoint');\n  }\n\n  database.pragma('foreign_keys = OFF');\n  try {\n    const run = database.transaction(() => {\n      database.exec(`\n        DROP TRIGGER IF EXISTS memory_fts_insert;\n        DROP TRIGGER IF EXISTS memory_fts_update;\n        DROP TRIGGER IF EXISTS memory_fts_delete;\n        DROP TABLE IF EXISTS memory_fts;\n      `);\n\n      database.exec(`ALTER TABLE memory_index RENAME TO memory_index_v16_backup`);\n\n      createMemoryIndexV15(database);\n\n      const columnsCsv = V15_COLUMNS.join(', ');\n      database.exec(`\n        INSERT INTO memory_index (${columnsCsv})\n        SELECT ${columnsCsv}\n        FROM memory_index_v16_backup\n      `);\n\n      // Drop backup table to release index names before re-creating v15 indexes.\n      database.exec(`DROP TABLE memory_index_v16_backup`);\n\n      createV15Indexes(database);\n      createFtsArtifacts(database);\n\n      database.prepare(`\n        INSERT OR REPLACE INTO schema_version (id, version, updated_at)\n        VALUES (1, ?, datetime('now'))\n      `).run(TARGET_TO_VERSION);\n    });\n\n    run();\n  } finally {\n    database.pragma('foreign_keys = ON');\n  }\n\n  const row = database.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number };\n  return {\n    fromVersion: TARGET_FROM_VERSION,\n    toVersion: TARGET_TO_VERSION,","lineStart":150,"lineEnd":309,"totalLines":326,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/schema-downgrade.ts","time":{"start":1781762501243,"end":1781762501246}},"metadata":{"openai":{"itemId":"fc_055fd2f702b20bad016a3389c50dc48191bd2152ccb7527763"}},"id":"prt_ed9522a3f001Yutx4KxMK9xn56","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed951fdad001DpLYFZzmzhTgCZ"}}
{"type":"tool_use","timestamp":1781762501265,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_K4NMWdCO9xD60G44Kzea7Xfq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/chunking-orchestrator.ts","offset":240,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/chunking-orchestrator.ts</path>\n<type>file</type>\n<content>\n240: \n241:       const fileMetadata = incrementalIndex.getFileMetadata(filePath);\n242:       const fileMtimeMs = fileMetadata ? fileMetadata.mtime : null;\n243: \n244:       applyMetadata(database, pid, {\n245:         content_hash: parsed.contentHash,\n246:         context_type: parsed.contextType,\n247:         importance_tier: parsed.importanceTier,\n248:         memory_type: parsed.memoryType,\n249:         type_inference_source: parsed.memoryTypeSource,\n250:         stability: fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n251:         difficulty: fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n252:         file_mtime_ms: fileMtimeMs,\n253:         embedding_status: 'partial',\n254:         quality_score: parsed.qualityScore ?? 0,\n255:         quality_flags: JSON.stringify(parsed.qualityFlags ?? []),\n256:       });\n257: \n258:       return { parentId: pid, isUpdate: false };\n259:     }\n260:   });\n261: \n262:   const { parentId, isUpdate: existingParentUpdated } = setupParent();\n263:   const parentMemoryId = parentId;\n264:   // Use existingParentUpdated below for mutation ledger (replaces `existing` variable)\n265:   const existing = existingParentUpdated;\n266:   const useSafeSwap = existing;\n267: \n268:   // Index each chunk as a child record\n269:   let successCount = 0;\n270:   let failedCount = 0;\n271:   const childIds: number[] = [];\n272:   const bm25FailedChunks: number[] = [];\n273: \n274:   for (let i = 0; i < retainedChunks.length; i++) {\n275:     const chunk = retainedChunks[i];\n276:     const chunkTitle = `${parsed.title || 'Untitled'} [chunk ${i + 1}/${retainedChunks.length}]`;\n277:     const chunkEncodingIntent = isEncodingIntentEnabled()\n278:       ? classifyEncodingIntent(chunk.content)\n279:       : undefined;\n280:     let childId: number | undefined;\n281: \n282:     try {\n283:       // Persistent embedding cache avoids re-calling the embedding\n284:       // Provider on re-index — content-hash keyed so unchanged chunks skip API entirely.\n285:       let chunkEmbedding: Float32Array | null = null;\n286:       let chunkEmbeddingStatus = 'pending';\n287: \n288:       try {\n289:         const chunkHash = computeNormalizedChunkCacheKey(chunk.content);\n290:         const modelId = embeddings.getModelName();\n291:         const embeddingDim = embeddings.getEmbeddingDimension();\n292:         const cachedChunkBuf = lookupEmbedding(database, chunkHash, modelId, embeddingDim);\n293:         if (cachedChunkBuf) {\n294:           chunkEmbedding = new Float32Array(new Uint8Array(cachedChunkBuf).buffer);\n295:           chunkEmbeddingStatus = 'success';\n296:         } else {\n297:           chunkEmbedding = await embeddings.generateDocumentEmbedding(normalizeContentForEmbedding(chunk.content));\n298:           if (chunkEmbedding) {\n299:             chunkEmbeddingStatus = 'success';\n300:             const chunkBuf = Buffer.from(chunkEmbedding.buffer, chunkEmbedding.byteOffset, chunkEmbedding.byteLength);\n301:             storeEmbedding(database, chunkHash, modelId, chunkBuf, chunkEmbedding.length);\n302:           }\n303:         }\n304:       } catch (embErr: unknown) {\n305:         const message = toErrorMessage(embErr);\n306:         console.warn(`[memory-save] Chunk ${i + 1} embedding failed: ${message}`);\n307:       }\n308:       const importanceWeight = calculateDocumentWeight(filePath, parsed.documentType);\n309:      