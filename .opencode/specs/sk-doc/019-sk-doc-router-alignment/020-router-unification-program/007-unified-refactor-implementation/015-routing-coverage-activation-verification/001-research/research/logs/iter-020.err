   196	
   197	function evidenceFeature(value: string): string {
   198	  const prefix = value.split(':', 1)[0];
   199	  switch (prefix) {
   200	    case 'phrase':
   201	      return 'phrase_match';
   202	    case 'token':
   203	      return 'token_match';
   204	    case 'hint':
   205	      return 'category_hint';
   206	    case 'derived':
   207	      return 'derived_skill_signal';
   208	    case 'doc':
   209	      return 'doc_reference_signal';
   210	    case 'cosine':
   211	      return 'semantic_similarity';
   212	    default:
   213	      if (value.includes('disambiguation')) return 'disambiguation_rule';
   214	      if (value.includes('surface')) return 'surface_signal';
   215	      if (value.includes('intent')) return 'intent_signal';
   216	      if (value.includes('loop')) return 'workflow_signal';
   217	      return 'scorer_signal';
   218	  }
   219	}
   220	
   221	function publicWhyRecommended(recommendation: ScoredRecommendation) {
   222	  const positiveLanes = recommendation.laneContributions
   223	    .filter((lane) => lane.rawScore > 0 || lane.weightedScore > 0)
   224	    .sort((left, right) => right.weightedScore - left.weightedScore)
   225	    .slice(0, 4);
   226	  const matchedSkillFeatures = positiveLanes.flatMap((lane) => (
   227	    Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))).map((feature) => ({
   228	      lane: lane.lane,
   229	      feature,
   230	    }))
   231	  ));
   232	  const dominant = recommendation.dominantLane;
   233	  return {
   234	    reason: dominant
   235	      ? `Recommended from ranker signals: ${dominant} contributed the strongest live score.`
   236	      : 'Recommended from ranker signals without a single dominant live lane.',
   237	    dominantLane: dominant,
   238	    topLanes: positiveLanes.map((lane) => ({
   239	      lane: lane.lane,
   240	      rawScore: lane.rawScore,
   241	      weightedScore: lane.weightedScore,
   242	      weight: lane.weight,
   243	      shadowOnly: lane.shadowOnly,
   244	      evidenceTypes: Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))),
   245	      evidenceCount: lane.evidence.length,
   246	    })),
   247	    matchedSkillFeatures,
   248	  };
   249	}
   250	
   251	// Doc evidence entries are skill-relative markdown paths emitted by the
   252	// derived lane as `doc:<path>`. The allowlist rejects anything that
   253	// could smuggle prompt content or path traversal into the response.
   254	const SAFE_DOC_PATH = /^(references|assets)\/[A-Za-z0-9_./-]+\.md$/;
   255	
   256	export function matchedDocsFromContributions(
   257	  recommendation: { readonly laneContributions: ReadonlyArray<{ readonly evidence: readonly string[] }> },
   258	): string[] {
   259	  const docs: string[] = [];
   260	  for (const lane of recommendation.laneContributions) {
   261	    for (const entry of lane.evidence) {
   262	      if (!entry.startsWith('doc:')) continue;
   263	      const path = entry.slice(4);
   264	      if (!SAFE_DOC_PATH.test(path) || path.includes('..')) continue;
   265	      if (!docs.includes(path)) docs.push(path);
   266	      if (docs.length >= 3) return docs;
   267	    }
   268	  }
   269	  return docs;
   270	}
   271	
   272	function workflowModeForRecommendation(
   273	  recommendation: ScoredRecommendation,
   274	  prompt: string,
   275	): string | undefined {
   276	  const directMode = modeForAlias(recommendation.skill);
   277	  const promptMode = recommendation.skill === MERGED_DEEP_SKILL_ID
   278	    ? modeForPromptAlias(prompt)
   279	    : null;
   280	  const workflowMode = sanitizeSkillLabel(directMode ?? promptMode ?? '');
   281	  return workflowMode || undefined;
   282	}
   283	
   284	function publicRecommendation(
   285	  recommendation: ScoredRecommendation,
   286	  includeAttribution: boolean,
   287	  prompt: string,
   288	) {
   289	  const skillId = sanitizeSkillLabel(recommendation.skill);
   290	  if (!skillId) return null;
   291	  const matchedDocs = matchedDocsFromContributions(recommendation);
   292	  const redirectFrom = safeMany(recommendation.redirectFrom);
   293	  const redirectTo = sanitizeSkillLabel(recommendation.redirectTo ?? '');
   294	  const sanitizedStatus = sanitizeSkillLabel(recommendation.lifecycleStatus);
   295	  const status: PublicRecommendationStatus | undefined = sanitizedStatus === 'active'
   296	    || sanitizedStatus === 'deprecated'
   297	    || sanitizedStatus === 'archived'
   298	    || sanitizedStatus === 'future'
   299	    ? sanitizedStatus as PublicRecommendationStatus
   300	    : undefined;
   301	  const workflowMode = workflowModeForRecommendation(recommendation, prompt);
   302	  return {
   303	    skillId,
   304	    score: recommendation.score,
   305	    confidence: recommendation.confidence,
   306	    uncertainty: recommendation.uncertainty,
   307	    dominantLane: recommendation.dominantLane,
   308	    ...(includeAttribution ? {
   309	      laneBreakdown: recommendation.laneContributions.map((lane) => ({
   310	        lane: lane.lane,
   311	        rawScore: lane.rawScore,
   312	        weightedScore: lane.weightedScore,
   313	        weight: lane.weight,
   314	        shadowOnly: lane.shadowOnly,
   315	      })),
   316	      why_recommended: publicWhyRecommended(recommendation),
   317	    } : {}),
   318	    ...(matchedDocs.length > 0 ? { matchedDocs } : {}),
   319	    ...(redirectFrom.length > 0 ? { redirectFrom } : {}),
   320	    ...(redirectTo ? { redirectTo } : {}),
   321	    ...(status ? { status } : {}),
   322	    ...(workflowMode ? { workflowMode } : {}),
   323	  };
   324	}
   325	
   326	function compiledRouteForRecommendation(
   327	  skillId: string,
   328	  prompt: string,
   329	  workspaceRoot: string,
   330	): Record<string, unknown> | undefined {
   331	  if (!COMPILED_ROUTING_HUBS.has(skillId)) return undefined;
   332	  try {
   333	    const output = execFileSync(process.execPath, [
   334	      resolve(workspaceRoot, '.opencode', 'bin', 'compiled-route.cjs'),
   335	      '--hub',
   336	      skillId,
   337	      '--prompt',
   338	      prompt,
   339	    ], {
   340	      cwd: workspaceRoot,
   341	      encoding: 'utf8',
   342	      stdio: ['ignore', 'pipe', 'ignore'],
   343	      timeout: 5_000,
   344	      maxBuffer: 1_048_576,
   345	    });
   346	    const parsed: unknown = JSON.parse(output.trim());
   347	    if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {
   348	      return undefined;
   349	    }
   350	    const compiledRoute = parsed as Record<string, unknown>;
   351	    return compiledRoute.servingAuthority === 'legacy' ? undefined : compiledRoute;
   352	  } catch {
   353	    return undefined;
   354	  }
   355	}
   356	
   357	function enrichCompiledRoutes(
   358	  output: AdvisorRecommendOutput,
   359	  prompt: string,
   360	  workspaceRoot: string,
   361	): AdvisorRecommendOutput {
   362	  if (process.env.SPECKIT_COMPILED_ROUTING !== '1') return output;
   363	  return AdvisorRecommendOutputSchema.parse({
   364	    ...output,
   365	    recommendations: output.recommendations.map((recommendation) => {
   366	      const compiledRoute = compiledRouteForRecommendation(
   367	        recommendation.skillId,
   368	        prompt,
   369	        workspaceRoot,
   370	      );
   371	      return compiledRoute ? { ...recommendation, compiledRoute } : recommendation;
   372	    }),
   373	  });
   374	}
   375	
   376	function publicShadowRecommendations(recommendations: readonly ScoredRecommendation[], topK: number): ShadowRecommendation[] {
   377	  const shadowRecommendations: ShadowRecommendation[] = [];
   378	  for (const recommendation of recommendations) {
   379	    const skillId = sanitizeSkillLabel(recommendation.skill);
   380	    if (!skillId) continue;
   381	    const shadowContributions = recommendation.laneContributions.map((lane) => ({
   382	      lane: lane.lane,
   383	      weightedScore: lane.rawScore * DEFAULT_SHADOW_SCORER_LANE_WEIGHTS[lane.lane],
   384	    }));
   385	    const shadowScore = roundScore(shadowContributions.reduce((total, lane) => total + lane.weightedScore, 0));
   386	    const dominant = shadowContributions
   387	      .filter((lane) => lane.weightedScore > 0)
   388	      .sort((left, right) => right.weightedScore - left.weightedScore)[0]?.lane ?? null;
   389	    shadowRecommendations.push({
   390	        skillId,
   391	        liveScore: recommendation.score,
   392	        shadowScore,
   393	        delta: roundScore(shadowScore - recommendation.score),
   394	        dominantShadowLane: dominant,
   395	    });
   396	  }
   397	  return shadowRecommendations
   398	    .sort((left, right) => right.shadowScore - left.shadowScore || left.skillId.localeCompare(right.skillId))
   399	    .slice(0, topK);
   400	}
   401	
   402	function roundScore(value: number): number {
   403	  return Math.round(value * 1_000_000) / 1_000_000;
   404	}
   405	
   406	function outputWarnings(
   407	  status: AdvisorStatus,
   408	  result: ReturnType<typeof scoreAdvisorPrompt>,
   409	): string[] {
   410	  const degradedLanes = result.metrics.degradedLanes ?? [];
   520	    } : {}),
   521	    ...(warnings.length > 0 ? { warnings } : {}),
   522	    ...(abstainReasons.length > 0 ? { abstainReasons } : {}),
   523	  };
   524	  const parsed = AdvisorRecommendOutputSchema.parse(output);
   525	  if (shadowDeltaSinkEnabled()) {
   526	    for (const shadow of parsed._shadow?.recommendations ?? []) {
   527	      recordShadowDelta({
   528	        prompt: `hmac:${key}`,
   529	        recommendation: shadow.skillId,
   530	        liveScore: shadow.liveScore,
   531	        shadowScore: shadow.shadowScore,
   532	        delta: shadow.delta,
   533	        dominantLane: shadow.dominantShadowLane,
   534	        timestamp: parsed.generatedAt,
   535	      });
   536	    }
   537	  }
   538	  advisorPromptCache.set({
   539	    key,
   540	    sourceSignature,
   541	    value: parsed,
   542	    skillLabels: recommendationLabels(parsed),
   543	  });
   544	  return enrichCompiledRoutes(parsed, input.prompt, workspaceRoot);
   545	}
   546	
   547	export async function handleAdvisorRecommend(args: unknown): Promise<HandlerResponse> {
   548	  const input = AdvisorRecommendInputSchema.parse(args);
   549	  // Canonicalize via realpath after the schema allowlist check.
   550	  const workspaceRoot = input.workspaceRoot
   551	    ? canonicalizeWorkspaceRoot(input.workspaceRoot)
   552	    : findWorkspaceRoot();
   553	  const effectiveThresholds = publicThresholds({
   554	    confidenceThreshold: input.options?.confidenceThreshold,
   555	    uncertaintyThreshold: input.options?.uncertaintyThreshold,
   556	  });
   557	  const data = process.env.MK_SKILL_ADVISOR_HOOK_DISABLED === '1'
   558	    || process.env.SPECKIT_SKILL_ADVISOR_HOOK_DISABLED === '1'
   559	    ? disabledOutput(workspaceRoot, effectiveThresholds)
   560	    : await computeRecommendationOutput(input);
   561	  return {
   562	    content: [{
   563	      type: 'text',
   564	      text: JSON.stringify({ status: 'ok', data }, null, 2),
   565	    }],
   566	  };
   567	}
   568	
   569	export const handle_advisor_recommend = handleAdvisorRecommend;

