    11	import { readAdvisorStatus } from './advisor-status-reader.js';
    12	
    13	export interface AdvisorDaemonProbeInput {
    14	  readonly workspaceRoot: string;
    15	  readonly timeoutMs?: number;
    16	  readonly statusReader?: (input: { workspaceRoot: string }) => AdvisorStatusOutput;
    17	}
    18	
    19	export interface AdvisorDaemonProbeResult {
    20	  readonly available: boolean;
    21	  readonly freshness: AdvisorFreshness;
    22	  readonly trustState: AdvisorStatusOutput['trustState'];
    23	  readonly generation: number;
    24	  readonly daemonPid?: number;
    25	  readonly reason: string | null;
    26	}
    27	
    28	const AVAILABLE_FRESHNESS: ReadonlySet<AdvisorFreshness> = new Set(['live', 'stale']);
    29	
    30	function unavailable(reason: string): AdvisorDaemonProbeResult {
    31	  return {
    32	    available: false,
    33	    freshness: 'unavailable',
    34	    trustState: {
    35	      state: 'unavailable',
    36	      reason,
    37	      generation: 0,
    38	      checkedAt: new Date().toISOString(),
    39	      lastLiveAt: null,
    40	    },
    41	    generation: 0,
    42	    reason,
    43	  };
    44	}
    45	
    46	export function probeAdvisorDaemon(input: AdvisorDaemonProbeInput): AdvisorDaemonProbeResult {
    47	  if (process.env.SPECKIT_SKILL_ADVISOR_HOOK_DISABLED === '1') {
    48	    return unavailable('ADVISOR_DISABLED');
    49	  }
    50	
    51	  try {
    52	    const statusReader = input.statusReader ?? readAdvisorStatus;
    53	    const status = statusReader({ workspaceRoot: resolve(input.workspaceRoot) });
    54	    const reason = status.errors?.[0] ?? status.trustState.reason ?? null;
    55	    return {
    56	      available: AVAILABLE_FRESHNESS.has(status.freshness),
    57	      freshness: status.freshness,
    58	      trustState: status.trustState,
    59	      generation: status.generation,
    60	      ...(status.daemonPid ? { daemonPid: status.daemonPid } : {}),
    61	      reason,
    62	    };
    63	  } catch (error: unknown) {
    64	    const code = error instanceof Error && error.name ? error.name : 'PROBE_FAILED';
    65	    return unavailable(code.toUpperCase().replace(/[^A-Z0-9_]/g, '_'));
    66	  }
    67	}
