    57	// (`/repo/proj-evil` vs `/repo/proj`) does NOT read as inside. Used to keep
    58	// grep / grep_absent criteria file reads anchored inside the fixture cwd.
    59	function isInsideCwd(candidate, base) {
    60	  return candidate === base || candidate.startsWith(base + path.sep);
