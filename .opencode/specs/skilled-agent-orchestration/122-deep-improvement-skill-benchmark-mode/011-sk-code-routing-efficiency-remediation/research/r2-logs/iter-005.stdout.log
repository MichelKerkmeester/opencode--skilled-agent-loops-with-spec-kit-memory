{"type":"tool_use","timestamp":1780372969821,"sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","part":{"type":"tool","tool":"read","callID":"call_Jj40QoqgyusewtoDlB3HpLyg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","offset":1,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * load-playbook-scenarios.cjs — corpus loader for Lane C.\n6:  *\n7:  * A skill's manual_testing_playbook is its authored, live-execution contract\n8:  * (\"Every scenario MUST be executed against the live skill — no mocks\"). It is\n9:  * a far better benchmark corpus than synthetic decontaminated fixtures: real\n10:  * prompts with real expected-routing gold. This module parses that playbook\n11:  * into one normalized scenario shape the orchestrator scores against.\n12:  *\n13:  * Two source shapes are supported:\n14:  *   1. The sk-code shape: a root index table (§ \"FEATURE CATALOG CROSS-REFERENCE\n15:  *      INDEX\") enumerating {id, per-feature file, critical}, plus per-feature\n16:  *      files carrying the exact prompt + expected references/assets + pass rules.\n17:  *   2. The sk-doc shape: per-scenario files whose YAML frontmatter carries\n18:  *      expected_intent / expected_resources (no root index table).\n19:  *\n20:  * Gold is captured AS AUTHORED. We deliberately do NOT assert that an expected\n21:  * path exists on disk — a stale expectation (e.g. a renamed reference) is a real\n22:  * finding the scorer should surface as router↔gold drift, not silently drop.\n23:  */\n24: \n25: const fs = require('fs');\n26: const path = require('path');\n27: \n28: const ID_RE = /\\b([A-Z]{2})-(\\d{3})\\b/;\n29: \n30: // classKind selects the executor: routing/advisor run via router-replay or live\n31: // cli-opencode; browser scenarios need a real browser (bdg) and are routed out\n32: // of the text executors.\n33: function classifyKind(scenarioId, category, expectedSurface, passCriteria) {\n34:   const cat = (category || '').toLowerCase();\n35:   const prefix = (ID_RE.exec(scenarioId || '') || [])[1] || '';\n36:   if (/motion|animation|browser|performance|visual|compositing|cross-browser/.test(cat)\n37:       || prefix === 'MR' || prefix === 'CB') {\n38:     return 'browser';\n39:   }\n40:   // A scenario that asserts an in-skill SURFACE is a routing test (the advisor\n41:   // check is just its precondition). Advisor-class is reserved for scenarios\n42:   // whose WHOLE test is skill selection — no surface — run as a skill_advisor.py\n43:   // probe (SA-*, and the sk-code-vs-sk-doc anti-pattern).\n44:   if (expectedSurface) return 'routing';\n45:   const pass = (passCriteria || '').toLowerCase();\n46:   if (prefix === 'SA' || /top-1\\s*(!=|==)|routes? .* to sk-doc|advisor (top-1|wins)/.test(pass)) {\n47:     return 'advisor';\n48:   }\n49:   return 'routing';\n50: }\n51: \n52: function readFileSafe(p) {\n53:   try { return fs.readFileSync(p, 'utf8'); } catch { return null; }\n54: }\n55: \n56: // Pull every `references/...` / `assets/...` markdown-ish path token out of a\n57: // text block, deduped, order-preserving. Tolerates backticks, bullets, and\n58: // trailing parentheticals like \"(when intent is X)\".\n59: function extractPaths(block) {\n60:   if (!block) return [];\n61:   const out = [];\n62:   const seen = new Set();\n63:   const re = /(?:references|assets)\\/[A-Za-z0-9_./-]+\\.[a-z]{1,4}/g;\n64:   let m;\n65:   while ((m = re.exec(block)) !== null) {\n66:     const p = m[0];\n67:     if (!seen.has(p)) { seen.add(p); out.push(p); }\n68:   }\n69:   return out;\n70: }\n71: \n72: // Grab the text between a `**Label**` marker and the next bold marker / heading.\n73: function sectionAfter(text, labelRe) {\n74:   const start = text.search(labelRe);\n75:   if (start === -1) return '';\n76:   const rest = text.slice(start);\n77:   const endRel = rest.slice(1).search(/\\n\\s*(?:\\*\\*[A-Z]|#{1,3}\\s|\\d+\\.\\s+[A-Z])/);\n78:   return endRel === -1 ? rest : rest.slice(0, endRel + 1);\n79: }\n80: \n81: function parsePromptBlock(text) {\n82:   // ```[lang]\\n<prompt>\\n``` after the prompt marker. Per-feature files vary:\n83:   // SD/LS/RD use \"**Exact prompt**\", CS use \"**Realistic user prompt**\".\n84:   const m = /\\*\\*(?:Exact prompt|Realistic user prompt)\\*\\*:?\\s*\\n+```[a-z]*\\n([\\s\\S]*?)\\n```/i.exec(text);\n85:   if (m) return m[1].trim();\n86:   // sk-doc / inline shape: \"Prompt: ...\" line.\n87:   const inline = /(?:^|\\n)\\s*(?:\\*\\*)?Prompt(?:\\*\\*)?:\\s*(.+)/i.exec(text);\n88:   return inline ? inline[1].trim() : null;\n89: }\n90: \n91: // The root §7-13 tables carry the \"Exact Prompt\" column for every scenario in a\n92: // uniform 9-column shape — the authoritative prompt source when a per-feature\n93: // file uses a non-standard marker or omits the fenced block.\n94: function parseRootScenarioTables(rootText) {\n95:   const map = {};\n96:   for (const line of rootText.split('\\n')) {\n97:     if (!/^\\|/.test(line)) continue;\n98:     const cells = line.split('|').map((c) => c.trim());\n99:     // Leading/trailing empties from the bounding pipes -> cells[1] is Feature ID.\n100:     const idCell = (cells[1] || '').replace(/`/g, '');\n101:     if (!/^[A-Z]{2}-\\d{3}$/.test(idCell)) continue;\n102:     if (cells.length < 9) continue; // not a §7-13 scenario row\n103:     const prompt = (cells[4] || '').replace(/^`|`$/g, '').trim();\n104:     map[idCell] = {\n105:       prompt: /multi-prompt battery|see per-feature/i.test(prompt) ? null : (prompt || null),\n106:       expectedSignals: cells[6] || null,\n107:       passCriteria: cells[8] || null,\n108:     };\n109:   }\n110:   return map;\n\n(Showing lines 1-110 of 271. Use offset=111 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * load-playbook-scenarios.cjs — corpus loader for Lane C.\n *\n * A skill's manual_testing_playbook is its authored, live-execution contract\n * (\"Every scenario MUST be executed against the live skill — no mocks\"). It is\n * a far better benchmark corpus than synthetic decontaminated fixtures: real\n * prompts with real expected-routing gold. This module parses that playbook\n * into one normalized scenario shape the orchestrator scores against.\n *\n * Two source shapes are supported:\n *   1. The sk-code shape: a root index table (§ \"FEATURE CATALOG CROSS-REFERENCE\n *      INDEX\") enumerating {id, per-feature file, critical}, plus per-feature\n *      files carrying the exact prompt + expected references/assets + pass rules.\n *   2. The sk-doc shape: per-scenario files whose YAML frontmatter carries\n *      expected_intent / expected_resources (no root index table).\n *\n * Gold is captured AS AUTHORED. We deliberately do NOT assert that an expected","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","time":{"start":1780372969802,"end":1780372969820}},"metadata":{"openai":{"itemId":"fc_07725c1e88157bce016a1e55e9c0f88191a50b70cfdce3bcb8"}},"id":"prt_e867f9928001vG2fi0tTefCAbj","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867f85d9001cawdQw1uCRC8QX"}}
