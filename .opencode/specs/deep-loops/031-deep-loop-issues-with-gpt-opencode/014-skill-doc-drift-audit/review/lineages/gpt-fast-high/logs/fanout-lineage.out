ed. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"\\.opencode/agents/\\*\\.toml|agents/.*toml|mirror|mirrors","time":{"start":1782919041520,"end":1782919041577}},"metadata":{"openai":{"itemId":"fc_052b73d6d7448eb4016a452f7fafa881918897fd32a9f8e56f"}},"id":"prt_f1e4191ea001Z83uT3sxwt9wfy","sessionID":"ses_0e1c12f14ffe56Cs01FOXHPL99","messageID":"msg_f1e412e42001e7STSMZLmXs9fI"}}
