{"type":"tool_use","timestamp":1781718639902,"sessionID":"ses_1294e112dffeF8UlfEsNhSrzCb","part":{"type":"tool","tool":"read","callID":"tool_vSAY7naAq9s9AX4WRlATxuGT","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/batch-processor.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/batch-processor.vitest.ts</path>\n<type>file</type>\n<content>\n1: // TEST: BATCH PROCESSOR\n2: import { describe, it, expect, vi, afterEach } from 'vitest';\n3: import {\n4:   processBatches,\n5:   processWithRetry,\n6:   processSequentially,\n7:   BATCH_SIZE,\n8:   BATCH_DELAY_MS,\n9:   DEFAULT_RETRY_OPTIONS,\n10:   MAX_BATCH_SIZE,\n11: } from '../utils/batch-processor';\n12: \n13: type RetryFailure = {\n14:   retries_failed: boolean;\n15:   error?: unknown;\n16:   item?: unknown;\n17:   errorDetail?: string;\n18: };\n19: \n20: afterEach(() => {\n21:   vi.restoreAllMocks();\n22: });\n23: \n24: describe('Batch Processor', () => {\n25:   /* ═══════════════════════════════════════════════════════════\n26:      1. Module Exports\n27:   ════════════════════════════════════════════════════════════ */\n28: \n29:   describe('1. Module Exports', () => {\n30:     it('T01: processBatches exported as function', () => {\n31:       expect(typeof processBatches).toBe('function');\n32:     });\n33: \n34:     it('T02: processWithRetry exported as function', () => {\n35:       expect(typeof processWithRetry).toBe('function');\n36:     });\n37: \n38:     it('T03: processSequentially exported as function', () => {\n39:       expect(typeof processSequentially).toBe('function');\n40:     });\n41: \n42:     it('T04: BATCH_SIZE exported as number', () => {\n43:       expect(typeof BATCH_SIZE).toBe('number');\n44:     });\n45: \n46:     it('T05: BATCH_DELAY_MS exported as number', () => {\n47:       expect(typeof BATCH_DELAY_MS).toBe('number');\n48:     });\n49: \n50:     it('T06: DEFAULT_RETRY_OPTIONS exported with maxRetries and retryDelay', () => {\n51:       expect(typeof DEFAULT_RETRY_OPTIONS).toBe('object');\n52:       expect(typeof DEFAULT_RETRY_OPTIONS.maxRetries).toBe('number');\n53:       expect(typeof DEFAULT_RETRY_OPTIONS.retryDelay).toBe('number');\n54:     });\n55: \n56:     it('T06b: MAX_BATCH_SIZE exported as number', () => {\n57:       expect(typeof MAX_BATCH_SIZE).toBe('number');\n58:       expect(MAX_BATCH_SIZE).toBeGreaterThan(0);\n59:     });\n60:   });\n61: \n62:   /* ═══════════════════════════════════════════════════════════\n63:      2. Batch Size Validation\n64:   ════════════════════════════════════════════════════════════ */\n65: \n66:   describe('2. batchSize Validation (P0-08)', () => {\n67:     it('T07: batchSize=0 throws Error with descriptive message', async () => {\n68:       await expect(\n69:         processBatches([1, 2, 3], async (x: number) => x, 0)\n70:       ).rejects.toThrow('positive integer');\n71:     });\n72: \n73:     it('T08: batchSize=-1 throws Error', async () => {\n74:       await expect(\n75:         processBatches([1], async (x: number) => x, -1)\n76:       ).rejects.toThrow();\n77:     });\n78: \n79:     it('T09: batchSize=-100 throws Error', async () => {\n80:       await expect(\n81:         processBatches([1], async (x: number) => x, -100)\n82:       ).rejects.toThrow();\n83:     });\n84: \n85:     it('T10: batchSize=0 throws even with empty items array', async () => {\n86:       await expect(\n87:         processBatches<number, number>([], async (x: number) => x, 0)\n88:       ).rejects.toThrow();\n89:     });\n90: \n91:     it('T11: batchSize=1 is valid (smallest positive integer)', async () => {\n92:       const results = await processBatches([42], async (x: number) => x * 2, 1, 0);\n93:       expect(results.length).toBe(1);\n94:       expect(results[0]).toBe(84);\n95:     });\n96:   });\n97: \n98:   /* ═══════════════════════════════════════════════════════════\n99:      3. Normal Operation (processBatches)\n100:   ════════════════════════════════════════════════════════════ */\n101: \n102:   describe('3. Normal Operation (processBatches)', () => {\n103:     it('T12: batchSize=1 processes items one at a time', async () => {\n104:       const order: number[] = [];\n105:       const items = [10, 20, 30];\n106:       const results = await processBatches(\n107:         items,\n108:         async (x: number) => { order.push(x); return x + 1; },\n109:         1, 0\n110:       );\n111:       expect(results).toEqual([11, 21, 31]);\n112:       expect(order).toEqual([10, 20, 30]);\n113:     });\n114: \n115:     it('T13: batchSize=5 with 12 items processes in 3 batches', async () => {\n116:       let batchCount = 0;\n117:       const spy = vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n118:         const msg = args.join(' ');\n119:         if (msg.includes('[batch-processor] Processing batch')) batchCount++;\n120:       });\n121: \n122:       const items = Array.from({ length: 12 }, (_, i) => i);\n123:       const results = await processBatches(\n124:         items,\n125:         async (x: number) => x * 10,\n126:         5, 0\n127:       );\n128: \n129:       expect(results.length).toBe(12);\n130:       expect(batchCount).toBe(3);\n131:       expect(results[0]).toBe(0);\n132:       expect(results[11]).toBe(110);\n133:     });\n134: \n135:     it('T14: Empty items array returns empty results', async () => {\n136:       const results = await processBatches<number, number>([], async (x: number) => x, 5, 0);\n137:       expect(results).toEqual([]);\n138:     });\n139: \n140:     it('T15: Results preserve input order', async () => {\n141:       const items = [3, 1, 4, 1, 5, 9, 2, 6];\n142:       const results = await processBatches(\n143:         items,\n144:         async (x: number) => x * 100,\n145:         3, 0\n146:       );\n147:       expect(results).toEqual([300, 100, 400, 100, 500, 900, 200, 600]);\n148:     });\n149:   });\n150: \n151:   /* ═══════════════════════════════════════════════════════════\n152:      4. Callback / Processor Behavior\n153:   ════════════════════════════════════════════════════════════ */\n154: \n155:   describe('4. Callback / Processor Behavior', () => {\n156:     it('T16: processFn called for each item exactly once', async () => {\n157:       const seen: string[] = [];\n158:       const items = ['a', 'b', 'c', 'd'];\n159:       await processBatches(\n160:         items,\n161:         async (x: string) => { seen.push(x); return x.toUpperCase(); },\n162:         2, 0\n163:       );\n164:       expect(seen.sort()).toEqual(['a', 'b', 'c', 'd']);\n165:     });\n166: \n167:     it('T17: Error in processFn returns RetryErrorResult', async () => {\n168:       const items = [1, 2, 3];\n169:       const results = await processBatches(\n170:         items,\n171:         async (x: number) => {\n172:           if (x === 2) throw new Error('deliberate non-transient failure');\n173:           return x;\n174:         },\n175:         3, 0,\n176:         { maxRetries: 0 }\n177:       );\n178:       expect(results.length).toBe(3);\n179:       expect(results[0]).toBe(1);\n180:       expect(results[2]).toBe(3);\n181:       const errResult = results[1] as RetryFailure;\n182:       expect(errResult.retries_failed).toBe(true);\n183:       expect(errResult.error).toBeTruthy();\n184:       expect(errResult.item).toBe(2);\n185:     });\n186: \n187:     it('T18: Async processor results are properly awaited', async () => {\n188:       const results = await processBatches(\n189:         [10, 20],\n190:         async (x: number) => {\n191:           await new Promise<void>(r => setTimeout(r, 10));\n192:           return x + 5;\n193:         },\n194:         2, 0\n195:       );\n196:       expect(results).toEqual([15, 25]);\n197:     });\n198:   });\n199: \n200:   /* ═══════════════════════════════════════════════════════════\n201:      5. Edge Cases (processBatches)\n202:   ════════════════════════════════════════════════════════════ */\n203: \n204:   describe('5. Edge Cases (processBatches)', () => {\n205:     it('T19: Single item processed correctly', async () => {\n206:       const results = await processBatches(['only'], async (x: string) => x.length, 5, 0);\n207:       expect(results).toEqual([4]);\n208:     });\n209: \n210:     it('T20: batchSize larger than items count processes in 1 batch', async () => {\n211:       let batchCount = 0;\n212:       const spy = vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n213:         const msg = args.join(' ');\n214:         if (msg.includes('[batch-processor] Processing batch')) batchCount++;\n215:       });\n216: \n217:       const results = await processBatches([1, 2, 3], async (x: number) => x, 100, 0);\n218: \n219:       expect(results).toEqual([1, 2, 3]);\n220:       expect(batchCount).toBe(1);\n221:     });\n222: \n223:     it('T21: Very large batchSize (10000) with small array works', async () => {\n224:       const results = await processBatches([42], async (x: number) => x, 10000, 0);\n225:       expect(results).toEqual([42]);\n226:     });\n227: \n228:     it('T21b: overly large batchSize is clamped before running concurrent work', async () => {\n229:       const batchLogs: string[] = [];\n230:       vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n231:         const message = args.join(' ');\n232:         if (message.includes('[batch-processor] Processing batch')) {\n233:           batchLogs.push(message);\n234:         }\n235:       });\n236:       const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});\n237: \n238:       const items = Array.from({ length: MAX_BATCH_SIZE * 2 + 1 }, (_, index) => index);\n239:       const results = await processBatches(items, async (x: number) => x, MAX_BATCH_SIZE * 10, 0);\n240: \n241:       expect(results).toHaveLength(items.length);\n242:       expect(batchLogs).toHaveLength(3);\n243:       expect(warnSpy).toHaveBeenCalledWith(\n244:         `[batch-processor] Clamped batch size ${MAX_BATCH_SIZE * 10} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n245:       );\n246:     });\n247: \n248:     it('T22: Exact batch boundary (6 items / batchSize 3 = 2 batches)', async () => {\n249:       let batchCount = 0;\n250:       const spy = vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n251:         const msg = args.join(' ');\n252:         if (msg.includes('[batch-processor] Processing batch')) batchCount++;\n253:       });\n254: \n255:       const results = await processBatches([1, 2, 3, 4, 5, 6], async (x: number) => x, 3, 0);\n256: \n257:       expect(results.length).toBe(6);\n258:       expect(batchCount).toBe(2);\n259:     });\n260:   });\n261: \n262:   /* ═══════════════════════════════════════════════════════════\n263:      6. processWithRetry\n264:   ════════════════════════════════════════════════════════════ */\n265: \n266:   describe('6. processWithRetry', () => {\n267:     it('T23: processWithRetry returns result on success', async () => {\n268:       const result = await processWithRetry(5, async (x: number) => x * 3);\n269:       expect(result).toBe(15);\n270:     });\n271: \n272:     it('T24: Non-transient error returns RetryErrorResult without retry', async () => {\n273:       const result = await processWithRetry(\n274:         'test',\n275:         async () => { throw new Error('permanent failure'); },\n276:         { maxRetries: 2, retryDelay: 1 }\n277:       ) as RetryFailure;\n278:       expect(result.retries_failed).toBe(true);\n279:       expect(result.error).toBeTruthy();\n280:       expect(result.item).toBe('test');\n281:     });\n282: \n283:     it('T25: maxRetries=0 means single attempt', async () => {\n284:       let attempts = 0;\n285:       const result = await processWithRetry(\n286:         'val',\n287:         async () => { attempts++; throw new Error('SQLITE_BUSY transient'); },\n288:         { maxRetries: 0, retryDelay: 1 }\n289:       ) as RetryFailure;\n290:       expect(attempts).toBe(1);\n291:       expect(result.retries_failed).toBe(true);\n292:     });\n293: \n294:     it('T26: DEFAULT_RETRY_OPTIONS has maxRetries=2, retryDelay=1000', () => {\n295:       expect(DEFAULT_RETRY_OPTIONS.maxRetries).toBe(2);\n296:       expect(DEFAULT_RETRY_OPTIONS.retryDelay).toBe(1000);\n297:     });\n298: \n299:     it('T26a: invalid maxRetries falls back to default without crashing', async () => {\n300:       let attempts = 0;\n301:       const result = await processWithRetry(\n302:         'retry',\n303:         async () => {\n304:           attempts++;\n305:           throw new Error('SQLITE_BUSY transient');\n306:         },\n307:         { maxRetries: -5, retryDelay: 0 }\n308:       ) as RetryFailure;\n309:       expect(attempts).toBe(DEFAULT_RETRY_OPTIONS.maxRetries + 1);\n310:       expect(result.retries_failed).toBe(true);\n311:     });\n312: \n313:     it('T26b: invalid retryDelay falls back to default and still completes', async () => {\n314:       const result = await processWithRetry(\n315:         1,\n316:         async () => {\n317:           throw new Error('permanent failure');\n318:         },\n319:         { maxRetries: 0, retryDelay: Number.NaN }\n320:       ) as RetryFailure;\n321:       expect(result.retries_failed).toBe(true);\n322:       expect(result.errorDetail).toContain('permanent failure');\n323:     });\n324:   });\n325: \n326:   /* ═══════════════════════════════════════════════════════════\n327:      7. processSequentially\n328:   ════════════════════════════════════════════════════════════ */\n329: \n330:   describe('7. processSequentially', () => {\n331:     it('T27: processSequentially processes items in strict order', async () => {\n332:       const order: number[] = [];\n333:       const items = [1, 2, 3, 4, 5];\n334:       const results = await processSequentially(\n335:         items,\n336:         async (x: number) => {\n337:           order.push(x);\n338:           return x * 2;\n339:         }\n340:       );\n341:       expect(order).toEqual([1, 2, 3, 4, 5]);\n342:       expect(results).toEqual([2, 4, 6, 8, 10]);\n343:     });\n344: \n345:     it('T28: processSequentially with empty array returns []', async () => {\n346:       const results = await processSequentially<number, number>([], async (x: number) => x);\n347:       expect(results).toEqual([]);\n348:     });\n349: \n350:     it('T29: processSequentially error in one item does not stop others', async () => {\n351:       const items = [1, 2, 3];\n352:       const results = await processSequentially(\n353:         items,\n354:         async (x: number) => {\n355:           if (x === 2) throw new Error('fail item 2');\n356:           return x;\n357:         },\n358:         { maxRetries: 0 }\n359:       );\n360:       expect(results.length).toBe(3);\n361:       expect(results[0]).toBe(1);\n362:       expect((results[1] as RetryFailure).retries_failed).toBe(true);\n363:       expect(results[2]).toBe(3);\n364:     });\n365: \n366:     it('T30: processSequentially with single item', async () => {\n367:       const results = await processSequentially([99], async (x: number) => x + 1);\n368:       expect(results).toEqual([100]);\n369:     });\n370:   });\n371: \n372:   /* ═══════════════════════════════════════════════════════════\n373:      8. Delay Behavior\n374:   ════════════════════════════════════════════════════════════ */\n375: \n376:   describe('8. Delay Behavior', () => {\n377:     it('T31: delayMs=0 does not add delay between batches', async () => {\n378:       const start = Date.now();\n379:       await processBatches([1, 2, 3, 4], async (x: number) => x, 2, 0);\n380:       const elapsed = Date.now() - start;\n381:       expect(elapsed).toBeLessThan(200);\n382:     });\n383: \n384:     it('T32: No delay after last batch (single batch case)', async () => {\n385:       const start = Date.now();\n386:       await processBatches([1, 2], async (x: number) => x, 2, 500);\n387:       const elapsed = Date.now() - start;\n388:       expect(elapsed).toBeLessThan(200);\n389:     });\n390:   });\n391: });\n\n(End of file - total 391 lines)\n</content>","metadata":{"preview":"// TEST: BATCH PROCESSOR\nimport { describe, it, expect, vi, afterEach } from 'vitest';\nimport {\n  processBatches,\n  processWithRetry,\n  processSequentially,\n  BATCH_SIZE,\n  BATCH_DELAY_MS,\n  DEFAULT_RETRY_OPTIONS,\n  MAX_BATCH_SIZE,\n} from '../utils/batch-processor';\n\ntype RetryFailure = {\n  retries_failed: boolean;\n  error?: unknown;\n  item?: unknown;\n  errorDetail?: string;\n};\n\nafterEach(() => {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/batch-processor.vitest.ts","text":"// TEST: BATCH PROCESSOR\nimport { describe, it, expect, vi, afterEach } from 'vitest';\nimport {\n  processBatches,\n  processWithRetry,\n  processSequentially,\n  BATCH_SIZE,\n  BATCH_DELAY_MS,\n  DEFAULT_RETRY_OPTIONS,\n  MAX_BATCH_SIZE,\n} from '../utils/batch-processor';\n\ntype RetryFailure = {\n  retries_failed: boolean;\n  error?: unknown;\n  item?: unknown;\n  errorDetail?: string;\n};\n\nafterEach(() => {\n  vi.restoreAllMocks();\n});\n\ndescribe('Batch Processor', () => {\n  /* ═══════════════════════════════════════════════════════════\n     1. Module Exports\n  ════════════════════════════════════════════════════════════ */\n\n  describe('1. Module Exports', () => {\n    it('T01: processBatches exported as function', () => {\n      expect(typeof processBatches).toBe('function');\n    });\n\n    it('T02: processWithRetry exported as function', () => {\n      expect(typeof processWithRetry).toBe('function');\n    });\n\n    it('T03: processSequentially exported as function', () => {\n      expect(typeof processSequentially).toBe('function');\n    });\n\n    it('T04: BATCH_SIZE exported as number', () => {\n      expect(typeof BATCH_SIZE).toBe('number');\n    });\n\n    it('T05: BATCH_DELAY_MS exported as number', () => {\n      expect(typeof BATCH_DELAY_MS).toBe('number');\n    });\n\n    it('T06: DEFAULT_RETRY_OPTIONS exported with maxRetries and retryDelay', () => {\n      expect(typeof DEFAULT_RETRY_OPTIONS).toBe('object');\n      expect(typeof DEFAULT_RETRY_OPTIONS.maxRetries).toBe('number');\n      expect(typeof DEFAULT_RETRY_OPTIONS.retryDelay).toBe('number');\n    });\n\n    it('T06b: MAX_BATCH_SIZE exported as number', () => {\n      expect(typeof MAX_BATCH_SIZE).toBe('number');\n      expect(MAX_BATCH_SIZE).toBeGreaterThan(0);\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     2. Batch Size Validation\n  ════════════════════════════════════════════════════════════ */\n\n  describe('2. batchSize Validation (P0-08)', () => {\n    it('T07: batchSize=0 throws Error with descriptive message', async () => {\n      await expect(\n        processBatches([1, 2, 3], async (x: number) => x, 0)\n      ).rejects.toThrow('positive integer');\n    });\n\n    it('T08: batchSize=-1 throws Error', async () => {\n      await expect(\n        processBatches([1], async (x: number) => x, -1)\n      ).rejects.toThrow();\n    });\n\n    it('T09: batchSize=-100 throws Error', async () => {\n      await expect(\n        processBatches([1], async (x: number) => x, -100)\n      ).rejects.toThrow();\n    });\n\n    it('T10: batchSize=0 throws even with empty items array', async () => {\n      await expect(\n        processBatches<number, number>([], async (x: number) => x, 0)\n      ).rejects.toThrow();\n    });\n\n    it('T11: batchSize=1 is valid (smallest positive integer)', async () => {\n      const results = await processBatches([42], async (x: number) => x * 2, 1, 0);\n      expect(results.length).toBe(1);\n      expect(results[0]).toBe(84);\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     3. Normal Operation (processBatches)\n  ════════════════════════════════════════════════════════════ */\n\n  describe('3. Normal Operation (processBatches)', () => {\n    it('T12: batchSize=1 processes items one at a time', async () => {\n      const order: number[] = [];\n      const items = [10, 20, 30];\n      const results = await processBatches(\n        items,\n        async (x: number) => { order.push(x); return x + 1; },\n        1, 0\n      );\n      expect(results).toEqual([11, 21, 31]);\n      expect(order).toEqual([10, 20, 30]);\n    });\n\n    it('T13: batchSize=5 with 12 items processes in 3 batches', async () => {\n      let batchCount = 0;\n      const spy = vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n        const msg = args.join(' ');\n        if (msg.includes('[batch-processor] Processing batch')) batchCount++;\n      });\n\n      const items = Array.from({ length: 12 }, (_, i) => i);\n      const results = await processBatches(\n        items,\n        async (x: number) => x * 10,\n        5, 0\n      );\n\n      expect(results.length).toBe(12);\n      expect(batchCount).toBe(3);\n      expect(results[0]).toBe(0);\n      expect(results[11]).toBe(110);\n    });\n\n    it('T14: Empty items array returns empty results', async () => {\n      const results = await processBatches<number, number>([], async (x: number) => x, 5, 0);\n      expect(results).toEqual([]);\n    });\n\n    it('T15: Results preserve input order', async () => {\n      const items = [3, 1, 4, 1, 5, 9, 2, 6];\n      const results = await processBatches(\n        items,\n        async (x: number) => x * 100,\n        3, 0\n      );\n      expect(results).toEqual([300, 100, 400, 100, 500, 900, 200, 600]);\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     4. Callback / Processor Behavior\n  ════════════════════════════════════════════════════════════ */\n\n  describe('4. Callback / Processor Behavior', () => {\n    it('T16: processFn called for each item exactly once', async () => {\n      const seen: string[] = [];\n      const items = ['a', 'b', 'c', 'd'];\n      await processBatches(\n        items,\n        async (x: string) => { seen.push(x); return x.toUpperCase(); },\n        2, 0\n      );\n      expect(seen.sort()).toEqual(['a', 'b', 'c', 'd']);\n    });\n\n    it('T17: Error in processFn returns RetryErrorResult', async () => {\n      const items = [1, 2, 3];\n      const results = await processBatches(\n        items,\n        async (x: number) => {\n          if (x === 2) throw new Error('deliberate non-transient failure');\n          return x;\n        },\n        3, 0,\n        { maxRetries: 0 }\n      );\n      expect(results.length).toBe(3);\n      expect(results[0]).toBe(1);\n      expect(results[2]).toBe(3);\n      const errResult = results[1] as RetryFailure;\n      expect(errResult.retries_failed).toBe(true);\n      expect(errResult.error).toBeTruthy();\n      expect(errResult.item).toBe(2);\n    });\n\n    it('T18: Async processor results are properly awaited', async () => {\n      const results = await processBatches(\n        [10, 20],\n        async (x: number) => {\n          await new Promise<void>(r => setTimeout(r, 10));\n          return x + 5;\n        },\n        2, 0\n      );\n      expect(results).toEqual([15, 25]);\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     5. Edge Cases (processBatches)\n  ════════════════════════════════════════════════════════════ */\n\n  describe('5. Edge Cases (processBatches)', () => {\n    it('T19: Single item processed correctly', async () => {\n      const results = await processBatches(['only'], async (x: string) => x.length, 5, 0);\n      expect(results).toEqual([4]);\n    });\n\n    it('T20: batchSize larger than items count processes in 1 batch', async () => {\n      let batchCount = 0;\n      const spy = vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n        const msg = args.join(' ');\n        if (msg.includes('[batch-processor] Processing batch')) batchCount++;\n      });\n\n      const results = await processBatches([1, 2, 3], async (x: number) => x, 100, 0);\n\n      expect(results).toEqual([1, 2, 3]);\n      expect(batchCount).toBe(1);\n    });\n\n    it('T21: Very large batchSize (10000) with small array works', async () => {\n      const results = await processBatches([42], async (x: number) => x, 10000, 0);\n      expect(results).toEqual([42]);\n    });\n\n    it('T21b: overly large batchSize is clamped before running concurrent work', async () => {\n      const batchLogs: string[] = [];\n      vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n        const message = args.join(' ');\n        if (message.includes('[batch-processor] Processing batch')) {\n          batchLogs.push(message);\n        }\n      });\n      const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});\n\n      const items = Array.from({ length: MAX_BATCH_SIZE * 2 + 1 }, (_, index) => index);\n      const results = await processBatches(items, async (x: number) => x, MAX_BATCH_SIZE * 10, 0);\n\n      expect(results).toHaveLength(items.length);\n      expect(batchLogs).toHaveLength(3);\n      expect(warnSpy).toHaveBeenCalledWith(\n        `[batch-processor] Clamped batch size ${MAX_BATCH_SIZE * 10} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n      );\n    });\n\n    it('T22: Exact batch boundary (6 items / batchSize 3 = 2 batches)', async () => {\n      let batchCount = 0;\n      const spy = vi.spyOn(console, 'error').mockImplementation((...args: unknown[]) => {\n        const msg = args.join(' ');\n        if (msg.includes('[batch-processor] Processing batch')) batchCount++;\n      });\n\n      const results = await processBatches([1, 2, 3, 4, 5, 6], async (x: number) => x, 3, 0);\n\n      expect(results.length).toBe(6);\n      expect(batchCount).toBe(2);\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     6. processWithRetry\n  ════════════════════════════════════════════════════════════ */\n\n  describe('6. processWithRetry', () => {\n    it('T23: processWithRetry returns result on success', async () => {\n      const result = await processWithRetry(5, async (x: number) => x * 3);\n      expect(result).toBe(15);\n    });\n\n    it('T24: Non-transient error returns RetryErrorResult without retry', async () => {\n      const result = await processWithRetry(\n        'test',\n        async () => { throw new Error('permanent failure'); },\n        { maxRetries: 2, retryDelay: 1 }\n      ) as RetryFailure;\n      expect(result.retries_failed).toBe(true);\n      expect(result.error).toBeTruthy();\n      expect(result.item).toBe('test');\n    });\n\n    it('T25: maxRetries=0 means single attempt', async () => {\n      let attempts = 0;\n      const result = await processWithRetry(\n        'val',\n        async () => { attempts++; throw new Error('SQLITE_BUSY transient'); },\n        { maxRetries: 0, retryDelay: 1 }\n      ) as RetryFailure;\n      expect(attempts).toBe(1);\n      expect(result.retries_failed).toBe(true);\n    });\n\n    it('T26: DEFAULT_RETRY_OPTIONS has maxRetries=2, retryDelay=1000', () => {\n      expect(DEFAULT_RETRY_OPTIONS.maxRetries).toBe(2);\n      expect(DEFAULT_RETRY_OPTIONS.retryDelay).toBe(1000);\n    });\n\n    it('T26a: invalid maxRetries falls back to default without crashing', async () => {\n      let attempts = 0;\n      const result = await processWithRetry(\n        'retry',\n        async () => {\n          attempts++;\n          throw new Error('SQLITE_BUSY transient');\n        },\n        { maxRetries: -5, retryDelay: 0 }\n      ) as RetryFailure;\n      expect(attempts).toBe(DEFAULT_RETRY_OPTIONS.maxRetries + 1);\n      expect(result.retries_failed).toBe(true);\n    });\n\n    it('T26b: invalid retryDelay falls back to default and still completes', async () => {\n      const result = await processWithRetry(\n        1,\n        async () => {\n          throw new Error('permanent failure');\n        },\n        { maxRetries: 0, retryDelay: Number.NaN }\n      ) as RetryFailure;\n      expect(result.retries_failed).toBe(true);\n      expect(result.errorDetail).toContain('permanent failure');\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     7. processSequentially\n  ════════════════════════════════════════════════════════════ */\n\n  describe('7. processSequentially', () => {\n    it('T27: processSequentially processes items in strict order', async () => {\n      const order: number[] = [];\n      const items = [1, 2, 3, 4, 5];\n      const results = await processSequentially(\n        items,\n        async (x: number) => {\n          order.push(x);\n          return x * 2;\n        }\n      );\n      expect(order).toEqual([1, 2, 3, 4, 5]);\n      expect(results).toEqual([2, 4, 6, 8, 10]);\n    });\n\n    it('T28: processSequentially with empty array returns []', async () => {\n      const results = await processSequentially<number, number>([], async (x: number) => x);\n      expect(results).toEqual([]);\n    });\n\n    it('T29: processSequentially error in one item does not stop others', async () => {\n      const items = [1, 2, 3];\n      const results = await processSequentially(\n        items,\n        async (x: number) => {\n          if (x === 2) throw new Error('fail item 2');\n          return x;\n        },\n        { maxRetries: 0 }\n      );\n      expect(results.length).toBe(3);\n      expect(results[0]).toBe(1);\n      expect((results[1] as RetryFailure).retries_failed).toBe(true);\n      expect(results[2]).toBe(3);\n    });\n\n    it('T30: processSequentially with single item', async () => {\n      const results = await processSequentially([99], async (x: number) => x + 1);\n      expect(results).toEqual([100]);\n    });\n  });\n\n  /* ═══════════════════════════════════════════════════════════\n     8. Delay Behavior\n  ════════════════════════════════════════════════════════════ */\n\n  describe('8. Delay Behavior', () => {\n    it('T31: delayMs=0 does not add delay between batches', async () => {\n      const start = Date.now();\n      await processBatches([1, 2, 3, 4], async (x: number) => x, 2, 0);\n      const elapsed = Date.now() - start;\n      expect(elapsed).toBeLessThan(200);\n    });\n\n    it('T32: No delay after last batch (single batch case)', async () => {\n      const start = Date.now();\n      await processBatches([1, 2], async (x: number) => x, 2, 500);\n      const elapsed = Date.now() - start;\n      expect(elapsed).toBeLessThan(200);\n    });\n  });\n});","lineStart":1,"lineEnd":391,"totalLines":391,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/batch-processor.vitest.ts","time":{"start":1781718639897,"end":1781718639901}},"id":"prt_ed6b4e285001iPSCTSxyoR6JJE","sessionID":"ses_1294e112dffeF8UlfEsNhSrzCb","messageID":"msg_ed6b4a6080010TzFAPbAPQOHhS"}}
