{"type":"tool_use","timestamp":1780729368775,"sessionID":"ses_164436571ffe8MyT3INeMfMzFK","part":{"type":"tool","tool":"read","callID":"call_NmW8BoOS9vjFrZpUpfCfrkGp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","offset":1,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Idempotency-Key helper (CAURA-601).\n2: \n3: Per-route opt-in: handlers call :func:`idempotency_for` after auth\n4: has enforced the tenant, get back a :class:`IdempotencyGuard`, check\n5: ``guard.cached_replay`` for a cached response, and call\n6: ``guard.record(...)`` after running the work.\n7: \n8: Not a middleware — slowapi + FastAPI already handle the request/response\n9: pipeline, and per-handler wiring keeps the replay contract explicit at\n10: the route level. The boilerplate is five lines per decorated handler.\n11: \"\"\"\n12: \n13: from __future__ import annotations\n14: \n15: import asyncio\n16: import hashlib\n17: import logging\n18: from datetime import UTC, datetime, timedelta\n19: from typing import Any, Literal\n20: \n21: from fastapi import HTTPException, Request\n22: \n23: from core_api.clients.storage_client import get_storage_client\n24: from core_api.config import settings\n25: \n26: logger = logging.getLogger(__name__)\n27: \n28: IDEMPOTENCY_HEADER = \"Idempotency-Key\"\n29: # Matches Stripe's limit. Guards the `Text` column against oversized\n30: # values from buggy or adversarial clients before it reaches storage.\n31: MAX_IDEMPOTENCY_KEY_LEN = 255\n32: \n33: # Poll cadence + budget while waiting for a concurrent holder of the\n34: # same key to finish. Total wait =\n35: # ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n36: # enough to absorb a typical write pipeline (~2-5s end-to-end) without\n37: # holding the second request indefinitely; on timeout the caller gets\n38: # 409 and can retry.\n39: _CLAIM_POLL_INTERVAL_SECONDS = 0.5\n40: _CLAIM_POLL_MAX_ATTEMPTS = 20\n41: \n42: # Sentinels ``_poll_until_complete`` may return alongside the\n43: # completed row dict and ``None`` (budget exhausted):\n44: #\n45: # - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n46: #   or pending TTL elapsed). Caller can tell the client to retry as\n47: #   a fresh request.\n48: # - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n49: #   timeout, network). Caller should respond 503 — retrying into a\n50: #   downed cluster wastes the client's retry budget.\n51: _POLL_VANISHED = \"vanished\"\n52: _POLL_STORAGE_ERROR = \"storage_error\"\n53: \n54: # Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n55: # header is absent. ``Idempotency-Key`` (header) remains the\n56: # canonical form per the IETF draft; the body fallback exists for\n57: # SDK / load-test clients that can't easily set headers per request.\n58: # ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n59: # alias the loadtest harness uses.\n60: _IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n61: \n62: \n63: def idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n64:     \"\"\"Extract the idempotency key from a request body's ``metadata``\n65:     dict, if present. Returns ``None`` if metadata is missing/empty\n66:     or no recognised key field is set.\n67: \n68:     The header takes precedence — call this only as a fallback when\n69:     the header is absent. Routes that wire idempotency wire it once\n70:     via:\n71: \n72:         key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n73:     \"\"\"\n74:     if not metadata:\n75:         return None\n76:     for field in _IDEMPOTENCY_BODY_FIELDS:\n77:         value = metadata.get(field)\n78:         # Return the un-stripped value: ``idempotency_for`` hashes the\n79:         # RAW request bytes for replay-conflict detection, so any\n80:         # normalisation here would let two byte-identical retries —\n81:         # one with surrounding whitespace, one without — hit the same\n82:         # cache bucket but mismatch on body hash, triggering a false\n83:         # 422. The blank guard still rejects pure-whitespace values.\n84:         if isinstance(value, str) and value.strip():\n85:             return value\n86:     return None\n87: \n88: \n89: class IdempotencyGuard:\n90:     \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n91: \n92:     def __init__(\n93:         self,\n94:         tenant_id: str,\n95:         key: str,\n96:         request_hash: str,\n97:         cached: dict | None,\n98:     ) -> None:\n99:         self.tenant_id = tenant_id\n100:         self.key = key\n101:         self.request_hash = request_hash\n102:         self._cached = cached\n103: \n104:     @property\n105:     def cached_replay(self) -> tuple[Any, int] | None:\n106:         \"\"\"``(response_body, status_code)`` if the same key + body was\n107:         served before and is still within TTL; else ``None``.\"\"\"\n108:         if self._cached is None:\n109:             return None\n110:         return self._cached[\"response_body\"], self._cached[\"status_code\"]\n111: \n112:     async def record(self, response_body: Any, status_code: int = 200) -> None:\n113:         \"\"\"Cache the response body under this key. Failures are logged,\n114:         not raised — the client already has the live response; losing the\n115:         cache only costs a chance at future dedup.\"\"\"\n116:         expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n117:         try:\n118:             await get_storage_client().upsert_idempotency(\n119:                 tenant_id=self.tenant_id,\n120:                 idempotency_key=self.key,\n121:                 request_hash=self.request_hash,\n122:                 response_body=response_body,\n123:                 status_code=status_code,\n124:                 expires_at=expires_at.isoformat(),\n125:             )\n126:         except Exception:\n127:             logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n128: \n129: \n130: async def idempotency_for(\n\n(Showing lines 1-130 of 333. Use offset=131 to continue.)\n</content>","metadata":{"preview":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","text":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n\nfrom fastapi import HTTPException, Request\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\nIDEMPOTENCY_HEADER = \"Idempotency-Key\"\n# Matches Stripe's limit. Guards the `Text` column against oversized\n# values from buggy or adversarial clients before it reaches storage.\nMAX_IDEMPOTENCY_KEY_LEN = 255\n\n# Poll cadence + budget while waiting for a concurrent holder of the\n# same key to finish. Total wait =\n# ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n# enough to absorb a typical write pipeline (~2-5s end-to-end) without\n# holding the second request indefinitely; on timeout the caller gets\n# 409 and can retry.\n_CLAIM_POLL_INTERVAL_SECONDS = 0.5\n_CLAIM_POLL_MAX_ATTEMPTS = 20\n\n# Sentinels ``_poll_until_complete`` may return alongside the\n# completed row dict and ``None`` (budget exhausted):\n#\n# - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n#   or pending TTL elapsed). Caller can tell the client to retry as\n#   a fresh request.\n# - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n#   timeout, network). Caller should respond 503 — retrying into a\n#   downed cluster wastes the client's retry budget.\n_POLL_VANISHED = \"vanished\"\n_POLL_STORAGE_ERROR = \"storage_error\"\n\n# Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n# header is absent. ``Idempotency-Key`` (header) remains the\n# canonical form per the IETF draft; the body fallback exists for\n# SDK / load-test clients that can't easily set headers per request.\n# ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n# alias the loadtest harness uses.\n_IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n\n\ndef idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n    \"\"\"Extract the idempotency key from a request body's ``metadata``\n    dict, if present. Returns ``None`` if metadata is missing/empty\n    or no recognised key field is set.\n\n    The header takes precedence — call this only as a fallback when\n    the header is absent. Routes that wire idempotency wire it once\n    via:\n\n        key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n    \"\"\"\n    if not metadata:\n        return None\n    for field in _IDEMPOTENCY_BODY_FIELDS:\n        value = metadata.get(field)\n        # Return the un-stripped value: ``idempotency_for`` hashes the\n        # RAW request bytes for replay-conflict detection, so any\n        # normalisation here would let two byte-identical retries —\n        # one with surrounding whitespace, one without — hit the same\n        # cache bucket but mismatch on body hash, triggering a false\n        # 422. The blank guard still rejects pure-whitespace values.\n        if isinstance(value, str) and value.strip():\n            return value\n    return None\n\n\nclass IdempotencyGuard:\n    \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n\n    def __init__(\n        self,\n        tenant_id: str,\n        key: str,\n        request_hash: str,\n        cached: dict | None,\n    ) -> None:\n        self.tenant_id = tenant_id\n        self.key = key\n        self.request_hash = request_hash\n        self._cached = cached\n\n    @property\n    def cached_replay(self) -> tuple[Any, int] | None:\n        \"\"\"``(response_body, status_code)`` if the same key + body was\n        served before and is still within TTL; else ``None``.\"\"\"\n        if self._cached is None:\n            return None\n        return self._cached[\"response_body\"], self._cached[\"status_code\"]\n\n    async def record(self, response_body: Any, status_code: int = 200) -> None:\n        \"\"\"Cache the response body under this key. Failures are logged,\n        not raised — the client already has the live response; losing the\n        cache only costs a chance at future dedup.\"\"\"\n        expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n        try:\n            await get_storage_client().upsert_idempotency(\n                tenant_id=self.tenant_id,\n                idempotency_key=self.key,\n                request_hash=self.request_hash,\n                response_body=response_body,\n                status_code=status_code,\n                expires_at=expires_at.isoformat(),\n            )\n        except Exception:\n            logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n\n\nasync def idempotency_for(","lineStart":1,"lineEnd":130,"totalLines":333,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","time":{"start":1780729368758,"end":1780729368773}},"metadata":{"openai":{"itemId":"fc_0928b4fbbc96c2a2016a23c618b13081919819bc79e44169d0"}},"id":"prt_e9bbdd0b4001MpK70FMtR0ArWH","sessionID":"ses_164436571ffe8MyT3INeMfMzFK","messageID":"msg_e9bbdafd9001X7bb0s9Zupn51N"}}
