{"type":"tool_use","timestamp":1781761622494,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_TmJOYArEXifbj9NSrgWV6JCF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/context/caller-context.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/context/caller-context.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: MCP Caller Context\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { AsyncLocalStorage } from 'node:async_hooks';\n6: \n7: export interface MCPCallerContext {\n8:   /** Session identifier bound by the MCP transport layer on connection. */\n9:   readonly sessionId: string | null;\n10:   /** Transport type: 'stdio' | 'sse' | 'ws' | 'unknown'. */\n11:   readonly transport: 'stdio' | 'sse' | 'ws' | 'unknown';\n12:   /** Timestamp when the caller connected (ISO 8601). */\n13:   readonly connectedAt: string;\n14:   /** Process PID of the caller (if available from transport). */\n15:   readonly callerPid?: number;\n16:   /** Whether this caller is authorized for mutable maintenance operations. */\n17:   readonly trusted?: boolean;\n18:   /** Arbitrary transport-provided metadata. */\n19:   readonly metadata: Record<string, unknown>;\n20: }\n21: \n22: const storage = new AsyncLocalStorage<MCPCallerContext>();\n23: \n24: /** Run a callback inside a caller context. All downstream async operations see the context. */\n25: export function runWithCallerContext<T>(ctx: MCPCallerContext, fn: () => T): T {\n26:   return storage.run(ctx, fn);\n27: }\n28: \n29: /** Get the current caller context, or null if not inside a callerContext.run(). */\n30: export function getCallerContext(): MCPCallerContext | null {\n31:   return storage.getStore() ?? null;\n32: }\n33: \n34: /** Assert-style access — throws if no context. Use at MCP handler boundaries where context is guaranteed. */\n35: export function requireCallerContext(): MCPCallerContext {\n36:   const ctx = storage.getStore();\n37:   if (!ctx) {\n38:     throw new Error('MCP caller context missing — handler called outside runWithCallerContext()');\n39:   }\n40:   return ctx;\n41: }\n\n(End of file - total 41 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: MCP Caller Context\n// ───────────────────────────────────────────────────────────────\n\nimport { AsyncLocalStorage } from 'node:async_hooks';\n\nexport interface MCPCallerContext {\n  /** Session identifier bound by the MCP transport layer on connection. */\n  readonly sessionId: string | null;\n  /** Transport type: 'stdio' | 'sse' | 'ws' | 'unknown'. */\n  readonly transport: 'stdio' | 'sse' | 'ws' | 'unknown';\n  /** Timestamp when the caller connected (ISO 8601). */\n  readonly connectedAt: string;\n  /** Process PID of the caller (if available from transport). */\n  readonly callerPid?: number;\n  /** Whether this caller is authorized for mutable maintenance operations. */\n  readonly trusted?: boolean;\n  /** Arbitrary transport-provided metadata. */\n  readonly metadata: Record<string, unknown>;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/context/caller-context.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: MCP Caller Context\n// ───────────────────────────────────────────────────────────────\n\nimport { AsyncLocalStorage } from 'node:async_hooks';\n\nexport interface MCPCallerContext {\n  /** Session identifier bound by the MCP transport layer on connection. */\n  readonly sessionId: string | null;\n  /** Transport type: 'stdio' | 'sse' | 'ws' | 'unknown'. */\n  readonly transport: 'stdio' | 'sse' | 'ws' | 'unknown';\n  /** Timestamp when the caller connected (ISO 8601). */\n  readonly connectedAt: string;\n  /** Process PID of the caller (if available from transport). */\n  readonly callerPid?: number;\n  /** Whether this caller is authorized for mutable maintenance operations. */\n  readonly trusted?: boolean;\n  /** Arbitrary transport-provided metadata. */\n  readonly metadata: Record<string, unknown>;\n}\n\nconst storage = new AsyncLocalStorage<MCPCallerContext>();\n\n/** Run a callback inside a caller context. All downstream async operations see the context. */\nexport function runWithCallerContext<T>(ctx: MCPCallerContext, fn: () => T): T {\n  return storage.run(ctx, fn);\n}\n\n/** Get the current caller context, or null if not inside a callerContext.run(). */\nexport function getCallerContext(): MCPCallerContext | null {\n  return storage.getStore() ?? null;\n}\n\n/** Assert-style access — throws if no context. Use at MCP handler boundaries where context is guaranteed. */\nexport function requireCallerContext(): MCPCallerContext {\n  const ctx = storage.getStore();\n  if (!ctx) {\n    throw new Error('MCP caller context missing — handler called outside runWithCallerContext()');\n  }\n  return ctx;\n}","lineStart":1,"lineEnd":41,"totalLines":41,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/context/caller-context.ts","time":{"start":1781761622460,"end":1781761622493}},"metadata":{"openai":{"itemId":"fc_0b79422767f6482d016a3386564d508191a52c0d4669b6d2a7"}},"id":"prt_ed944c190001pr0WuvZG4hcy16","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed9448635001cOLl8FC4vTwASI"}}
