epair error: ${results.checkpointRepair.error}`);\n1422:   }\n1423:   if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n1424:     hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n1425:   }\n1426:   if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n1427:     hints.push('All files already up-to-date. Use force: true to re-index');\n1428:   }\n1429: \n1430:   await releaseScanLease();\n1431: \n1432:   recordMaintenanceRun('memory_index_scan', {\n1433:     status: 'success',\n1434:     counts: {\n1435:       scanned: results.scanned,\n1436:       indexed: results.indexed,\n1437:       updated: results.updated,\n1438:       unchanged: results.unchanged,\n1439:       failed: results.failed,\n1440:       staleDeleted: results.staleDeleted,\n1441:       staleDeleteFailed: results.staleDeleteFailed,\n1442:       orphanSwept: results.orphanSwept,\n1443:     },\n1444:     staleCandidates: filesToDelete.length,\n1445:   });\n1446: \n1447:   return createMCPSuccessResponse({\n1448:     tool: 'memory_index_scan',\n1449:     summary,\n1450:     data: {\n1451:       status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n1452:       ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n1453:       scanKey,\n1454:       batchSize: scanBatchSize,\n1455:       ...results,\n1456:       ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n1457:         ? {\n1458:             _debug_fileCounts: {\n1459:               constitutionalFiles: constitutionalFiles.length,\n1460:               specDocFiles: specDocFiles.length,\n1461:               totalFiles: files.length,\n1462:               mergedFiles: mergedFiles.length,\n1463:               dedupSkipped: dedupDuplicatesSkipped,\n1464:               includeSpecDocs: include_spec_docs,\n1465:               workspacePath,\n1466:             },\n1467:           }\n1468:         : {})\n1469:     },\n1470:     hints\n1471:   });\n1472:   } finally {\n1473:     if (leaseHeartbeat) {\n1474:       clearInterval(leaseHeartbeat);\n1475:       leaseHeartbeat = null;\n1476:     }\n1477:     if (loopLagTimer) {\n1478:       clearInterval(loopLagTimer);\n1479:       loopLagTimer = null;\n1480:       console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n1481:     }\n1482:     await releaseScanLease();\n1483:   }\n1484: }\n1485: \n1486: /** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n1487:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1488: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1489:   if (!args.background) {\n1490:     return runIndexScan(args, {});\n1491:   }\n1492: \n1493:   const jobId = createJobId();\n1494:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1495: \n1496:   setImmediate(() => {\n1497:     void (async () => {\n1498:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1499:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1500:       // background-embedding queue draining this scan's deferred embeddings can\n1501:       // keep it held past the scan itself.\n1502:       const maintenance = beginMaintenance('index_scan');\n1503:       try {\n1504:         await setJobState(jobId, 'running');\n1505:         const response = await runIndexScan(args, {\n1506:           isCancelled: () => isCancelRequestedFast(jobId),\n1507:           onPhase: (phase) => {\n1508:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1509:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1510:             maintenance.refresh();\n1511:             void setJobPhase(jobId, phase).catch(() => {});\n1512:           },\n1513:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1514:         });\n1515:         const scanData = extractEnvelopeData(response);\n1516:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1517:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1518:         if (wasCancelled) {\n1519:           // The run itself short-circuited on cancellation. A cancel that arrives\n1520:           // after the scan already finished does not retroactively cancel it.\n1521:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1522:         } else if (response.isError === true) {\n1523:           // An error envelope (not a thrown error) still means the scan failed.\n1524:           await appendJobError(jobId, '__scan__', scanData);\n1525:           await setJobState(jobId, 'failed');\n1526:         } else {\n1527:           await completeJob(jobId, { state: 'complete', result: scanData });\n1528:         }\n1529:       } catch (error: unknown) {\n1530:         try {\n1531:           await appendJobError(jobId, '__job__', error);\n1532:           await setJobState(jobId, 'failed');\n1533:         } catch (_secondaryError: unknown) {\n1534:           // Best-effort failure record; never surface a background unhandled rejection.\n1535:         }\n1536:       } finally {\n1537:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1538:         // Release this scan's hold; the marker stays present only while the\n1539:         // background-embedding queue still holds it.\n1540:         maintenance.end();\n1541:       }\n1542:     })();\n1543:   });\n1544: \n1545:   return createMCPSuccessResponse({\n1546:     tool: 'memory_index_scan',\n1547:     summary: `Queued background index scan ${jobId}`,\n1548:     data: { jobId, state: 'queued', background: true },\n1549:     hints: [\n1550:       'Use memory_index_scan_status with jobId to poll progress',\n1551:       '