7dab920f2183016a5dcae4ba0c8191a0bf212465b1101f"}},"id":"prt_f7e608db6001wez0WvM30nzN2X","sessionID":"ses_08202bafbffe7aMYl1BZMs5SAo","messageID":"msg_f7e606674001SZhCELK3Hr9yj9"}}
{"type":"tool_use","timestamp":1784531684814,"sessionID":"ses_08202bafbffe7aMYl1BZMs5SAo","part":{"type":"tool","tool":"read","callID":"call_VxD9aRLJsjL4miZ5tSOLtEHU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/research.md","offset":1,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/research.md</path>\n<type>file</type>\n<content>\n1: # Hallmark Design Skill Reuse Research\n2: \n3: ## 1. Executive Verdict\n4: \n5: Hallmark is valuable as a source of granular quality probes, structural reasoning patterns, and compact design-DNA vocabulary, but it should not replace sk-design or become a preset catalog. The highest-value path is clean-room adaptation into the existing Interface, Foundations, Motion, Audit, and MD-GENERATOR owners. No standalone redesign, variant, study, theme, chart, tactile, imagery, or preview command is justified.\n6: \n7: The strongest immediate adoptions are: correct Interface's hero/media and authored-depth contracts; add multi-page locks/deltas; add selected evidence-backed Audit probes; add a provider-neutral asset receipt; expose measured provenance and Motion in MD-GENERATOR; strengthen semantic motion/interruption/async proof; and add fallback-font metrics plus target-derived responsive verification.\n8: \n9: Hallmark's curated themes can complement the 1,290-bundle extracted corpus only as independently authored, post-selection explanation or evaluation lenses. They must never select taste, emit values, bypass source rights, or become bundles/presets.\n10: \n11: ## 2. Licensing Verdict\n12: \n13: Hallmark is MIT-licensed. The checked-in license permits use, copying, modification, merging, publication, distribution, sublicensing, and sale, but requires the copyright and permission notice in all copies or substantial portions. It is supplied without warranty. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/external/hallmark/LICENSE:1-20]\n14: \n15: Practical verdict:\n16: \n17: - `COPY` is legally available, but no direct-copy candidate is recommended by this research.\n18: - `ADAPT` and `LEARN` should normally use independently authored sk-design terminology and preserve stronger native contracts.\n19: - Copying substantial Hallmark prose, tables, schemas, examples, code, recipes, catalogs, or assets requires the Hallmark MIT notice.\n20: - Hallmark's MIT license does not establish rights for hosted imagery, third-party quotations, fonts, logos, reference sites, or generated outputs. Those require separate provenance and rights evidence.\n21: - The meaning of \"substantial portions\" and final repository notice placement require owner/counsel confirmation; this is source-text analysis, not legal advice.\n22: \n23: ## 3. Method And Coverage\n24: \n25: The loop ran ten forced-depth iterations. It inspected Hallmark's license, README, ROADMAP, core skill, 24 root references, two nested verb packets, four genre files, four detailed theme files plus the twenty-name catalog, 21 macrostructure leaves, and 50 component leaves. It compared those assets with the shipped sk-design hub, five mode packets, `/interface:*` commands, Audit registries/checklists, MD-GENERATOR v3 schema and backend, and the exact 1,290-bundle styles corpus. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/iterations/iteration-001.md:27-55] [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/iterations/iteration-010.md:3-7]\n26: \n27: ## 4. Verb-To-Mode Mapping\n28: \n29: | Hallmark behavior | sk-design owner | Conclusion |\n30: |---|---|---|\n31: | Default `build` | Interface + Foundations | Existing owner is stronger; adapt selected structural and verification heuristics. |\n32: | `audit` | Audit | Keep shipped evidence/P0-P3 contract; add selected granular probes, not all 58 gates. |\n33: | `study` | MD-GENERATOR + `/interface:design-reference` | Keep measured extract-write-validate authority; add bounded provenance/structure/Motion projections. |\n34: | `redesign` | Existing `/interface:design` redesign lane | Equivalent already exists; strengthen multi-surface scope and shared-system locks/deltas. |\n35: | Motion/microinteractions | Motion + Foundations/shared token contracts | Add semantic motion character and proof propagation; reject named-theme multipliers. |\n36: \n37: ## 5. Reuse And Learning Matrix\n38: \n39: | Hallmark asset | sk-design target | Verdict | Specific concrete change | Value | Effort | Licensing treatment |\n40: |---|---|---|---|---|---|---|\n41: | `LICENSE` | Repository third-party notices and reused target provenance | LEARN | Treat MIT as reuse authority; retain copyright and permission notice for copies/substantial portions | Critical | Low | Notice required for substantial copied expression |\n42: | `README.md` | Research/decision record only | SKIP | Do not treat \"use it, fork it, ship it\" as the license contract | High risk avoided | None | `LICENSE` controls |\n43: | `skills/hallmark/SKILL.md` route | `design-interface/SKILL.md`; `/interface:design` | LEARN | Preserve load-by-job and index-then-pick efficiency while keeping the five-mode router | Medium | Low | Clean-room routing language |\n44: | `anti-patterns.md` | `design-audit/assets/ai-fingerprint-registry.json`; `references/ai-fingerprint-tells.md` | ADAPT | Add only evidence-backed structural/chrome/content tells with exceptions, owner, and P0-P3 impact | High | Medium | Independent wording; copied entries/tables require notice |\n45: | `assets.md` | Interface preflight; `shared/sk-code-handoff.md` | ADAPT | Add provider-neutral asset origin/rights/hosting/accessibility receipt | High | Medium | Verify provider/asset rights separately |\n46: | `color.md` | Foundations palette reference and token starter | ADAPT | Keep canonical roles opaque; model alpha only in named overlay/scrim/shadow roles | Medium | Low | No palette recipe copying |\n47: | `component-cookbook.md` index | Interface wireframe and variation procedures | LEARN | Separate whole-page shape from section-role decisions; no reusable chooser | High | Low | Do not copy tables, codes, sketches, or recipes |\n48: | `contract.md` | `shared/sk-code-handoff.md` | ADAPT | Record stylesheet entrypoints/import directives and explicit rewrite permission | Medium-high | Low | Independent wording |\n49: | `copy.md` | Interface copy reference and preflight | LEARN | Add measured-latency loading/status copy while retaining cause/recovery semantics | Medium-high | Low | Do not copy attributed voice samples |\n50: | `custom-craft.md` | Interface real-UI loop and preflight | ADAPT | Permit brief-grounded CSS/SVG only with semantic, fallback, cost, motion, and render proof | High | Medium | No recipe/vendor/support-table copy |\n51: | `custom-theme.md` | Interface aesthetic-direction and real-UI loop | ADAPT | Distinguish precedent-grounded, authored-tuned, and authored-bespoke depth; label authored values | Very high | Medium | Native labels; no catalog values/stamps |\n52: | `design-md.md` schema | `/interface:design-reference`; MD-GENERATOR v3 schema | SKIP | Keep uppercase measured `DESIGN.md`; use a distinct artifact for authored systems | Critical boundary | None | Notice if substantial format text is copied |\n53: | `export-formats.md` | Optional MD-GENERATOR post-validate exporter | INSPIRE-NEW | Emit separate traceable DTCG/shadcn outputs with omission diagnostics | Medium-high | Medium | Implement standards independently |\n54: | `floating-nav.md` | Interface prototype-flow and preflight | LEARN | Add geometry/property ownership, input, reduced-motion, and performance proof for morphs | Medium | Low-medium | Do not copy exact CSS/timing/shadow recipes |\n55: | `hero-enrichment.md` | Interface preflight and aesthetic direction | ADAPT | Replace mandatory imagery with a brief-grounded signature-role decision and deletion test | Very high | Low-medium | No archetype catalog copy; media rights separate |\n56: | `imagery-kit.md` | Interface real-UI loop; shared creation contract | INSPIRE-NEW | Optional owned-asset manifest with stable URI, rights, dimensions, role, and fallback | Medium-high | Medium | Never hotlink/redistribute Hallmark-hosted binaries |\n57: | `interaction-and-states.md` | Motion interaction-state procedure/cards; Interface preflight | LEARN | Enumerate applicable states or explicit N/A; retain events/guards/recovery | Medium-high | Low | Do not copy fixed eight-state/CSS recipes |\n58: | `layout-and-space.md` | Foundations responsive/adaptation references | LEARN | Keep target/content/input/posture model and require narrow-context transformation | Medium | Low | No fixed-width recipes |\n59: | `macrostructures.md` index | Interface wireframe and variation procedures | LEARN | Commit a subject-grounded whole-page composition before component styling | High | Low | Do not copy 21-name chooser/table |\n60: | `microinteractions.md` | Motion pattern cards; Interface preflight | ADAPT | Propagate interruption/reversal/retrigger and safe async feedback checks | High | Low-medium | Use target-derived values |\n61: | `motion.md` | Motion strategy; shared token vocabulary; Foundations artifact contract | ADAPT | Define semantic motion character and role tokens; Motion owns behavior and values | High | Medium | No timing/curve/multiplier/token-block copy |\n62: | `preview-examples.md` | Existing Interface presentation/proof | SKIP | Test existing fields; do not create preview or preset catalogs | Low incremental | None | Copying examples requires notice |\n63: | `responsive.md` | Foundations responsive/adaptation; Interface preflight | ADAPT | Add target-derived viewport/input/orientation/zoom/content-risk proof matrix | High | Medium | Independent matrix |\n64: | `slop-test.md` 58 checks | Audit registry, production hardening, edge cases, fixtures | ADAPT | Promote precise probes only; retain hypothesis posture, evidence labels, P0-P3 | High | Medium-high | No wholesale gate copy |\n65: | `structure.md` six axes | Interface variation/wireframe procedures | ADAPT | Add independently worded structural-completeness prompts | High | Low | Copying the axis table requires notice |\n66: | `study.md` diagnosis schema | MD-GENERATOR report/types; `/interface:design-reference` | ADAPT | Add measured-neutral provenance, composition, and region summaries; label inference | High | Medium-high | No Hallmark enums/templates |\n67: | `typography.md` | Foundations typography and token starter | ADAPT | Add source/rights/weights and fallback metric override proof | High | Low | No font catalog/pairing copy |\n68: | `verbs/audit.md` | `/interface:audit`; Audit contract | LEARN | Keep shipped evidence/impact/owner schema and severity; absorb granular probes only | High | Low | No report/severity copy |\n69: | `verbs/redesign.md` | `/interface:design` redesign lane and intake | ADAPT | Add single- vs multi-surface scope and shared-system locks/deltas | Very high | Low | No new command |\n70: | Four genre guides | Optional post-retrieval Interface explanatory lens | LEARN | Use independently authored evidence labels only after rights-gated mode selection | Medium | High | Do not reuse names/fixtures/rules as selectors |\n71: | Twenty-name theme catalog | No generation target; optional evaluation experiment | SKIP | Do not ingest names, token combinations, or selector behavior | High risk avoided | None | Direct reuse requires notice and ingredient-rights review |\n72: | Four detailed theme files | Evaluation fixtures only if independently authored | SKIP | Do not import rich theme specifications | Low | None | No copy |\n73: | 21 macrostructure leaves | Interface wireframe/variation procedures | LEARN | Use as evidence that whole-page composition must be explicit; generate target-specific alternatives | High method value | Low | Do not copy names, prose, diagrams, or recipes |\n74: | 9 hero leaves | Interface signature-role and wireframe procedures | LEARN | Generate a brief-specific hero role; typography-only may pass | High | Low | No leaf copy |\n75: | 5 section-head leaves | Interface variation procedures | LEARN | Test heading/body relationship and narrow collapse | Medium | Low | No leaf copy |\n76: | 6 feature leaves | Interface variation; Foundations responsive proof | LEARN | Vary section composition without a fixed feature preset | Medium | Low | No leaf copy |\n77: | 4 CTA leaves | Interface copy/preflight | LEARN | Choose action treatment from task hierarchy and state evidence | Medium | Low | No leaf copy |\n78: | 4 testimonial/proof leaves | Interface copy/mock data; Audit content integrity | ADAPT | Require sourced proof; never fabricate metrics/logos/quotes | High | Low | Quote/logo rights separate |\n79: | 8 footer leaves | Interface wireframe; Audit fingerprint registry | ADAPT | Detect generic sitemap footer as hypothesis; choose structure from site role | High | Medium | No catalog/routing-table copy |\n80: | 14 navigation leaves | Interface wireframe; Audit fingerprint registry | ADAPT | Detect genre-blind SaaS nav as hypothesis; preserve actual information architecture | High | Medium | No catalog/routing-table copy |\n81: | ROADMAP Nanobanana hook | Interface native-image branch + selected external transport | ADAPT | Provider-neutral gated generation plus asset receipt | High when image-led | Medium | Current terms, secrets, cost, input/output rights required |\n82: | ROADMAP `Plate` | None | SKIP | Derive image role per brief; no image-led preset | Negative | None | No copy |\n83: | ROADMAP brand-first flow | Interface-led new authored artifact; Foundations tokens | INSPIRE-NEW | Persist a validated authored system distinct from measured `DESIGN.md` | Very high | High | Prefer native schema; imagery rights separate |\n84: | ROADMAP theme-aware motion | Shared token vocabulary; Foundations starter; Motion strategy | ADAPT | Semantic character/rationale with target-derived values | High | Medium | No theme labels/multipliers copied |\n85: | ROADMAP variant | Existing `/interface:design` directions lane | SKIP | Verify structural deltas; no alias or new command | High duplication avoided | Low | No copy |\n86: | ROADMAP structural cookbook | Interface wireframe/variation procedure | ADAPT | Optional abstract brief-bound decision card, never implementation catalog | Medium-high | Medium | Independently author; no sketches/HTML copy |\n87: | ROADMAP tactile rebellion | Interface aesthetic direction and preflight | ADAPT | Controlled-imperfection check with brief evidence and bounded roles | Medium | Low-medium | Texture rights/receipt required |\n88: | ROADMAP charts | Foundations data-viz; Audit production checks | ADAPT | Add evidence-based 3D/perspective and dual-axis cautions | Medium | Low | Independent wording |\n89: | ROADMAP multi-page coherence | Interface real-UI loop; shared handoff | ADAPT | Explicit site locks versus page deltas | Very high | Low-medium | Clean-room concept |\n90: | ROADMAP project-path study | `/interface:design-reference`; extraction adapter | INSPIRE-NEW | Guarded project launcher resolves canonical render; segregate static evidence | High | High | Security/source attestation required |\n91: | ROADMAP explain | Existing Interface proof/presentation | SKIP | Add nothing unless fixtures reveal missing rationale | Medium | None-low | No copy |\n92: | ROADMAP negative capability | Audit registry/tells; shared cognitive laws | ADAPT | Optional evidence-backed perceptual cause and user impact | High | Low-medium | No invented rationale or prose copy |\n93: | ROADMAP emotion-first prompting | Interface brief-to-dials and aesthetic direction | LEARN | Capture desired/avoided audience feeling and translate through evidence | Medium-high | Low | No emotion theme/chooser |\n94: | ROADMAP sound policy | Motion microinteractions; Audit accessibility/performance | ADAPT | Require purpose, user control, alternate channel, frequency, and rights proof | Medium-high for audio products | Low-medium | Audio rights/provenance separate |\n95: | ROADMAP haptics | Future target-specific Motion reference only | SKIP | Reopen only for a named runtime/API/product/device matrix | Unknown | Unknown | Privacy, permission, accessible fallback required |\n96: | ROADMAP live-preview MCP | Existing Open Design preview, MD-GENERATOR proof, browser inspection | SKIP | At most normalize a read-only receipt after measured user pain | Low incremental | None-low | Sandbox untrusted renders; transport never owns acceptance |\n97: \n98: ## 6. Audit Findings\n99: \n100: Hallmark's current slop checklist contains 58 checks: integer gates 1-57 plus gate `38a`; the README's 57 count is stale. Shipped Audit should keep its stronger evidence labels, user-impact severity, owner routing, and five-dimension scoring. The useful additions are selected structural fingerprints, fabricated-content/fake-chrome checks, input geometry, wrapped-affordance checks, intrinsic grid/long-word/section-head probes, and sticky/focus interaction edge cases. Every promoted tell needs positive, clean, and legitimate-exception fixtures. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/iterations/iteration-002.md:14-57]\n\n(Showing lines 1-100 of 203. Use offset=101 to continue.)\n</content>","metadata":{"preview":"# Hallmark Design Skill Reuse Research\n\n## 1. Executive Verdict\n\nHallmark is valuable as a source of granular quality probes, structural reasoning patterns, and compact design-DNA vocabulary, but it should not replace sk-design or become a preset catalog. The highest-value path is clean-room adaptation into the existing Interface, Foundations, Motion, Audit, and MD-GENERATOR owners. No standalone redesign, variant, study, theme, chart, tactile, imagery, or preview command is justified.\n\nThe strongest immediate adoptions are: correct Interface's hero/media and authored-depth contracts; add multi-page locks/deltas; add selected evidence-backed Audit probes; add a provider-neutral asset receipt; expose measured provenance and Motion in MD-GENERATOR; strengthen semantic motion/interruption/async proof; and add fallback-font metrics plus target-derived responsive verification.\n\nHallmark's curated themes can complement the 1,290-bundle extracted corpus only as independently authored, post-selection explanation or evaluation lenses. They must never select taste, emit values, bypass source rights, or become bundles/presets.\n\n## 2. Licensing Verdict\n\nHallmark is MIT-licensed. The checked-in license permits use, copying, modification, merging, publication, distribution, sublicensing, and sale, but requires the copyright and permission notice in all copies or substantial portions. It is supplied without warranty. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/external/hallmark/LICENSE:1-20]\n\nPractical verdict:\n\n- `COPY` is legally available, but no direct-copy candidate is recommended by this research.\n- `ADAPT` and `LEARN` should normally use independently authored sk-design terminology and preserve stronger native contracts.\n- Copying substantial Hallmark prose, tables, schemas, examples, code, recipes, catalogs, or assets requires the Hallmark MIT notice.\n- Hallmark's MIT license does not establish rights for hosted imagery, third-party quotations, fonts, logos, reference sites, or generated outputs. Those require separate provenance and rights evidence.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/research.md","text":"# Hallmark Design Skill Reuse Research\n\n## 1. Executive Verdict\n\nHallmark is valuable as a source of granular quality probes, structural reasoning patterns, and compact design-DNA vocabulary, but it should not replace sk-design or become a preset catalog. The highest-value path is clean-room adaptation into the existing Interface, Foundations, Motion, Audit, and MD-GENERATOR owners. No standalone redesign, variant, study, theme, chart, tactile, imagery, or preview command is justified.\n\nThe strongest immediate adoptions are: correct Interface's hero/media and authored-depth contracts; add multi-page locks/deltas; add selected evidence-backed Audit probes; add a provider-neutral asset receipt; expose measured provenance and Motion in MD-GENERATOR; strengthen semantic motion/interruption/async proof; and add fallback-font metrics plus target-derived responsive verification.\n\nHallmark's curated themes can complement the 1,290-bundle extracted corpus only as independently authored, post-selection explanation or evaluation lenses. They must never select taste, emit values, bypass source rights, or become bundles/presets.\n\n## 2. Licensing Verdict\n\nHallmark is MIT-licensed. The checked-in license permits use, copying, modification, merging, publication, distribution, sublicensing, and sale, but requires the copyright and permission notice in all copies or substantial portions. It is supplied without warranty. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/external/hallmark/LICENSE:1-20]\n\nPractical verdict:\n\n- `COPY` is legally available, but no direct-copy candidate is recommended by this research.\n- `ADAPT` and `LEARN` should normally use independently authored sk-design terminology and preserve stronger native contracts.\n- Copying substantial Hallmark prose, tables, schemas, examples, code, recipes, catalogs, or assets requires the Hallmark MIT notice.\n- Hallmark's MIT license does not establish rights for hosted imagery, third-party quotations, fonts, logos, reference sites, or generated outputs. Those require separate provenance and rights evidence.\n- The meaning of \"substantial portions\" and final repository notice placement require owner/counsel confirmation; this is source-text analysis, not legal advice.\n\n## 3. Method And Coverage\n\nThe loop ran ten forced-depth iterations. It inspected Hallmark's license, README, ROADMAP, core skill, 24 root references, two nested verb packets, four genre files, four detailed theme files plus the twenty-name catalog, 21 macrostructure leaves, and 50 component leaves. It compared those assets with the shipped sk-design hub, five mode packets, `/interface:*` commands, Audit registries/checklists, MD-GENERATOR v3 schema and backend, and the exact 1,290-bundle styles corpus. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/iterations/iteration-001.md:27-55] [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/iterations/iteration-010.md:3-7]\n\n## 4. Verb-To-Mode Mapping\n\n| Hallmark behavior | sk-design owner | Conclusion |\n|---|---|---|\n| Default `build` | Interface + Foundations | Existing owner is stronger; adapt selected structural and verification heuristics. |\n| `audit` | Audit | Keep shipped evidence/P0-P3 contract; add selected granular probes, not all 58 gates. |\n| `study` | MD-GENERATOR + `/interface:design-reference` | Keep measured extract-write-validate authority; add bounded provenance/structure/Motion projections. |\n| `redesign` | Existing `/interface:design` redesign lane | Equivalent already exists; strengthen multi-surface scope and shared-system locks/deltas. |\n| Motion/microinteractions | Motion + Foundations/shared token contracts | Add semantic motion character and proof propagation; reject named-theme multipliers. |\n\n## 5. Reuse And Learning Matrix\n\n| Hallmark asset | sk-design target | Verdict | Specific concrete change | Value | Effort | Licensing treatment |\n|---|---|---|---|---|---|---|\n| `LICENSE` | Repository third-party notices and reused target provenance | LEARN | Treat MIT as reuse authority; retain copyright and permission notice for copies/substantial portions | Critical | Low | Notice required for substantial copied expression |\n| `README.md` | Research/decision record only | SKIP | Do not treat \"use it, fork it, ship it\" as the license contract | High risk avoided | None | `LICENSE` controls |\n| `skills/hallmark/SKILL.md` route | `design-interface/SKILL.md`; `/interface:design` | LEARN | Preserve load-by-job and index-then-pick efficiency while keeping the five-mode router | Medium | Low | Clean-room routing language |\n| `anti-patterns.md` | `design-audit/assets/ai-fingerprint-registry.json`; `references/ai-fingerprint-tells.md` | ADAPT | Add only evidence-backed structural/chrome/content tells with exceptions, owner, and P0-P3 impact | High | Medium | Independent wording; copied entries/tables require notice |\n| `assets.md` | Interface preflight; `shared/sk-code-handoff.md` | ADAPT | Add provider-neutral asset origin/rights/hosting/accessibility receipt | High | Medium | Verify provider/asset rights separately |\n| `color.md` | Foundations palette reference and token starter | ADAPT | Keep canonical roles opaque; model alpha only in named overlay/scrim/shadow roles | Medium | Low | No palette recipe copying |\n| `component-cookbook.md` index | Interface wireframe and variation procedures | LEARN | Separate whole-page shape from section-role decisions; no reusable chooser | High | Low | Do not copy tables, codes, sketches, or recipes |\n| `contract.md` | `shared/sk-code-handoff.md` | ADAPT | Record stylesheet entrypoints/import directives and explicit rewrite permission | Medium-high | Low | Independent wording |\n| `copy.md` | Interface copy reference and preflight | LEARN | Add measured-latency loading/status copy while retaining cause/recovery semantics | Medium-high | Low | Do not copy attributed voice samples |\n| `custom-craft.md` | Interface real-UI loop and preflight | ADAPT | Permit brief-grounded CSS/SVG only with semantic, fallback, cost, motion, and render proof | High | Medium | No recipe/vendor/support-table copy |\n| `custom-theme.md` | Interface aesthetic-direction and real-UI loop | ADAPT | Distinguish precedent-grounded, authored-tuned, and authored-bespoke depth; label authored values | Very high | Medium | Native labels; no catalog values/stamps |\n| `design-md.md` schema | `/interface:design-reference`; MD-GENERATOR v3 schema | SKIP | Keep uppercase measured `DESIGN.md`; use a distinct artifact for authored systems | Critical boundary | None | Notice if substantial format text is copied |\n| `export-formats.md` | Optional MD-GENERATOR post-validate exporter | INSPIRE-NEW | Emit separate traceable DTCG/shadcn outputs with omission diagnostics | Medium-high | Medium | Implement standards independently |\n| `floating-nav.md` | Interface prototype-flow and preflight | LEARN | Add geometry/property ownership, input, reduced-motion, and performance proof for morphs | Medium | Low-medium | Do not copy exact CSS/timing/shadow recipes |\n| `hero-enrichment.md` | Interface preflight and aesthetic direction | ADAPT | Replace mandatory imagery with a brief-grounded signature-role decision and deletion test | Very high | Low-medium | No archetype catalog copy; media rights separate |\n| `imagery-kit.md` | Interface real-UI loop; shared creation contract | INSPIRE-NEW | Optional owned-asset manifest with stable URI, rights, dimensions, role, and fallback | Medium-high | Medium | Never hotlink/redistribute Hallmark-hosted binaries |\n| `interaction-and-states.md` | Motion interaction-state procedure/cards; Interface preflight | LEARN | Enumerate applicable states or explicit N/A; retain events/guards/recovery | Medium-high | Low | Do not copy fixed eight-state/CSS recipes |\n| `layout-and-space.md` | Foundations responsive/adaptation references | LEARN | Keep target/content/input/posture model and require narrow-context transformation | Medium | Low | No fixed-width recipes |\n| `macrostructures.md` index | Interface wireframe and variation procedures | LEARN | Commit a subject-grounded whole-page composition before component styling | High | Low | Do not copy 21-name chooser/table |\n| `microinteractions.md` | Motion pattern cards; Interface preflight | ADAPT | Propagate interruption/reversal/retrigger and safe async feedback checks | High | Low-medium | Use target-derived values |\n| `motion.md` | Motion strategy; shared token vocabulary; Foundations artifact contract | ADAPT | Define semantic motion character and role tokens; Motion owns behavior and values | High | Medium | No timing/curve/multiplier/token-block copy |\n| `preview-examples.md` | Existing Interface presentation/proof | SKIP | Test existing fields; do not create preview or preset catalogs | Low incremental | None | Copying examples requires notice |\n| `responsive.md` | Foundations responsive/adaptation; Interface preflight | ADAPT | Add target-derived viewport/input/orientation/zoom/content-risk proof matrix | High | Medium | Independent matrix |\n| `slop-test.md` 58 checks | Audit registry, production hardening, edge cases, fixtures | ADAPT | Promote precise probes only; retain hypothesis posture, evidence labels, P0-P3 | High | Medium-high | No wholesale gate copy |\n| `structure.md` six axes | Interface variation/wireframe procedures | ADAPT | Add independently worded structural-completeness prompts | High | Low | Copying the axis table requires notice |\n| `study.md` diagnosis schema | MD-GENERATOR report/types; `/interface:design-reference` | ADAPT | Add measured-neutral provenance, composition, and region summaries; label inference | High | Medium-high | No Hallmark enums/templates |\n| `typography.md` | Foundations typography and token starter | ADAPT | Add source/rights/weights and fallback metric override proof | High | Low | No font catalog/pairing copy |\n| `verbs/audit.md` | `/interface:audit`; Audit contract | LEARN | Keep shipped evidence/impact/owner schema and severity; absorb granular probes only | High | Low | No report/severity copy |\n| `verbs/redesign.md` | `/interface:design` redesign lane and intake | ADAPT | Add single- vs multi-surface scope and shared-system locks/deltas | Very high | Low | No new command |\n| Four genre guides | Optional post-retrieval Interface explanatory lens | LEARN | Use independently authored evidence labels only after rights-gated mode selection | Medium | High | Do not reuse names/fixtures/rules as selectors |\n| Twenty-name theme catalog | No generation target; optional evaluation experiment | SKIP | Do not ingest names, token combinations, or selector behavior | High risk avoided | None | Direct reuse requires notice and ingredient-rights review |\n| Four detailed theme files | Evaluation fixtures only if independently authored | SKIP | Do not import rich theme specifications | Low | None | No copy |\n| 21 macrostructure leaves | Interface wireframe/variation procedures | LEARN | Use as evidence that whole-page composition must be explicit; generate target-specific alternatives | High method value | Low | Do not copy names, prose, diagrams, or recipes |\n| 9 hero leaves | Interface signature-role and wireframe procedures | LEARN | Generate a brief-specific hero role; typography-only may pass | High | Low | No leaf copy |\n| 5 section-head leaves | Interface variation procedures | LEARN | Test heading/body relationship and narrow collapse | Medium | Low | No leaf copy |\n| 6 feature leaves | Interface variation; Foundations responsive proof | LEARN | Vary section composition without a fixed feature preset | Medium | Low | No leaf copy |\n| 4 CTA leaves | Interface copy/preflight | LEARN | Choose action treatment from task hierarchy and state evidence | Medium | Low | No leaf copy |\n| 4 testimonial/proof leaves | Interface copy/mock data; Audit content integrity | ADAPT | Require sourced proof; never fabricate metrics/logos/quotes | High | Low | Quote/logo rights separate |\n| 8 footer leaves | Interface wireframe; Audit fingerprint registry | ADAPT | Detect generic sitemap footer as hypothesis; choose structure from site role | High | Medium | No catalog/routing-table copy |\n| 14 navigation leaves | Interface wireframe; Audit fingerprint registry | ADAPT | Detect genre-blind SaaS nav as hypothesis; preserve actual information architecture | High | Medium | No catalog/routing-table copy |\n| ROADMAP Nanobanana hook | Interface native-image branch + selected external transport | ADAPT | Provider-neutral gated generation plus asset receipt | High when image-led | Medium | Current terms, secrets, cost, input/output rights required |\n| ROADMAP `Plate` | None | SKIP | Derive image role per brief; no image-led preset | Negative | None | No copy |\n| ROADMAP brand-first flow | Interface-led new authored artifact; Foundations tokens | INSPIRE-NEW | Persist a validated authored system distinct from measured `DESIGN.md` | Very high | High | Prefer native schema; imagery rights separate |\n| ROADMAP theme-aware motion | Shared token vocabulary; Foundations starter; Motion strategy | ADAPT | Semantic character/rationale with target-derived values | High | Medium | No theme labels/multipliers copied |\n| ROADMAP variant | Existing `/interface:design` directions lane | SKIP | Verify structural deltas; no alias or new command | High duplication avoided | Low | No copy |\n| ROADMAP structural cookbook | Interface wireframe/variation procedure | ADAPT | Optional abstract brief-bound decision card, never implementation catalog | Medium-high | Medium | Independently author; no sketches/HTML copy |\n| ROADMAP tactile rebellion | Interface aesthetic direction and preflight | ADAPT | Controlled-imperfection check with brief evidence and bounded roles | Medium | Low-medium | Texture rights/receipt required |\n| ROADMAP charts | Foundations data-viz; Audit production checks | ADAPT | Add evidence-based 3D/perspective and dual-axis cautions | Medium | Low | Independent wording |\n| ROADMAP multi-page coherence | Interface real-UI loop; shared handoff | ADAPT | Explicit site locks versus page deltas | Very high | Low-medium | Clean-room concept |\n| ROADMAP project-path study | `/interface:design-reference`; extraction adapter | INSPIRE-NEW | Guarded project launcher resolves canonical render; segregate static evidence | High | High | Security/source attestation required |\n| ROADMAP explain | Existing Interface proof/presentation | SKIP | Add nothing unless fixtures reveal missing rationale | Medium | None-low | No copy |\n| ROADMAP negative capability | Audit registry/tells; shared cognitive laws | ADAPT | Optional evidence-backed perceptual cause and user impact | High | Low-medium | No invented rationale or prose copy |\n| ROADMAP emotion-first prompting | Interface brief-to-dials and aesthetic direction | LEARN | Capture desired/avoided audience feeling and translate through evidence | Medium-high | Low | No emotion theme/chooser |\n| ROADMAP sound policy | Motion microinteractions; Audit accessibility/performance | ADAPT | Require purpose, user control, alternate channel, frequency, and rights proof | Medium-high for audio products | Low-medium | Audio rights/provenance separate |\n| ROADMAP haptics | Future target-specific Motion reference only | SKIP | Reopen only for a named runtime/API/product/device matrix | Unknown | Unknown | Privacy, permission, accessible fallback required |\n| ROADMAP live-preview MCP | Existing Open Design preview, MD-GENERATOR proof, browser inspection | SKIP | At most normalize a read-only receipt after measured user pain | Low incremental | None-low | Sandbox untrusted renders; transport never owns acceptance |\n\n## 6. Audit Findings\n\nHallmark's current slop checklist contains 58 checks: integer gates 1-57 plus gate `38a`; the README's 57 count is stale. Shipped Audit should keep its stronger evidence labels, user-impact severity, owner routing, and five-dimension scoring. The useful additions are selected structural fingerprints, fabricated-content/fake-chrome checks, input geometry, wrapped-affordance checks, intrinsic grid/long-word/section-head probes, and sticky/focus interaction edge cases. Every promoted tell needs positive, clean, and legitimate-exception fixtures. [SOURCE: .opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/iterations/iteration-002.md:14-57]","lineStart":1,"lineEnd":100,"totalLines":203,"truncated":true}},"title":".opencode/specs/sk-design/014-hallmark-design-skill-research/001-research/research/lineages/sol-opencode/research.md","time":{"start":1784531684804,"end":1784531684813}},"metadata":{"openai":{"itemId":"fc_060b7dab920f2183016a5dcae4ba14819182f69619bc5d9c3b"}},"id":"prt_f7e608dc2001tD5WkDBao1QQkb","sessionID":"ses_08202bafbffe7aMYl1BZMs5SAo","messageID":"msg_f7e606674001SZhCELK3Hr9yj9"}}
