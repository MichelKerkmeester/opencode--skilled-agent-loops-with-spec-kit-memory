{"type":"tool_use","timestamp":1781763378231,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_deSyJrTzjGtnjGVZVyaTwqYn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2290,"limit":450},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2290:       targetDocPath: routedFilePath,\n2291:     });\n2292:     const canonicalFilePath = recordIdentity.canonicalFilePath;\n2293:     const samePathDedupExclusion = {\n2294:       canonicalFilePath,\n2295:       filePath: routedFilePath,\n2296:       ...(recordIdentity.targetAnchorId != null ? { targetAnchorId: recordIdentity.targetAnchorId } : {}),\n2297:     };\n2298:     const samePathExisting = findSamePathExistingMemory(\n2299:       database,\n2300:       routedParsed.specFolder,\n2301:       canonicalFilePath,\n2302:       routedFilePath,\n2303:       scope,\n2304:       recordIdentity,\n2305:     );\n2306:     const shouldChunkContent = shouldUseChunkedIndexing(routedParsed.content, plannerMode);\n2307:     const shouldPersistFinalizedFile = persistQualityLoopContent && typeof finalizedFileContent === 'string';\n2308:     let finalizeWarning: string | null = null;\n2309: \n2310:     // DEDUP: Check existing row by file path\n2311:     const existingResult = checkExistingRow(\n2312:       database,\n2313:       routedParsed,\n2314:       canonicalFilePath,\n2315:       routedFilePath,\n2316:       recordIdentity.targetAnchorId,\n2317:       force,\n2318:       validation.warnings,\n2319:       scope,\n2320:     );\n2321:     if (existingResult) return existingResult;\n2322: \n2323:     // NOTE: Content-hash dedup (C5-1) moved inside BEGIN IMMEDIATE transaction\n2324:     // to eliminate TOCTOU race between check and insert.\n2325: \n2326:     // EMBEDDING GENERATION (with persistent SQLite cache)\n2327:     const embeddingResult = await generateOrCacheEmbedding(database, routedParsed, routedFilePath, asyncEmbedding);\n2328:     const {\n2329:       embedding,\n2330:       status: embeddingStatus,\n2331:       failureReason: embeddingFailureReason,\n2332:       pendingCacheWrite,\n2333:     } = embeddingResult;\n2334: \n2335:     // the rollout: Quality Gate (before PE gating, after embedding)\n2336:     if (isSaveQualityGateEnabled() && isQualityGateEnabled()) {\n2337:       try {\n2338:         const qualityGateResult = runQualityGate({\n2339:           title: routedParsed.title,\n2340:           content: routedParsed.content,\n2341:           specFolder: routedParsed.specFolder,\n2342:           triggerPhrases: routedParsed.triggerPhrases,\n2343:           contextType: routedParsed.contextType,\n2344:           mode: 'legacy',\n2345:           embedding: embedding,\n2346:           findSimilar: embedding ? (emb, gateOptions) => {\n2347:             return findSimilarMemories(emb as Float32Array, {\n2348:               limit: gateOptions.limit,\n2349:               specFolder: gateOptions.specFolder,\n2350:               tenantId: scope.tenantId,\n2351:               userId: scope.userId,\n2352:               agentId: scope.agentId,\n2353:               sessionId: scope.sessionId,\n2354:             }).map(m => ({\n2355:               id: m.id,\n2356:               file_path: m.file_path,\n2357:               similarity: m.similarity,\n2358:             }));\n2359:           } : null,\n2360:         });\n2361: \n2362:         if (!qualityGateResult.pass && !qualityGateResult.warnOnly && qualityGateMode !== 'warn-only') {\n2363:           console.error(`[memory-save] TM-04: Quality gate REJECTED save for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2364:           return {\n2365:             status: 'rejected',\n2366:             id: 0,\n2367:             specFolder: routedParsed.specFolder,\n2368:             title: routedParsed.title ?? '',\n2369:             qualityScore: routedParsed.qualityScore,\n2370:             qualityFlags: routedParsed.qualityFlags,\n2371:             rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2372:             message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2373:             qualityGate: {\n2374:               pass: false,\n2375:               reasons: qualityGateResult.reasons,\n2376:               layers: qualityGateResult.layers,\n2377:             },\n2378:           };\n2379:         }\n2380: \n2381:         if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n2382:           console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2383:         }\n2384: \n2385:         if (qualityGateResult.wouldReject) {\n2386:           console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2387:         }\n2388:       } catch (qgErr: unknown) {\n2389:         const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n2390:         console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n2391:         // Quality gate errors must not block saves\n2392:       }\n2393:     }\n2394: \n2395:     const duplicatePrecheck = checkContentHashDedup(\n2396:       database,\n2397:       routedParsed,\n2398:       force,\n2399:       validation.warnings,\n2400:       samePathDedupExclusion,\n2401:       scope,\n2402:     );\n2403:     if (duplicatePrecheck) {\n2404:       await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n2405:       return duplicatePrecheck;\n2406:     }\n2407: \n2408:     persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n2409: \n2410:     // PE GATING\n2411:     const peResult = evaluateAndApplyPeDecision(\n2412:       database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope, writeProvenance,\n2413:     );\n2414:     if (peResult.earlyReturn) return peResult.earlyReturn;\n2415: \n2416:     let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n2417:       earlyReturn: null,\n2418:       warnings: [],\n2419:       saveTimeReconsolidation: {\n2420:         status: 'skipped',\n2421:         persistedState: { kind: 'create' },\n2422:       },\n2423:     };\n2424: \n2425:     // Complete async reconsolidation planning before chunking or\n2426:     // taking the SQLite writer lock, so chunked saves do not bypass the gate\n2427:     // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n2428:     reconResult = await runReconsolidationIfEnabled(\n2429:       database,\n2430:       routedParsed,\n2431:       routedFilePath,\n2432:       force,\n2433:       embedding,\n2434:       scope,\n2435:       { plannerMode, provenance: writeProvenance },\n2436:     );\n2437:     if (reconResult.earlyReturn) return reconResult.earlyReturn;\n2438:     if (reconResult.saveTimeReconsolidation.status === 'failed') {\n2439:       return buildSaveTimeReconsolidationFailureResult({\n2440:         parsed: routedParsed,\n2441:         validation,\n2442:         reconWarnings: reconResult.warnings,\n2443:         failure: {\n2444:           status: 'failed',\n2445:           reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n2446:           ...(reconResult.saveTimeReconsolidation.warnings\n2447:             ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n2448:             : {}),\n2449:           ...(reconResult.saveTimeReconsolidation.persistedState\n2450:             ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n2451:             : {}),\n2452:         },\n2453:       });\n2454:     }\n2455: \n2456:     if (shouldChunkContent) {\n2457:       console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n2458:       const chunkedInsertTracker = createChunkedInsertTracker();\n2459:       const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n2460:         force,\n2461:         scope,\n2462:         provenance: writeProvenance,\n2463:         applyPostInsertMetadata: (db, memoryId, fields) => {\n2464:           applyPostInsertMetadata(db, memoryId, fields);\n2465:           trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n2466:         },\n2467:       });\n2468: \n2469:       if (\n2470:         peResult.supersededId != null\n2471:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2472:       ) {\n2473:         try {\n2474:           const finalizeChunkedPeTx = database.transaction(() => {\n2475:             if (chunkedResult.id > 0) {\n2476:               recordCrossPathPeSupersedes(\n2477:                 database,\n2478:                 chunkedResult.id,\n2479:                 peResult.supersededId,\n2480:                 samePathExisting?.id ?? null,\n2481:                 peResult.decision.reason,\n2482:               );\n2483:             }\n2484:             if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n2485:               throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2486:             }\n2487:           });\n2488:           finalizeChunkedPeTx.immediate();\n2489:         } catch (supersedeErr: unknown) {\n2490:           const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n2491:           const cleanupSuffix = cleanup.cleaned\n2492:             ? ' Rolled back the newly created chunk tree.'\n2493:             : cleanup.attempted && cleanup.error\n2494:               ? ` Cleanup failed: ${cleanup.error}`\n2495:               : '';\n2496:           return {\n2497:             ...chunkedResult,\n2498:             status: 'error',\n2499:             error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n2500:             message: `Chunked indexing succeeded, but predecessor ${peResult.supersededId} could not be superseded.${cleanupSuffix}`,\n2501:           };\n2502:         }\n2503:       }\n2504: \n2505:       if (\n2506:         shouldPersistFinalizedFile\n2507:         && finalizedFileContent\n2508:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2509:       ) {\n2510:         try {\n2511:           await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n2512:         } catch (finalizeErr: unknown) {\n2513:           finalizeWarning = `Quality-loop file persistence failed after chunked indexing: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}`;\n2514:           console.warn(`[memory-save] ${finalizeWarning}`);\n2515:         }\n2516:       }\n2517: \n2518:       if (peResult.decision.action !== 'CREATE') {\n2519:         chunkedResult.pe_action = peResult.decision.action;\n2520:         chunkedResult.pe_reason = peResult.decision.reason;\n2521:       }\n2522:       if (peResult.supersededId != null) {\n2523:         chunkedResult.superseded_id = peResult.supersededId;\n2524:       }\n2525:       if (Array.isArray(reconResult.warnings) && reconResult.warnings.length > 0) {\n2526:         const existingWarnings = Array.isArray(chunkedResult.warnings)\n2527:           ? [...(chunkedResult.warnings as string[])]\n2528:           : [];\n2529:         chunkedResult.warnings = [...existingWarnings, ...reconResult.warnings];\n2530:       }\n2531:       if (reconResult.assistiveRecommendation) {\n2532:         reconResult.assistiveRecommendation.advisory_stale = true;\n2533:         chunkedResult.assistiveRecommendation = reconResult.assistiveRecommendation;\n2534:       }\n2535:       chunkedResult.saveTimeReconsolidation = reconResult.saveTimeReconsolidation;\n2536: \n2537:       return appendResultWarning(chunkedResult, finalizeWarning);\n2538:     }\n2539: \n2540:     // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n2541:     // atomicity. Uses database.transaction() so inner transaction() calls in\n2542:     // createMemoryRecord / index_memory correctly nest via SAVEPOINTs instead\n2543:     // of failing with \"cannot start a transaction within a transaction\".\n2544:     // withSpecFolderLock handles in-process serialization; this transaction\n2545:     // provides defense-in-depth against multi-process races.\n2546:     let existing: { id: number; content_hash: string } | undefined;\n2547: \n2548:     // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n2549:     // safe outside the transaction and this avoids an early-return inside the\n2550:     // transaction callback (which would COMMIT an empty tx unnecessarily).\n2551:     const dupResult = checkContentHashDedup(\n2552:       database,\n2553:       routedParsed,\n2554:       force,\n2555:       validation.warnings,\n2556:       samePathDedupExclusion,\n2557:       scope,\n2558:     );\n2559:     if (dupResult) {\n2560:       await repairReplayEnrichmentIfNeeded(database, dupResult.id, routedParsed);\n2561:       return dupResult;\n2562:     }\n2563: \n2564:     const requestedScope = getRequestedScope(scope);\n2565:     const writeTransaction = database.transaction((): number => {\n2566:       if (indexingOrigin !== 'scan' && embedding) {\n2567:         const complementRecheck = findScopeFilteredCandidates({\n2568:           database,\n2569:           embedding,\n2570:           parsed: routedParsed,\n2571:           requestedScope,\n2572:           limit: 1,\n2573:           minSimilarity: 50,\n2574:           overfetchMultiplier: 3,\n2575:         });\n2576:         const topCandidate = complementRecheck.candidates[0];\n2577:         if (topCandidate) {\n2578:           const transactionalAction = determineAction(topCandidate.similarity);\n2579:           if (transactionalAction !== 'complement') {\n2580:             throw new SaveTimeReconsolidationAbort({\n2581:               status: 'failed',\n2582:               reason: 'candidate_changed',\n2583:               warnings: [\n2584:                 `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n2585:               ],\n2586:               persistedState: {\n2587:                 kind: transactionalAction,\n2588:                 candidateMemoryIds: [topCandidate.id],\n2589:               },\n2590:             });\n2591:           }\n2592:         }\n2593:       }\n2594: \n2595:       // CREATE NEW MEMORY\n2596:       existing = findSamePathExistingMemory(\n2597:         database,\n2598:         routedParsed.specFolder,\n2599:         canonicalFilePath,\n2600:         routedFilePath,\n2601:         scope,\n2602:         recordIdentity,\n2603:       ) as { id: number; content_hash: string } | undefined;\n2604: \n2605:       // A same-path re-index whose file content changed appends a new version\n2606:       // row; the prior row for this logical key is retired below so re-indexing\n2607:       // replaces in place rather than leaving a deprecated duplicate. Scoped to\n2608:       // this branch only — PE-gate / reconsolidation lineage (createMemoryRecord)\n2609:       // is intentionally preserved.\n2610:       const samePathSupersededPredecessorId =\n2611:         existing && existing.content_hash !== routedParsed.contentHash ? existing.id : null;\n2612: \n2613:       // Retire the same-path predecessor before inserting the new version so the\n2614:       // active-row uniqueness guard holds at insert time. Deprecating (not deleting)\n2615:       // keeps the predecessor row, its lineage chain, and its history intact while\n2616:       // removing it from the active-row guard; the new version supersedes it in place.\n2617:       const reindexTierCarry = samePathSupersededPredecessorId != null\n2618:         ? retirePredecessorForActiveReindex(database, samePathSupersededPredecessorId)\n2619:         : null;\n2620: \n2621:       const memoryId = samePathSupersededPredecessorId != null\n2622:         ? createAppendOnlyMemoryRecord({\n2623:             database,\n2624:             parsed: routedParsed,\n2625:             filePath: routedFilePath,\n2626:             embedding,\n2627:             embeddingFailureReason,\n2628:             predecessorMemoryId: samePathSupersededPredecessorId,\n2629:             anchorId: recordIdentity.targetAnchorId,\n2630:             tenantId: scope.tenantId,\n2631:             userId: scope.userId,\n2632:             agentId: scope.agentId,\n2633:             sessionId: scope.sessionId,\n2634:             actor: 'mcp:memory_save',\n2635:           })\n2636:         : createMemoryRecord(\n2637:             database,\n2638:             routedParsed,\n2639:             routedFilePath,\n2640:             embedding,\n2641:             embeddingFailureReason,\n2642:             peResult.decision,\n2643:             scope,\n2644:             recordIdentity,\n2645:             writeProvenance,\n2646:           );\n2647: \n2648:       if (samePathSupersededPredecessorId != null) {\n2649:         applyWriteProvenance(database, memoryId, writeProvenance);\n2650:       }\n2651: \n2652:       // A human's tier decision on the retired predecessor carries forward to the\n2653:       // reindexed successor. Re-stamp after provenance so the manual tier and its\n2654:       // human source-kind survive the reindex instead of resetting to the default.\n2655:       if (reindexTierCarry != null) {\n2656:         database\n2657:           .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n2658:           .run(reindexTierCarry.importanceTier, memoryId);\n2659:         persistSourceKind(database, memoryId, reindexTierCarry.sourceKind as SourceKind);\n2660:       }\n2661: \n2662:       // F1.01 fix: Mark superseded memory AFTER new record creation, inside\n2663:       // the same transaction, so a creation failure rolls back both operations.\n2664:       if (peResult.supersededId != null) {\n2665:         const supersededOk = markMemorySuperseded(peResult.supersededId);\n2666:         // C5-3: Supersede failure should abort the transaction\n2667:         if (!supersededOk) {\n2668:           throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2669:         }\n2670:       }\n2671: \n2672:       recordLineageVersion(database, {\n2673:         memoryId,\n2674:         predecessorMemoryId: samePathSupersededPredecessorId,\n2675:         actor: 'mcp:memory_save',\n2676:         transitionEvent: samePathSupersededPredecessorId != null ? 'SUPERSEDE' : 'CREATE',\n2677:       });\n2678:       markEnrichmentPending(database, memoryId, POST_INSERT_ENRICHMENT_VERSION);\n2679: \n2680:       return memoryId;\n2681:     });\n2682: \n2683:     let id: number;\n2684:     try {\n2685:       id = writeTransaction.immediate();\n2686:     } catch (error: unknown) {\n2687:       if (error instanceof SaveTimeReconsolidationAbort) {\n2688:         return buildSaveTimeReconsolidationFailureResult({\n2689:           parsed: routedParsed,\n2690:           validation,\n2691:           reconWarnings: reconResult.warnings,\n2692:           failure: error.result,\n2693:           message: `Save aborted before commit: ${error.result.reason}`,\n2694:         });\n2695:       }\n2696:       throw error;\n2697:     }\n2698: \n2699:     if (shouldPersistFinalizedFile && finalizedFileContent) {\n2700:       try {\n2701:         await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n2702:       } catch (finalizeErr: unknown) {\n2703:         finalizeWarning = `[file-persistence-failed] Quality-loop file persistence failed after DB commit: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}. DB row committed — manual file recovery may be needed.`;\n2704:         console.warn(`[memory-save] ${finalizeWarning}`);\n2705:       }\n2706:     }\n2707: \n2708:     // Data integrity: clean stale auto-entities before re-extraction on update\n2709:     // When a memory is superseded or replaced in-place, purge the predecessor's\n2710:     // auto-entity rows so the entity catalog reflects only active content.\n2711:     if (existing && existing.id !== id) {\n2712:       try {\n2713:         refreshAutoEntitiesForMemory(database, existing.id, []);\n2714:         console.error(`[memory-save] Cleaned stale auto-entities for superseded memory #${existing.id}`);\n2715:       } catch (entityCleanupErr: unknown) {\n2716:         // Entity cleanup failure must not block save — log and continue\n2717:         console.warn(`[memory-save] Auto-entity cleanup for #${existing.id} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n2718:       }\n2719:     }\n2720:     if (peResult.supersededId != null && peResult.supersededId !== existing?.id) {\n2721:       try {\n2722:         refreshAutoEntitiesForMemory(database, peResult.supersededId, []);\n2723:         console.error(`[memory-save] Cleaned stale auto-entities for PE-superseded memory #${peResult.supersededId}`);\n2724:       } catch (entityCleanupErr: unknown) {\n2725:         console.warn(`[memory-save] Auto-entity cleanup for PE #${peResult.supersededId} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n2726:       }\n2727:     }\n2728: \n2729:     if (embedding) {\n2730:       try {\n2731:         recordNearDuplicateCheck({\n2732:           database,\n2733:           memoryId: id,\n2734:           specFolder: routedParsed.specFolder,\n2735:           contentHash: routedParsed.contentHash,\n2736:           embedding,\n2737:           scope,\n2738:         });\n2739:       } catch (error: unknown) {\n\n(Showing lines 2290-2739 of 4082. Use offset=2740 to continue.)\n</content>","metadata":{"preview":"      targetDocPath: routedFilePath,\n    });\n    const canonicalFilePath = recordIdentity.canonicalFilePath;\n    const samePathDedupExclusion = {\n      canonicalFilePath,\n      filePath: routedFilePath,\n      ...(recordIdentity.targetAnchorId != null ? { targetAnchorId: recordIdentity.targetAnchorId } : {}),\n    };\n    const samePathExisting = findSamePathExistingMemory(\n      database,\n      routedParsed.specFolder,\n      canonicalFilePath,\n      routedFilePath,\n      scope,\n      recordIdentity,\n    );\n    const shouldChunkContent = shouldUseChunkedIndexing(routedParsed.content, plannerMode);\n    const shouldPersistFinalizedFile = persistQualityLoopContent && typeof finalizedFileContent === 'string';\n    let finalizeWarning: string | null = null;\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"      targetDocPath: routedFilePath,\n    });\n    const canonicalFilePath = recordIdentity.canonicalFilePath;\n    const samePathDedupExclusion = {\n      canonicalFilePath,\n      filePath: routedFilePath,\n      ...(recordIdentity.targetAnchorId != null ? { targetAnchorId: recordIdentity.targetAnchorId } : {}),\n    };\n    const samePathExisting = findSamePathExistingMemory(\n      database,\n      routedParsed.specFolder,\n      canonicalFilePath,\n      routedFilePath,\n      scope,\n      recordIdentity,\n    );\n    const shouldChunkContent = shouldUseChunkedIndexing(routedParsed.content, plannerMode);\n    const shouldPersistFinalizedFile = persistQualityLoopContent && typeof finalizedFileContent === 'string';\n    let finalizeWarning: string | null = null;\n\n    // DEDUP: Check existing row by file path\n    const existingResult = checkExistingRow(\n      database,\n      routedParsed,\n      canonicalFilePath,\n      routedFilePath,\n      recordIdentity.targetAnchorId,\n      force,\n      validation.warnings,\n      scope,\n    );\n    if (existingResult) return existingResult;\n\n    // NOTE: Content-hash dedup (C5-1) moved inside BEGIN IMMEDIATE transaction\n    // to eliminate TOCTOU race between check and insert.\n\n    // EMBEDDING GENERATION (with persistent SQLite cache)\n    const embeddingResult = await generateOrCacheEmbedding(database, routedParsed, routedFilePath, asyncEmbedding);\n    const {\n      embedding,\n      status: embeddingStatus,\n      failureReason: embeddingFailureReason,\n      pendingCacheWrite,\n    } = embeddingResult;\n\n    // the rollout: Quality Gate (before PE gating, after embedding)\n    if (isSaveQualityGateEnabled() && isQualityGateEnabled()) {\n      try {\n        const qualityGateResult = runQualityGate({\n          title: routedParsed.title,\n          content: routedParsed.content,\n          specFolder: routedParsed.specFolder,\n          triggerPhrases: routedParsed.triggerPhrases,\n          contextType: routedParsed.contextType,\n          mode: 'legacy',\n          embedding: embedding,\n          findSimilar: embedding ? (emb, gateOptions) => {\n            return findSimilarMemories(emb as Float32Array, {\n              limit: gateOptions.limit,\n              specFolder: gateOptions.specFolder,\n              tenantId: scope.tenantId,\n              userId: scope.userId,\n              agentId: scope.agentId,\n              sessionId: scope.sessionId,\n            }).map(m => ({\n              id: m.id,\n              file_path: m.file_path,\n              similarity: m.similarity,\n            }));\n          } : null,\n        });\n\n        if (!qualityGateResult.pass && !qualityGateResult.warnOnly && qualityGateMode !== 'warn-only') {\n          console.error(`[memory-save] TM-04: Quality gate REJECTED save for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n          return {\n            status: 'rejected',\n            id: 0,\n            specFolder: routedParsed.specFolder,\n            title: routedParsed.title ?? '',\n            qualityScore: routedParsed.qualityScore,\n            qualityFlags: routedParsed.qualityFlags,\n            rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            qualityGate: {\n              pass: false,\n              reasons: qualityGateResult.reasons,\n              layers: qualityGateResult.layers,\n            },\n          };\n        }\n\n        if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n          console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n\n        if (qualityGateResult.wouldReject) {\n          console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n      } catch (qgErr: unknown) {\n        const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n        console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n        // Quality gate errors must not block saves\n      }\n    }\n\n    const duplicatePrecheck = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (duplicatePrecheck) {\n      await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n      return duplicatePrecheck;\n    }\n\n    persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n\n    // PE GATING\n    const peResult = evaluateAndApplyPeDecision(\n      database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope, writeProvenance,\n    );\n    if (peResult.earlyReturn) return peResult.earlyReturn;\n\n    let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n      earlyReturn: null,\n      warnings: [],\n      saveTimeReconsolidation: {\n        status: 'skipped',\n        persistedState: { kind: 'create' },\n      },\n    };\n\n    // Complete async reconsolidation planning before chunking or\n    // taking the SQLite writer lock, so chunked saves do not bypass the gate\n    // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n    reconResult = await runReconsolidationIfEnabled(\n      database,\n      routedParsed,\n      routedFilePath,\n      force,\n      embedding,\n      scope,\n      { plannerMode, provenance: writeProvenance },\n    );\n    if (reconResult.earlyReturn) return reconResult.earlyReturn;\n    if (reconResult.saveTimeReconsolidation.status === 'failed') {\n      return buildSaveTimeReconsolidationFailureResult({\n        parsed: routedParsed,\n        validation,\n        reconWarnings: reconResult.warnings,\n        failure: {\n          status: 'failed',\n          reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n          ...(reconResult.saveTimeReconsolidation.warnings\n            ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n            : {}),\n          ...(reconResult.saveTimeReconsolidation.persistedState\n            ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n            : {}),\n        },\n      });\n    }\n\n    if (shouldChunkContent) {\n      console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n      const chunkedInsertTracker = createChunkedInsertTracker();\n      const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n        force,\n        scope,\n        provenance: writeProvenance,\n        applyPostInsertMetadata: (db, memoryId, fields) => {\n          applyPostInsertMetadata(db, memoryId, fields);\n          trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n        },\n      });\n\n      if (\n        peResult.supersededId != null\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          const finalizeChunkedPeTx = database.transaction(() => {\n            if (chunkedResult.id > 0) {\n              recordCrossPathPeSupersedes(\n                database,\n                chunkedResult.id,\n                peResult.supersededId,\n                samePathExisting?.id ?? null,\n                peResult.decision.reason,\n              );\n            }\n            if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n              throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n            }\n          });\n          finalizeChunkedPeTx.immediate();\n        } catch (supersedeErr: unknown) {\n          const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n          const cleanupSuffix = cleanup.cleaned\n            ? ' Rolled back the newly created chunk tree.'\n            : cleanup.attempted && cleanup.error\n              ? ` Cleanup failed: ${cleanup.error}`\n              : '';\n          return {\n            ...chunkedResult,\n            status: 'error',\n            error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n            message: `Chunked indexing succeeded, but predecessor ${peResult.supersededId} could not be superseded.${cleanupSuffix}`,\n          };\n        }\n      }\n\n      if (\n        shouldPersistFinalizedFile\n        && finalizedFileContent\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n        } catch (finalizeErr: unknown) {\n          finalizeWarning = `Quality-loop file persistence failed after chunked indexing: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}`;\n          console.warn(`[memory-save] ${finalizeWarning}`);\n        }\n      }\n\n      if (peResult.decision.action !== 'CREATE') {\n        chunkedResult.pe_action = peResult.decision.action;\n        chunkedResult.pe_reason = peResult.decision.reason;\n      }\n      if (peResult.supersededId != null) {\n        chunkedResult.superseded_id = peResult.supersededId;\n      }\n      if (Array.isArray(reconResult.warnings) && reconResult.warnings.length > 0) {\n        const existingWarnings = Array.isArray(chunkedResult.warnings)\n          ? [...(chunkedResult.warnings as string[])]\n          : [];\n        chunkedResult.warnings = [...existingWarnings, ...reconResult.warnings];\n      }\n      if (reconResult.assistiveRecommendation) {\n        reconResult.assistiveRecommendation.advisory_stale = true;\n        chunkedResult.assistiveRecommendation = reconResult.assistiveRecommendation;\n      }\n      chunkedResult.saveTimeReconsolidation = reconResult.saveTimeReconsolidation;\n\n      return appendResultWarning(chunkedResult, finalizeWarning);\n    }\n\n    // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n    // atomicity. Uses database.transaction() so inner transaction() calls in\n    // createMemoryRecord / index_memory correctly nest via SAVEPOINTs instead\n    // of failing with \"cannot start a transaction within a transaction\".\n    // withSpecFolderLock handles in-process serialization; this transaction\n    // provides defense-in-depth against multi-process races.\n    let existing: { id: number; content_hash: string } | undefined;\n\n    // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n    // safe outside the transaction and this avoids an early-return inside the\n    // transaction callback (which would COMMIT an empty tx unnecessarily).\n    const dupResult = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (dupResult) {\n      await repairReplayEnrichmentIfNeeded(database, dupResult.id, routedParsed);\n      return dupResult;\n    }\n\n    const requestedScope = getRequestedScope(scope);\n    const writeTransaction = database.transaction((): number => {\n      if (indexingOrigin !== 'scan' && embedding) {\n        const complementRecheck = findScopeFilteredCandidates({\n          database,\n          embedding,\n          parsed: routedParsed,\n          requestedScope,\n          limit: 1,\n          minSimilarity: 50,\n          overfetchMultiplier: 3,\n        });\n        const topCandidate = complementRecheck.candidates[0];\n        if (topCandidate) {\n          const transactionalAction = determineAction(topCandidate.similarity);\n          if (transactionalAction !== 'complement') {\n            throw new SaveTimeReconsolidationAbort({\n              status: 'failed',\n              reason: 'candidate_changed',\n              warnings: [\n                `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n              ],\n              persistedState: {\n                kind: transactionalAction,\n                candidateMemoryIds: [topCandidate.id],\n              },\n            });\n          }\n        }\n      }\n\n      // CREATE NEW MEMORY\n      existing = findSamePathExistingMemory(\n        database,\n        routedParsed.specFolder,\n        canonicalFilePath,\n        routedFilePath,\n        scope,\n        recordIdentity,\n      ) as { id: number; content_hash: string } | undefined;\n\n      // A same-path re-index whose file content changed appends a new version\n      // row; the prior row for this logical key is retired below so re-indexing\n      // replaces in place rather than leaving a deprecated duplicate. Scoped to\n      // this branch only — PE-gate / reconsolidation lineage (createMemoryRecord)\n      // is intentionally preserved.\n      const samePathSupersededPredecessorId =\n        existing && existing.content_hash !== routedParsed.contentHash ? existing.id : null;\n\n      // Retire the same-path predecessor before inserting the new version so the\n      // active-row uniqueness guard holds at insert time. Deprecating (not deleting)\n      // keeps the predecessor row, its lineage chain, and its history intact while\n      // removing it from the active-row guard; the new version supersedes it in place.\n      const reindexTierCarry = samePathSupersededPredecessorId != null\n        ? retirePredecessorForActiveReindex(database, samePathSupersededPredecessorId)\n        : null;\n\n      const memoryId = samePathSupersededPredecessorId != null\n        ? createAppendOnlyMemoryRecord({\n            database,\n            parsed: routedParsed,\n            filePath: routedFilePath,\n            embedding,\n            embeddingFailureReason,\n            predecessorMemoryId: samePathSupersededPredecessorId,\n            anchorId: recordIdentity.targetAnchorId,\n            tenantId: scope.tenantId,\n            userId: scope.userId,\n            agentId: scope.agentId,\n            sessionId: scope.sessionId,\n            actor: 'mcp:memory_save',\n          })\n        : createMemoryRecord(\n            database,\n            routedParsed,\n            routedFilePath,\n            embedding,\n            embeddingFailureReason,\n            peResult.decision,\n            scope,\n            recordIdentity,\n            writeProvenance,\n          );\n\n      if (samePathSupersededPredecessorId != null) {\n        applyWriteProvenance(database, memoryId, writeProvenance);\n      }\n\n      // A human's tier decision on the retired predecessor carries forward to the\n      // reindexed successor. Re-stamp after provenance so the manual tier and its\n      // human source-kind survive the reindex instead of resetting to the default.\n      if (reindexTierCarry != null) {\n        database\n          .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n          .run(reindexTierCarry.importanceTier, memoryId);\n        persistSourceKind(database, memoryId, reindexTierCarry.sourceKind as SourceKind);\n      }\n\n      // F1.01 fix: Mark superseded memory AFTER new record creation, inside\n      // the same transaction, so a creation failure rolls back both operations.\n      if (peResult.supersededId != null) {\n        const supersededOk = markMemorySuperseded(peResult.supersededId);\n        // C5-3: Supersede failure should abort the transaction\n        if (!supersededOk) {\n          throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n        }\n      }\n\n      recordLineageVersion(database, {\n        memoryId,\n        predecessorMemoryId: samePathSupersededPredecessorId,\n        actor: 'mcp:memory_save',\n        transitionEvent: samePathSupersededPredecessorId != null ? 'SUPERSEDE' : 'CREATE',\n      });\n      markEnrichmentPending(database, memoryId, POST_INSERT_ENRICHMENT_VERSION);\n\n      return memoryId;\n    });\n\n    let id: number;\n    try {\n      id = writeTransaction.immediate();\n    } catch (error: unknown) {\n      if (error instanceof SaveTimeReconsolidationAbort) {\n        return buildSaveTimeReconsolidationFailureResult({\n          parsed: routedParsed,\n          validation,\n          reconWarnings: reconResult.warnings,\n          failure: error.result,\n          message: `Save aborted before commit: ${error.result.reason}`,\n        });\n      }\n      throw error;\n    }\n\n    if (shouldPersistFinalizedFile && finalizedFileContent) {\n      try {\n        await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n      } catch (finalizeErr: unknown) {\n        finalizeWarning = `[file-persistence-failed] Quality-loop file persistence failed after DB commit: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}. DB row committed — manual file recovery may be needed.`;\n        console.warn(`[memory-save] ${finalizeWarning}`);\n      }\n    }\n\n    // Data integrity: clean stale auto-entities before re-extraction on update\n    // When a memory is superseded or replaced in-place, purge the predecessor's\n    // auto-entity rows so the entity catalog reflects only active content.\n    if (existing && existing.id !== id) {\n      try {\n        refreshAutoEntitiesForMemory(database, existing.id, []);\n        console.error(`[memory-save] Cleaned stale auto-entities for superseded memory #${existing.id}`);\n      } catch (entityCleanupErr: unknown) {\n        // Entity cleanup failure must not block save — log and continue\n        console.warn(`[memory-save] Auto-entity cleanup for #${existing.id} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n      }\n    }\n    if (peResult.supersededId != null && peResult.supersededId !== existing?.id) {\n      try {\n        refreshAutoEntitiesForMemory(database, peResult.supersededId, []);\n        console.error(`[memory-save] Cleaned stale auto-entities for PE-superseded memory #${peResult.supersededId}`);\n      } catch (entityCleanupErr: unknown) {\n        console.warn(`[memory-save] Auto-entity cleanup for PE #${peResult.supersededId} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n      }\n    }\n\n    if (embedding) {\n      try {\n        recordNearDuplicateCheck({\n          database,\n          memoryId: id,\n          specFolder: routedParsed.specFolder,\n          contentHash: routedParsed.contentHash,\n          embedding,\n          scope,\n        });\n      } catch (error: unknown) {","lineStart":2290,"lineEnd":2739,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781763378215,"end":1781763378228}},"metadata":{"openai":{"itemId":"fc_0c42a1b9296254b9016a338d32261c819199315c01b3b3b5a7"}},"id":"prt_ed95f8c23001X9fZcntZHg3Cp3","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f6e260010iN1syd82sktaK"}}
{"type":"tool_use","timestamp":1781763378306,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_nNIrTcqbHhnCud7NPLf4gHeb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2830,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2830: };\n2831: \n2832: /** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\n2833: async function indexMemoryFile(\n2834:   filePath: string,\n2835:   {\n2836:     force = false,\n2837:     parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n2838:     asyncEmbedding = false,\n2839:     plannerMode,\n2840:     scope = {} as MemoryScopeMatch,\n2841:     qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n2842:     routing,\n2843:     provenance,\n2844:     governance,\n2845:     ...originOptions\n2846:   }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n2847: ): Promise<IndexResult> {\n2848:   // Reuse parsed content when provided by caller to avoid a second parse.\n2849:   const indexingOrigin = resolveIndexingOrigin(originOptions);\n2850:   const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n2851:   const database = requireDb();\n2852:   const prepared = prepareParsedMemoryForIndexing(parsed, database);\n2853:   const validation = prepared.validation;\n2854:   if (!validation.valid) {\n2855:     throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n2856:   }\n2857:   if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n2858:     console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n2859:   }\n2860: \n2861:   // When a governance decision is threaded in (bulk scan/ingest), derive the\n2862:   // scope tuple from it so the row is created under the governed scope, matching\n2863:   // how the direct save path seeds saveScope from governanceDecision.normalized.\n2864:   const effectiveScope: MemoryScopeMatch = governance\n2865:     ? {\n2866:         tenantId: governance.normalized.tenantId ?? null,\n2867:         userId: governance.normalized.userId ?? null,\n2868:         agentId: governance.normalized.agentId ?? null,\n2869:         sessionId: governance.normalized.sessionId ?? null,\n2870:       }\n2871:     : scope;\n2872:   const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n2873:     ? {\n2874:         provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n2875:         provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n2876:         tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n2877:       }\n2878:     : undefined);\n2879: \n2880:   const result = await processPreparedMemory(prepared, filePath, {\n2881:     force,\n2882:     asyncEmbedding,\n2883:     plannerMode,\n2884:     origin: indexingOrigin,\n2885:     persistQualityLoopContent: true,\n2886:     refreshFromDiskAfterLock: parsedOverride !== null,\n2887:     scope: effectiveScope,\n2888:     qualityGateMode,\n2889:     routing,\n2890:     provenance: effectiveProvenance,\n2891:   });\n2892: \n2893:   // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n2894:   // direct memory_save path so governed bulk/scan/async ingests are not silently\n2895:   // downgraded to ungoverned rows. Only for freshly written rows.\n2896:   if (governance && typeof result.id === 'number' && result.id > 0\n2897:     && result.status !== 'unchanged' && result.status !== 'duplicate') {\n2898:     applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n2899:   }\n2900: \n2901:   return result;\n2902: }\n2903: \n2904: async function indexMemoryFileFromScan(\n2905:   filePath: string,\n2906:   options: BaseIndexMemoryFileOptions = {},\n2907: ): Promise<IndexResult> {\n2908:   return indexMemoryFile(filePath, {\n2909:     ...options,\n2910:     origin: 'scan',\n2911:   });\n2912: }\n2913: \n2914: /* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n2915: \n2916: // Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n2917: // entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n2918: // slots free.\n2919: const MAX_BACKGROUND_ENRICHMENTS = 4;\n2920: let activeBackgroundEnrichments = 0;\n2921: const backgroundEnrichmentQueue: Array<() => void> = [];\n2922: \n2923: // Set during shutdown BEFORE closeDb. A deferred/queued enrichment run re-resolves the DB handle via\n2924: // requireDb(), which REOPENS a closed connection — so without this fence a run firing during the\n2925: // shutdown drain would reopen the DB and write fresh WAL frames after the TRUNCATE checkpoint, leaving\n2926: // a non-empty WAL at rest and defeating the close durability guarantee. Same hazard the fileWatcher\n2927: // and ingestWorker fences guard against.\n2928: let enrichmentShuttingDown = false;\n2929: \n2930: /**\n2931:  * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n2932:  * in-flight run bail before it touches the DB. Synchronous so fatalShutdown can call it in its\n2933:  * pre-close fence block, before any await lets a queued setImmediate run fire. Dropped rows remain\n2934:  * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n2935:  */\n2936: export function shutdownBackgroundEnrichment(): void {\n2937:   enrichmentShuttingDown = true;\n2938:   backgroundEnrichmentQueue.length = 0;\n2939: }\n2940: \n2941: // Bound the OVERFLOW queue, not just concurrency. A sustained live-save flood (saves arriving faster\n2942: // than the 4-wide drain) would otherwise grow the queue — and the parsed payload each entry retains —\n2943: // without bound. On overflow we DROP rather than push: the row is enrichment-pending in the commit\n2944: // transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n2945: // scheduler visible through memory_health (otherwise a stuck scheduler is a silent enrichment outage).\n2946: const MAX_QUEUED_ENRICHMENTS = 2000;\n2947: let enrichmentDroppedTotal = 0;\n2948: let enrichmentFailureTotal = 0;\n2949: let enrichmentLastError: string | null = null;\n2950: let enrichmentLastErrorAt: string | null = null;\n2951: let enrichmentSuppressedWarnings = 0;\n2952: \n2953: /** Scheduler observability snapshot for memory_health — module-local counters only, no DB access. */\n2954: export function getBackgroundEnrichmentStats(): {\n2955:   active: number;\n2956:   queued: number;\n2957:   max: number;\n2958:   maxQueued: number;\n2959:   droppedTotal: number;\n2960:   failureTotal: number;\n2961:   lastError: string | null;\n2962:   lastErrorAt: string | null;\n2963: } {\n2964:   return {\n2965:     active: activeBackgroundEnrichments,\n2966:     queued: backgroundEnrichmentQueue.length,\n2967:     max: MAX_BACKGROUND_ENRICHMENTS,\n2968:     maxQueued: MAX_QUEUED_ENRICHMENTS,\n2969:     droppedTotal: enrichmentDroppedTotal,\n2970:     failureTotal: enrichmentFailureTotal,\n2971:     lastError: enrichmentLastError,\n2972:     lastErrorAt: enrichmentLastErrorAt,\n2973:   };\n2974: }\n2975: \n2976: /**\n2977:  * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n2978:  * - re-resolves the DB handle when the run starts (covers a recycle before the run begins; a recycle\n2979:  *   mid-run throws on the post-await write and the row falls back to the pending-marker backfill),\n2980:  * - skips rows that were superseded/deprecated before the deferred run starts, so it never\n2981:  *   repopulates purged entity/graph data for an inactive row,\n2982:  * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n2983:  *   skipped or dropped run is recovered by the pending-marker replay/backfill path.\n2984:  */\n2985: function scheduleBackgroundEnrichment(\n2986:   memoryId: number,\n2987:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n2988: ): void {\n2989:   if (enrichmentShuttingDown) return; // do not schedule new enrichment work during shutdown\n2990:   // Reserve a slot and schedule on a macrotask. The counter MUST be incremented here, at schedule\n2991:   // time — not inside the deferred callback. If it were bumped inside the callback, a burst (a startup\n2992:   // scan calling this once per row) would race: every call reads the still-zero counter before any\n2993:   // callback runs, all pass the cap, and unbounded setImmediate callbacks pile up that then drain as a\n2994:   // synchronous microtask chain and starve the event loop, so the daemon's IPC accept() never runs.\n2995:   // Re-arming dequeued work through setImmediate (rather than calling it inline from the finally)\n2996:   // returns control to the poll phase between runs.\n2997:   const start = (task: () => void): void => {\n2998:     activeBackgroundEnrichments++;\n2999:     // setImmediate (a MACROTASK boundary) is required here, not queueMicrotask: only a macrotask hands\n\n(Showing lines 2830-2999 of 4082. Use offset=3000 to continue.)\n</content>","metadata":{"preview":"};\n\n/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    provenance,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"};\n\n/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    provenance,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);\n  const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n  const database = requireDb();\n  const prepared = prepareParsedMemoryForIndexing(parsed, database);\n  const validation = prepared.validation;\n  if (!validation.valid) {\n    throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n  }\n  if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n    console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n  }\n\n  // When a governance decision is threaded in (bulk scan/ingest), derive the\n  // scope tuple from it so the row is created under the governed scope, matching\n  // how the direct save path seeds saveScope from governanceDecision.normalized.\n  const effectiveScope: MemoryScopeMatch = governance\n    ? {\n        tenantId: governance.normalized.tenantId ?? null,\n        userId: governance.normalized.userId ?? null,\n        agentId: governance.normalized.agentId ?? null,\n        sessionId: governance.normalized.sessionId ?? null,\n      }\n    : scope;\n  const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n    ? {\n        provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n        provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n        tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n      }\n    : undefined);\n\n  const result = await processPreparedMemory(prepared, filePath, {\n    force,\n    asyncEmbedding,\n    plannerMode,\n    origin: indexingOrigin,\n    persistQualityLoopContent: true,\n    refreshFromDiskAfterLock: parsedOverride !== null,\n    scope: effectiveScope,\n    qualityGateMode,\n    routing,\n    provenance: effectiveProvenance,\n  });\n\n  // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n  // direct memory_save path so governed bulk/scan/async ingests are not silently\n  // downgraded to ungoverned rows. Only for freshly written rows.\n  if (governance && typeof result.id === 'number' && result.id > 0\n    && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n  }\n\n  return result;\n}\n\nasync function indexMemoryFileFromScan(\n  filePath: string,\n  options: BaseIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    ...options,\n    origin: 'scan',\n  });\n}\n\n/* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n\n// Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n// entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n// slots free.\nconst MAX_BACKGROUND_ENRICHMENTS = 4;\nlet activeBackgroundEnrichments = 0;\nconst backgroundEnrichmentQueue: Array<() => void> = [];\n\n// Set during shutdown BEFORE closeDb. A deferred/queued enrichment run re-resolves the DB handle via\n// requireDb(), which REOPENS a closed connection — so without this fence a run firing during the\n// shutdown drain would reopen the DB and write fresh WAL frames after the TRUNCATE checkpoint, leaving\n// a non-empty WAL at rest and defeating the close durability guarantee. Same hazard the fileWatcher\n// and ingestWorker fences guard against.\nlet enrichmentShuttingDown = false;\n\n/**\n * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n * in-flight run bail before it touches the DB. Synchronous so fatalShutdown can call it in its\n * pre-close fence block, before any await lets a queued setImmediate run fire. Dropped rows remain\n * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n */\nexport function shutdownBackgroundEnrichment(): void {\n  enrichmentShuttingDown = true;\n  backgroundEnrichmentQueue.length = 0;\n}\n\n// Bound the OVERFLOW queue, not just concurrency. A sustained live-save flood (saves arriving faster\n// than the 4-wide drain) would otherwise grow the queue — and the parsed payload each entry retains —\n// without bound. On overflow we DROP rather than push: the row is enrichment-pending in the commit\n// transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n// scheduler visible through memory_health (otherwise a stuck scheduler is a silent enrichment outage).\nconst MAX_QUEUED_ENRICHMENTS = 2000;\nlet enrichmentDroppedTotal = 0;\nlet enrichmentFailureTotal = 0;\nlet enrichmentLastError: string | null = null;\nlet enrichmentLastErrorAt: string | null = null;\nlet enrichmentSuppressedWarnings = 0;\n\n/** Scheduler observability snapshot for memory_health — module-local counters only, no DB access. */\nexport function getBackgroundEnrichmentStats(): {\n  active: number;\n  queued: number;\n  max: number;\n  maxQueued: number;\n  droppedTotal: number;\n  failureTotal: number;\n  lastError: string | null;\n  lastErrorAt: string | null;\n} {\n  return {\n    active: activeBackgroundEnrichments,\n    queued: backgroundEnrichmentQueue.length,\n    max: MAX_BACKGROUND_ENRICHMENTS,\n    maxQueued: MAX_QUEUED_ENRICHMENTS,\n    droppedTotal: enrichmentDroppedTotal,\n    failureTotal: enrichmentFailureTotal,\n    lastError: enrichmentLastError,\n    lastErrorAt: enrichmentLastErrorAt,\n  };\n}\n\n/**\n * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n * - re-resolves the DB handle when the run starts (covers a recycle before the run begins; a recycle\n *   mid-run throws on the post-await write and the row falls back to the pending-marker backfill),\n * - skips rows that were superseded/deprecated before the deferred run starts, so it never\n *   repopulates purged entity/graph data for an inactive row,\n * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n *   skipped or dropped run is recovered by the pending-marker replay/backfill path.\n */\nfunction scheduleBackgroundEnrichment(\n  memoryId: number,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n): void {\n  if (enrichmentShuttingDown) return; // do not schedule new enrichment work during shutdown\n  // Reserve a slot and schedule on a macrotask. The counter MUST be incremented here, at schedule\n  // time — not inside the deferred callback. If it were bumped inside the callback, a burst (a startup\n  // scan calling this once per row) would race: every call reads the still-zero counter before any\n  // callback runs, all pass the cap, and unbounded setImmediate callbacks pile up that then drain as a\n  // synchronous microtask chain and starve the event loop, so the daemon's IPC accept() never runs.\n  // Re-arming dequeued work through setImmediate (rather than calling it inline from the finally)\n  // returns control to the poll phase between runs.\n  const start = (task: () => void): void => {\n    activeBackgroundEnrichments++;\n    // setImmediate (a MACROTASK boundary) is required here, not queueMicrotask: only a macrotask hands","lineStart":2830,"lineEnd":2999,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781763378286,"end":1781763378302}},"metadata":{"openai":{"itemId":"fc_0c42a1b9296254b9016a338d32262c8191ae6b7423a7a4ef83"}},"id":"prt_ed95f8c48001YXBepGXjl4heCq","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f6e260010iN1syd82sktaK"}}
{"type":"tool_use","timestamp":1781763378320,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_1DgYxMeBEu539KSnQSDTbbDa","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":3530,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n3530:           errors: preflightResult.errors,\n3531:           warnings: preflightResult.warnings,\n3532:           recoverable: true,\n3533:           suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n3534:         }\n3535:       );\n3536:     }\n3537: \n3538:     if (preflightResult.warnings.length > 0) {\n3539:       console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n3540:       preflightResult.warnings.forEach((w: string | { message: string }) => {\n3541:         const msg = typeof w === 'string' ? w : w.message;\n3542:         console.warn(`[preflight]   - ${msg}`);\n3543:       });\n3544:     }\n3545:   }\n3546: \n3547:   if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n3548:     try {\n3549:       const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n3550:       // The compared payload IS the fingerprint object: both lookup inputs\n3551:       // below point at this same idempotencySemantics value, so payloadHash\n3552:       // always equals requestFingerprintHash and the receiptKey is derived from\n3553:       // it. Consequence: distinct logical requests always produce distinct\n3554:       // keys, so the same-key/different-payload 'conflict' status can never fire\n3555:       // from this caller (a force-flip yields a key MISS, not a conflict). The\n3556:       // conflict branch below is fail-safe defense-in-depth, not active\n3557:       // protection. To make conflicts detectable, the payload would have to\n3558:       // carry MORE than the key material (e.g. execution-mode flags); it\n3559:       // deliberately does not, so a benign flag flip cannot become a false\n3560:       // hard conflict.\n3561:       const idempotencySemantics = {\n3562:         filePath: canonicalValidatedPath,\n3563:         contentHash: parsedForIdempotency.contentHash,\n3564:         routeAs: routeAs ?? null,\n3565:         mergeModeHint: mergeModeHint ?? null,\n3566:         targetAnchorId: targetAnchorId ?? null,\n3567:         scope: saveScope,\n3568:         // A force-flipped retry is a DIFFERENT logical request: keeping force in\n3569:         // the key material makes it a distinct key (a clean MISS that re-runs),\n3570:         // never a collision with the non-forced receipt.\n3571:         force: force === true,\n3572:       };\n3573:       const lookup = lookupIdempotencyReceipt(database, {\n3574:         operation: 'memory_save',\n3575:         contentHash: parsedForIdempotency.contentHash,\n3576:         requestFingerprint: idempotencySemantics,\n3577:         payload: idempotencySemantics,\n3578:       });\n3579:       idempotencyKey = lookup.key;\n3580:       if (lookup.status === 'replay') {\n3581:         // A receipt is a replay cache, not proof the cached response still\n3582:         // describes the live state. After an A->B->A revert the receipt for A\n3583:         // is intact but the active row now holds B (or, after deletion, a\n3584:         // superseded row), so replaying A's old response would diverge from\n3585:         // the index. Honor the replay ONLY when the active row for this logical\n3586:         // identity still carries the receipt's content_hash AND is the same row\n3587:         // the cached response reports. Content alone is insufficient: a planner\n3588:         // re-create of identical content (the planner branch skips this whole\n3589:         // block and never refreshes the receipt) produces a NEW id, so a\n3590:         // content-only match would replay a response naming a deleted id and\n3591:         // strand a follow-up update by that id. Mirror the handler's own\n3592:         // active-row identity (findSamePathExistingMemory) and exclude retired\n3593:         // tiers so a deprecated/archived predecessor cannot satisfy the match.\n3594:         const activeRow = database.prepare(`\n3595:           SELECT id, content_hash\n3596:           FROM memory_index\n3597:           WHERE spec_folder = ?\n3598:             AND parent_id IS NULL\n3599:             AND (canonical_file_path = ? OR file_path = ?)\n3600:             AND ${targetAnchorId != null ? 'anchor_id = ?' : 'anchor_id IS NULL'}\n3601:             AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n3602:             AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n3603:             AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n3604:             AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n3605:             AND COALESCE(importance_tier, 'normal') NOT IN ('deprecated', 'archived')\n3606:           ORDER BY id DESC\n3607:           LIMIT 1\n3608:         `).get(\n3609:           parsedForIdempotency.specFolder,\n3610:           canonicalValidatedPath,\n3611:           validatedPath,\n3612:           ...(targetAnchorId != null ? [targetAnchorId] : []),\n3613:           saveScope.tenantId ?? null, saveScope.tenantId ?? null,\n3614:           saveScope.userId ?? null, saveScope.userId ?? null,\n3615:           saveScope.agentId ?? null, saveScope.agentId ?? null,\n3616:           saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n3617:         ) as { id: number; content_hash: string } | undefined;\n3618: \n3619:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n3620:         if (\n3621:           activeRow\n3622:           && activeRow.content_hash === lookup.key.contentHash\n3623:           && (replayMemoryId == null || activeRow.id === replayMemoryId)\n3624:         ) {\n3625:           return lookup.response;\n3626:         }\n3627:         // Stale receipt for this attempt: drop the cache entry so the\n3628:         // re-indexed write stores its current response (the post-write store\n3629:         // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n3630:         // the stale receipt), then fall through to the normal save/reindex path.\n3631:         deleteIdempotencyReceiptByKey(database, lookup.key);\n3632:       } else if (lookup.status === 'conflict') {\n3633:         // Unreachable from this caller: payload === requestFingerprint (above),\n3634:         // so a key match implies a payload match and lookup never returns\n3635:         // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n3636:         // material and payload ever diverge.\n3637:         return createMCPErrorResponse({\n3638:           tool: 'memory_save',\n3639:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n3640:           code: 'idempotency_key_conflict',\n3641:           details: { requestId, receiptKey: lookup.key.receiptKey },\n3642:           recovery: {\n3643:             hint: 'Retry the original byte-identical request or submit a fresh logical write.',\n3644:             severity: 'warning',\n3645:           },\n3646:         });\n3647:       }\n3648:     } catch (error: unknown) {\n3649:       const message = error instanceof Error ? error.message : String(error);\n3650:       console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n3651:       idempotencyKey = null;\n3652:     }\n3653:   }\n3654: \n3655:   if (shouldPlanCanonicalSave) {\n3656:     const plannerResult = await atomicSaveMemory({\n3657:       file_path: validatedPath,\n3658:       content: fs.readFileSync(validatedPath, 'utf8'),\n3659:       plannerMode,\n3660:       ...(routeAs ? { routeAs } : {}),\n3661:       ...(mergeModeHint ? { mergeModeHint } : {}),\n3662:       ...(targetAnchorId ? { targetAnchorId } : {}),\n3663:     }, { force });\n3664: \n3665:     return buildPlannerResponse({\n3666:       planner: {\n3667:         filePath: validatedPath,\n3668:         specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n3669:         title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n3670:         status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n3671:         message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n3672:         plannerMode: 'plan-only',\n3673:         routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n3674:           routeCategory: routeAs ?? 'drop',\n3675:           targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n3676:           targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n3677:           mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n3678:         }),\n3679:         proposedEdits: plannerResult.proposedEdits ?? [],\n3680:         blockers: plannerResult.blockers ?? [],\n3681:         advisories: plannerResult.advisories ?? [],\n3682:         followUpActions: plannerResult.followUpActions ?? [],\n3683:       },\n3684:     });\n3685:   }\n3686: \n3687:   let result: IndexResult;\n3688:   try {\n3689:     result = await indexMemoryFile(validatedPath, {\n3690:       force,\n3691:       parsedOverride: parsedForPreflight,\n3692:       asyncEmbedding,\n3693:       plannerMode,\n3694:       scope: saveScope,\n3695:       routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n3696:       provenance: (provenanceSource || provenanceActor)\n3697:         ? { provenanceSource, provenanceActor, tool: 'memory_save' }\n3698:         : undefined,\n3699:     });\n3700:   } catch (error: unknown) {\n3701:     if (error instanceof VRuleUnavailableError) {\n3702:       return createMCPErrorResponse({\n3703:         tool: 'memory_save',\n3704:         error: error.message,\n3705:         code: 'E_RUNTIME',\n3706:         details: { requestId },\n3707:         recovery: {\n3708:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3709:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3710:           severity: 'warning',\n3711:         },\n3712:       });\n3713:     }\n3714:     // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n3715:     // response code points at the actual failure mode instead of the generic E081 catch-all.\n3716:     const indexErrorMessage = error instanceof Error ? error.message : String(error);\n3717:     return createMCPErrorResponse({\n3718:       tool: 'memory_save',\n3719:       error: indexErrorMessage,\n3720:       code: classifySaveErrorCode(indexErrorMessage),\n3721:       details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n3722:       recovery: {\n3723:         hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n3724:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3725:         severity: 'warning',\n3726:       },\n3727:     });\n3728:   }\n3729: \n3730:   if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n3731:     // Wrap governance metadata in a transaction with rollback on failure.\n3732:     // If governance application fails, delete the orphaned memory row to prevent\n3733:     // persisted rows without tenant/session/retention metadata.\n3734:     const applyGovernanceTx = database.transaction(() => {\n3735:       applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n3736:       recordGovernanceAudit(database, {\n3737:         action: 'memory_save',\n3738:         decision: 'allow',\n3739:         memoryId: result.id,\n3740:         tenantId,\n3741:         userId,\n3742:         agentId,\n3743:         sessionId,\n3744:         reason: 'governed_ingest',\n3745:         metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n3746:       });\n3747:     });\n3748:     try {\n3749:       applyGovernanceTx();\n3750:     } catch (govErr: unknown) {\n3751:       // C2 FIX: Use full delete helper to clean up ALL ancillary records\n3752:       // (vec_memories, BM25 index, causal edges, projections, etc.)\n3753:       // not just memory_index, to prevent orphaned search phantoms.\n3754:       const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n3755:       console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n3756:       try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n3757:       // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n3758:       // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n3759:       // generic E081 catch-all.\n3760:       return createMCPErrorResponse({\n3761:         tool: 'memory_save',\n3762:         error: govErrorMessage,\n3763:         code: classifySaveErrorCode(govErrorMessage),\n3764:         details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n3765:         recovery: {\n3766:           hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n3767:           actions: ['Resolve the reported cause', 'Retry memory_save'],\n3768:           severity: 'warning',\n3769:         },\n3770:       });\n3771:     }\n3772:   }\n3773: \n3774:   const response = buildSaveResponse({ result, filePath: file_path, asyncEmbedding, requestId });\n3775:   if (idempotencyKey && shouldStoreMemorySaveReceipt(result, response)) {\n3776:     try {\n3777:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n3778:       if (!won) {\n3779:         // A concurrent same-key save already stored the canonical receipt. Replay the\n3780:         // first winner's response so this mutating loser returns the idempotent result\n3781:         // instead of its own separately-created response.\n3782:         const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n3783:         if (winner.status === 'replay') {\n3784:           return winner.response;\n3785:         }\n3786:         if (winner.status === 'conflict') {\n3787:           // Different-payload winner: this loser's mutation landed, so an\n3788:           // error would lie and replaying the winner would answer a\n3789:           // different request — return the loser's response with the\n3790:           // conflict made visible instead of silent.\n3791:           return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n3792:         }\n3793:       }\n3794:     } catch (error: unknown) {\n3795:       const message = error instanceof Error ? error.message : String(error);\n3796:       console.warn(`[memory-save] idempotency receipt store failed; continuing without replay receipt: ${message}`);\n3797:     }\n3798:   }\n3799:   return response;\n3800: }\n3801: \n3802: /* --- 10. ATOMIC MEMORY SAVE --- */\n3803: \n3804: /**\n3805:  * Save memory content to disk with retry + rollback guarded indexing.\n3806:  *\n3807:  * The file write promotes a pending file while holding the per-spec-folder\n3808:  * mutex so concurrent saves cannot overwrite each other between disk\n3809:  * promotion and indexing. If indexing later fails, the original file content\n3810:  * is restored before the error is returned and before the lock is released.\n3811:  */\n3812: async function atomicSaveMemory(params: AtomicSaveParams, options: AtomicSaveOptions = {}): Promise<AtomicSaveResult> {\n3813:   // Scrub once at the entry so every durably persisted artifact (canonical\n3814:   // markdown, continuity merge, pending-file promotion) carries redacted text,\n3815:   // not only the parsed/index copy the parser scrubs. Fail-closed: a scrubber\n3816:   // failure throws and refuses the write rather than persisting raw content.\n3817:   if (typeof params.content === 'string' && params.content.length > 0) {\n3818:     const scrubResult = scrubSecretsDetailed(params.content);\n3819:     if (scrubResult.redactions > 0) {\n3820:       console.warn(\n3821:         `[memory-save] Redacted ${scrubResult.redactions} secret(s) [${scrubResult.kinds.join(', ')}] before durable save`,\n3822:       );\n3823:       params = { ...params, content: scrubResult.text };\n3824:     }\n3825:   }\n3826:   const { file_path, routeAs, mergeModeHint, targetAnchorId } = params;\n3827:   const database = requireDb();\n3828:   const routing = buildRoutedSaveOptions(file_path, routeAs, mergeModeHint, targetAnchorId);\n3829:   const plannerMode = params.plannerMode ?? resolveSavePlannerMode();\n\n(Showing lines 3530-3829 of 4082. Use offset=3830 to continue.)\n</content>","metadata":{"preview":"          errors: preflightResult.errors,\n          warnings: preflightResult.warnings,\n          recoverable: true,\n          suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n        }\n      );\n    }\n\n    if (preflightResult.warnings.length > 0) {\n      console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n      preflightResult.warnings.forEach((w: string | { message: string }) => {\n        const msg = typeof w === 'string' ? w : w.message;\n        console.warn(`[preflight]   - ${msg}`);\n      });\n    }\n  }\n\n  if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n    try {\n      const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"          errors: preflightResult.errors,\n          warnings: preflightResult.warnings,\n          recoverable: true,\n          suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n        }\n      );\n    }\n\n    if (preflightResult.warnings.length > 0) {\n      console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n      preflightResult.warnings.forEach((w: string | { message: string }) => {\n        const msg = typeof w === 'string' ? w : w.message;\n        console.warn(`[preflight]   - ${msg}`);\n      });\n    }\n  }\n\n  if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n    try {\n      const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n      // The compared payload IS the fingerprint object: both lookup inputs\n      // below point at this same idempotencySemantics value, so payloadHash\n      // always equals requestFingerprintHash and the receiptKey is derived from\n      // it. Consequence: distinct logical requests always produce distinct\n      // keys, so the same-key/different-payload 'conflict' status can never fire\n      // from this caller (a force-flip yields a key MISS, not a conflict). The\n      // conflict branch below is fail-safe defense-in-depth, not active\n      // protection. To make conflicts detectable, the payload would have to\n      // carry MORE than the key material (e.g. execution-mode flags); it\n      // deliberately does not, so a benign flag flip cannot become a false\n      // hard conflict.\n      const idempotencySemantics = {\n        filePath: canonicalValidatedPath,\n        contentHash: parsedForIdempotency.contentHash,\n        routeAs: routeAs ?? null,\n        mergeModeHint: mergeModeHint ?? null,\n        targetAnchorId: targetAnchorId ?? null,\n        scope: saveScope,\n        // A force-flipped retry is a DIFFERENT logical request: keeping force in\n        // the key material makes it a distinct key (a clean MISS that re-runs),\n        // never a collision with the non-forced receipt.\n        force: force === true,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_save',\n        contentHash: parsedForIdempotency.contentHash,\n        requestFingerprint: idempotencySemantics,\n        payload: idempotencySemantics,\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live state. After an A->B->A revert the receipt for A\n        // is intact but the active row now holds B (or, after deletion, a\n        // superseded row), so replaying A's old response would diverge from\n        // the index. Honor the replay ONLY when the active row for this logical\n        // identity still carries the receipt's content_hash AND is the same row\n        // the cached response reports. Content alone is insufficient: a planner\n        // re-create of identical content (the planner branch skips this whole\n        // block and never refreshes the receipt) produces a NEW id, so a\n        // content-only match would replay a response naming a deleted id and\n        // strand a follow-up update by that id. Mirror the handler's own\n        // active-row identity (findSamePathExistingMemory) and exclude retired\n        // tiers so a deprecated/archived predecessor cannot satisfy the match.\n        const activeRow = database.prepare(`\n          SELECT id, content_hash\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND parent_id IS NULL\n            AND (canonical_file_path = ? OR file_path = ?)\n            AND ${targetAnchorId != null ? 'anchor_id = ?' : 'anchor_id IS NULL'}\n            AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n            AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n            AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n            AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n            AND COALESCE(importance_tier, 'normal') NOT IN ('deprecated', 'archived')\n          ORDER BY id DESC\n          LIMIT 1\n        `).get(\n          parsedForIdempotency.specFolder,\n          canonicalValidatedPath,\n          validatedPath,\n          ...(targetAnchorId != null ? [targetAnchorId] : []),\n          saveScope.tenantId ?? null, saveScope.tenantId ?? null,\n          saveScope.userId ?? null, saveScope.userId ?? null,\n          saveScope.agentId ?? null, saveScope.agentId ?? null,\n          saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n        ) as { id: number; content_hash: string } | undefined;\n\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          activeRow\n          && activeRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || activeRow.id === replayMemoryId)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the\n        // re-indexed write stores its current response (the post-write store\n        // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n        // the stale receipt), then fall through to the normal save/reindex path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload === requestFingerprint (above),\n        // so a key match implies a payload match and lookup never returns\n        // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n        // material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_save',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical write.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n      idempotencyKey = null;\n    }\n  }\n\n  if (shouldPlanCanonicalSave) {\n    const plannerResult = await atomicSaveMemory({\n      file_path: validatedPath,\n      content: fs.readFileSync(validatedPath, 'utf8'),\n      plannerMode,\n      ...(routeAs ? { routeAs } : {}),\n      ...(mergeModeHint ? { mergeModeHint } : {}),\n      ...(targetAnchorId ? { targetAnchorId } : {}),\n    }, { force });\n\n    return buildPlannerResponse({\n      planner: {\n        filePath: validatedPath,\n        specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n        title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n        status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n        message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n        plannerMode: 'plan-only',\n        routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n          routeCategory: routeAs ?? 'drop',\n          targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n          targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n          mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n        }),\n        proposedEdits: plannerResult.proposedEdits ?? [],\n        blockers: plannerResult.blockers ?? [],\n        advisories: plannerResult.advisories ?? [],\n        followUpActions: plannerResult.followUpActions ?? [],\n      },\n    });\n  }\n\n  let result: IndexResult;\n  try {\n    result = await indexMemoryFile(validatedPath, {\n      force,\n      parsedOverride: parsedForPreflight,\n      asyncEmbedding,\n      plannerMode,\n      scope: saveScope,\n      routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n      provenance: (provenanceSource || provenanceActor)\n        ? { provenanceSource, provenanceActor, tool: 'memory_save' }\n        : undefined,\n    });\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n    // response code points at the actual failure mode instead of the generic E081 catch-all.\n    const indexErrorMessage = error instanceof Error ? error.message : String(error);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: indexErrorMessage,\n      code: classifySaveErrorCode(indexErrorMessage),\n      details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    // Wrap governance metadata in a transaction with rollback on failure.\n    // If governance application fails, delete the orphaned memory row to prevent\n    // persisted rows without tenant/session/retention metadata.\n    const applyGovernanceTx = database.transaction(() => {\n      applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n      recordGovernanceAudit(database, {\n        action: 'memory_save',\n        decision: 'allow',\n        memoryId: result.id,\n        tenantId,\n        userId,\n        agentId,\n        sessionId,\n        reason: 'governed_ingest',\n        metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n      });\n    });\n    try {\n      applyGovernanceTx();\n    } catch (govErr: unknown) {\n      // C2 FIX: Use full delete helper to clean up ALL ancillary records\n      // (vec_memories, BM25 index, causal edges, projections, etc.)\n      // not just memory_index, to prevent orphaned search phantoms.\n      const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n      console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n      try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n      // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n      // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n      // generic E081 catch-all.\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: govErrorMessage,\n        code: classifySaveErrorCode(govErrorMessage),\n        details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n        recovery: {\n          hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n          actions: ['Resolve the reported cause', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  const response = buildSaveResponse({ result, filePath: file_path, asyncEmbedding, requestId });\n  if (idempotencyKey && shouldStoreMemorySaveReceipt(result, response)) {\n    try {\n      const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n      if (!won) {\n        // A concurrent same-key save already stored the canonical receipt. Replay the\n        // first winner's response so this mutating loser returns the idempotent result\n        // instead of its own separately-created response.\n        const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n        if (winner.status === 'replay') {\n          return winner.response;\n        }\n        if (winner.status === 'conflict') {\n          // Different-payload winner: this loser's mutation landed, so an\n          // error would lie and replaying the winner would answer a\n          // different request — return the loser's response with the\n          // conflict made visible instead of silent.\n          return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n        }\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(`[memory-save] idempotency receipt store failed; continuing without replay receipt: ${message}`);\n    }\n  }\n  return response;\n}\n\n/* --- 10. ATOMIC MEMORY SAVE --- */\n\n/**\n * Save memory content to disk with retry + rollback guarded indexing.\n *\n * The file write promotes a pending file while holding the per-spec-folder\n * mutex so concurrent saves cannot overwrite each other between disk\n * promotion and indexing. If indexing later fails, the original file content\n * is restored before the error is returned and before the lock is released.\n */\nasync function atomicSaveMemory(params: AtomicSaveParams, options: AtomicSaveOptions = {}): Promise<AtomicSaveResult> {\n  // Scrub once at the entry so every durably persisted artifact (canonical\n  // markdown, continuity merge, pending-file promotion) carries redacted text,\n  // not only the parsed/index copy the parser scrubs. Fail-closed: a scrubber\n  // failure throws and refuses the write rather than persisting raw content.\n  if (typeof params.content === 'string' && params.content.length > 0) {\n    const scrubResult = scrubSecretsDetailed(params.content);\n    if (scrubResult.redactions > 0) {\n      console.warn(\n        `[memory-save] Redacted ${scrubResult.redactions} secret(s) [${scrubResult.kinds.join(', ')}] before durable save`,\n      );\n      params = { ...params, content: scrubResult.text };\n    }\n  }\n  const { file_path, routeAs, mergeModeHint, targetAnchorId } = params;\n  const database = requireDb();\n  const routing = buildRoutedSaveOptions(file_path, routeAs, mergeModeHint, targetAnchorId);\n  const plannerMode = params.plannerMode ?? resolveSavePlannerMode();","lineStart":3530,"lineEnd":3829,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781763378305,"end":1781763378318}},"metadata":{"openai":{"itemId":"fc_0c42a1b9296254b9016a338d32263481918159a89285877cb7"}},"id":"prt_ed95f8c70001De0xAa4ZaAspC7","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f6e260010iN1syd82sktaK"}}
{"type":"tool_use","timestamp":1781763378340,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_wL5N1opdP6DOxQXdlR1du4z5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Post Insert Metadata\n3: // ───────────────────────────────────────────────────────────────\n4: // Shared post-insert metadata updates extracted from handlers/save\n5: // so storage-layer writers do not depend on handler modules.\n6: \n7: import type Database from 'better-sqlite3';\n8: import {\n9:   buildGovernanceLogicalKey,\n10:   recordTierDowngradeAudit,\n11: } from '../governance/scope-governance.js';\n12: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n13: \n14: // ───────────────────────────────────────────────────────────────\n15: // 1. TYPES\n16: // ───────────────────────────────────────────────────────────────\n17: \n18: /**\n19:  * Field map accepted by the post-insert metadata update helper.\n20:  * Keys align to the guarded `memory_index` columns below.\n21:  */\n22: export interface PostInsertMetadataFields {\n23:   content_hash?: string;\n24:   context_type?: string;\n25:   importance_tier?: string;\n26:   memory_type?: string;\n27:   type_inference_source?: string;\n28:   stability?: number;\n29:   difficulty?: number;\n30:   review_count?: number;\n31:   file_mtime_ms?: number | null;\n32:   embedding_status?: string;\n33:   encoding_intent?: string | null;\n34:   document_type?: string;\n35:   spec_level?: number | null;\n36:   quality_score?: number;\n37:   quality_flags?: string;\n38:   parent_id?: number;\n39:   chunk_index?: number;\n40:   chunk_label?: string;\n41:   tenant_id?: string;\n42:   user_id?: string;\n43:   agent_id?: string;\n44:   session_id?: string;\n45:   provenance_source?: string;\n46:   provenance_actor?: string;\n47:   governed_at?: string;\n48:   retention_policy?: string;\n49:   delete_after?: string | null;\n50:   governance_metadata?: string;\n51: }\n52: \n53: // ───────────────────────────────────────────────────────────────\n54: // 2. CONSTANTS\n55: // ───────────────────────────────────────────────────────────────\n56: \n57: /** Allowed column names for the dynamic UPDATE builder (injection guard). */\n58: export const ALLOWED_POST_INSERT_COLUMNS = new Set<string>([\n59:   'content_hash', 'context_type', 'importance_tier', 'memory_type',\n60:   'type_inference_source', 'stability', 'difficulty', 'review_count',\n61:   'file_mtime_ms', 'embedding_status', 'encoding_intent', 'document_type',\n62:   'spec_level', 'quality_score', 'quality_flags', 'parent_id',\n63:   'chunk_index', 'chunk_label', 'tenant_id', 'user_id', 'agent_id',\n64:   'session_id',\n65:   'provenance_source', 'provenance_actor',\n66:   'governed_at', 'retention_policy', 'delete_after', 'governance_metadata',\n67: ]);\n68: \n69: // ───────────────────────────────────────────────────────────────\n70: // 3. HELPERS\n71: // ───────────────────────────────────────────────────────────────\n72: \n73: /**\n74:  * Build and execute a dynamic `UPDATE memory_index SET ... WHERE id = ?`\n75:  * from the supplied field map.\n76:  *\n77:  * Special handling:\n78:  * - `encoding_intent` uses `COALESCE(?, encoding_intent)`\n79:  * - `last_review` is always refreshed to `datetime('now')`\n80:  *\n81:  * @param db - Database connection that stores memory rows.\n82:  * @param memoryId - Inserted memory identifier to enrich.\n83:  * @param fields - Column/value map for the metadata update.\n84:  */\n85: export function applyPostInsertMetadata(\n86:   db: Database.Database,\n87:   memoryId: number,\n88:   fields: PostInsertMetadataFields,\n89: ): void {\n90:   const normalizedFields: PostInsertMetadataFields = { ...fields };\n91:   if (normalizedFields.importance_tier === 'constitutional') {\n92:     const row = db.prepare(`\n93:       SELECT spec_folder, anchor_id, file_path, canonical_file_path\n94:       FROM memory_index\n95:       WHERE id = ?\n96:     `).get(memoryId) as {\n97:       spec_folder: string | null;\n98:       anchor_id: string | null;\n99:       file_path: string | null;\n100:       canonical_file_path: string | null;\n101:     } | undefined;\n102: \n103:     const guardPath = row?.canonical_file_path || row?.file_path || null;\n104:     if (guardPath && !isIndexableConstitutionalMemoryPath(guardPath)) {\n105:       normalizedFields.importance_tier = 'important';\n106:       try {\n107:         recordTierDowngradeAudit(db, {\n108:           memoryId,\n109:           logicalKey: buildGovernanceLogicalKey(row?.spec_folder, guardPath, row?.anchor_id),\n110:           requestedTier: 'constitutional',\n111:           nextTier: 'important',\n112:           source: 'applyPostInsertMetadata',\n113:           filePath: row?.file_path ?? null,\n114:           canonicalFilePath: row?.canonical_file_path ?? null,\n115:         });\n116:       } catch (error: unknown) {\n117:         console.warn(\n118:           '[post-insert-metadata] governance_audit insert failed for tier downgrade:',\n119:           error instanceof Error ? error.message : String(error),\n120:         );\n121:       }\n122:     }\n123:   }\n124: \n125:   const setClauses: string[] = [];\n126:   const values: unknown[] = [];\n127: \n128:   for (const [col, val] of Object.entries(normalizedFields)) {\n129:     if (val === undefined) continue;\n130:     if (!ALLOWED_POST_INSERT_COLUMNS.has(col)) continue;\n131: \n132:     if (col === 'encoding_intent') {\n133:       setClauses.push('encoding_intent = COALESCE(?, encoding_intent)');\n134:     } else {\n135:       setClauses.push(`${col} = ?`);\n136:     }\n137:     values.push(val);\n138:   }\n139: \n140:   setClauses.push(\"last_review = datetime('now')\");\n141: \n142:   values.push(memoryId);\n143: \n144:   db.prepare(`\n145:     UPDATE memory_index\n146:     SET ${setClauses.join(',\\n        ')}\n147:     WHERE id = ?\n148:   `).run(...values);\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Post Insert Metadata\n// ───────────────────────────────────────────────────────────────\n// Shared post-insert metadata updates extracted from handlers/save\n// so storage-layer writers do not depend on handler modules.\n\nimport type Database from 'better-sqlite3';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Field map accepted by the post-insert metadata update helper.\n * Keys align to the guarded `memory_index` columns below.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Post Insert Metadata\n// ───────────────────────────────────────────────────────────────\n// Shared post-insert metadata updates extracted from handlers/save\n// so storage-layer writers do not depend on handler modules.\n\nimport type Database from 'better-sqlite3';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Field map accepted by the post-insert metadata update helper.\n * Keys align to the guarded `memory_index` columns below.\n */\nexport interface PostInsertMetadataFields {\n  content_hash?: string;\n  context_type?: string;\n  importance_tier?: string;\n  memory_type?: string;\n  type_inference_source?: string;\n  stability?: number;\n  difficulty?: number;\n  review_count?: number;\n  file_mtime_ms?: number | null;\n  embedding_status?: string;\n  encoding_intent?: string | null;\n  document_type?: string;\n  spec_level?: number | null;\n  quality_score?: number;\n  quality_flags?: string;\n  parent_id?: number;\n  chunk_index?: number;\n  chunk_label?: string;\n  tenant_id?: string;\n  user_id?: string;\n  agent_id?: string;\n  session_id?: string;\n  provenance_source?: string;\n  provenance_actor?: string;\n  governed_at?: string;\n  retention_policy?: string;\n  delete_after?: string | null;\n  governance_metadata?: string;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────\n\n/** Allowed column names for the dynamic UPDATE builder (injection guard). */\nexport const ALLOWED_POST_INSERT_COLUMNS = new Set<string>([\n  'content_hash', 'context_type', 'importance_tier', 'memory_type',\n  'type_inference_source', 'stability', 'difficulty', 'review_count',\n  'file_mtime_ms', 'embedding_status', 'encoding_intent', 'document_type',\n  'spec_level', 'quality_score', 'quality_flags', 'parent_id',\n  'chunk_index', 'chunk_label', 'tenant_id', 'user_id', 'agent_id',\n  'session_id',\n  'provenance_source', 'provenance_actor',\n  'governed_at', 'retention_policy', 'delete_after', 'governance_metadata',\n]);\n\n// ───────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Build and execute a dynamic `UPDATE memory_index SET ... WHERE id = ?`\n * from the supplied field map.\n *\n * Special handling:\n * - `encoding_intent` uses `COALESCE(?, encoding_intent)`\n * - `last_review` is always refreshed to `datetime('now')`\n *\n * @param db - Database connection that stores memory rows.\n * @param memoryId - Inserted memory identifier to enrich.\n * @param fields - Column/value map for the metadata update.\n */\nexport function applyPostInsertMetadata(\n  db: Database.Database,\n  memoryId: number,\n  fields: PostInsertMetadataFields,\n): void {\n  const normalizedFields: PostInsertMetadataFields = { ...fields };\n  if (normalizedFields.importance_tier === 'constitutional') {\n    const row = db.prepare(`\n      SELECT spec_folder, anchor_id, file_path, canonical_file_path\n      FROM memory_index\n      WHERE id = ?\n    `).get(memoryId) as {\n      spec_folder: string | null;\n      anchor_id: string | null;\n      file_path: string | null;\n      canonical_file_path: string | null;\n    } | undefined;\n\n    const guardPath = row?.canonical_file_path || row?.file_path || null;\n    if (guardPath && !isIndexableConstitutionalMemoryPath(guardPath)) {\n      normalizedFields.importance_tier = 'important';\n      try {\n        recordTierDowngradeAudit(db, {\n          memoryId,\n          logicalKey: buildGovernanceLogicalKey(row?.spec_folder, guardPath, row?.anchor_id),\n          requestedTier: 'constitutional',\n          nextTier: 'important',\n          source: 'applyPostInsertMetadata',\n          filePath: row?.file_path ?? null,\n          canonicalFilePath: row?.canonical_file_path ?? null,\n        });\n      } catch (error: unknown) {\n        console.warn(\n          '[post-insert-metadata] governance_audit insert failed for tier downgrade:',\n          error instanceof Error ? error.message : String(error),\n        );\n      }\n    }\n  }\n\n  const setClauses: string[] = [];\n  const values: unknown[] = [];\n\n  for (const [col, val] of Object.entries(normalizedFields)) {\n    if (val === undefined) continue;\n    if (!ALLOWED_POST_INSERT_COLUMNS.has(col)) continue;\n\n    if (col === 'encoding_intent') {\n      setClauses.push('encoding_intent = COALESCE(?, encoding_intent)');\n    } else {\n      setClauses.push(`${col} = ?`);\n    }\n    values.push(val);\n  }\n\n  setClauses.push(\"last_review = datetime('now')\");\n\n  values.push(memoryId);\n\n  db.prepare(`\n    UPDATE memory_index\n    SET ${setClauses.join(',\\n        ')}\n    WHERE id = ?\n  `).run(...values);\n}","lineStart":1,"lineEnd":149,"totalLines":149,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/post-insert-metadata.ts","time":{"start":1781763378332,"end":1781763378339}},"metadata":{"openai":{"itemId":"fc_0c42a1b9296254b9016a338d32263c8191b7e65dac103d83a1"}},"id":"prt_ed95f8c83001H8cxO7Wq1OPoMY","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f6e260010iN1syd82sktaK"}}
