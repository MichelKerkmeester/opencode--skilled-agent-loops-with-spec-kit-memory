{"type":"step_start","timestamp":1781764288464,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"id":"prt_ed96d6fcd001iT75R4lqGp5S6n","messageID":"msg_ed96d672a001h7N3UgLa0BSaZf","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","snapshot":"ee3085200a722852b866a080fe30a77730c1d3c4","type":"step-start"}}
{"type":"text","timestamp":1781764292523,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"id":"prt_ed96d7c67001oJkKltWOfOfDXq","messageID":"msg_ed96d672a001h7N3UgLa0BSaZf","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","type":"text","text":"A second candidate surfaced in async ingest: the worker treats `processFile` completion as success, while the configured `processFile` ignores `indexSingleFile`вҖҷs returned status. IвҖҷm reading `indexMemoryFile` to confirm whether failures are returned rather than thrown.","time":{"start":1781764291687,"end":1781764292522},"metadata":{"openai":{"itemId":"msg_0ccf25a65e9d2ae5016a3390c3a6e081919374b95e5815109a","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781764293908,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_2mqV8ZzTBwbGqxdOpQWddj9P","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2820,"limit":950},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2820: };\n2821: \n2822: type IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n2823:   origin?: IndexingOrigin;\n2824:   fromScan?: never;\n2825: };\n2826: \n2827: type LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n2828:   fromScan?: boolean;\n2829:   origin?: never;\n2830: };\n2831: \n2832: /** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\n2833: async function indexMemoryFile(\n2834:   filePath: string,\n2835:   {\n2836:     force = false,\n2837:     parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n2838:     asyncEmbedding = false,\n2839:     plannerMode,\n2840:     scope = {} as MemoryScopeMatch,\n2841:     qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n2842:     routing,\n2843:     provenance,\n2844:     governance,\n2845:     ...originOptions\n2846:   }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n2847: ): Promise<IndexResult> {\n2848:   // Reuse parsed content when provided by caller to avoid a second parse.\n2849:   const indexingOrigin = resolveIndexingOrigin(originOptions);\n2850:   const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n2851:   const database = requireDb();\n2852:   const prepared = prepareParsedMemoryForIndexing(parsed, database);\n2853:   const validation = prepared.validation;\n2854:   if (!validation.valid) {\n2855:     throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n2856:   }\n2857:   if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n2858:     console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n2859:   }\n2860: \n2861:   // When a governance decision is threaded in (bulk scan/ingest), derive the\n2862:   // scope tuple from it so the row is created under the governed scope, matching\n2863:   // how the direct save path seeds saveScope from governanceDecision.normalized.\n2864:   const effectiveScope: MemoryScopeMatch = governance\n2865:     ? {\n2866:         tenantId: governance.normalized.tenantId ?? null,\n2867:         userId: governance.normalized.userId ?? null,\n2868:         agentId: governance.normalized.agentId ?? null,\n2869:         sessionId: governance.normalized.sessionId ?? null,\n2870:       }\n2871:     : scope;\n2872:   const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n2873:     ? {\n2874:         provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n2875:         provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n2876:         tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n2877:       }\n2878:     : undefined);\n2879: \n2880:   const result = await processPreparedMemory(prepared, filePath, {\n2881:     force,\n2882:     asyncEmbedding,\n2883:     plannerMode,\n2884:     origin: indexingOrigin,\n2885:     persistQualityLoopContent: true,\n2886:     refreshFromDiskAfterLock: parsedOverride !== null,\n2887:     scope: effectiveScope,\n2888:     qualityGateMode,\n2889:     routing,\n2890:     provenance: effectiveProvenance,\n2891:   });\n2892: \n2893:   // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n2894:   // direct memory_save path so governed bulk/scan/async ingests are not silently\n2895:   // downgraded to ungoverned rows. Only for freshly written rows.\n2896:   if (governance && typeof result.id === 'number' && result.id > 0\n2897:     && result.status !== 'unchanged' && result.status !== 'duplicate') {\n2898:     applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n2899:   }\n2900: \n2901:   return result;\n2902: }\n2903: \n2904: async function indexMemoryFileFromScan(\n2905:   filePath: string,\n2906:   options: BaseIndexMemoryFileOptions = {},\n2907: ): Promise<IndexResult> {\n2908:   return indexMemoryFile(filePath, {\n2909:     ...options,\n2910:     origin: 'scan',\n2911:   });\n2912: }\n2913: \n2914: /* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n2915: \n2916: // Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n2917: // entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n2918: // slots free.\n2919: const MAX_BACKGROUND_ENRICHMENTS = 4;\n2920: let activeBackgroundEnrichments = 0;\n2921: const backgroundEnrichmentQueue: Array<() => void> = [];\n2922: \n2923: // Set during shutdown BEFORE closeDb. A deferred/queued enrichment run re-resolves the DB handle via\n2924: // requireDb(), which REOPENS a closed connection вҖ” so without this fence a run firing during the\n2925: // shutdown drain would reopen the DB and write fresh WAL frames after the TRUNCATE checkpoint, leaving\n2926: // a non-empty WAL at rest and defeating the close durability guarantee. Same hazard the fileWatcher\n2927: // and ingestWorker fences guard against.\n2928: let enrichmentShuttingDown = false;\n2929: \n2930: /**\n2931:  * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n2932:  * in-flight run bail before it touches the DB. Synchronous so fatalShutdown can call it in its\n2933:  * pre-close fence block, before any await lets a queued setImmediate run fire. Dropped rows remain\n2934:  * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n2935:  */\n2936: export function shutdownBackgroundEnrichment(): void {\n2937:   enrichmentShuttingDown = true;\n2938:   backgroundEnrichmentQueue.length = 0;\n2939: }\n2940: \n2941: // Bound the OVERFLOW queue, not just concurrency. A sustained live-save flood (saves arriving faster\n2942: // than the 4-wide drain) would otherwise grow the queue вҖ” and the parsed payload each entry retains вҖ”\n2943: // without bound. On overflow we DROP rather than push: the row is enrichment-pending in the commit\n2944: // transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n2945: // scheduler visible through memory_health (otherwise a stuck scheduler is a silent enrichment outage).\n2946: const MAX_QUEUED_ENRICHMENTS = 2000;\n2947: let enrichmentDroppedTotal = 0;\n2948: let enrichmentFailureTotal = 0;\n2949: let enrichmentLastError: string | null = null;\n2950: let enrichmentLastErrorAt: string | null = null;\n2951: let enrichmentSuppressedWarnings = 0;\n2952: \n2953: /** Scheduler observability snapshot for memory_health вҖ” module-local counters only, no DB access. */\n2954: export function getBackgroundEnrichmentStats(): {\n2955:   active: number;\n2956:   queued: number;\n2957:   max: number;\n2958:   maxQueued: number;\n2959:   droppedTotal: number;\n2960:   failureTotal: number;\n2961:   lastError: string | null;\n2962:   lastErrorAt: string | null;\n2963: } {\n2964:   return {\n2965:     active: activeBackgroundEnrichments,\n2966:     queued: backgroundEnrichmentQueue.length,\n2967:     max: MAX_BACKGROUND_ENRICHMENTS,\n2968:     maxQueued: MAX_QUEUED_ENRICHMENTS,\n2969:     droppedTotal: enrichmentDroppedTotal,\n2970:     failureTotal: enrichmentFailureTotal,\n2971:     lastError: enrichmentLastError,\n2972:     lastErrorAt: enrichmentLastErrorAt,\n2973:   };\n2974: }\n2975: \n2976: /**\n2977:  * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n2978:  * - re-resolves the DB handle when the run starts (covers a recycle before the run begins; a recycle\n2979:  *   mid-run throws on the post-await write and the row falls back to the pending-marker backfill),\n2980:  * - skips rows that were superseded/deprecated before the deferred run starts, so it never\n2981:  *   repopulates purged entity/graph data for an inactive row,\n2982:  * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n2983:  *   skipped or dropped run is recovered by the pending-marker replay/backfill path.\n2984:  */\n2985: function scheduleBackgroundEnrichment(\n2986:   memoryId: number,\n2987:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n2988: ): void {\n2989:   if (enrichmentShuttingDown) return; // do not schedule new enrichment work during shutdown\n2990:   // Reserve a slot and schedule on a macrotask. The counter MUST be incremented here, at schedule\n2991:   // time вҖ” not inside the deferred callback. If it were bumped inside the callback, a burst (a startup\n2992:   // scan calling this once per row) would race: every call reads the still-zero counter before any\n2993:   // callback runs, all pass the cap, and unbounded setImmediate callbacks pile up that then drain as a\n2994:   // synchronous microtask chain and starve the event loop, so the daemon's IPC accept() never runs.\n2995:   // Re-arming dequeued work through setImmediate (rather than calling it inline from the finally)\n2996:   // returns control to the poll phase between runs.\n2997:   const start = (task: () => void): void => {\n2998:     activeBackgroundEnrichments++;\n2999:     // setImmediate (a MACROTASK boundary) is required here, not queueMicrotask: only a macrotask hands\n3000:     // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n3001:     setImmediate(task);\n3002:   };\n3003:   const run = (): void => {\n3004:     void (async () => {\n3005:       try {\n3006:         if (enrichmentShuttingDown) return; // fenced before this run started вҖ” do not reopen the DB during shutdown\n3007:         let db: ReturnType<typeof requireDb>;\n3008:         try {\n3009:           db = requireDb();\n3010:         } catch {\n3011:           return; // DB unavailable (e.g. recycle in flight) вҖ” row stays pending for backfill repair\n3012:         }\n3013:         const row = db\n3014:           .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n3015:           .get(memoryId) as { importance_tier?: string } | undefined;\n3016:         if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n3017:           return; // superseded/removed/archived since the save вҖ” do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n3018:         }\n3019:         const result = await runPostInsertEnrichment(db, memoryId, parsed);\n3020:         if (enrichmentShuttingDown) return; // shutdown began during the embed await вҖ” do not write after the close checkpoint\n3021:         recordEnrichmentResult(db, memoryId, result);\n3022:         emitPostInsertEnrichmentSubscribers(memoryId, 'post-insert-enrichment-async');\n3023:       } catch (bgErr: unknown) {\n3024:         enrichmentFailureTotal++;\n3025:         enrichmentLastError = bgErr instanceof Error ? bgErr.message : String(bgErr);\n3026:         enrichmentLastErrorAt = new Date().toISOString();\n3027:         // Rate-limit the per-failure warning so a systemic failure burst cannot spam the log; the\n3028:         // running total + last error stay available via memory_health. Log the first few, then suppress\n3029:         // and fold a suppressed-count summary into the next emitted line.\n3030:         if (enrichmentFailureTotal <= 5 || enrichmentFailureTotal % 100 === 0) {\n3031:           const suppressed = enrichmentSuppressedWarnings;\n3032:           enrichmentSuppressedWarnings = 0;\n3033:           console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n3034:         } else {\n3035:           enrichmentSuppressedWarnings++;\n3036:         }\n3037:       } finally {\n3038:         activeBackgroundEnrichments--;\n3039:         if (!enrichmentShuttingDown) {\n3040:           const next = backgroundEnrichmentQueue.shift();\n3041:           if (next) start(next);\n3042:         }\n3043:       }\n3044:     })();\n3045:   };\n3046:   if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n3047:     start(run);\n3048:   } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n3049:     backgroundEnrichmentQueue.push(run);\n3050:   } else {\n3051:     // Overflow: drop rather than grow the queue (and its retained parsed payloads) without bound under\n3052:     // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n3053:     // path re-enriches it later. Surfaced via the dropped counter in memory_health.\n3054:     enrichmentDroppedTotal++;\n3055:   }\n3056: }\n3057: \n3058: /* --- 9. MEMORY SAVE HANDLER --- */\n3059: \n3060: /** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\n3061: async function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n3062:   // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n3063:   // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n3064:   // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n3065:   // carries a code (e.g. preflight.PreflightError) keeps it.\n3066:   const requestId = randomUUID();\n3067:   try {\n3068:     return await handleMemorySaveInner(args, requestId);\n3069:   } catch (error: unknown) {\n3070:     if (error instanceof VRuleUnavailableError) {\n3071:       return createMCPErrorResponse({\n3072:         tool: 'memory_save',\n3073:         error: error.message,\n3074:         code: 'E_RUNTIME',\n3075:         details: { requestId },\n3076:         recovery: {\n3077:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3078:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3079:           severity: 'warning',\n3080:         },\n3081:       });\n3082:     }\n3083:     const message = error instanceof Error ? error.message : String(error);\n3084:     const existingCode = (error as { code?: string }).code;\n3085:     const code = typeof existingCode === 'string' && existingCode.length > 0\n3086:       ? existingCode\n3087:       : classifySaveErrorCode(message);\n3088:     return createMCPErrorResponse({\n3089:       tool: 'memory_save',\n3090:       error: message,\n3091:       code,\n3092:       details: { requestId, ...extractSaveErrorDetails(message) },\n3093:       recovery: {\n3094:         hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n3095:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3096:         severity: 'warning',\n3097:       },\n3098:     });\n3099:   }\n3100: }\n3101: \n3102: async function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n3103:   await ensureMemoryRuntimeInitialized('handler:memory_save');\n3104: \n3105:   // Fail fast with a clear message when the target file does not exist, before any\n3106:   // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n3107:   // caller-supplied path is safe to echo back.\n3108:   if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n3109:     const probePath = path.isAbsolute(args.filePath)\n3110:       ? args.filePath\n3111:       : path.resolve(process.cwd(), args.filePath);\n3112:     if (!fs.existsSync(probePath)) {\n3113:       return createMCPErrorResponse({\n3114:         tool: 'memory_save',\n3115:         error: `File not found: ${probePath}`,\n3116:         code: 'E089',\n3117:         details: { requestId, filePath: probePath },\n3118:         recovery: {\n3119:           hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n3120:           actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n3121:           severity: 'warning',\n3122:         },\n3123:       });\n3124:     }\n3125:   }\n3126: \n3127:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n3128: \n3129:   if (restoreBarrier) {\n3130:     return createMCPErrorResponse({\n3131:       tool: 'memory_save',\n3132:       error: restoreBarrier.message,\n3133:       code: restoreBarrier.code,\n3134:       details: {\n3135:         requestId,\n3136:       },\n3137:       recovery: {\n3138:         hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n3139:         actions: ['Wait for the restore to finish', 'Retry the save request'],\n3140:         severity: 'warning',\n3141:       },\n3142:     });\n3143:   }\n3144: \n3145:   const {\n3146:     filePath: file_path,\n3147:     force = false,\n3148:     dryRun = false,\n3149:     plannerMode: requestedPlannerMode,\n3150:     skipPreflight = false,\n3151:     asyncEmbedding = false,\n3152:     routeAs,\n3153:     mergeModeHint,\n3154:     targetAnchorId,\n3155:     tenantId,\n3156:     userId,\n3157:     agentId,\n3158:     sessionId,\n3159:     provenanceSource,\n3160:     provenanceActor,\n3161:     governedAt,\n3162:     retentionPolicy,\n3163:     deleteAfter,\n3164:   } = args;\n3165:   const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n3166:   const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n3167: \n3168:   // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n3169:   // Return a classified validation error instead of a bare throw, which the dispatcher would\n3170:   // otherwise flatten into the generic \"unexpected error\" (E081).\n3171:   if (!file_path || typeof file_path !== 'string') {\n3172:     return createMCPErrorResponse({\n3173:       tool: 'memory_save',\n3174:       error: 'filePath is required and must be a string',\n3175:       code: 'E089',\n3176:       details: { requestId },\n3177:       recovery: {\n3178:         hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n3179:         actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n3180:         severity: 'warning',\n3181:       },\n3182:     });\n3183:   }\n3184: \n3185:   await checkDatabaseUpdated();\n3186: \n3187:   const validatedPath: string = validateFilePathLocal(file_path);\n3188:   const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n3189:   const database = requireDb();\n3190: \n3191:   if (!shouldIndexForMemory(canonicalValidatedPath)) {\n3192:     return createIndexScopeExcludedResponse(requestId, canonicalValidatedPath, validatedPath);\n3193:   }\n3194: \n3195:   // A non-canonical target (e.g. a scratch file outside specs/**) returns a clear\n3196:   // validation error rather than a bare throw the dispatcher would surface as E081.\n3197:   if (!memoryParser.isMemoryFile(validatedPath)) {\n3198:     return createMCPErrorResponse({\n3199:       tool: 'memory_save',\n3200:       error: 'File must be a canonical spec document under specs/**/ (spec.md, plan.md, tasks.md, checklist.md, decision-record.md, implementation-summary.md, handover.md, research.md, resource-map.md, review-report.md, description.json, graph-metadata.json) or a constitutional memory under .opencode/skills/*/constitutional/',\n3201:       code: 'E089',\n3202:       details: { requestId, filePath: validatedPath },\n3203:       recovery: {\n3204:         hint: 'Save a canonical spec document or constitutional memory; scratch files outside specs/** are not indexable.',\n3205:         actions: ['Move the content into a spec folder under specs/** or .opencode/specs/**', 'Retry memory_save with the canonical path'],\n3206:         severity: 'warning',\n3207:       },\n3208:     });\n3209:   }\n3210: \n3211:   // Fail fast with a clear message when a spec doc's folder lacks both structural\n3212:   // metadata files, instead of the generic save \"unexpected error\" (E081).\n3213:   if (path.basename(canonicalValidatedPath) !== 'description.json'\n3214:     && path.basename(canonicalValidatedPath) !== 'graph-metadata.json'\n3215:     && !canonicalValidatedPath.includes('/constitutional/')) {\n3216:     const specFolderDir = path.dirname(canonicalValidatedPath);\n3217:     const missingMetadata = ['description.json', 'graph-metadata.json']\n3218:       .filter((name) => !fs.existsSync(path.join(specFolderDir, name)));\n3219:     if (missingMetadata.length === 2) {\n3220:       return createMCPErrorResponse({\n3221:         tool: 'memory_save',\n3222:         error: `Spec folder is missing required metadata (${missingMetadata.join(', ')}): ${specFolderDir}`,\n3223:         code: 'E089',\n3224:         details: { requestId, filePath: canonicalValidatedPath, missingMetadata },\n3225:         recovery: {\n3226:           hint: 'Generate the spec-folder metadata before indexing its other documents.',\n3227:           actions: ['Run generate-context.js / generate-description.js for this spec folder', 'Then retry memory_save'],\n3228:           severity: 'warning',\n3229:         },\n3230:       });\n3231:     }\n3232:   }\n3233: \n3234:   if (typeof database.exec === 'function') {\n3235:     ensureGovernanceRuntime(database);\n3236:   }\n3237: \n3238:   const governanceDecision = validateGovernedIngest({\n3239:     tenantId,\n3240:     userId,\n3241:     agentId,\n3242:     sessionId,\n3243:     provenanceSource,\n3244:     provenanceActor,\n3245:     governedAt,\n3246:     retentionPolicy,\n3247:     deleteAfter,\n3248:   });\n3249: \n3250:   if (!governanceDecision.allowed) {\n3251:     recordGovernanceAudit(database, {\n3252:       action: 'memory_save',\n3253:       decision: 'deny',\n3254:       tenantId,\n3255:       userId,\n3256:       agentId,\n3257:       sessionId,\n3258:       reason: governanceDecision.reason ?? 'governance_rejected',\n3259:       metadata: { issues: governanceDecision.issues },\n3260:     });\n3261:     // Surface the governance rejection with its own code + issue list instead of a bare\n3262:     // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n3263:     return createMCPErrorResponse({\n3264:       tool: 'memory_save',\n3265:       error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n3266:       code: 'E085',\n3267:       details: { requestId, issues: governanceDecision.issues },\n3268:       recovery: {\n3269:         hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n3270:         actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n3271:         severity: 'warning',\n3272:       },\n3273:     });\n3274:   }\n3275: \n3276:   // Shared dry-run response builder вҖ” both the skipPreflight and post-preflight\n3277:   // dry-run branches delegate here to prevent near-duplicate envelope drift.\n3278:   async function buildDryRunResponse(\n3279:     preparedDryRun: PreparedParsedMemory,\n3280:     parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n3281:     preflightValidation: {\n3282:       skipped: boolean;\n3283:       errors: preflight.PreflightIssue[];\n3284:       warnings: preflight.PreflightResult['warnings'];\n3285:       details: Record<string, unknown>;\n3286:       wouldPass: boolean;\n3287:     },\n3288:   ) {\n3289:     const templateContractPass = preparedDryRun.templateContract.valid\n3290:       || shouldBypassTemplateContract(\n3291:         preparedDryRun.sourceClassification,\n3292:         preparedDryRun.sufficiencyResult,\n3293:         preparedDryRun.templateContract,\n3294:         preparedDryRun.specDocHealth,\n3295:         preparedDryRun.parsed.documentType,\n3296:       );\n3297:     const bypassMode = shouldBypassTemplateContract(\n3298:       preparedDryRun.sourceClassification,\n3299:       preparedDryRun.sufficiencyResult,\n3300:       preparedDryRun.templateContract,\n3301:       preparedDryRun.specDocHealth,\n3302:       preparedDryRun.parsed.documentType,\n3303:     );\n3304:     const { createMCPSuccessResponse } = await import('../lib/response/envelope.js');\n3305:     const dryRunSummary = !preflightValidation.wouldPass\n3306:       ? `Pre-flight validation failed: ${preflightValidation.errors.length} error(s)`\n3307:       : bypassMode\n3308:         ? 'Dry-run would pass in manual-fallback mode with deferred indexing.'\n3309:         : buildDryRunSummary(\n3310:             preparedDryRun.sufficiencyResult,\n3311:             preparedDryRun.qualityLoopResult,\n3312:             preparedDryRun.templateContract,\n3313:           );\n3314: \n3315:     const wouldPass = preflightValidation.wouldPass\n3316:       && preparedDryRun.validation.valid\n3317:       && preparedDryRun.qualityLoopResult.rejected !== true\n3318:       && templateContractPass\n3319:       && preparedDryRun.sufficiencyResult.pass;\n3320: \n3321:     const hints: string[] = !preflightValidation.wouldPass\n3322:       ? ['Fix validation errors before saving', 'Use skipPreflight: true to bypass validation']\n3323:       : templateContractPass && preparedDryRun.sufficiencyResult.pass\n3324:         ? [\n3325:             'Dry-run complete - no changes made',\n3326:             ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n3327:             ...(bypassMode\n3328:               ? ['Manual-fallback mode would bypass the strict memory template contract for this save']\n3329:               : []),\n3330:           ]\n3331:         : [\n3332:             'Dry-run complete - no changes made',\n3333:             ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n3334:             ...(!preparedDryRun.templateContract.valid\n3335:               ? ['Rendered content must match the memory template contract before indexing']\n3336:               : []),\n3337:             'Not enough context was available to save a durable memory',\n3338:             ...(!preflightValidation.skipped\n3339:               ? ['Add concrete file, tool, decision, blocker, next action, or outcome evidence and retry']\n3340:               : []),\n3341:           ];\n3342: \n3343:     return createMCPSuccessResponse({\n3344:       tool: 'memory_save',\n3345:       summary: dryRunSummary,\n3346:       data: {\n3347:         status: 'dry_run',\n3348:         would_pass: wouldPass,\n3349:         file_path: validatedPath,\n3350:         spec_folder: parsed.specFolder,\n3351:         title: parsed.title,\n3352:         validation: preflightValidation.skipped\n3353:           ? { skipped: true, errors: [], warnings: [], details: { skipped: true } }\n3354:           : { errors: preflightValidation.errors, warnings: preflightValidation.warnings, details: preflightValidation.details },\n3355:         qualityLoop: {\n3356:           passed: preparedDryRun.qualityLoopResult.passed,\n3357:           rejected: preparedDryRun.qualityLoopResult.rejected,\n3358:           fixes: preparedDryRun.qualityLoopResult.fixes,\n3359:           rejectionReason: preparedDryRun.qualityLoopResult.rejectionReason,\n3360:         },\n3361:         templateContract: preparedDryRun.templateContract,\n3362:         sufficiency: preparedDryRun.sufficiencyResult,\n3363:         specDocHealth: preparedDryRun.specDocHealth,\n3364:         rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n3365:         message: dryRunSummary,\n3366:       },\n3367:       hints,\n3368:     });\n3369:   }\n3370: \n3371:   // DryRun must remain non-mutating even when preflight is explicitly skipped.\n3372:   if (dryRun && skipPreflight) {\n3373:     const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n3374:     const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n3375:       emitEvalMetrics: false,\n3376:       qualityLoopMode: 'advisory',\n3377:     });\n3378:     return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n3379:       skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,\n3380:     });\n3381:   }\n3382: \n3383:   const saveScope: MemoryScopeMatch = {\n3384:     tenantId: governanceDecision.normalized.tenantId,\n3385:     userId: governanceDecision.normalized.userId ?? null,\n3386:     agentId: governanceDecision.normalized.agentId ?? null,\n3387:     sessionId: governanceDecision.normalized.sessionId,\n3388:   };\n3389:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n3390: \n3391:   // PRE-FLIGHT VALIDATION\n3392:   let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n3393:   if (!skipPreflight) {\n3394:     parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n3395: \n3396:     const preflightResult = preflight.runPreflight(\n3397:       {\n3398:         content: parsedForPreflight.content,\n3399:         file_path: validatedPath,\n3400:         spec_folder: parsedForPreflight.specFolder,\n3401:         database: database,\n3402:         find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n3403:         tenantId: saveScope.tenantId ?? undefined,\n3404:         userId: saveScope.userId ?? undefined,\n3405:         agentId: saveScope.agentId ?? undefined,\n3406:       },\n3407:       {\n3408:         dry_run: dryRun,\n3409:         check_anchors: true,\n3410:         check_duplicates: !force,\n3411:         check_similar: false,\n3412:         check_tokens: true,\n3413:         check_size: true,\n3414:         strict_anchors: false,\n3415:       }\n3416:     );\n3417: \n3418:     if (dryRun) {\n3419:       let preparedDryRun: PreparedParsedMemory;\n3420:       try {\n3421:         preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n3422:           emitEvalMetrics: false,\n3423:           qualityLoopMode: 'advisory',\n3424:         });\n3425:       } catch (error: unknown) {\n3426:         if (error instanceof VRuleUnavailableError) {\n3427:           return createMCPErrorResponse({\n3428:             tool: 'memory_save',\n3429:             error: error.message,\n3430:             code: 'E_RUNTIME',\n3431:             details: { requestId },\n3432:             recovery: {\n3433:               hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3434:               actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3435:               severity: 'warning',\n3436:             },\n3437:           });\n3438:         }\n3439:         // Classify dry-run preparation failures so even validation-only runs surface the\n3440:         // specific cause instead of the generic E081 catch-all at the dispatcher.\n3441:         const dryRunErrorMessage = error instanceof Error ? error.message : String(error);\n3442:         return createMCPErrorResponse({\n3443:           tool: 'memory_save',\n3444:           error: dryRunErrorMessage,\n3445:           code: classifySaveErrorCode(dryRunErrorMessage),\n3446:           details: { requestId, ...extractSaveErrorDetails(dryRunErrorMessage) },\n3447:           recovery: {\n3448:             hint: 'Inspect the error message for the specific dry-run preparation failure.',\n3449:             actions: ['Resolve the reported cause', 'Retry memory_save'],\n3450:             severity: 'warning',\n3451:           },\n3452:         });\n3453:       }\n3454:       return buildDryRunResponse(preparedDryRun, parsedForPreflight, {\n3455:         skipped: false,\n3456:         errors: preflightResult.errors,\n3457:         warnings: preflightResult.warnings,\n3458:         details: preflightResult.details,\n3459:         wouldPass: preflightResult.dry_run_would_pass ?? preflightResult.pass,\n3460:       });\n3461:     }\n3462: \n3463:     if (!preflightResult.pass) {\n3464:       if (shouldPlanCanonicalSave) {\n3465:         return buildPlannerResponse({\n3466:           planner: {\n3467:             filePath: validatedPath,\n3468:             specFolder: parsedForPreflight.specFolder,\n3469:             title: parsedForPreflight.title ?? path.basename(validatedPath),\n3470:             status: 'blocked',\n3471:             message: 'Planner found blocker(s) during pre-flight validation.',\n3472:             plannerMode: 'plan-only',\n3473:             routeTarget: serializePlannerRouteTarget({\n3474:               routeCategory: routeAs ?? 'drop',\n3475:               targetDocPath: validatedPath,\n3476:               targetAnchorId: targetAnchorId ?? null,\n3477:               mergeMode: mergeModeHint,\n3478:             }),\n3479:             proposedEdits: [],\n3480:             blockers: preflightResult.errors.map((entry: string | { message: string; code?: string }) =>\n3481:               serializePlannerBlocker(buildPlannerBlocker({\n3482:                 code: typeof entry === 'string' ? 'PREFLIGHT_BLOCKER' : (entry.code ?? 'PREFLIGHT_BLOCKER'),\n3483:                 message: typeof entry === 'string' ? entry : entry.message,\n3484:                 routeCategory: routeAs ?? undefined,\n3485:                 targetDocPath: validatedPath,\n3486:                 targetAnchorId: targetAnchorId ?? null,\n3487:               }))\n3488:             ),\n3489:             advisories: preflightResult.warnings.map((entry: string | { message: string }) =>\n3490:               serializePlannerAdvisory(buildPlannerAdvisory({\n3491:                 code: 'PREFLIGHT_WARNING',\n3492:                 message: typeof entry === 'string' ? entry : entry.message,\n3493:                 routeCategory: routeAs ?? undefined,\n3494:                 targetDocPath: validatedPath,\n3495:                 targetAnchorId: targetAnchorId ?? null,\n3496:               }))\n3497:             ),\n3498:             followUpActions: [\n3499:               serializePlannerFollowUpAction({\n3500:                 action: 'apply',\n3501:                 title: 'Retry with full-auto after fixing pre-flight blockers',\n3502:                 description: 'Fix the reported blockers, then request explicit full-auto mode.',\n3503:                 args: {\n3504:                   filePath: validatedPath,\n3505:                   plannerMode: 'full-auto',\n3506:                   ...(routeAs ? { routeAs } : {}),\n3507:                   ...(mergeModeHint ? { mergeModeHint } : {}),\n3508:                   ...(targetAnchorId ? { targetAnchorId } : {}),\n3509:                 },\n3510:               }),\n3511:             ],\n3512:           },\n3513:         });\n3514:       }\n3515: \n3516:       const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n3517:         typeof e === 'string' ? e : e.message\n3518:       ).join('; ');\n3519: \n3520:       // Use the actual error code from the\n3521:       // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n3522:       const firstError = preflightResult.errors[0];\n3523:       const errorCode = (typeof firstError === 'object' && firstError?.code)\n3524:         ? firstError.code\n3525:         : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n3526:       throw new preflight.PreflightError(\n3527:         errorCode,\n3528:         `Pre-flight validation failed: ${errorMessages}`,\n3529:         {\n3530:           errors: preflightResult.errors,\n3531:           warnings: preflightResult.warnings,\n3532:           recoverable: true,\n3533:           suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n3534:         }\n3535:       );\n3536:     }\n3537: \n3538:     if (preflightResult.warnings.length > 0) {\n3539:       console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n3540:       preflightResult.warnings.forEach((w: string | { message: string }) => {\n3541:         const msg = typeof w === 'string' ? w : w.message;\n3542:         console.warn(`[preflight]   - ${msg}`);\n3543:       });\n3544:     }\n3545:   }\n3546: \n3547:   if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n3548:     try {\n3549:       const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n3550:       // The compared payload IS the fingerprint object: both lookup inputs\n3551:       // below point at this same idempotencySemantics value, so payloadHash\n3552:       // always equals requestFingerprintHash and the receiptKey is derived from\n3553:       // it. Consequence: distinct logical requests always produce distinct\n3554:       // keys, so the same-key/different-payload 'conflict' status can never fire\n3555:       // from this caller (a force-flip yields a key MISS, not a conflict). The\n3556:       // conflict branch below is fail-safe defense-in-depth, not active\n3557:       // protection. To make conflicts detectable, the payload would have to\n3558:       // carry MORE than the key material (e.g. execution-mode flags); it\n3559:       // deliberately does not, so a benign flag flip cannot become a false\n3560:       // hard conflict.\n3561:       const idempotencySemantics = {\n3562:         filePath: canonicalValidatedPath,\n3563:         contentHash: parsedForIdempotency.contentHash,\n3564:         routeAs: routeAs ?? null,\n3565:         mergeModeHint: mergeModeHint ?? null,\n3566:         targetAnchorId: targetAnchorId ?? null,\n3567:         scope: saveScope,\n3568:         // A force-flipped retry is a DIFFERENT logical request: keeping force in\n3569:         // the key material makes it a distinct key (a clean MISS that re-runs),\n3570:         // never a collision with the non-forced receipt.\n3571:         force: force === true,\n3572:       };\n3573:       const lookup = lookupIdempotencyReceipt(database, {\n3574:         operation: 'memory_save',\n3575:         contentHash: parsedForIdempotency.contentHash,\n3576:         requestFingerprint: idempotencySemantics,\n3577:         payload: idempotencySemantics,\n3578:       });\n3579:       idempotencyKey = lookup.key;\n3580:       if (lookup.status === 'replay') {\n3581:         // A receipt is a replay cache, not proof the cached response still\n3582:         // describes the live state. After an A->B->A revert the receipt for A\n3583:         // is intact but the active row now holds B (or, after deletion, a\n3584:         // superseded row), so replaying A's old response would diverge from\n3585:         // the index. Honor the replay ONLY when the active row for this logical\n3586:         // identity still carries the receipt's content_hash AND is the same row\n3587:         // the cached response reports. Content alone is insufficient: a planner\n3588:         // re-create of identical content (the planner branch skips this whole\n3589:         // block and never refreshes the receipt) produces a NEW id, so a\n3590:         // content-only match would replay a response naming a deleted id and\n3591:         // strand a follow-up update by that id. Mirror the handler's own\n3592:         // active-row identity (findSamePathExistingMemory) and exclude retired\n3593:         // tiers so a deprecated/archived predecessor cannot satisfy the match.\n3594:         const activeRow = database.prepare(`\n3595:           SELECT id, content_hash\n3596:           FROM memory_index\n3597:           WHERE spec_folder = ?\n3598:             AND parent_id IS NULL\n3599:             AND (canonical_file_path = ? OR file_path = ?)\n3600:             AND ${targetAnchorId != null ? 'anchor_id = ?' : 'anchor_id IS NULL'}\n3601:             AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n3602:             AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n3603:             AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n3604:             AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n3605:             AND COALESCE(importance_tier, 'normal') NOT IN ('deprecated', 'archived')\n3606:           ORDER BY id DESC\n3607:           LIMIT 1\n3608:         `).get(\n3609:           parsedForIdempotency.specFolder,\n3610:           canonicalValidatedPath,\n3611:           validatedPath,\n3612:           ...(targetAnchorId != null ? [targetAnchorId] : []),\n3613:           saveScope.tenantId ?? null, saveScope.tenantId ?? null,\n3614:           saveScope.userId ?? null, saveScope.userId ?? null,\n3615:           saveScope.agentId ?? null, saveScope.agentId ?? null,\n3616:           saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n3617:         ) as { id: number; content_hash: string } | undefined;\n3618: \n3619:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n3620:         if (\n3621:           activeRow\n3622:           && activeRow.content_hash === lookup.key.contentHash\n3623:           && (replayMemoryId == null || activeRow.id === replayMemoryId)\n3624:         ) {\n3625:           return lookup.response;\n3626:         }\n3627:         // Stale receipt for this attempt: drop the cache entry so the\n3628:         // re-indexed write stores its current response (the post-write store\n3629:         // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n3630:         // the stale receipt), then fall through to the normal save/reindex path.\n3631:         deleteIdempotencyReceiptByKey(database, lookup.key);\n3632:       } else if (lookup.status === 'conflict') {\n3633:         // Unreachable from this caller: payload === requestFingerprint (above),\n3634:         // so a key match implies a payload match and lookup never returns\n3635:         // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n3636:         // material and payload ever diverge.\n3637:         return createMCPErrorResponse({\n3638:           tool: 'memory_save',\n3639:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n3640:           code: 'idempotency_key_conflict',\n3641:           details: { requestId, receiptKey: lookup.key.receiptKey },\n3642:           recovery: {\n3643:             hint: 'Retry the original byte-identical request or submit a fresh logical write.',\n3644:             severity: 'warning',\n3645:           },\n3646:         });\n3647:       }\n3648:     } catch (error: unknown) {\n3649:       const message = error instanceof Error ? error.message : String(error);\n3650:       console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n3651:       idempotencyKey = null;\n3652:     }\n3653:   }\n3654: \n3655:   if (shouldPlanCanonicalSave) {\n3656:     const plannerResult = await atomicSaveMemory({\n3657:       file_path: validatedPath,\n3658:       content: fs.readFileSync(validatedPath, 'utf8'),\n3659:       plannerMode,\n3660:       ...(routeAs ? { routeAs } : {}),\n3661:       ...(mergeModeHint ? { mergeModeHint } : {}),\n3662:       ...(targetAnchorId ? { targetAnchorId } : {}),\n3663:     }, { force });\n3664: \n3665:     return buildPlannerResponse({\n3666:       planner: {\n3667:         filePath: validatedPath,\n3668:         specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n3669:         title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n3670:         status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n3671:         message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n3672:         plannerMode: 'plan-only',\n3673:         routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n3674:           routeCategory: routeAs ?? 'drop',\n3675:           targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n3676:           targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n3677:           mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n3678:         }),\n3679:         proposedEdits: plannerResult.proposedEdits ?? [],\n3680:         blockers: plannerResult.blockers ?? [],\n3681:         advisories: plannerResult.advisories ?? [],\n3682:         followUpActions: plannerResult.followUpActions ?? [],\n3683:       },\n3684:     });\n3685:   }\n3686: \n3687:   let result: IndexResult;\n3688:   try {\n3689:     result = await indexMemoryFile(validatedPath, {\n3690:       force,\n3691:       parsedOverride: parsedForPreflight,\n3692:       asyncEmbedding,\n3693:       plannerMode,\n3694:       scope: saveScope,\n3695:       routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n3696:       provenance: (provenanceSource || provenanceActor)\n3697:         ? { provenanceSource, provenanceActor, tool: 'memory_save' }\n3698:         : undefined,\n3699:     });\n3700:   } catch (error: unknown) {\n3701:     if (error instanceof VRuleUnavailableError) {\n3702:       return createMCPErrorResponse({\n3703:         tool: 'memory_save',\n3704:         error: error.message,\n3705:         code: 'E_RUNTIME',\n3706:         details: { requestId },\n3707:         recovery: {\n3708:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3709:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3710:           severity: 'warning',\n3711:         },\n3712:       });\n3713:     }\n3714:     // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n3715:     // response code points at the actual failure mode instead of the generic E081 catch-all.\n3716:     const indexErrorMessage = error instanceof Error ? error.message : String(error);\n3717:     return createMCPErrorResponse({\n3718:       tool: 'memory_save',\n3719:       error: indexErrorMessage,\n3720:       code: classifySaveErrorCode(indexErrorMessage),\n3721:       details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n3722:       recovery: {\n3723:         hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n3724:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3725:         severity: 'warning',\n3726:       },\n3727:     });\n3728:   }\n3729: \n3730:   if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n3731:     // Wrap governance metadata in a transaction with rollback on failure.\n3732:     // If governance application fails, delete the orphaned memory row to prevent\n3733:     // persisted rows without tenant/session/retention metadata.\n3734:     const applyGovernanceTx = database.transaction(() => {\n3735:       applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n3736:       recordGovernanceAudit(database, {\n3737:         action: 'memory_save',\n3738:         decision: 'allow',\n3739:         memoryId: result.id,\n3740:         tenantId,\n3741:         userId,\n3742:         agentId,\n3743:         sessionId,\n3744:         reason: 'governed_ingest',\n3745:         metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n3746:       });\n3747:     });\n3748:     try {\n3749:       applyGovernanceTx();\n3750:     } catch (govErr: unknown) {\n3751:       // C2 FIX: Use full delete helper to clean up ALL ancillary records\n3752:       // (vec_memories, BM25 index, causal edges, projections, etc.)\n3753:       // not just memory_index, to prevent orphaned search phantoms.\n3754:       const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n3755:       console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n3756:       try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n3757:       // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n3758:       // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n3759:       // generic E081 catch-all.\n3760:       return createMCPErrorResponse({\n3761:         tool: 'memory_save',\n3762:         error: govErrorMessage,\n3763:         code: classifySaveErrorCode(govErrorMessage),\n3764:         details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n3765:         recovery: {\n3766:           hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n3767:           actions: ['Resolve the reported cause', 'Retry memory_save'],\n3768:           severity: 'warning',\n3769:         },\n\n(Showing lines 2820-3769 of 4082. Use offset=3770 to continue.)\n</content>","metadata":{"preview":"};\n\ntype IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  origin?: IndexingOrigin;\n  fromScan?: never;\n};\n\ntype LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  fromScan?: boolean;\n  origin?: never;\n};\n\n/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"};\n\ntype IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  origin?: IndexingOrigin;\n  fromScan?: never;\n};\n\ntype LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  fromScan?: boolean;\n  origin?: never;\n};\n\n/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    provenance,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);\n  const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n  const database = requireDb();\n  const prepared = prepareParsedMemoryForIndexing(parsed, database);\n  const validation = prepared.validation;\n  if (!validation.valid) {\n    throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n  }\n  if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n    console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n  }\n\n  // When a governance decision is threaded in (bulk scan/ingest), derive the\n  // scope tuple from it so the row is created under the governed scope, matching\n  // how the direct save path seeds saveScope from governanceDecision.normalized.\n  const effectiveScope: MemoryScopeMatch = governance\n    ? {\n        tenantId: governance.normalized.tenantId ?? null,\n        userId: governance.normalized.userId ?? null,\n        agentId: governance.normalized.agentId ?? null,\n        sessionId: governance.normalized.sessionId ?? null,\n      }\n    : scope;\n  const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n    ? {\n        provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n        provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n        tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n      }\n    : undefined);\n\n  const result = await processPreparedMemory(prepared, filePath, {\n    force,\n    asyncEmbedding,\n    plannerMode,\n    origin: indexingOrigin,\n    persistQualityLoopContent: true,\n    refreshFromDiskAfterLock: parsedOverride !== null,\n    scope: effectiveScope,\n    qualityGateMode,\n    routing,\n    provenance: effectiveProvenance,\n  });\n\n  // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n  // direct memory_save path so governed bulk/scan/async ingests are not silently\n  // downgraded to ungoverned rows. Only for freshly written rows.\n  if (governance && typeof result.id === 'number' && result.id > 0\n    && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n  }\n\n  return result;\n}\n\nasync function indexMemoryFileFromScan(\n  filePath: string,\n  options: BaseIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    ...options,\n    origin: 'scan',\n  });\n}\n\n/* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n\n// Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n// entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n// slots free.\nconst MAX_BACKGROUND_ENRICHMENTS = 4;\nlet activeBackgroundEnrichments = 0;\nconst backgroundEnrichmentQueue: Array<() => void> = [];\n\n// Set during shutdown BEFORE closeDb. A deferred/queued enrichment run re-resolves the DB handle via\n// requireDb(), which REOPENS a closed connection вҖ” so without this fence a run firing during the\n// shutdown drain would reopen the DB and write fresh WAL frames after the TRUNCATE checkpoint, leaving\n// a non-empty WAL at rest and defeating the close durability guarantee. Same hazard the fileWatcher\n// and ingestWorker fences guard against.\nlet enrichmentShuttingDown = false;\n\n/**\n * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n * in-flight run bail before it touches the DB. Synchronous so fatalShutdown can call it in its\n * pre-close fence block, before any await lets a queued setImmediate run fire. Dropped rows remain\n * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n */\nexport function shutdownBackgroundEnrichment(): void {\n  enrichmentShuttingDown = true;\n  backgroundEnrichmentQueue.length = 0;\n}\n\n// Bound the OVERFLOW queue, not just concurrency. A sustained live-save flood (saves arriving faster\n// than the 4-wide drain) would otherwise grow the queue вҖ” and the parsed payload each entry retains вҖ”\n// without bound. On overflow we DROP rather than push: the row is enrichment-pending in the commit\n// transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n// scheduler visible through memory_health (otherwise a stuck scheduler is a silent enrichment outage).\nconst MAX_QUEUED_ENRICHMENTS = 2000;\nlet enrichmentDroppedTotal = 0;\nlet enrichmentFailureTotal = 0;\nlet enrichmentLastError: string | null = null;\nlet enrichmentLastErrorAt: string | null = null;\nlet enrichmentSuppressedWarnings = 0;\n\n/** Scheduler observability snapshot for memory_health вҖ” module-local counters only, no DB access. */\nexport function getBackgroundEnrichmentStats(): {\n  active: number;\n  queued: number;\n  max: number;\n  maxQueued: number;\n  droppedTotal: number;\n  failureTotal: number;\n  lastError: string | null;\n  lastErrorAt: string | null;\n} {\n  return {\n    active: activeBackgroundEnrichments,\n    queued: backgroundEnrichmentQueue.length,\n    max: MAX_BACKGROUND_ENRICHMENTS,\n    maxQueued: MAX_QUEUED_ENRICHMENTS,\n    droppedTotal: enrichmentDroppedTotal,\n    failureTotal: enrichmentFailureTotal,\n    lastError: enrichmentLastError,\n    lastErrorAt: enrichmentLastErrorAt,\n  };\n}\n\n/**\n * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n * - re-resolves the DB handle when the run starts (covers a recycle before the run begins; a recycle\n *   mid-run throws on the post-await write and the row falls back to the pending-marker backfill),\n * - skips rows that were superseded/deprecated before the deferred run starts, so it never\n *   repopulates purged entity/graph data for an inactive row,\n * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n *   skipped or dropped run is recovered by the pending-marker replay/backfill path.\n */\nfunction scheduleBackgroundEnrichment(\n  memoryId: number,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n): void {\n  if (enrichmentShuttingDown) return; // do not schedule new enrichment work during shutdown\n  // Reserve a slot and schedule on a macrotask. The counter MUST be incremented here, at schedule\n  // time вҖ” not inside the deferred callback. If it were bumped inside the callback, a burst (a startup\n  // scan calling this once per row) would race: every call reads the still-zero counter before any\n  // callback runs, all pass the cap, and unbounded setImmediate callbacks pile up that then drain as a\n  // synchronous microtask chain and starve the event loop, so the daemon's IPC accept() never runs.\n  // Re-arming dequeued work through setImmediate (rather than calling it inline from the finally)\n  // returns control to the poll phase between runs.\n  const start = (task: () => void): void => {\n    activeBackgroundEnrichments++;\n    // setImmediate (a MACROTASK boundary) is required here, not queueMicrotask: only a macrotask hands\n    // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n    setImmediate(task);\n  };\n  const run = (): void => {\n    void (async () => {\n      try {\n        if (enrichmentShuttingDown) return; // fenced before this run started вҖ” do not reopen the DB during shutdown\n        let db: ReturnType<typeof requireDb>;\n        try {\n          db = requireDb();\n        } catch {\n          return; // DB unavailable (e.g. recycle in flight) вҖ” row stays pending for backfill repair\n        }\n        const row = db\n          .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n          .get(memoryId) as { importance_tier?: string } | undefined;\n        if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n          return; // superseded/removed/archived since the save вҖ” do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n        }\n        const result = await runPostInsertEnrichment(db, memoryId, parsed);\n        if (enrichmentShuttingDown) return; // shutdown began during the embed await вҖ” do not write after the close checkpoint\n        recordEnrichmentResult(db, memoryId, result);\n        emitPostInsertEnrichmentSubscribers(memoryId, 'post-insert-enrichment-async');\n      } catch (bgErr: unknown) {\n        enrichmentFailureTotal++;\n        enrichmentLastError = bgErr instanceof Error ? bgErr.message : String(bgErr);\n        enrichmentLastErrorAt = new Date().toISOString();\n        // Rate-limit the per-failure warning so a systemic failure burst cannot spam the log; the\n        // running total + last error stay available via memory_health. Log the first few, then suppress\n        // and fold a suppressed-count summary into the next emitted line.\n        if (enrichmentFailureTotal <= 5 || enrichmentFailureTotal % 100 === 0) {\n          const suppressed = enrichmentSuppressedWarnings;\n          enrichmentSuppressedWarnings = 0;\n          console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n        } else {\n          enrichmentSuppressedWarnings++;\n        }\n      } finally {\n        activeBackgroundEnrichments--;\n        if (!enrichmentShuttingDown) {\n          const next = backgroundEnrichmentQueue.shift();\n          if (next) start(next);\n        }\n      }\n    })();\n  };\n  if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n    start(run);\n  } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n    backgroundEnrichmentQueue.push(run);\n  } else {\n    // Overflow: drop rather than grow the queue (and its retained parsed payloads) without bound under\n    // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n    // path re-enriches it later. Surfaced via the dropped counter in memory_health.\n    enrichmentDroppedTotal++;\n  }\n}\n\n/* --- 9. MEMORY SAVE HANDLER --- */\n\n/** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\nasync function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n  // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n  // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n  // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n  // carries a code (e.g. preflight.PreflightError) keeps it.\n  const requestId = randomUUID();\n  try {\n    return await handleMemorySaveInner(args, requestId);\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    const message = error instanceof Error ? error.message : String(error);\n    const existingCode = (error as { code?: string }).code;\n    const code = typeof existingCode === 'string' && existingCode.length > 0\n      ? existingCode\n      : classifySaveErrorCode(message);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: message,\n      code,\n      details: { requestId, ...extractSaveErrorDetails(message) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n}\n\nasync function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_save');\n\n  // Fail fast with a clear message when the target file does not exist, before any\n  // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n  // caller-supplied path is safe to echo back.\n  if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n    const probePath = path.isAbsolute(args.filePath)\n      ? args.filePath\n      : path.resolve(process.cwd(), args.filePath);\n    if (!fs.existsSync(probePath)) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `File not found: ${probePath}`,\n        code: 'E089',\n        details: { requestId, filePath: probePath },\n        recovery: {\n          hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n          actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        requestId,\n      },\n      recovery: {\n        hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the save request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    filePath: file_path,\n    force = false,\n    dryRun = false,\n    plannerMode: requestedPlannerMode,\n    skipPreflight = false,\n    asyncEmbedding = false,\n    routeAs,\n    mergeModeHint,\n    targetAnchorId,\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  } = args;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n  // Return a classified validation error instead of a bare throw, which the dispatcher would\n  // otherwise flatten into the generic \"unexpected error\" (E081).\n  if (!file_path || typeof file_path !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'filePath is required and must be a string',\n      code: 'E089',\n      details: { requestId },\n      recovery: {\n        hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n        actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const validatedPath: string = validateFilePathLocal(file_path);\n  const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n  const database = requireDb();\n\n  if (!shouldIndexForMemory(canonicalValidatedPath)) {\n    return createIndexScopeExcludedResponse(requestId, canonicalValidatedPath, validatedPath);\n  }\n\n  // A non-canonical target (e.g. a scratch file outside specs/**) returns a clear\n  // validation error rather than a bare throw the dispatcher would surface as E081.\n  if (!memoryParser.isMemoryFile(validatedPath)) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'File must be a canonical spec document under specs/**/ (spec.md, plan.md, tasks.md, checklist.md, decision-record.md, implementation-summary.md, handover.md, research.md, resource-map.md, review-report.md, description.json, graph-metadata.json) or a constitutional memory under .opencode/skills/*/constitutional/',\n      code: 'E089',\n      details: { requestId, filePath: validatedPath },\n      recovery: {\n        hint: 'Save a canonical spec document or constitutional memory; scratch files outside specs/** are not indexable.',\n        actions: ['Move the content into a spec folder under specs/** or .opencode/specs/**', 'Retry memory_save with the canonical path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Fail fast with a clear message when a spec doc's folder lacks both structural\n  // metadata files, instead of the generic save \"unexpected error\" (E081).\n  if (path.basename(canonicalValidatedPath) !== 'description.json'\n    && path.basename(canonicalValidatedPath) !== 'graph-metadata.json'\n    && !canonicalValidatedPath.includes('/constitutional/')) {\n    const specFolderDir = path.dirname(canonicalValidatedPath);\n    const missingMetadata = ['description.json', 'graph-metadata.json']\n      .filter((name) => !fs.existsSync(path.join(specFolderDir, name)));\n    if (missingMetadata.length === 2) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `Spec folder is missing required metadata (${missingMetadata.join(', ')}): ${specFolderDir}`,\n        code: 'E089',\n        details: { requestId, filePath: canonicalValidatedPath, missingMetadata },\n        recovery: {\n          hint: 'Generate the spec-folder metadata before indexing its other documents.',\n          actions: ['Run generate-context.js / generate-description.js for this spec folder', 'Then retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  if (typeof database.exec === 'function') {\n    ensureGovernanceRuntime(database);\n  }\n\n  const governanceDecision = validateGovernedIngest({\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  });\n\n  if (!governanceDecision.allowed) {\n    recordGovernanceAudit(database, {\n      action: 'memory_save',\n      decision: 'deny',\n      tenantId,\n      userId,\n      agentId,\n      sessionId,\n      reason: governanceDecision.reason ?? 'governance_rejected',\n      metadata: { issues: governanceDecision.issues },\n    });\n    // Surface the governance rejection with its own code + issue list instead of a bare\n    // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n      code: 'E085',\n      details: { requestId, issues: governanceDecision.issues },\n      recovery: {\n        hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n        actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Shared dry-run response builder вҖ” both the skipPreflight and post-preflight\n  // dry-run branches delegate here to prevent near-duplicate envelope drift.\n  async function buildDryRunResponse(\n    preparedDryRun: PreparedParsedMemory,\n    parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n    preflightValidation: {\n      skipped: boolean;\n      errors: preflight.PreflightIssue[];\n      warnings: preflight.PreflightResult['warnings'];\n      details: Record<string, unknown>;\n      wouldPass: boolean;\n    },\n  ) {\n    const templateContractPass = preparedDryRun.templateContract.valid\n      || shouldBypassTemplateContract(\n        preparedDryRun.sourceClassification,\n        preparedDryRun.sufficiencyResult,\n        preparedDryRun.templateContract,\n        preparedDryRun.specDocHealth,\n        preparedDryRun.parsed.documentType,\n      );\n    const bypassMode = shouldBypassTemplateContract(\n      preparedDryRun.sourceClassification,\n      preparedDryRun.sufficiencyResult,\n      preparedDryRun.templateContract,\n      preparedDryRun.specDocHealth,\n      preparedDryRun.parsed.documentType,\n    );\n    const { createMCPSuccessResponse } = await import('../lib/response/envelope.js');\n    const dryRunSummary = !preflightValidation.wouldPass\n      ? `Pre-flight validation failed: ${preflightValidation.errors.length} error(s)`\n      : bypassMode\n        ? 'Dry-run would pass in manual-fallback mode with deferred indexing.'\n        : buildDryRunSummary(\n            preparedDryRun.sufficiencyResult,\n            preparedDryRun.qualityLoopResult,\n            preparedDryRun.templateContract,\n          );\n\n    const wouldPass = preflightValidation.wouldPass\n      && preparedDryRun.validation.valid\n      && preparedDryRun.qualityLoopResult.rejected !== true\n      && templateContractPass\n      && preparedDryRun.sufficiencyResult.pass;\n\n    const hints: string[] = !preflightValidation.wouldPass\n      ? ['Fix validation errors before saving', 'Use skipPreflight: true to bypass validation']\n      : templateContractPass && preparedDryRun.sufficiencyResult.pass\n        ? [\n            'Dry-run complete - no changes made',\n            ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n            ...(bypassMode\n              ? ['Manual-fallback mode would bypass the strict memory template contract for this save']\n              : []),\n          ]\n        : [\n            'Dry-run complete - no changes made',\n            ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n            ...(!preparedDryRun.templateContract.valid\n              ? ['Rendered content must match the memory template contract before indexing']\n              : []),\n            'Not enough context was available to save a durable memory',\n            ...(!preflightValidation.skipped\n              ? ['Add concrete file, tool, decision, blocker, next action, or outcome evidence and retry']\n              : []),\n          ];\n\n    return createMCPSuccessResponse({\n      tool: 'memory_save',\n      summary: dryRunSummary,\n      data: {\n        status: 'dry_run',\n        would_pass: wouldPass,\n        file_path: validatedPath,\n        spec_folder: parsed.specFolder,\n        title: parsed.title,\n        validation: preflightValidation.skipped\n          ? { skipped: true, errors: [], warnings: [], details: { skipped: true } }\n          : { errors: preflightValidation.errors, warnings: preflightValidation.warnings, details: preflightValidation.details },\n        qualityLoop: {\n          passed: preparedDryRun.qualityLoopResult.passed,\n          rejected: preparedDryRun.qualityLoopResult.rejected,\n          fixes: preparedDryRun.qualityLoopResult.fixes,\n          rejectionReason: preparedDryRun.qualityLoopResult.rejectionReason,\n        },\n        templateContract: preparedDryRun.templateContract,\n        sufficiency: preparedDryRun.sufficiencyResult,\n        specDocHealth: preparedDryRun.specDocHealth,\n        rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n        message: dryRunSummary,\n      },\n      hints,\n    });\n  }\n\n  // DryRun must remain non-mutating even when preflight is explicitly skipped.\n  if (dryRun && skipPreflight) {\n    const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n    const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n      emitEvalMetrics: false,\n      qualityLoopMode: 'advisory',\n    });\n    return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n      skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,\n    });\n  }\n\n  const saveScope: MemoryScopeMatch = {\n    tenantId: governanceDecision.normalized.tenantId,\n    userId: governanceDecision.normalized.userId ?? null,\n    agentId: governanceDecision.normalized.agentId ?? null,\n    sessionId: governanceDecision.normalized.sessionId,\n  };\n  let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  // PRE-FLIGHT VALIDATION\n  let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n  if (!skipPreflight) {\n    parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n\n    const preflightResult = preflight.runPreflight(\n      {\n        content: parsedForPreflight.content,\n        file_path: validatedPath,\n        spec_folder: parsedForPreflight.specFolder,\n        database: database,\n        find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n        tenantId: saveScope.tenantId ?? undefined,\n        userId: saveScope.userId ?? undefined,\n        agentId: saveScope.agentId ?? undefined,\n      },\n      {\n        dry_run: dryRun,\n        check_anchors: true,\n        check_duplicates: !force,\n        check_similar: false,\n        check_tokens: true,\n        check_size: true,\n        strict_anchors: false,\n      }\n    );\n\n    if (dryRun) {\n      let preparedDryRun: PreparedParsedMemory;\n      try {\n        preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n          emitEvalMetrics: false,\n          qualityLoopMode: 'advisory',\n        });\n      } catch (error: unknown) {\n        if (error instanceof VRuleUnavailableError) {\n          return createMCPErrorResponse({\n            tool: 'memory_save',\n            error: error.message,\n            code: 'E_RUNTIME',\n            details: { requestId },\n            recovery: {\n              hint: 'Build the Spec Kit scripts workspace and retry the save.',\n              actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n              severity: 'warning',\n            },\n          });\n        }\n        // Classify dry-run preparation failures so even validation-only runs surface the\n        // specific cause instead of the generic E081 catch-all at the dispatcher.\n        const dryRunErrorMessage = error instanceof Error ? error.message : String(error);\n        return createMCPErrorResponse({\n          tool: 'memory_save',\n          error: dryRunErrorMessage,\n          code: classifySaveErrorCode(dryRunErrorMessage),\n          details: { requestId, ...extractSaveErrorDetails(dryRunErrorMessage) },\n          recovery: {\n            hint: 'Inspect the error message for the specific dry-run preparation failure.',\n            actions: ['Resolve the reported cause', 'Retry memory_save'],\n            severity: 'warning',\n          },\n        });\n      }\n      return buildDryRunResponse(preparedDryRun, parsedForPreflight, {\n        skipped: false,\n        errors: preflightResult.errors,\n        warnings: preflightResult.warnings,\n        details: preflightResult.details,\n        wouldPass: preflightResult.dry_run_would_pass ?? preflightResult.pass,\n      });\n    }\n\n    if (!preflightResult.pass) {\n      if (shouldPlanCanonicalSave) {\n        return buildPlannerResponse({\n          planner: {\n            filePath: validatedPath,\n            specFolder: parsedForPreflight.specFolder,\n            title: parsedForPreflight.title ?? path.basename(validatedPath),\n            status: 'blocked',\n            message: 'Planner found blocker(s) during pre-flight validation.',\n            plannerMode: 'plan-only',\n            routeTarget: serializePlannerRouteTarget({\n              routeCategory: routeAs ?? 'drop',\n              targetDocPath: validatedPath,\n              targetAnchorId: targetAnchorId ?? null,\n              mergeMode: mergeModeHint,\n            }),\n            proposedEdits: [],\n            blockers: preflightResult.errors.map((entry: string | { message: string; code?: string }) =>\n              serializePlannerBlocker(buildPlannerBlocker({\n                code: typeof entry === 'string' ? 'PREFLIGHT_BLOCKER' : (entry.code ?? 'PREFLIGHT_BLOCKER'),\n                message: typeof entry === 'string' ? entry : entry.message,\n                routeCategory: routeAs ?? undefined,\n                targetDocPath: validatedPath,\n                targetAnchorId: targetAnchorId ?? null,\n              }))\n            ),\n            advisories: preflightResult.warnings.map((entry: string | { message: string }) =>\n              serializePlannerAdvisory(buildPlannerAdvisory({\n                code: 'PREFLIGHT_WARNING',\n                message: typeof entry === 'string' ? entry : entry.message,\n                routeCategory: routeAs ?? undefined,\n                targetDocPath: validatedPath,\n                targetAnchorId: targetAnchorId ?? null,\n              }))\n            ),\n            followUpActions: [\n              serializePlannerFollowUpAction({\n                action: 'apply',\n                title: 'Retry with full-auto after fixing pre-flight blockers',\n                description: 'Fix the reported blockers, then request explicit full-auto mode.',\n                args: {\n                  filePath: validatedPath,\n                  plannerMode: 'full-auto',\n                  ...(routeAs ? { routeAs } : {}),\n                  ...(mergeModeHint ? { mergeModeHint } : {}),\n                  ...(targetAnchorId ? { targetAnchorId } : {}),\n                },\n              }),\n            ],\n          },\n        });\n      }\n\n      const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n        typeof e === 'string' ? e : e.message\n      ).join('; ');\n\n      // Use the actual error code from the\n      // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n      const firstError = preflightResult.errors[0];\n      const errorCode = (typeof firstError === 'object' && firstError?.code)\n        ? firstError.code\n        : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n      throw new preflight.PreflightError(\n        errorCode,\n        `Pre-flight validation failed: ${errorMessages}`,\n        {\n          errors: preflightResult.errors,\n          warnings: preflightResult.warnings,\n          recoverable: true,\n          suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n        }\n      );\n    }\n\n    if (preflightResult.warnings.length > 0) {\n      console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n      preflightResult.warnings.forEach((w: string | { message: string }) => {\n        const msg = typeof w === 'string' ? w : w.message;\n        console.warn(`[preflight]   - ${msg}`);\n      });\n    }\n  }\n\n  if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n    try {\n      const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n      // The compared payload IS the fingerprint object: both lookup inputs\n      // below point at this same idempotencySemantics value, so payloadHash\n      // always equals requestFingerprintHash and the receiptKey is derived from\n      // it. Consequence: distinct logical requests always produce distinct\n      // keys, so the same-key/different-payload 'conflict' status can never fire\n      // from this caller (a force-flip yields a key MISS, not a conflict). The\n      // conflict branch below is fail-safe defense-in-depth, not active\n      // protection. To make conflicts detectable, the payload would have to\n      // carry MORE than the key material (e.g. execution-mode flags); it\n      // deliberately does not, so a benign flag flip cannot become a false\n      // hard conflict.\n      const idempotencySemantics = {\n        filePath: canonicalValidatedPath,\n        contentHash: parsedForIdempotency.contentHash,\n        routeAs: routeAs ?? null,\n        mergeModeHint: mergeModeHint ?? null,\n        targetAnchorId: targetAnchorId ?? null,\n        scope: saveScope,\n        // A force-flipped retry is a DIFFERENT logical request: keeping force in\n        // the key material makes it a distinct key (a clean MISS that re-runs),\n        // never a collision with the non-forced receipt.\n        force: force === true,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_save',\n        contentHash: parsedForIdempotency.contentHash,\n        requestFingerprint: idempotencySemantics,\n        payload: idempotencySemantics,\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live state. After an A->B->A revert the receipt for A\n        // is intact but the active row now holds B (or, after deletion, a\n        // superseded row), so replaying A's old response would diverge from\n        // the index. Honor the replay ONLY when the active row for this logical\n        // identity still carries the receipt's content_hash AND is the same row\n        // the cached response reports. Content alone is insufficient: a planner\n        // re-create of identical content (the planner branch skips this whole\n        // block and never refreshes the receipt) produces a NEW id, so a\n        // content-only match would replay a response naming a deleted id and\n        // strand a follow-up update by that id. Mirror the handler's own\n        // active-row identity (findSamePathExistingMemory) and exclude retired\n        // tiers so a deprecated/archived predecessor cannot satisfy the match.\n        const activeRow = database.prepare(`\n          SELECT id, content_hash\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND parent_id IS NULL\n            AND (canonical_file_path = ? OR file_path = ?)\n            AND ${targetAnchorId != null ? 'anchor_id = ?' : 'anchor_id IS NULL'}\n            AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n            AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n            AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n            AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n            AND COALESCE(importance_tier, 'normal') NOT IN ('deprecated', 'archived')\n          ORDER BY id DESC\n          LIMIT 1\n        `).get(\n          parsedForIdempotency.specFolder,\n          canonicalValidatedPath,\n          validatedPath,\n          ...(targetAnchorId != null ? [targetAnchorId] : []),\n          saveScope.tenantId ?? null, saveScope.tenantId ?? null,\n          saveScope.userId ?? null, saveScope.userId ?? null,\n          saveScope.agentId ?? null, saveScope.agentId ?? null,\n          saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n        ) as { id: number; content_hash: string } | undefined;\n\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          activeRow\n          && activeRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || activeRow.id === replayMemoryId)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the\n        // re-indexed write stores its current response (the post-write store\n        // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n        // the stale receipt), then fall through to the normal save/reindex path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload === requestFingerprint (above),\n        // so a key match implies a payload match and lookup never returns\n        // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n        // material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_save',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical write.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n      idempotencyKey = null;\n    }\n  }\n\n  if (shouldPlanCanonicalSave) {\n    const plannerResult = await atomicSaveMemory({\n      file_path: validatedPath,\n      content: fs.readFileSync(validatedPath, 'utf8'),\n      plannerMode,\n      ...(routeAs ? { routeAs } : {}),\n      ...(mergeModeHint ? { mergeModeHint } : {}),\n      ...(targetAnchorId ? { targetAnchorId } : {}),\n    }, { force });\n\n    return buildPlannerResponse({\n      planner: {\n        filePath: validatedPath,\n        specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n        title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n        status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n        message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n        plannerMode: 'plan-only',\n        routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n          routeCategory: routeAs ?? 'drop',\n          targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n          targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n          mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n        }),\n        proposedEdits: plannerResult.proposedEdits ?? [],\n        blockers: plannerResult.blockers ?? [],\n        advisories: plannerResult.advisories ?? [],\n        followUpActions: plannerResult.followUpActions ?? [],\n      },\n    });\n  }\n\n  let result: IndexResult;\n  try {\n    result = await indexMemoryFile(validatedPath, {\n      force,\n      parsedOverride: parsedForPreflight,\n      asyncEmbedding,\n      plannerMode,\n      scope: saveScope,\n      routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n      provenance: (provenanceSource || provenanceActor)\n        ? { provenanceSource, provenanceActor, tool: 'memory_save' }\n        : undefined,\n    });\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n    // response code points at the actual failure mode instead of the generic E081 catch-all.\n    const indexErrorMessage = error instanceof Error ? error.message : String(error);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: indexErrorMessage,\n      code: classifySaveErrorCode(indexErrorMessage),\n      details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    // Wrap governance metadata in a transaction with rollback on failure.\n    // If governance application fails, delete the orphaned memory row to prevent\n    // persisted rows without tenant/session/retention metadata.\n    const applyGovernanceTx = database.transaction(() => {\n      applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n      recordGovernanceAudit(database, {\n        action: 'memory_save',\n        decision: 'allow',\n        memoryId: result.id,\n        tenantId,\n        userId,\n        agentId,\n        sessionId,\n        reason: 'governed_ingest',\n        metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n      });\n    });\n    try {\n      applyGovernanceTx();\n    } catch (govErr: unknown) {\n      // C2 FIX: Use full delete helper to clean up ALL ancillary records\n      // (vec_memories, BM25 index, causal edges, projections, etc.)\n      // not just memory_index, to prevent orphaned search phantoms.\n      const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n      console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n      try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n      // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n      // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n      // generic E081 catch-all.\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: govErrorMessage,\n        code: classifySaveErrorCode(govErrorMessage),\n        details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n        recovery: {\n          hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n          actions: ['Resolve the reported cause', 'Retry memory_save'],\n          severity: 'warning',\n        },","lineStart":2820,"lineEnd":3769,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781764293893,"end":1781764293899}},"metadata":{"openai":{"itemId":"fc_0ccf25a65e9d2ae5016a3390c47f188191b00eba2383ade4c9"}},"id":"prt_ed96d7fab0010H7kbI12Fkj4iN","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96d672a001h7N3UgLa0BSaZf"}}
