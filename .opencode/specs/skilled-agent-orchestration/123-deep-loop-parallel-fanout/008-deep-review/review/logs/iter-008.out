    76	): string {
    77	  return `${nodeAlias}.spec_folder = ${edgeAlias}.spec_folder
    78	      AND ${nodeAlias}.loop_type = ${edgeAlias}.loop_type
    79	      AND ${nodeAlias}.session_id = ${edgeAlias}.session_id
    80	      AND ${nodeAlias}.id = ${edgeAlias}.${edgeNodeColumn}`;
    81	}
