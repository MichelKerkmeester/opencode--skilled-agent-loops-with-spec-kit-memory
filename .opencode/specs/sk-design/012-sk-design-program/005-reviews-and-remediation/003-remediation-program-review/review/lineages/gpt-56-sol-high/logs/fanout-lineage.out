  \"killSwitchActive\": false,\n      \"causalBoosted\": 0,\n      \"coActivationBoosted\": 2,\n      \"communityInjected\": 0,\n      \"graphSignalsBoosted\": 0,\n      \"totalGraphInjected\": 0,\n      \"rolloutState\": \"bounded_runtime\"\n    },\n    \"sourceContract\": {\n      \"version\": \"gate-d-reader-ready-v1\",\n      \"archivedTierEnabled\": true,\n      \"legacyFallbackEnabled\": false,\n      \"includeArchivedCompatibility\": \"not_requested\",\n      \"preferredDocumentTypes\": [\n        \"spec_doc\",\n        \"continuity\"\n      ],\n      \"retainedResults\": 0,\n      \"droppedNonCanonicalResults\": 0,\n      \"countsBySourceKind\": {\n        \"spec_doc\": 0,\n        \"continuity\": 0,\n        \"constitutional\": 0\n      }\n    },\n    \"queryTimeExistenceFilter\": {\n      \"enabled\": false,\n      \"checked\": 0,\n      \"excluded\": 0\n    },\n    \"queryTimeExistenceFilterAggregate\": {\n      \"checked\": 0,\n      \"excluded\": 0\n    },\n    \"retrievalTrace\": {\n      \"traceId\": \"tr_mruunq68_q9ljun\",\n      \"query\": \"Review target .opencode/specs/sk-design/017-remediation-program-review: prior decisions, claimed remediation status, key implementation and verification context for a detached deep-review lineage.\",\n      \"intent\": \"understand\",\n      \"stages\": [\n        {\n          \"stage\": \"candidate\",\n          \"timestamp\": 1784650213955,\n          \"inputCount\": 0,\n          \"outputCount\": 0,\n          \"durationMs\": 0,\n          \"metadata\": {\n            \"channel\": \"d2-concept-expansion\",\n            \"originalQuery\": \"Review target .opencode/specs/sk-design/017-remediation-program-review: prior decisions, claimed remediation status, key implementation and verification context for a detached deep-review lineage.\",\n            \"expandedQuery\": \"Review target .opencode/specs/sk-design/017-remediation-program-review: prior decisions, claimed remediation status, key implementation and ve