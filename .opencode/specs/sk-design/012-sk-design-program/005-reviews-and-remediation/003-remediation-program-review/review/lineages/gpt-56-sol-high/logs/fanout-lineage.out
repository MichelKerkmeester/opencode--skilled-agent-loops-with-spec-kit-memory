{"type":"tool_use","timestamp":1784650185972,"sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","part":{"type":"tool","tool":"read","callID":"call_mgEmwW5ZX2ru1h2Yx3SvoxOF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n7: // ║         --base-artifact-dir).                                            ║\n8: // ║ Output: JSON to stdout.                                                  ║\n9: // ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: \n12: 'use strict';\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 1. IMPORTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: const fs = require('node:fs');\n19: const os = require('node:os');\n20: const path = require('node:path');\n21: const { spawn, spawnSync } = require('node:child_process');\n22: const { createHash } = require('node:crypto');\n23: \n24: const {\n25:   classifyExitCode,\n26:   maybeThrowTestFault,\n27:   validateNamespaceValue,\n28: } = require('./lib/cli-guards.cjs');\n29: \n30: const {\n31:   runCappedPool,\n32:   appendStatusLedger,\n33:   markOrphanedLineages,\n34:   readRetryCountsFromLedger,\n35:   createWavePlannerInterface,\n36:   writeOrchestrationSummary,\n37: } = require('./fanout-pool.cjs');\n38: \n39: const {\n40:   runSalvageSweep,\n41:   extractTextFromOpencodeJson,\n42: } = require('./fanout-salvage.cjs');\n43: \n44: const {\n45:   appendObservabilityEvent,\n46: } = require('../lib/deep-loop/observability-events.cjs');\n47: \n48: // ─────────────────────────────────────────────────────────────────────────────\n49: // 2. TSX BOOTSTRAP\n50: // ─────────────────────────────────────────────────────────────────────────────\n51: \n52: const TSX_LOADER = require.resolve('tsx');\n53: const isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n54: \n55: function runTsxBootstrap() {\n56:   const child = spawn(\n57:     process.execPath,\n58:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n59:     {\n60:       cwd: process.cwd(),\n61:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n62:       stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n63:     },\n64:   );\n65: \n66:   if (!process.stdin.isTTY && child.stdin) {\n67:     child.stdin.on('error', () => {});\n68:     process.stdin.pipe(child.stdin);\n69:   }\n70: \n71:   child.stdout?.pipe(process.stdout);\n72:   child.stderr?.pipe(process.stderr);\n73: \n74:   for (const signal of ['SIGINT', 'SIGTERM']) {\n75:     process.once(signal, () => {\n76:       child.kill(signal);\n77:     });\n78:   }\n79: \n80:   child.on('close', (status, signal) => {\n81:     if (status !== null) {\n82:       process.exit(status);\n83:     }\n84:     process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n85:   });\n86: }\n87: \n88: if (require.main === module && !isTsxLoaded) {\n89:   runTsxBootstrap();\n90: }\n91: \n92: // ─────────────────────────────────────────────────────────────────────────────\n93: // 3. HELPERS\n94: // ─────────────────────────────────────────────────────────────────────────────\n95: \n96: function parseArgs(argv = process.argv.slice(2)) {\n97:   const args = {};\n98:   for (let i = 0; i < argv.length; i += 1) {\n99:     const token = argv[i];\n100:     if (!token.startsWith('--')) {\n101:       throw inputError(`Unexpected positional argument: ${token}`);\n102:     }\n103:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n104:     const next = argv[i + 1];\n105:     if (next === undefined || next.startsWith('--')) {\n106:       args[key] = true;\n107:     } else {\n108:       args[key] = next;\n109:       i += 1;\n110:     }\n111:   }\n112:   return args;\n113: }\n114: \n115: function inputError(message) {\n116:   const err = new Error(message);\n117:   err.code = 'INPUT_VALIDATION';\n118:   return err;\n119: }\n120: \n121: function ensureString(args, key) {\n122:   if (!args[key] || typeof args[key] !== 'string') {\n123:     throw inputError(`${key} is required`);\n124:   }\n125:   return args[key];\n126: }\n127: \n128: function parseOptionalNumber(args, key) {\n129:   const raw = args[key];\n130:   if (raw === undefined || raw === false || raw === null || raw === '') {\n131:     return null;\n132:   }\n133:   if (raw === true || typeof raw !== 'string') {\n134:     throw inputError(`${key} must be a number`);\n135:   }\n136:   const value = Number(raw);\n137:   if (!Number.isFinite(value) || value < 0) {\n138:     throw inputError(`${key} must be a non-negative number`);\n139:   }\n140:   return value;\n141: }\n142: \n143: function readRawConfigNumber(rawConfig, names, fieldName) {\n144:   if (!isRecord(rawConfig)) return null;\n145:   for (const name of names) {\n146:     if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n147:     const raw = rawConfig[name];\n148:     if (raw === undefined || raw === null || raw === '') return null;\n149:     if (raw === true || raw === false) {\n150:       throw inputError(`${fieldName} must be a non-negative number`);\n151:     }\n152:     const value = Number(raw);\n153:     if (!Number.isFinite(value) || value < 0) {\n154:       throw inputError(`${fieldName} must be a non-negative number`);\n155:     }\n156:     return Math.floor(value);\n157:   }\n158:   return null;\n159: }\n160: \n161: function readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n162:   const value = readRawConfigNumber(rawConfig, names, fieldName);\n163:   if (value === null) return fallback;\n164:   if (value <= 0) {\n165:     throw inputError(`${fieldName} must be greater than 0`);\n166:   }\n167:   return value;\n168: }\n169: \n170: function rawConfigWithCliBudgetOverrides(rawConfig, args) {\n171:   const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n172:   const mappings = [\n173:     ['stallWatchdogMs', 'stallWatchdogMs'],\n174:     ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n175:     ['maxAggregateCostUnits', 'maxAggregateCostUnits'],\n176:     ['maxTokensPerLineage', 'maxTokensPerLineage'],\n177:     ['maxTokenBudget', 'maxTokenBudget'],\n178:     ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n179:     ['costUnitsPerIteration', 'costUnitsPerIteration'],\n180:     ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n181:   ];\n182:   for (const [targetKey, argKey] of mappings) {\n183:     if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n184:       merged[targetKey] = args[argKey];\n185:     }\n186:   }\n187:   return merged;\n188: }\n189: \n190: function normalizeStopPolicy(raw) {\n191:   if (raw === undefined || raw === false || raw === null || raw === '') {\n192:     return 'convergence';\n193:   }\n194:   if (raw === true || typeof raw !== 'string') {\n195:     throw inputError('stopPolicy must be convergence or max-iterations');\n196:   }\n197:   if (raw !== 'convergence' && raw !== 'max-iterations') {\n198:     throw inputError('stopPolicy must be convergence or max-iterations');\n199:   }\n200:   return raw;\n201: }\n202: \n203: function jsonOut(payload) {\n204:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n205: }\n206: \n207: function signalExitCode(signal) {\n208:   return signal === 'SIGINT' ? 130 : 143;\n209: }\n210: \n211: let fanoutSignalHandlersInstalled = false;\n212: \n213: function installFanoutSignalHandlers(onStop) {\n214:   if (fanoutSignalHandlersInstalled) return;\n215:   fanoutSignalHandlersInstalled = true;\n216: \n217:   for (const signal of ['SIGINT', 'SIGTERM']) {\n218:     process.once(signal, () => {\n219:       try {\n220:         onStop(signal);\n221:       } finally {\n222:         process.exit(signalExitCode(signal));\n223:       }\n224:     });\n225:   }\n226: }\n227: \n228: function updateLineageSnapshot(snapshots, event) {\n229:   if (!event || typeof event.label !== 'string') return;\n230:   const existing = snapshots.get(event.label) || { label: event.label };\n231: \n232:   if (event.event === 'started') {\n233:     snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n234:     return;\n235:   }\n236:   if (event.event === 'completed') {\n237:     snapshots.set(event.label, {\n238:       ...existing,\n239:       status: 'fulfilled',\n240:       completed_at_iso: event.at,\n241:       duration_ms: event.duration_ms,\n242:     });\n243:     return;\n244:   }\n245:   if (event.event === 'failed') {\n246:     snapshots.set(event.label, {\n247:       ...existing,\n248:       status: event.terminal === false ? 'retrying' : 'rejected',\n249:       completed_at_iso: event.at,\n250:       duration_ms: event.duration_ms,\n251:       error: event.error,\n252:     });\n253:     return;\n254:   }\n255:   if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n256:     snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n257:     return;\n258:   }\n259:   if (event.event === 'progress') {\n260:     snapshots.set(event.label, {\n261:       ...existing,\n262:       status: 'running',\n263:       updated_at_iso: event.at,\n264:       duration_ms: event.duration_ms,\n265:     });\n266:   }\n267: }\n268: \n269: function buildLineageSnapshots(lineages, snapshots) {\n270:   return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n271: }\n272: \n273: function summarizeSnapshots(lineages, snapshots) {\n274:   const results = buildLineageSnapshots(lineages, snapshots);\n275:   const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n276:   const failed = results.filter((result) => result.status === 'rejected').length;\n277:   return {\n278:     results,\n279:     summary: {\n280:       total: lineages.length,\n281:       succeeded,\n282:       failed,\n283:       all_failed: lineages.length > 0 && failed === lineages.length,\n284:     },\n285:   };\n286: }\n287: \n288: function observabilityPathForLedger(ledgerPath) {\n289:   return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n290: }\n291: \n292: function statusForLedgerEvent(entry) {\n293:   if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n294:     return entry.status;\n295:   }\n296:   if (!entry || typeof entry.event !== 'string') return 'unknown';\n297:   if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n298:   if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n299:   if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n300:   if (entry.event === 'stopped') return 'stopped';\n301:   if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n302:   // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n303:   // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n304:   if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n305:   if (entry.event === 'lag_ceiling_abort') return 'failed';\n306:   if (entry.event === 'stall_detected') return 'warning';\n307:   if (entry.event === 'budget_cap_exceeded') return 'failed';\n308:   if (entry.event === 'aggregate_budget_cap_exceeded') return 'failed';\n309:   return 'unknown';\n310: }\n311: \n312: function appendFanoutStatusLedger(ledgerPath, entry) {\n313:   appendStatusLedger(ledgerPath, entry);\n314:   try {\n315:     appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n316:       producer: 'fanout-run',\n317:       stream: 'orchestration-status',\n318:       subject: {\n319:         run_id: entry.run_id ?? null,\n320:         label: entry.label ?? null,\n321:         loop_type: entry.loop_type ?? null,\n322:         spec_folder: entry.spec_folder ?? null,\n323:       },\n324:       event: entry.event,\n325:       status: statusForLedgerEvent(entry),\n326:     });\n327:   } catch {\n328:     // Observability must not make the primary orchestration ledger fail.\n329:   }\n330: }\n331: \n332: const FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\n333: const WAVE_ASSIGNMENT_MODEL = 'wave';\n334: const WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\n335: const WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\n336: const STATE_LOG_BY_LOOP_TYPE = {\n337:   research: 'deep-research-state.jsonl',\n338:   review: 'deep-review-state.jsonl',\n339: };\n340: const ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\n341: const DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n342: \n343: function assertActiveFanoutLoopType(loopType) {\n344:   if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n345:     throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n346:   }\n347: }\n348: \n349: function hasNonEmptyArrayField(value) {\n350:   return Array.isArray(value) && value.length > 0;\n351: }\n352: \n353: function collectFlatPoolGuardRejections(fanoutConfig) {\n354:   const rejections = [];\n355:   if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n356:     rejections.push({\n357:       scope: 'fanout',\n358:       label: null,\n359:       field: 'assignment_model',\n360:       message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n361:     });\n362:   }\n363: \n364:   for (const lineage of fanoutConfig.executors) {\n365:     if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n366:       rejections.push({\n367:         scope: 'lineage',\n368:         label: lineage.label,\n369:         field: 'assignment_model',\n370:         message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n371:       });\n372:     }\n373: \n374:     const reservedFields = [];\n375:     if (hasNonEmptyArrayField(lineage.depends_on)) {\n376:       reservedFields.push('depends_on');\n377:     }\n378:     if (hasNonEmptyArrayField(lineage.touches)) {\n379:       reservedFields.push('touches');\n380:     }\n381:     if (reservedFields.length > 0) {\n382:       rejections.push({\n383:         scope: 'lineage',\n384:         label: lineage.label,\n385:         field: reservedFields.join(','),\n386:         message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n387:       });\n388:     }\n389:   }\n390: \n391:   return rejections;\n392: }\n393: \n394: /**\n395:  * Force fan-out execution onto the existing flat pool while wave planning is gated.\n396:  *\n397:  * @param {Object} fanoutConfig - Parsed fan-out config.\n398:  * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n399:  */\n400: function applyFlatPoolAssignmentGuard(fanoutConfig) {\n401:   const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n402:   return {\n403:     config: {\n404:       ...fanoutConfig,\n405:       assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n406:       executors: fanoutConfig.executors.map((lineage) => ({\n407:         ...lineage,\n408:         assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n409:       })),\n410:     },\n411:     rejections,\n412:   };\n413: }\n414: \n415: function logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n416:   if (rejections.length === 0) {\n417:     return;\n418:   }\n419:   const wavePlanner = createWavePlannerInterface();\n420:   for (const rejection of rejections) {\n421:     const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n422:     process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n423:     appendFanoutStatusLedger(ledgerPath, {\n424:       event: 'assignment_model_rejected',\n425:       severity: 'warning',\n426:       at: new Date().toISOString(),\n427:       run_id: runId,\n428:       loop_type: loopType,\n429:       spec_folder: specFolder,\n430:       planner_status: wavePlanner.status,\n431:       fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n432:       ...rejection,\n433:     });\n434:   }\n435: }\n436: \n437: // Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\n438: const SPECKIT_STATE_ENV_BY_KIND = {\n439:   'cli-codex': 'SPECKIT_CODEX_STATE_DIR',\n440:   'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n441:   'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n442: };\n443: \n444: const activeLineageProcesses = new Set();\n445: const WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\n446: const WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\n447: const WAIT_SLEEP_CHUNK_MS = 200;\n448: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n449: const DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n450: \n451: function stopActiveLineageProcesses(signal) {\n452:   for (const child of activeLineageProcesses) {\n453:     terminateLineageProcess(child, signal);\n454:   }\n455: }\n456: \n457: function expandHomeDir(inputPath) {\n458:   if (inputPath === '~') {\n459:     return os.homedir();\n460:   }\n461:   if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n462:     return path.join(os.homedir(), inputPath.slice(2));\n463:   }\n464:   return inputPath;\n465: }\n466: \n467: function isPathInside(childPath, parentPath) {\n468:   const relative = path.relative(parentPath, childPath);\n469:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n470: }\n471: \n472: function physicalPathForValidation(targetPath) {\n473:   try {\n474:     return fs.realpathSync.native(targetPath);\n475:   } catch {\n476:     const parentPath = path.dirname(targetPath);\n477:     try {\n478:       return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n479:     } catch {\n480:       return targetPath;\n481:     }\n482:   }\n483: }\n484: \n485: function validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n486:   if (baseArtifactDir.includes('\\0')) {\n487:     throw inputError('baseArtifactDir must not contain null bytes');\n488:   }\n489:   if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n490:     throw inputError('baseArtifactDir must not contain \"..\" path segments');\n491:   }\n492:   const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n493:   const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n494:   const expectedRoot = path.join(resolvedSpecFolder, loopType);\n495:   if (!isPathInside(resolvedBase, expectedRoot)) {\n496:     throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n497:   }\n498:   return baseArtifactDir;\n499: }\n500: \n501: function validateClaudeConfigDir(configDir) {\n502:   if (typeof configDir !== 'string' || configDir.trim() === '') {\n503:     throw inputError('configDir must be a non-empty string when set');\n504:   }\n505:   validateNamespaceValue(configDir, 'configDir', inputError);\n506: \n507:   const expanded = expandHomeDir(configDir);\n508:   const resolved = path.resolve(process.cwd(), expanded);\n509:   const homeDir = path.resolve(os.homedir());\n510:   const cwd = path.resolve(process.cwd());\n511:   const homeRelative = path.relative(homeDir, resolved);\n512:   const cwdRelative = path.relative(cwd, resolved);\n513:   const homeTop = homeRelative.split(path.sep)[0] || '';\n514:   const cwdTop = cwdRelative.split(path.sep)[0] || '';\n515:   const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n516: \n517:   if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n518:     return resolved;\n519:   }\n520:   if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n521:     return resolved;\n522:   }\n523:   throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n524: }\n525: \n526: function terminateLineageProcess(child, signal) {\n527:   if (!child || child.killed) return;\n528:   if (process.platform !== 'win32' && child.pid) {\n529:     try {\n530:       process.kill(-child.pid, signal);\n531:       return;\n532:     } catch (error) {\n533:       if (error && error.code !== 'ESRCH') {\n534:         try {\n535:           child.kill(signal);\n536:         } catch {\n537:           // The process may have already exited between the group and direct kill attempts.\n538:         }\n539:       }\n540:       return;\n541:     }\n542:   }\n543:   try {\n544:     child.kill(signal);\n545:   } catch {\n546:     // The process may have already exited.\n547:   }\n548: }\n549: \n550: function expectedLineageArtifactPaths(loopType, lineageDir) {\n551:   assertActiveFanoutLoopType(loopType);\n552:   if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n553:   return [path.join(lineageDir, 'research.md')];\n554: }\n555: \n556: function hasNonEmptyFile(filePath) {\n557:   try {\n558:     return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n559:   } catch {\n560:     return false;\n561:   }\n562: }\n563: \n564: function findMissingLineageArtifacts(loopType, lineageDir) {\n565:   return expectedLineageArtifactPaths(loopType, lineageDir)\n566:     .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n567: }\n568: \n569: function parseJsonlRecords(filePath) {\n570:   const text = fs.readFileSync(filePath, 'utf8');\n571:   return text\n572:     .split(/\\r?\\n/)\n573:     .filter((line) => line.trim() !== '')\n574:     .map((line) => JSON.parse(line));\n575: }\n576: \n577: function lineageStateLogName(loopType) {\n578:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n579: }\n580: \n581: function readLineageStateRecords(loopType, lineageDir) {\n582:   const stateLogName = lineageStateLogName(loopType);\n583:   if (!stateLogName) {\n584:     return { statePath: null, records: [], missing: true, parseError: null };\n585:   }\n586:   const statePath = path.join(lineageDir, stateLogName);\n587:   if (!hasNonEmptyFile(statePath)) {\n588:     return { statePath, records: [], missing: true, parseError: null };\n589:   }\n590:   try {\n591:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n592:   } catch (error) {\n593:     return {\n594:       statePath,\n595:       records: [],\n596:       missing: false,\n597:       parseError: error instanceof Error ? error.message : String(error),\n598:     };\n599:   }\n600: }\n601: \n602: // A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n603: // spelling. The iteration-count check above already proves the lineage ran every iteration,\n604: // so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n605: // \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n606: // such as convergence, a manual stop, or an error.\n607: function isMaxIterationsStopReason(stopReason) {\n608:   if (typeof stopReason !== 'string') return false;\n609:   return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n610: }\n611: \n612: function findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n613:   if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n614:   if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n615:     return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n616:   }\n617: \n618:   if (!stateRead || stateRead.missing) {\n619:     return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n620:   }\n621:   if (stateRead.parseError) {\n622:     return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n623:   }\n624: \n625:   const records = stateRead.records;\n626:   const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n627:   const synthesis = [...records]\n628:     .reverse()\n629:     .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n630:   if (!synthesis) {\n631:     return 'missing synthesis_complete event for max-iterations stop-policy validation';\n632:   }\n633: \n634:   const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n635:     ? Number(synthesis.totalIterations)\n636:     : iterationCount;\n637:   if (totalIterations !== lineage.iterations) {\n638:     return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n639:   }\n640:   if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n641:     return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n642:   }\n643:   return null;\n644: }\n645: \n646: function isRecord(value) {\n647:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n648: }\n649: \n650: function normalizeStallWatchdogMs(rawConfig) {\n651:   // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n652:   // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n653:   // because this knob is intentionally outside fanoutConfigSchema. Non-disableable while\n654:   // running autonomously: an explicit 0 no longer opts out, it is rejected.\n655:   const value = readRawConfigNumber(rawConfig, [\n656:     'stallWatchdogMs',\n657:     'stall_watchdog_ms',\n658:     'stallWatchdogMillis',\n659:     'stall_watchdog_millis',\n660:   ], 'stallWatchdogMs');\n661:   if (value === 0) {\n662:     throw inputError('stallWatchdogMs must be greater than 0; stall detection cannot be disabled for autonomous fan-out runs');\n663:   }\n664:   return value ?? 300000;\n665: }\n666: \n667: const DEFAULT_MAX_COST_UNITS_PER_LINEAGE = 72;\n668: \n669: function normalizeLineageBudgetGuards(rawConfig = {}) {\n670:   return {\n671:     max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n672:       'maxCostUnitsPerLineage',\n673:       'max_cost_units_per_lineage',\n674:       'maxLineageCostUnits',\n675:       'max_lineage_cost_units',\n676:       'maxTokensPerLineage',\n677:       'max_tokens_per_lineage',\n678:       'maxTokenBudget',\n679:       'max_token_budget',\n680:       'maxTokenBudgetPerLineage',\n681:       'max_token_budget_per_lineage',\n682:     ], 'maxCostUnitsPerLineage') ?? DEFAULT_MAX_COST_UNITS_PER_LINEAGE,\n683:     cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n684:       'costUnitsPerIteration',\n685:       'cost_units_per_iteration',\n686:       'estimatedTokensPerIteration',\n687:       'estimated_tokens_per_iteration',\n688:     ], 'costUnitsPerIteration', 1),\n689:   };\n690: }\n691: \n692: function computeLineageBudgetUpperBound(lineage, guardsInput = {}, maxRetries = 0) {\n693:   const guards = normalizeLineageBudgetGuards(guardsInput);\n694:   const rawIterations = Number(lineage && lineage.iterations);\n695:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n696:   const normalizedRetries = Number.isFinite(Number(maxRetries)) && Number(maxRetries) >= 0\n697:     ? Math.floor(Number(maxRetries))\n698:     : 0;\n699:   const totalAttempts = normalizedRetries + 1;\n700:   return {\n701:     ...guards,\n702:     iterations,\n703:     total_attempts: totalAttempts,\n704:     estimated_cost_units: iterations * guards.cost_units_per_iteration * totalAttempts,\n705:   };\n706: }\n707: \n708: function evaluateLineageBudgetCap(input = {}) {\n709:   const upperBound = computeLineageBudgetUpperBound(\n710:     input.lineage || {},\n711:     input.guards || input,\n712:     input.maxRetries,\n713:   );\n714:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n715:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n716:   return {\n717:     continue_allowed: !exceeded,\n718:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n719:     upper_bound: upperBound,\n720:   };\n721: }\n722: \n723: // Aggregate budget across every expanded lineage in a run. This is a SEPARATE ceiling\n724: // from DEFAULT_MAX_COST_UNITS_PER_LINEAGE above: the per-lineage cap bounds any single\n725: // lineage, this bounds the whole fan-out submission, and both are enforced independently\n726: // (a run may pass one and still fail the other).\n727: const DEFAULT_MAX_AGGREGATE_COST_UNITS = 288;\n728: \n729: function normalizeAggregateBudgetGuards(rawConfig = {}) {\n730:   return {\n731:     max_aggregate_cost_units: readRawConfigNumber(rawConfig, [\n732:       'maxAggregateCostUnits',\n733:       'max_aggregate_cost_units',\n734:       'maxTotalCostUnits',\n735:       'max_total_cost_units',\n736:     ], 'maxAggregateCostUnits') ?? DEFAULT_MAX_AGGREGATE_COST_UNITS,\n737:   };\n738: }\n739: \n740: function computeAggregateBudgetUpperBound(lineages, guardsInput = {}, maxRetries = 0) {\n741:   const aggregateGuards = normalizeAggregateBudgetGuards(guardsInput);\n742:   const lineageGuards = normalizeLineageBudgetGuards(guardsInput);\n743:   const perLineage = (lineages || []).map((lineage) => {\n744:     const upperBound = computeLineageBudgetUpperBound(lineage, lineageGuards, maxRetries);\n745:     return { label: lineage && lineage.label, estimated_cost_units: upperBound.estimated_cost_units };\n746:   });\n747:   const estimatedCostUnits = perLineage.reduce((sum, entry) => sum + entry.estimated_cost_units, 0);\n748:   return {\n749:     max_aggregate_cost_units: aggregateGuards.max_aggregate_cost_units,\n750:     estimated_cost_units: estimatedCostUnits,\n751:     lineage_count: perLineage.length,\n752:     per_lineage: perLineage,\n753:   };\n754: }\n755: \n756: function evaluateAggregateBudgetCap(input = {}) {\n757:   const upperBound = computeAggregateBudgetUpperBound(\n758:     input.lineages || [],\n759:     input.guards || input,\n760:     input.maxRetries,\n761:   );\n762:   const exceeded = upperBound.max_aggregate_cost_units > 0\n763:     && upperBound.estimated_cost_units > upperBound.max_aggregate_cost_units;\n764:   return {\n765:     continue_allowed: !exceeded,\n766:     stop_reasons: exceeded ? ['max_aggregate_cost_units'] : [],\n767:     upper_bound: upperBound,\n768:   };\n769: }\n770: \n771: function buildTimestampAnomalyCounts(check) {\n772:   return {\n773:     anomalous: check.anomalous,\n774:     untimestamped: check.untimestamped,\n775:     unparseable: check.unparseable,\n776:     total: check.total,\n777:   };\n778: }\n779: \n780: function buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n781:   return {\n782:     label: lineage.label,\n783:     state_log: statePath,\n784:     window: {\n785:       start_at_iso: check.windowStart,\n786:       end_at_iso: check.windowEnd,\n787:       tolerance_ms: check.toleranceMs,\n788:     },\n789:     counts: buildTimestampAnomalyCounts(check),\n790:     sample: check.sample,\n791:   };\n792: }\n793: \n794: function collectTimestampAnomalies(results) {\n795:   return results\n796:     .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n797:     .map((result) => result.output.timestamp_anomaly);\n798: }\n799: \n800: function normalizeNonNegativeDelayMs(value) {\n801:   if (value === undefined || value === null) return null;\n802:   const n = Number(value);\n803:   if (!Number.isFinite(n) || n < 0) return null;\n804:   return Math.floor(n);\n805: }\n806: \n807: function normalizeWaitDurationMs(value) {\n808:   return normalizeNonNegativeDelayMs(value) ?? 0;\n809: }\n810: \n811: function waitCheckpointPath(baseArtifactDir) {\n812:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n813: }\n814: \n815: function atomicWriteJson(filePath, payload) {\n816:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n817:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n818:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n819:   fs.renameSync(tmpPath, filePath);\n820: }\n821: \n822: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n823:   const durationMs = normalizeWaitDurationMs(waitMs);\n824:   const updatedAt = new Date(nowMs).toISOString();\n825:   if (durationMs <= 0) {\n826:     return {\n827:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n828:       status: 'idle',\n829:       nextRunAt: null,\n830:       remainingDelayMs: null,\n831:       updatedAt,\n832:       runId,\n833:       loopType,\n834:       specFolder,\n835:     };\n836:   }\n837: \n838:   return {\n839:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n840:     status: 'waiting',\n841:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n842:     remainingDelayMs: durationMs,\n843:     updatedAt,\n844:     runId,\n845:     loopType,\n846:     specFolder,\n847:   };\n848: }\n849: \n850: function normalizeWaitCheckpoint(raw, context) {\n851:   if (!isRecord(raw)) {\n852:     throw inputError('wait checkpoint must be a JSON object');\n853:   }\n854: \n855:   const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n856:   const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n857:   const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n858:   const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n859:     ? raw.nextRunAt\n860:     : null;\n861:   const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n862:   const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n863:   const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n864:   const base = {\n865:     runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n866:     loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n867:     specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n868:   };\n869: \n870:   const checkpoint = waiting\n871:     ? {\n872:         schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n873:         status: 'waiting',\n874:         nextRunAt,\n875:         remainingDelayMs,\n876:         updatedAt: new Date(nowMs).toISOString(),\n877:         ...base,\n878:       }\n879:     : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n880:   const staleWaitingFields = !waiting\n881:     && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n882:   const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n883: \n884:   return {\n885:     checkpoint,\n886:     migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n887:   };\n888: }\n889: \n890: function readWaitCheckpoint(checkpointPath, context) {\n891:   if (!fs.existsSync(checkpointPath)) {\n892:     return { exists: false, checkpoint: null, migrated: false };\n893:   }\n894: \n895:   let raw;\n896:   try {\n897:     raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n898:   } catch (error) {\n899:     throw inputError(\n900:       `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n901:     );\n902:   }\n903: \n904:   const normalized = normalizeWaitCheckpoint(raw, context);\n905:   if (normalized.migrated) {\n906:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n907:   }\n908:   return { exists: true, ...normalized };\n909: }\n910: \n911: function sleepWaitChunk(ms) {\n912:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n913: }\n914: \n915: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n916:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n917:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n918: \n919:   while (remainingDelayMs > 0) {\n920:     atomicWriteJson(checkpointPath, {\n921:       ...checkpoint,\n922:       remainingDelayMs,\n923:       updatedAt: new Date().toISOString(),\n924:     });\n925:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n926:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n927:   }\n928: \n929:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n930: }\n931: \n932: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n933:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n934:   const loaded = readWaitCheckpoint(checkpointPath, context);\n935:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n936:     return { didWait: false, migrated: loaded.migrated };\n937:   }\n938: \n939:   appendFanoutStatusLedger(ledgerPath, {\n940:     event: 'resume_waiting',\n941:     at: new Date().toISOString(),\n942:     run_id: runId,\n943:     loop_type: loopType,\n944:     spec_folder: specFolder,\n945:     nextRunAt: loaded.checkpoint.nextRunAt,\n946:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n947:   });\n948: \n949:   await waitUntilCheckpointExpires({\n950:     checkpointPath,\n951:     checkpoint: loaded.checkpoint,\n952:     context: { runId, loopType, specFolder },\n953:   });\n954: \n955:   appendFanoutStatusLedger(ledgerPath, {\n956:     event: 'resume_waiting_complete',\n957:     at: new Date().toISOString(),\n958:     run_id: runId,\n959:     loop_type: loopType,\n960:     spec_folder: specFolder,\n961:   });\n962: \n963:   return { didWait: true, migrated: loaded.migrated };\n964: }\n965: \n966: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n967:   const durationMs = normalizeWaitDurationMs(waitMs);\n968:   if (durationMs <= 0) {\n969:     return { didWait: false };\n970:   }\n971: \n972:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n973:   atomicWriteJson(checkpointPath, checkpoint);\n974:   appendFanoutStatusLedger(ledgerPath, {\n975:     event: 'wait_checkpoint_persisted',\n976:     at: checkpoint.updatedAt,\n977:     run_id: runId,\n978:     loop_type: loopType,\n979:     spec_folder: specFolder,\n980:     nextRunAt: checkpoint.nextRunAt,\n981:     remainingDelayMs: checkpoint.remainingDelayMs,\n982:   });\n983: \n984:   await waitUntilCheckpointExpires({\n985:     checkpointPath,\n986:     checkpoint,\n987:     context: { runId, loopType, specFolder },\n988:   });\n989: \n990:   appendFanoutStatusLedger(ledgerPath, {\n991:     event: 'wait_checkpoint_cleared',\n992:     at: new Date().toISOString(),\n993:     run_id: runId,\n994:     loop_type: loopType,\n995:     spec_folder: specFolder,\n996:   });\n997: \n998:   return { didWait: true };\n999: }\n1000: \n1001: /**\n1002:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1003:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1004:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1005:  */\n1006: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1007:   assertActiveFanoutLoopType(loopType);\n1008:   const skillFile =\n1009:     loopType === 'review'\n1010:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1011:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1012:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1013:   const detachedIntro = lineage.kind === 'cli-opencode'\n1014:     ? [\n1015:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1016:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1017:         ``,\n1018:       ]\n1019:     : lineage.kind === 'native'\n1020:       ? [\n1021:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1022:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1023:           ``,\n1024:         ]\n1025:       : [];\n1026:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1027:   const stopPolicy = options.stopPolicy || 'convergence';\n1028:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1029:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1030:     : hasIterationCap\n1031:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1032:       : 'to legal convergence';\n1033:   const params = [\n1034:     `  spec_folder: ${specFolder}`,\n1035:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1036:     `  session_id: ${sessionId}`,\n1037:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1038:     `  loop_type: ${loopType}`,\n1039:     `  config.stopPolicy: ${stopPolicy}`,\n1040:   ];\n1041:   if (researchTopic) {\n1042:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1043:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1044:     // Review loops scope by spec_folder and intentionally pass no topic.\n1045:     params.push(`  research_topic: ${researchTopic}`);\n1046:   }\n1047:   if (hasIterationCap) {\n1048:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1049:   }\n1050:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1051:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1052:   }\n1053:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1054:   // still requires the same review setup bindings the native command path pre-binds.\n1055:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1056:   // different setup contract than native lineages.\n1057:   const setupBindings =\n1058:     loopType === 'review'\n1059:       ? [\n1060:           ``,\n1061:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1062:           `review_target: ${specFolder}`,\n1063:           `review_target_type: spec-folder`,\n1064:           `review_dimensions: all`,\n1065:           `spec_folder: ${specFolder}`,\n1066:           `execution_mode: AUTONOMOUS`,\n1067:           `lineage_mode: auto`,\n1068:           ``,\n1069:         ]\n1070:       : [];\n1071:   return [\n1072:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1073:     ...detachedIntro,\n1074:     ``,\n1075:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1076:     ...params,\n1077:     ...setupBindings,\n1078:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1079:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1080:     `command; bind artifact_dir directly to the override value.`,\n1081:     ``,\n1082:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1083:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1084:     ``,\n1085:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1086:   ].join('\\n');\n1087: }\n1088: \n1089: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1090:   assertActiveFanoutLoopType(loopType);\n1091:   const maxIterations = lineage.iterations || 12;\n1092:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1093:   const stopPolicy = options.stopPolicy || 'convergence';\n1094:   const sessionId = options.sessionId || '';\n1095:   const args = [\n1096:     ':auto',\n1097:     JSON.stringify(specFolder),\n1098:     `--spec-folder=${specFolder}`,\n1099:     `--max-iterations=${maxIterations}`,\n1100:     `--convergence=${convergenceThreshold}`,\n1101:     `--stop-policy=${stopPolicy}`,\n1102:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1103:     '--lineage-mode=auto',\n1104:   ];\n1105:   if (loopType === 'research' && options.researchTopic) {\n1106:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1107:   }\n1108: \n1109:   return [\n1110:     args.join(' '),\n1111:     '',\n1112:     'PRE-BOUND SETUP ANSWERS:',\n1113:     `review_target: ${specFolder}`,\n1114:     'review_target_type: spec-folder',\n1115:     'review_dimensions: all',\n1116:     `spec_folder: ${specFolder}`,\n1117:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1118:     'execution_mode: AUTONOMOUS',\n1119:     'lineage_mode: auto',\n1120:     `maxIterations: ${maxIterations}`,\n1121:     `convergenceThreshold: ${convergenceThreshold}`,\n1122:     `stop_policy: ${stopPolicy}`,\n1123:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1124:   ].join('\\n');\n1125: }\n1126: \n1127: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1128: // ceiling and a positive override may only narrow it, never widen past it.\n1129: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1130: \n1131: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1132:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1133:     throw inputError(\n1134:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1135:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1136:     );\n1137:   }\n1138: }\n1139: \n1140: /**\n1141:  * Compute a generous timeout for a full lineage loop run.\n1142:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1143:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1144:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1145:  */\n1146: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1147:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1148:   const iters = lineage.iterations || 12;\n1149:   const perIterSecs = lineage.timeoutSeconds || 900;\n1150:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1151:     ? ceilingHoursOverride * 60 * 60 * 1000\n1152:     : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n1153:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1154: }\n1155: \n1156: function normalizeProgressHeartbeatMs(seconds) {\n1157:   const value = Number(seconds);\n1158:   if (!Number.isFinite(value) || value <= 0) return 0;\n1159:   return Math.max(1, Math.floor(value * 1000));\n1160: }\n1161: \n1162: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1163:   const explicit = readRawConfigNumber(rawConfig, [\n1164:     'postExitGraceMs',\n1165:     'post_exit_grace_ms',\n1166:     'postSubprocessExitGraceMs',\n1167:     'post_subprocess_exit_grace_ms',\n1168:     'orchestratorPostExitGraceMs',\n1169:     'orchestrator_post_exit_grace_ms',\n1170:   ], 'postExitGraceMs');\n1171:   if (explicit !== null) return explicit;\n1172: \n1173:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1174:     ? progressHeartbeatMs * 2\n1175:     : 0;\n1176:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1177: }\n1178: \n1179: function slotDurationMsFromHrtime(hrStart) {\n1180:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1181:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1182: }\n1183: \n1184: function computeSkippedCount(slotDurationMs, intervalMs) {\n1185:   const elapsed = Number(slotDurationMs);\n1186:   const interval = Number(intervalMs);\n1187:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1188:     return 0;\n1189:   }\n1190:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1191: }\n1192: \n1193: function buildSlotAccounting(hrStart, intervalMs) {\n1194:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1195:   return {\n1196:     slotDurationMs,\n1197:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1198:   };\n1199: }\n1200: \n1201: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1202:   if (!event || typeof event.label !== 'string') return event;\n1203:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1204: \n1205:   const accounting = accountingByLabel.get(event.label);\n1206:   if (!accounting) return event;\n1207:   return {\n1208:     ...event,\n1209:     skippedCount: accounting.skippedCount,\n1210:     slotDurationMs: accounting.slotDurationMs,\n1211:   };\n1212: }\n1213: \n1214: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1215:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1216:     return () => {};\n1217:   }\n1218:   const startedAtMs = Date.now();\n1219:   const timer = setInterval(() => {\n1220:     appendFanoutStatusLedger(ledgerPath, {\n1221:       event: 'progress',\n1222:       label,\n1223:       at: new Date().toISOString(),\n1224:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1225:         gauges: getGauges(),\n1226:       });\n1227:       if (typeof onProgress === 'function') onProgress();\n1228:     }, cadenceMs);\n1229:   timer.unref?.();\n1230:   return () => clearInterval(timer);\n1231: }\n1232: \n1233: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1234:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1235:     return () => {};\n1236:   }\n1237: \n1238:   let timer = null;\n1239:   let fired = false;\n1240:   const schedule = () => {\n1241:     if (fired) return;\n1242:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1243:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1244:     timer = setTimeout(() => {\n1245:       timer = null;\n1246:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1247:       if (latestQuietMs >= thresholdMs) {\n1248:         fired = true;\n1249:         appendFanoutStatusLedger(ledgerPath, {\n1250:           event: 'stall_detected',\n1251:           label,\n1252:           at: new Date().toISOString(),\n1253:           severity: 'warning',\n1254:           metric: 'time_since_last_lineage_event',\n1255:           stall_watchdog_ms: thresholdMs,\n1256:           quiet_ms: Math.floor(latestQuietMs),\n1257:           gauges: getGauges(),\n1258:         });\n1259:         return;\n1260:       }\n1261:       schedule();\n1262:     }, delayMs);\n1263:     timer.unref?.();\n1264:   };\n1265: \n1266:   schedule();\n1267:   return () => {\n1268:     fired = true;\n1269:     if (timer) clearTimeout(timer);\n1270:   };\n1271: }\n1272: \n1273: /**\n1274:  * Run a lineage subprocess without blocking the Node event loop.\n1275:  *\n1276:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1277:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1278:  * thread until each child exited, serializing every lineage regardless of the\n1279:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1280:  *\n1281:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1282:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1283:  *\n1284:  * @param {string} command - Executable to run.\n1285:  * @param {string[]} cmdArgs - Arguments for the executable.\n1286:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1287:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1288:  */\n1289: function runLineageProcess(command, cmdArgs, opts) {\n1290:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1291:   const hasInput = typeof opts.input === 'string';\n1292: \n1293:   return new Promise((resolvePromise) => {\n1294:     let child;\n1295:     try {\n1296:       child = spawn(command, cmdArgs, {\n1297:         cwd,\n1298:         env,\n1299:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1300:         detached: process.platform !== 'win32',\n1301:       });\n1302:     } catch (error) {\n1303:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1304:       return;\n1305:     }\n1306:     activeLineageProcesses.add(child);\n1307:     if (typeof opts.onSpawn === 'function') {\n1308:       opts.onSpawn({ pid: child.pid });\n1309:     }\n1310: \n1311:     let stdout = '';\n1312:     let stdoutBytes = 0;\n1313:     let truncated = false;\n1314:     let timedOut = false;\n1315:     let settled = false;\n1316:     let spawnError;\n1317: \n1318:     const timer = setTimeout(() => {\n1319:       timedOut = true;\n1320:       terminateLineageProcess(child, 'SIGTERM');\n1321:     }, timeoutMs);\n1322:     timer.unref?.();\n1323: \n1324:     const abortHandler = () => {\n1325:       terminateLineageProcess(child, 'SIGTERM');\n1326:     };\n1327:     if (opts.abortSignal) {\n1328:       if (opts.abortSignal.aborted) {\n1329:         abortHandler();\n1330:       } else {\n1331:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1332:       }\n1333:     }\n1334: \n1335:     child.stdout?.setEncoding('utf8');\n1336:     child.stdout?.on('data', (chunk) => {\n1337:       if (typeof opts.onOutput === 'function') opts.onOutput();\n1338:       if (truncated) return;\n1339:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1340:       if (stdoutBytes > maxBuffer) {\n1341:         truncated = true;\n1342:         terminateLineageProcess(child, 'SIGTERM');\n1343:         return;\n1344:       }\n1345:       stdout += chunk;\n1346:     });\n1347:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1348:     child.stderr?.resume();\n1349: \n1350:     child.on('error', (error) => {\n1351:       spawnError = error;\n1352:     });\n1353: \n1354:     child.on('close', (code, signal) => {\n1355:       if (settled) return;\n1356:       settled = true;\n1357:       activeLineageProcesses.delete(child);\n1358:       clearTimeout(timer);\n1359:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1360:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1361:       if (typeof opts.onExit === 'function') {\n1362:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1363:       }\n1364:       resolvePromise({\n1365:         status: timedOut ? null : code,\n1366:         signal: effectiveSignal,\n1367:         stdout,\n1368:         ...(spawnError ? { error: spawnError } : {}),\n1369:       });\n1370:     });\n1371: \n1372:     if (hasInput) {\n1373:       child.stdin?.on('error', () => {});\n1374:       child.stdin?.end(opts.input);\n1375:     }\n1376:   });\n1377: }\n1378: \n1379: function digestText(value) {\n1380:   return createHash('sha256').update(String(value)).digest('hex');\n1381: }\n1382: \n1383: const executableIdentityCache = new Map();\n1384: \n1385: function resolveExecutableVersion(command, options = {}) {\n1386:   if (typeof options.executableVersion === 'string' && options.executableVersion.trim()) {\n1387:     return options.executableVersion.trim();\n1388:   }\n1389:   const env = options.env || process.env;\n1390:   const pathEntries = String(env.PATH || '').split(path.delimiter).filter(Boolean);\n1391:   for (const entry of pathEntries) {\n1392:     const candidate = path.join(entry, command);\n1393:     try {\n1394:       const executablePath = fs.realpathSync(candidate);\n1395:       const stat = fs.statSync(executablePath);\n1396:       if (!stat.isFile()) continue;\n1397:       const cacheKey = `${executablePath}:${stat.size}:${stat.mtimeMs}`;\n1398:       const cached = executableIdentityCache.get(cacheKey);\n1399:       if (cached) return cached;\n1400:       const identity = `sha256:${createHash('sha256').update(fs.readFileSync(executablePath)).digest('hex')}`;\n1401:       executableIdentityCache.set(cacheKey, identity);\n1402:       return identity;\n1403:     } catch {}\n1404:   }\n1405:   return 'unknown';\n1406: }\n1407: \n1408: function effectiveWebSearchPolicy(lineage) {\n1409:   return lineage.liveTools?.webSearch || 'inherit';\n1410: }\n1411: \n1412: /**\n1413:  * Build the allowlisted fingerprint payload without raw prompts or environment maps.\n1414:  *\n1415:  * @param {Object} input - Resolved invocation fields.\n1416:  * @returns {Object} Canonical JSON-safe payload.\n1417:  */\n1418: function buildInvocationFingerprintPayload(input) {\n1419:   const promptDigest = digestText(input.prompt);\n1420:   const promptArgIndexes = new Set(input.promptArgIndexes || []);\n1421:   const argv = input.args.map((arg, index) => (\n1422:     promptArgIndexes.has(index) ? `<prompt:${promptDigest}>` : arg\n1423:   ));\n1424:   return {\n1425:     kind: input.kind,\n1426:     executable: input.command,\n1427:     executableVersion: input.executableVersion || 'unknown',\n1428:     model: input.model,\n1429:     effort: input.reasoningEffort,\n1430:     tier: input.serviceTier,\n1431:     sandboxPosture: {\n1432:       sandboxMode: input.resolvedSandbox,\n1433:       permissionMode: input.resolvedPermission,\n1434:     },\n1435:     webSearch: input.webSearch,\n1436:     argv,\n1437:     promptDigest,\n1438:   };\n1439: }\n1440: \n1441: function finalizeLineageCommand(input) {\n1442:   const effectiveConfig = {\n1443:     kind: input.kind,\n1444:     executable: input.command,\n\n(Output capped at 50 KB. Showing lines 1-1444. Use offset=1445 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\nconst { spawn, spawnSync } = require('node:child_process');\nconst { createHash } = require('node:crypto');\n\nconst {\n  classifyExitCode,\n  maybeThrowTestFault,\n  validateNamespaceValue,\n} = require('./lib/cli-guards.cjs');\n\nconst {\n  runCappedPool,\n  appendStatusLedger,\n  markOrphanedLineages,\n  readRetryCountsFromLedger,\n  createWavePlannerInterface,\n  writeOrchestrationSummary,\n} = require('./fanout-pool.cjs');\n\nconst {\n  runSalvageSweep,\n  extractTextFromOpencodeJson,\n} = require('./fanout-salvage.cjs');\n\nconst {\n  appendObservabilityEvent,\n} = require('../lib/deep-loop/observability-events.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\nconst isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n\nfunction runTsxBootstrap() {\n  const child = spawn(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n    },\n  );\n\n  if (!process.stdin.isTTY && child.stdin) {\n    child.stdin.on('error', () => {});\n    process.stdin.pipe(child.stdin);\n  }\n\n  child.stdout?.pipe(process.stdout);\n  child.stderr?.pipe(process.stderr);\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      child.kill(signal);\n    });\n  }\n\n  child.on('close', (status, signal) => {\n    if (status !== null) {\n      process.exit(status);\n    }\n    process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n  });\n}\n\nif (require.main === module && !isTsxLoaded) {\n  runTsxBootstrap();\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction parseOptionalNumber(args, key) {\n  const raw = args[key];\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return null;\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError(`${key} must be a number`);\n  }\n  const value = Number(raw);\n  if (!Number.isFinite(value) || value < 0) {\n    throw inputError(`${key} must be a non-negative number`);\n  }\n  return value;\n}\n\nfunction readRawConfigNumber(rawConfig, names, fieldName) {\n  if (!isRecord(rawConfig)) return null;\n  for (const name of names) {\n    if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n    const raw = rawConfig[name];\n    if (raw === undefined || raw === null || raw === '') return null;\n    if (raw === true || raw === false) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    const value = Number(raw);\n    if (!Number.isFinite(value) || value < 0) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    return Math.floor(value);\n  }\n  return null;\n}\n\nfunction readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n  const value = readRawConfigNumber(rawConfig, names, fieldName);\n  if (value === null) return fallback;\n  if (value <= 0) {\n    throw inputError(`${fieldName} must be greater than 0`);\n  }\n  return value;\n}\n\nfunction rawConfigWithCliBudgetOverrides(rawConfig, args) {\n  const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n  const mappings = [\n    ['stallWatchdogMs', 'stallWatchdogMs'],\n    ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n    ['maxAggregateCostUnits', 'maxAggregateCostUnits'],\n    ['maxTokensPerLineage', 'maxTokensPerLineage'],\n    ['maxTokenBudget', 'maxTokenBudget'],\n    ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n    ['costUnitsPerIteration', 'costUnitsPerIteration'],\n    ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n  ];\n  for (const [targetKey, argKey] of mappings) {\n    if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n      merged[targetKey] = args[argKey];\n    }\n  }\n  return merged;\n}\n\nfunction normalizeStopPolicy(raw) {\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return 'convergence';\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  if (raw !== 'convergence' && raw !== 'max-iterations') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  return raw;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\nfunction signalExitCode(signal) {\n  return signal === 'SIGINT' ? 130 : 143;\n}\n\nlet fanoutSignalHandlersInstalled = false;\n\nfunction installFanoutSignalHandlers(onStop) {\n  if (fanoutSignalHandlersInstalled) return;\n  fanoutSignalHandlersInstalled = true;\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      try {\n        onStop(signal);\n      } finally {\n        process.exit(signalExitCode(signal));\n      }\n    });\n  }\n}\n\nfunction updateLineageSnapshot(snapshots, event) {\n  if (!event || typeof event.label !== 'string') return;\n  const existing = snapshots.get(event.label) || { label: event.label };\n\n  if (event.event === 'started') {\n    snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'completed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'fulfilled',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n    return;\n  }\n  if (event.event === 'failed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: event.terminal === false ? 'retrying' : 'rejected',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n      error: event.error,\n    });\n    return;\n  }\n  if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n    snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'progress') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'running',\n      updated_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n  }\n}\n\nfunction buildLineageSnapshots(lineages, snapshots) {\n  return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n}\n\nfunction summarizeSnapshots(lineages, snapshots) {\n  const results = buildLineageSnapshots(lineages, snapshots);\n  const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n  const failed = results.filter((result) => result.status === 'rejected').length;\n  return {\n    results,\n    summary: {\n      total: lineages.length,\n      succeeded,\n      failed,\n      all_failed: lineages.length > 0 && failed === lineages.length,\n    },\n  };\n}\n\nfunction observabilityPathForLedger(ledgerPath) {\n  return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n}\n\nfunction statusForLedgerEvent(entry) {\n  if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n    return entry.status;\n  }\n  if (!entry || typeof entry.event !== 'string') return 'unknown';\n  if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n  if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n  if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n  if (entry.event === 'stopped') return 'stopped';\n  if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n  // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n  // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n  if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n  if (entry.event === 'lag_ceiling_abort') return 'failed';\n  if (entry.event === 'stall_detected') return 'warning';\n  if (entry.event === 'budget_cap_exceeded') return 'failed';\n  if (entry.event === 'aggregate_budget_cap_exceeded') return 'failed';\n  return 'unknown';\n}\n\nfunction appendFanoutStatusLedger(ledgerPath, entry) {\n  appendStatusLedger(ledgerPath, entry);\n  try {\n    appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n      producer: 'fanout-run',\n      stream: 'orchestration-status',\n      subject: {\n        run_id: entry.run_id ?? null,\n        label: entry.label ?? null,\n        loop_type: entry.loop_type ?? null,\n        spec_folder: entry.spec_folder ?? null,\n      },\n      event: entry.event,\n      status: statusForLedgerEvent(entry),\n    });\n  } catch {\n    // Observability must not make the primary orchestration ledger fail.\n  }\n}\n\nconst FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\nconst WAVE_ASSIGNMENT_MODEL = 'wave';\nconst WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\nconst WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\nconst STATE_LOG_BY_LOOP_TYPE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n};\nconst ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\nconst DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n\nfunction assertActiveFanoutLoopType(loopType) {\n  if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n    throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n  }\n}\n\nfunction hasNonEmptyArrayField(value) {\n  return Array.isArray(value) && value.length > 0;\n}\n\nfunction collectFlatPoolGuardRejections(fanoutConfig) {\n  const rejections = [];\n  if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n    rejections.push({\n      scope: 'fanout',\n      label: null,\n      field: 'assignment_model',\n      message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n    });\n  }\n\n  for (const lineage of fanoutConfig.executors) {\n    if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: 'assignment_model',\n        message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n      });\n    }\n\n    const reservedFields = [];\n    if (hasNonEmptyArrayField(lineage.depends_on)) {\n      reservedFields.push('depends_on');\n    }\n    if (hasNonEmptyArrayField(lineage.touches)) {\n      reservedFields.push('touches');\n    }\n    if (reservedFields.length > 0) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: reservedFields.join(','),\n        message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n      });\n    }\n  }\n\n  return rejections;\n}\n\n/**\n * Force fan-out execution onto the existing flat pool while wave planning is gated.\n *\n * @param {Object} fanoutConfig - Parsed fan-out config.\n * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n */\nfunction applyFlatPoolAssignmentGuard(fanoutConfig) {\n  const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n  return {\n    config: {\n      ...fanoutConfig,\n      assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      executors: fanoutConfig.executors.map((lineage) => ({\n        ...lineage,\n        assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      })),\n    },\n    rejections,\n  };\n}\n\nfunction logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n  if (rejections.length === 0) {\n    return;\n  }\n  const wavePlanner = createWavePlannerInterface();\n  for (const rejection of rejections) {\n    const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n    process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'assignment_model_rejected',\n      severity: 'warning',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      planner_status: wavePlanner.status,\n      fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      ...rejection,\n    });\n  }\n}\n\n// Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\nconst SPECKIT_STATE_ENV_BY_KIND = {\n  'cli-codex': 'SPECKIT_CODEX_STATE_DIR',\n  'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n  'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n};\n\nconst activeLineageProcesses = new Set();\nconst WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\nconst WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\nconst WAIT_SLEEP_CHUNK_MS = 200;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\nconst DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n\nfunction stopActiveLineageProcesses(signal) {\n  for (const child of activeLineageProcesses) {\n    terminateLineageProcess(child, signal);\n  }\n}\n\nfunction expandHomeDir(inputPath) {\n  if (inputPath === '~') {\n    return os.homedir();\n  }\n  if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n    return path.join(os.homedir(), inputPath.slice(2));\n  }\n  return inputPath;\n}\n\nfunction isPathInside(childPath, parentPath) {\n  const relative = path.relative(parentPath, childPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction physicalPathForValidation(targetPath) {\n  try {\n    return fs.realpathSync.native(targetPath);\n  } catch {\n    const parentPath = path.dirname(targetPath);\n    try {\n      return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n    } catch {\n      return targetPath;\n    }\n  }\n}\n\nfunction validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n  if (baseArtifactDir.includes('\\0')) {\n    throw inputError('baseArtifactDir must not contain null bytes');\n  }\n  if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n    throw inputError('baseArtifactDir must not contain \"..\" path segments');\n  }\n  const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n  const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n  const expectedRoot = path.join(resolvedSpecFolder, loopType);\n  if (!isPathInside(resolvedBase, expectedRoot)) {\n    throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n  }\n  return baseArtifactDir;\n}\n\nfunction validateClaudeConfigDir(configDir) {\n  if (typeof configDir !== 'string' || configDir.trim() === '') {\n    throw inputError('configDir must be a non-empty string when set');\n  }\n  validateNamespaceValue(configDir, 'configDir', inputError);\n\n  const expanded = expandHomeDir(configDir);\n  const resolved = path.resolve(process.cwd(), expanded);\n  const homeDir = path.resolve(os.homedir());\n  const cwd = path.resolve(process.cwd());\n  const homeRelative = path.relative(homeDir, resolved);\n  const cwdRelative = path.relative(cwd, resolved);\n  const homeTop = homeRelative.split(path.sep)[0] || '';\n  const cwdTop = cwdRelative.split(path.sep)[0] || '';\n  const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n\n  if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n    return resolved;\n  }\n  if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n    return resolved;\n  }\n  throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {\n    child.kill(signal);\n  } catch {\n    // The process may have already exited.\n  }\n}\n\nfunction expectedLineageArtifactPaths(loopType, lineageDir) {\n  assertActiveFanoutLoopType(loopType);\n  if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n  return [path.join(lineageDir, 'research.md')];\n}\n\nfunction hasNonEmptyFile(filePath) {\n  try {\n    return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n  } catch {\n    return false;\n  }\n}\n\nfunction findMissingLineageArtifacts(loopType, lineageDir) {\n  return expectedLineageArtifactPaths(loopType, lineageDir)\n    .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n}\n\nfunction parseJsonlRecords(filePath) {\n  const text = fs.readFileSync(filePath, 'utf8');\n  return text\n    .split(/\\r?\\n/)\n    .filter((line) => line.trim() !== '')\n    .map((line) => JSON.parse(line));\n}\n\nfunction lineageStateLogName(loopType) {\n  return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n}\n\nfunction readLineageStateRecords(loopType, lineageDir) {\n  const stateLogName = lineageStateLogName(loopType);\n  if (!stateLogName) {\n    return { statePath: null, records: [], missing: true, parseError: null };\n  }\n  const statePath = path.join(lineageDir, stateLogName);\n  if (!hasNonEmptyFile(statePath)) {\n    return { statePath, records: [], missing: true, parseError: null };\n  }\n  try {\n    return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n  } catch (error) {\n    return {\n      statePath,\n      records: [],\n      missing: false,\n      parseError: error instanceof Error ? error.message : String(error),\n    };\n  }\n}\n\n// A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n// spelling. The iteration-count check above already proves the lineage ran every iteration,\n// so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n// \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n// such as convergence, a manual stop, or an error.\nfunction isMaxIterationsStopReason(stopReason) {\n  if (typeof stopReason !== 'string') return false;\n  return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n}\n\nfunction findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n  if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n  if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n    return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n  }\n\n  if (!stateRead || stateRead.missing) {\n    return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n  }\n  if (stateRead.parseError) {\n    return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n  }\n\n  const records = stateRead.records;\n  const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n  const synthesis = [...records]\n    .reverse()\n    .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n  if (!synthesis) {\n    return 'missing synthesis_complete event for max-iterations stop-policy validation';\n  }\n\n  const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n    ? Number(synthesis.totalIterations)\n    : iterationCount;\n  if (totalIterations !== lineage.iterations) {\n    return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n  }\n  if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n    return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n  }\n  return null;\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n  // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n  // because this knob is intentionally outside fanoutConfigSchema. Non-disableable while\n  // running autonomously: an explicit 0 no longer opts out, it is rejected.\n  const value = readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs');\n  if (value === 0) {\n    throw inputError('stallWatchdogMs must be greater than 0; stall detection cannot be disabled for autonomous fan-out runs');\n  }\n  return value ?? 300000;\n}\n\nconst DEFAULT_MAX_COST_UNITS_PER_LINEAGE = 72;\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? DEFAULT_MAX_COST_UNITS_PER_LINEAGE,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}, maxRetries = 0) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  const normalizedRetries = Number.isFinite(Number(maxRetries)) && Number(maxRetries) >= 0\n    ? Math.floor(Number(maxRetries))\n    : 0;\n  const totalAttempts = normalizedRetries + 1;\n  return {\n    ...guards,\n    iterations,\n    total_attempts: totalAttempts,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration * totalAttempts,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(\n    input.lineage || {},\n    input.guards || input,\n    input.maxRetries,\n  );\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\n// Aggregate budget across every expanded lineage in a run. This is a SEPARATE ceiling\n// from DEFAULT_MAX_COST_UNITS_PER_LINEAGE above: the per-lineage cap bounds any single\n// lineage, this bounds the whole fan-out submission, and both are enforced independently\n// (a run may pass one and still fail the other).\nconst DEFAULT_MAX_AGGREGATE_COST_UNITS = 288;\n\nfunction normalizeAggregateBudgetGuards(rawConfig = {}) {\n  return {\n    max_aggregate_cost_units: readRawConfigNumber(rawConfig, [\n      'maxAggregateCostUnits',\n      'max_aggregate_cost_units',\n      'maxTotalCostUnits',\n      'max_total_cost_units',\n    ], 'maxAggregateCostUnits') ?? DEFAULT_MAX_AGGREGATE_COST_UNITS,\n  };\n}\n\nfunction computeAggregateBudgetUpperBound(lineages, guardsInput = {}, maxRetries = 0) {\n  const aggregateGuards = normalizeAggregateBudgetGuards(guardsInput);\n  const lineageGuards = normalizeLineageBudgetGuards(guardsInput);\n  const perLineage = (lineages || []).map((lineage) => {\n    const upperBound = computeLineageBudgetUpperBound(lineage, lineageGuards, maxRetries);\n    return { label: lineage && lineage.label, estimated_cost_units: upperBound.estimated_cost_units };\n  });\n  const estimatedCostUnits = perLineage.reduce((sum, entry) => sum + entry.estimated_cost_units, 0);\n  return {\n    max_aggregate_cost_units: aggregateGuards.max_aggregate_cost_units,\n    estimated_cost_units: estimatedCostUnits,\n    lineage_count: perLineage.length,\n    per_lineage: perLineage,\n  };\n}\n\nfunction evaluateAggregateBudgetCap(input = {}) {\n  const upperBound = computeAggregateBudgetUpperBound(\n    input.lineages || [],\n    input.guards || input,\n    input.maxRetries,\n  );\n  const exceeded = upperBound.max_aggregate_cost_units > 0\n    && upperBound.estimated_cost_units > upperBound.max_aggregate_cost_units;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_aggregate_cost_units'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction buildTimestampAnomalyCounts(check) {\n  return {\n    anomalous: check.anomalous,\n    untimestamped: check.untimestamped,\n    unparseable: check.unparseable,\n    total: check.total,\n  };\n}\n\nfunction buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n  return {\n    label: lineage.label,\n    state_log: statePath,\n    window: {\n      start_at_iso: check.windowStart,\n      end_at_iso: check.windowEnd,\n      tolerance_ms: check.toleranceMs,\n    },\n    counts: buildTimestampAnomalyCounts(check),\n    sample: check.sample,\n  };\n}\n\nfunction collectTimestampAnomalies(results) {\n  return results\n    .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n    .map((result) => result.output.timestamp_anomaly);\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };\n}\n\nfunction normalizeWaitCheckpoint(raw, context) {\n  if (!isRecord(raw)) {\n    throw inputError('wait checkpoint must be a JSON object');\n  }\n\n  const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n  const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n  const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n  const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n    ? raw.nextRunAt\n    : null;\n  const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n  const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n  const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n  const base = {\n    runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n    loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n    specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n  };\n\n  const checkpoint = waiting\n    ? {\n        schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n        status: 'waiting',\n        nextRunAt,\n        remainingDelayMs,\n        updatedAt: new Date(nowMs).toISOString(),\n        ...base,\n      }\n    : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n  const staleWaitingFields = !waiting\n    && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n  const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n\n  return {\n    checkpoint,\n    migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n  };\n}\n\nfunction readWaitCheckpoint(checkpointPath, context) {\n  if (!fs.existsSync(checkpointPath)) {\n    return { exists: false, checkpoint: null, migrated: false };\n  }\n\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n  } catch (error) {\n    throw inputError(\n      `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n\n  const normalized = normalizeWaitCheckpoint(raw, context);\n  if (normalized.migrated) {\n    atomicWriteJson(checkpointPath, normalized.checkpoint);\n  }\n  return { exists: true, ...normalized };\n}\n\nfunction sleepWaitChunk(ms) {\n  return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n}\n\nasync function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n  const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n  let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n\n  while (remainingDelayMs > 0) {\n    atomicWriteJson(checkpointPath, {\n      ...checkpoint,\n      remainingDelayMs,\n      updatedAt: new Date().toISOString(),\n    });\n    await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n    remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n  }\n\n  atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n}\n\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n      : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n// Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n// ceiling and a positive override may only narrow it, never widen past it.\nconst LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n\nfunction assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n  if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n    throw inputError(\n      `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n        + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n    );\n  }\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (typeof opts.onOutput === 'function') opts.onOutput();\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\nfunction digestText(value) {\n  return createHash('sha256').update(String(value)).digest('hex');\n}\n\nconst executableIdentityCache = new Map();\n\nfunction resolveExecutableVersion(command, options = {}) {\n  if (typeof options.executableVersion === 'string' && options.executableVersion.trim()) {\n    return options.executableVersion.trim();\n  }\n  const env = options.env || process.env;\n  const pathEntries = String(env.PATH || '').split(path.delimiter).filter(Boolean);\n  for (const entry of pathEntries) {\n    const candidate = path.join(entry, command);\n    try {\n      const executablePath = fs.realpathSync(candidate);\n      const stat = fs.statSync(executablePath);\n      if (!stat.isFile()) continue;\n      const cacheKey = `${executablePath}:${stat.size}:${stat.mtimeMs}`;\n      const cached = executableIdentityCache.get(cacheKey);\n      if (cached) return cached;\n      const identity = `sha256:${createHash('sha256').update(fs.readFileSync(executablePath)).digest('hex')}`;\n      executableIdentityCache.set(cacheKey, identity);\n      return identity;\n    } catch {}\n  }\n  return 'unknown';\n}\n\nfunction effectiveWebSearchPolicy(lineage) {\n  return lineage.liveTools?.webSearch || 'inherit';\n}\n\n/**\n * Build the allowlisted fingerprint payload without raw prompts or environment maps.\n *\n * @param {Object} input - Resolved invocation fields.\n * @returns {Object} Canonical JSON-safe payload.\n */\nfunction buildInvocationFingerprintPayload(input) {\n  const promptDigest = digestText(input.prompt);\n  const promptArgIndexes = new Set(input.promptArgIndexes || []);\n  const argv = input.args.map((arg, index) => (\n    promptArgIndexes.has(index) ? `<prompt:${promptDigest}>` : arg\n  ));\n  return {\n    kind: input.kind,\n    executable: input.command,\n    executableVersion: input.executableVersion || 'unknown',\n    model: input.model,\n    effort: input.reasoningEffort,\n    tier: input.serviceTier,\n    sandboxPosture: {\n      sandboxMode: input.resolvedSandbox,\n      permissionMode: input.resolvedPermission,\n    },\n    webSearch: input.webSearch,\n    argv,\n    promptDigest,\n  };\n}\n\nfunction finalizeLineageCommand(input) {\n  const effectiveConfig = {\n    kind: input.kind,\n    executable: input.command,","lineStart":1,"lineEnd":1444,"totalLines":1445,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784650185897,"end":1784650185920}},"metadata":{"openai":{"itemId":"fc_0faa9dc6e138ff0b016a5f99c9aecc819190c95c7e96f7d085"}},"id":"prt_f8570bc73001tvYgi9XpW2bpyy","sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","messageID":"msg_f8570725b001DK0GOt6we0e4EV"}}
{"type":"tool_use","timestamp":1784650186003,"sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","part":{"type":"tool","tool":"read","callID":"call_I4Mk7pfT2R7HszWDcb0Zb3bo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt-quality-card.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt-quality-card.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: OpenCode CLI — Prompt Quality Card\n3: description: Fast-path prompt discipline for OpenCode CLI dispatches; frameworks and CLEAR are canonical in sk-prompt.\n4: trigger_phrases:\n5:   - \"opencode prompt quality card\"\n6:   - \"opencode model overrides\"\n7:   - \"minimax tidd-ec dense pre-plan\"\n8:   - \"mimo costar lean prompt\"\n9:   - \"opencode dispatch framework precedence\"\n10: importance_tier: normal\n11: contextType: planning\n12: version: 1.3.0.21\n13: ---\n14: \n15: # OpenCode CLI — Prompt Quality Card\n16: \n17: Fast-path dispatch discipline for `opencode run` prompts. The 7-framework table, task-to-framework map, pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are owned by the canonical card — do not inline them here.\n18: \n19: ## 1. OVERVIEW\n20: \n21: ### Purpose\n22: \n23: This card is the OpenCode CLI fast-path prompt-quality reference; it delegates the framework table + CLEAR check to the canonical card and records only OpenCode-specific model overrides plus the precedence rule.\n24: \n25: ### Usage\n26: \n27: Compose a dispatch prompt by starting from the shared layer (canonical card), applying the OpenCode model overrides, and following the precedence rule.\n28: \n29: ---\n30: \n31: ## 2. SHARED LAYER (DELEGATED — DO NOT INLINE)\n32: \n33: The 7-framework selection table, the task->framework map, the pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are OWNED by the canonical card. Do NOT copy them here.\n34: \n35: -> `../../../sk-prompt/prompt-models/assets/cli-prompt-quality-card.md`  (deep theory: `../../../sk-prompt/prompt-improve/references/patterns-evaluation.md`)\n36: \n37: ---\n38: \n39: ## 3. OPENCODE MODEL OVERRIDES\n40: \n41: OpenCode dispatches the MiniMax, MiMo, DeepSeek-v4-pro, and Kimi-K2.7 small models, which override or default against the cross-model defaults from the canonical card:\n42: \n43: | Model (dispatchable here) | Override | Profile |\n44: |---|---|---|\n45: | MiniMax M3 (Token Plan default) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n46: | MiniMax M3 (Direct API) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n47: | MiMo V2.5 Pro (Token Plan) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n48: | MiMo V2.5 Pro (Direct API) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n49: | MiMo V2.5 Pro UltraSpeed (Direct API, low-latency) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n50: | GLM-5.2 (Z.AI GLM Coding Plan) | COSTAR + lean (empirical, benchmark 008) | [`glm-5.2.md`](../../../sk-prompt/prompt-models/references/models/glm-5.2.md) |\n51: | deepseek-v4-pro / kimi-k2.7-code | default RCAF (no model-specific benchmark; shared default-unverified note) | [`deepseek-v4-pro.md`](../../../sk-prompt/prompt-models/references/models/deepseek-v4-pro.md) · [`kimi-k2.7-code.md`](../../../sk-prompt/prompt-models/references/models/kimi-k2.7-code.md) |\n52: \n53: **Executor notes:** Omit `--agent` for all small-model dispatches listed above. OpenCode maps `--variant low/medium/high` to MiMo's reasoning effort; `high` is the standing default for MiMo. MiniMax Token Plan (`minimax-coding-plan/MiniMax-M3`) and Direct API (`minimax/MiniMax-M3`) both serve M3. Xiaomi Token Plan (`xiaomi-token-plan-ams/mimo-v2.5-pro`) and Direct API (`xiaomi/mimo-v2.5-pro`) both serve MiMo-V2.5-Pro; the Direct API additionally serves `xiaomi/mimo-v2.5-pro-ultraspeed`, a low-latency tier with the same prompt contract. Ambiguous use-case (1 vs 2 vs 3) prevents the router from picking a path — resolve before dispatch. Always include a self-invocation guard signal when the dispatched session could loop back.\n54: \n55: ---\n56: \n57: ## 4. DELEGATION / PRECEDENCE\n58: \n59: The 3-tier precedence rule (fast path -> model override -> deep path) is canonical in `../../../sk-prompt/prompt-models/assets/cli-prompt-quality-card.md` and restated in `../SKILL.md`.\n60: \n61: OpenCode-specific escalation example: if the task would otherwise need a long `opencode run` prompt plus an explicit Memory Epilogue and a parallel-session decision, ask `@prompt-improver` for the final `ENHANCED_PROMPT` first, then pass that result to OpenCode.\n62: \n63: ---\n64: \n65: ## 5. RELATED RESOURCES\n66: \n67: -> `../../../sk-prompt/prompt-models/assets/cli-prompt-quality-card.md` · `./prompt-templates.md` · `../SKILL.md` · `../../../sk-prompt/prompt-models/references/models/` (per-model profiles)\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"---\ntitle: OpenCode CLI — Prompt Quality Card\ndescription: Fast-path prompt discipline for OpenCode CLI dispatches; frameworks and CLEAR are canonical in sk-prompt.\ntrigger_phrases:\n  - \"opencode prompt quality card\"\n  - \"opencode model overrides\"\n  - \"minimax tidd-ec dense pre-plan\"\n  - \"mimo costar lean prompt\"\n  - \"opencode dispatch framework precedence\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.3.0.21\n---\n\n# OpenCode CLI — Prompt Quality Card\n\nFast-path dispatch discipline for `opencode run` prompts. The 7-framework table, task-to-framework map, pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are owned by the canonical card — do not inline them here.\n\n## 1. OVERVIEW\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt-quality-card.md","text":"---\ntitle: OpenCode CLI — Prompt Quality Card\ndescription: Fast-path prompt discipline for OpenCode CLI dispatches; frameworks and CLEAR are canonical in sk-prompt.\ntrigger_phrases:\n  - \"opencode prompt quality card\"\n  - \"opencode model overrides\"\n  - \"minimax tidd-ec dense pre-plan\"\n  - \"mimo costar lean prompt\"\n  - \"opencode dispatch framework precedence\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.3.0.21\n---\n\n# OpenCode CLI — Prompt Quality Card\n\nFast-path dispatch discipline for `opencode run` prompts. The 7-framework table, task-to-framework map, pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are owned by the canonical card — do not inline them here.\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis card is the OpenCode CLI fast-path prompt-quality reference; it delegates the framework table + CLEAR check to the canonical card and records only OpenCode-specific model overrides plus the precedence rule.\n\n### Usage\n\nCompose a dispatch prompt by starting from the shared layer (canonical card), applying the OpenCode model overrides, and following the precedence rule.\n\n---\n\n## 2. SHARED LAYER (DELEGATED — DO NOT INLINE)\n\nThe 7-framework selection table, the task->framework map, the pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are OWNED by the canonical card. Do NOT copy them here.\n\n-> `../../../sk-prompt/prompt-models/assets/cli-prompt-quality-card.md`  (deep theory: `../../../sk-prompt/prompt-improve/references/patterns-evaluation.md`)\n\n---\n\n## 3. OPENCODE MODEL OVERRIDES\n\nOpenCode dispatches the MiniMax, MiMo, DeepSeek-v4-pro, and Kimi-K2.7 small models, which override or default against the cross-model defaults from the canonical card:\n\n| Model (dispatchable here) | Override | Profile |\n|---|---|---|\n| MiniMax M3 (Token Plan default) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n| MiniMax M3 (Direct API) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n| MiMo V2.5 Pro (Token Plan) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n| MiMo V2.5 Pro (Direct API) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n| MiMo V2.5 Pro UltraSpeed (Direct API, low-latency) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n| GLM-5.2 (Z.AI GLM Coding Plan) | COSTAR + lean (empirical, benchmark 008) | [`glm-5.2.md`](../../../sk-prompt/prompt-models/references/models/glm-5.2.md) |\n| deepseek-v4-pro / kimi-k2.7-code | default RCAF (no model-specific benchmark; shared default-unverified note) | [`deepseek-v4-pro.md`](../../../sk-prompt/prompt-models/references/models/deepseek-v4-pro.md) · [`kimi-k2.7-code.md`](../../../sk-prompt/prompt-models/references/models/kimi-k2.7-code.md) |\n\n**Executor notes:** Omit `--agent` for all small-model dispatches listed above. OpenCode maps `--variant low/medium/high` to MiMo's reasoning effort; `high` is the standing default for MiMo. MiniMax Token Plan (`minimax-coding-plan/MiniMax-M3`) and Direct API (`minimax/MiniMax-M3`) both serve M3. Xiaomi Token Plan (`xiaomi-token-plan-ams/mimo-v2.5-pro`) and Direct API (`xiaomi/mimo-v2.5-pro`) both serve MiMo-V2.5-Pro; the Direct API additionally serves `xiaomi/mimo-v2.5-pro-ultraspeed`, a low-latency tier with the same prompt contract. Ambiguous use-case (1 vs 2 vs 3) prevents the router from picking a path — resolve before dispatch. Always include a self-invocation guard signal when the dispatched session could loop back.\n\n---\n\n## 4. DELEGATION / PRECEDENCE\n\nThe 3-tier precedence rule (fast path -> model override -> deep path) is canonical in `../../../sk-prompt/prompt-models/assets/cli-prompt-quality-card.md` and restated in `../SKILL.md`.\n\nOpenCode-specific escalation example: if the task would otherwise need a long `opencode run` prompt plus an explicit Memory Epilogue and a parallel-session decision, ask `@prompt-improver` for the final `ENHANCED_PROMPT` first, then pass that result to OpenCode.\n\n---\n\n## 5. RELATED RESOURCES\n\n-> `../../../sk-prompt/prompt-models/assets/cli-prompt-quality-card.md` · `./prompt-templates.md` · `../SKILL.md` · `../../../sk-prompt/prompt-models/references/models/` (per-model profiles)","lineStart":1,"lineEnd":67,"totalLines":67,"truncated":false}},"title":".opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt-quality-card.md","time":{"start":1784650185959,"end":1784650185989}},"metadata":{"openai":{"itemId":"fc_0faa9dc6e138ff0b016a5f99c9aedc81918c69434aa91d5011"}},"id":"prt_f8570bce40019PnqPomDqZsDtz","sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","messageID":"msg_f8570725b001DK0GOt6we0e4EV"}}
{"type":"tool_use","timestamp":1784650186004,"sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","part":{"type":"tool","tool":"read","callID":"call_Wn8Ll9kVrp91mAZJFG5slZY8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/references/cli-reference.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/references/cli-reference.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"OpenCode CLI - Complete Command Reference\"\n3: description: \"Comprehensive reference for OpenCode CLI subcommands, flags, models, configuration, agent flags, sandbox boundaries, and troubleshooting. Pinned to v1.3.17.\"\n4: trigger_phrases:\n5:   - \"opencode cli reference\"\n6:   - \"opencode run flags\"\n7:   - \"opencode model selection\"\n8:   - \"opencode provider auth pre-flight\"\n9:   - \"opencode variant reasoning effort\"\n10:   - \"opencode version drift\"\n11: importance_tier: important\n12: contextType: implementation\n13: version: 1.3.0.29\n14: ---\n15: \n16: # OpenCode CLI - Complete Command Reference\n17: \n18: Comprehensive reference for the OpenCode CLI binary, every subcommand the cli-opencode skill dispatches against, the flag set it relies on, the agent surface it can target, and the failure modes that need explicit handling. Pinned to v1.3.17 baseline.\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: ### Core Principle\n25: \n26: OpenCode is the framework that owns this repository. The same binary that hosts the operator's TUI session also accepts non-interactive invocations through `opencode run`. The cli-opencode skill calls `opencode run` from external runtimes (Claude Code, OpenCode, Copilot, raw shell) so the calling AI can dispatch a task into a fresh OpenCode session that loads the full plugin, skill, MCP, and Spec Kit Memory runtime.\n27: \n28: ### Purpose\n29: \n30: Provide a single-source reference for the OpenCode CLI surface — every subcommand cli-opencode invokes, every flag it pins, every agent it can route to, the version baseline it is built against, and the error envelopes that need explicit recovery.\n31: \n32: ### When to Use\n33: \n34: - Looking up an OpenCode CLI subcommand or flag during a delegation\n35: - Selecting a model + variant + agent for a dispatch\n36: - Confirming the version baseline before pinning a flag set\n37: - Troubleshooting a failed `opencode run` invocation\n38: - Confirming the self-invocation guard signal against the live binary\n39: \n40: ### Key Sources\n41: \n42: | Source | URL |\n43: |--------|-----|\n44: | **Binary** | `$(command -v opencode)` (typically `~/.superset/bin/opencode` or another local bin path) |\n45: | **Repository** | https://github.com/sst/opencode |\n46: | **Version baseline** | v1.3.17 (pinned in this reference) |\n47: | **Runtime** | Node.js 18+ for the npm install path; standalone binary on macOS |\n48: \n49: ---\n50: \n51: ## 2. INSTALLATION\n52: \n53: | Method | Command | Notes |\n54: |--------|---------|-------|\n55: | **Standalone** | `curl -fsSL https://opencode.ai/install \\| bash` | macOS / Linux installer |\n56: | **Homebrew** | `brew install opencode` | macOS package manager |\n57: | **npm global** | `npm install -g opencode-ai` | Cross-platform when Node.js 18+ is present |\n58: | **Upgrade** | `opencode upgrade [target]` | Pin a specific version with the `target` argument |\n59: | **Uninstall** | `opencode uninstall` | Removes the binary and related state |\n60: \n61: After installation, run `opencode --version` to confirm. The cli-opencode skill is pinned to v1.3.17. Newer binaries may add or rename flags — consult Section 9 (Version Drift) before relying on a non-pinned flag.\n62: \n63: ---\n64: \n65: ## 3. SUBCOMMAND MAP\n66: \n67: OpenCode exposes a multi-subcommand surface. The cli-opencode skill primarily invokes `run`, with secondary use of `serve`, `web`, `agent`, and `debug`.\n68: \n69: | Subcommand | Purpose | Invoked by cli-opencode |\n70: |------------|---------|-------------------------|\n71: | `opencode` (default) | Start the TUI in the current project | No (interactive only) |\n72: | `opencode run [message..]` | Non-interactive single-shot dispatch | YES (canonical use case) |\n73: | `opencode serve` | Start a headless server | YES (for parallel detached sessions) |\n74: | `opencode web` | Start a server plus open the web interface | YES (when the operator wants a browser surface) |\n75: | `opencode acp` | Start an ACP (Agent Client Protocol) server | No (specialized integration path) |\n76: | `opencode attach <url>` | Attach to a running OpenCode server | YES (for share-URL flows) |\n77: | `opencode agent` | Manage agent definitions | YES (for agent listing) |\n78: | `opencode debug` | Debugging and troubleshooting tools | YES (for `debug skill` and `debug agent` listings) |\n79: | `opencode mcp` | Manage MCP server registrations | No |\n80: | `opencode providers` (alias `auth`) | Manage AI providers and credentials | No (operator-driven setup) |\n81: | `opencode models [provider]` | List available models | YES (for capability discovery) |\n82: | `opencode session` | Manage sessions | No (state inspection only) |\n83: | `opencode export [sessionID]` | Export session data as JSON | YES (for memory handback flows) |\n84: | `opencode stats` | Token and cost statistics | No |\n85: | `opencode db` | Database tools | No |\n86: | `opencode plugin <module>` (alias `plug`) | Install a plugin | No (operator-driven setup) |\n87: | `opencode upgrade [target]` | Upgrade the binary | No (operator-driven) |\n88: | `opencode uninstall` | Uninstall the binary | No (operator-driven) |\n89: \n90: ---\n91: \n92: ## 4. `opencode run` FLAGS\n93: \n94: `opencode run [message..]` is the canonical non-interactive entry point. The cli-opencode skill builds every dispatch around this subcommand.\n95: \n96: ### Core flags\n97: \n98: | Flag / Option | Type | Purpose |\n99: |---------------|------|---------|\n100: | `[message..]` | positional | One or more positional message strings |\n101: | `--print-logs` | boolean | Stream logs to stderr |\n102: | `--log-level` | enum | `DEBUG`, `INFO`, `WARN`, `ERROR` |\n103: | `--pure` | boolean | Run without external plugins (skill loads disabled) |\n104: | `--command` | string | Run a known command, the message becomes its args |\n105: | `-c`, `--continue` | boolean | Continue the last session in this project |\n106: | `-s`, `--session` | string | Continue a specific session id |\n107: | `--fork` | boolean | Fork before continuing — requires `--continue` or `--session` |\n108: | `--share` | boolean | Publish a shareable URL for this session |\n109: | `-m`, `--model` | string | Provider/model selector — e.g. `deepseek/deepseek-v4-pro` |\n110: | `--agent` | string | Agent slug (loads from `.opencode/agents/<slug>.md`) |\n111: | `--format` | enum | `default` (formatted) or `json` (raw event stream) |\n112: | `-f`, `--file` | array | Attach files to the message |\n113: | `--title` | string | Session title (truncated message used when omitted) |\n114: | `--attach` | string | Attach to a running OpenCode server URL |\n115: | `-p`, `--password` | string | Basic auth password (or `OPENCODE_SERVER_PASSWORD`) |\n116: | `--dir` | string | Working directory or remote-server path |\n117: | `--port` | number | Local server port (random when omitted) |\n118: | `--variant` | string | Provider-specific reasoning effort (`high`, `max`, `minimal`, etc.) |\n119: | `--thinking` | boolean | Show thinking blocks (default false) |\n120: \n121: > **`--command` semantics (verified on v1.17.4):** the `run` message is plain text — slash-command syntax inside it (`opencode run \"/memory:search query\"`) is NOT expanded, so the command's template never reaches the model. Executing a registered command non-interactively requires `--command <family>/<name>` with the args as the message (they become `$ARGUMENTS`). Registry names are slash-namespaced (`memory/search` for `/memory:search`); a wrong name fails with the full registry list. Behavior probes of slash commands MUST use `--command`; the raw-text form only measures the model freestyling without the contract. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n122: \n123: ### cli-opencode default invocation shape\n124: \n125: The skill builds every dispatch from a base shape and overlays use-case-specific flags:\n126: \n127: ```bash\n128: opencode run \\\n129:   --model deepseek/deepseek-v4-pro \\\n130:   --agent <agent-slug> \\\n131:   --variant high \\\n132:   --format json \\\n133:   --dir \"$REPO_ROOT\" \\\n134:   \"<prompt>\"\n135: ```\n136: \n137: | Flag | Default | Reason |\n138: |------|---------|--------|\n139: | `--model` | `deepseek/deepseek-v4-pro` | Direct DeepSeek is the default provider — elevated reasoning at low cost; operator may override (e.g. `deepseek/deepseek-v4-flash`, `kimi-for-coding/k2p7`, or any live OpenAI GPT-5.6 slug: `openai/gpt-5.6`, `openai/gpt-5.6-fast`, `openai/gpt-5.6-pro`, `openai/gpt-5.6-sol`, `openai/gpt-5.6-sol-fast`, `openai/gpt-5.6-sol-pro`, `openai/gpt-5.6-terra`, `openai/gpt-5.6-terra-fast`, `openai/gpt-5.6-terra-pro`, `openai/gpt-5.6-luna`, `openai/gpt-5.6-luna-fast`, `openai/gpt-5.6-luna-pro`) |\n140: | `--agent` | per use case | Required for use case 1 / 3; optional for use case 2 |\n141: | `--variant high` | high | Routine cli-opencode dispatches benefit from elevated reasoning effort |\n142: | `--format json` | json | Structured event stream is what external runtimes parse |\n143: | `--dir` | repo root | Pin the working directory to avoid CWD ambiguity |\n144: \n145: ### Stdin handling — `</dev/null` is required for non-interactive dispatch\n146: \n147: > **opencode v1.14.39 reads stdin at startup before session creation.** If you redirect stdout/stderr to files in automation (`> stdout.log 2> stderr.log`), opencode hangs at 0% CPU after the `+60s snapshot prune cleanup` log line because stdin remains attached to the parent terminal and never receives EOF.\n148: \n149: ALWAYS append `</dev/null` AFTER the prompt argument and BEFORE the stdout/stderr redirects:\n150: \n151: ```bash\n152: opencode run --model X \"<prompt>\" </dev/null > stdout.log 2> stderr.log\n153: #                                  ^^^^^^^^^^\n154: #                                  redirects stdin from /dev/null → immediate EOF\n155: ```\n156: \n157: Foreground `| tail` accidentally works because the upstream pipe stage provides closed stdin, but `> file 2> file` does not. See `references/integration-patterns.md` §6 for the full failure-mode + fix matrix and `../CHANGELOG-2026-05-08-tool-name-regex-fix.md` §Fix 4 for the discovery context.\n158: \n159: ### Sessions, share URLs, and ports\n160: \n161: `--share` publishes the session over the OpenCode share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). External-runtime dispatches do NOT publish share URLs by default.\n162: \n163: `--port` only matters when the dispatch needs to bind a known port (e.g. for a parallel detached session that another tool will attach to). The default random port is correct for one-shot dispatches.\n164: \n165: `--continue` and `--session <id>` reuse prior session state. `--fork` branches an existing session into a new one. cli-opencode uses session continuation in memory handback flows where the calling AI wants to thread context across multiple delegations.\n166: \n167: ### Provider Auth Pre-Flight (smart fallback)\n168: \n169: Before the first dispatch in a session, run a one-shot auth pre-flight against `opencode providers list` so a missing default doesn't fail mid-dispatch. Cache the result for the session; only re-run on auth failure.\n170: \n171: ```bash\n172: # Pre-flight — one call per session\n173: PROVIDERS=$(opencode providers list 2>&1)\n174: echo \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\n175: echo \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\n176: echo \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\n177: echo \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\n178: echo \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\n179: echo \"default=$DEEPSEEK_OK minimax_token=$MINIMAX_TOKEN_OK minimax_direct=$MINIMAX_DIRECT_OK xiaomi=$XIAOMI_OK xiaomi_direct=$XIAOMI_DIRECT_OK\"\n180: ```\n181: \n182: | State | DEEPSEEK_OK | Action |\n183: |-------|-------------|--------|\n184: | Default available | 1 | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n185: | Default missing | 0 | **ASK user** before substituting (offer A: openai/gpt-5.6-sol-pro, B: login deepseek and retry, C: name a different model) — do not dispatch until configured |\n186: \n187: **MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative):\n188: \n189: | State | Condition | Action |\n190: |-------|-----------|--------|\n191: | MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n192: | Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n193: | Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n194: | Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n195: \n196: **MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n197: \n198: | State | Condition | Action |\n199: |-------|-----------|--------|\n200: | MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n201: | MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n202: | Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n203: | Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n204: | Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n205: | Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n206: \n207: **Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n208: \n209: ```bash\n210: # Recommended default — direct DeepSeek API\n211: opencode providers login deepseek\n212: \n213: # MiniMax Token Plan — DEFAULT MiniMax path (subscription). Interactive: pick \"MiniMax Token Plan (minimax.io)\".\n214: opencode auth login          # → provider minimax-coding-plan; Anthropic-compatible https://api.minimax.io/anthropic/v1 (China: api.minimaxi.com)\n215: \n216: # MiniMax Direct API — pay-per-token alternative (needs MINIMAX_API_KEY; platform endpoint https://api.minimax.io/v1)\n217: opencode providers login minimax\n218: \n219: # Xiaomi Token Plan (Europe) — provider-managed endpoint. Interactive: pick \"Xiaomi Token Plan (Europe)\".\n220: opencode auth login          # → provider xiaomi-token-plan-ams (Xiaomi Token Plan, Europe)\n221: \n222: # Xiaomi Direct API — pay-per-token alternative\n223: opencode providers login xiaomi\n224: \n225: # Z.AI GLM Coding Plan — GLM coding subscription. Interactive: pick \"Z.AI Coding Plan\".\n226: opencode auth login          # → provider zai-coding-plan; model zai-coding-plan/glm-5.2\n227: ```\n228: \n229: > Do not mix region endpoints (international `minimax.io` vs China `minimaxi.com`). Confirm live model ids with `opencode models minimax-coding-plan`. The Xiaomi endpoint is provider-managed (no documented base URL — do not invent one); confirm live model ids with `opencode models xiaomi-token-plan-ams` (Token Plan) or `opencode models xiaomi` (Direct API).\n230: \n231: **On auth-error mid-dispatch** (`401 Unauthorized`, `provider/model not found`): invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n232: \n233: ### User-facing prompt templates\n234: \n235: Surface these verbatim to the operator when the pre-flight decision tree lands on \"ASK user\" (default missing with a fallback configured, or all providers missing). Never dispatch until the operator responds.\n236: \n237: **Default missing, fallback configured:**\n238: \n239: ```text\n240: The skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\n241: A configured fallback is available. Pick one:\n242:   A) Use `openai/gpt-5.6-sol-pro --variant high` (OpenAI premium, configured now — paid)\n243:   B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n244:   C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n245:   D) Run `opencode providers login deepseek` first, then retry the original dispatch\n246:   E) Name a different model — paste the `--model <provider/model>` you want to use\n247: ```\n248: \n249: **All providers missing:**\n250: \n251: ```text\n252: No supported providers are configured on this machine. Run one:\n253:   - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n254:   - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n255:   - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n256:   - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n257:   - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n258:   - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n259:   - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n260:   - `opencode providers login openai`       (OpenAI premium alternative — paid)\n261: Which would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n262: ```\n263: \n264: **Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n265: \n266: ---\n267: \n268: ## 5. MODEL SELECTION\n269: \n270: OpenCode resolves models through configured providers. The cli-opencode skill supports `deepseek` (default), `minimax-coding-plan` (MiniMax Token Plan — default MiniMax path), `minimax` (MiniMax Direct API — pay-per-token alternative), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe — MiMo, explicitly-selectable; NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), and `xiaomi` (Xiaomi Direct API — MiMo: `xiaomi/mimo-v2.5-pro` + low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`, pay-per-token) — confirmed against `opencode providers list` and `opencode models`. Run `opencode models [provider]` for the full live list on a given install.\n271: \n272: | Provider | Example model id | Use case |\n273: |----------|------------------|----------|\n274: | `deepseek` (DEFAULT) | `deepseek/deepseek-v4-pro` | Default — deep reasoning at low cost via direct DeepSeek API |\n275: | `deepseek` | `deepseek/deepseek-v4-flash` | Latency-optimized direct-API sibling |\n276: | `kimi-for-coding` | `kimi-for-coding/k2p7` | Long-context Kimi K2.7 Code (256k; subscription plan) |\n277: | `zai-coding-plan` | `zai-coding-plan/glm-5.2` | Z.AI GLM Coding Plan — GLM-5.2 flagship long-horizon coding (1M context; subscription); omit `--agent`; verify with `opencode models zai-coding-plan` |\n278: | `minimax-coding-plan` (DEFAULT MiniMax) | `minimax-coding-plan/MiniMax-M3` | MiniMax Token Plan (subscription) — default MiniMax dispatch; omit `--agent`; verify with `opencode models minimax-coding-plan` |\n279: | `minimax` | `minimax/MiniMax-M3` | MiniMax Direct API — pay-per-token alternative; needs `MINIMAX_API_KEY`; confirm the live id via `opencode models minimax` |\n280: | `xiaomi-token-plan-ams` | `xiaomi-token-plan-ams/mimo-v2.5-pro` | Xiaomi Token Plan (Europe) — MiMo-V2.5-Pro: 1M-token context, strongly agentic (1000+ tool calls), token-efficient; omit `--agent`; verify with `opencode models xiaomi-token-plan-ams` |\n281: | `xiaomi` | `xiaomi/mimo-v2.5-pro` | Xiaomi Direct API — pay-per-token; MiMo-V2.5-Pro; confirm the live id via `opencode models xiaomi` |\n282: \n283: `opencode models <provider>` lists every model id the provider exposes. The model string passed to `--model` is always `provider/model-id`.\n284: \n285: ### Reasoning effort via `--variant`\n286: \n287: The `--variant` flag maps to provider-specific reasoning effort. Underlying-model conventions apply per provider routing.\n288: \n289: | Provider | Variant values |\n290: |----------|----------------|\n291: | `deepseek` (`deepseek-v4-pro`) | reasoning effort accepted |\n292: | `deepseek` (`deepseek-v4-flash`) | non-reasoning — `--variant` ignored |\n293: | `minimax-coding-plan` / `minimax` (MiniMax-M3) | `--variant` behavior unverified — omitted by default; confirm against the MiniMax API before relying on it |\n294: | `xiaomi-token-plan-ams` (mimo-v2.5-pro) | `--variant` maps to MiMo reasoning effort (low/medium/high); **always use `--variant high`** (confirmed accepted on opencode 1.15.13) |\n295: | `zai-coding-plan` (glm-5.2) | GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it |\n296: | `openai` GPT-5.6 (`gpt-5.6` / `gpt-5.6-fast` / `gpt-5.6-pro` / `gpt-5.6-sol` / `gpt-5.6-sol-fast` / `gpt-5.6-sol-pro` / `gpt-5.6-terra` / `gpt-5.6-terra-fast` / `gpt-5.6-terra-pro` / `gpt-5.6-luna` / `gpt-5.6-luna-fast` / `gpt-5.6-luna-pro`) | `--variant` maps to OpenAI reasoning effort — a separate lever from the model tier: `none`/`low`/`medium`/`high`/**`xhigh`** (Pro tiers — `gpt-5.6-pro` / `gpt-5.6-sol-pro` / `gpt-5.6-terra-pro` / `gpt-5.6-luna-pro`: `medium`/`high`/`xhigh` — **inferred from the now-retired `gpt-5.5-pro` mapping and unverified against the live catalog (which no longer lists `gpt-5.5-pro` to re-check); smoke-test a Pro slug at `--variant low` before relying on the restriction**). **The `-fast` slugs** (`gpt-5.6-fast` / `gpt-5.6-sol-fast` / `gpt-5.6-terra-fast` / `gpt-5.6-luna-fast`) are the low-latency **Fast** model tier (OpenAI `priority` service tier) with the same effort range — e.g. `--model openai/gpt-5.6-sol-fast --variant xhigh`. `gpt-5.6-sol` is the flagship default; confirm live slugs via `opencode models openai`. |\n297: \n298: Default skill behavior: pass `--variant high` for cross-AI dispatches. Operators may override via the prompt template's variant field.\n299: \n300: ### Model-specific operational caveats\n301: \n302: - **Kimi K2.7 Code (`kimi-for-coding/k2p7`) over-exploration (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`.\n303: - **GLM-5.2 (`zai-coding-plan/glm-5.2`) latency variance (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45 transient dispatch failures (retry the cell). Empirical prompt framework: COSTAR (benchmark 008).\n304: - **GLM-5.2 vision (image input):** `glm-5.2` is natively multimodal (vision-to-code), but `opencode run --file <image>` does NOT deliver images to this provider — upstream #20802 for custom OpenAI-compatible providers (confirmed 2026-06-28: `--file` → `NO_IMAGE_RECEIVED`). For image input use the direct Z.AI Coding Plan multimodal API (base64 `image_url` at `https://api.z.ai/api/coding/paas/v4/chat/completions`) — a deviation from this skill's dispatch path justified only by the verified #20802 breakage; see `../../sk-prompt/prompt-models/references/models/glm-5.2.md` §7.\n305: \n306: ---\n307: \n308: ## 6. AGENT FLAG\n309: \n310: `--agent <slug>` loads an agent definition from `.opencode/agents/<slug>.md` (project-local) or the user-level fallback. The agent definition's frontmatter pins the model, tool permissions, and system prompt that shape the dispatch.\n311: \n312: ### Discovering agents\n313: \n314: | Command | What it shows |\n315: |---------|---------------|\n316: | `opencode agent list` | All registered agent slugs across project + user scopes |\n317: | `opencode debug agent <slug>` | Resolved frontmatter and system prompt for a slug |\n318: | `opencode debug skill <slug>` | Skill resolution for a slug if the agent loads one |\n319: \n320: ### Agent slugs in this repo\n321: \n322: | Slug | Role |\n323: |------|------|\n324: | `general` | Implementation, default subagent |\n325: | `context` | Read-only retrieval and search |\n326: | `orchestrate` | Multi-agent coordination |\n327: | `write` | Documentation generation |\n328: | `review` | Code review and PR analysis |\n329: | `debug` | Fresh-perspective debugging |\n330: | `deep-research` | Iterative research loop executor |\n331: | `deep-review` | Iterative code review loop executor |\n332: | `ai-council` | Multi-strategy planning |\n333: | `deep-improvement` | Agent improvement proposal mutator |\n334: \n335: The cli-opencode skill defers to the calling AI on agent selection — see `references/agent-delegation.md` for the routing matrix and `assets/prompt-templates.md` for canonical invocation shapes.\n336: \n337: ---\n338: \n339: ## 7. OUTPUT FORMAT AND EVENT STREAM\n340: \n341: `--format default` produces a human-formatted log. `--format json` emits a newline-delimited JSON event stream.\n342: \n343: ### JSON event shape (v1.3.17)\n344: \n345: Each line is a JSON object with at minimum:\n346: \n347: | Field | Meaning |\n348: |-------|---------|\n349: | `type` | Event type (`session.started`, `message.delta`, `tool.call`, `tool.result`, `session.completed`, ...) |\n350: | `timestamp` | ISO 8601 UTC timestamp |\n351: | `session_id` | The session id assigned by OpenCode |\n352: | `payload` | Type-specific payload |\n353: \n354: External runtimes parse the stream incrementally to surface tool calls, partial messages, and the final summary. cli-opencode prompt templates always pass `--format json` so the calling AI parses structured events instead of guessing format boundaries.\n355: \n356: ---\n357: \n358: ## 8. STATE LOCATION AND SHARE URLS\n359: \n360: ### State directory\n361: \n362: OpenCode persists session state in a shared SQLite database and storage tree under `~/.local/share/opencode/`:\n363: \n364: - `opencode.db` (`-shm`/`-wal` companions) — the session/message database\n365: - `storage/` — per-session structured artifacts\n366: - `snapshot/` — working-tree snapshots\n367: \n368: There is no per-session directory under `~/.opencode/state/<session_id>/` on a standard install — that path does not exist on this runtime layout. To inspect a specific session, use `opencode export <session_id>` (§3) rather than reading files from a state directory. The cli-opencode self-invocation guard's Layer 3 lock-file probe (`~/.opencode/state/<id>/lock`, per ADR-001) targets the older path as a best-effort third layer on top of the env-var and process-ancestry checks; treat it as a heuristic, not a verified-present artifact, on installs where `~/.opencode/state/` does not exist.\n369: \n370: ### Share URLs\n371: \n372: `--share` publishes a session URL via OpenCode's share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). The CHK-033 P1 checklist item requires operator confirmation before publishing a share URL because the URL exposes the session contents.\n373: \n374: ---\n375: \n376: ## 9. VERSION DRIFT\n377: \n378: This reference is pinned to OpenCode v1.3.17. If the live binary reports a different version, do the following:\n379: \n380: 1. Run `opencode run --help` and diff the flag list against Section 4.\n381: 2. Run `opencode --help` and diff the subcommand list against Section 3.\n382: 3. If a flag was renamed, prefer the new name in the dispatch. If a flag was removed, fall back to the closest analogue and surface the drift in the calling AI's response.\n383: 4. If the operator's machine has a major version bump (v1.4+, v2.x), re-validate the entire skill against the new flag table and bump the cli-opencode minor version.\n384: \n385: ### Failure modes specific to drift\n386: \n387: | Symptom | Likely cause |\n388: |---------|--------------|\n389: | `unknown option --variant` | v1.2 or earlier — variant flag was named `--reasoning` |\n390: | `unknown option --share` | Older standalone build without share infrastructure |\n391: | `unknown option --format json` | v1.0 — JSON event stream was the default and the flag did not exist |\n392: | `MODULE_NOT_FOUND` | Plugin loader crash; rerun with `--pure` to bypass plugins |\n393: \n394: ---\n395: \n396: ## 10. TROUBLESHOOTING\n397: \n398: | Symptom | Cause | Fix |\n399: |---------|-------|-----|\n400: | `command not found: opencode` | Binary not on PATH | Install via standalone installer or `brew install opencode` |\n401: | `OPENCODE_SERVER_PASSWORD required` | Server enforces basic auth | Pass `-p <password>` or set the env var |\n402: | `provider/model not found` | Provider not configured | Run `opencode providers` to enumerate, then `auth login <provider>` |\n403: | Empty output stream | `--format default` with non-TTY parent | Pass `--format json` and parse the event stream |\n404: | Session never finishes | Tool call hung | Run `opencode export <session_id>` and inspect the message log it returns |\n405: | Plugin load crash | Misconfigured plugin | Rerun with `--pure` to bypass all plugins |\n406: | Self-invocation refused | cli-opencode detected an in-OpenCode runtime | Use a sibling cli-* skill or a fresh shell session — see ADR-001 |\n407: | `--share` URL leaks | Share infrastructure published a session containing secrets | Operator MUST confirm before publishing per CHK-033 |\n408: \n409: ---\n410: \n411: ## 11. RELATED RESOURCES\n412: \n413: - `./integration-patterns.md` - The three documented use cases and their copy-paste invocation shapes\n414: - `./agent-delegation.md` - Agent routing matrix and invocation patterns\n415: - `./opencode-tools.md` - Unique capabilities (full plugin/skill/MCP runtime, parallel detached sessions)\n416: - `../assets/prompt-templates.md` - Copy-paste prompt templates per use case\n417: - `../assets/prompt-quality-card.md` - Framework selection and CLEAR 5-check\n418: - `../SKILL.md` - Skill entry point and smart router\n\n(End of file - total 418 lines)\n</content>","metadata":{"preview":"---\ntitle: \"OpenCode CLI - Complete Command Reference\"\ndescription: \"Comprehensive reference for OpenCode CLI subcommands, flags, models, configuration, agent flags, sandbox boundaries, and troubleshooting. Pinned to v1.3.17.\"\ntrigger_phrases:\n  - \"opencode cli reference\"\n  - \"opencode run flags\"\n  - \"opencode model selection\"\n  - \"opencode provider auth pre-flight\"\n  - \"opencode variant reasoning effort\"\n  - \"opencode version drift\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.3.0.29\n---\n\n# OpenCode CLI - Complete Command Reference\n\nComprehensive reference for the OpenCode CLI binary, every subcommand the cli-opencode skill dispatches against, the flag set it relies on, the agent surface it can target, and the failure modes that need explicit handling. Pinned to v1.3.17 baseline.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/references/cli-reference.md","text":"---\ntitle: \"OpenCode CLI - Complete Command Reference\"\ndescription: \"Comprehensive reference for OpenCode CLI subcommands, flags, models, configuration, agent flags, sandbox boundaries, and troubleshooting. Pinned to v1.3.17.\"\ntrigger_phrases:\n  - \"opencode cli reference\"\n  - \"opencode run flags\"\n  - \"opencode model selection\"\n  - \"opencode provider auth pre-flight\"\n  - \"opencode variant reasoning effort\"\n  - \"opencode version drift\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.3.0.29\n---\n\n# OpenCode CLI - Complete Command Reference\n\nComprehensive reference for the OpenCode CLI binary, every subcommand the cli-opencode skill dispatches against, the flag set it relies on, the agent surface it can target, and the failure modes that need explicit handling. Pinned to v1.3.17 baseline.\n\n---\n\n## 1. OVERVIEW\n\n### Core Principle\n\nOpenCode is the framework that owns this repository. The same binary that hosts the operator's TUI session also accepts non-interactive invocations through `opencode run`. The cli-opencode skill calls `opencode run` from external runtimes (Claude Code, OpenCode, Copilot, raw shell) so the calling AI can dispatch a task into a fresh OpenCode session that loads the full plugin, skill, MCP, and Spec Kit Memory runtime.\n\n### Purpose\n\nProvide a single-source reference for the OpenCode CLI surface — every subcommand cli-opencode invokes, every flag it pins, every agent it can route to, the version baseline it is built against, and the error envelopes that need explicit recovery.\n\n### When to Use\n\n- Looking up an OpenCode CLI subcommand or flag during a delegation\n- Selecting a model + variant + agent for a dispatch\n- Confirming the version baseline before pinning a flag set\n- Troubleshooting a failed `opencode run` invocation\n- Confirming the self-invocation guard signal against the live binary\n\n### Key Sources\n\n| Source | URL |\n|--------|-----|\n| **Binary** | `$(command -v opencode)` (typically `~/.superset/bin/opencode` or another local bin path) |\n| **Repository** | https://github.com/sst/opencode |\n| **Version baseline** | v1.3.17 (pinned in this reference) |\n| **Runtime** | Node.js 18+ for the npm install path; standalone binary on macOS |\n\n---\n\n## 2. INSTALLATION\n\n| Method | Command | Notes |\n|--------|---------|-------|\n| **Standalone** | `curl -fsSL https://opencode.ai/install \\| bash` | macOS / Linux installer |\n| **Homebrew** | `brew install opencode` | macOS package manager |\n| **npm global** | `npm install -g opencode-ai` | Cross-platform when Node.js 18+ is present |\n| **Upgrade** | `opencode upgrade [target]` | Pin a specific version with the `target` argument |\n| **Uninstall** | `opencode uninstall` | Removes the binary and related state |\n\nAfter installation, run `opencode --version` to confirm. The cli-opencode skill is pinned to v1.3.17. Newer binaries may add or rename flags — consult Section 9 (Version Drift) before relying on a non-pinned flag.\n\n---\n\n## 3. SUBCOMMAND MAP\n\nOpenCode exposes a multi-subcommand surface. The cli-opencode skill primarily invokes `run`, with secondary use of `serve`, `web`, `agent`, and `debug`.\n\n| Subcommand | Purpose | Invoked by cli-opencode |\n|------------|---------|-------------------------|\n| `opencode` (default) | Start the TUI in the current project | No (interactive only) |\n| `opencode run [message..]` | Non-interactive single-shot dispatch | YES (canonical use case) |\n| `opencode serve` | Start a headless server | YES (for parallel detached sessions) |\n| `opencode web` | Start a server plus open the web interface | YES (when the operator wants a browser surface) |\n| `opencode acp` | Start an ACP (Agent Client Protocol) server | No (specialized integration path) |\n| `opencode attach <url>` | Attach to a running OpenCode server | YES (for share-URL flows) |\n| `opencode agent` | Manage agent definitions | YES (for agent listing) |\n| `opencode debug` | Debugging and troubleshooting tools | YES (for `debug skill` and `debug agent` listings) |\n| `opencode mcp` | Manage MCP server registrations | No |\n| `opencode providers` (alias `auth`) | Manage AI providers and credentials | No (operator-driven setup) |\n| `opencode models [provider]` | List available models | YES (for capability discovery) |\n| `opencode session` | Manage sessions | No (state inspection only) |\n| `opencode export [sessionID]` | Export session data as JSON | YES (for memory handback flows) |\n| `opencode stats` | Token and cost statistics | No |\n| `opencode db` | Database tools | No |\n| `opencode plugin <module>` (alias `plug`) | Install a plugin | No (operator-driven setup) |\n| `opencode upgrade [target]` | Upgrade the binary | No (operator-driven) |\n| `opencode uninstall` | Uninstall the binary | No (operator-driven) |\n\n---\n\n## 4. `opencode run` FLAGS\n\n`opencode run [message..]` is the canonical non-interactive entry point. The cli-opencode skill builds every dispatch around this subcommand.\n\n### Core flags\n\n| Flag / Option | Type | Purpose |\n|---------------|------|---------|\n| `[message..]` | positional | One or more positional message strings |\n| `--print-logs` | boolean | Stream logs to stderr |\n| `--log-level` | enum | `DEBUG`, `INFO`, `WARN`, `ERROR` |\n| `--pure` | boolean | Run without external plugins (skill loads disabled) |\n| `--command` | string | Run a known command, the message becomes its args |\n| `-c`, `--continue` | boolean | Continue the last session in this project |\n| `-s`, `--session` | string | Continue a specific session id |\n| `--fork` | boolean | Fork before continuing — requires `--continue` or `--session` |\n| `--share` | boolean | Publish a shareable URL for this session |\n| `-m`, `--model` | string | Provider/model selector — e.g. `deepseek/deepseek-v4-pro` |\n| `--agent` | string | Agent slug (loads from `.opencode/agents/<slug>.md`) |\n| `--format` | enum | `default` (formatted) or `json` (raw event stream) |\n| `-f`, `--file` | array | Attach files to the message |\n| `--title` | string | Session title (truncated message used when omitted) |\n| `--attach` | string | Attach to a running OpenCode server URL |\n| `-p`, `--password` | string | Basic auth password (or `OPENCODE_SERVER_PASSWORD`) |\n| `--dir` | string | Working directory or remote-server path |\n| `--port` | number | Local server port (random when omitted) |\n| `--variant` | string | Provider-specific reasoning effort (`high`, `max`, `minimal`, etc.) |\n| `--thinking` | boolean | Show thinking blocks (default false) |\n\n> **`--command` semantics (verified on v1.17.4):** the `run` message is plain text — slash-command syntax inside it (`opencode run \"/memory:search query\"`) is NOT expanded, so the command's template never reaches the model. Executing a registered command non-interactively requires `--command <family>/<name>` with the args as the message (they become `$ARGUMENTS`). Registry names are slash-namespaced (`memory/search` for `/memory:search`); a wrong name fails with the full registry list. Behavior probes of slash commands MUST use `--command`; the raw-text form only measures the model freestyling without the contract. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n\n### cli-opencode default invocation shape\n\nThe skill builds every dispatch from a base shape and overlays use-case-specific flags:\n\n```bash\nopencode run \\\n  --model deepseek/deepseek-v4-pro \\\n  --agent <agent-slug> \\\n  --variant high \\\n  --format json \\\n  --dir \"$REPO_ROOT\" \\\n  \"<prompt>\"\n```\n\n| Flag | Default | Reason |\n|------|---------|--------|\n| `--model` | `deepseek/deepseek-v4-pro` | Direct DeepSeek is the default provider — elevated reasoning at low cost; operator may override (e.g. `deepseek/deepseek-v4-flash`, `kimi-for-coding/k2p7`, or any live OpenAI GPT-5.6 slug: `openai/gpt-5.6`, `openai/gpt-5.6-fast`, `openai/gpt-5.6-pro`, `openai/gpt-5.6-sol`, `openai/gpt-5.6-sol-fast`, `openai/gpt-5.6-sol-pro`, `openai/gpt-5.6-terra`, `openai/gpt-5.6-terra-fast`, `openai/gpt-5.6-terra-pro`, `openai/gpt-5.6-luna`, `openai/gpt-5.6-luna-fast`, `openai/gpt-5.6-luna-pro`) |\n| `--agent` | per use case | Required for use case 1 / 3; optional for use case 2 |\n| `--variant high` | high | Routine cli-opencode dispatches benefit from elevated reasoning effort |\n| `--format json` | json | Structured event stream is what external runtimes parse |\n| `--dir` | repo root | Pin the working directory to avoid CWD ambiguity |\n\n### Stdin handling — `</dev/null` is required for non-interactive dispatch\n\n> **opencode v1.14.39 reads stdin at startup before session creation.** If you redirect stdout/stderr to files in automation (`> stdout.log 2> stderr.log`), opencode hangs at 0% CPU after the `+60s snapshot prune cleanup` log line because stdin remains attached to the parent terminal and never receives EOF.\n\nALWAYS append `</dev/null` AFTER the prompt argument and BEFORE the stdout/stderr redirects:\n\n```bash\nopencode run --model X \"<prompt>\" </dev/null > stdout.log 2> stderr.log\n#                                  ^^^^^^^^^^\n#                                  redirects stdin from /dev/null → immediate EOF\n```\n\nForeground `| tail` accidentally works because the upstream pipe stage provides closed stdin, but `> file 2> file` does not. See `references/integration-patterns.md` §6 for the full failure-mode + fix matrix and `../CHANGELOG-2026-05-08-tool-name-regex-fix.md` §Fix 4 for the discovery context.\n\n### Sessions, share URLs, and ports\n\n`--share` publishes the session over the OpenCode share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). External-runtime dispatches do NOT publish share URLs by default.\n\n`--port` only matters when the dispatch needs to bind a known port (e.g. for a parallel detached session that another tool will attach to). The default random port is correct for one-shot dispatches.\n\n`--continue` and `--session <id>` reuse prior session state. `--fork` branches an existing session into a new one. cli-opencode uses session continuation in memory handback flows where the calling AI wants to thread context across multiple delegations.\n\n### Provider Auth Pre-Flight (smart fallback)\n\nBefore the first dispatch in a session, run a one-shot auth pre-flight against `opencode providers list` so a missing default doesn't fail mid-dispatch. Cache the result for the session; only re-run on auth failure.\n\n```bash\n# Pre-flight — one call per session\nPROVIDERS=$(opencode providers list 2>&1)\necho \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\necho \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\necho \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\necho \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\necho \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\necho \"default=$DEEPSEEK_OK minimax_token=$MINIMAX_TOKEN_OK minimax_direct=$MINIMAX_DIRECT_OK xiaomi=$XIAOMI_OK xiaomi_direct=$XIAOMI_DIRECT_OK\"\n```\n\n| State | DEEPSEEK_OK | Action |\n|-------|-------------|--------|\n| Default available | 1 | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n| Default missing | 0 | **ASK user** before substituting (offer A: openai/gpt-5.6-sol-pro, B: login deepseek and retry, C: name a different model) — do not dispatch until configured |\n\n**MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n| Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n| Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n| Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n\n**MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n| MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n| Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n| Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n| Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n| Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n\n**Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n\n```bash\n# Recommended default — direct DeepSeek API\nopencode providers login deepseek\n\n# MiniMax Token Plan — DEFAULT MiniMax path (subscription). Interactive: pick \"MiniMax Token Plan (minimax.io)\".\nopencode auth login          # → provider minimax-coding-plan; Anthropic-compatible https://api.minimax.io/anthropic/v1 (China: api.minimaxi.com)\n\n# MiniMax Direct API — pay-per-token alternative (needs MINIMAX_API_KEY; platform endpoint https://api.minimax.io/v1)\nopencode providers login minimax\n\n# Xiaomi Token Plan (Europe) — provider-managed endpoint. Interactive: pick \"Xiaomi Token Plan (Europe)\".\nopencode auth login          # → provider xiaomi-token-plan-ams (Xiaomi Token Plan, Europe)\n\n# Xiaomi Direct API — pay-per-token alternative\nopencode providers login xiaomi\n\n# Z.AI GLM Coding Plan — GLM coding subscription. Interactive: pick \"Z.AI Coding Plan\".\nopencode auth login          # → provider zai-coding-plan; model zai-coding-plan/glm-5.2\n```\n\n> Do not mix region endpoints (international `minimax.io` vs China `minimaxi.com`). Confirm live model ids with `opencode models minimax-coding-plan`. The Xiaomi endpoint is provider-managed (no documented base URL — do not invent one); confirm live model ids with `opencode models xiaomi-token-plan-ams` (Token Plan) or `opencode models xiaomi` (Direct API).\n\n**On auth-error mid-dispatch** (`401 Unauthorized`, `provider/model not found`): invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n### User-facing prompt templates\n\nSurface these verbatim to the operator when the pre-flight decision tree lands on \"ASK user\" (default missing with a fallback configured, or all providers missing). Never dispatch until the operator responds.\n\n**Default missing, fallback configured:**\n\n```text\nThe skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\nA configured fallback is available. Pick one:\n  A) Use `openai/gpt-5.6-sol-pro --variant high` (OpenAI premium, configured now — paid)\n  B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n  C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n  D) Run `opencode providers login deepseek` first, then retry the original dispatch\n  E) Name a different model — paste the `--model <provider/model>` you want to use\n```\n\n**All providers missing:**\n\n```text\nNo supported providers are configured on this machine. Run one:\n  - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n  - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n  - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n  - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n  - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n  - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n  - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n  - `opencode providers login openai`       (OpenAI premium alternative — paid)\nWhich would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n```\n\n**Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n---\n\n## 5. MODEL SELECTION\n\nOpenCode resolves models through configured providers. The cli-opencode skill supports `deepseek` (default), `minimax-coding-plan` (MiniMax Token Plan — default MiniMax path), `minimax` (MiniMax Direct API — pay-per-token alternative), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe — MiMo, explicitly-selectable; NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), and `xiaomi` (Xiaomi Direct API — MiMo: `xiaomi/mimo-v2.5-pro` + low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`, pay-per-token) — confirmed against `opencode providers list` and `opencode models`. Run `opencode models [provider]` for the full live list on a given install.\n\n| Provider | Example model id | Use case |\n|----------|------------------|----------|\n| `deepseek` (DEFAULT) | `deepseek/deepseek-v4-pro` | Default — deep reasoning at low cost via direct DeepSeek API |\n| `deepseek` | `deepseek/deepseek-v4-flash` | Latency-optimized direct-API sibling |\n| `kimi-for-coding` | `kimi-for-coding/k2p7` | Long-context Kimi K2.7 Code (256k; subscription plan) |\n| `zai-coding-plan` | `zai-coding-plan/glm-5.2` | Z.AI GLM Coding Plan — GLM-5.2 flagship long-horizon coding (1M context; subscription); omit `--agent`; verify with `opencode models zai-coding-plan` |\n| `minimax-coding-plan` (DEFAULT MiniMax) | `minimax-coding-plan/MiniMax-M3` | MiniMax Token Plan (subscription) — default MiniMax dispatch; omit `--agent`; verify with `opencode models minimax-coding-plan` |\n| `minimax` | `minimax/MiniMax-M3` | MiniMax Direct API — pay-per-token alternative; needs `MINIMAX_API_KEY`; confirm the live id via `opencode models minimax` |\n| `xiaomi-token-plan-ams` | `xiaomi-token-plan-ams/mimo-v2.5-pro` | Xiaomi Token Plan (Europe) — MiMo-V2.5-Pro: 1M-token context, strongly agentic (1000+ tool calls), token-efficient; omit `--agent`; verify with `opencode models xiaomi-token-plan-ams` |\n| `xiaomi` | `xiaomi/mimo-v2.5-pro` | Xiaomi Direct API — pay-per-token; MiMo-V2.5-Pro; confirm the live id via `opencode models xiaomi` |\n\n`opencode models <provider>` lists every model id the provider exposes. The model string passed to `--model` is always `provider/model-id`.\n\n### Reasoning effort via `--variant`\n\nThe `--variant` flag maps to provider-specific reasoning effort. Underlying-model conventions apply per provider routing.\n\n| Provider | Variant values |\n|----------|----------------|\n| `deepseek` (`deepseek-v4-pro`) | reasoning effort accepted |\n| `deepseek` (`deepseek-v4-flash`) | non-reasoning — `--variant` ignored |\n| `minimax-coding-plan` / `minimax` (MiniMax-M3) | `--variant` behavior unverified — omitted by default; confirm against the MiniMax API before relying on it |\n| `xiaomi-token-plan-ams` (mimo-v2.5-pro) | `--variant` maps to MiMo reasoning effort (low/medium/high); **always use `--variant high`** (confirmed accepted on opencode 1.15.13) |\n| `zai-coding-plan` (glm-5.2) | GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it |\n| `openai` GPT-5.6 (`gpt-5.6` / `gpt-5.6-fast` / `gpt-5.6-pro` / `gpt-5.6-sol` / `gpt-5.6-sol-fast` / `gpt-5.6-sol-pro` / `gpt-5.6-terra` / `gpt-5.6-terra-fast` / `gpt-5.6-terra-pro` / `gpt-5.6-luna` / `gpt-5.6-luna-fast` / `gpt-5.6-luna-pro`) | `--variant` maps to OpenAI reasoning effort — a separate lever from the model tier: `none`/`low`/`medium`/`high`/**`xhigh`** (Pro tiers — `gpt-5.6-pro` / `gpt-5.6-sol-pro` / `gpt-5.6-terra-pro` / `gpt-5.6-luna-pro`: `medium`/`high`/`xhigh` — **inferred from the now-retired `gpt-5.5-pro` mapping and unverified against the live catalog (which no longer lists `gpt-5.5-pro` to re-check); smoke-test a Pro slug at `--variant low` before relying on the restriction**). **The `-fast` slugs** (`gpt-5.6-fast` / `gpt-5.6-sol-fast` / `gpt-5.6-terra-fast` / `gpt-5.6-luna-fast`) are the low-latency **Fast** model tier (OpenAI `priority` service tier) with the same effort range — e.g. `--model openai/gpt-5.6-sol-fast --variant xhigh`. `gpt-5.6-sol` is the flagship default; confirm live slugs via `opencode models openai`. |\n\nDefault skill behavior: pass `--variant high` for cross-AI dispatches. Operators may override via the prompt template's variant field.\n\n### Model-specific operational caveats\n\n- **Kimi K2.7 Code (`kimi-for-coding/k2p7`) over-exploration (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`.\n- **GLM-5.2 (`zai-coding-plan/glm-5.2`) latency variance (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45 transient dispatch failures (retry the cell). Empirical prompt framework: COSTAR (benchmark 008).\n- **GLM-5.2 vision (image input):** `glm-5.2` is natively multimodal (vision-to-code), but `opencode run --file <image>` does NOT deliver images to this provider — upstream #20802 for custom OpenAI-compatible providers (confirmed 2026-06-28: `--file` → `NO_IMAGE_RECEIVED`). For image input use the direct Z.AI Coding Plan multimodal API (base64 `image_url` at `https://api.z.ai/api/coding/paas/v4/chat/completions`) — a deviation from this skill's dispatch path justified only by the verified #20802 breakage; see `../../sk-prompt/prompt-models/references/models/glm-5.2.md` §7.\n\n---\n\n## 6. AGENT FLAG\n\n`--agent <slug>` loads an agent definition from `.opencode/agents/<slug>.md` (project-local) or the user-level fallback. The agent definition's frontmatter pins the model, tool permissions, and system prompt that shape the dispatch.\n\n### Discovering agents\n\n| Command | What it shows |\n|---------|---------------|\n| `opencode agent list` | All registered agent slugs across project + user scopes |\n| `opencode debug agent <slug>` | Resolved frontmatter and system prompt for a slug |\n| `opencode debug skill <slug>` | Skill resolution for a slug if the agent loads one |\n\n### Agent slugs in this repo\n\n| Slug | Role |\n|------|------|\n| `general` | Implementation, default subagent |\n| `context` | Read-only retrieval and search |\n| `orchestrate` | Multi-agent coordination |\n| `write` | Documentation generation |\n| `review` | Code review and PR analysis |\n| `debug` | Fresh-perspective debugging |\n| `deep-research` | Iterative research loop executor |\n| `deep-review` | Iterative code review loop executor |\n| `ai-council` | Multi-strategy planning |\n| `deep-improvement` | Agent improvement proposal mutator |\n\nThe cli-opencode skill defers to the calling AI on agent selection — see `references/agent-delegation.md` for the routing matrix and `assets/prompt-templates.md` for canonical invocation shapes.\n\n---\n\n## 7. OUTPUT FORMAT AND EVENT STREAM\n\n`--format default` produces a human-formatted log. `--format json` emits a newline-delimited JSON event stream.\n\n### JSON event shape (v1.3.17)\n\nEach line is a JSON object with at minimum:\n\n| Field | Meaning |\n|-------|---------|\n| `type` | Event type (`session.started`, `message.delta`, `tool.call`, `tool.result`, `session.completed`, ...) |\n| `timestamp` | ISO 8601 UTC timestamp |\n| `session_id` | The session id assigned by OpenCode |\n| `payload` | Type-specific payload |\n\nExternal runtimes parse the stream incrementally to surface tool calls, partial messages, and the final summary. cli-opencode prompt templates always pass `--format json` so the calling AI parses structured events instead of guessing format boundaries.\n\n---\n\n## 8. STATE LOCATION AND SHARE URLS\n\n### State directory\n\nOpenCode persists session state in a shared SQLite database and storage tree under `~/.local/share/opencode/`:\n\n- `opencode.db` (`-shm`/`-wal` companions) — the session/message database\n- `storage/` — per-session structured artifacts\n- `snapshot/` — working-tree snapshots\n\nThere is no per-session directory under `~/.opencode/state/<session_id>/` on a standard install — that path does not exist on this runtime layout. To inspect a specific session, use `opencode export <session_id>` (§3) rather than reading files from a state directory. The cli-opencode self-invocation guard's Layer 3 lock-file probe (`~/.opencode/state/<id>/lock`, per ADR-001) targets the older path as a best-effort third layer on top of the env-var and process-ancestry checks; treat it as a heuristic, not a verified-present artifact, on installs where `~/.opencode/state/` does not exist.\n\n### Share URLs\n\n`--share` publishes a session URL via OpenCode's share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). The CHK-033 P1 checklist item requires operator confirmation before publishing a share URL because the URL exposes the session contents.\n\n---\n\n## 9. VERSION DRIFT\n\nThis reference is pinned to OpenCode v1.3.17. If the live binary reports a different version, do the following:\n\n1. Run `opencode run --help` and diff the flag list against Section 4.\n2. Run `opencode --help` and diff the subcommand list against Section 3.\n3. If a flag was renamed, prefer the new name in the dispatch. If a flag was removed, fall back to the closest analogue and surface the drift in the calling AI's response.\n4. If the operator's machine has a major version bump (v1.4+, v2.x), re-validate the entire skill against the new flag table and bump the cli-opencode minor version.\n\n### Failure modes specific to drift\n\n| Symptom | Likely cause |\n|---------|--------------|\n| `unknown option --variant` | v1.2 or earlier — variant flag was named `--reasoning` |\n| `unknown option --share` | Older standalone build without share infrastructure |\n| `unknown option --format json` | v1.0 — JSON event stream was the default and the flag did not exist |\n| `MODULE_NOT_FOUND` | Plugin loader crash; rerun with `--pure` to bypass plugins |\n\n---\n\n## 10. TROUBLESHOOTING\n\n| Symptom | Cause | Fix |\n|---------|-------|-----|\n| `command not found: opencode` | Binary not on PATH | Install via standalone installer or `brew install opencode` |\n| `OPENCODE_SERVER_PASSWORD required` | Server enforces basic auth | Pass `-p <password>` or set the env var |\n| `provider/model not found` | Provider not configured | Run `opencode providers` to enumerate, then `auth login <provider>` |\n| Empty output stream | `--format default` with non-TTY parent | Pass `--format json` and parse the event stream |\n| Session never finishes | Tool call hung | Run `opencode export <session_id>` and inspect the message log it returns |\n| Plugin load crash | Misconfigured plugin | Rerun with `--pure` to bypass all plugins |\n| Self-invocation refused | cli-opencode detected an in-OpenCode runtime | Use a sibling cli-* skill or a fresh shell session — see ADR-001 |\n| `--share` URL leaks | Share infrastructure published a session containing secrets | Operator MUST confirm before publishing per CHK-033 |\n\n---\n\n## 11. RELATED RESOURCES\n\n- `./integration-patterns.md` - The three documented use cases and their copy-paste invocation shapes\n- `./agent-delegation.md` - Agent routing matrix and invocation patterns\n- `./opencode-tools.md` - Unique capabilities (full plugin/skill/MCP runtime, parallel detached sessions)\n- `../assets/prompt-templates.md` - Copy-paste prompt templates per use case\n- `../assets/prompt-quality-card.md` - Framework selection and CLEAR 5-check\n- `../SKILL.md` - Skill entry point and smart router","lineStart":1,"lineEnd":418,"totalLines":418,"truncated":false}},"title":".opencode/skills/cli-external-orchestration/cli-opencode/references/cli-reference.md","time":{"start":1784650185954,"end":1784650185993}},"metadata":{"openai":{"itemId":"fc_0faa9dc6e138ff0b016a5f99c9aed88191ad24ca67d7f06ef1"}},"id":"prt_f8570bcdc001rvwSii2BOpqSir","sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","messageID":"msg_f8570725b001DK0GOt6we0e4EV"}}
{"type":"tool_use","timestamp":1784650186004,"sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","part":{"type":"tool","tool":"read","callID":"call_M9sWLScGGF4Fa5o3ceWoC9te","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/references/integration-patterns.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/references/integration-patterns.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"OpenCode CLI - Integration Patterns and Use Cases\"\n3: description: \"The three documented use cases for cli-opencode (external runtime to OpenCode, in-OpenCode parallel detached session, cross-AI orchestration handback) with copy-paste prompt templates, smart-router signals, and the self-invocation guard decision tree.\"\n4: trigger_phrases:\n5:   - \"opencode integration patterns\"\n6:   - \"opencode self-invocation guard\"\n7:   - \"opencode parallel detached session\"\n8:   - \"opencode cross-ai handback\"\n9:   - \"opencode stdin dev null rule\"\n10:   - \"opencode run hang non-interactive\"\n11: importance_tier: important\n12: contextType: implementation\n13: version: 1.3.0.14\n14: ---\n15: \n16: # OpenCode CLI - Integration Patterns\n17: \n18: How cli-opencode positions itself relative to the three sibling cli-* skills, the three documented use cases (per ADR-002), the smart-router decision tree that picks between them, and the self-invocation guard that protects against circular dispatch (per ADR-001).\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: The three sibling cli-* skills exist because their target binaries are external runtimes — Claude Code, OpenCode, Copilot do not own this repo. OpenCode owns this repo. A naive \"delegate to opencode\" skill makes no sense for an in-OpenCode operator (it would create a circular dispatch).\n25: \n26: cli-opencode resolves this by documenting THREE orthogonal use cases. The smart router selects between them based on the calling AI's runtime context.\n27: \n28: | Use case | Calling runtime | Target | Self-invocation? |\n29: |----------|-----------------|--------|------------------|\n30: | 1. External runtime to OpenCode | Claude Code, OpenCode, Copilot, raw shell | OpenCode for full plugin / skill / MCP runtime | No |\n31: | 2. In-OpenCode parallel detached session | OpenCode itself (TUI / web / serve / acp) | New OpenCode session via `--share --port N` | No (different session id) |\n32: | 3. Cross-AI orchestration handback | OpenCode / Copilot | OpenCode for spec-kit specific workflows | No |\n33: \n34: The cycle ADR-001 protects against is the operator inside OpenCode asking cli-opencode to \"delegate this exact prompt to OpenCode\" — that case is REFUSED at the routing layer.\n35: \n36: ---\n37: \n38: ## 2. USE CASE 1 — EXTERNAL RUNTIME TO OPENCODE\n39: \n40: ### When to use\n41: \n42: The calling AI is Claude Code, OpenCode, Copilot, or a raw shell. The task needs the project's full plugin / skill / MCP / Spec Kit Memory runtime — not just a raw model dispatch. Examples:\n43: \n44: - Run `memory_search` against the project's spec-doc database\n45: - Call Code Graph for semantic code search across the repo\n46: - Dispatch a `@deep-research` or `@deep-review` agent loop with externalized state\n47: - Run a sub-agent that needs Spec Kit Memory for continuity across iterations\n48: \n49: ### Smart-router signal\n50: \n51: ADR-001's detection signal does NOT trip (no OPENCODE_* env var, no opencode parent process, no live state lock).\n52: \n53: ### Prompt template\n54: \n55: ```text\n56: You are dispatching from <calling-runtime> into a fresh OpenCode session via cli-opencode.\n57: \n58: Goal: <one-sentence goal>\n59: \n60: Context:\n61: - Spec folder: <path> (pre-approved, skip Gate 3)\n62: - Plugins / skills required: <list>\n63: - MCP tools required: <list>\n64: \n65: Constraints:\n66: - <list>\n67: \n68: Success criteria:\n69: - <list>\n70: \n71: Memory epilogue: include MEMORY_HANDBACK delimiters at the end of the response so the calling runtime can preserve context.\n72: ```\n73: \n74: ### Invocation shape\n75: \n76: ```bash\n77: opencode run \\\n78:   --model deepseek/deepseek-v4-pro \\\n79:   --agent general \\\n80:   --variant high \\\n81:   --format json \\\n82:   --dir \"$REPO_ROOT\" \\\n83:   \"<prompt-from-template>\" 2>&1\n84: ```\n85: \n86: ### Why it matters\n87: \n88: This is the canonical cross-AI dispatch path. It gives external runtimes a one-shot bridge into the project's full runtime without forcing the operator to leave their host session.\n89: \n90: ---\n91: \n92: ## 3. USE CASE 2 — IN-OPENCODE PARALLEL DETACHED SESSION\n93: \n94: ### When to use\n95: \n96: The operator is already inside an OpenCode session (TUI, web, serve, acp). They want a SEPARATE OpenCode session — not a continuation, not a fork — to run an ablation suite, a worker farm, or a parallel research sweep. The new session has its own session id, its own state directory, and an optional share URL.\n97: \n98: ### Smart-router signal\n99: \n100: ADR-001's detection signal trips (in-OpenCode runtime). The router checks the prompt for explicit parallel-session keywords:\n101: \n102: - \"parallel detached session\"\n103: - \"ablation suite\"\n104: - \"worker farm\"\n105: - \"parallel research\"\n106: - \"spawn detached\"\n107: - \"share URL\"\n108: \n109: If at least one of these phrases appears AND the prompt does NOT request \"delegate this exact prompt\", the router permits the dispatch with `--share --port <N>`.\n110: \n111: ### Prompt template\n112: \n113: ```text\n114: You are spawning a parallel detached OpenCode session for <purpose>.\n115: \n116: Goal: <one-sentence goal>\n117: \n118: Context:\n119: - Spec folder: <path> (pre-approved, skip Gate 3)\n120: - Iteration N of <total>\n121: - State file: <path>\n122: \n123: Constraints:\n124: - This session must NOT modify the parent session's state.\n125: - Write results to <state file path>.\n126: - Publish a share URL only if the operator confirmed (CHK-033).\n127: \n128: Success criteria:\n129: - <list>\n130: ```\n131: \n132: ### Invocation shape\n133: \n134: ```bash\n135: opencode run \\\n136:   --share \\\n137:   --port 4096 \\\n138:   --model deepseek/deepseek-v4-pro \\\n139:   --agent deep-research \\\n140:   --variant high \\\n141:   --format json \\\n142:   --dir \"$REPO_ROOT\" \\\n143:   \"<prompt-from-template>\" 2>&1\n144: ```\n145: \n146: ### Why it matters\n147: \n148: Parallel research, ablation studies, and worker farms need N concurrent sessions. Each must be independent. The detached pattern makes this possible without leaking state between sessions.\n149: \n150: ### Operator confirmation for share URLs\n151: \n152: Per CHK-033, the calling AI MUST confirm with the operator before passing `--share`. The share URL exposes the session's contents to anyone with the URL, so it is opt-in.\n153: \n154: ---\n155: \n156: ## 4. USE CASE 3 — CROSS-AI ORCHESTRATION HANDBACK\n157: \n158: ### When to use\n159: \n160: The calling AI is a non-Anthropic CLI (OpenCode, Copilot). The task requires OpenCode-specific plugins or skills (e.g. spec-kit workflows, the Spec Kit Memory MCP database, the structural code graph). The non-Anthropic CLI cannot load the project's plugins on its own — cli-opencode is the documented bridge.\n161: \n162: ### Smart-router signal\n163: \n164: ADR-001's detection signal does NOT trip (the calling AI is OpenCode / Copilot, not OpenCode). The prompt mentions a project-specific subsystem:\n165: \n166: - \"spec kit\" / \"spec-kit\" / \"spec_kit\"\n167: - \"spec kit memory\"\n168: - \"code graph\"\n169: - \"skill advisor\"\n170: - \"session bootstrap\"\n171: \n172: When the calling AI is non-Anthropic AND a project-specific subsystem is named, this use case is selected over use case 1 (which is the more general path).\n173: \n174: ### Prompt template\n175: \n176: ```text\n177: You are dispatching from <calling-runtime> into OpenCode for a spec-kit-specific workflow.\n178: \n179: Goal: <one-sentence goal>\n180: \n181: Context:\n182: - Spec folder: <path> (pre-approved, skip Gate 3)\n183: - Subsystem: <spec-kit / memory / code-graph / advisor>\n184: - Operation: <save / search / query / scan / validate>\n185: \n186: Constraints:\n187: - The OpenCode session MUST load the system-spec-kit skill for this dispatch.\n188: - All MCP calls go through the project's local MCP servers.\n189: \n190: Success criteria:\n191: - <list>\n192: \n193: Memory epilogue: include MEMORY_HANDBACK delimiters at the end so the calling runtime can preserve context.\n194: ```\n195: \n196: ### Invocation shape\n197: \n198: ```bash\n199: opencode run \\\n200:   --model deepseek/deepseek-v4-pro \\\n201:   --agent general \\\n202:   --variant high \\\n203:   --format json \\\n204:   --dir \"$REPO_ROOT\" \\\n205:   \"<prompt-from-template>\" 2>&1\n206: ```\n207: \n208: The invocation shape is identical to use case 1 — the difference is the prompt content, which targets a project-specific subsystem.\n209: \n210: ### Why it matters\n211: \n212: OpenCode and Copilot cannot load this project's plugin / skill / MCP runtime on their own. cli-opencode is the documented bridge that lets a OpenCode-led orchestration call into the project's spec-kit workflows without leaving the OpenCode session.\n213: \n214: ---\n215: \n216: ## 5. SMART-ROUTER DECISION TREE\n217: \n218: The skill's smart router picks between the three use cases (or refuses) using this decision tree:\n219: \n220: ```text\n221: INPUT: prompt + calling runtime\n222:                 |\n223:                 v\n224: [ADR-001 SELF-INVOCATION GUARD]\n225: - Layer 1: env var lookup (any OPENCODE_* env var present?)\n226: - Layer 2: process ancestry (opencode in parent process tree?)\n227: - Layer 3: best-effort lock-file probe (~/.opencode/state/<id>/lock present? -- heuristic, not guaranteed on every install)\n228:                 |\n229:         +-------+-------+\n230:         |               |\n231:        NO              YES\n232:         |               |\n233:         v               v\n234: [CALLING RUNTIME]   [PROMPT KEYWORDS]\n235:         |               |\n236:    +----+----+    +-----+-----+\n237:    |         |    |           |\n238: Anthropic  Other  parallel   self-dispatch\n239: (Claude    (OpenCode words    only\n240: Code)      Copilot)        |           |\n241:    |         |             v           v\n242:    v         v        USE CASE 2   REFUSE\n243: USE CASE  [PROJECT     (in-       (cycle —\n244: 1         SUBSYSTEM    OpenCode   surface\n245: (external NAMED?]      parallel)  ADR-001\n246: to                      |          error)\n247: OpenCode)        +------+------+\n248:                  |             |\n249:                 YES            NO\n250:                  |             |\n251:                  v             v\n252:              USE CASE 3     USE CASE 1\n253:              (cross-AI      (external\n254:              handback)      to OpenCode)\n255: ```\n256: \n257: ### Refusal message\n258: \n259: When the router hits the REFUSE leaf, it surfaces this exact message:\n260: \n261: ```text\n262: ERROR: cli-opencode self-invocation refused.\n263: \n264: You are already inside OpenCode (signal: <env|ancestry|lockfile> tripped).\n265: Asking cli-opencode to delegate this exact prompt back to OpenCode would create\n266: a circular dispatch.\n267: \n268: Options:\n269: 1. Use a sibling cli-* skill (cli-claude-code, cli-opencode)\n270:    to dispatch a different model.\n271: 2. Open a fresh shell session (no OpenCode parent) and re-run from there.\n272: 3. If you wanted a parallel detached session (different session id, separate\n273:    state directory), restate the request with explicit \"parallel detached\" /\n274:    \"ablation suite\" / \"worker farm\" / \"share URL\" keywords — that triggers\n275:    use case 2 instead of refusal.\n276: ```\n277: \n278: ---\n279: \n280: ## 6. STDIN HANDLING — `</dev/null` IS REQUIRED FOR ALL NON-INTERACTIVE DISPATCH\n281: \n282: **`opencode run` reads stdin at startup before session creation (opencode v1.14.39).** Without an explicit closed stdin, ANY non-interactive automation that redirects stdout/stderr hangs forever at 0% CPU — even with a clean tool registry, valid model, and `--pure` set. This is the third independent root cause discovered during the 027-xce-research-based-refinement deep-research run on 2026-05-08; see `../CHANGELOG-2026-05-08-tool-name-regex-fix.md` §Fix 4 and memory `feedback_opencode_run_requires_dev_null_stdin.md`.\n283: \n284: ### Hang symptom (diagnostic)\n285: \n286: If you see ALL of:\n287: - Process at 0% CPU after >60s\n288: - `~/.local/share/opencode/log/<timestamp>.log` last entry is `service=snapshot prune=7.days cleanup`\n289: - 0 bytes stdout, 0 bytes stderr\n290: - No TCP connections to provider\n291: - 12-min timeout fires, exit code 124\n292: \n293: …it's the stdin-startup-deadlock. Append `</dev/null`.\n294: \n295: ### Failure patterns (all hang)\n296: \n297: ```bash\n298: # WRONG #1 — file redirect without </dev/null\n299: opencode run --model X \"<prompt>\" > stdout.log 2> stderr.log\n300: \n301: # WRONG #2 — combined redirect via tee\n302: opencode run --model X \"<prompt>\" 2>&1 | tee combined.log\n303: \n304: # WRONG #3 — background opencode in while-read loop without </dev/null\n305: while IFS= read -r line; do\n306:   opencode run --format json \"<prompt>\" > \"$LOG\" 2>&1 &\n307: done < input.jsonl\n308: # Both bugs apply: stdin-startup-read AND silent loop-stdin consumption.\n309: ```\n310: \n311: ### Fix patterns (all work)\n312: \n313: ```bash\n314: # RIGHT #1 — file redirect with </dev/null\n315: opencode run --model X \"<prompt>\" </dev/null > stdout.log 2> stderr.log\n316: \n317: # RIGHT #2 — combined redirect with explicit closed stdin via < /dev/null\n318: opencode run --model X \"<prompt>\" </dev/null 2>&1 | tee combined.log\n319: \n320: # RIGHT #3 — background in while-read loop\n321: while IFS= read -r line; do\n322:   opencode run --format json \"<prompt>\" > \"$LOG\" 2>&1 </dev/null &\n323: done < input.jsonl\n324: \n325: # RIGHT #4 — foreground pipe to tail (works WITHOUT </dev/null because the empty pipe upstream provides EOF)\n326: opencode run --model X \"<prompt>\" 2>&1 | tail -15\n327: ```\n328: \n329: ### Why foreground `| tail` accidentally works\n330: \n331: When you run `opencode run \"...\" 2>&1 | tail`, the shell sets up a pipe BEFORE invoking opencode. opencode's stdin is NOT connected to your terminal — it's connected to the upstream pipe stage, which has no producer (the prompt is the positional argument, not piped via stdin). The shell closes that pipe immediately, opencode reads EOF, and startup proceeds. This is fragile — `2>&1 | tee combined.log` does NOT work because `tee` may keep the pipe open differently depending on shell + tee implementation. **Always use `</dev/null` explicitly** rather than relying on accidental pipe behavior.\n332: \n333: ### Position rule\n334: \n335: `</dev/null` belongs:\n336: - AFTER the prompt positional argument\n337: - BEFORE the `> stdout 2> stderr` redirects (or anywhere on the command line — shell parses redirects independent of position, but right-after-prompt is conventional and easiest to spot during code review)\n338: \n339: ```bash\n340: # canonical order\n341: opencode run --flags \"<prompt>\" </dev/null > stdout 2> stderr\n342: #                              ^^^^^^^^^^\n343: #                              stdin from /dev/null (immediate EOF)\n344: ```\n345: \n346: ### Background dispatch from automation scripts (the deep-research / deep-review pattern)\n347: \n348: ```bash\n349: timeout 720 opencode run \\\n350:   --model deepseek/deepseek-v4-pro \\\n351:   --variant high \\\n352:   --pure \\\n353:   --dangerously-skip-permissions \\\n354:   \"$(cat prompt.md)\" \\\n355:   </dev/null \\\n356:   > \"$LOG_DIR/iter-N-stdout.log\" \\\n357:   2> \"$LOG_DIR/iter-N-stderr.log\"\n358: ```\n359: \n360: This is the pattern enforced by the 4 `if_cli_opencode` blocks in the deep-research and deep-review YAML workflow files. Any new automation that dispatches opencode MUST follow it.\n361: \n362: ### Upstream\n363: \n364: The bug is in opencode v1.14.39. The fix would be: in the `run` subcommand entrypoint, check `process.stdin.isTTY` (or equivalent) and skip the stdin read in non-interactive mode — the message is already provided as a positional argument, so stdin is informational only. Until upstream patches this, `</dev/null` at every callsite is the workaround. File a bug report with opencode-ai/opencode if not already filed.\n365: \n366: ---\n367: \n368: ## 7. MEMORY HANDBACK\n369: \n370: cli-opencode dispatches that produce evidence for a Spec Kit Memory save MUST include the Memory Epilogue at the end of the prompt. The dispatched session adds `MEMORY_HANDBACK_START` / `MEMORY_HANDBACK_END` delimiters around a structured JSON payload that the calling AI extracts and feeds to `generate-context.js`.\n371: \n372: The full Memory Handback Protocol is shared with cli-claude-code and cli-opencode. See SKILL.md Section 4 (RULES) for the canonical 7-step procedure. The same JSON normalization (camelCase / snake_case aliases) and post-010 save gates apply.\n373: \n374: ---\n375: \n376: ## 8. RELATED RESOURCES\n377: \n378: - `./cli-reference.md` - Full subcommand and flag reference\n379: - `./opencode-tools.md` - Unique value props vs sibling cli-* skills\n380: - `./agent-delegation.md` - Agent routing matrix\n381: - `../assets/prompt-templates.md` - Copy-paste templates per use case\n382: - `../SKILL.md` - Skill entry point and smart router pseudocode\n\n(End of file - total 382 lines)\n</content>","metadata":{"preview":"---\ntitle: \"OpenCode CLI - Integration Patterns and Use Cases\"\ndescription: \"The three documented use cases for cli-opencode (external runtime to OpenCode, in-OpenCode parallel detached session, cross-AI orchestration handback) with copy-paste prompt templates, smart-router signals, and the self-invocation guard decision tree.\"\ntrigger_phrases:\n  - \"opencode integration patterns\"\n  - \"opencode self-invocation guard\"\n  - \"opencode parallel detached session\"\n  - \"opencode cross-ai handback\"\n  - \"opencode stdin dev null rule\"\n  - \"opencode run hang non-interactive\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.3.0.14\n---\n\n# OpenCode CLI - Integration Patterns\n\nHow cli-opencode positions itself relative to the three sibling cli-* skills, the three documented use cases (per ADR-002), the smart-router decision tree that picks between them, and the self-invocation guard that protects against circular dispatch (per ADR-001).\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/cli-external-orchestration/cli-opencode/references/integration-patterns.md","text":"---\ntitle: \"OpenCode CLI - Integration Patterns and Use Cases\"\ndescription: \"The three documented use cases for cli-opencode (external runtime to OpenCode, in-OpenCode parallel detached session, cross-AI orchestration handback) with copy-paste prompt templates, smart-router signals, and the self-invocation guard decision tree.\"\ntrigger_phrases:\n  - \"opencode integration patterns\"\n  - \"opencode self-invocation guard\"\n  - \"opencode parallel detached session\"\n  - \"opencode cross-ai handback\"\n  - \"opencode stdin dev null rule\"\n  - \"opencode run hang non-interactive\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.3.0.14\n---\n\n# OpenCode CLI - Integration Patterns\n\nHow cli-opencode positions itself relative to the three sibling cli-* skills, the three documented use cases (per ADR-002), the smart-router decision tree that picks between them, and the self-invocation guard that protects against circular dispatch (per ADR-001).\n\n---\n\n## 1. OVERVIEW\n\nThe three sibling cli-* skills exist because their target binaries are external runtimes — Claude Code, OpenCode, Copilot do not own this repo. OpenCode owns this repo. A naive \"delegate to opencode\" skill makes no sense for an in-OpenCode operator (it would create a circular dispatch).\n\ncli-opencode resolves this by documenting THREE orthogonal use cases. The smart router selects between them based on the calling AI's runtime context.\n\n| Use case | Calling runtime | Target | Self-invocation? |\n|----------|-----------------|--------|------------------|\n| 1. External runtime to OpenCode | Claude Code, OpenCode, Copilot, raw shell | OpenCode for full plugin / skill / MCP runtime | No |\n| 2. In-OpenCode parallel detached session | OpenCode itself (TUI / web / serve / acp) | New OpenCode session via `--share --port N` | No (different session id) |\n| 3. Cross-AI orchestration handback | OpenCode / Copilot | OpenCode for spec-kit specific workflows | No |\n\nThe cycle ADR-001 protects against is the operator inside OpenCode asking cli-opencode to \"delegate this exact prompt to OpenCode\" — that case is REFUSED at the routing layer.\n\n---\n\n## 2. USE CASE 1 — EXTERNAL RUNTIME TO OPENCODE\n\n### When to use\n\nThe calling AI is Claude Code, OpenCode, Copilot, or a raw shell. The task needs the project's full plugin / skill / MCP / Spec Kit Memory runtime — not just a raw model dispatch. Examples:\n\n- Run `memory_search` against the project's spec-doc database\n- Call Code Graph for semantic code search across the repo\n- Dispatch a `@deep-research` or `@deep-review` agent loop with externalized state\n- Run a sub-agent that needs Spec Kit Memory for continuity across iterations\n\n### Smart-router signal\n\nADR-001's detection signal does NOT trip (no OPENCODE_* env var, no opencode parent process, no live state lock).\n\n### Prompt template\n\n```text\nYou are dispatching from <calling-runtime> into a fresh OpenCode session via cli-opencode.\n\nGoal: <one-sentence goal>\n\nContext:\n- Spec folder: <path> (pre-approved, skip Gate 3)\n- Plugins / skills required: <list>\n- MCP tools required: <list>\n\nConstraints:\n- <list>\n\nSuccess criteria:\n- <list>\n\nMemory epilogue: include MEMORY_HANDBACK delimiters at the end of the response so the calling runtime can preserve context.\n```\n\n### Invocation shape\n\n```bash\nopencode run \\\n  --model deepseek/deepseek-v4-pro \\\n  --agent general \\\n  --variant high \\\n  --format json \\\n  --dir \"$REPO_ROOT\" \\\n  \"<prompt-from-template>\" 2>&1\n```\n\n### Why it matters\n\nThis is the canonical cross-AI dispatch path. It gives external runtimes a one-shot bridge into the project's full runtime without forcing the operator to leave their host session.\n\n---\n\n## 3. USE CASE 2 — IN-OPENCODE PARALLEL DETACHED SESSION\n\n### When to use\n\nThe operator is already inside an OpenCode session (TUI, web, serve, acp). They want a SEPARATE OpenCode session — not a continuation, not a fork — to run an ablation suite, a worker farm, or a parallel research sweep. The new session has its own session id, its own state directory, and an optional share URL.\n\n### Smart-router signal\n\nADR-001's detection signal trips (in-OpenCode runtime). The router checks the prompt for explicit parallel-session keywords:\n\n- \"parallel detached session\"\n- \"ablation suite\"\n- \"worker farm\"\n- \"parallel research\"\n- \"spawn detached\"\n- \"share URL\"\n\nIf at least one of these phrases appears AND the prompt does NOT request \"delegate this exact prompt\", the router permits the dispatch with `--share --port <N>`.\n\n### Prompt template\n\n```text\nYou are spawning a parallel detached OpenCode session for <purpose>.\n\nGoal: <one-sentence goal>\n\nContext:\n- Spec folder: <path> (pre-approved, skip Gate 3)\n- Iteration N of <total>\n- State file: <path>\n\nConstraints:\n- This session must NOT modify the parent session's state.\n- Write results to <state file path>.\n- Publish a share URL only if the operator confirmed (CHK-033).\n\nSuccess criteria:\n- <list>\n```\n\n### Invocation shape\n\n```bash\nopencode run \\\n  --share \\\n  --port 4096 \\\n  --model deepseek/deepseek-v4-pro \\\n  --agent deep-research \\\n  --variant high \\\n  --format json \\\n  --dir \"$REPO_ROOT\" \\\n  \"<prompt-from-template>\" 2>&1\n```\n\n### Why it matters\n\nParallel research, ablation studies, and worker farms need N concurrent sessions. Each must be independent. The detached pattern makes this possible without leaking state between sessions.\n\n### Operator confirmation for share URLs\n\nPer CHK-033, the calling AI MUST confirm with the operator before passing `--share`. The share URL exposes the session's contents to anyone with the URL, so it is opt-in.\n\n---\n\n## 4. USE CASE 3 — CROSS-AI ORCHESTRATION HANDBACK\n\n### When to use\n\nThe calling AI is a non-Anthropic CLI (OpenCode, Copilot). The task requires OpenCode-specific plugins or skills (e.g. spec-kit workflows, the Spec Kit Memory MCP database, the structural code graph). The non-Anthropic CLI cannot load the project's plugins on its own — cli-opencode is the documented bridge.\n\n### Smart-router signal\n\nADR-001's detection signal does NOT trip (the calling AI is OpenCode / Copilot, not OpenCode). The prompt mentions a project-specific subsystem:\n\n- \"spec kit\" / \"spec-kit\" / \"spec_kit\"\n- \"spec kit memory\"\n- \"code graph\"\n- \"skill advisor\"\n- \"session bootstrap\"\n\nWhen the calling AI is non-Anthropic AND a project-specific subsystem is named, this use case is selected over use case 1 (which is the more general path).\n\n### Prompt template\n\n```text\nYou are dispatching from <calling-runtime> into OpenCode for a spec-kit-specific workflow.\n\nGoal: <one-sentence goal>\n\nContext:\n- Spec folder: <path> (pre-approved, skip Gate 3)\n- Subsystem: <spec-kit / memory / code-graph / advisor>\n- Operation: <save / search / query / scan / validate>\n\nConstraints:\n- The OpenCode session MUST load the system-spec-kit skill for this dispatch.\n- All MCP calls go through the project's local MCP servers.\n\nSuccess criteria:\n- <list>\n\nMemory epilogue: include MEMORY_HANDBACK delimiters at the end so the calling runtime can preserve context.\n```\n\n### Invocation shape\n\n```bash\nopencode run \\\n  --model deepseek/deepseek-v4-pro \\\n  --agent general \\\n  --variant high \\\n  --format json \\\n  --dir \"$REPO_ROOT\" \\\n  \"<prompt-from-template>\" 2>&1\n```\n\nThe invocation shape is identical to use case 1 — the difference is the prompt content, which targets a project-specific subsystem.\n\n### Why it matters\n\nOpenCode and Copilot cannot load this project's plugin / skill / MCP runtime on their own. cli-opencode is the documented bridge that lets a OpenCode-led orchestration call into the project's spec-kit workflows without leaving the OpenCode session.\n\n---\n\n## 5. SMART-ROUTER DECISION TREE\n\nThe skill's smart router picks between the three use cases (or refuses) using this decision tree:\n\n```text\nINPUT: prompt + calling runtime\n                |\n                v\n[ADR-001 SELF-INVOCATION GUARD]\n- Layer 1: env var lookup (any OPENCODE_* env var present?)\n- Layer 2: process ancestry (opencode in parent process tree?)\n- Layer 3: best-effort lock-file probe (~/.opencode/state/<id>/lock present? -- heuristic, not guaranteed on every install)\n                |\n        +-------+-------+\n        |               |\n       NO              YES\n        |               |\n        v               v\n[CALLING RUNTIME]   [PROMPT KEYWORDS]\n        |               |\n   +----+----+    +-----+-----+\n   |         |    |           |\nAnthropic  Other  parallel   self-dispatch\n(Claude    (OpenCode words    only\nCode)      Copilot)        |           |\n   |         |             v           v\n   v         v        USE CASE 2   REFUSE\nUSE CASE  [PROJECT     (in-       (cycle —\n1         SUBSYSTEM    OpenCode   surface\n(external NAMED?]      parallel)  ADR-001\nto                      |          error)\nOpenCode)        +------+------+\n                 |             |\n                YES            NO\n                 |             |\n                 v             v\n             USE CASE 3     USE CASE 1\n             (cross-AI      (external\n             handback)      to OpenCode)\n```\n\n### Refusal message\n\nWhen the router hits the REFUSE leaf, it surfaces this exact message:\n\n```text\nERROR: cli-opencode self-invocation refused.\n\nYou are already inside OpenCode (signal: <env|ancestry|lockfile> tripped).\nAsking cli-opencode to delegate this exact prompt back to OpenCode would create\na circular dispatch.\n\nOptions:\n1. Use a sibling cli-* skill (cli-claude-code, cli-opencode)\n   to dispatch a different model.\n2. Open a fresh shell session (no OpenCode parent) and re-run from there.\n3. If you wanted a parallel detached session (different session id, separate\n   state directory), restate the request with explicit \"parallel detached\" /\n   \"ablation suite\" / \"worker farm\" / \"share URL\" keywords — that triggers\n   use case 2 instead of refusal.\n```\n\n---\n\n## 6. STDIN HANDLING — `</dev/null` IS REQUIRED FOR ALL NON-INTERACTIVE DISPATCH\n\n**`opencode run` reads stdin at startup before session creation (opencode v1.14.39).** Without an explicit closed stdin, ANY non-interactive automation that redirects stdout/stderr hangs forever at 0% CPU — even with a clean tool registry, valid model, and `--pure` set. This is the third independent root cause discovered during the 027-xce-research-based-refinement deep-research run on 2026-05-08; see `../CHANGELOG-2026-05-08-tool-name-regex-fix.md` §Fix 4 and memory `feedback_opencode_run_requires_dev_null_stdin.md`.\n\n### Hang symptom (diagnostic)\n\nIf you see ALL of:\n- Process at 0% CPU after >60s\n- `~/.local/share/opencode/log/<timestamp>.log` last entry is `service=snapshot prune=7.days cleanup`\n- 0 bytes stdout, 0 bytes stderr\n- No TCP connections to provider\n- 12-min timeout fires, exit code 124\n\n…it's the stdin-startup-deadlock. Append `</dev/null`.\n\n### Failure patterns (all hang)\n\n```bash\n# WRONG #1 — file redirect without </dev/null\nopencode run --model X \"<prompt>\" > stdout.log 2> stderr.log\n\n# WRONG #2 — combined redirect via tee\nopencode run --model X \"<prompt>\" 2>&1 | tee combined.log\n\n# WRONG #3 — background opencode in while-read loop without </dev/null\nwhile IFS= read -r line; do\n  opencode run --format json \"<prompt>\" > \"$LOG\" 2>&1 &\ndone < input.jsonl\n# Both bugs apply: stdin-startup-read AND silent loop-stdin consumption.\n```\n\n### Fix patterns (all work)\n\n```bash\n# RIGHT #1 — file redirect with </dev/null\nopencode run --model X \"<prompt>\" </dev/null > stdout.log 2> stderr.log\n\n# RIGHT #2 — combined redirect with explicit closed stdin via < /dev/null\nopencode run --model X \"<prompt>\" </dev/null 2>&1 | tee combined.log\n\n# RIGHT #3 — background in while-read loop\nwhile IFS= read -r line; do\n  opencode run --format json \"<prompt>\" > \"$LOG\" 2>&1 </dev/null &\ndone < input.jsonl\n\n# RIGHT #4 — foreground pipe to tail (works WITHOUT </dev/null because the empty pipe upstream provides EOF)\nopencode run --model X \"<prompt>\" 2>&1 | tail -15\n```\n\n### Why foreground `| tail` accidentally works\n\nWhen you run `opencode run \"...\" 2>&1 | tail`, the shell sets up a pipe BEFORE invoking opencode. opencode's stdin is NOT connected to your terminal — it's connected to the upstream pipe stage, which has no producer (the prompt is the positional argument, not piped via stdin). The shell closes that pipe immediately, opencode reads EOF, and startup proceeds. This is fragile — `2>&1 | tee combined.log` does NOT work because `tee` may keep the pipe open differently depending on shell + tee implementation. **Always use `</dev/null` explicitly** rather than relying on accidental pipe behavior.\n\n### Position rule\n\n`</dev/null` belongs:\n- AFTER the prompt positional argument\n- BEFORE the `> stdout 2> stderr` redirects (or anywhere on the command line — shell parses redirects independent of position, but right-after-prompt is conventional and easiest to spot during code review)\n\n```bash\n# canonical order\nopencode run --flags \"<prompt>\" </dev/null > stdout 2> stderr\n#                              ^^^^^^^^^^\n#                              stdin from /dev/null (immediate EOF)\n```\n\n### Background dispatch from automation scripts (the deep-research / deep-review pattern)\n\n```bash\ntimeout 720 opencode run \\\n  --model deepseek/deepseek-v4-pro \\\n  --variant high \\\n  --pure \\\n  --dangerously-skip-permissions \\\n  \"$(cat prompt.md)\" \\\n  </dev/null \\\n  > \"$LOG_DIR/iter-N-stdout.log\" \\\n  2> \"$LOG_DIR/iter-N-stderr.log\"\n```\n\nThis is the pattern enforced by the 4 `if_cli_opencode` blocks in the deep-research and deep-review YAML workflow files. Any new automation that dispatches opencode MUST follow it.\n\n### Upstream\n\nThe bug is in opencode v1.14.39. The fix would be: in the `run` subcommand entrypoint, check `process.stdin.isTTY` (or equivalent) and skip the stdin read in non-interactive mode — the message is already provided as a positional argument, so stdin is informational only. Until upstream patches this, `</dev/null` at every callsite is the workaround. File a bug report with opencode-ai/opencode if not already filed.\n\n---\n\n## 7. MEMORY HANDBACK\n\ncli-opencode dispatches that produce evidence for a Spec Kit Memory save MUST include the Memory Epilogue at the end of the prompt. The dispatched session adds `MEMORY_HANDBACK_START` / `MEMORY_HANDBACK_END` delimiters around a structured JSON payload that the calling AI extracts and feeds to `generate-context.js`.\n\nThe full Memory Handback Protocol is shared with cli-claude-code and cli-opencode. See SKILL.md Section 4 (RULES) for the canonical 7-step procedure. The same JSON normalization (camelCase / snake_case aliases) and post-010 save gates apply.\n\n---\n\n## 8. RELATED RESOURCES\n\n- `./cli-reference.md` - Full subcommand and flag reference\n- `./opencode-tools.md` - Unique value props vs sibling cli-* skills\n- `./agent-delegation.md` - Agent routing matrix\n- `../assets/prompt-templates.md` - Copy-paste templates per use case\n- `../SKILL.md` - Skill entry point and smart router pseudocode","lineStart":1,"lineEnd":382,"totalLines":382,"truncated":false}},"title":".opencode/skills/cli-external-orchestration/cli-opencode/references/integration-patterns.md","time":{"start":1784650185940,"end":1784650186001}},"metadata":{"openai":{"itemId":"fc_0faa9dc6e138ff0b016a5f99c9aed08191b38cc1d0da98ef54"}},"id":"prt_f8570bcad001Ax2p1d9ropwWyV","sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","messageID":"msg_f8570725b001DK0GOt6we0e4EV"}}
{"type":"tool_use","timestamp":1784650186017,"sessionID":"ses_07a91b76bffeQVZz6UB7PapKuO","part":{"type":"tool","tool":"grep","callID":"call_b0eqrQuoWYV2MpF5LhWpk3P4","state":{"status":"completed","input":{"pattern":"fanout_lineage_artifact_dir|FANOUT_LINEAGE_COMPLETE|parallel-detached|detached","path":".opencode/skills/system-deep-loop/runtime","include":"*.{cjs,ts,js}"},"output":"Found 20 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediation-review/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs:\n  Line 1004:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n\n  Line 1013:   const detachedIntro = lineage.kind === 'cli-opencode'\n\n  Line 1015:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n\n  Line 1016:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n\n  Line 1022:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n\n  Line 1035:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n  Line 1055:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n\n  Line 1072:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n\n  Line 1073:     ...detachedIntro,\n\n  Line 1079:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n\n  Line 1085:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n\n  Line 1123:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n  Line 1300:         detached: process.platform !== 'win32',\n\n  Line 1941:       // runtime before the first detached fan-out spawn. The lineage marker is added only\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0094-sk-design-017-remediati