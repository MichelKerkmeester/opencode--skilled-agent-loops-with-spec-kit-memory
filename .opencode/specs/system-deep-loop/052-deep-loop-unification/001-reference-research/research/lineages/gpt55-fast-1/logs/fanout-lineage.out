nd test config contain concrete old paths.\",\"evidence\":\".opencode/commands/deep/assets/deep_research_auto.yaml:64-77; .opencode/commands/doctor/_routes.yaml:100-110; .opencode/agents/orchestrate.md:180-206\"}],\"toolsUsed\":[\"Read\",\"Grep\"],\"sourcesQueried\":[\".opencode/commands/deep/assets/deep_research_auto.yaml:64-77\",\".opencode/commands/deep/assets/compiled/deep_research.contract.md:1-80\",\".opencode/commands/doctor/_routes.yaml:100-110\",\".opencode/agents/orchestrate.md:180-206\",\".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2570-2587\",\".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts:95-165\",\".opencode/skills/system-spec-kit/mcp_server/vitest.config.ts:15-22\",\".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json:7-18\",\".opencode/skills/deep-loop-runtime/references/integration_points.md:158-170\"],\"graphEvents\":[... (line truncated to 2000 chars)\n\n(End of file - total 4 lines)\n</content>","metadata":{"preview":"{\"type\":\"config\",\"topic\":\"Validate and stress-test the merge design for folding deep-loop-runtime into deep-loop-workflows as system-deep-loop: structural layout, bidirectional path-coupling repair, the system-spec-kit tooling-borrow, reference migration across commands/agents/READMEs/advisor-corpus, and whether fallback-router.ts should be wired for real GLM-5.2 to MiMo-v2.5-Pro fallback.\",\"maxIterations\":10,\"minIterations\":3,\"convergenceThreshold\":0.05,\"convergenceMode\":\"default\",\"minIdeaObservations\":2,\"resource_map_present\":false,\"resource_map\":{\"emit\":true},\"createdAt\":\"2026-07-08T04:57:16Z\",\"specFolder\":\".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research\",\"sessionId\":\"fanout-gpt55-fast-1-1783486518892-2qss01\",\"lineageLabel\":\"gpt55-fast-1\",\"nextRunAt\":null,\"remainingDelayMs\":null}\n{\"type\":\"event\",\"event\":\"spec_check_result\",\"folder_state\":\"spec-present-scope-locke