{"type":"tool_use","timestamp":1781756212028,"sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","part":{"type":"tool","tool":"read","callID":"call_vlwQ5aIkyNDhTIgv8OaFcazr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Batch Processor\n3: // ───────────────────────────────────────────────────────────────\n4: import { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n5: \n6: // ───────────────────────────────────────────────────────────────\n7: // 1. TYPES\n8: \n9: // ───────────────────────────────────────────────────────────────\n10: /** Retry options for batch processing */\n11: export interface RetryOptions {\n12:   maxRetries?: number;\n13:   retryDelay?: number;\n14:   // Early-abort hook. When it returns true the batch loop stops immediately,\n15:   // skipping every remaining batch AND its inter-batch pacing delay. Without\n16:   // this a cancelled long run still drains thousands of no-op batches (and their\n17:   // delays) before the caller's post-loop cancel check is reached.\n18:   shouldAbort?: () => boolean;\n19: }\n20: \n21: /** Default retry configuration */\n22: export interface RetryDefaults {\n23:   maxRetries: number;\n24:   retryDelay: number;\n25: }\n26: \n27: /** Error result from a failed retry operation */\n28: export interface RetryErrorResult {\n29:   error: string;\n30:   errorDetail?: string;\n31:   item: unknown;\n32:   retries_failed: boolean;\n33: }\n34: \n35: /** Processor function type */\n36: export type ItemProcessor<T, R> = (item: T) => Promise<R>;\n37: \n38: // ───────────────────────────────────────────────────────────────\n39: // 2. CONFIGURATION CONSTANTS\n40: \n41: // ───────────────────────────────────────────────────────────────\n42: // Single source of truth for batch config — imported from core/config.ts\n43: import { BATCH_SIZE, BATCH_DELAY_MS } from '../core/config.js';\n44: export { BATCH_SIZE, BATCH_DELAY_MS };\n45: export const MAX_BATCH_SIZE = 100;\n46: const COOPERATIVE_YIELD_EVERY = 50;\n47: \n48: /** Default retry configuration */\n49: export const DEFAULT_RETRY_OPTIONS: Readonly<RetryDefaults> = {\n50:   maxRetries: 2,\n51:   retryDelay: 1000\n52: } as const;\n53: \n54: function normalizeRetryValue(value: number | undefined, fallback: number): number {\n55:   if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {\n56:     return fallback;\n57:   }\n58:   return Math.floor(value);\n59: }\n60: \n61: function cooperativeYield(): Promise<void> {\n62:   return new Promise<void>(resolve => setImmediate(resolve));\n63: }\n64: \n65: // ───────────────────────────────────────────────────────────────\n66: // 3. RETRY LOGIC\n67: \n68: // ───────────────────────────────────────────────────────────────\n69: /**\n70:  * Process a single item with retry logic for transient failures.\n71:  * Uses exponential backoff strategy for retries.\n72:  */\n73: export async function processWithRetry<T, R>(\n74:   item: T,\n75:   processor: ItemProcessor<T, R>,\n76:   options: RetryOptions = {}\n77: ): Promise<R | RetryErrorResult> {\n78:   const maxRetries = normalizeRetryValue(options.maxRetries, DEFAULT_RETRY_OPTIONS.maxRetries);\n79:   const retryDelay = normalizeRetryValue(options.retryDelay, DEFAULT_RETRY_OPTIONS.retryDelay);\n80:   let last_error: Error | undefined;\n81: \n82:   for (let attempt = 0; attempt <= maxRetries; attempt++) {\n83:     try {\n84:       return await processor(item);\n85:     } catch (err: unknown) {\n86:       last_error = err instanceof Error ? err : new Error(String(err));\n87:       // Only retry transient errors\n88:       if (attempt < maxRetries && isTransientError(last_error)) {\n89:         const delay = retryDelay * (attempt + 1); // Exponential backoff\n90:         console.error(`[batch-retry] Attempt ${attempt + 1}/${maxRetries + 1} failed, retrying in ${delay}ms: ${last_error.message}`);\n91:         await new Promise<void>(r => setTimeout(r, delay));\n92:       } else if (attempt < maxRetries) {\n93:         // Non-transient error, don't retry\n94:         break;\n95:       }\n96:     }\n97:   }\n98:   if (!last_error) {\n99:     last_error = new Error('Retry loop exited without processor result');\n100:   }\n101: \n102:   return {\n103:     error: userFriendlyError(last_error),\n104:     errorDetail: last_error.message,\n105:     item,\n106:     retries_failed: true,\n107:   };\n108: }\n109: \n110: // ───────────────────────────────────────────────────────────────\n111: // 4. BATCH PROCESSING\n112: \n113: // ───────────────────────────────────────────────────────────────\n114: /**\n115:  * Process items in batches with concurrency control and retry logic.\n116:  * Provides controlled execution to prevent resource exhaustion.\n117:  *\n118:  * @throws {Error} If batchSize is not a positive finite integer.\n119:  * Validates batchSize BEFORE any processing to prevent\n120:  *   infinite loops (batchSize=0) or nonsensical iteration (NaN, negative,\n121:  *   Infinity, fractional values).\n122:  */\n123: export async function processBatches<T, R>(\n124:   items: T[],\n125:   processor: ItemProcessor<T, R>,\n126:   batchSize: number = BATCH_SIZE,\n127:   delayMs: number = BATCH_DELAY_MS,\n128:   retryOptions: RetryOptions = {}\n129: ): Promise<Array<R | RetryErrorResult>> {\n130:   // Validate batchSize before any processing.\n131:   // NaN <= 0 is false, so the original <= 0 check alone would miss NaN.\n132:   // Also reject Infinity and non-integer values for safety.\n133:   if (typeof batchSize !== 'number' || !Number.isFinite(batchSize) || batchSize <= 0 || batchSize !== Math.floor(batchSize)) {\n134:     throw new Error(`batchSize must be a positive integer, got: ${batchSize}`);\n135:   }\n136: \n137:   const effectiveBatchSize = Math.min(batchSize, MAX_BATCH_SIZE);\n138:   if (effectiveBatchSize !== batchSize) {\n139:     console.warn(\n140:       `[batch-processor] Clamped batch size ${batchSize} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n141:     );\n142:   }\n143: \n144:   const results: Array<R | RetryErrorResult> = [];\n145:   const totalBatches = Math.ceil(items.length / effectiveBatchSize);\n146:   let currentBatch = 0;\n147:   let processedSinceYield = 0;\n148: \n149:   for (let i = 0; i < items.length; i += effectiveBatchSize) {\n150:     if (retryOptions.shouldAbort?.()) break;\n151:     currentBatch++;\n152:     console.error(`[batch-processor] Processing batch ${currentBatch}/${totalBatches}`);\n153: \n154:     const batch = items.slice(i, i + effectiveBatchSize);\n155:     const batchResults = await Promise.all(\n156:       batch.map(async (item, index) => {\n157:         if (index > 0 && index % COOPERATIVE_YIELD_EVERY === 0) {\n158:           await cooperativeYield();\n159:         }\n160:         return processWithRetry(item, processor, retryOptions);\n161:       })\n162:     );\n163:     results.push(...batchResults);\n164:     processedSinceYield += batchResults.length;\n165: \n166:     if (processedSinceYield >= COOPERATIVE_YIELD_EVERY) {\n167:       await cooperativeYield();\n168:       processedSinceYield %= COOPERATIVE_YIELD_EVERY;\n169:     }\n170: \n171:     // Small delay between batches to prevent resource exhaustion\n172:     if (i + effectiveBatchSize < items.length && delayMs > 0) {\n173:       await new Promise<void>(resolve => setTimeout(resolve, delayMs));\n174:     }\n175:   }\n176: \n177:   return results;\n178: }\n179: \n180: /**\n181:  * Process items sequentially (one at a time) with retry logic.\n182:  * Use when order matters or for resource-constrained operations.\n183:  */\n184: export async function processSequentially<T, R>(\n185:   items: T[],\n186:   processor: ItemProcessor<T, R>,\n187:   retryOptions: RetryOptions = {}\n188: ): Promise<Array<R | RetryErrorResult>> {\n189:   const results: Array<R | RetryErrorResult> = [];\n190: \n191:   for (let i = 0; i < items.length; i++) {\n192:     console.error(`[batch-processor] Processing item ${i + 1}/${items.length}`);\n193:     const result = await processWithRetry(items[i], processor, retryOptions);\n194:     results.push(result);\n195:   }\n196: \n197:   return results;\n198: }\n199: \n200: /* ───────────────────────────────────────────────────────────────\n201:    5. (ESM exports above — no CommonJS module.exports needed)\n202:    ──────────────────────────────────────────────────────────────── */\n\n(End of file - total 202 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Batch Processor\n// ───────────────────────────────────────────────────────────────\nimport { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Retry options for batch processing */\nexport interface RetryOptions {\n  maxRetries?: number;\n  retryDelay?: number;\n  // Early-abort hook. When it returns true the batch loop stops immediately,\n  // skipping every remaining batch AND its inter-batch pacing delay. Without\n  // this a cancelled long run still drains thousands of no-op batches (and their\n  // delays) before the caller's post-loop cancel check is reached.\n  shouldAbort?: () => boolean;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Batch Processor\n// ───────────────────────────────────────────────────────────────\nimport { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Retry options for batch processing */\nexport interface RetryOptions {\n  maxRetries?: number;\n  retryDelay?: number;\n  // Early-abort hook. When it returns true the batch loop stops immediately,\n  // skipping every remaining batch AND its inter-batch pacing delay. Without\n  // this a cancelled long run still drains thousands of no-op batches (and their\n  // delays) before the caller's post-loop cancel check is reached.\n  shouldAbort?: () => boolean;\n}\n\n/** Default retry configuration */\nexport interface RetryDefaults {\n  maxRetries: number;\n  retryDelay: number;\n}\n\n/** Error result from a failed retry operation */\nexport interface RetryErrorResult {\n  error: string;\n  errorDetail?: string;\n  item: unknown;\n  retries_failed: boolean;\n}\n\n/** Processor function type */\nexport type ItemProcessor<T, R> = (item: T) => Promise<R>;\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONFIGURATION CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\n// Single source of truth for batch config — imported from core/config.ts\nimport { BATCH_SIZE, BATCH_DELAY_MS } from '../core/config.js';\nexport { BATCH_SIZE, BATCH_DELAY_MS };\nexport const MAX_BATCH_SIZE = 100;\nconst COOPERATIVE_YIELD_EVERY = 50;\n\n/** Default retry configuration */\nexport const DEFAULT_RETRY_OPTIONS: Readonly<RetryDefaults> = {\n  maxRetries: 2,\n  retryDelay: 1000\n} as const;\n\nfunction normalizeRetryValue(value: number | undefined, fallback: number): number {\n  if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {\n    return fallback;\n  }\n  return Math.floor(value);\n}\n\nfunction cooperativeYield(): Promise<void> {\n  return new Promise<void>(resolve => setImmediate(resolve));\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. RETRY LOGIC\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Process a single item with retry logic for transient failures.\n * Uses exponential backoff strategy for retries.\n */\nexport async function processWithRetry<T, R>(\n  item: T,\n  processor: ItemProcessor<T, R>,\n  options: RetryOptions = {}\n): Promise<R | RetryErrorResult> {\n  const maxRetries = normalizeRetryValue(options.maxRetries, DEFAULT_RETRY_OPTIONS.maxRetries);\n  const retryDelay = normalizeRetryValue(options.retryDelay, DEFAULT_RETRY_OPTIONS.retryDelay);\n  let last_error: Error | undefined;\n\n  for (let attempt = 0; attempt <= maxRetries; attempt++) {\n    try {\n      return await processor(item);\n    } catch (err: unknown) {\n      last_error = err instanceof Error ? err : new Error(String(err));\n      // Only retry transient errors\n      if (attempt < maxRetries && isTransientError(last_error)) {\n        const delay = retryDelay * (attempt + 1); // Exponential backoff\n        console.error(`[batch-retry] Attempt ${attempt + 1}/${maxRetries + 1} failed, retrying in ${delay}ms: ${last_error.message}`);\n        await new Promise<void>(r => setTimeout(r, delay));\n      } else if (attempt < maxRetries) {\n        // Non-transient error, don't retry\n        break;\n      }\n    }\n  }\n  if (!last_error) {\n    last_error = new Error('Retry loop exited without processor result');\n  }\n\n  return {\n    error: userFriendlyError(last_error),\n    errorDetail: last_error.message,\n    item,\n    retries_failed: true,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. BATCH PROCESSING\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Process items in batches with concurrency control and retry logic.\n * Provides controlled execution to prevent resource exhaustion.\n *\n * @throws {Error} If batchSize is not a positive finite integer.\n * Validates batchSize BEFORE any processing to prevent\n *   infinite loops (batchSize=0) or nonsensical iteration (NaN, negative,\n *   Infinity, fractional values).\n */\nexport async function processBatches<T, R>(\n  items: T[],\n  processor: ItemProcessor<T, R>,\n  batchSize: number = BATCH_SIZE,\n  delayMs: number = BATCH_DELAY_MS,\n  retryOptions: RetryOptions = {}\n): Promise<Array<R | RetryErrorResult>> {\n  // Validate batchSize before any processing.\n  // NaN <= 0 is false, so the original <= 0 check alone would miss NaN.\n  // Also reject Infinity and non-integer values for safety.\n  if (typeof batchSize !== 'number' || !Number.isFinite(batchSize) || batchSize <= 0 || batchSize !== Math.floor(batchSize)) {\n    throw new Error(`batchSize must be a positive integer, got: ${batchSize}`);\n  }\n\n  const effectiveBatchSize = Math.min(batchSize, MAX_BATCH_SIZE);\n  if (effectiveBatchSize !== batchSize) {\n    console.warn(\n      `[batch-processor] Clamped batch size ${batchSize} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n    );\n  }\n\n  const results: Array<R | RetryErrorResult> = [];\n  const totalBatches = Math.ceil(items.length / effectiveBatchSize);\n  let currentBatch = 0;\n  let processedSinceYield = 0;\n\n  for (let i = 0; i < items.length; i += effectiveBatchSize) {\n    if (retryOptions.shouldAbort?.()) break;\n    currentBatch++;\n    console.error(`[batch-processor] Processing batch ${currentBatch}/${totalBatches}`);\n\n    const batch = items.slice(i, i + effectiveBatchSize);\n    const batchResults = await Promise.all(\n      batch.map(async (item, index) => {\n        if (index > 0 && index % COOPERATIVE_YIELD_EVERY === 0) {\n          await cooperativeYield();\n        }\n        return processWithRetry(item, processor, retryOptions);\n      })\n    );\n    results.push(...batchResults);\n    processedSinceYield += batchResults.length;\n\n    if (processedSinceYield >= COOPERATIVE_YIELD_EVERY) {\n      await cooperativeYield();\n      processedSinceYield %= COOPERATIVE_YIELD_EVERY;\n    }\n\n    // Small delay between batches to prevent resource exhaustion\n    if (i + effectiveBatchSize < items.length && delayMs > 0) {\n      await new Promise<void>(resolve => setTimeout(resolve, delayMs));\n    }\n  }\n\n  return results;\n}\n\n/**\n * Process items sequentially (one at a time) with retry logic.\n * Use when order matters or for resource-constrained operations.\n */\nexport async function processSequentially<T, R>(\n  items: T[],\n  processor: ItemProcessor<T, R>,\n  retryOptions: RetryOptions = {}\n): Promise<Array<R | RetryErrorResult>> {\n  const results: Array<R | RetryErrorResult> = [];\n\n  for (let i = 0; i < items.length; i++) {\n    console.error(`[batch-processor] Processing item ${i + 1}/${items.length}`);\n    const result = await processWithRetry(items[i], processor, retryOptions);\n    results.push(result);\n  }\n\n  return results;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. (ESM exports above — no CommonJS module.exports needed)\n   ──────────────────────────────────────────────────────────────── */","lineStart":1,"lineEnd":202,"totalLines":202,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","time":{"start":1781756212018,"end":1781756212028}},"metadata":{"openai":{"itemId":"fc_0a25edc1aa27f4c8016a337133e8a081918d39519e08670083"}},"id":"prt_ed8f232ef001YXOGHp6KZD2ge5","sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","messageID":"msg_ed8f2156e001Y19HHvIGv27W3v"}}
{"type":"tool_use","timestamp":1781756212035,"sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","part":{"type":"tool","tool":"read","callID":"call_GfDRPCQ0LlQcBUSGynEVQMia","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","offset":1,"limit":430},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance Job Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Kind-agnostic persisted job lifecycle: jobId, state record, progress\n5: // counters, error capture+truncation, cancel flag, and crash-recovery\n6: // reset. Shared lifecycle/registry across long-running maintenance jobs.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import { randomBytes } from 'node:crypto';\n13: \n14: import { requireDb, toErrorMessage } from '../../utils/index.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: export type MaintenanceJobKind = 'ingest' | 'index_scan';\n22: \n23: export type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n24: \n25: export interface JobError {\n26:   source: string;\n27:   message: string;\n28:   timestamp: string;\n29: }\n30: \n31: export interface MaintenanceJob {\n32:   id: string;\n33:   kind: MaintenanceJobKind;\n34:   state: JobLifecycleState;\n35:   phase: string | null;\n36:   progressTotal: number;\n37:   progressProcessed: number;\n38:   cancelRequested: boolean;\n39:   errors: JobError[];\n40:   result: unknown | null;\n41:   payload: unknown | null;\n42:   createdAt: string;\n43:   updatedAt: string;\n44: }\n45: \n46: interface MaintenanceJobRow {\n47:   id: string;\n48:   kind: string;\n49:   state: string;\n50:   phase: string | null;\n51:   progress_total: number;\n52:   progress_processed: number;\n53:   cancel_requested: number;\n54:   errors_json: string;\n55:   result_json: string | null;\n56:   payload_json: string | null;\n57:   created_at: string;\n58:   updated_at: string;\n59: }\n60: \n61: /* ───────────────────────────────────────────────────────────────\n62:    3. CONSTANTS\n63: ──────────────────────────────────────────────────────────────── */\n64: \n65: export const MAX_STORED_ERRORS = 50;\n66: \n67: const TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n68: \n69: // In-process mirror of cancel_requested. A running job polls this from a hot loop\n70: // to decide whether to stop, avoiding a DB SELECT on the single shared connection\n71: // every check. The cancel request runs in this same process, so the Set is\n72: // authoritative for an in-flight run; the durable column still backs status\n73: // responses and crash recovery. Entries are cleared when a job reaches a terminal\n74: // state so the Set cannot grow without bound across many jobs.\n75: const cancelledJobIds = new Set<string>();\n76: \n77: const ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n78:   queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n79:   running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n80:   complete: new Set<JobLifecycleState>([]),\n81:   failed: new Set<JobLifecycleState>([]),\n82:   cancelled: new Set<JobLifecycleState>([]),\n83: };\n84: \n85: // URL-safe 12-char identifier without a UUID dependency.\n86: const NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    4. HELPERS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: function nowIso(): string {\n93:   return new Date().toISOString();\n94: }\n95: \n96: function isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n97:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n98: }\n99: \n100: function parseJson<T>(value: string | null | undefined, fallback: T): T {\n101:   if (value === null || value === undefined) return fallback;\n102:   try {\n103:     return JSON.parse(value) as T;\n104:   } catch (_error: unknown) {\n105:     return fallback;\n106:   }\n107: }\n108: \n109: function parseJobErrors(value: string | null | undefined): JobError[] {\n110:   const parsed = parseJson<unknown>(value, []);\n111:   return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n112: }\n113: \n114: function mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n115:   if (!row) return null;\n116:   return {\n117:     id: row.id,\n118:     kind: row.kind as MaintenanceJobKind,\n119:     state: row.state as JobLifecycleState,\n120:     phase: row.phase,\n121:     progressTotal: row.progress_total,\n122:     progressProcessed: row.progress_processed,\n123:     cancelRequested: row.cancel_requested === 1,\n124:     errors: parseJobErrors(row.errors_json),\n125:     result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n126:     payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n127:     createdAt: row.created_at,\n128:     updatedAt: row.updated_at,\n129:   };\n130: }\n131: \n132: const SELECT_COLUMNS =\n133:   'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n134: \n135: /* ───────────────────────────────────────────────────────────────\n136:    5. SCHEMA\n137: ──────────────────────────────────────────────────────────────── */\n138: \n139: export function ensureMaintenanceJobsTable(): void {\n140:   const db = requireDb();\n141:   db.exec(`\n142:     CREATE TABLE IF NOT EXISTS maintenance_jobs (\n143:       id TEXT PRIMARY KEY,\n144:       kind TEXT NOT NULL,\n145:       state TEXT NOT NULL,\n146:       phase TEXT,\n147:       progress_total INTEGER NOT NULL DEFAULT 0,\n148:       progress_processed INTEGER NOT NULL DEFAULT 0,\n149:       cancel_requested INTEGER NOT NULL DEFAULT 0,\n150:       errors_json TEXT NOT NULL DEFAULT '[]',\n151:       result_json TEXT,\n152:       payload_json TEXT,\n153:       created_at TEXT NOT NULL,\n154:       updated_at TEXT NOT NULL\n155:     )\n156:   `);\n157:   db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n158: }\n159: \n160: /* ───────────────────────────────────────────────────────────────\n161:    6. IDENTIFIERS\n162: ──────────────────────────────────────────────────────────────── */\n163: \n164: export function createJobId(): string {\n165:   const bytes = randomBytes(12);\n166:   let id = '';\n167:   for (let i = 0; i < 12; i++) {\n168:     id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n169:   }\n170:   return `job_${id}`;\n171: }\n172: \n173: /* ───────────────────────────────────────────────────────────────\n174:    7. LIFECYCLE\n175: ──────────────────────────────────────────────────────────────── */\n176: \n177: export async function createMaintenanceJob(args: {\n178:   id: string;\n179:   kind: MaintenanceJobKind;\n180:   payload?: unknown;\n181: }): Promise<MaintenanceJob> {\n182:   const db = requireDb();\n183:   const timestamp = nowIso();\n184:   const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n185: \n186:   await withBusyRetry(() =>\n187:     db.prepare(`\n188:       INSERT INTO maintenance_jobs (\n189:         id, kind, state, phase, progress_total, progress_processed,\n190:         cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n191:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n192:     `).run(\n193:       args.id,\n194:       args.kind,\n195:       'queued',\n196:       null,\n197:       0,\n198:       0,\n199:       0,\n200:       '[]',\n201:       null,\n202:       payloadJson,\n203:       timestamp,\n204:       timestamp,\n205:     )\n206:   );\n207: \n208:   return {\n209:     id: args.id,\n210:     kind: args.kind,\n211:     state: 'queued',\n212:     phase: null,\n213:     progressTotal: 0,\n214:     progressProcessed: 0,\n215:     cancelRequested: false,\n216:     errors: [],\n217:     result: null,\n218:     payload: args.payload ?? null,\n219:     createdAt: timestamp,\n220:     updatedAt: timestamp,\n221:   };\n222: }\n223: \n224: export function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n225:   const db = requireDb();\n226:   const row = db.prepare(`\n227:     SELECT ${SELECT_COLUMNS}\n228:     FROM maintenance_jobs\n229:     WHERE id = ?\n230:   `).get(jobId) as MaintenanceJobRow | undefined;\n231:   return mapRowToJob(row);\n232: }\n233: \n234: export async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n235:   const db = requireDb();\n236:   const current = getMaintenanceJob(jobId);\n237:   if (!current) {\n238:     throw new Error(`Maintenance job not found: ${jobId}`);\n239:   }\n240: \n241:   if (current.state === nextState) {\n242:     return current;\n243:   }\n244: \n245:   if (!isTransitionAllowed(current.state, nextState)) {\n246:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n247:   }\n248: \n249:   const updatedAt = nowIso();\n250:   const result = await withBusyRetry(() =>\n251:     db.prepare(`\n252:       UPDATE maintenance_jobs\n253:       SET state = ?, updated_at = ?\n254:       WHERE id = ? AND state = ?\n255:     `).run(nextState, updatedAt, jobId, current.state)\n256:   );\n257: \n258:   if ((result as { changes: number }).changes === 0) {\n259:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n260:   }\n261: \n262:   // Every terminal transition must release the in-process cancel mirror, not just\n263:   // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n264:   // routes through setJobState('failed'); without this the job-id would leak,\n265:   // contradicting the cancelledJobIds bounded-growth guarantee.\n266:   if (isTerminalJobState(nextState)) {\n267:     cancelledJobIds.delete(jobId);\n268:   }\n269: \n270:   return { ...current, state: nextState, updatedAt };\n271: }\n272: \n273: export async function setJobPhase(jobId: string, phase: string): Promise<void> {\n274:   const db = requireDb();\n275:   await withBusyRetry(() =>\n276:     db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n277:       .run(phase, nowIso(), jobId)\n278:   );\n279: }\n280: \n281: export async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n282:   const db = requireDb();\n283:   const processed = Math.max(0, Math.trunc(progress.processed));\n284:   const total = Math.max(0, Math.trunc(progress.total));\n285:   await withBusyRetry(() =>\n286:     db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n287:       .run(processed, total, nowIso(), jobId)\n288:   );\n289: }\n290: \n291: export async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n292:   const db = requireDb();\n293:   const current = getMaintenanceJob(jobId);\n294:   if (!current) {\n295:     throw new Error(`Maintenance job not found: ${jobId}`);\n296:   }\n297: \n298:   let errors: JobError[] = [\n299:     ...current.errors,\n300:     { source, message: toErrorMessage(error), timestamp: nowIso() },\n301:   ];\n302: \n303:   if (errors.length > MAX_STORED_ERRORS) {\n304:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n305:     const trimmedCount = errors.length - tailLength;\n306:     const truncationNotice: JobError = {\n307:       source: '__job__',\n308:       message: `error log truncated (${trimmedCount} older entries removed)`,\n309:       timestamp: nowIso(),\n310:     };\n311:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n312:     errors = [truncationNotice, ...truncatedTail];\n313:   }\n314: \n315:   const updatedAt = nowIso();\n316:   await withBusyRetry(() =>\n317:     db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n318:       .run(JSON.stringify(errors), updatedAt, jobId)\n319:   );\n320: \n321:   return { ...current, errors, updatedAt };\n322: }\n323: \n324: export async function requestCancel(jobId: string): Promise<void> {\n325:   // Set the in-process flag first so a running loop observes the cancel even if the\n326:   // durable write contends on the shared connection.\n327:   cancelledJobIds.add(jobId);\n328:   const db = requireDb();\n329:   await withBusyRetry(() =>\n330:     db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n331:       .run(nowIso(), jobId)\n332:   );\n333: }\n334: \n335: // Synchronous so the runner can poll it inline at batch/phase boundaries.\n336: export function isCancelRequested(jobId: string): boolean {\n337:   const db = requireDb();\n338:   const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n339:     .get(jobId) as { cancel_requested?: number } | undefined;\n340:   return !!row && row.cancel_requested === 1;\n341: }\n342: \n343: // Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n344: // mirror, so it is safe to call thousands of times during a scan without touching\n345: // the shared SQLite connection. Use isCancelRequested when durability across the\n346: // in-memory boundary matters (status responses, post-restart).\n347: export function isCancelRequestedFast(jobId: string): boolean {\n348:   return cancelledJobIds.has(jobId);\n349: }\n350: \n351: export async function completeJob(\n352:   jobId: string,\n353:   options: { state: JobLifecycleState; result?: unknown },\n354: ): Promise<MaintenanceJob> {\n355:   const db = requireDb();\n356:   const current = getMaintenanceJob(jobId);\n357:   if (!current) {\n358:     throw new Error(`Maintenance job not found: ${jobId}`);\n359:   }\n360: \n361:   if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n362:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n363:   }\n364: \n365:   const updatedAt = nowIso();\n366:   const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n367:   const completion = await withBusyRetry(() =>\n368:     db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n369:       .run(options.state, resultJson, updatedAt, jobId, current.state)\n370:   );\n371:   if (completion.changes === 0) {\n372:     // The row moved out from under the read-then-check; refuse to clobber a state\n373:     // another writer set rather than overwriting it from a stale read.\n374:     throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n375:   }\n376: \n377:   cancelledJobIds.delete(jobId);\n378:   return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n379: }\n380: \n381: // Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n382: // re-run fresh, so they are reset to 'failed' rather than re-enqueued.\n383: export function resetRunningJobsForKind(\n384:   kind: MaintenanceJobKind,\n385:   // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n386:   // target keeps a caller from persisting an illegal transition past the guard.\n387:   options: { to: 'failed' | 'cancelled' },\n388: ): string[] {\n389:   const db = requireDb();\n390:   const rows = db.prepare(`\n391:     SELECT id FROM maintenance_jobs\n392:     WHERE kind = ? AND state IN ('queued', 'running')\n393:   `).all(kind) as Array<{ id: string }>;\n394: \n395:   if (rows.length === 0) return [];\n396: \n397:   withBusyRetrySync(() =>\n398:     db.prepare(`\n399:       UPDATE maintenance_jobs\n400:       SET state = ?, updated_at = ?\n401:       WHERE kind = ? AND state IN ('queued', 'running')\n402:     `).run(options.to, nowIso(), kind)\n403:   );\n404: \n405:   for (const row of rows) {\n406:     cancelledJobIds.delete(row.id);\n407:   }\n408:   return rows.map((r) => r.id);\n409: }\n410: \n411: export function isTerminalJobState(state: JobLifecycleState): boolean {\n412:   return TERMINAL_STATES.has(state);\n413: }\n\n(End of file - total 413 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\nexport type MaintenanceJobKind = 'ingest' | 'index_scan';\n\nexport type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n\nexport interface JobError {\n  source: string;\n  message: string;\n  timestamp: string;\n}\n\nexport interface MaintenanceJob {\n  id: string;\n  kind: MaintenanceJobKind;\n  state: JobLifecycleState;\n  phase: string | null;\n  progressTotal: number;\n  progressProcessed: number;\n  cancelRequested: boolean;\n  errors: JobError[];\n  result: unknown | null;\n  payload: unknown | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\ninterface MaintenanceJobRow {\n  id: string;\n  kind: string;\n  state: string;\n  phase: string | null;\n  progress_total: number;\n  progress_processed: number;\n  cancel_requested: number;\n  errors_json: string;\n  result_json: string | null;\n  payload_json: string | null;\n  created_at: string;\n  updated_at: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nexport const MAX_STORED_ERRORS = 50;\n\nconst TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n\n// In-process mirror of cancel_requested. A running job polls this from a hot loop\n// to decide whether to stop, avoiding a DB SELECT on the single shared connection\n// every check. The cancel request runs in this same process, so the Set is\n// authoritative for an in-flight run; the durable column still backs status\n// responses and crash recovery. Entries are cleared when a job reaches a terminal\n// state so the Set cannot grow without bound across many jobs.\nconst cancelledJobIds = new Set<string>();\n\nconst ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n  queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n  running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n  complete: new Set<JobLifecycleState>([]),\n  failed: new Set<JobLifecycleState>([]),\n  cancelled: new Set<JobLifecycleState>([]),\n};\n\n// URL-safe 12-char identifier without a UUID dependency.\nconst NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\nfunction parseJson<T>(value: string | null | undefined, fallback: T): T {\n  if (value === null || value === undefined) return fallback;\n  try {\n    return JSON.parse(value) as T;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseJobErrors(value: string | null | undefined): JobError[] {\n  const parsed = parseJson<unknown>(value, []);\n  return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n}\n\nfunction mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    kind: row.kind as MaintenanceJobKind,\n    state: row.state as JobLifecycleState,\n    phase: row.phase,\n    progressTotal: row.progress_total,\n    progressProcessed: row.progress_processed,\n    cancelRequested: row.cancel_requested === 1,\n    errors: parseJobErrors(row.errors_json),\n    result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n    payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nconst SELECT_COLUMNS =\n  'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n\n/* ───────────────────────────────────────────────────────────────\n   5. SCHEMA\n──────────────────────────────────────────────────────────────── */\n\nexport function ensureMaintenanceJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS maintenance_jobs (\n      id TEXT PRIMARY KEY,\n      kind TEXT NOT NULL,\n      state TEXT NOT NULL,\n      phase TEXT,\n      progress_total INTEGER NOT NULL DEFAULT 0,\n      progress_processed INTEGER NOT NULL DEFAULT 0,\n      cancel_requested INTEGER NOT NULL DEFAULT 0,\n      errors_json TEXT NOT NULL DEFAULT '[]',\n      result_json TEXT,\n      payload_json TEXT,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL\n    )\n  `);\n  db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. IDENTIFIERS\n──────────────────────────────────────────────────────────────── */\n\nexport function createJobId(): string {\n  const bytes = randomBytes(12);\n  let id = '';\n  for (let i = 0; i < 12; i++) {\n    id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n  }\n  return `job_${id}`;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LIFECYCLE\n──────────────────────────────────────────────────────────────── */\n\nexport async function createMaintenanceJob(args: {\n  id: string;\n  kind: MaintenanceJobKind;\n  payload?: unknown;\n}): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO maintenance_jobs (\n        id, kind, state, phase, progress_total, progress_processed,\n        cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      args.kind,\n      'queued',\n      null,\n      0,\n      0,\n      0,\n      '[]',\n      null,\n      payloadJson,\n      timestamp,\n      timestamp,\n    )\n  );\n\n  return {\n    id: args.id,\n    kind: args.kind,\n    state: 'queued',\n    phase: null,\n    progressTotal: 0,\n    progressProcessed: 0,\n    cancelRequested: false,\n    errors: [],\n    result: null,\n    payload: args.payload ?? null,\n    createdAt: timestamp,\n    updatedAt: timestamp,\n  };\n}\n\nexport function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n  const db = requireDb();\n  const row = db.prepare(`\n    SELECT ${SELECT_COLUMNS}\n    FROM maintenance_jobs\n    WHERE id = ?\n  `).get(jobId) as MaintenanceJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nexport async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  // Every terminal transition must release the in-process cancel mirror, not just\n  // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n  // routes through setJobState('failed'); without this the job-id would leak,\n  // contradicting the cancelledJobIds bounded-growth guarantee.\n  if (isTerminalJobState(nextState)) {\n    cancelledJobIds.delete(jobId);\n  }\n\n  return { ...current, state: nextState, updatedAt };\n}\n\nexport async function setJobPhase(jobId: string, phase: string): Promise<void> {\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n      .run(phase, nowIso(), jobId)\n  );\n}\n\nexport async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n  const db = requireDb();\n  const processed = Math.max(0, Math.trunc(progress.processed));\n  const total = Math.max(0, Math.trunc(progress.total));\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n      .run(processed, total, nowIso(), jobId)\n  );\n}\n\nexport async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  let errors: JobError[] = [\n    ...current.errors,\n    { source, message: toErrorMessage(error), timestamp: nowIso() },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: JobError = {\n      source: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n      .run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return { ...current, errors, updatedAt };\n}\n\nexport async function requestCancel(jobId: string): Promise<void> {\n  // Set the in-process flag first so a running loop observes the cancel even if the\n  // durable write contends on the shared connection.\n  cancelledJobIds.add(jobId);\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n      .run(nowIso(), jobId)\n  );\n}\n\n// Synchronous so the runner can poll it inline at batch/phase boundaries.\nexport function isCancelRequested(jobId: string): boolean {\n  const db = requireDb();\n  const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n    .get(jobId) as { cancel_requested?: number } | undefined;\n  return !!row && row.cancel_requested === 1;\n}\n\n// Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n// mirror, so it is safe to call thousands of times during a scan without touching\n// the shared SQLite connection. Use isCancelRequested when durability across the\n// in-memory boundary matters (status responses, post-restart).\nexport function isCancelRequestedFast(jobId: string): boolean {\n  return cancelledJobIds.has(jobId);\n}\n\nexport async function completeJob(\n  jobId: string,\n  options: { state: JobLifecycleState; result?: unknown },\n): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n  }\n\n  const updatedAt = nowIso();\n  const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n  const completion = await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n      .run(options.state, resultJson, updatedAt, jobId, current.state)\n  );\n  if (completion.changes === 0) {\n    // The row moved out from under the read-then-check; refuse to clobber a state\n    // another writer set rather than overwriting it from a stale read.\n    throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n  }\n\n  cancelledJobIds.delete(jobId);\n  return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n}\n\n// Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n// re-run fresh, so they are reset to 'failed' rather than re-enqueued.\nexport function resetRunningJobsForKind(\n  kind: MaintenanceJobKind,\n  // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n  // target keeps a caller from persisting an illegal transition past the guard.\n  options: { to: 'failed' | 'cancelled' },\n): string[] {\n  const db = requireDb();\n  const rows = db.prepare(`\n    SELECT id FROM maintenance_jobs\n    WHERE kind = ? AND state IN ('queued', 'running')\n  `).all(kind) as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE kind = ? AND state IN ('queued', 'running')\n    `).run(options.to, nowIso(), kind)\n  );\n\n  for (const row of rows) {\n    cancelledJobIds.delete(row.id);\n  }\n  return rows.map((r) => r.id);\n}\n\nexport function isTerminalJobState(state: JobLifecycleState): boolean {\n  return TERMINAL_STATES.has(state);\n}","lineStart":1,"lineEnd":413,"totalLines":413,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","time":{"start":1781756212032,"end":1781756212034}},"metadata":{"openai":{"itemId":"fc_0a25edc1aa27f4c8016a337133e8ac8191a993919682e5f22a"}},"id":"prt_ed8f23339001mxPClZijOPf84H","sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","messageID":"msg_ed8f2156e001Y19HHvIGv27W3v"}}
{"type":"tool_use","timestamp":1781756212064,"sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","part":{"type":"tool","tool":"read","callID":"call_vfAQS6uZ72z9jwNisg6FvOAv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: Background index scan dispatch + status/cancel handlers\n3: // ───────────────────────────────────────────────────────────────\n4: import { beforeEach, describe, expect, it, vi } from 'vitest';\n5: import { setTimeout as delay } from 'node:timers/promises';\n6: \n7: // ──────────────────────────────────────────────────────────────\n8: // 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n9: // ──────────────────────────────────────────────────────────────\n10: \n11: const mocks = vi.hoisted(() => ({\n12:   mockAcquireIndexScanLease: vi.fn(),\n13:   mockCompleteIndexScanLease: vi.fn(),\n14:   mockCheckDatabaseUpdated: vi.fn(),\n15:   mockProcessBatches: vi.fn(),\n16:   mockFindSpecDocuments: vi.fn((): string[] => []),\n17:   mockFindConstitutionalFiles: vi.fn((): string[] => []),\n18:   mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n19:   mockRequireDb: vi.fn(() => ({\n20:     prepare: vi.fn(() => ({\n21:       all: vi.fn(() => []),\n22:       get: vi.fn(() => undefined),\n23:     })),\n24:   })),\n25:   mockCategorizeFilesForIndexing: vi.fn((files: string[]) => ({\n26:     toIndex: files,\n27:     toUpdate: [] as string[],\n28:     toSkip: [] as string[],\n29:     toDelete: [] as string[],\n30:   })),\n31:   mockBatchUpdateMtimes: vi.fn(() => ({ updated: 0 })),\n3