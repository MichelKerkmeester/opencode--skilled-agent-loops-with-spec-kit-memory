 function runJob(db: Database.Database, jobId: string): Promise<void> {\n482:   const dbPath = getDatabasePath(db);\n483:   let jobDb = db;\n484:   if (getRestoreBarrierStatus()) {\n485:     scheduleJobAfterRestore(jobId, dbPath);\n486:     return;\n487:   }\n488:   const resolveJobDb = (): Database.Database => {\n489:     const barrierStatus = getRestoreBarrierStatus();\n\n(Showing lines 440-489 of 821. Use offset=490 to continue.)\n</content>","metadata":{"preview":"    try {\n      sqliteVec.load(shard);\n    } catch (_err) {\n      vecAvailable = false;\n    }\n\n    ensureShardSchema(shard, profile, tableName);\n\n    if (vecAvailable) {\n      shard.exec(`\n        CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n          embedding FLOAT[${profile.dim}]\n        )\n      `);\n    }\n\n    writeVectors(shard, tableName, rows, embeddings);\n    if (vecAvailable) {\n      writeVectorsToKnn(shard, rows, embeddings);\n    }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","text":"    try {\n      sqliteVec.load(shard);\n    } catch (_err) {\n      vecAvailable = false;\n    }\n\n    ensureShardSchema(shard, profile, tableName);\n\n    if (vecAvailable) {\n      shard.exec(`\n        CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n          embedding FLOAT[${profile.dim}]\n        )\n      `);\n    }\n\n    writeVectors(shard, tableName, rows, embeddings);\n    if (vecAvailable) {\n      writeVectorsToKnn(shard, rows, embeddings);\n    }\n  } finally {\n    // WAL-durability: flush + TRUNCATE the shard WAL before close so the shard file is\n    // consistent at rest with an empty WAL — mirrors close_db's corruption-prevention.\n    // better-sqlite3 .close() only does a passive checkpoint; an abrupt later kill could otherwise\n    // corrupt un-checkpointed shard frames (vec0 / FTS segment writes). Best-effort; never block close.\n    new BetterSqliteMaintenance(shard).checkpoint({ mode: 'truncate' });\n    shard.close();\n  }\n}\n\nfunction enqueueJob(db: Database.Database, jobId: string): void {\n  if (runningJobs.has(jobId)) {\n    return;\n  }\n\n  runningJobs.add(jobId);\n  void runJob(db, jobId).finally(() => {\n    runningJobs.delete(jobId);\n  });\n}\n\nasync function runJob(db: Database.Database, jobId: string): Promise<void> {\n  const dbPath = getDatabasePath(db);\n  let jobDb = db;\n  if (getRestoreBarrierStatus()) {\n    scheduleJobAfterRestore(jobId, dbPath);\n    return;\n  }\n  const resolveJobDb = (): Database.Database => {\n    const barrierStatus = getRestoreBarrierStatus();","lineStart":440,"lineEnd":489,"totalLines":821,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","time":{"start":1781144204119,"end":1781144204122}},"metadata":{"openai":{"itemId":"fc_0855f74cea9e2624016a2a1a8c02e48191803e3385837387d8"}},"id":"prt_eb477b3560018wItHbVMU9NXrK","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477917c001svZdX4mVh5wPSf"}}
