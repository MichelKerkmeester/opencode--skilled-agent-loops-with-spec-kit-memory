{"type":"tool_use","timestamp":1784188289162,"sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","part":{"type":"tool","tool":"read","callID":"call_b4c1671732224717acd34692","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/_routes.yaml"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/_routes.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DOCTOR ROUTER — CANONICAL ROUTE MANIFEST\n3: # ─────────────────────────────────────────────────────────────────\n4: # Source of truth for /doctor <target> dispatch.\n5: # Read by: .opencode/commands/doctor/speckit.md (the router)\n6: # Validated by: .opencode/commands/doctor/scripts/route-validate.sh\n7: # Consumed by: NOT currently harvested by either Skill Advisor implementation.\n8: #   Both harvesters (Python skill_advisor.py:810-871 _DOC_HARVEST_SUBDIRS =\n9: #   (\"references\",\"assets\") rooted at SKILLS_DIR; TS doc-frontmatter.ts:23)\n10: #   walk only .opencode/skills/*/{references,assets}/*.md frontmatter — a\n11: #   .yaml file under .opencode/commands/doctor/ is out of scope by both file\n12: #   type and root. /doctor <target> dispatch is presentation-menu/argv-driven\n13: #   (see speckit.md), not advisor-driven. The trigger_phrases field below is\n14: #   retained for a possible future doctor-routes harvester but is inert today.\n15: #\n16: # Schema (per route):\n17: #   target:           string — positional name the user types\n18: #   yaml:             string — YAML asset filename in assets/\n19: #   setup_vars:       list   — variables the router resolves and passes to YAML\n20: #   allowed_flags:    list   — per-target flag schema (target-first parsing)\n21: #   mutating:         enum   — read-only | add-only | mutates\n22: #   gate3_location:   string — concrete mutation target (or \"n/a\" for read-only)\n23: #   mcp_tools:        list   — subset of router's frontmatter allowed-tools union\n24: #   trigger_phrases:  list   — descriptive routing phrases for this target; not\n25: #                              currently harvested by advisor (see \"Consumed by\" above)\n26: #\n27: # Code-graph implementation/docs are owned by .opencode/skills/system-code-graph/;\n28: # stable code_graph/detect_changes MCP tools are registered through mk-code-index.\n29: # Skill-advisor recommendation tools are registered through mk-skill-advisor.\n30: # To add a new target: append a route here, then re-run route-validate.sh.\n31: # To remove a target: delete the route AND its corresponding assets/doctor_<target>.yaml.\n32: # ─────────────────────────────────────────────────────────────────\n33: schema_version: 1\n34: routes:\n35:   - target: memory\n36:     yaml: doctor_memory.yaml\n37:     setup_vars: [execution_mode, intent, incremental]\n38:     allowed_flags: [\"--incremental=true|false\"]\n39:     mutating: add-only\n40:     gate3_location: \"<packet_scratch>/doctor-memory-report.<timestamp>.md + <packet_scratch>/doctor-memory-state.<timestamp>.json\"\n41:     mcp_tools:\n42:       - mcp__mk_spec_memory__memory_health\n43:       - mcp__mk_spec_memory__memory_drift_why\n44:       - mcp__mk_spec_memory__memory_search\n45:       - mcp__mk_spec_memory__memory_stats\n46:     script_invocations:\n47:       - 'Warm-only: probe the existing mk-spec-memory IPC socket first; only when it answers, run node .opencode/bin/spec-memory.cjs memory_health --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n48:     trigger_phrases:\n49:       - \"memory continuity index drift\"\n50:       - \"memory health rebuild\"\n51:       - \"context-index doctor\"\n52:       - \"voyage embedding rebuild\"\n53: \n54:   - target: embeddings\n55:     yaml: doctor_embeddings.yaml\n56:     setup_vars: [execution_mode]\n57:     allowed_flags: []\n58:     mutating: read-only\n59:     gate3_location: \"n/a (read-only provider and model-server status)\"\n60:     mcp_tools:\n61:       - mcp__mk_spec_memory__embedder_status\n62:     trigger_phrases:\n63:       - \"embedding provider status\"\n64:       - \"hf-local model-server health\"\n65:       - \"embedder_status diagnostics\"\n66: \n67:   - target: causal-graph\n68:     yaml: doctor_causal-graph.yaml\n69:     setup_vars: [execution_mode, intent, confidence_threshold]\n70:     allowed_flags: [\"--confidence-threshold=N\"]\n71:     mutating: add-only\n72:     gate3_location: \"<packet_scratch>/doctor-causal-graph-state.<timestamp>.json\"\n73:     mcp_tools:\n74:       - mcp__mk_spec_memory__memory_causal_stats\n75:       - mcp__mk_spec_memory__memory_drift_why\n76:       - mcp__mk_spec_memory__memory_search\n77:     trigger_phrases:\n78:       - \"causal edges drift\"\n79:       - \"causal graph doctor\"\n80:       - \"lineage coverage\"\n81:       - \"memory_causal_stats\"\n82: \n83:   - target: code-graph\n84:     yaml: doctor_code-graph.yaml\n85:     setup_vars: [execution_mode, scope]\n86:     allowed_flags:\n87:       # apply-mode flags (--operation, --confirm) return when the confirm workflow is promoted (phase_b)\n88:       - \"--scope=stale|missed|bloat|all|excludes\"\n89:       - \"--dry-run\"\n90:     mutating: add-only\n91:     gate3_location: \"{packet_scratch}/code-graph-diagnostic-{timestamp}.md\"\n92:     mcp_tools:\n93:       - mcp__mk_code_index__code_graph_status\n94:       - mcp__mk_code_index__code_graph_query\n95:       - mcp__mk_code_index__code_graph_context\n96:       - mcp__mk_code_index__detect_changes\n97:       - mcp__mk_spec_memory__memory_context\n98:       - mcp__mk_spec_memory__memory_search\n99:     script_invocations:\n100:       - 'Warm-only: probe the existing mk-code-index IPC socket first; only when it answers, run node .opencode/bin/code-index.cjs code_graph_status --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n101:     trigger_phrases:\n102:       - \"code-graph index drift\"\n103:       - \"code-graph rebuild\"\n104:       - \"code-graph stale excludes\"\n105:       - \"code-graph corruption recover\"\n106: \n107:   - target: deep-loop\n108:     yaml: doctor_deep-loop.yaml\n109:     setup_vars: [execution_mode, intent, scope]\n110:     allowed_flags: [\"--scope=research|review|council|both|all\"]\n111:     mutating: add-only\n112:     gate3_location: \"<packet_scratch>/doctor-deep-loop-state.<timestamp>.json\"\n113:     mcp_tools: []\n114:     script_invocations:\n115:       - 'node .opencode/skills/system-deep-loop/runtime/scripts/status.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n116:       - 'node .opencode/skills/system-deep-loop/runtime/scripts/query.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\" --query-type \"{query_type}\"'\n117:       - 'node .opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n118:     trigger_phrases:\n119:       - \"deep-loop coverage\"\n120:       - \"deep-loop graph rebuild\"\n121:       - \"deep-research convergence drift\"\n122:       - \"deep-review iteration graph\"\n123: \n124:   - target: skill-advisor\n125:     yaml: doctor_skill-advisor.yaml\n126:     setup_vars: [execution_mode, scope, skip_tests, dry_run]\n127:     allowed_flags: [\"--skip-tests\", \"--dry-run\", \"--scope=all|explicit|derived|lexical\"]\n128:     mutating: mutates\n129:     gate3_location: \"lib/scorer/lanes/*.ts + .opencode/skills/*/graph-metadata.json\"\n130:     mcp_tools:\n131:       - mcp__mk_skill_advisor__advisor_recommend\n132:       - mcp__mk_skill_advisor__advisor_status\n133:       - mcp__mk_skill_advisor__advisor_validate\n134:       - mcp__mk_skill_advisor__advisor_rebuild\n135:       - mcp__mk_skill_advisor__skill_graph_scan\n136:       - mcp__mk_skill_advisor__skill_graph_query\n137:       - mcp__mk_skill_advisor__skill_graph_status\n138:       - mcp__mk_spec_memory__memory_context\n139:       - mcp__mk_spec_memory__memory_search\n140:     script_invocations:\n141:       - 'Warm-only: probe the existing mk-skill-advisor IPC socket first; only when it answers, run node .opencode/bin/skill-advisor.cjs advisor_status --workspace-root \"$PWD\" --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n142:     trigger_phrases:\n143:       - \"skill advisor scoring\"\n144:       - \"skill advisor rebuild\"\n145:       - \"advisor recommendation tuning\"\n146:       - \"skill_graph scan\"\n147: \n148:   - target: skill-budget\n149:     yaml: doctor_skill-budget.yaml\n150:     setup_vars: [execution_mode, json_output, top_n, fail_over, project_ceiling]\n151:     allowed_flags: [\"--json\", \"--top-n=N\", \"--fail-over=N\", \"--project-ceiling=N\"]\n152:     mutating: read-only\n153:     gate3_location: \"n/a (read-only audit; no spec folder required)\"\n154:     mcp_tools: []   # script-only audit; no MCP calls\n155:     script_invocations:\n156:       - 'Warm-only: probe the existing mk-skill-advisor IPC socket first; only when it answers, run node .opencode/bin/skill-advisor.cjs advisor_status --workspace-root \"$PWD\" --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n157:     trigger_phrases:\n158:       - \"skill budget audit\"\n159:       - \"description budget check\"\n160:       - \"skill char count drift\"\n161:       - \"frontmatter description trim\"\n162: \n163:   - target: parent-skill\n164:     yaml: doctor_parent-skill.yaml\n165:     setup_vars: [execution_mode, parent_skill_dir]\n166:     allowed_flags: [\"--dir=<path>\"]\n167:     mutating: read-only\n168:     gate3_location: \"n/a (read-only structural audit; inspects a parent skill's graph-metadata/registry and reports, no writes)\"\n169:     mcp_tools: []   # script-only structural audit; no MCP calls\n170:     script_invocations:\n171:       - 'node .opencode/commands/doctor/scripts/parent-skill-check.cjs \"{parent_skill_dir}\"'\n172:     trigger_phrases:\n173:       - \"parent skill structure audit\"\n174:       - \"nested mode packet check\"\n175:       - \"mode-registry drift guard\"\n176:       - \"single graph-metadata identity\"\n177: \n178:   - target: skill-graph-freshness\n179:     yaml: doctor_skill-graph-freshness.yaml\n180:     setup_vars: [execution_mode]\n181:     allowed_flags: []\n182:     mutating: read-only\n183:     gate3_location: \"n/a (read-only diagnostic; 3-way diffs the skill-graph representations and reports drift, writes nothing)\"\n184:     mcp_tools: []   # script-only read; no MCP calls\n185:     script_invocations:\n186:       - 'node .opencode/commands/doctor/scripts/skill-graph-freshness.cjs'\n187:     trigger_phrases:\n188:       - \"skill graph freshness\"\n189:       - \"skill-graph zombie ghost nodes\"\n190:       - \"compiled vs sqlite vs disk graph drift\"\n191:       - \"reindex staleness check\"\n192: \n193:   - target: fable-mode\n194:     yaml: doctor_fable-mode.yaml\n195:     setup_vars: [execution_mode, target_dir]\n196:     allowed_flags: [\"--dir=<path>\", \"--baseline=<path>\"]\n197:     mutating: read-only\n198:     gate3_location: \"n/a (read-only behavioral-metric diagnostic; reads deep-loop state + iteration markdown + baseline snapshot, writes no files)\"\n199:     mcp_tools: []   # script-only behavioral-metric read; no MCP calls\n200:     script_invocations:\n201:       - 'node .opencode/commands/doctor/scripts/fable-mode-check.cjs --dir \"{target_dir}\"'\n202:     trigger_phrases:\n203:       - \"fable-5 behavioral metrics\"\n204:       - \"fable mode efficiency check\"\n205:       - \"tool text ratio diagnostic\"\n206:       - \"result-first opener metric\"\n207: \n208: # ─────────────────────────────────────────────────────────────────\n209: # COMPANION COMMAND ROUTES (/doctor:mcp sub-actions)\n210: # ─────────────────────────────────────────────────────────────────\n211: # /doctor:mcp dispatches via its own command (.opencode/commands/doctor/mcp.md).\n212: # These rows are tracked here for advisor + CI visibility only — the mcp.md\n213: # command parses its own sub-action argv and dispatches to the right YAML.\n214: # ─────────────────────────────────────────────────────────────────\n215: mcp_subroutes:\n216:   - sub_action: install\n217:     yaml: doctor_mcp_install.yaml\n218:     allowed_flags: [\"--server <name>\", \"--runtime <name>\"]\n219:     mutating: mutates\n220:     gate3_location: \"MCP server install dirs + runtime config (.opencode.json / .claude/settings.json / )\"\n221:     trigger_phrases:\n222:       - \"MCP install\"\n223:       - \"MCP server fresh install\"\n224:       - \"reinstall MCP\"\n225: \n226:   - sub_action: debug\n227:     yaml: doctor_mcp_debug.yaml\n228:     allowed_flags: [\"--fix\", \"--server <name>\"]\n229:     mutating: mutates\n230:     gate3_location: \"MCP server logs + runtime config repair\"\n231:     trigger_phrases:\n232:       - \"MCP server broken\"\n233:       - \"MCP debug\"\n234:       - \"MCP connection failure\"\n235:       - \"mcp-doctor.sh\"\n236: \n237: # ─────────────────────────────────────────────────────────────────\n238: # ORCHESTRATOR (NOT routed through /doctor — kept here for reference)\n239: # ─────────────────────────────────────────────────────────────────\n240: # /doctor:update is a STANDALONE command at .opencode/commands/doctor/update.md.\n241: # It does NOT route through /doctor. This block exists for advisor visibility.\n242: # ─────────────────────────────────────────────────────────────────\n243: standalone:\n244:   - command: /doctor:update\n245:     file: .opencode/commands/doctor/update.md\n246:     yaml: doctor_update.yaml\n247:     mutating: mutates\n248:     trigger_phrases:\n249:       - \"spec-kit version migration\"\n250:       - \"doctor update orchestrator\"\n251:       - \"rebuild all spec-kit databases\"\n252:       - \"doctor full sync\"\n\n(End of file - total 252 lines)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR ROUTER — CANONICAL ROUTE MANIFEST\n# ─────────────────────────────────────────────────────────────────\n# Source of truth for /doctor <target> dispatch.\n# Read by: .opencode/commands/doctor/speckit.md (the router)\n# Validated by: .opencode/commands/doctor/scripts/route-validate.sh\n# Consumed by: NOT currently harvested by either Skill Advisor implementation.\n#   Both harvesters (Python skill_advisor.py:810-871 _DOC_HARVEST_SUBDIRS =\n#   (\"references\",\"assets\") rooted at SKILLS_DIR; TS doc-frontmatter.ts:23)\n#   walk only .opencode/skills/*/{references,assets}/*.md frontmatter — a\n#   .yaml file under .opencode/commands/doctor/ is out of scope by both file\n#   type and root. /doctor <target> dispatch is presentation-menu/argv-driven\n#   (see speckit.md), not advisor-driven. The trigger_phrases field below is\n#   retained for a possible future doctor-routes harvester but is inert today.\n#\n# Schema (per route):\n#   target:           string — positional name the user types\n#   yaml:             string — YAML asset filename in assets/\n#   setup_vars:       list   — variables the router resolves and passes to YAML\n#   allowed_flags:    list   — per-target flag schema (target-first parsing)","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/_routes.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR ROUTER — CANONICAL ROUTE MANIFEST\n# ─────────────────────────────────────────────────────────────────\n# Source of truth for /doctor <target> dispatch.\n# Read by: .opencode/commands/doctor/speckit.md (the router)\n# Validated by: .opencode/commands/doctor/scripts/route-validate.sh\n# Consumed by: NOT currently harvested by either Skill Advisor implementation.\n#   Both harvesters (Python skill_advisor.py:810-871 _DOC_HARVEST_SUBDIRS =\n#   (\"references\",\"assets\") rooted at SKILLS_DIR; TS doc-frontmatter.ts:23)\n#   walk only .opencode/skills/*/{references,assets}/*.md frontmatter — a\n#   .yaml file under .opencode/commands/doctor/ is out of scope by both file\n#   type and root. /doctor <target> dispatch is presentation-menu/argv-driven\n#   (see speckit.md), not advisor-driven. The trigger_phrases field below is\n#   retained for a possible future doctor-routes harvester but is inert today.\n#\n# Schema (per route):\n#   target:           string — positional name the user types\n#   yaml:             string — YAML asset filename in assets/\n#   setup_vars:       list   — variables the router resolves and passes to YAML\n#   allowed_flags:    list   — per-target flag schema (target-first parsing)\n#   mutating:         enum   — read-only | add-only | mutates\n#   gate3_location:   string — concrete mutation target (or \"n/a\" for read-only)\n#   mcp_tools:        list   — subset of router's frontmatter allowed-tools union\n#   trigger_phrases:  list   — descriptive routing phrases for this target; not\n#                              currently harvested by advisor (see \"Consumed by\" above)\n#\n# Code-graph implementation/docs are owned by .opencode/skills/system-code-graph/;\n# stable code_graph/detect_changes MCP tools are registered through mk-code-index.\n# Skill-advisor recommendation tools are registered through mk-skill-advisor.\n# To add a new target: append a route here, then re-run route-validate.sh.\n# To remove a target: delete the route AND its corresponding assets/doctor_<target>.yaml.\n# ─────────────────────────────────────────────────────────────────\nschema_version: 1\nroutes:\n  - target: memory\n    yaml: doctor_memory.yaml\n    setup_vars: [execution_mode, intent, incremental]\n    allowed_flags: [\"--incremental=true|false\"]\n    mutating: add-only\n    gate3_location: \"<packet_scratch>/doctor-memory-report.<timestamp>.md + <packet_scratch>/doctor-memory-state.<timestamp>.json\"\n    mcp_tools:\n      - mcp__mk_spec_memory__memory_health\n      - mcp__mk_spec_memory__memory_drift_why\n      - mcp__mk_spec_memory__memory_search\n      - mcp__mk_spec_memory__memory_stats\n    script_invocations:\n      - 'Warm-only: probe the existing mk-spec-memory IPC socket first; only when it answers, run node .opencode/bin/spec-memory.cjs memory_health --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n    trigger_phrases:\n      - \"memory continuity index drift\"\n      - \"memory health rebuild\"\n      - \"context-index doctor\"\n      - \"voyage embedding rebuild\"\n\n  - target: embeddings\n    yaml: doctor_embeddings.yaml\n    setup_vars: [execution_mode]\n    allowed_flags: []\n    mutating: read-only\n    gate3_location: \"n/a (read-only provider and model-server status)\"\n    mcp_tools:\n      - mcp__mk_spec_memory__embedder_status\n    trigger_phrases:\n      - \"embedding provider status\"\n      - \"hf-local model-server health\"\n      - \"embedder_status diagnostics\"\n\n  - target: causal-graph\n    yaml: doctor_causal-graph.yaml\n    setup_vars: [execution_mode, intent, confidence_threshold]\n    allowed_flags: [\"--confidence-threshold=N\"]\n    mutating: add-only\n    gate3_location: \"<packet_scratch>/doctor-causal-graph-state.<timestamp>.json\"\n    mcp_tools:\n      - mcp__mk_spec_memory__memory_causal_stats\n      - mcp__mk_spec_memory__memory_drift_why\n      - mcp__mk_spec_memory__memory_search\n    trigger_phrases:\n      - \"causal edges drift\"\n      - \"causal graph doctor\"\n      - \"lineage coverage\"\n      - \"memory_causal_stats\"\n\n  - target: code-graph\n    yaml: doctor_code-graph.yaml\n    setup_vars: [execution_mode, scope]\n    allowed_flags:\n      # apply-mode flags (--operation, --confirm) return when the confirm workflow is promoted (phase_b)\n      - \"--scope=stale|missed|bloat|all|excludes\"\n      - \"--dry-run\"\n    mutating: add-only\n    gate3_location: \"{packet_scratch}/code-graph-diagnostic-{timestamp}.md\"\n    mcp_tools:\n      - mcp__mk_code_index__code_graph_status\n      - mcp__mk_code_index__code_graph_query\n      - mcp__mk_code_index__code_graph_context\n      - mcp__mk_code_index__detect_changes\n      - mcp__mk_spec_memory__memory_context\n      - mcp__mk_spec_memory__memory_search\n    script_invocations:\n      - 'Warm-only: probe the existing mk-code-index IPC socket first; only when it answers, run node .opencode/bin/code-index.cjs code_graph_status --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n    trigger_phrases:\n      - \"code-graph index drift\"\n      - \"code-graph rebuild\"\n      - \"code-graph stale excludes\"\n      - \"code-graph corruption recover\"\n\n  - target: deep-loop\n    yaml: doctor_deep-loop.yaml\n    setup_vars: [execution_mode, intent, scope]\n    allowed_flags: [\"--scope=research|review|council|both|all\"]\n    mutating: add-only\n    gate3_location: \"<packet_scratch>/doctor-deep-loop-state.<timestamp>.json\"\n    mcp_tools: []\n    script_invocations:\n      - 'node .opencode/skills/system-deep-loop/runtime/scripts/status.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n      - 'node .opencode/skills/system-deep-loop/runtime/scripts/query.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\" --query-type \"{query_type}\"'\n      - 'node .opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n    trigger_phrases:\n      - \"deep-loop coverage\"\n      - \"deep-loop graph rebuild\"\n      - \"deep-research convergence drift\"\n      - \"deep-review iteration graph\"\n\n  - target: skill-advisor\n    yaml: doctor_skill-advisor.yaml\n    setup_vars: [execution_mode, scope, skip_tests, dry_run]\n    allowed_flags: [\"--skip-tests\", \"--dry-run\", \"--scope=all|explicit|derived|lexical\"]\n    mutating: mutates\n    gate3_location: \"lib/scorer/lanes/*.ts + .opencode/skills/*/graph-metadata.json\"\n    mcp_tools:\n      - mcp__mk_skill_advisor__advisor_recommend\n      - mcp__mk_skill_advisor__advisor_status\n      - mcp__mk_skill_advisor__advisor_validate\n      - mcp__mk_skill_advisor__advisor_rebuild\n      - mcp__mk_skill_advisor__skill_graph_scan\n      - mcp__mk_skill_advisor__skill_graph_query\n      - mcp__mk_skill_advisor__skill_graph_status\n      - mcp__mk_spec_memory__memory_context\n      - mcp__mk_spec_memory__memory_search\n    script_invocations:\n      - 'Warm-only: probe the existing mk-skill-advisor IPC socket first; only when it answers, run node .opencode/bin/skill-advisor.cjs advisor_status --workspace-root \"$PWD\" --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n    trigger_phrases:\n      - \"skill advisor scoring\"\n      - \"skill advisor rebuild\"\n      - \"advisor recommendation tuning\"\n      - \"skill_graph scan\"\n\n  - target: skill-budget\n    yaml: doctor_skill-budget.yaml\n    setup_vars: [execution_mode, json_output, top_n, fail_over, project_ceiling]\n    allowed_flags: [\"--json\", \"--top-n=N\", \"--fail-over=N\", \"--project-ceiling=N\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only audit; no spec folder required)\"\n    mcp_tools: []   # script-only audit; no MCP calls\n    script_invocations:\n      - 'Warm-only: probe the existing mk-skill-advisor IPC socket first; only when it answers, run node .opencode/bin/skill-advisor.cjs advisor_status --workspace-root \"$PWD\" --format json --timeout-ms 500 --warm-only (the flag guarantees no daemon start; exit 75 = backend unavailable, retryable)'\n    trigger_phrases:\n      - \"skill budget audit\"\n      - \"description budget check\"\n      - \"skill char count drift\"\n      - \"frontmatter description trim\"\n\n  - target: parent-skill\n    yaml: doctor_parent-skill.yaml\n    setup_vars: [execution_mode, parent_skill_dir]\n    allowed_flags: [\"--dir=<path>\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only structural audit; inspects a parent skill's graph-metadata/registry and reports, no writes)\"\n    mcp_tools: []   # script-only structural audit; no MCP calls\n    script_invocations:\n      - 'node .opencode/commands/doctor/scripts/parent-skill-check.cjs \"{parent_skill_dir}\"'\n    trigger_phrases:\n      - \"parent skill structure audit\"\n      - \"nested mode packet check\"\n      - \"mode-registry drift guard\"\n      - \"single graph-metadata identity\"\n\n  - target: skill-graph-freshness\n    yaml: doctor_skill-graph-freshness.yaml\n    setup_vars: [execution_mode]\n    allowed_flags: []\n    mutating: read-only\n    gate3_location: \"n/a (read-only diagnostic; 3-way diffs the skill-graph representations and reports drift, writes nothing)\"\n    mcp_tools: []   # script-only read; no MCP calls\n    script_invocations:\n      - 'node .opencode/commands/doctor/scripts/skill-graph-freshness.cjs'\n    trigger_phrases:\n      - \"skill graph freshness\"\n      - \"skill-graph zombie ghost nodes\"\n      - \"compiled vs sqlite vs disk graph drift\"\n      - \"reindex staleness check\"\n\n  - target: fable-mode\n    yaml: doctor_fable-mode.yaml\n    setup_vars: [execution_mode, target_dir]\n    allowed_flags: [\"--dir=<path>\", \"--baseline=<path>\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only behavioral-metric diagnostic; reads deep-loop state + iteration markdown + baseline snapshot, writes no files)\"\n    mcp_tools: []   # script-only behavioral-metric read; no MCP calls\n    script_invocations:\n      - 'node .opencode/commands/doctor/scripts/fable-mode-check.cjs --dir \"{target_dir}\"'\n    trigger_phrases:\n      - \"fable-5 behavioral metrics\"\n      - \"fable mode efficiency check\"\n      - \"tool text ratio diagnostic\"\n      - \"result-first opener metric\"\n\n# ─────────────────────────────────────────────────────────────────\n# COMPANION COMMAND ROUTES (/doctor:mcp sub-actions)\n# ─────────────────────────────────────────────────────────────────\n# /doctor:mcp dispatches via its own command (.opencode/commands/doctor/mcp.md).\n# These rows are tracked here for advisor + CI visibility only — the mcp.md\n# command parses its own sub-action argv and dispatches to the right YAML.\n# ─────────────────────────────────────────────────────────────────\nmcp_subroutes:\n  - sub_action: install\n    yaml: doctor_mcp_install.yaml\n    allowed_flags: [\"--server <name>\", \"--runtime <name>\"]\n    mutating: mutates\n    gate3_location: \"MCP server install dirs + runtime config (.opencode.json / .claude/settings.json / )\"\n    trigger_phrases:\n      - \"MCP install\"\n      - \"MCP server fresh install\"\n      - \"reinstall MCP\"\n\n  - sub_action: debug\n    yaml: doctor_mcp_debug.yaml\n    allowed_flags: [\"--fix\", \"--server <name>\"]\n    mutating: mutates\n    gate3_location: \"MCP server logs + runtime config repair\"\n    trigger_phrases:\n      - \"MCP server broken\"\n      - \"MCP debug\"\n      - \"MCP connection failure\"\n      - \"mcp-doctor.sh\"\n\n# ─────────────────────────────────────────────────────────────────\n# ORCHESTRATOR (NOT routed through /doctor — kept here for reference)\n# ─────────────────────────────────────────────────────────────────\n# /doctor:update is a STANDALONE command at .opencode/commands/doctor/update.md.\n# It does NOT route through /doctor. This block exists for advisor visibility.\n# ─────────────────────────────────────────────────────────────────\nstandalone:\n  - command: /doctor:update\n    file: .opencode/commands/doctor/update.md\n    yaml: doctor_update.yaml\n    mutating: mutates\n    trigger_phrases:\n      - \"spec-kit version migration\"\n      - \"doctor update orchestrator\"\n      - \"rebuild all spec-kit databases\"\n      - \"doctor full sync\"","lineStart":1,"lineEnd":252,"totalLines":252,"truncated":false}},"title":".opencode/commands/doctor/_routes.yaml","time":{"start":1784188289155,"end":1784188289160}},"id":"prt_f69e8c082001T4DCuYsC6VeAK4","sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","messageID":"msg_f69e8440b0015aGlejQq2oGzhH"}}
{"type":"tool_use","timestamp":1784188289167,"sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","part":{"type":"tool","tool":"read","callID":"call_2bcf1c6f766c4848a912dc86","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_command_confirm.yaml"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_command_confirm.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # OPENCODE CREATE: COMMAND AUTHORING WORKFLOW (CONFIRM MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: # Mode: confirm-only (interactive step-by-step approval)\n5: # Note: This workflow mirrors auto mode and adds user approval gates\n6: #       at each checkpoint. Workflow behavior must stay equivalent\n7: #       to create_command_auto.yaml except for checkpoint handling.\n8: # ─────────────────────────────────────────────────────────────────\n9: role: Expert Slash Command Author using sk-doc create-command packet\n10: purpose: Create production-ready OpenCode slash command 4-file sets with router/presentation separation\n11: action: Guide command creation from invocation contract through validation with frontmatter, routing, YAML workflow, and presentation verification\n12: \n13: # ─────────────────────────────────────────────────────────────────\n14: # PREREQUISITE: CREATE-COMMAND PACKET VERIFICATION\n15: # ─────────────────────────────────────────────────────────────────\n16: # This workflow REQUIRES the sk-doc create-command packet for:\n17: #   • Command invocation and path rules\n18: #   • Argument-hint and allowed-tools standards\n19: #   • Router/presentation separation\n20: #   • Canonical command and presentation templates\n21: #\n22: # PHASE 0 in the presentation contract verifies packet resources BEFORE\n23: # this YAML workflow loads. If you're executing this workflow,\n24: # create-command verification has already passed.\n25: #\n26: # To invoke correctly: /create:command <command-invocation>\n27: # ─────────────────────────────────────────────────────────────────\n28: \n29: operating_mode:\n30:   workflow: sequential_6_step\n31:   workflow_compliance: MANDATORY\n32:   workflow_execution: interactive\n33:   approvals: step_by_step\n34:   tracking: progressive_task_checklists\n35:   validation: checkpoint_based_with_structural_validation\n36:   permission_configuration: least_privilege_allowed_tools\n37:   description: |\n38:     Executes the 6-step command authoring workflow with approval gates at each checkpoint.\n39:     User confirms, reviews, or modifies at each step before the workflow advances.\n40: \n41: development_philosophy:\n42:   principle: \"Resolve invocation and repeatable workflow before writing files\"\n43:   approach: \"Understand → Plan → Generate → Validate\"\n44:   mandate: \"Command contract first, then routing assets, then presentation text\"\n45: \n46: runtime_command_path_resolution:\n47:   root_command: .opencode/commands/[command].md\n48:   namespace_command: .opencode/commands/[namespace]/[action].md\n49:   split_assets: .opencode/commands/[namespace]/assets/[namespace]_[action]_[kind]\n50: \n51: # ─────────────────────────────────────────────────────────────────\n52: # CONFIDENCE & CLARIFICATION FRAMEWORK\n53: # ─────────────────────────────────────────────────────────────────\n54: confidence_framework:\n55:   thresholds:\n56:     high: { range: \"80-100%\", action: \"Proceed with citable source\" }\n57:     medium: { range: \"40-79%\", action: \"Proceed with caution, document assumptions\" }\n58:     low: { range: \"0-39%\", action: \"STOP - Ask clarification with A/B/C options\" }\n59: \n60:   scoring_weights:\n61:     invocation_clarity: 0.30\n62:     workflow_specificity: 0.25\n63:     tool_permission_clarity: 0.25\n64:     presentation_boundary_defined: 0.20\n65: \n66:   clarification_format: |\n67:     \"I need clarity (confidence: [NN%]). Which approach:\n68:     - A) [option with brief rationale]\n69:     - B) [option with brief rationale]\n70:     - C) [option with brief rationale]\"\n71: \n72:   escalation:\n73:     timebox_minutes: 10\n74:     failed_attempts_threshold: 2\n75:     action: \"Present options to user with current findings\"\n76: \n77: # ─────────────────────────────────────────────────────────────────\n78: # REQUEST ANALYSIS FRAMEWORK\n79: # ─────────────────────────────────────────────────────────────────\n80: request_analysis_framework:\n81:   code_search_note: \"Use Grep/Glob for existing command files and direct Read for exact contents. memory_search is for spec docs/memory, not arbitrary code.\"\n82:   solution_flow:\n83:   - \"Parse carefully: What slash command is ACTUALLY requested?\"\n84:   - \"Gather Context: Read target packet resources and nearby commands\"\n85:   - \"Identify Approach: SIMPLEST command set that matches the workflow\"\n86:   - \"Validate Choice: Follow create-command packet patterns\"\n87:   - \"Clarify If Needed: If <80% confidence, ask\"\n88:   - \"Scope Check: Solving ONLY what was asked?\"\n89:   - \"Execute: Implement with minimal complexity\"\n90: \n91:   pre_change_validation:\n92:     items:\n93:     - \"Command invocation format validated? (/name or /namespace:action)\"\n94:     - \"Command output paths confirmed?\"\n95:     - \"Spec folder created or selected?\"\n96:     - \"Workflow purpose and inputs gathered?\"\n97:     - \"Confidence >=80%? (if not: ask)\"\n98:     stop_conditions: [ \"Any item unchecked\", \"No spec folder\" ]\n99:     stop_action: \"STOP and address before proceeding\"\n100: \n101: # ─────────────────────────────────────────────────────────────────\n102: # USER INPUTS (From gate outputs)\n103: # ─────────────────────────────────────────────────────────────────\n104: user_inputs:\n105:   command_invocation: |\n106:     [COMMAND_INVOCATION]\n107:     Slash command invocation, either /command or /namespace:action.\n108:     FROM UNIFIED SETUP PHASE (Q0 or command argument).\n109: \n110:   command_path: |\n111:     [COMMAND_PATH]\n112:     Output router path derived from command_invocation.\n113:     FROM UNIFIED SETUP PHASE (derived path or explicit --path override).\n114: \n115:   spec_path: |\n116:     [SPEC_PATH]\n117:     Spec folder for tracking this work.\n118:     FROM UNIFIED SETUP PHASE (Q1 choice A/B/C/D).\n119: \n120:   memory_choice: |\n121:     [MEMORY_CHOICE]\n122:     Prior-session context loading choice (A/B/C).\n123:     FROM UNIFIED SETUP PHASE (Q4 if applicable).\n124: \n125: # ─────────────────────────────────────────────────────────────────\n126: # FIELD HANDLING\n127: # ─────────────────────────────────────────────────────────────────\n128: field_handling:\n129:   command_invocation:\n130:     validation: \"must start with /; root commands use lowercase hyphen-case; namespace commands use /namespace:action\"\n131:     required: true\n132: \n133:   command_package_shape:\n134:     validation: \"must be split_4_file_set for this workflow\"\n135:     default: \"split_4_file_set\"\n136:     note: \"Creates router .md plus _auto.yaml, _confirm.yaml, and _presentation.txt assets\"\n137: \n138:   defaults:\n139:     commands_root: \".opencode/commands/\"\n140:     execution_mode: \"confirm_when_omitted\"\n141:     spec_path_from_phase: \"FROM USER CHOICE IN SETUP PHASE\"\n142: \n143: input_contract:\n144:   required:\n145:     - create_command_verified\n146:     - command_invocation\n147:     - command_path\n148:     - spec_path\n149:   optional:\n150:     - memory_choice\n151:     - command_package_shape\n152: \n153: # ─────────────────────────────────────────────────────────────────\n154: # DOCUMENTATION LEVEL\n155: # ─────────────────────────────────────────────────────────────────\n156: documentation_level:\n157:   default: \"Level 1 (Baseline)\"\n158:   required_files:\n159:   - spec.md\n160:   - plan.md\n161:   - tasks.md\n162:   note: \"Command creation typically Level 1 unless destructive behavior, broad routing, or multi-command orchestration increases risk\"\n163: \n164: # ─────────────────────────────────────────────────────────────────\n165: # COMMAND CREATION TEMPLATES\n166: # ─────────────────────────────────────────────────────────────────\n167: command_templates:\n168:   command_markdown: .opencode/skills/sk-doc/create-command/assets/command_template.md\n169:   presentation_contract: .opencode/skills/sk-doc/create-command/assets/command_presentation_template.md\n170: \n171: command_scripts:\n172:   packet_local: \"No packet-local scripts are wired; follow create-command/SKILL.md validation instructions.\"\n173: \n174: command_references:\n175:   command_creation: .opencode/skills/sk-doc/create-command/SKILL.md\n176:   route_map: .opencode/skills/sk-doc/create-command/references/README.md\n177:   worked_example: .opencode/skills/sk-doc/create-command/references/worked_example.md\n178:   router_presentation_split: .opencode/skills/sk-doc/create-command/references/router_presentation_split.md\n179:   argument_hints_and_modes: .opencode/skills/sk-doc/create-command/references/argument_hints_and_modes.md\n180:   common_pitfalls: .opencode/skills/sk-doc/create-command/references/common_pitfalls.md\n181: \n182: # ─────────────────────────────────────────────────────────────────\n183: # CHECKPOINT OPTIONS\n184: # ─────────────────────────────────────────────────────────────────\n185: checkpoint_options:\n186:   standard:\n187:   - label: \"Approve\"\n188:     description: \"Approve and continue to next step\"\n189:   - label: \"Review\"\n190:     description: \"Show more details\"\n191:   - label: \"Modify\"\n192:     description: \"Make changes before proceeding\"\n193:   - label: \"Skip\"\n194:     description: \"Skip this step only when marked optional\"\n195: \n196: # ─────────────────────────────────────────────────────────────────\n197: # CONTEXT LOADING\n198: # ─────────────────────────────────────────────────────────────────\n199: context_loading:\n200:   trigger: \"During UNIFIED SETUP PHASE, when memory_choice is answered (Q4 if applicable) and prior context exists\"\n201:   applies_when: \"An existing spec_path with handover.md or _memory.continuity in implementation-summary.md present from a prior command-creation session\"\n202:   mcp_integration:\n203:     tool: memory_context\n204:     note: \"Call MCP tools directly - NEVER through Code Mode\"\n205:     parameters: { input: \"resume previous work on {spec_path}\", mode: \"resume\", profile: \"resume\", specFolder: \"{spec_path}\", includeContent: true }\n206:     transport_fallback: \"If MCP tools are missing or erroring while the daemon is otherwise warm, use: node .opencode/bin/spec-memory.cjs memory_context --json '{\\\"input\\\":\\\"resume previous work\\\",\\\"mode\\\":\\\"resume\\\"}' --format json --timeout-ms 3000 --warm-only. Exit 75 = retryable backend unavailability.\"\n207:   behavior:\n208:     memory_choice_A: \"Load handover.md plus implementation-summary.md _memory.continuity for spec_path via memory_context; sets memory_loaded: handover\"\n209:     memory_choice_B: \"Load canonical spec docs (spec.md, plan.md, tasks.md) up to a recent cap via memory_context; sets memory_loaded: canonical_docs\"\n210:     memory_choice_C: \"Skip context loading; sets memory_loaded: skipped\"\n211:   when_to_skip: [\"New spec folder or command with no prior context\", \"User says 'skip context' or 'fresh start'\"]\n212:   output: memory_loaded\n213: \n214: # ─────────────────────────────────────────────────────────────────\n215: # WORKFLOW ENFORCEMENT (CRITICAL)\n216: # ─────────────────────────────────────────────────────────────────\n217: workflow_enforcement:\n218:   mode: strict\n219:   step_order: sequential_mandatory\n220:   skip_allowed: false\n221: \n222:   phase_gate:\n223:     location: \"Between Step 2 and Step 3\"\n224:     purpose: \"Verify command contract complete before package planning\"\n225:     requirements:\n226:     - \"Invocation and output paths clearly defined\"\n227:     - \"Repeatable command workflow captured\"\n228:     - \"Tool and presentation boundaries documented\"\n229:     action_if_failed: \"STOP and return to incomplete step\"\n230: \n231:   critical_steps:\n232:     step_2_understanding:\n233:       enforcement: \"MUST gather purpose, inputs, modes, tools, and safety boundaries\"\n234:       verification: \"Cannot proceed without user confirmation of command contract\"\n235:     step_3_planning:\n236:       enforcement: \"MUST define frontmatter, routing assets, and presentation boundary\"\n237:       verification: \"All command package decisions documented and approved\"\n238:     step_4_generation:\n239:       enforcement: \"MUST use create-command templates and real resource paths\"\n240:       verification: \"Router is thin; assets own workflow and presentation\"\n241:     step_5_validation:\n242:       enforcement: \"MUST run structural and path validation\"\n243:       verification: \"Frontmatter parses, assets exist, and no placeholders remain\"\n244: \n245: # ─────────────────────────────────────────────────────────────────\n246: # WORKFLOW (6 STEPS WITH CHECKPOINTS)\n247: # ─────────────────────────────────────────────────────────────────\n248: gate_logic:\n249:   hard:\n250:     H0_create_command_verified:\n251:       description: \"create-command packet verification must have passed in Phase 0\"\n252:       fail_action: \"STOP and return to the command setup phase\"\n253:     H1_required_fields:\n254:       description: \"Required setup fields must be present before generation\"\n255:       fail_action: \"STOP and collect missing inputs\"\n256:     H2_generation_contract:\n257:       description: \"Generated command set must follow the create-command template and router/presentation contract\"\n258:       fail_action: \"Fix the generated output before continuing\"\n259:   soft:\n260:     S1_existing_command:\n261:       description: \"Warn when a command already exists at the target path\"\n262:       fail_action: \"Proceed only after explicit update intent\"\n263: \n264: workflow_overview:\n265:   steps:\n266:     - id: step_1_request_analysis\n267:       purpose: \"Normalize inputs, validate invocation, and resolve output paths\"\n268:     - id: step_2_understanding\n269:       purpose: \"Capture the command purpose, workflow, inputs, tools, and boundaries\"\n270:     - id: step_3_planning\n271:       purpose: \"Define frontmatter, routing assets, mode behavior, and presentation boundary\"\n272:     - id: step_4_generation\n273:       purpose: \"Generate the command 4-file set from canonical templates\"\n274:     - id: step_5_validation\n275:       purpose: \"Validate frontmatter, YAML, paths, placeholders, and router thinness\"\n276:     - id: step_6_save_context\n277:       purpose: \"Persist spec context and emit completion status\"\n278: \n279: workflow:\n280:   # ═══════════════════════════════════════════════════════════════\n281:   # PHASE A: PLANNING (Steps 1-3)\n282:   # ═══════════════════════════════════════════════════════════════\n283: \n284:   step_1_request_analysis:\n285:     purpose: Parse inputs and validate command invocation (from UNIFIED SETUP PHASE)\n286:     activities:\n287:     - Confirm command_invocation from UNIFIED SETUP PHASE (Q0 or argument)\n288:     - Derive command_path from command_invocation unless explicit path is provided\n289:     - Confirm spec_path from UNIFIED SETUP PHASE (Q1 choice A/B/C/D)\n290:     - Resolve memory_choice via the context_loading block (Q4 if applicable); record result as memory_loaded\n291:     - Verify command invocation format and path mapping\n292:     - Check if command router or owned assets already exist at target paths\n293:     validation:\n294:       invocation_format: \"root /command or namespace /namespace:action\"\n295:       check_exists: true\n296:       command: \"ls [command_path] 2>/dev/null\"\n297:     outputs:\n298:     - command_invocation_validated\n299:     - command_path_confirmed\n300:     - command_exists_check\n301:     checkpoint:\n302:       question: \"Creating command '[command-invocation]' at [command-path]. Proceed?\"\n303:       options:\n304:       - label: \"A) Proceed\"\n305:         description: \"Create or update command with these settings\"\n306:       - label: \"B) Change invocation\"\n307:         description: \"Use a different command invocation\"\n308:       - label: \"C) Change output path\"\n309:         description: \"Use a different command path\"\n310: \n311:   step_1b_command_discovery:\n312:     purpose: Search for similar existing commands before creating or updating (MANDATORY)\n313:     gate_type: SOFT_BLOCK\n314:     enforcement: \"Warn if similar command exists, allow user override\"\n315:     activities:\n316:     - \"Use Glob to list .opencode/commands/**/*.md\"\n317:     - \"Use Grep to search for matching invocation names, descriptions, and workflow phrases\"\n318:     - \"Read exact matches and nearby namespace commands before planning\"\n319:     validation:\n320:       similar_exists_threshold: \"same invocation, same namespace/action, or significant description overlap\"\n321:       action_if_found: \"SOFT_BLOCK - Present findings to user\"\n322:     outputs:\n323:     - similar_commands_found: list_of_matching_commands\n324:     - reusable_patterns: patterns_to_consider\n325:     - proceed_recommendation: boolean\n326:     checkpoint:\n327:       condition: \"similar_commands_found.length > 0\"\n328:       question: \"Found similar command(s): [command_names]. Continue creating or updating this command?\"\n329:       options:\n330:       - label: \"A) Proceed anyway\"\n331:         description: \"Continue despite similar existing command\"\n332:       - label: \"B) Review existing first\"\n333:         description: \"Load and review the similar command before deciding\"\n334:       - label: \"C) Abort\"\n335:         description: \"Cancel command creation\"\n336:     skip_condition: \"User explicitly skips discovery\"\n337: \n338:   step_1c_spec_folder_setup:\n339:     purpose: Create documentation folder for tracking (if user chose B or C in Q1)\n340:     condition: \"spec_choice != D (Skip)\"\n341:     activities:\n342:     - IF spec_choice == B (Create new):\n343:       - Find next available spec number in the selected spec root\n344:       - \"Create folder: [spec-root]/[NNN]-[command-slug]/\"\n345:     - IF spec_choice == A or C (Use existing):\n346:       - Use selected spec_path\n347:     - \"Create or update Level 1 spec.md, plan.md, and tasks.md through the active spec-folder workflow; do not wire non-target packet template paths here\"\n348:     outputs:\n349:     - spec.md: created_or_updated\n350:     - plan.md: created_or_updated\n351:     - tasks.md: created_or_updated\n352:     checkpoint:\n353:       question: \"Spec folder created/confirmed. Continue to command contract phase?\"\n354:       options: checkpoint_options.standard\n355: \n356:   step_2_understanding:\n357:     purpose: Gather command purpose, workflow, inputs, tools, and boundaries (CRITICAL - DO NOT SKIP)\n358:     enforcement: MANDATORY\n359:     activities:\n360:     - Ask focused questions about the command's repeatable workflow\n361:     - Gather invocation purpose and expected user inputs\n362:     - Identify :auto and :confirm behavior\n363:     - Define least-privilege allowed-tools\n364:     - Identify visible prompts, dashboards, result templates, and next-step wording\n365:     - Identify destructive or privileged actions and required safety gates\n366:     questions:\n367:     - \"What should this slash command create, update, or route?\"\n368:     - \"What arguments and modes should it accept?\"\n369:     - \"Which tools does the workflow actually need?\"\n370:     - \"What user-facing prompts and results must be separated into presentation?\"\n371:     outputs:\n372:     - purpose_defined: \"clear repeatable command workflow\"\n373:     - inputs_defined: \"required arguments, optional flags, and modes\"\n374:     - tools_defined: \"least-privilege allowed-tools list\"\n375:     - boundaries_defined: \"router, YAML, and presentation ownership\"\n376:     validation: understanding_complete\n377:     checkpoint:\n378:       question: \"I've identified: Purpose=[purpose], Inputs=[inputs], Tools=[tools]. Is this command contract correct?\"\n379:       options:\n380:       - label: \"A) Approve\"\n381:         description: \"Command contract is correct\"\n382:       - label: \"B) Add more\"\n383:         description: \"Add additional workflow details\"\n384:       - label: \"C) Modify\"\n385:         description: \"Change existing command contract\"\n386: \n387:   # ═══════════════════════════════════════════════════════════════\n388:   # 🔒 PHASE GATE: UNDERSTANDING → CONFIGURATION\n389:   # ═══════════════════════════════════════════════════════════════\n390:   phase_gate_understanding_to_configuration:\n391:     trigger: \"After Step 2 completes\"\n392:     enforcement: HARD_BLOCK\n393:     verification: |\n394:       BEFORE proceeding to Configuration Phase (Step 3):\n395: \n396:       VERIFY all understanding artifacts exist:\n397:       ├─ [ ] Invocation and output path clearly defined\n398:       ├─ [ ] Repeatable workflow purpose captured\n399:       ├─ [ ] Required arguments, modes, and tools documented\n400:       ├─ [ ] Router/YAML/presentation boundaries identified\n401: \n402:       IF any artifact missing:\n403:       └─ STOP → Return to Step 2 → Complete it → Return here\n404: \n405:       WHEN all artifacts verified:\n406:       └─ SET PHASE GATE STATUS: PASSED → Proceed to Step 3\n407:     action_if_failed: \"Return to incomplete step\"\n408: \n409:   # ═══════════════════════════════════════════════════════════════\n410:   # PHASE B: IMPLEMENTATION (Steps 3-6)\n411:   # ═══════════════════════════════════════════════════════════════\n412: \n413:   step_3_planning:\n414:     purpose: Define command package, frontmatter, routing assets, and behavioral rules\n415:     activities:\n416:     - Confirm split 4-file package shape for workflow-backed command creation\n417:     - Define router frontmatter: description, argument-hint, allowed-tools\n418:     - Define asset paths for _auto.yaml, _confirm.yaml, and _presentation.txt\n419:     - Define :auto and :confirm behavior; confirm must equal auto plus checkpoints\n420:     - Define presentation sections for prompts, dashboard, result, and failure display\n421:     - Plan validation commands and grep checks\n422:     outputs:\n423:     - command_package_selected\n424:     - frontmatter_configured\n425:     - routing_assets_defined\n426:     - presentation_boundary_defined\n427:     - validation_plan_defined\n428:     validation: configuration_planned\n429:     checkpoint:\n430:       question: \"Configuration: Package=[package], Allowed Tools=[tools], Assets=[paths]. Approve?\"\n431:       options:\n432:       - label: \"A) Approve\"\n433:         description: \"Configuration is correct\"\n434:       - label: \"B) Modify tools\"\n435:         description: \"Adjust allowed-tools\"\n436:       - label: \"C) Modify assets\"\n437:         description: \"Adjust command asset plan\"\n438: \n439:   step_4_generation:\n440:     purpose: Create command 4-file set with router markdown, workflow YAML, and presentation contract\n441:     activities:\n442:     - Load command_template.md for command structure reference\n443:     - Load command_presentation_template.md for presentation structure reference\n444:     - Generate thin router markdown with asset table, execution order, routing rules, and presentation boundary\n445:     - Generate _auto.yaml with the workflow steps and no user approval checkpoints\n446:     - Generate _confirm.yaml with the same workflow plus checkpoint blocks\n447:     - Generate _presentation.txt with startup, setup, dashboard, completion, and failure displays\n448:     - Write files to the resolved command paths\n449:     - Verify each file exists and is readable\n450:     outputs:\n451:     - router_file_created\n452:     - auto_yaml_created\n453:     - confirm_yaml_created\n454:     - presentation_file_created\n455:     validation: files_created\n456:     checkpoint:\n457:       question: \"Command files generated. Review before validation?\"\n458:       options:\n459:       - label: \"A) Show router\"\n460:         description: \"Display router markdown summary\"\n461:       - label: \"B) Show assets\"\n462:         description: \"Display YAML and presentation summaries\"\n463:       - label: \"C) Proceed\"\n464:         description: \"Continue to validation\"\n465: \n466:   step_5_validation:\n467:     purpose: Frontmatter, YAML, path, structure, and leftover-source validation\n468:     enforcement: HARD_BLOCK\n469:     activities:\n470:     - Parse router frontmatter and verify required fields\n471:     - Parse _auto.yaml and _confirm.yaml as YAML when parser is available\n472:     - Verify all resource paths referenced in workflow assets exist on disk\n473:     - Verify confirm workflow mirrors auto workflow except checkpoint blocks and interactive execution settings\n474:     - Verify router stays thin and presentation owns visible templates\n475:     - Run validate_document.py if available\n476:     - Grep generated files for copied source workflow names\n477:     - IF validation fails: Fix issues and re-run\n478:     - Repeat until passing\n479:     outputs:\n480:     - frontmatter_validation_result: pass_or_fail\n481:     - yaml_validation_result: pass_or_fail\n482:     - path_validation_result: pass_or_fail\n483:     - leftover_source_check: pass_or_fail\n484:     validation: command_set_valid\n485:     checkpoint:\n486:       question: \"Validation complete. [PASS/FAIL]. Proceed?\"\n487:       options:\n488:       - label: \"A) Continue to save context\"\n489:         description: \"Validation passed, finalize command\"\n490:       - label: \"B) Review errors\"\n491:         description: \"Show detailed validation errors\"\n492:       - label: \"C) Fix issues\"\n493:         description: \"Address validation failures and revalidate\"\n494: \n495:   step_5b_quality_validation:\n496:     purpose: Quality-validate the created command artifact set\n497:     activities:\n498:     - \"Run command structural validation against the router markdown\"\n499:     - \"Validate frontmatter description budget and allowed-tools accuracy\"\n500:     - \"Review router/presentation split against create-command references\"\n501:     - \"Confirm the output package has exactly the expected owned files\"\n502:     on_low_score:\n503:       threshold: 70\n504:       action: \"Log warnings and suggest improvements; do not block workflow unless structural rules fail\"\n505:     outputs:\n506:     - quality_score: number\n507:     - validation_findings: list\n508:     - improvement_suggestions: list (if score < 70)\n509:     - description_length_warnings: list\n510:     checkpoint:\n511:       question: \"Quality validation complete (score: [quality_score]/100). Continue?\"\n512:       options:\n513:       - label: \"A) Accept and continue\"\n514:         description: \"Proceed to save context\"\n515:       - label: \"B) View findings\"\n516:         description: \"Show detailed review findings\"\n517:       - label: \"C) Address issues\"\n518:         description: \"Fix issues before continuing\"\n519: \n520:   step_6_save_context:\n521:     purpose: Preserve workflow decisions and context\n522:     condition: \"spec_path is not null\"\n523:     activities:\n524:     - Invoke system-spec-kit skill\n525:     - Document command creation decisions\n526:     - Record routing, frontmatter, tools, and presentation-boundary rationale\n527:     - Save validation results\n528:     - Update canonical spec documents\n529:     - Index canonical spec document for immediate search availability\n530:     outputs:\n531:     - implementation_summary: \"[spec_path]/implementation-summary.md\"\n532:     validation: context_saved\n533:     checkpoint:\n534:       question: \"Context saved. Command creation complete!\"\n535:       options:\n536:       - label: \"Done\"\n537:         description: \"Complete workflow\"\n538:       - label: \"View summary\"\n539:         description: \"Show final summary\"\n540: \n541: # ─────────────────────────────────────────────────────────────────\n542: # CIRCUIT BREAKER\n543: # ─────────────────────────────────────────────────────────────────\n544: circuit_breaker:\n545:   consecutive_failure_threshold: 3\n546:   states:\n547:     closed: \"Normal operation\"\n548:     open: \"3+ failures — pause and report to user\"\n549:     half_open: \"Test with single retry before resuming\"\n550:   on_open:\n551:     action: \"Report failures to user with summary\"\n552:     suggest: \"Review inputs and try again, or escalate\"\n553: \n554: # ─────────────────────────────────────────────────────────────────\n555: # ERROR RECOVERY\n556: # ─────────────────────────────────────────────────────────────────\n557: error_recovery:\n558:   invalid_command_invocation:\n559:     action: \"Show valid format (/command or /namespace:action), prompt for correction\"\n560:     example: \"Expected: /create:thing or /memory-save\"\n561:   command_already_exists:\n562:     action: \"Offer to update existing or choose a new invocation\"\n563:     options: [ \"Update existing\", \"Choose new invocation\", \"Cancel\" ]\n564:   yaml_parse_error:\n565:     action: \"Check workflow asset syntax, fix and re-validate\"\n566:     common_issues:\n567:     - \"Missing colon after field name\"\n568:     - \"Incorrect indentation (use 2 spaces)\"\n569:     - \"Unquoted strings with special characters\"\n570:     - \"Invalid block scalar indentation\"\n571:   missing_required_field:\n572:     action: \"Add the missing router frontmatter or workflow field and re-validate\"\n573:     required_fields: [ \"description\", \"argument-hint\", \"allowed-tools\" ]\n574:   missing_resource_path:\n575:     action: \"Remove fabricated path or replace with a verified on-disk path\"\n576:   presentation_boundary_violation:\n577:     action: \"Move prompts, dashboards, results, and next-step text from router into presentation asset\"\n578: \n579: # ─────────────────────────────────────────────────────────────────\n580: # INTERACTIVE EXECUTION\n581: # ─────────────────────────────────────────────────────────────────\n582: interactive_execution:\n583:   principle: \"Execute workflow steps with user approval at each checkpoint\"\n584:   user_feedback_handling:\n585:     approve: \"Continue to next step\"\n586:     review: \"Show detailed output before proceeding\"\n587:     modify: \"Apply requested changes and re-validate\"\n588:     skip: \"Mark step as skipped with reason only when optional, continue\"\n589: \n590: # ─────────────────────────────────────────────────────────────────\n591: # QUALITY STANDARDS\n592: # ─────────────────────────────────────────────────────────────────\n593: quality_standards:\n594:   frontmatter_validation: MANDATORY\n595:   yaml_validation: MANDATORY\n596:   router_presentation_separation: MANDATORY\n597:   validation_pipeline:\n598:     stage_1: \"Router frontmatter parsing\"\n599:     stage_2: \"Required field check (description, argument-hint, allowed-tools)\"\n600:     stage_3: \"YAML workflow asset parsing\"\n601:     stage_4: \"Resource path existence check\"\n602:     stage_5: \"Leftover source-name grep\"\n603:   template_adherence: required\n604:   core_standards_reference: \".opencode/skills/sk-doc/create-command/SKILL.md\"\n605: \n606: # ─────────────────────────────────────────────────────────────────\n607: # COMPLETION REPORT TEMPLATE\n608: # ─────────────────────────────────────────────────────────────────\n609: completion_report:\n610:   template: |\n611:     Command Creation Complete\n612: \n613:     Command: [command-invocation]\n614:     Router: [command-path]\n615:     Assets:\n616:     - Auto workflow: [auto-yaml-path]\n617:     - Confirm workflow: [confirm-yaml-path]\n618:     - Presentation: [presentation-path]\n619: \n620:     Configuration:\n621:     - Allowed Tools: [allowed-tools]\n622:     - Modes: :auto and :confirm\n623:     - Router Boundary: thin router verified\n624: \n625:     Spec Folder: [spec path or none]\n626:     Memory: [saved/indexed/not applicable]\n627: \n628:     Validation:\n629:     - Router frontmatter: PASSED\n630:     - YAML workflows: PASSED\n631:     - Resource paths: PASSED\n632:     - Source leftovers: PASSED\n633: \n634:     Invocation:\n635:     - Type [command-invocation] [arguments]\n636:     - Add :auto for autonomous execution\n637:     - Add :confirm for checkpointed execution\n638: \n639:     Next Steps:\n640:     - Run the command with a small sample request\n641:     - Review generated prompts and result displays\n642:     - Tighten allowed-tools if validation finds unused tools\n643: \n644:     STATUS=OK PATH=[command-path]\n645: \n646: # ─────────────────────────────────────────────────────────────────\n647: # TERMINATION\n648: # ─────────────────────────────────────────────────────────────────\n649: termination:\n650:   after_step: step_6_save_context\n651:   message: \"Command creation workflow complete.\"\n652:   next_steps:\n653:     - condition: \"Command needs testing\"\n654:       action: \"Run with a sample request matching the intended workflow\"\n655:     - condition: \"Command needs refinement\"\n656:       action: \"Iterate on prompts, routing, or allowed-tools based on testing\"\n657:     - condition: \"Context should be saved\"\n658:       action: \"Run /memory:save\"\n659: \n660: # ─────────────────────────────────────────────────────────────────\n661: # RULES\n662: # ─────────────────────────────────────────────────────────────────\n663: rules:\n664:   ALWAYS:\n665:     - \"Copy templates from canonical paths, never create from memory\"\n666:     - \"Run structural validation before claiming completion\"\n667:     - \"Pause at checkpoints for user approval\"\n668:     - \"Respect user feedback and modification requests\"\n669:     - \"Reference core_standards.md for formatting rules\"\n670:     - \"Validate workflow YAML syntax when parser support is available\"\n671:     - \"Keep routers thin when presentation assets exist\"\n672:     - \"Save context after successful completion when a spec path is present\"\n673:   NEVER:\n674:     - \"Skip validation steps\"\n675:     - \"Create documents without loading templates first\"\n676:     - \"Proceed without user approval at checkpoints\"\n677:     - \"Leave placeholder text in final output\"\n678:     - \"Invent template, script, or reference paths\"\n679:     - \"Ignore YAML parse errors\"\n680:     - \"Put presentation templates inside the router\"\n\n(End of file - total 680 lines)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# OPENCODE CREATE: COMMAND AUTHORING WORKFLOW (CONFIRM MODE)\n# ─────────────────────────────────────────────────────────────────\n# Mode: confirm-only (interactive step-by-step approval)\n# Note: This workflow mirrors auto mode and adds user approval gates\n#       at each checkpoint. Workflow behavior must stay equivalent\n#       to create_command_auto.yaml except for checkpoint handling.\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Slash Command Author using sk-doc create-command packet\npurpose: Create production-ready OpenCode slash command 4-file sets with router/presentation separation\naction: Guide command creation from invocation contract through validation with frontmatter, routing, YAML workflow, and presentation verification\n\n# ─────────────────────────────────────────────────────────────────\n# PREREQUISITE: CREATE-COMMAND PACKET VERIFICATION\n# ─────────────────────────────────────────────────────────────────\n# This workflow REQUIRES the sk-doc create-command packet for:\n#   • Command invocation and path rules\n#   • Argument-hint and allowed-tools standards\n#   • Router/presentation separation\n#   • Canonical command and presentation templates","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_command_confirm.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# OPENCODE CREATE: COMMAND AUTHORING WORKFLOW (CONFIRM MODE)\n# ─────────────────────────────────────────────────────────────────\n# Mode: confirm-only (interactive step-by-step approval)\n# Note: This workflow mirrors auto mode and adds user approval gates\n#       at each checkpoint. Workflow behavior must stay equivalent\n#       to create_command_auto.yaml except for checkpoint handling.\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Slash Command Author using sk-doc create-command packet\npurpose: Create production-ready OpenCode slash command 4-file sets with router/presentation separation\naction: Guide command creation from invocation contract through validation with frontmatter, routing, YAML workflow, and presentation verification\n\n# ─────────────────────────────────────────────────────────────────\n# PREREQUISITE: CREATE-COMMAND PACKET VERIFICATION\n# ─────────────────────────────────────────────────────────────────\n# This workflow REQUIRES the sk-doc create-command packet for:\n#   • Command invocation and path rules\n#   • Argument-hint and allowed-tools standards\n#   • Router/presentation separation\n#   • Canonical command and presentation templates\n#\n# PHASE 0 in the presentation contract verifies packet resources BEFORE\n# this YAML workflow loads. If you're executing this workflow,\n# create-command verification has already passed.\n#\n# To invoke correctly: /create:command <command-invocation>\n# ─────────────────────────────────────────────────────────────────\n\noperating_mode:\n  workflow: sequential_6_step\n  workflow_compliance: MANDATORY\n  workflow_execution: interactive\n  approvals: step_by_step\n  tracking: progressive_task_checklists\n  validation: checkpoint_based_with_structural_validation\n  permission_configuration: least_privilege_allowed_tools\n  description: |\n    Executes the 6-step command authoring workflow with approval gates at each checkpoint.\n    User confirms, reviews, or modifies at each step before the workflow advances.\n\ndevelopment_philosophy:\n  principle: \"Resolve invocation and repeatable workflow before writing files\"\n  approach: \"Understand → Plan → Generate → Validate\"\n  mandate: \"Command contract first, then routing assets, then presentation text\"\n\nruntime_command_path_resolution:\n  root_command: .opencode/commands/[command].md\n  namespace_command: .opencode/commands/[namespace]/[action].md\n  split_assets: .opencode/commands/[namespace]/assets/[namespace]_[action]_[kind]\n\n# ─────────────────────────────────────────────────────────────────\n# CONFIDENCE & CLARIFICATION FRAMEWORK\n# ─────────────────────────────────────────────────────────────────\nconfidence_framework:\n  thresholds:\n    high: { range: \"80-100%\", action: \"Proceed with citable source\" }\n    medium: { range: \"40-79%\", action: \"Proceed with caution, document assumptions\" }\n    low: { range: \"0-39%\", action: \"STOP - Ask clarification with A/B/C options\" }\n\n  scoring_weights:\n    invocation_clarity: 0.30\n    workflow_specificity: 0.25\n    tool_permission_clarity: 0.25\n    presentation_boundary_defined: 0.20\n\n  clarification_format: |\n    \"I need clarity (confidence: [NN%]). Which approach:\n    - A) [option with brief rationale]\n    - B) [option with brief rationale]\n    - C) [option with brief rationale]\"\n\n  escalation:\n    timebox_minutes: 10\n    failed_attempts_threshold: 2\n    action: \"Present options to user with current findings\"\n\n# ─────────────────────────────────────────────────────────────────\n# REQUEST ANALYSIS FRAMEWORK\n# ─────────────────────────────────────────────────────────────────\nrequest_analysis_framework:\n  code_search_note: \"Use Grep/Glob for existing command files and direct Read for exact contents. memory_search is for spec docs/memory, not arbitrary code.\"\n  solution_flow:\n  - \"Parse carefully: What slash command is ACTUALLY requested?\"\n  - \"Gather Context: Read target packet resources and nearby commands\"\n  - \"Identify Approach: SIMPLEST command set that matches the workflow\"\n  - \"Validate Choice: Follow create-command packet patterns\"\n  - \"Clarify If Needed: If <80% confidence, ask\"\n  - \"Scope Check: Solving ONLY what was asked?\"\n  - \"Execute: Implement with minimal complexity\"\n\n  pre_change_validation:\n    items:\n    - \"Command invocation format validated? (/name or /namespace:action)\"\n    - \"Command output paths confirmed?\"\n    - \"Spec folder created or selected?\"\n    - \"Workflow purpose and inputs gathered?\"\n    - \"Confidence >=80%? (if not: ask)\"\n    stop_conditions: [ \"Any item unchecked\", \"No spec folder\" ]\n    stop_action: \"STOP and address before proceeding\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (From gate outputs)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  command_invocation: |\n    [COMMAND_INVOCATION]\n    Slash command invocation, either /command or /namespace:action.\n    FROM UNIFIED SETUP PHASE (Q0 or command argument).\n\n  command_path: |\n    [COMMAND_PATH]\n    Output router path derived from command_invocation.\n    FROM UNIFIED SETUP PHASE (derived path or explicit --path override).\n\n  spec_path: |\n    [SPEC_PATH]\n    Spec folder for tracking this work.\n    FROM UNIFIED SETUP PHASE (Q1 choice A/B/C/D).\n\n  memory_choice: |\n    [MEMORY_CHOICE]\n    Prior-session context loading choice (A/B/C).\n    FROM UNIFIED SETUP PHASE (Q4 if applicable).\n\n# ─────────────────────────────────────────────────────────────────\n# FIELD HANDLING\n# ─────────────────────────────────────────────────────────────────\nfield_handling:\n  command_invocation:\n    validation: \"must start with /; root commands use lowercase hyphen-case; namespace commands use /namespace:action\"\n    required: true\n\n  command_package_shape:\n    validation: \"must be split_4_file_set for this workflow\"\n    default: \"split_4_file_set\"\n    note: \"Creates router .md plus _auto.yaml, _confirm.yaml, and _presentation.txt assets\"\n\n  defaults:\n    commands_root: \".opencode/commands/\"\n    execution_mode: \"confirm_when_omitted\"\n    spec_path_from_phase: \"FROM USER CHOICE IN SETUP PHASE\"\n\ninput_contract:\n  required:\n    - create_command_verified\n    - command_invocation\n    - command_path\n    - spec_path\n  optional:\n    - memory_choice\n    - command_package_shape\n\n# ─────────────────────────────────────────────────────────────────\n# DOCUMENTATION LEVEL\n# ─────────────────────────────────────────────────────────────────\ndocumentation_level:\n  default: \"Level 1 (Baseline)\"\n  required_files:\n  - spec.md\n  - plan.md\n  - tasks.md\n  note: \"Command creation typically Level 1 unless destructive behavior, broad routing, or multi-command orchestration increases risk\"\n\n# ─────────────────────────────────────────────────────────────────\n# COMMAND CREATION TEMPLATES\n# ─────────────────────────────────────────────────────────────────\ncommand_templates:\n  command_markdown: .opencode/skills/sk-doc/create-command/assets/command_template.md\n  presentation_contract: .opencode/skills/sk-doc/create-command/assets/command_presentation_template.md\n\ncommand_scripts:\n  packet_local: \"No packet-local scripts are wired; follow create-command/SKILL.md validation instructions.\"\n\ncommand_references:\n  command_creation: .opencode/skills/sk-doc/create-command/SKILL.md\n  route_map: .opencode/skills/sk-doc/create-command/references/README.md\n  worked_example: .opencode/skills/sk-doc/create-command/references/worked_example.md\n  router_presentation_split: .opencode/skills/sk-doc/create-command/references/router_presentation_split.md\n  argument_hints_and_modes: .opencode/skills/sk-doc/create-command/references/argument_hints_and_modes.md\n  common_pitfalls: .opencode/skills/sk-doc/create-command/references/common_pitfalls.md\n\n# ─────────────────────────────────────────────────────────────────\n# CHECKPOINT OPTIONS\n# ─────────────────────────────────────────────────────────────────\ncheckpoint_options:\n  standard:\n  - label: \"Approve\"\n    description: \"Approve and continue to next step\"\n  - label: \"Review\"\n    description: \"Show more details\"\n  - label: \"Modify\"\n    description: \"Make changes before proceeding\"\n  - label: \"Skip\"\n    description: \"Skip this step only when marked optional\"\n\n# ─────────────────────────────────────────────────────────────────\n# CONTEXT LOADING\n# ─────────────────────────────────────────────────────────────────\ncontext_loading:\n  trigger: \"During UNIFIED SETUP PHASE, when memory_choice is answered (Q4 if applicable) and prior context exists\"\n  applies_when: \"An existing spec_path with handover.md or _memory.continuity in implementation-summary.md present from a prior command-creation session\"\n  mcp_integration:\n    tool: memory_context\n    note: \"Call MCP tools directly - NEVER through Code Mode\"\n    parameters: { input: \"resume previous work on {spec_path}\", mode: \"resume\", profile: \"resume\", specFolder: \"{spec_path}\", includeContent: true }\n    transport_fallback: \"If MCP tools are missing or erroring while the daemon is otherwise warm, use: node .opencode/bin/spec-memory.cjs memory_context --json '{\\\"input\\\":\\\"resume previous work\\\",\\\"mode\\\":\\\"resume\\\"}' --format json --timeout-ms 3000 --warm-only. Exit 75 = retryable backend unavailability.\"\n  behavior:\n    memory_choice_A: \"Load handover.md plus implementation-summary.md _memory.continuity for spec_path via memory_context; sets memory_loaded: handover\"\n    memory_choice_B: \"Load canonical spec docs (spec.md, plan.md, tasks.md) up to a recent cap via memory_context; sets memory_loaded: canonical_docs\"\n    memory_choice_C: \"Skip context loading; sets memory_loaded: skipped\"\n  when_to_skip: [\"New spec folder or command with no prior context\", \"User says 'skip context' or 'fresh start'\"]\n  output: memory_loaded\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW ENFORCEMENT (CRITICAL)\n# ─────────────────────────────────────────────────────────────────\nworkflow_enforcement:\n  mode: strict\n  step_order: sequential_mandatory\n  skip_allowed: false\n\n  phase_gate:\n    location: \"Between Step 2 and Step 3\"\n    purpose: \"Verify command contract complete before package planning\"\n    requirements:\n    - \"Invocation and output paths clearly defined\"\n    - \"Repeatable command workflow captured\"\n    - \"Tool and presentation boundaries documented\"\n    action_if_failed: \"STOP and return to incomplete step\"\n\n  critical_steps:\n    step_2_understanding:\n      enforcement: \"MUST gather purpose, inputs, modes, tools, and safety boundaries\"\n      verification: \"Cannot proceed without user confirmation of command contract\"\n    step_3_planning:\n      enforcement: \"MUST define frontmatter, routing assets, and presentation boundary\"\n      verification: \"All command package decisions documented and approved\"\n    step_4_generation:\n      enforcement: \"MUST use create-command templates and real resource paths\"\n      verification: \"Router is thin; assets own workflow and presentation\"\n    step_5_validation:\n      enforcement: \"MUST run structural and path validation\"\n      verification: \"Frontmatter parses, assets exist, and no placeholders remain\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW (6 STEPS WITH CHECKPOINTS)\n# ─────────────────────────────────────────────────────────────────\ngate_logic:\n  hard:\n    H0_create_command_verified:\n      description: \"create-command packet verification must have passed in Phase 0\"\n      fail_action: \"STOP and return to the command setup phase\"\n    H1_required_fields:\n      description: \"Required setup fields must be present before generation\"\n      fail_action: \"STOP and collect missing inputs\"\n    H2_generation_contract:\n      description: \"Generated command set must follow the create-command template and router/presentation contract\"\n      fail_action: \"Fix the generated output before continuing\"\n  soft:\n    S1_existing_command:\n      description: \"Warn when a command already exists at the target path\"\n      fail_action: \"Proceed only after explicit update intent\"\n\nworkflow_overview:\n  steps:\n    - id: step_1_request_analysis\n      purpose: \"Normalize inputs, validate invocation, and resolve output paths\"\n    - id: step_2_understanding\n      purpose: \"Capture the command purpose, workflow, inputs, tools, and boundaries\"\n    - id: step_3_planning\n      purpose: \"Define frontmatter, routing assets, mode behavior, and presentation boundary\"\n    - id: step_4_generation\n      purpose: \"Generate the command 4-file set from canonical templates\"\n    - id: step_5_validation\n      purpose: \"Validate frontmatter, YAML, paths, placeholders, and router thinness\"\n    - id: step_6_save_context\n      purpose: \"Persist spec context and emit completion status\"\n\nworkflow:\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE A: PLANNING (Steps 1-3)\n  # ═══════════════════════════════════════════════════════════════\n\n  step_1_request_analysis:\n    purpose: Parse inputs and validate command invocation (from UNIFIED SETUP PHASE)\n    activities:\n    - Confirm command_invocation from UNIFIED SETUP PHASE (Q0 or argument)\n    - Derive command_path from command_invocation unless explicit path is provided\n    - Confirm spec_path from UNIFIED SETUP PHASE (Q1 choice A/B/C/D)\n    - Resolve memory_choice via the context_loading block (Q4 if applicable); record result as memory_loaded\n    - Verify command invocation format and path mapping\n    - Check if command router or owned assets already exist at target paths\n    validation:\n      invocation_format: \"root /command or namespace /namespace:action\"\n      check_exists: true\n      command: \"ls [command_path] 2>/dev/null\"\n    outputs:\n    - command_invocation_validated\n    - command_path_confirmed\n    - command_exists_check\n    checkpoint:\n      question: \"Creating command '[command-invocation]' at [command-path]. Proceed?\"\n      options:\n      - label: \"A) Proceed\"\n        description: \"Create or update command with these settings\"\n      - label: \"B) Change invocation\"\n        description: \"Use a different command invocation\"\n      - label: \"C) Change output path\"\n        description: \"Use a different command path\"\n\n  step_1b_command_discovery:\n    purpose: Search for similar existing commands before creating or updating (MANDATORY)\n    gate_type: SOFT_BLOCK\n    enforcement: \"Warn if similar command exists, allow user override\"\n    activities:\n    - \"Use Glob to list .opencode/commands/**/*.md\"\n    - \"Use Grep to search for matching invocation names, descriptions, and workflow phrases\"\n    - \"Read exact matches and nearby namespace commands before planning\"\n    validation:\n      similar_exists_threshold: \"same invocation, same namespace/action, or significant description overlap\"\n      action_if_found: \"SOFT_BLOCK - Present findings to user\"\n    outputs:\n    - similar_commands_found: list_of_matching_commands\n    - reusable_patterns: patterns_to_consider\n    - proceed_recommendation: boolean\n    checkpoint:\n      condition: \"similar_commands_found.length > 0\"\n      question: \"Found similar command(s): [command_names]. Continue creating or updating this command?\"\n      options:\n      - label: \"A) Proceed anyway\"\n        description: \"Continue despite similar existing command\"\n      - label: \"B) Review existing first\"\n        description: \"Load and review the similar command before deciding\"\n      - label: \"C) Abort\"\n        description: \"Cancel command creation\"\n    skip_condition: \"User explicitly skips discovery\"\n\n  step_1c_spec_folder_setup:\n    purpose: Create documentation folder for tracking (if user chose B or C in Q1)\n    condition: \"spec_choice != D (Skip)\"\n    activities:\n    - IF spec_choice == B (Create new):\n      - Find next available spec number in the selected spec root\n      - \"Create folder: [spec-root]/[NNN]-[command-slug]/\"\n    - IF spec_choice == A or C (Use existing):\n      - Use selected spec_path\n    - \"Create or update Level 1 spec.md, plan.md, and tasks.md through the active spec-folder workflow; do not wire non-target packet template paths here\"\n    outputs:\n    - spec.md: created_or_updated\n    - plan.md: created_or_updated\n    - tasks.md: created_or_updated\n    checkpoint:\n      question: \"Spec folder created/confirmed. Continue to command contract phase?\"\n      options: checkpoint_options.standard\n\n  step_2_understanding:\n    purpose: Gather command purpose, workflow, inputs, tools, and boundaries (CRITICAL - DO NOT SKIP)\n    enforcement: MANDATORY\n    activities:\n    - Ask focused questions about the command's repeatable workflow\n    - Gather invocation purpose and expected user inputs\n    - Identify :auto and :confirm behavior\n    - Define least-privilege allowed-tools\n    - Identify visible prompts, dashboards, result templates, and next-step wording\n    - Identify destructive or privileged actions and required safety gates\n    questions:\n    - \"What should this slash command create, update, or route?\"\n    - \"What arguments and modes should it accept?\"\n    - \"Which tools does the workflow actually need?\"\n    - \"What user-facing prompts and results must be separated into presentation?\"\n    outputs:\n    - purpose_defined: \"clear repeatable command workflow\"\n    - inputs_defined: \"required arguments, optional flags, and modes\"\n    - tools_defined: \"least-privilege allowed-tools list\"\n    - boundaries_defined: \"router, YAML, and presentation ownership\"\n    validation: understanding_complete\n    checkpoint:\n      question: \"I've identified: Purpose=[purpose], Inputs=[inputs], Tools=[tools]. Is this command contract correct?\"\n      options:\n      - label: \"A) Approve\"\n        description: \"Command contract is correct\"\n      - label: \"B) Add more\"\n        description: \"Add additional workflow details\"\n      - label: \"C) Modify\"\n        description: \"Change existing command contract\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # 🔒 PHASE GATE: UNDERSTANDING → CONFIGURATION\n  # ═══════════════════════════════════════════════════════════════\n  phase_gate_understanding_to_configuration:\n    trigger: \"After Step 2 completes\"\n    enforcement: HARD_BLOCK\n    verification: |\n      BEFORE proceeding to Configuration Phase (Step 3):\n\n      VERIFY all understanding artifacts exist:\n      ├─ [ ] Invocation and output path clearly defined\n      ├─ [ ] Repeatable workflow purpose captured\n      ├─ [ ] Required arguments, modes, and tools documented\n      ├─ [ ] Router/YAML/presentation boundaries identified\n\n      IF any artifact missing:\n      └─ STOP → Return to Step 2 → Complete it → Return here\n\n      WHEN all artifacts verified:\n      └─ SET PHASE GATE STATUS: PASSED → Proceed to Step 3\n    action_if_failed: \"Return to incomplete step\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE B: IMPLEMENTATION (Steps 3-6)\n  # ═══════════════════════════════════════════════════════════════\n\n  step_3_planning:\n    purpose: Define command package, frontmatter, routing assets, and behavioral rules\n    activities:\n    - Confirm split 4-file package shape for workflow-backed command creation\n    - Define router frontmatter: description, argument-hint, allowed-tools\n    - Define asset paths for _auto.yaml, _confirm.yaml, and _presentation.txt\n    - Define :auto and :confirm behavior; confirm must equal auto plus checkpoints\n    - Define presentation sections for prompts, dashboard, result, and failure display\n    - Plan validation commands and grep checks\n    outputs:\n    - command_package_selected\n    - frontmatter_configured\n    - routing_assets_defined\n    - presentation_boundary_defined\n    - validation_plan_defined\n    validation: configuration_planned\n    checkpoint:\n      question: \"Configuration: Package=[package], Allowed Tools=[tools], Assets=[paths]. Approve?\"\n      options:\n      - label: \"A) Approve\"\n        description: \"Configuration is correct\"\n      - label: \"B) Modify tools\"\n        description: \"Adjust allowed-tools\"\n      - label: \"C) Modify assets\"\n        description: \"Adjust command asset plan\"\n\n  step_4_generation:\n    purpose: Create command 4-file set with router markdown, workflow YAML, and presentation contract\n    activities:\n    - Load command_template.md for command structure reference\n    - Load command_presentation_template.md for presentation structure reference\n    - Generate thin router markdown with asset table, execution order, routing rules, and presentation boundary\n    - Generate _auto.yaml with the workflow steps and no user approval checkpoints\n    - Generate _confirm.yaml with the same workflow plus checkpoint blocks\n    - Generate _presentation.txt with startup, setup, dashboard, completion, and failure displays\n    - Write files to the resolved command paths\n    - Verify each file exists and is readable\n    outputs:\n    - router_file_created\n    - auto_yaml_created\n    - confirm_yaml_created\n    - presentation_file_created\n    validation: files_created\n    checkpoint:\n      question: \"Command files generated. Review before validation?\"\n      options:\n      - label: \"A) Show router\"\n        description: \"Display router markdown summary\"\n      - label: \"B) Show assets\"\n        description: \"Display YAML and presentation summaries\"\n      - label: \"C) Proceed\"\n        description: \"Continue to validation\"\n\n  step_5_validation:\n    purpose: Frontmatter, YAML, path, structure, and leftover-source validation\n    enforcement: HARD_BLOCK\n    activities:\n    - Parse router frontmatter and verify required fields\n    - Parse _auto.yaml and _confirm.yaml as YAML when parser is available\n    - Verify all resource paths referenced in workflow assets exist on disk\n    - Verify confirm workflow mirrors auto workflow except checkpoint blocks and interactive execution settings\n    - Verify router stays thin and presentation owns visible templates\n    - Run validate_document.py if available\n    - Grep generated files for copied source workflow names\n    - IF validation fails: Fix issues and re-run\n    - Repeat until passing\n    outputs:\n    - frontmatter_validation_result: pass_or_fail\n    - yaml_validation_result: pass_or_fail\n    - path_validation_result: pass_or_fail\n    - leftover_source_check: pass_or_fail\n    validation: command_set_valid\n    checkpoint:\n      question: \"Validation complete. [PASS/FAIL]. Proceed?\"\n      options:\n      - label: \"A) Continue to save context\"\n        description: \"Validation passed, finalize command\"\n      - label: \"B) Review errors\"\n        description: \"Show detailed validation errors\"\n      - label: \"C) Fix issues\"\n        description: \"Address validation failures and revalidate\"\n\n  step_5b_quality_validation:\n    purpose: Quality-validate the created command artifact set\n    activities:\n    - \"Run command structural validation against the router markdown\"\n    - \"Validate frontmatter description budget and allowed-tools accuracy\"\n    - \"Review router/presentation split against create-command references\"\n    - \"Confirm the output package has exactly the expected owned files\"\n    on_low_score:\n      threshold: 70\n      action: \"Log warnings and suggest improvements; do not block workflow unless structural rules fail\"\n    outputs:\n    - quality_score: number\n    - validation_findings: list\n    - improvement_suggestions: list (if score < 70)\n    - description_length_warnings: list\n    checkpoint:\n      question: \"Quality validation complete (score: [quality_score]/100). Continue?\"\n      options:\n      - label: \"A) Accept and continue\"\n        description: \"Proceed to save context\"\n      - label: \"B) View findings\"\n        description: \"Show detailed review findings\"\n      - label: \"C) Address issues\"\n        description: \"Fix issues before continuing\"\n\n  step_6_save_context:\n    purpose: Preserve workflow decisions and context\n    condition: \"spec_path is not null\"\n    activities:\n    - Invoke system-spec-kit skill\n    - Document command creation decisions\n    - Record routing, frontmatter, tools, and presentation-boundary rationale\n    - Save validation results\n    - Update canonical spec documents\n    - Index canonical spec document for immediate search availability\n    outputs:\n    - implementation_summary: \"[spec_path]/implementation-summary.md\"\n    validation: context_saved\n    checkpoint:\n      question: \"Context saved. Command creation complete!\"\n      options:\n      - label: \"Done\"\n        description: \"Complete workflow\"\n      - label: \"View summary\"\n        description: \"Show final summary\"\n\n# ─────────────────────────────────────────────────────────────────\n# CIRCUIT BREAKER\n# ─────────────────────────────────────────────────────────────────\ncircuit_breaker:\n  consecutive_failure_threshold: 3\n  states:\n    closed: \"Normal operation\"\n    open: \"3+ failures — pause and report to user\"\n    half_open: \"Test with single retry before resuming\"\n  on_open:\n    action: \"Report failures to user with summary\"\n    suggest: \"Review inputs and try again, or escalate\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  invalid_command_invocation:\n    action: \"Show valid format (/command or /namespace:action), prompt for correction\"\n    example: \"Expected: /create:thing or /memory-save\"\n  command_already_exists:\n    action: \"Offer to update existing or choose a new invocation\"\n    options: [ \"Update existing\", \"Choose new invocation\", \"Cancel\" ]\n  yaml_parse_error:\n    action: \"Check workflow asset syntax, fix and re-validate\"\n    common_issues:\n    - \"Missing colon after field name\"\n    - \"Incorrect indentation (use 2 spaces)\"\n    - \"Unquoted strings with special characters\"\n    - \"Invalid block scalar indentation\"\n  missing_required_field:\n    action: \"Add the missing router frontmatter or workflow field and re-validate\"\n    required_fields: [ \"description\", \"argument-hint\", \"allowed-tools\" ]\n  missing_resource_path:\n    action: \"Remove fabricated path or replace with a verified on-disk path\"\n  presentation_boundary_violation:\n    action: \"Move prompts, dashboards, results, and next-step text from router into presentation asset\"\n\n# ─────────────────────────────────────────────────────────────────\n# INTERACTIVE EXECUTION\n# ─────────────────────────────────────────────────────────────────\ninteractive_execution:\n  principle: \"Execute workflow steps with user approval at each checkpoint\"\n  user_feedback_handling:\n    approve: \"Continue to next step\"\n    review: \"Show detailed output before proceeding\"\n    modify: \"Apply requested changes and re-validate\"\n    skip: \"Mark step as skipped with reason only when optional, continue\"\n\n# ─────────────────────────────────────────────────────────────────\n# QUALITY STANDARDS\n# ─────────────────────────────────────────────────────────────────\nquality_standards:\n  frontmatter_validation: MANDATORY\n  yaml_validation: MANDATORY\n  router_presentation_separation: MANDATORY\n  validation_pipeline:\n    stage_1: \"Router frontmatter parsing\"\n    stage_2: \"Required field check (description, argument-hint, allowed-tools)\"\n    stage_3: \"YAML workflow asset parsing\"\n    stage_4: \"Resource path existence check\"\n    stage_5: \"Leftover source-name grep\"\n  template_adherence: required\n  core_standards_reference: \".opencode/skills/sk-doc/create-command/SKILL.md\"\n\n# ─────────────────────────────────────────────────────────────────\n# COMPLETION REPORT TEMPLATE\n# ─────────────────────────────────────────────────────────────────\ncompletion_report:\n  template: |\n    Command Creation Complete\n\n    Command: [command-invocation]\n    Router: [command-path]\n    Assets:\n    - Auto workflow: [auto-yaml-path]\n    - Confirm workflow: [confirm-yaml-path]\n    - Presentation: [presentation-path]\n\n    Configuration:\n    - Allowed Tools: [allowed-tools]\n    - Modes: :auto and :confirm\n    - Router Boundary: thin router verified\n\n    Spec Folder: [spec path or none]\n    Memory: [saved/indexed/not applicable]\n\n    Validation:\n    - Router frontmatter: PASSED\n    - YAML workflows: PASSED\n    - Resource paths: PASSED\n    - Source leftovers: PASSED\n\n    Invocation:\n    - Type [command-invocation] [arguments]\n    - Add :auto for autonomous execution\n    - Add :confirm for checkpointed execution\n\n    Next Steps:\n    - Run the command with a small sample request\n    - Review generated prompts and result displays\n    - Tighten allowed-tools if validation finds unused tools\n\n    STATUS=OK PATH=[command-path]\n\n# ─────────────────────────────────────────────────────────────────\n# TERMINATION\n# ─────────────────────────────────────────────────────────────────\ntermination:\n  after_step: step_6_save_context\n  message: \"Command creation workflow complete.\"\n  next_steps:\n    - condition: \"Command needs testing\"\n      action: \"Run with a sample request matching the intended workflow\"\n    - condition: \"Command needs refinement\"\n      action: \"Iterate on prompts, routing, or allowed-tools based on testing\"\n    - condition: \"Context should be saved\"\n      action: \"Run /memory:save\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - \"Copy templates from canonical paths, never create from memory\"\n    - \"Run structural validation before claiming completion\"\n    - \"Pause at checkpoints for user approval\"\n    - \"Respect user feedback and modification requests\"\n    - \"Reference core_standards.md for formatting rules\"\n    - \"Validate workflow YAML syntax when parser support is available\"\n    - \"Keep routers thin when presentation assets exist\"\n    - \"Save context after successful completion when a spec path is present\"\n  NEVER:\n    - \"Skip validation steps\"\n    - \"Create documents without loading templates first\"\n    - \"Proceed without user approval at checkpoints\"\n    - \"Leave placeholder text in final output\"\n    - \"Invent template, script, or reference paths\"\n    - \"Ignore YAML parse errors\"\n    - \"Put presentation templates inside the router\"","lineStart":1,"lineEnd":680,"totalLines":680,"truncated":false}},"title":".opencode/commands/create/assets/create_command_confirm.yaml","time":{"start":1784188289153,"end":1784188289163}},"id":"prt_f69e8c07f001XFXUYR5yV9j7Kv","sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","messageID":"msg_f69e8440b0015aGlejQq2oGzhH"}}
{"type":"tool_use","timestamp":1784188289167,"sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","part":{"type":"tool","tool":"read","callID":"call_7ddb2f76c49a43119f9b49fb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_command_auto.yaml"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_command_auto.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # OPENCODE CREATE: COMMAND AUTHORING WORKFLOW (AUTO MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: # Mode: autonomous (no user approval gates)\n5: # Note: This workflow executes all steps sequentially with\n6: #       continuous self-validation. Pauses only if confidence < 40%.\n7: # ─────────────────────────────────────────────────────────────────\n8: role: Expert Slash Command Author using sk-doc create-command packet\n9: purpose: Create production-ready OpenCode slash command 4-file sets with router/presentation separation\n10: action: Guide command creation from invocation contract through validation with frontmatter, routing, YAML workflow, and presentation verification\n11: \n12: # ─────────────────────────────────────────────────────────────────\n13: # PREREQUISITE: CREATE-COMMAND PACKET VERIFICATION\n14: # ─────────────────────────────────────────────────────────────────\n15: # This workflow REQUIRES the sk-doc create-command packet for:\n16: #   • Command invocation and path rules\n17: #   • Argument-hint and allowed-tools standards\n18: #   • Router/presentation separation\n19: #   • Canonical command and presentation templates\n20: #\n21: # PHASE 0 in the presentation contract verifies packet resources BEFORE\n22: # this YAML workflow loads. If you're executing this workflow,\n23: # create-command verification has already passed.\n24: #\n25: # To invoke correctly: /create:command <command-invocation>\n26: # ─────────────────────────────────────────────────────────────────\n27: \n28: operating_mode:\n29:   workflow: sequential_6_step\n30:   workflow_compliance: MANDATORY\n31:   workflow_execution: autonomous\n32:   approvals: none\n33:   tracking: progressive_task_checklists\n34:   validation: continuous_self_validation\n35:   permission_configuration: least_privilege_allowed_tools\n36:   description: |\n37:     Executes the 6-step command authoring workflow without step-by-step approval.\n38:     Pauses only if confidence drops below threshold or structural validation fails.\n39: \n40: development_philosophy:\n41:   principle: \"Resolve invocation and repeatable workflow before writing files\"\n42:   approach: \"Understand → Plan → Generate → Validate\"\n43:   mandate: \"Command contract first, then routing assets, then presentation text\"\n44: \n45: runtime_command_path_resolution:\n46:   root_command: .opencode/commands/[command].md\n47:   namespace_command: .opencode/commands/[namespace]/[action].md\n48:   split_assets: .opencode/commands/[namespace]/assets/[namespace]_[action]_[kind]\n49: \n50: # ─────────────────────────────────────────────────────────────────\n51: # CONFIDENCE & CLARIFICATION FRAMEWORK\n52: # ─────────────────────────────────────────────────────────────────\n53: confidence_framework:\n54:   thresholds:\n55:     high: { range: \"80-100%\", action: \"Proceed with citable source\" }\n56:     medium: { range: \"40-79%\", action: \"Proceed with caution, document assumptions\" }\n57:     low: { range: \"0-39%\", action: \"STOP - Ask clarification with A/B/C options\" }\n58: \n59:   scoring_weights:\n60:     invocation_clarity: 0.30\n61:     workflow_specificity: 0.25\n62:     tool_permission_clarity: 0.25\n63:     presentation_boundary_defined: 0.20\n64: \n65:   clarification_format: |\n66:     \"I need clarity (confidence: [NN%]). Which approach:\n67:     - A) [option with brief rationale]\n68:     - B) [option with brief rationale]\n69:     - C) [option with brief rationale]\"\n70: \n71:   escalation:\n72:     timebox_minutes: 10\n73:     failed_attempts_threshold: 2\n74:     action: \"Present options to user with current findings\"\n75: \n76: # ─────────────────────────────────────────────────────────────────\n77: # REQUEST ANALYSIS FRAMEWORK\n78: # ─────────────────────────────────────────────────────────────────\n79: request_analysis_framework:\n80:   code_search_note: \"Use Grep/Glob for existing command files and direct Read for exact contents. memory_search is for spec docs/memory, not arbitrary code.\"\n81:   solution_flow:\n82:   - \"Parse carefully: What slash command is ACTUALLY requested?\"\n83:   - \"Gather Context: Read target packet resources and nearby commands\"\n84:   - \"Identify Approach: SIMPLEST command set that matches the workflow\"\n85:   - \"Validate Choice: Follow create-command packet patterns\"\n86:   - \"Clarify If Needed: If <80% confidence, ask\"\n87:   - \"Scope Check: Solving ONLY what was asked?\"\n88:   - \"Execute: Implement with minimal complexity\"\n89: \n90:   pre_change_validation:\n91:     items:\n92:     - \"Command invocation format validated? (/name or /namespace:action)\"\n93:     - \"Command output paths confirmed?\"\n94:     - \"Spec folder created or selected?\"\n95:     - \"Workflow purpose and inputs gathered?\"\n96:     - \"Confidence >=80%? (if not: ask)\"\n97:     stop_conditions: [ \"Any item unchecked\", \"No spec folder\" ]\n98:     stop_action: \"STOP and address before proceeding\"\n99: \n100: # ─────────────────────────────────────────────────────────────────\n101: # USER INPUTS (From gate outputs)\n102: # ─────────────────────────────────────────────────────────────────\n103: user_inputs:\n104:   command_invocation: |\n105:     [COMMAND_INVOCATION]\n106:     Slash command invocation, either /command or /namespace:action.\n107:     FROM UNIFIED SETUP PHASE (Q0 or command argument).\n108: \n109:   command_path: |\n110:     [COMMAND_PATH]\n111:     Output router path derived from command_invocation.\n112:     FROM UNIFIED SETUP PHASE (derived path or explicit --path override).\n113: \n114:   spec_path: |\n115:     [SPEC_PATH]\n116:     Spec folder for tracking this work.\n117:     FROM UNIFIED SETUP PHASE (Q1 choice A/B/C/D).\n118: \n119:   memory_choice: |\n120:     [MEMORY_CHOICE]\n121:     Prior-session context loading choice (A/B/C).\n122:     FROM UNIFIED SETUP PHASE (Q4 if applicable).\n123: \n124: # ─────────────────────────────────────────────────────────────────\n125: # FIELD HANDLING\n126: # ─────────────────────────────────────────────────────────────────\n127: field_handling:\n128:   command_invocation:\n129:     validation: \"must start with /; root commands use lowercase hyphen-case; namespace commands use /namespace:action\"\n130:     required: true\n131: \n132:   command_package_shape:\n133:     validation: \"must be split_4_file_set for this workflow\"\n134:     default: \"split_4_file_set\"\n135:     note: \"Creates router .md plus _auto.yaml, _confirm.yaml, and _presentation.txt assets\"\n136: \n137:   defaults:\n138:     commands_root: \".opencode/commands/\"\n139:     execution_mode: \"confirm_when_omitted\"\n140:     spec_path_from_phase: \"FROM USER CHOICE IN SETUP PHASE\"\n141: \n142: input_contract:\n143:   required:\n144:     - create_command_verified\n145:     - command_invocation\n146:     - command_path\n147:     - spec_path\n148:   optional:\n149:     - memory_choice\n150:     - command_package_shape\n151: \n152: # ─────────────────────────────────────────────────────────────────\n153: # DOCUMENTATION LEVEL\n154: # ─────────────────────────────────────────────────────────────────\n155: documentation_level:\n156:   default: \"Level 1 (Baseline)\"\n157:   required_files:\n158:   - spec.md\n159:   - plan.md\n160:   - tasks.md\n161:   note: \"Command creation typically Level 1 unless destructive behavior, broad routing, or multi-command orchestration increases risk\"\n162: \n163: # ─────────────────────────────────────────────────────────────────\n164: # COMMAND CREATION TEMPLATES\n165: # ─────────────────────────────────────────────────────────────────\n166: command_templates:\n167:   command_markdown: .opencode/skills/sk-doc/create-command/assets/command_template.md\n168:   presentation_contract: .opencode/skills/sk-doc/create-command/assets/command_presentation_template.md\n169: \n170: command_scripts:\n171:   packet_local: \"No packet-local scripts are wired; follow create-command/SKILL.md validation instructions.\"\n172: \n173: command_references:\n174:   command_creation: .opencode/skills/sk-doc/create-command/SKILL.md\n175:   route_map: .opencode/skills/sk-doc/create-command/references/README.md\n176:   worked_example: .opencode/skills/sk-doc/create-command/references/worked_example.md\n177:   router_presentation_split: .opencode/skills/sk-doc/create-command/references/router_presentation_split.md\n178:   argument_hints_and_modes: .opencode/skills/sk-doc/create-command/references/argument_hints_and_modes.md\n179:   common_pitfalls: .opencode/skills/sk-doc/create-command/references/common_pitfalls.md\n180: \n181: # ─────────────────────────────────────────────────────────────────\n182: # CONTEXT LOADING\n183: # ─────────────────────────────────────────────────────────────────\n184: context_loading:\n185:   trigger: \"During UNIFIED SETUP PHASE, non-interactive resolution before Step 1\"\n186:   applies_when: \"An existing spec_path with handover.md or _memory.continuity in implementation-summary.md present from a prior command-creation session\"\n187:   auto_resolution:\n188:     default: \"If prior context exists (handover.md <24h old or _memory.continuity present), load it automatically via memory_context; sets memory_loaded: handover. Otherwise skip; sets memory_loaded: skipped.\"\n189:     override: \"Honor memory_choice if explicitly supplied as a command argument or marker (A = handover, B = canonical docs, C = skip)\"\n190:   mcp_integration:\n191:     tool: memory_context\n192:     note: \"Call MCP tools directly - NEVER through Code Mode\"\n193:     parameters: { input: \"resume previous work on {spec_path}\", mode: \"resume\", profile: \"resume\", specFolder: \"{spec_path}\", includeContent: true }\n194:     transport_fallback: \"If MCP tools are missing or erroring while the daemon is otherwise warm, use: node .opencode/bin/spec-memory.cjs memory_context --json '{\\\"input\\\":\\\"resume previous work\\\",\\\"mode\\\":\\\"resume\\\"}' --format json --timeout-ms 3000 --warm-only. Exit 75 = retryable backend unavailability.\"\n195:   output: memory_loaded\n196: \n197: # ─────────────────────────────────────────────────────────────────\n198: # WORKFLOW ENFORCEMENT (CRITICAL)\n199: # ─────────────────────────────────────────────────────────────────\n200: workflow_enforcement:\n201:   mode: strict\n202:   step_order: sequential_mandatory\n203:   skip_allowed: false\n204: \n205:   phase_gate:\n206:     location: \"Between Step 2 and Step 3\"\n207:     purpose: \"Verify command contract complete before package planning\"\n208:     requirements:\n209:     - \"Invocation and output paths clearly defined\"\n210:     - \"Repeatable command workflow captured\"\n211:     - \"Tool and presentation boundaries documented\"\n212:     action_if_failed: \"STOP and return to incomplete step\"\n213: \n214:   critical_steps:\n215:     step_2_understanding:\n216:       enforcement: \"MUST gather purpose, inputs, modes, tools, and safety boundaries\"\n217:       verification: \"Self-validate command contract before proceeding\"\n218:     step_3_planning:\n219:       enforcement: \"MUST define frontmatter, routing assets, and presentation boundary\"\n220:       verification: \"All command package decisions documented\"\n221:     step_4_generation:\n222:       enforcement: \"MUST use create-command templates and real resource paths\"\n223:       verification: \"Router is thin; assets own workflow and presentation\"\n224:     step_5_validation:\n225:       enforcement: \"MUST run structural and path validation\"\n226:       verification: \"Frontmatter parses, assets exist, and no placeholders remain\"\n227: \n228: # ─────────────────────────────────────────────────────────────────\n229: # WORKFLOW (6 STEPS - AUTONOMOUS)\n230: # ─────────────────────────────────────────────────────────────────\n231: gate_logic:\n232:   hard:\n233:     H0_create_command_verified:\n234:       description: \"create-command packet verification must have passed in Phase 0\"\n235:       fail_action: \"STOP and return to the command setup phase\"\n236:     H1_required_fields:\n237:       description: \"Required setup fields must be present before generation\"\n238:       fail_action: \"STOP and collect missing inputs\"\n239:     H2_generation_contract:\n240:       description: \"Generated command set must follow the create-command template and router/presentation contract\"\n241:       fail_action: \"Fix the generated output before continuing\"\n242:   soft:\n243:     S1_existing_command:\n244:       description: \"Warn when a command already exists at the target path\"\n245:       fail_action: \"Proceed only after explicit update intent\"\n246: \n247: workflow_overview:\n248:   steps:\n249:     - id: step_1_request_analysis\n250:       purpose: \"Normalize inputs, validate invocation, and resolve output paths\"\n251:     - id: step_2_understanding\n252:       purpose: \"Capture the command purpose, workflow, inputs, tools, and boundaries\"\n253:     - id: step_3_planning\n254:       purpose: \"Define frontmatter, routing assets, mode behavior, and presentation boundary\"\n255:     - id: step_4_generation\n256:       purpose: \"Generate the command 4-file set from canonical templates\"\n257:     - id: step_5_validation\n258:       purpose: \"Validate frontmatter, YAML, paths, placeholders, and router thinness\"\n259:     - id: step_6_save_context\n260:       purpose: \"Persist spec context and emit completion status\"\n261: \n262: workflow:\n263:   # ═══════════════════════════════════════════════════════════════\n264:   # PHASE A: PLANNING (Steps 1-3)\n265:   # ═══════════════════════════════════════════════════════════════\n266: \n267:   step_1_request_analysis:\n268:     purpose: Parse inputs and validate command invocation (from UNIFIED SETUP PHASE)\n269:     activities:\n270:     - Confirm command_invocation from UNIFIED SETUP PHASE (Q0 or argument)\n271:     - Derive command_path from command_invocation unless explicit path is provided\n272:     - Confirm spec_path from UNIFIED SETUP PHASE (Q1 choice A/B/C/D)\n273:     - Resolve memory_choice via the context_loading block (Q4 if applicable); record result as memory_loaded\n274:     - Verify command invocation format and path mapping\n275:     - Check if command router or owned assets already exist at target paths\n276:     validation:\n277:       invocation_format: \"root /command or namespace /namespace:action\"\n278:       check_exists: true\n279:       command: \"ls [command_path] 2>/dev/null\"\n280:     outputs:\n281:     - command_invocation_validated\n282:     - command_path_confirmed\n283:     - command_exists_check\n284: \n285:   step_1b_command_discovery:\n286:     purpose: Search for similar existing commands before creating or updating (MANDATORY)\n287:     gate_type: SOFT_BLOCK\n288:     enforcement: \"Warn if similar command exists, allow user override\"\n289:     activities:\n290:     - \"Use Glob to list .opencode/commands/**/*.md\"\n291:     - \"Use Grep to search for matching invocation names, descriptions, and workflow phrases\"\n292:     - \"Read exact matches and nearby namespace commands before planning\"\n293:     validation:\n294:       similar_exists_threshold: \"same invocation, same namespace/action, or significant description overlap\"\n295:       action_if_found: \"Log finding and proceed unless exact duplicate conflicts with requested update intent\"\n296:     outputs:\n297:     - similar_commands_found: list_of_matching_commands\n298:     - reusable_patterns: patterns_to_consider\n299:     - proceed_recommendation: boolean\n300:     auto_decision: \"Proceed unless exact invocation conflict contradicts requested intent; log similar commands for reference\"\n301:     skip_condition: \"User explicitly skips discovery\"\n302: \n303:   step_1c_spec_folder_setup:\n304:     purpose: Create documentation folder for tracking (if user chose B or C in Q1)\n305:     condition: \"spec_choice != D (Skip)\"\n306:     activities:\n307:     - IF spec_choice == B (Create new):\n308:       - Find next available spec number in the selected spec root\n309:       - \"Create folder: [spec-root]/[NNN]-[command-slug]/\"\n310:     - IF spec_choice == A or C (Use existing):\n311:       - Use selected spec_path\n312:     - \"Create or update Level 1 spec.md, plan.md, and tasks.md through the active spec-folder workflow; do not wire non-target packet template paths here\"\n313:     outputs:\n314:     - spec.md: created_or_updated\n315:     - plan.md: created_or_updated\n316:     - tasks.md: created_or_updated\n317: \n318:   step_2_understanding:\n319:     purpose: Gather command purpose, workflow, inputs, tools, and boundaries (CRITICAL - DO NOT SKIP)\n320:     enforcement: MANDATORY\n321:     activities:\n322:     - Ask focused questions about the command's repeatable workflow\n323:     - Gather invocation purpose and expected user inputs\n324:     - Identify :auto and :confirm behavior\n325:     - Define least-privilege allowed-tools\n326:     - Identify visible prompts, dashboards, result templates, and next-step wording\n327:     - Identify destructive or privileged actions and required safety gates\n328:     questions:\n329:     - \"What should this slash command create, update, or route?\"\n330:     - \"What arguments and modes should it accept?\"\n331:     - \"Which tools does the workflow actually need?\"\n332:     - \"What user-facing prompts and results must be separated into presentation?\"\n333:     prompt_template: |\n334:       ┌────────────────────────────────────────────────────────────┐\n335:       │ \"What command workflow should be authored?\"                │\n336:       │                                                            │\n337:       │ Please provide:                                            │\n338:       │ - Purpose: What repeatable workflow does it run?           │\n339:       │ - Inputs: Required arguments, optional flags, modes         │\n340:       │ - Tools: Least-privilege tool list                         │\n341:       │ - Boundary: What belongs in router vs presentation/YAML     │\n342:       └────────────────────────────────────────────────────────────┘\n343:     outputs:\n344:     - purpose_defined: \"clear repeatable command workflow\"\n345:     - inputs_defined: \"required arguments, optional flags, and modes\"\n346:     - tools_defined: \"least-privilege allowed-tools list\"\n347:     - boundaries_defined: \"router, YAML, and presentation ownership\"\n348:     validation: understanding_complete\n349: \n350:   # ═══════════════════════════════════════════════════════════════\n351:   # 🔒 PHASE GATE: UNDERSTANDING → CONFIGURATION\n352:   # ═══════════════════════════════════════════════════════════════\n353:   phase_gate_understanding_to_configuration:\n354:     trigger: \"After Step 2 completes\"\n355:     enforcement: HARD_BLOCK\n356:     verification: |\n357:       BEFORE proceeding to Configuration Phase (Step 3):\n358: \n359:       VERIFY all understanding artifacts exist:\n360:       ├─ [ ] Invocation and output path clearly defined\n361:       ├─ [ ] Repeatable workflow purpose captured\n362:       ├─ [ ] Required arguments, modes, and tools documented\n363:       ├─ [ ] Router/YAML/presentation boundaries identified\n364: \n365:       IF any artifact missing:\n366:       └─ STOP → Return to Step 2 → Complete it → Return here\n367: \n368:       WHEN all artifacts verified:\n369:       └─ SET PHASE GATE STATUS: PASSED → Proceed to Step 3\n370:     action_if_failed: \"Return to incomplete step\"\n371: \n372:   # ═══════════════════════════════════════════════════════════════\n373:   # PHASE B: IMPLEMENTATION (Steps 3-6)\n374:   # ═══════════════════════════════════════════════════════════════\n375: \n376:   step_3_planning:\n377:     purpose: Define command package, frontmatter, routing assets, and behavioral rules\n378:     activities:\n379:     - Confirm split 4-file package shape for workflow-backed command creation\n380:     - Define router frontmatter: description, argument-hint, allowed-tools\n381:     - Define asset paths for _auto.yaml, _confirm.yaml, and _presentation.txt\n382:     - Define :auto and :confirm behavior; confirm must equal auto plus checkpoints\n383:     - Define presentation sections for prompts, dashboard, result, and failure display\n384:     - Plan validation commands and grep checks\n385:     command_type_selection:\n386:       split_mode_based:\n387:         description: \"Thin router plus owned auto, confirm, and presentation assets\"\n388:         invocation: \"/namespace:action [:auto|:confirm]\"\n389:         use_case: \"Workflow-backed command sets with visible prompts and checkpointed mode\"\n390:     permission_planning:\n391:       core_tools:\n392:         read: { purpose: \"Read templates and existing commands\", default: \"allow\" }\n393:         write: { purpose: \"Create command files\", default: \"allow\" }\n394:         edit: { purpose: \"Modify existing command files\", default: \"allow\" }\n395:         bash: { purpose: \"Run validators\", default: \"allow\" }\n396:         grep: { purpose: \"Search source leftovers and existing patterns\", default: \"allow\" }\n397:         glob: { purpose: \"Find command and resource paths\", default: \"allow\" }\n398:       extended_tools:\n399:         todowrite: { purpose: \"Track multi-step command creation\", default: \"allow\" }\n400:         memory_save: { purpose: \"Index canonical spec context when requested\", default: \"allow\" }\n401:       permission_values:\n402:         allow: \"Available for workflow execution\"\n403:         omit: \"Do not include in allowed-tools\"\n404:     behavioral_rules_template: |\n405:       ALWAYS:\n406:         - Keep routers thin when presentation assets exist\n407:         - Wire only paths verified on disk\n408:         - Keep confirm behavior equal to auto plus approval checkpoints\n409: \n410:       NEVER:\n411:         - Put dashboard/result templates in the thin router\n412:         - Invent scripts, templates, or references\n413:         - Leave source workflow names or placeholders in generated files\n414: \n415:       ESCALATE IF:\n416:         - Invocation, package shape, or destructive behavior is unclear\n417:     outputs:\n418:     - command_package_selected\n419:     - frontmatter_configured\n420:     - routing_assets_defined\n421:     - presentation_boundary_defined\n422:     - validation_plan_defined\n423:     validation: configuration_planned\n424: \n425:   step_4_generation:\n426:     purpose: Create command 4-file set with router markdown, workflow YAML, and presentation contract\n427:     activities:\n428:     - Load command_template.md for command structure reference\n429:     - Load command_presentation_template.md for presentation structure reference\n430:     - Generate thin router markdown with asset table, execution order, routing rules, and presentation boundary\n431:     - Generate _auto.yaml with the workflow steps and no user approval checkpoints\n432:     - Generate _confirm.yaml with the same workflow plus checkpoint blocks\n433:     - Generate _presentation.txt with startup, setup, dashboard, completion, and failure displays\n434:     - Write files to the resolved command paths\n435:     - Verify each file exists and is readable\n436:     frontmatter_template: |\n437:       ---\n438:       description: [Action-oriented single-line description]\n439:       argument-hint: \"<required> [optional] [:auto|:confirm]\"\n440:       allowed-tools: Read, Write, Edit, Bash, Glob, Grep\n441:       ---\n442:     quality_requirements:\n443:       router: \"thin; no inline startup prompts, dashboard templates, or result templates\"\n444:       yaml: \"auto and confirm share the same workflow; confirm adds checkpoints only\"\n445:       presentation: \"owns all visible prompt and result wording\"\n446:       resources: \"only verified on-disk paths\"\n447:     outputs:\n448:     - router_file_created\n449:     - auto_yaml_created\n450:     - confirm_yaml_created\n451:     - presentation_file_created\n452:     validation: files_created\n453: \n454:   step_5_validation:\n455:     purpose: Frontmatter, YAML, path, structure, and leftover-source validation\n456:     enforcement: HARD_BLOCK\n457:     activities:\n458:     - Parse router frontmatter and verify required fields\n459:     - Parse _auto.yaml and _confirm.yaml as YAML when parser is available\n460:     - Verify all resource paths referenced in workflow assets exist on disk\n461:     - Verify confirm workflow mirrors auto workflow except checkpoint blocks and interactive execution settings\n462:     - Verify router stays thin and presentation owns visible templates\n463:     - Run validate_document.py if available\n464:     - Grep generated files for copied source workflow names\n465:     - IF validation fails: Fix issues and re-run\n466:     - Repeat until passing\n467:     validation_command: |\n468:       Run the validators specified by .opencode/skills/sk-doc/create-command/SKILL.md Step 13 when available.\n469:       grep -R \"[source-workflow-name]\" [generated-file-list]\n470:     quality_gates:\n471:       frontmatter_parse: \"must pass\"\n472:       required_fields: \"description, argument-hint, allowed-tools\"\n473:       asset_paths_exist: \"all referenced resource and owned asset paths exist\"\n474:       router_thinness: \"no presentation templates in router\"\n475:       confirm_consistency: \"same workflow as auto plus checkpoints\"\n476:       no_source_leftovers: \"must pass\"\n477:       enforcement: HARD_BLOCK\n478:     fix_workflow: |\n479:       IF validation fails:\n480:       1. Review specific errors from validation output\n481:       2. Fix issues in generated files\n482:       3. Re-run validation command\n483:       4. Repeat until passing\n484:     outputs:\n485:     - frontmatter_validation_result: pass_or_fail\n486:     - yaml_validation_result: pass_or_fail\n487:     - path_validation_result: pass_or_fail\n488:     - leftover_source_check: pass_or_fail\n489:     validation: command_set_valid\n490: \n491:   step_5b_quality_validation:\n492:     purpose: Quality-validate the created command artifact set\n493:     template_contract:\n494:       source: \"sk-doc create-command\"\n495:       validators: \"validate_document.py + extract_structure.py + quick_validate.py when applicable\"\n496:       precedence: \"Template compliance, router/presentation separation, and description-length budget are all checked before completion.\"\n497:     activities:\n498:     - \"Run command structural validation against the router markdown\"\n499:     - \"Validate frontmatter description budget and allowed-tools accuracy\"\n500:     - \"Review router/presentation split against create-command references\"\n501:     - \"Confirm the output package has exactly the expected owned files\"\n502:     on_low_score:\n503:       threshold: 70\n504:       action: \"Log warnings and suggest improvements; do not block workflow unless structural rules fail\"\n505:     description_budget:\n506:       soft_target: 110\n507:       hard_cap: 1536\n508:       reference: \".opencode/skills/sk-doc/create-command/assets/command_template.md\"\n509:     outputs:\n510:     - quality_score: number\n511:     - validation_findings: list\n512:     - improvement_suggestions: list (if score < 70)\n513:     - description_length_warnings: list\n514: \n515:   step_6_save_context:\n516:     purpose: Preserve workflow decisions and context\n517:     condition: \"spec_path is not null\"\n518:     activities:\n519:     - Invoke system-spec-kit skill\n520:     - Document command creation decisions\n521:     - Record routing, frontmatter, tools, and presentation-boundary rationale\n522:     - Save validation results\n523:     - Update canonical spec documents\n524:     - Index canonical spec document for immediate search availability\n525:     tool_invocation:\n526:       command: \"Use the active spec-folder context-saving workflow\"\n527:       note: \"Do not wire non-target packet resource paths in this command asset\"\n528:     memory_content:\n529:       include:\n530:       - Command invocation and purpose\n531:       - Output file paths\n532:       - Mode and routing decisions\n533:       - Allowed-tools rationale\n534:       - Router/presentation boundary decisions\n535:       - Validation results\n536:     outputs:\n537:     - implementation_summary: \"[spec_path]/implementation-summary.md\"\n538:     validation: context_saved\n539: \n540:     # ── SEMANTIC MEMORY INTEGRATION ─────────────────────────────────\n541:     post_save_indexing:\n542:       purpose: \"Index the canonical spec document immediately for search availability\"\n543:       mcp_tool: memory_save\n544:       invocation: |\n545:         memory_save({\n546:           filePath: \"[spec_path]/implementation-summary.md\"\n547:         })\n548:       critical_note: \"Call semantic memory MCP directly. The save target is a canonical spec document.\"\n549:       when: \"Immediately after implementation-summary.md is written to disk\"\n550: \n551:     anchor_requirements:\n552:       enforcement: MANDATORY\n553:       minimum_anchors: 2\n554:       pattern: \"[context-type]-[keywords]-[spec-number]\"\n555:       format: \"<!-- ANCHOR:ID --> content <!-- /ANCHOR:ID -->\"\n556:       case: \"UPPERCASE recommended for visibility\"\n557:       required_sections:\n558:       - context_type: \"general\"\n559:         section: \"Session summary with command creation outcomes\"\n560:         example_id: \"GENERAL-COMMAND-SUMMARY-{spec#}\"\n561:         example: |\n562:           <!-- ANCHOR:GENERAL-COMMAND-SUMMARY-{spec#} -->\n563:           ## Session Summary\n564:           Created command X with router/assets Y...\n565:           <!-- /ANCHOR:GENERAL-COMMAND-SUMMARY-{spec#} -->\n566:       - context_type: \"decision\"\n567:         section: \"Key decisions made during command creation\"\n568:         example_id: \"DECISION-COMMAND-CONFIG-{spec#}\"\n569:         example: |\n570:           <!-- ANCHOR:DECISION-COMMAND-CONFIG-{spec#} -->\n571:           ## Key Decisions\n572:           - Chose split command set because...\n573:           - Allowed-tools rationale...\n574:           <!-- /ANCHOR:DECISION-COMMAND-CONFIG-{spec#} -->\n575:       optional_sections:\n576:       - context_type: \"implementation\"\n577:         section: \"Command file structure and assets added\"\n578:         example_id: \"IMPLEMENTATION-COMMAND-STRUCTURE-{spec#}\"\n579:       - context_type: \"general\"\n580:         section: \"Validation results and quality checks\"\n581:         example_id: \"GENERAL-VALIDATION-{spec#}\"\n582:       benefit: \"Anchor-based retrieval keeps command decisions recoverable\"\n583:       reference: \"See /memory:save Step 3 for full anchor documentation\"\n584: \n585:     importance_tier:\n586:       assign: important\n587:       rationale: \"Command creation captures reusable workflow and routing decisions\"\n588:       promotion_note: \"Use memory_update() to promote to 'critical' if this command becomes foundational\"\n589:       tier_reference: |\n590:         constitutional: Core project rules (auto-surface always)\n591:         critical: Foundational decisions (high priority in search)\n592:         important: Significant work like command creation (this workflow)\n593:         normal: Standard context (default)\n594:         temporary: Short-term notes\n595:         deprecated: Outdated but retained\n596: \n597: # ─────────────────────────────────────────────────────────────────\n598: # CIRCUIT BREAKER\n599: # ─────────────────────────────────────────────────────────────────\n600: circuit_breaker:\n601:   consecutive_failure_threshold: 3\n602:   states:\n603:     closed: \"Normal operation\"\n604:     open: \"3+ failures — pause and report to user\"\n605:     half_open: \"Test with single retry before resuming\"\n606:   on_open:\n607:     action: \"Report failures to user with summary\"\n608:     suggest: \"Review inputs and try again, or escalate\"\n609: \n610: # ─────────────────────────────────────────────────────────────────\n611: # ERROR RECOVERY\n612: # ─────────────────────────────────────────────────────────────────\n613: error_recovery:\n614:   invalid_command_invocation:\n615:     action: \"Show valid format (/command or /namespace:action), prompt for correction\"\n616:     example: \"Expected: /create:thing or /memory-save\"\n617:   command_already_exists:\n618:     action: \"Offer to update existing or choose a new invocation\"\n619:     options: [ \"Update existing\", \"Choose new invocation\", \"Cancel\" ]\n620:   yaml_parse_error:\n621:     action: \"Check workflow asset syntax, fix and re-validate\"\n622:     common_issues:\n623:     - \"Missing colon after field name\"\n624:     - \"Incorrect indentation (use 2 spaces)\"\n625:     - \"Unquoted strings with special characters\"\n626:     - \"Invalid block scalar indentation\"\n627:   missing_required_field:\n628:     action: \"Add the missing router frontmatter or workflow field and re-validate\"\n629:     required_fields: [ \"description\", \"argument-hint\", \"allowed-tools\" ]\n630:   missing_resource_path:\n631:     action: \"Remove fabricated path or replace with a verified on-disk path\"\n632:   presentation_boundary_violation:\n633:     action: \"Move prompts, dashboards, results, and next-step text from router into presentation asset\"\n634: \n635: # ─────────────────────────────────────────────────────────────────\n636: # AUTONOMOUS EXECUTION\n637: # ─────────────────────────────────────────────────────────────────\n638: autonomous_execution:\n639:   validation_approach: \"Continuous self-validation at each step\"\n640:   error_handling: \"Auto-recover if possible, halt on critical failures\"\n641:   progress_reporting: \"Brief status updates between steps\"\n642: \n643: # ─────────────────────────────────────────────────────────────────\n644: # QUALITY STANDARDS\n645: # ─────────────────────────────────────────────────────────────────\n646: quality_standards:\n647:   frontmatter_validation: MANDATORY\n648:   yaml_validation: MANDATORY\n649:   router_presentation_separation: MANDATORY\n650:   validation_pipeline:\n651:     stage_1: \"Router frontmatter parsing\"\n652:     stage_2: \"Required field check (description, argument-hint, allowed-tools)\"\n653:     stage_3: \"YAML workflow asset parsing\"\n654:     stage_4: \"Resource path existence check\"\n655:     stage_5: \"Leftover source-name grep\"\n656:   template_adherence: required\n657:   core_standards_reference: \".opencode/skills/sk-doc/create-command/SKILL.md\"\n658: \n659: # ─────────────────────────────────────────────────────────────────\n660: # COMPLETION REPORT TEMPLATE\n661: # ─────────────────────────────────────────────────────────────────\n662: completion_report:\n663:   template: |\n664:     Command Creation Complete\n665: \n666:     Command: [command-invocation]\n667:     Router: [command-path]\n668:     Assets:\n669:     - Auto workflow: [auto-yaml-path]\n670:     - Confirm workflow: [confirm-yaml-path]\n671:     - Presentation: [presentation-path]\n672: \n673:     Configuration:\n674:     - Allowed Tools: [allowed-tools]\n675:     - Modes: :auto and :confirm\n676:     - Router Boundary: thin router verified\n677: \n678:     Spec Folder: [spec path or none]\n679:     Memory: [saved/indexed/not applicable]\n680: \n681:     Validation:\n682:     - Router frontmatter: PASSED\n683:     - YAML workflows: PASSED\n684:     - Resource paths: PASSED\n685:     - Source leftovers: PASSED\n686: \n687:     Invocation:\n688:     - Type [command-invocation] [arguments]\n689:     - Add :auto for autonomous execution\n690:     - Add :confirm for checkpointed execution\n691: \n692:     Next Steps:\n693:     - Run the command with a small sample request\n694:     - Review generated prompts and result displays\n695:     - Tighten allowed-tools if validation finds unused tools\n696: \n697:     STATUS=OK PATH=[command-path]\n698: \n699: # ─────────────────────────────────────────────────────────────────\n700: # TERMINATION\n701: # ─────────────────────────────────────────────────────────────────\n702: termination:\n703:   after_step: step_6_save_context\n704:   message: \"Command creation workflow complete.\"\n705:   next_steps:\n706:     - condition: \"Command needs testing\"\n707:       action: \"Run with a sample request matching the intended workflow\"\n708:     - condition: \"Command needs refinement\"\n709:       action: \"Iterate on prompts, routing, or allowed-tools based on testing\"\n710:     - condition: \"Context should be saved\"\n711:       action: \"Run /memory:save\"\n712: \n713: # ─────────────────────────────────────────────────────────────────\n714: # RULES\n715: # ─────────────────────────────────────────────────────────────────\n716: rules:\n717:   ALWAYS:\n718:     - \"Copy templates from canonical paths, never create from memory\"\n719:     - \"Run structural validation before claiming completion\"\n720:     - \"Self-validate at each step\"\n721:     - \"Respect user feedback and modification requests\"\n722:     - \"Reference core_standards.md for formatting rules\"\n723:     - \"Validate workflow YAML syntax when parser support is available\"\n724:     - \"Keep routers thin when presentation assets exist\"\n725:     - \"Save context after successful completion when a spec path is present\"\n726:   NEVER:\n727:     - \"Skip validation between steps\"\n728:     - \"Create documents without loading templates first\"\n729:     - \"Write files without self-validation\"\n730:     - \"Leave placeholder text in final output\"\n731:     - \"Invent template, script, or reference paths\"\n732:     - \"Ignore YAML parse errors\"\n733:     - \"Put presentation templates inside the router\"\n\n(End of file - total 733 lines)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# OPENCODE CREATE: COMMAND AUTHORING WORKFLOW (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# Mode: autonomous (no user approval gates)\n# Note: This workflow executes all steps sequentially with\n#       continuous self-validation. Pauses only if confidence < 40%.\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Slash Command Author using sk-doc create-command packet\npurpose: Create production-ready OpenCode slash command 4-file sets with router/presentation separation\naction: Guide command creation from invocation contract through validation with frontmatter, routing, YAML workflow, and presentation verification\n\n# ─────────────────────────────────────────────────────────────────\n# PREREQUISITE: CREATE-COMMAND PACKET VERIFICATION\n# ─────────────────────────────────────────────────────────────────\n# This workflow REQUIRES the sk-doc create-command packet for:\n#   • Command invocation and path rules\n#   • Argument-hint and allowed-tools standards\n#   • Router/presentation separation\n#   • Canonical command and presentation templates\n#","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/create/assets/create_command_auto.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# OPENCODE CREATE: COMMAND AUTHORING WORKFLOW (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# Mode: autonomous (no user approval gates)\n# Note: This workflow executes all steps sequentially with\n#       continuous self-validation. Pauses only if confidence < 40%.\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Slash Command Author using sk-doc create-command packet\npurpose: Create production-ready OpenCode slash command 4-file sets with router/presentation separation\naction: Guide command creation from invocation contract through validation with frontmatter, routing, YAML workflow, and presentation verification\n\n# ─────────────────────────────────────────────────────────────────\n# PREREQUISITE: CREATE-COMMAND PACKET VERIFICATION\n# ─────────────────────────────────────────────────────────────────\n# This workflow REQUIRES the sk-doc create-command packet for:\n#   • Command invocation and path rules\n#   • Argument-hint and allowed-tools standards\n#   • Router/presentation separation\n#   • Canonical command and presentation templates\n#\n# PHASE 0 in the presentation contract verifies packet resources BEFORE\n# this YAML workflow loads. If you're executing this workflow,\n# create-command verification has already passed.\n#\n# To invoke correctly: /create:command <command-invocation>\n# ─────────────────────────────────────────────────────────────────\n\noperating_mode:\n  workflow: sequential_6_step\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_task_checklists\n  validation: continuous_self_validation\n  permission_configuration: least_privilege_allowed_tools\n  description: |\n    Executes the 6-step command authoring workflow without step-by-step approval.\n    Pauses only if confidence drops below threshold or structural validation fails.\n\ndevelopment_philosophy:\n  principle: \"Resolve invocation and repeatable workflow before writing files\"\n  approach: \"Understand → Plan → Generate → Validate\"\n  mandate: \"Command contract first, then routing assets, then presentation text\"\n\nruntime_command_path_resolution:\n  root_command: .opencode/commands/[command].md\n  namespace_command: .opencode/commands/[namespace]/[action].md\n  split_assets: .opencode/commands/[namespace]/assets/[namespace]_[action]_[kind]\n\n# ─────────────────────────────────────────────────────────────────\n# CONFIDENCE & CLARIFICATION FRAMEWORK\n# ─────────────────────────────────────────────────────────────────\nconfidence_framework:\n  thresholds:\n    high: { range: \"80-100%\", action: \"Proceed with citable source\" }\n    medium: { range: \"40-79%\", action: \"Proceed with caution, document assumptions\" }\n    low: { range: \"0-39%\", action: \"STOP - Ask clarification with A/B/C options\" }\n\n  scoring_weights:\n    invocation_clarity: 0.30\n    workflow_specificity: 0.25\n    tool_permission_clarity: 0.25\n    presentation_boundary_defined: 0.20\n\n  clarification_format: |\n    \"I need clarity (confidence: [NN%]). Which approach:\n    - A) [option with brief rationale]\n    - B) [option with brief rationale]\n    - C) [option with brief rationale]\"\n\n  escalation:\n    timebox_minutes: 10\n    failed_attempts_threshold: 2\n    action: \"Present options to user with current findings\"\n\n# ─────────────────────────────────────────────────────────────────\n# REQUEST ANALYSIS FRAMEWORK\n# ─────────────────────────────────────────────────────────────────\nrequest_analysis_framework:\n  code_search_note: \"Use Grep/Glob for existing command files and direct Read for exact contents. memory_search is for spec docs/memory, not arbitrary code.\"\n  solution_flow:\n  - \"Parse carefully: What slash command is ACTUALLY requested?\"\n  - \"Gather Context: Read target packet resources and nearby commands\"\n  - \"Identify Approach: SIMPLEST command set that matches the workflow\"\n  - \"Validate Choice: Follow create-command packet patterns\"\n  - \"Clarify If Needed: If <80% confidence, ask\"\n  - \"Scope Check: Solving ONLY what was asked?\"\n  - \"Execute: Implement with minimal complexity\"\n\n  pre_change_validation:\n    items:\n    - \"Command invocation format validated? (/name or /namespace:action)\"\n    - \"Command output paths confirmed?\"\n    - \"Spec folder created or selected?\"\n    - \"Workflow purpose and inputs gathered?\"\n    - \"Confidence >=80%? (if not: ask)\"\n    stop_conditions: [ \"Any item unchecked\", \"No spec folder\" ]\n    stop_action: \"STOP and address before proceeding\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (From gate outputs)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  command_invocation: |\n    [COMMAND_INVOCATION]\n    Slash command invocation, either /command or /namespace:action.\n    FROM UNIFIED SETUP PHASE (Q0 or command argument).\n\n  command_path: |\n    [COMMAND_PATH]\n    Output router path derived from command_invocation.\n    FROM UNIFIED SETUP PHASE (derived path or explicit --path override).\n\n  spec_path: |\n    [SPEC_PATH]\n    Spec folder for tracking this work.\n    FROM UNIFIED SETUP PHASE (Q1 choice A/B/C/D).\n\n  memory_choice: |\n    [MEMORY_CHOICE]\n    Prior-session context loading choice (A/B/C).\n    FROM UNIFIED SETUP PHASE (Q4 if applicable).\n\n# ─────────────────────────────────────────────────────────────────\n# FIELD HANDLING\n# ─────────────────────────────────────────────────────────────────\nfield_handling:\n  command_invocation:\n    validation: \"must start with /; root commands use lowercase hyphen-case; namespace commands use /namespace:action\"\n    required: true\n\n  command_package_shape:\n    validation: \"must be split_4_file_set for this workflow\"\n    default: \"split_4_file_set\"\n    note: \"Creates router .md plus _auto.yaml, _confirm.yaml, and _presentation.txt assets\"\n\n  defaults:\n    commands_root: \".opencode/commands/\"\n    execution_mode: \"confirm_when_omitted\"\n    spec_path_from_phase: \"FROM USER CHOICE IN SETUP PHASE\"\n\ninput_contract:\n  required:\n    - create_command_verified\n    - command_invocation\n    - command_path\n    - spec_path\n  optional:\n    - memory_choice\n    - command_package_shape\n\n# ─────────────────────────────────────────────────────────────────\n# DOCUMENTATION LEVEL\n# ─────────────────────────────────────────────────────────────────\ndocumentation_level:\n  default: \"Level 1 (Baseline)\"\n  required_files:\n  - spec.md\n  - plan.md\n  - tasks.md\n  note: \"Command creation typically Level 1 unless destructive behavior, broad routing, or multi-command orchestration increases risk\"\n\n# ─────────────────────────────────────────────────────────────────\n# COMMAND CREATION TEMPLATES\n# ─────────────────────────────────────────────────────────────────\ncommand_templates:\n  command_markdown: .opencode/skills/sk-doc/create-command/assets/command_template.md\n  presentation_contract: .opencode/skills/sk-doc/create-command/assets/command_presentation_template.md\n\ncommand_scripts:\n  packet_local: \"No packet-local scripts are wired; follow create-command/SKILL.md validation instructions.\"\n\ncommand_references:\n  command_creation: .opencode/skills/sk-doc/create-command/SKILL.md\n  route_map: .opencode/skills/sk-doc/create-command/references/README.md\n  worked_example: .opencode/skills/sk-doc/create-command/references/worked_example.md\n  router_presentation_split: .opencode/skills/sk-doc/create-command/references/router_presentation_split.md\n  argument_hints_and_modes: .opencode/skills/sk-doc/create-command/references/argument_hints_and_modes.md\n  common_pitfalls: .opencode/skills/sk-doc/create-command/references/common_pitfalls.md\n\n# ─────────────────────────────────────────────────────────────────\n# CONTEXT LOADING\n# ─────────────────────────────────────────────────────────────────\ncontext_loading:\n  trigger: \"During UNIFIED SETUP PHASE, non-interactive resolution before Step 1\"\n  applies_when: \"An existing spec_path with handover.md or _memory.continuity in implementation-summary.md present from a prior command-creation session\"\n  auto_resolution:\n    default: \"If prior context exists (handover.md <24h old or _memory.continuity present), load it automatically via memory_context; sets memory_loaded: handover. Otherwise skip; sets memory_loaded: skipped.\"\n    override: \"Honor memory_choice if explicitly supplied as a command argument or marker (A = handover, B = canonical docs, C = skip)\"\n  mcp_integration:\n    tool: memory_context\n    note: \"Call MCP tools directly - NEVER through Code Mode\"\n    parameters: { input: \"resume previous work on {spec_path}\", mode: \"resume\", profile: \"resume\", specFolder: \"{spec_path}\", includeContent: true }\n    transport_fallback: \"If MCP tools are missing or erroring while the daemon is otherwise warm, use: node .opencode/bin/spec-memory.cjs memory_context --json '{\\\"input\\\":\\\"resume previous work\\\",\\\"mode\\\":\\\"resume\\\"}' --format json --timeout-ms 3000 --warm-only. Exit 75 = retryable backend unavailability.\"\n  output: memory_loaded\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW ENFORCEMENT (CRITICAL)\n# ─────────────────────────────────────────────────────────────────\nworkflow_enforcement:\n  mode: strict\n  step_order: sequential_mandatory\n  skip_allowed: false\n\n  phase_gate:\n    location: \"Between Step 2 and Step 3\"\n    purpose: \"Verify command contract complete before package planning\"\n    requirements:\n    - \"Invocation and output paths clearly defined\"\n    - \"Repeatable command workflow captured\"\n    - \"Tool and presentation boundaries documented\"\n    action_if_failed: \"STOP and return to incomplete step\"\n\n  critical_steps:\n    step_2_understanding:\n      enforcement: \"MUST gather purpose, inputs, modes, tools, and safety boundaries\"\n      verification: \"Self-validate command contract before proceeding\"\n    step_3_planning:\n      enforcement: \"MUST define frontmatter, routing assets, and presentation boundary\"\n      verification: \"All command package decisions documented\"\n    step_4_generation:\n      enforcement: \"MUST use create-command templates and real resource paths\"\n      verification: \"Router is thin; assets own workflow and presentation\"\n    step_5_validation:\n      enforcement: \"MUST run structural and path validation\"\n      verification: \"Frontmatter parses, assets exist, and no placeholders remain\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW (6 STEPS - AUTONOMOUS)\n# ─────────────────────────────────────────────────────────────────\ngate_logic:\n  hard:\n    H0_create_command_verified:\n      description: \"create-command packet verification must have passed in Phase 0\"\n      fail_action: \"STOP and return to the command setup phase\"\n    H1_required_fields:\n      description: \"Required setup fields must be present before generation\"\n      fail_action: \"STOP and collect missing inputs\"\n    H2_generation_contract:\n      description: \"Generated command set must follow the create-command template and router/presentation contract\"\n      fail_action: \"Fix the generated output before continuing\"\n  soft:\n    S1_existing_command:\n      description: \"Warn when a command already exists at the target path\"\n      fail_action: \"Proceed only after explicit update intent\"\n\nworkflow_overview:\n  steps:\n    - id: step_1_request_analysis\n      purpose: \"Normalize inputs, validate invocation, and resolve output paths\"\n    - id: step_2_understanding\n      purpose: \"Capture the command purpose, workflow, inputs, tools, and boundaries\"\n    - id: step_3_planning\n      purpose: \"Define frontmatter, routing assets, mode behavior, and presentation boundary\"\n    - id: step_4_generation\n      purpose: \"Generate the command 4-file set from canonical templates\"\n    - id: step_5_validation\n      purpose: \"Validate frontmatter, YAML, paths, placeholders, and router thinness\"\n    - id: step_6_save_context\n      purpose: \"Persist spec context and emit completion status\"\n\nworkflow:\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE A: PLANNING (Steps 1-3)\n  # ═══════════════════════════════════════════════════════════════\n\n  step_1_request_analysis:\n    purpose: Parse inputs and validate command invocation (from UNIFIED SETUP PHASE)\n    activities:\n    - Confirm command_invocation from UNIFIED SETUP PHASE (Q0 or argument)\n    - Derive command_path from command_invocation unless explicit path is provided\n    - Confirm spec_path from UNIFIED SETUP PHASE (Q1 choice A/B/C/D)\n    - Resolve memory_choice via the context_loading block (Q4 if applicable); record result as memory_loaded\n    - Verify command invocation format and path mapping\n    - Check if command router or owned assets already exist at target paths\n    validation:\n      invocation_format: \"root /command or namespace /namespace:action\"\n      check_exists: true\n      command: \"ls [command_path] 2>/dev/null\"\n    outputs:\n    - command_invocation_validated\n    - command_path_confirmed\n    - command_exists_check\n\n  step_1b_command_discovery:\n    purpose: Search for similar existing commands before creating or updating (MANDATORY)\n    gate_type: SOFT_BLOCK\n    enforcement: \"Warn if similar command exists, allow user override\"\n    activities:\n    - \"Use Glob to list .opencode/commands/**/*.md\"\n    - \"Use Grep to search for matching invocation names, descriptions, and workflow phrases\"\n    - \"Read exact matches and nearby namespace commands before planning\"\n    validation:\n      similar_exists_threshold: \"same invocation, same namespace/action, or significant description overlap\"\n      action_if_found: \"Log finding and proceed unless exact duplicate conflicts with requested update intent\"\n    outputs:\n    - similar_commands_found: list_of_matching_commands\n    - reusable_patterns: patterns_to_consider\n    - proceed_recommendation: boolean\n    auto_decision: \"Proceed unless exact invocation conflict contradicts requested intent; log similar commands for reference\"\n    skip_condition: \"User explicitly skips discovery\"\n\n  step_1c_spec_folder_setup:\n    purpose: Create documentation folder for tracking (if user chose B or C in Q1)\n    condition: \"spec_choice != D (Skip)\"\n    activities:\n    - IF spec_choice == B (Create new):\n      - Find next available spec number in the selected spec root\n      - \"Create folder: [spec-root]/[NNN]-[command-slug]/\"\n    - IF spec_choice == A or C (Use existing):\n      - Use selected spec_path\n    - \"Create or update Level 1 spec.md, plan.md, and tasks.md through the active spec-folder workflow; do not wire non-target packet template paths here\"\n    outputs:\n    - spec.md: created_or_updated\n    - plan.md: created_or_updated\n    - tasks.md: created_or_updated\n\n  step_2_understanding:\n    purpose: Gather command purpose, workflow, inputs, tools, and boundaries (CRITICAL - DO NOT SKIP)\n    enforcement: MANDATORY\n    activities:\n    - Ask focused questions about the command's repeatable workflow\n    - Gather invocation purpose and expected user inputs\n    - Identify :auto and :confirm behavior\n    - Define least-privilege allowed-tools\n    - Identify visible prompts, dashboards, result templates, and next-step wording\n    - Identify destructive or privileged actions and required safety gates\n    questions:\n    - \"What should this slash command create, update, or route?\"\n    - \"What arguments and modes should it accept?\"\n    - \"Which tools does the workflow actually need?\"\n    - \"What user-facing prompts and results must be separated into presentation?\"\n    prompt_template: |\n      ┌────────────────────────────────────────────────────────────┐\n      │ \"What command workflow should be authored?\"                │\n      │                                                            │\n      │ Please provide:                                            │\n      │ - Purpose: What repeatable workflow does it run?           │\n      │ - Inputs: Required arguments, optional flags, modes         │\n      │ - Tools: Least-privilege tool list                         │\n      │ - Boundary: What belongs in router vs presentation/YAML     │\n      └────────────────────────────────────────────────────────────┘\n    outputs:\n    - purpose_defined: \"clear repeatable command workflow\"\n    - inputs_defined: \"required arguments, optional flags, and modes\"\n    - tools_defined: \"least-privilege allowed-tools list\"\n    - boundaries_defined: \"router, YAML, and presentation ownership\"\n    validation: understanding_complete\n\n  # ═══════════════════════════════════════════════════════════════\n  # 🔒 PHASE GATE: UNDERSTANDING → CONFIGURATION\n  # ═══════════════════════════════════════════════════════════════\n  phase_gate_understanding_to_configuration:\n    trigger: \"After Step 2 completes\"\n    enforcement: HARD_BLOCK\n    verification: |\n      BEFORE proceeding to Configuration Phase (Step 3):\n\n      VERIFY all understanding artifacts exist:\n      ├─ [ ] Invocation and output path clearly defined\n      ├─ [ ] Repeatable workflow purpose captured\n      ├─ [ ] Required arguments, modes, and tools documented\n      ├─ [ ] Router/YAML/presentation boundaries identified\n\n      IF any artifact missing:\n      └─ STOP → Return to Step 2 → Complete it → Return here\n\n      WHEN all artifacts verified:\n      └─ SET PHASE GATE STATUS: PASSED → Proceed to Step 3\n    action_if_failed: \"Return to incomplete step\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE B: IMPLEMENTATION (Steps 3-6)\n  # ═══════════════════════════════════════════════════════════════\n\n  step_3_planning:\n    purpose: Define command package, frontmatter, routing assets, and behavioral rules\n    activities:\n    - Confirm split 4-file package shape for workflow-backed command creation\n    - Define router frontmatter: description, argument-hint, allowed-tools\n    - Define asset paths for _auto.yaml, _confirm.yaml, and _presentation.txt\n    - Define :auto and :confirm behavior; confirm must equal auto plus checkpoints\n    - Define presentation sections for prompts, dashboard, result, and failure display\n    - Plan validation commands and grep checks\n    command_type_selection:\n      split_mode_based:\n        description: \"Thin router plus owned auto, confirm, and presentation assets\"\n        invocation: \"/namespace:action [:auto|:confirm]\"\n        use_case: \"Workflow-backed command sets with visible prompts and checkpointed mode\"\n    permission_planning:\n      core_tools:\n        read: { purpose: \"Read templates and existing commands\", default: \"allow\" }\n        write: { purpose: \"Create command files\", default: \"allow\" }\n        edit: { purpose: \"Modify existing command files\", default: \"allow\" }\n        bash: { purpose: \"Run validators\", default: \"allow\" }\n        grep: { purpose: \"Search source leftovers and existing patterns\", default: \"allow\" }\n        glob: { purpose: \"Find command and resource paths\", default: \"allow\" }\n      extended_tools:\n        todowrite: { purpose: \"Track multi-step command creation\", default: \"allow\" }\n        memory_save: { purpose: \"Index canonical spec context when requested\", default: \"allow\" }\n      permission_values:\n        allow: \"Available for workflow execution\"\n        omit: \"Do not include in allowed-tools\"\n    behavioral_rules_template: |\n      ALWAYS:\n        - Keep routers thin when presentation assets exist\n        - Wire only paths verified on disk\n        - Keep confirm behavior equal to auto plus approval checkpoints\n\n      NEVER:\n        - Put dashboard/result templates in the thin router\n        - Invent scripts, templates, or references\n        - Leave source workflow names or placeholders in generated files\n\n      ESCALATE IF:\n        - Invocation, package shape, or destructive behavior is unclear\n    outputs:\n    - command_package_selected\n    - frontmatter_configured\n    - routing_assets_defined\n    - presentation_boundary_defined\n    - validation_plan_defined\n    validation: configuration_planned\n\n  step_4_generation:\n    purpose: Create command 4-file set with router markdown, workflow YAML, and presentation contract\n    activities:\n    - Load command_template.md for command structure reference\n    - Load command_presentation_template.md for presentation structure reference\n    - Generate thin router markdown with asset table, execution order, routing rules, and presentation boundary\n    - Generate _auto.yaml with the workflow steps and no user approval checkpoints\n    - Generate _confirm.yaml with the same workflow plus checkpoint blocks\n    - Generate _presentation.txt with startup, setup, dashboard, completion, and failure displays\n    - Write files to the resolved command paths\n    - Verify each file exists and is readable\n    frontmatter_template: |\n      ---\n      description: [Action-oriented single-line description]\n      argument-hint: \"<required> [optional] [:auto|:confirm]\"\n      allowed-tools: Read, Write, Edit, Bash, Glob, Grep\n      ---\n    quality_requirements:\n      router: \"thin; no inline startup prompts, dashboard templates, or result templates\"\n      yaml: \"auto and confirm share the same workflow; confirm adds checkpoints only\"\n      presentation: \"owns all visible prompt and result wording\"\n      resources: \"only verified on-disk paths\"\n    outputs:\n    - router_file_created\n    - auto_yaml_created\n    - confirm_yaml_created\n    - presentation_file_created\n    validation: files_created\n\n  step_5_validation:\n    purpose: Frontmatter, YAML, path, structure, and leftover-source validation\n    enforcement: HARD_BLOCK\n    activities:\n    - Parse router frontmatter and verify required fields\n    - Parse _auto.yaml and _confirm.yaml as YAML when parser is available\n    - Verify all resource paths referenced in workflow assets exist on disk\n    - Verify confirm workflow mirrors auto workflow except checkpoint blocks and interactive execution settings\n    - Verify router stays thin and presentation owns visible templates\n    - Run validate_document.py if available\n    - Grep generated files for copied source workflow names\n    - IF validation fails: Fix issues and re-run\n    - Repeat until passing\n    validation_command: |\n      Run the validators specified by .opencode/skills/sk-doc/create-command/SKILL.md Step 13 when available.\n      grep -R \"[source-workflow-name]\" [generated-file-list]\n    quality_gates:\n      frontmatter_parse: \"must pass\"\n      required_fields: \"description, argument-hint, allowed-tools\"\n      asset_paths_exist: \"all referenced resource and owned asset paths exist\"\n      router_thinness: \"no presentation templates in router\"\n      confirm_consistency: \"same workflow as auto plus checkpoints\"\n      no_source_leftovers: \"must pass\"\n      enforcement: HARD_BLOCK\n    fix_workflow: |\n      IF validation fails:\n      1. Review specific errors from validation output\n      2. Fix issues in generated files\n      3. Re-run validation command\n      4. Repeat until passing\n    outputs:\n    - frontmatter_validation_result: pass_or_fail\n    - yaml_validation_result: pass_or_fail\n    - path_validation_result: pass_or_fail\n    - leftover_source_check: pass_or_fail\n    validation: command_set_valid\n\n  step_5b_quality_validation:\n    purpose: Quality-validate the created command artifact set\n    template_contract:\n      source: \"sk-doc create-command\"\n      validators: \"validate_document.py + extract_structure.py + quick_validate.py when applicable\"\n      precedence: \"Template compliance, router/presentation separation, and description-length budget are all checked before completion.\"\n    activities:\n    - \"Run command structural validation against the router markdown\"\n    - \"Validate frontmatter description budget and allowed-tools accuracy\"\n    - \"Review router/presentation split against create-command references\"\n    - \"Confirm the output package has exactly the expected owned files\"\n    on_low_score:\n      threshold: 70\n      action: \"Log warnings and suggest improvements; do not block workflow unless structural rules fail\"\n    description_budget:\n      soft_target: 110\n      hard_cap: 1536\n      reference: \".opencode/skills/sk-doc/create-command/assets/command_template.md\"\n    outputs:\n    - quality_score: number\n    - validation_findings: list\n    - improvement_suggestions: list (if score < 70)\n    - description_length_warnings: list\n\n  step_6_save_context:\n    purpose: Preserve workflow decisions and context\n    condition: \"spec_path is not null\"\n    activities:\n    - Invoke system-spec-kit skill\n    - Document command creation decisions\n    - Record routing, frontmatter, tools, and presentation-boundary rationale\n    - Save validation results\n    - Update canonical spec documents\n    - Index canonical spec document for immediate search availability\n    tool_invocation:\n      command: \"Use the active spec-folder context-saving workflow\"\n      note: \"Do not wire non-target packet resource paths in this command asset\"\n    memory_content:\n      include:\n      - Command invocation and purpose\n      - Output file paths\n      - Mode and routing decisions\n      - Allowed-tools rationale\n      - Router/presentation boundary decisions\n      - Validation results\n    outputs:\n    - implementation_summary: \"[spec_path]/implementation-summary.md\"\n    validation: context_saved\n\n    # ── SEMANTIC MEMORY INTEGRATION ─────────────────────────────────\n    post_save_indexing:\n      purpose: \"Index the canonical spec document immediately for search availability\"\n      mcp_tool: memory_save\n      invocation: |\n        memory_save({\n          filePath: \"[spec_path]/implementation-summary.md\"\n        })\n      critical_note: \"Call semantic memory MCP directly. The save target is a canonical spec document.\"\n      when: \"Immediately after implementation-summary.md is written to disk\"\n\n    anchor_requirements:\n      enforcement: MANDATORY\n      minimum_anchors: 2\n      pattern: \"[context-type]-[keywords]-[spec-number]\"\n      format: \"<!-- ANCHOR:ID --> content <!-- /ANCHOR:ID -->\"\n      case: \"UPPERCASE recommended for visibility\"\n      required_sections:\n      - context_type: \"general\"\n        section: \"Session summary with command creation outcomes\"\n        example_id: \"GENERAL-COMMAND-SUMMARY-{spec#}\"\n        example: |\n          <!-- ANCHOR:GENERAL-COMMAND-SUMMARY-{spec#} -->\n          ## Session Summary\n          Created command X with router/assets Y...\n          <!-- /ANCHOR:GENERAL-COMMAND-SUMMARY-{spec#} -->\n      - context_type: \"decision\"\n        section: \"Key decisions made during command creation\"\n        example_id: \"DECISION-COMMAND-CONFIG-{spec#}\"\n        example: |\n          <!-- ANCHOR:DECISION-COMMAND-CONFIG-{spec#} -->\n          ## Key Decisions\n          - Chose split command set because...\n          - Allowed-tools rationale...\n          <!-- /ANCHOR:DECISION-COMMAND-CONFIG-{spec#} -->\n      optional_sections:\n      - context_type: \"implementation\"\n        section: \"Command file structure and assets added\"\n        example_id: \"IMPLEMENTATION-COMMAND-STRUCTURE-{spec#}\"\n      - context_type: \"general\"\n        section: \"Validation results and quality checks\"\n        example_id: \"GENERAL-VALIDATION-{spec#}\"\n      benefit: \"Anchor-based retrieval keeps command decisions recoverable\"\n      reference: \"See /memory:save Step 3 for full anchor documentation\"\n\n    importance_tier:\n      assign: important\n      rationale: \"Command creation captures reusable workflow and routing decisions\"\n      promotion_note: \"Use memory_update() to promote to 'critical' if this command becomes foundational\"\n      tier_reference: |\n        constitutional: Core project rules (auto-surface always)\n        critical: Foundational decisions (high priority in search)\n        important: Significant work like command creation (this workflow)\n        normal: Standard context (default)\n        temporary: Short-term notes\n        deprecated: Outdated but retained\n\n# ─────────────────────────────────────────────────────────────────\n# CIRCUIT BREAKER\n# ─────────────────────────────────────────────────────────────────\ncircuit_breaker:\n  consecutive_failure_threshold: 3\n  states:\n    closed: \"Normal operation\"\n    open: \"3+ failures — pause and report to user\"\n    half_open: \"Test with single retry before resuming\"\n  on_open:\n    action: \"Report failures to user with summary\"\n    suggest: \"Review inputs and try again, or escalate\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  invalid_command_invocation:\n    action: \"Show valid format (/command or /namespace:action), prompt for correction\"\n    example: \"Expected: /create:thing or /memory-save\"\n  command_already_exists:\n    action: \"Offer to update existing or choose a new invocation\"\n    options: [ \"Update existing\", \"Choose new invocation\", \"Cancel\" ]\n  yaml_parse_error:\n    action: \"Check workflow asset syntax, fix and re-validate\"\n    common_issues:\n    - \"Missing colon after field name\"\n    - \"Incorrect indentation (use 2 spaces)\"\n    - \"Unquoted strings with special characters\"\n    - \"Invalid block scalar indentation\"\n  missing_required_field:\n    action: \"Add the missing router frontmatter or workflow field and re-validate\"\n    required_fields: [ \"description\", \"argument-hint\", \"allowed-tools\" ]\n  missing_resource_path:\n    action: \"Remove fabricated path or replace with a verified on-disk path\"\n  presentation_boundary_violation:\n    action: \"Move prompts, dashboards, results, and next-step text from router into presentation asset\"\n\n# ─────────────────────────────────────────────────────────────────\n# AUTONOMOUS EXECUTION\n# ─────────────────────────────────────────────────────────────────\nautonomous_execution:\n  validation_approach: \"Continuous self-validation at each step\"\n  error_handling: \"Auto-recover if possible, halt on critical failures\"\n  progress_reporting: \"Brief status updates between steps\"\n\n# ─────────────────────────────────────────────────────────────────\n# QUALITY STANDARDS\n# ─────────────────────────────────────────────────────────────────\nquality_standards:\n  frontmatter_validation: MANDATORY\n  yaml_validation: MANDATORY\n  router_presentation_separation: MANDATORY\n  validation_pipeline:\n    stage_1: \"Router frontmatter parsing\"\n    stage_2: \"Required field check (description, argument-hint, allowed-tools)\"\n    stage_3: \"YAML workflow asset parsing\"\n    stage_4: \"Resource path existence check\"\n    stage_5: \"Leftover source-name grep\"\n  template_adherence: required\n  core_standards_reference: \".opencode/skills/sk-doc/create-command/SKILL.md\"\n\n# ─────────────────────────────────────────────────────────────────\n# COMPLETION REPORT TEMPLATE\n# ─────────────────────────────────────────────────────────────────\ncompletion_report:\n  template: |\n    Command Creation Complete\n\n    Command: [command-invocation]\n    Router: [command-path]\n    Assets:\n    - Auto workflow: [auto-yaml-path]\n    - Confirm workflow: [confirm-yaml-path]\n    - Presentation: [presentation-path]\n\n    Configuration:\n    - Allowed Tools: [allowed-tools]\n    - Modes: :auto and :confirm\n    - Router Boundary: thin router verified\n\n    Spec Folder: [spec path or none]\n    Memory: [saved/indexed/not applicable]\n\n    Validation:\n    - Router frontmatter: PASSED\n    - YAML workflows: PASSED\n    - Resource paths: PASSED\n    - Source leftovers: PASSED\n\n    Invocation:\n    - Type [command-invocation] [arguments]\n    - Add :auto for autonomous execution\n    - Add :confirm for checkpointed execution\n\n    Next Steps:\n    - Run the command with a small sample request\n    - Review generated prompts and result displays\n    - Tighten allowed-tools if validation finds unused tools\n\n    STATUS=OK PATH=[command-path]\n\n# ─────────────────────────────────────────────────────────────────\n# TERMINATION\n# ─────────────────────────────────────────────────────────────────\ntermination:\n  after_step: step_6_save_context\n  message: \"Command creation workflow complete.\"\n  next_steps:\n    - condition: \"Command needs testing\"\n      action: \"Run with a sample request matching the intended workflow\"\n    - condition: \"Command needs refinement\"\n      action: \"Iterate on prompts, routing, or allowed-tools based on testing\"\n    - condition: \"Context should be saved\"\n      action: \"Run /memory:save\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - \"Copy templates from canonical paths, never create from memory\"\n    - \"Run structural validation before claiming completion\"\n    - \"Self-validate at each step\"\n    - \"Respect user feedback and modification requests\"\n    - \"Reference core_standards.md for formatting rules\"\n    - \"Validate workflow YAML syntax when parser support is available\"\n    - \"Keep routers thin when presentation assets exist\"\n    - \"Save context after successful completion when a spec path is present\"\n  NEVER:\n    - \"Skip validation between steps\"\n    - \"Create documents without loading templates first\"\n    - \"Write files without self-validation\"\n    - \"Leave placeholder text in final output\"\n    - \"Invent template, script, or reference paths\"\n    - \"Ignore YAML parse errors\"\n    - \"Put presentation templates inside the router\"","lineStart":1,"lineEnd":733,"totalLines":733,"truncated":false}},"title":".opencode/commands/create/assets/create_command_auto.yaml","time":{"start":1784188289149,"end":1784188289165}},"id":"prt_f69e8c076001iG1nxSCNaJvbKK","sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","messageID":"msg_f69e8440b0015aGlejQq2oGzhH"}}
