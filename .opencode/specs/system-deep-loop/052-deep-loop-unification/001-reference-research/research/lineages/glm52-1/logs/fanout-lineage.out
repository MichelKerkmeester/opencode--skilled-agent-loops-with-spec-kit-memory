'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.4]],\n\n  Line 144:   'model benchmark': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n\n  Line 146:   'prompt framework benchmark': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.4]],\n\n  Line 173:   'deep research': [['deep-loop-workflows', 1]],\n\n  Line 174:   'deep review': [['deep-loop-workflows', 1]],\n\n  Line 175:   'deep ai council': [['deep-loop-workflows', 1.6]],\n\n  Line 176:   'deep-ai-council': [['deep-loop-workflows', 1.6]],\n\n  Line 177:   'deep-research': [['deep-loop-workflows', 1.3]],\n\n  Line 178:   'deep-review': [['deep-loop-workflows', 1.3]],\n\n  Line 179:   'ai council': [['deep-loop-workflows', 1.4]],\n\n  Line 180:   'planning council': [['deep-loop-workflows', 1.2]],\n\n  Line 181:   'council deliberation': [['deep-loop-workflows', 1.4]],\n\n  Line 182:   'persist council artifacts': [['deep-loop-workflows', 1.2]],\n\n  Line 183:   'ai-council artifacts': [['deep-loop-workflows', 1.2]],\n\n  Line 184:   'multi-ai-council': [['deep-loop-workflows', 1.2]],\n\n  Line 196:   'resume deep research': [['deep-loop-workflows', 1]],\n\n  Line 197:   'resume deep review': [['deep-loop-workflows', 1]],\n\n  Line 308:     push(scores, 'deep-loop-workflows', 0.85, 'research-loop');\n\n  Line 311:     push(scores, 'deep-loop-workflows', 0.85, 'review-loop');\n\n  Line 318:     push(scores, 'deep-loop-workflows', 0.45, 'ambiguous-code-problem');\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts:\n  Line 30:   'deep-loop-workflows': ['deep research', 'research loop', 'overnight research', 'delta record', 'state log', 'lineage', 'deep review', 'review loop', 'release readiness', 'canonical jsonl', 'convergence tracked', 'iterative review', 'iterative review loop', 'spec folder audit', 'iterative audit', 'multi-pass review', 'review iteration', 'convergence detection', 'review packet', 'spec folder review', 'deep ai council', 'ai council', 'planning council', 'council deliberation', 'multi-seat planning', 'ai-council artifacts', 'persist council artifacts', 'multi-ai-council'],\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/scoring-constants.ts:\n  Line 107:   // deep-review intent\n\n  Line 109:   // deep-research intent (text-only)\n\n  Line 111:   // deep-research-cycle phrase intent\n\n  Line 131:   // task, so sk-code must beat the deep-review loop skill on the near-tie.\n\n  Line 133:   // review-loop colon syntax (\":review:auto\"): rank the deep-review loop above\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts:\n  Line 501:   if (skillId === 'deep-loop-workflows' && /\\b(ai council|planning council|council deliberation|council artifacts|multi-seat planning)\\b/.test(promptLower)) {\n\n  Line 565:   // A \"code audit\" is a single-pass code-review task, not a deep-review loop, so\n\n  Line 572:   // Colon-command review-loop syntax (\":review:auto\") invokes the deep-review\n\n  Line 575:     if (recommendation.skill === 'deep-loop-workflows') return R.reviewLoopDeepReviewBonus;\n\n  Line 597:     if (recommendation.skill === 'deep-loop-workflows') return R.createTestingPlaybookOtherSkillsPenalty;\n","metadata":{"matches":77,"truncated":false},"title":"deep-loop-runtime|deep-loop-workflows|deep-research|deep-review|deep-ai-council|deep-improvement","time":{"start":1783488637932,"end":1783488637946}},"id":"prt_f4034ebe8001RIPBSo0Y3B8JGR","sessionID":"ses_0bfd48e01ffew5W9Qhj3V2EB2W","messageID":"msg_f4034a7600012sv8026wRnXuNn"}}
