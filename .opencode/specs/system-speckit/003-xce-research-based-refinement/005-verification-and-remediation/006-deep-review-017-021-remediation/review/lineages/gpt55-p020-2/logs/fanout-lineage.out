684:     });\n685: \n686:     // 4i. Edge Cases\n687:     describe('4i. Edge Cases', () => {\n688:       it('T51: Multiple markAsFailed() calls update reason', () => {\n689:         insertTestMemory(8001, '/tmp/multifail.md', 'pending');\n690: \n691:         mod.markAsFailed(8001, 'First failure');\n692:         mod.markAsFailed(8001, 'Second failure');\n693: \n694:         const activeDb = getDbOrThrow();\n695:         const row = activeDb.prepare('SELECT failure_reason FROM memory_index WHERE id = ?').get(8001) as {\n696:           failure_reason: string | null;\n697:         };\n698:         expect(row.failure_reason).toBe('Second failure');\n699:       });\n700: \n701:       it('T52: resetForRetry() -> markAsFailed() cycle works', () => {\n702:         insertTestMemory(8010, '/tmp/cycle.md', 'failed', 3, null, 'initial');\n703: \n704:         const resetResult = mod.resetForRetry(8010);\n705:         expect(resetResult).toBe(true);\n706: \n707:         const activeDb = getDbOrThrow();\n708:         const row1 = activeDb.prepare('SELECT embedding_status FROM memory_index WHERE id = ?').get(8010) as {\n709:           embedding_status: string;\n\n(Showing lines 650-709 of 756. Use offset=710 to continue.)\n</content>","metadata":{"preview":"          return null;\n        };\n\n        const result = await mod.processRetryQueue(1, contentLoader);\n        if (result.processed > 0) {\n          expect(loaderCalled).toBe(true);\n        }\n      });\n    });\n\n    // 4h. runBackgroundJob\n    describe('4h. runBackgroundJob', () => {\n      it('T49: runBackgroundJob() with empty queue reports empty', async () => {\n        // Mock getDb to return null so getRetryStats() reports an empty queue,\n        // Avoiding interference from the real production database.\n        // @ts-expect-error testing runtime null-db fallback despite non-null typing\n        const spy = vi.spyOn(vectorIndex, 'getDb').mockReturnValue(null);\n        try {\n          const result = await mod.runBackgroundJob(5);\n          expect(typeof result).toBe('object');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/retry-manager.vitest.ts","text":"          return null;\n        };\n\n        const result = await mod.processRetryQueue(1, contentLoader);\n        if (result.processed > 0) {\n          expect(loaderCalled).toBe(true);\n        }\n      });\n    });\n\n    // 4h. runBackgroundJob\n    describe('4h. runBackgroundJob', () => {\n      it('T49: runBackgroundJob() with empty queue reports empty', async () => {\n        // Mock getDb to return null so getRetryStats() reports an empty queue,\n        // Avoiding interference from the real production database.\n        // @ts-expect-error testing runtime null-db fallback despite non-null typing\n        const spy = vi.spyOn(vectorIndex, 'getDb').mockReturnValue(null);\n        try {\n          const result = await mod.runBackgroundJob(5);\n          expect(typeof result).toBe('object');\n          if (result.queue_empty !== undefined) {\n            expect(result.queue_empty).toBe(true);\n          } else {\n            expect(result.processed).toBe(0);\n          }\n        } finally {\n          spy.mockRestore();\n        }\n      });\n\n      it('T50: runBackgroundJob() returns an object', async () => {\n        const result = await mod.runBackgroundJob(1);\n        expect(typeof result).toBe('object');\n      });\n    });\n\n    // 4i. Edge Cases\n    describe('4i. Edge Cases', () => {\n      it('T51: Multiple markAsFailed() calls update reason', () => {\n        insertTestMemory(8001, '/tmp/multifail.md', 'pending');\n\n        mod.markAsFailed(8001, 'First failure');\n        mod.markAsFailed(8001, 'Second failure');\n\n        const activeDb = getDbOrThrow();\n        const row = activeDb.prepare('SELECT failure_reason FROM memory_index WHERE id = ?').get(8001) as {\n          failure_reason: string | null;\n        };\n        expect(row.failure_reason).toBe('Second failure');\n      });\n\n      it('T52: resetForRetry() -> markAsFailed() cycle works', () => {\n        insertTestMemory(8010, '/tmp/cycle.md', 'failed', 3, null, 'initial');\n\n        const resetResult = mod.resetForRetry(8010);\n        expect(resetResult).toBe(true);\n\n        const activeDb = getDbOrThrow();\n        const row1 = activeDb.prepare('SELECT embedding_status FROM memory_index WHERE id = ?').get(8010) as {\n          embedding_status: string;","lineStart":650,"lineEnd":709,"totalLines":756,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/retry-manager.vitest.ts","time":{"start":1781756786874,"end":1781756786882}},"metadata":{"openai":{"itemId":"fc_03ebecbc6e88b563016a337372a988819191f0d6c180a5aa2e"}},"id":"prt_ed8faf8b9001bswhaLX9AvagbG","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fab5ed0015PC9Bi455AYh43"}}
{"type":"tool_use","timestamp":1781756786883,"sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","part":{"type":"tool","tool":"read","callID":"call_SZfp07oC0kj77nHhlMhCEFCd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":240,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n241:     return {\n242:       code: null,\n243:       provider: null,\n244:       errorType: null,\n245:       publicMessage,\n246:       sanitized: false,\n247:     };\n248:   }\n249: \n250:   const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n251:   const { code, errorType } = inferEmbeddingFailure(publicMessage);\n252: \n253:   return {\n254:     code,\n255:     provider,\n256:     errorType,\n257:     publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n258:     sanitized: true,\n259:   };\n260: }\n261: \n262: export function sanitizeEmbeddingFailureMessage(\n263:   raw: unknown,\n264:   options: SanitizeEmbeddingFailureOptions = {},\n265: ): string | null {\n266:   const failure = sanitizeEmbeddingFailure(raw, options);\n267:   return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n268: }\n269: \n270: export function sanitizeAndLogEmbeddingFailure(\n271:   context: string,\n272:   raw: unknown,\n273:   options: SanitizeEmbeddingFailureOptions = {},\n274: ): string | null {\n275:   const failure = sanitizeEmbeddingFailure(raw, options);\n276:   if (failure.publicMessage.length === 0) {\n277:     return null;\n278:   }\n279: \n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n301:   const now = new Date().toISOString();\n302:   const retryCount = getRetryCountValue(memory);\n303:   const lastRetryAt = getLastRetryAtValue(memory);\n304:   // Concurrency: atomic claim prevents double-processing of retry jobs\n305:   const result = previousStatus === 'pending'\n306:     ? db.prepare(`\n307:         UPDATE memory_index\n308:         SET embedding_status = 'retry',\n309:             last_retry_at = ?,\n310:             updated_at = ?\n311:         WHERE id = ?\n312:           AND embedding_status = 'pending'\n313:           AND retry_count = ?\n314:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n315:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n316:     : db.prepare(`\n317:         UPDATE memory_index\n318:         SET last_retry_at = ?,\n319:             updated_at = ?\n320:         WHERE id = ?\n321:           AND embedding_status = 'retry'\n322:           AND retry_count = ?\n323:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n324:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n325: \n326:   return {\n327:     claimed: result.changes > 0,\n328:     previousStatus,\n329:   };\n330: }\n331: \n332: /* ───────────────────────────────────────────────────────────────\n333:    2. CONFIGURATION\n334: ──────────────────────────────────────────────────────────────── */\n335: \n336: // Backoff delays in milliseconds (1min, 5min, 15min)\n337: const BACKOFF_DELAYS: number[] = [\n338:   60 * 1000,\n339:   5 * 60 * 1000,\n340:   15 * 60 * 1000,\n341: ];\n342: \n343: const MAX_RETRIES = 3;\n344: const MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n345: const MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n346: \n347: // 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n348: // applies to a long-lived daemon without depending on the exact restart sequence. The\n349: // module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\n350: function getMaxRetryQueuePending(): number {\n351:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n352: }\n353: \n354: function getMaxRetryQueueAgeMs(): number {\n355:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n356: }\n357: \n358: // Background retry job configuration\n359: // Env-overrideable\n360: //   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n361: //   SPECKIT_RETRY_BATCH_SIZE  — items processed per batch (default 5)\n362: //   SPECKIT_RETRY_ENABLED     — set to \"false\" to disable the background loop entirely (default enabled)\n363: const BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n364:   intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n365:   batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n366:   enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n367: };\n368: \n369: // Background job state\n370: let backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\n371: let backgroundJobRunning = false;\n372: let shutdownRequested = false;\n373: let retryAbortController: AbortController | null = null;\n374: \n375: // In-memory retry telemetry (never persisted to DB — read by getEmbeddingRetryStats)\n376: let lastBackgroundRunAt: string | null = null;\n377: let totalRetryAttempts = 0;\n378: const retryHealthSnapshot: EmbeddingRetryStats = {\n379:   pending: 0,\n380:   failed: 0,\n381:   retryAttempts: 0,\n382:   circuitBreakerOpen: false,\n383:   lastRun: null,\n384:   queueDepth: 0,\n385: };\n386: \n387: // circuit breaker — prevents the background retry job from\n388: // Hammering the embedding API when the provider is entirely down. After\n389: // PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n390: // Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n391: // The API call and return a transient error instead.\n392: const PROVIDER_FAILURE_THRESHOLD = 5;\n393: const PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\n394: const CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\n395: const FLAPPING_THRESHOLD = 2;\n396: const circuitTransitions: number[] = [];\n397: \n398: let providerFailures = 0;\n399: let providerCircuitOpenedAt: number | null = null;\n400: \n401: function parsePositiveIntEnv(name: string, fallback: number): number {\n402:   const raw = process.env[name];\n403:   if (!raw) return fallback;\n404: \n405:   const parsed = Number.parseInt(raw, 10);\n406:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n407: }\n408: \n409: function recordCircuitTransition(): void {\n410:   const now = Date.now();\n411:   circuitTransitions.push(now);\n412:   while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n413:     circuitTransitions.shift();\n414:   }\n415: }\n416: \n417: function getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n418:   const now = Date.now();\n419:   const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n420:   return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n421: }\n422: \n423: function isProviderCircuitOpen(): boolean {\n424:   if (providerCircuitOpenedAt === null) return false;\n425:   if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n426:     providerCircuitOpenedAt = null;\n427:     providerFailures = 0;\n428:     recordCircuitTransition();\n429:     return false;\n430:   }\n431:   return true;\n432: }\n433: \n434: function recordProviderSuccess(): void {\n435:   providerFailures = 0;\n436:   providerCircuitOpenedAt = null;\n437:   retryHealthSnapshot.circuitBreakerOpen = false;\n438: }\n439: \n440: function recordProviderFailure(): void {\n441:   providerFailures++;\n442:   if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n443:     providerCircuitOpenedAt = Date.now();\n444:     recordCircuitTransition();\n445:     console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n446:   }\n447:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n448: }\n449: \n450: function applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n451:   if (previousStatus === 'pending') {\n452:     retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n453:   }\n454: \n455:   if (previousStatus === 'pending' || previousStatus === 'retry') {\n456:     retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n457:   }\n458: \n459:   if (nextStatus === 'pending') {\n460:     retryHealthSnapshot.pending++;\n461:     retryHealthSnapshot.queueDepth++;\n462:   }\n463: \n464:   if (nextStatus === 'retry') {\n465:     retryHealthSnapshot.queueDepth++;\n466:   }\n467: \n468:   if (previousStatus === 'failed') {\n469:     retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n470:   }\n471: \n472:   if (nextStatus === 'failed') {\n473:     retryHealthSnapshot.failed++;\n474:   }\n475: }\n476: \n477: function refreshRetryHealthSnapshot(stats: RetryStats): void {\n478:   retryHealthSnapshot.pending = stats.pending;\n479:   retryHealthSnapshot.failed = stats.failed;\n480:   retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n481:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n482:   retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n483:   retryHealthSnapshot.queueDepth = stats.queue_size;\n484: }\n485: \n486: function enforceRetryRetentionLimits(\n487:   maxPending = getMaxRetryQueuePending(),\n488:   maxAgeMs = getMaxRetryQueueAgeMs(),\n489:   now: Date = new Date(),\n490: ): { expired: number; overflow: number } {\n491:   const db = vectorIndex.getDb();\n492:   if (!db) return { expired: 0, overflow: 0 };\n493: \n494:   const nowIso = now.toISOString();\n495:   const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n496:   // Retention is non-destructive for never-attempted clean `pending` rows.\n497:   // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n498:   // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n499:   // embedded instead of being parked as `failed` before the drain can claim it.\n\n(Showing lines 240-499 of 1141. Use offset=500 to continue.)\n</content>","metadata":{"preview":"  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };\n}\n\nexport function sanitizeEmbeddingFailureMessage(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n}\n\nexport function sanitizeAndLogEmbeddingFailure(\n  context: string,\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  if (failure.publicMessage.length === 0) {\n    return null;\n  }\n\n  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n\n  const now = new Date().toISOString();\n  const retryCount = getRetryCountValue(memory);\n  const lastRetryAt = getLastRetryAtValue(memory);\n  // Concurrency: atomic claim prevents double-processing of retry jobs\n  const result = previousStatus === 'pending'\n    ? db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'pending'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n    : db.prepare(`\n        UPDATE memory_index\n        SET last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'retry'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n\n  return {\n    claimed: result.changes > 0,\n    previousStatus,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Backoff delays in milliseconds (1min, 5min, 15min)\nconst BACKOFF_DELAYS: number[] = [\n  60 * 1000,\n  5 * 60 * 1000,\n  15 * 60 * 1000,\n];\n\nconst MAX_RETRIES = 3;\nconst MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\nconst MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n\n// 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n// applies to a long-lived daemon without depending on the exact restart sequence. The\n// module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\nfunction getMaxRetryQueuePending(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n}\n\nfunction getMaxRetryQueueAgeMs(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n}\n\n// Background retry job configuration\n// Env-overrideable\n//   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n//   SPECKIT_RETRY_BATCH_SIZE  — items processed per batch (default 5)\n//   SPECKIT_RETRY_ENABLED     — set to \"false\" to disable the background loop entirely (default enabled)\nconst BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n  intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n  batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n  enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n};\n\n// Background job state\nlet backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\nlet backgroundJobRunning = false;\nlet shutdownRequested = false;\nlet retryAbortController: AbortController | null = null;\n\n// In-memory retry telemetry (never persisted to DB — read by getEmbeddingRetryStats)\nlet lastBackgroundRunAt: string | null = null;\nlet totalRetryAttempts = 0;\nconst retryHealthSnapshot: EmbeddingRetryStats = {\n  pending: 0,\n  failed: 0,\n  retryAttempts: 0,\n  circuitBreakerOpen: false,\n  lastRun: null,\n  queueDepth: 0,\n};\n\n// circuit breaker — prevents the background retry job from\n// Hammering the embedding API when the provider is entirely down. After\n// PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n// Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n// The API call and return a transient error instead.\nconst PROVIDER_FAILURE_THRESHOLD = 5;\nconst PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\nconst CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\nconst FLAPPING_THRESHOLD = 2;\nconst circuitTransitions: number[] = [];\n\nlet providerFailures = 0;\nlet providerCircuitOpenedAt: number | null = null;\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction recordCircuitTransition(): void {\n  const now = Date.now();\n  circuitTransitions.push(now);\n  while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n    circuitTransitions.shift();\n  }\n}\n\nfunction getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n  const now = Date.now();\n  const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n  return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n}\n\nfunction isProviderCircuitOpen(): boolean {\n  if (providerCircuitOpenedAt === null) return false;\n  if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n    providerCircuitOpenedAt = null;\n    providerFailures = 0;\n    recordCircuitTransition();\n    return false;\n  }\n  return true;\n}\n\nfunction recordProviderSuccess(): void {\n  providerFailures = 0;\n  providerCircuitOpenedAt = null;\n  retryHealthSnapshot.circuitBreakerOpen = false;\n}\n\nfunction recordProviderFailure(): void {\n  providerFailures++;\n  if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n    providerCircuitOpenedAt = Date.now();\n    recordCircuitTransition();\n    console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n  }\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n}\n\nfunction applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n  if (previousStatus === 'pending') {\n    retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n  }\n\n  if (previousStatus === 'pending' || previousStatus === 'retry') {\n    retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n  }\n\n  if (nextStatus === 'pending') {\n    retryHealthSnapshot.pending++;\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (nextStatus === 'retry') {\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (previousStatus === 'failed') {\n    retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n  }\n\n  if (nextStatus === 'failed') {\n    retryHealthSnapshot.failed++;\n  }\n}\n\nfunction refreshRetryHealthSnapshot(stats: RetryStats): void {\n  retryHealthSnapshot.pending = stats.pending;\n  retryHealthSnapshot.failed = stats.failed;\n  retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n  retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n  retryHealthSnapshot.queueDepth = stats.queue_size;\n}\n\nfunction enforceRetryRetentionLimits(\n  maxPending = getMaxRetryQueuePending(),\n  maxAgeMs = getMaxRetryQueueAgeMs(),\n  now: Date = new Date(),\n): { expired: number; overflow: number } {\n  const db = vectorIndex.getDb();\n  if (!db) return { expired: 0, overflow: 0 };\n\n  const nowIso = now.toISOString();\n  const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n  // Retention is non-destructive for never-attempted clean `pending` rows.\n  // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n  // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n  // embedded instead of being parked as `failed` before the drain can claim it.","lineStart":240,"lineEnd":499,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781756786870,"end":1781756786882}},"metadata":{"openai":{"itemId":"fc_03ebecbc6e88b563016a337372a9708191912fa761c169ac7a"}},"id":"prt_ed8faf8b5001jZyyxfePpGagi8","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fab5ed0015PC9Bi455AYh43"}}
