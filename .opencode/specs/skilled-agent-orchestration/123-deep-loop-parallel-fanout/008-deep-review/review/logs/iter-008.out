    56	function buildNamespacePredicate(alias: string, ns: Namespace): SqlFragment {
    57	  const prefix = alias ? `${alias}.` : '';
    58	  const clauses = [`${prefix}spec_folder = ?`, `${prefix}loop_type = ?`];
    59	  const params: unknown[] = [ns.specFolder, ns.loopType];
    60	
