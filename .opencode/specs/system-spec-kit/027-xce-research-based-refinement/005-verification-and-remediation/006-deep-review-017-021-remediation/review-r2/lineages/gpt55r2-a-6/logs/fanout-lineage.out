          \"delta\": -0.043344,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"sk-code-review\",\n          \"liveScore\": 0.560137,\n          \"shadowScore\": 0.524344,\n          \"delta\": -0.035793,\n          \"dominantShadowLane\": \"explicit_author\"\n        }\n      ]\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781762645866,"end":1781762646116}},"metadata":{"openai":{"itemId":"fc_0fb1c0642ea8daab016a338a554a28819181e33ff65f00dc1c"}},"id":"prt_ed9545d46001KQ0rv4I7xQaFEc","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed9544b020019Sqwhlxf7VVdPy"}}
