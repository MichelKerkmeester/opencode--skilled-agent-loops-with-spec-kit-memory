{"type":"tool_use","timestamp":1783915750031,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_adqEONU4b0EOk18o9dOzCBfc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/review-research-paths.cjs","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/review-research-paths.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Review Research Paths                                                    ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const os = require('node:os');\n13: const path = require('node:path');\n14: \n15: const MODE_CONFIG_FILE = {\n16:   research: 'deep-research-config.json',\n17:   review: 'deep-review-config.json',\n18:   alignment: 'deep-alignment-config.json',\n19: };\n20: \n21: const MODE_STATE_FILE = {\n22:   research: 'deep-research-state.jsonl',\n23:   review: 'deep-review-state.jsonl',\n24:   alignment: 'deep-alignment-state.jsonl',\n25: };\n26: \n27: // ─────────────────────────────────────────────────────────────────────────────\n28: // 2. CORE LOGIC\n29: // ─────────────────────────────────────────────────────────────────────────────\n30: \n31: /**\n32:  * Allocate the next artifact subfolder name under an artifact root directory\n33:  * using the {phaseSlug}-pt-{NN} naming convention.\n34:  *\n35:  * The phase slug is the FULL first-segment folder name under the spec tree\n36:  * root (e.g. \"019-system-hardening\").  NN is a two-digit zero-padded counter:\n37:  * 1 + the number of existing pt-folders whose slug prefix matches the requested\n38:  * phase, so repeated calls produce sequential names without any stored counter.\n39:  *\n40:  * @param {string} rootDir   - Absolute path to the artifact root (research/ or review/)\n41:  * @param {string} phaseSlug - Full phase folder name (e.g. \"019-system-hardening\")\n42:  * @returns {string} Subfolder name, e.g. \"019-system-hardening-pt-03\"\n43:  */\n44: function allocateShortSubfolder(rootDir, phaseSlug) {\n45:   let existingCount = 0;\n46: \n47:   if (fs.existsSync(rootDir)) {\n48:     const prefix = `${phaseSlug}-pt-`;\n49:     existingCount = fs.readdirSync(rootDir).filter(\n50:       (entry) => entry.startsWith(prefix),\n51:     ).length;\n52:   }\n53: \n54:   const nn = String(existingCount + 1).padStart(2, '0');\n55:   return `${phaseSlug}-pt-${nn}`;\n56: }\n57: \n58: function normalizeSpecFolderReference(specFolder) {\n59:   if (!specFolder) {\n60:     return null;\n61:   }\n62: \n63:   const normalized = String(specFolder)\n64:     .trim()\n65:     .replace(/\\\\/g, '/')\n66:     .replace(/\\/+$/g, '');\n67: \n68:   if (!normalized) {\n69:     return null;\n70:   }\n71: \n72:   const opencodeSpecsMarker = '/.opencode/specs/';\n73:   const specsMarker = '/specs/';\n74:   const opencodeIndex = normalized.lastIndexOf(opencodeSpecsMarker);\n75:   if (opencodeIndex !== -1) {\n76:     return normalized.slice(opencodeIndex + opencodeSpecsMarker.length);\n77:   }\n78: \n79:   const specsIndex = normalized.lastIndexOf(specsMarker);\n80:   if (specsIndex !== -1) {\n81:     return normalized.slice(specsIndex + specsMarker.length);\n82:   }\n83: \n84:   return normalized\n85:     .replace(/^\\.\\/+/, '')\n86:     .replace(/^\\.opencode\\/specs\\//, '')\n87:     .replace(/^specs\\//, '');\n88: }\n89: \n90: function findAncestorSpecFolder(specFolder) {\n91:   let current = path.resolve(specFolder);\n92: \n93:   while (true) {\n94:     const parent = path.dirname(current);\n95: \n96:     if (parent === current || path.basename(parent) === 'specs') {\n97:       return null;\n98:     }\n99: \n100:     if (fs.existsSync(path.join(parent, 'spec.md'))) {\n101:       return parent;\n102:     }\n103: \n104:     current = parent;\n105:   }\n106: }\n107: \n108: function readPacketSpecFolder(packetDir, mode) {\n109:   const configPath = path.join(packetDir, MODE_CONFIG_FILE[mode]);\n110:   if (fs.existsSync(configPath)) {\n111:     try {\n112:       const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));\n113:       return normalizeSpecFolderReference(config.specFolder);\n114:     } catch (_error) {\n115:       // Fall through to state log probing.\n116:     }\n117:   }\n118: \n119:   const stateLogPath = path.join(packetDir, MODE_STATE_FILE[mode]);\n120:   if (!fs.existsSync(stateLogPath)) {\n121:     return null;\n122:   }\n123: \n124:   try {\n125:     const lines = fs.readFileSync(stateLogPath, 'utf8').split(/\\r?\\n/);\n126:     for (const line of lines) {\n127:       if (!line.trim()) {\n128:         continue;\n129:       }\n130:       const parsed = JSON.parse(line);\n131:       return normalizeSpecFolderReference(parsed.specFolder);\n132:     }\n133:   } catch (_error) {\n134:     return null;\n135:   }\n136: \n137:   return null;\n138: }\n139: \n140: function listPacketDirectories(rootDir) {\n141:   if (!fs.existsSync(rootDir)) {\n142:     return [];\n143:   }\n144: \n145:   return fs.readdirSync(rootDir, { withFileTypes: true })\n146:     .filter((entry) => entry.isDirectory() && /-pt-\\d+$/.test(entry.name))\n147:     .map((entry) => entry.name)\n148:     .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }));\n149: }\n150: \n151: function findExistingPacket(rootDir, specFolder, mode) {\n152:   const targetSpecFolder = normalizeSpecFolderReference(specFolder);\n153: \n154:   if (!targetSpecFolder) {\n155:     return null;\n156:   }\n157: \n158:   const matches = [];\n159:   for (const packetName of listPacketDirectories(rootDir)) {\n160:     const packetDir = path.join(rootDir, packetName);\n161:     if (readPacketSpecFolder(packetDir, mode) === targetSpecFolder) {\n162:       matches.push(packetName);\n163:     }\n164:   }\n165: \n166:   return matches.at(-1) || null;\n167: }\n168: \n169: // SCRIPT_DIR: .opencode/skills/system-spec-kit/shared -> repo root is 4 levels\n170: // up. Mirrors the REPO_ROOT convention already used by\n171: // scripts/migrate-deep-loop-local-owner.cjs, so this stays a portable,\n172: // __dirname-relative anchor rather than a hardcoded absolute path.\n173: const REPO_ROOT = path.resolve(__dirname, '../../../../');\n174: \n175: /**\n176:  * Canonicalize a path via realpath when possible, falling back to the plain\n177:  * resolved value when the path does not exist yet or cannot be canonicalized.\n178:  * Needed because macOS aliases `os.tmpdir()` under `/var/...` while\n179:  * `fs.realpathSync()` resolves it to `/private/var/...` — reducer unit tests\n180:  * use both forms depending on whether they realpath their own fixture root.\n181:  */\n182: function canonicalizeForContainment(target) {\n183:   try {\n184:     return fs.realpathSync(target);\n185:   } catch (_error) {\n186:     return path.resolve(target);\n187:   }\n188: }\n189: \n190: /** Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it. */\n191: function isWithinRoot(root, candidate) {\n192:   if (candidate === root) {\n193:     return true;\n194:   }\n195:   const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n196:   return candidate.startsWith(prefix);\n197: }\n198: \n199: /**\n200:  * Allowed roots for resolveArtifactRoot() writes: this repo's two spec-folder\n201:  * roots (.opencode/specs, specs — the convention also used by\n202:  * normalizeSpecFolderReference() above and by migrate-deep-loop-local-owner.cjs),\n203:  * plus the OS temp dir. The temp dir is included because the reducer unit test\n204:  * suites (both here and under system-deep-loop/runtime) deliberately build\n205:  * isolated fixture trees under `os.tmpdir()` rather than the live repo tree —\n206:  * matching the same os.tmpdir()-as-allowed-root convention already used by\n207:  * shared/ipc/socket-server.ts's allowedSocketRoots().\n208:  */\n209: function getApprovedArtifactRoots() {\n210:   const roots = new Set();\n211:   roots.add(path.join(REPO_ROOT, '.opencode', 'specs'));\n212:   roots.add(canonicalizeForContainment(path.join(REPO_ROOT, '.opencode', 'specs')));\n213:   roots.add(path.join(REPO_ROOT, 'specs'));\n214:   roots.add(canonicalizeForContainment(path.join(REPO_ROOT, 'specs')));\n215:   roots.add(path.resolve(os.tmpdir()));\n216:   roots.add(canonicalizeForContainment(os.tmpdir()));\n217:   return [...roots];\n218: }\n219: \n220: function isWithinApprovedArtifactRoot(resolvedSpecFolder) {\n221:   const candidate = canonicalizeForContainment(resolvedSpecFolder);\n222:   return getApprovedArtifactRoots().some((root) => isWithinRoot(root, candidate));\n223: }\n224: \n225: /**\n226:  * Resolve the canonical artifact directory for review or research output.\n227:  *\n228:  * Conventions (post-028 contract fix):\n229:  *   - Root specs ALWAYS use flat: {spec_folder}/{mode}/\n230:  *   - Child phases use FLAT-FIRST:\n231:  *       (a) First run with empty {mode}/ directory → flat (subfolder=null)\n232:  *       (b) Continuation when flat artifact's config matches current target → reuse flat\n233:  *       (c) Existing pt-NN packet matches current target → reuse pt-NN\n234:  *       (d) Prior content exists for non-matching target → allocate pt-NN\n235:  *\n236:  * Subfolder naming convention (when pt-NN allocation kicks in): {phaseSlug}-pt-{NN}\n237:  *   - phaseSlug: the FULL immediate child phase segment under the spec tree\n238:  *     root (e.g. \"019-system-hardening\")\n239:  *   - NN: sequential two-digit counter scoped to that phase within the\n240:  *     artifact root directory; allocated by counting existing same-prefix\n241:  *     entries at call time\n242:  *\n243:  * Example:\n244:  *   - root spec run → {spec_folder}/research/\n245:  *   - child phase first run → {spec_folder}/research/   (flat, no pt-NN wrapper)\n246:  *   - child phase second run with prior content for different target → {spec_folder}/research/{phaseSlug}-pt-NN/\n247:  *   - child phase same-target continuation → reuses prior flat or pt-NN\n248:  *\n249:  * @param {string} specFolder - Absolute or relative path to the target spec folder\n250:  * @param {'review'|'research'|'context'|'alignment'} [mode='review'] - Which artifact type to resolve\n251:  *\n252:  * @returns {{\n253:  *   rootDir: string,\n254:  *   subfolder: string|null,\n255:  *   artifactDir: string,\n256:  *   artifactArchiveRoot: string\n257:  * }} Resolved packet root plus canonical packet/archive directories\n258:  */\n259: function resolveArtifactRoot(specFolder, mode = 'review') {\n260:   // Workflow write-authority: reject specFolder values that contain\n261:   // shell metacharacters or quote characters. The YAML workflow interpolates\n262:   // {spec_folder} into a `node -e` shell command; without this guard, a\n263:   // malicious specFolder containing single-quotes / semicolons / backticks /\n264:   // $ / | / & / < / > could break out of the shell-quoted argument and\n265:   // execute arbitrary code in the Node process or shell.\n266:   if (typeof specFolder !== 'string' || specFolder.length === 0) {\n267:     throw new Error(`resolveArtifactRoot: specFolder must be a non-empty string`);\n268:   }\n269:   if (/['\"`$;|&<>\\\\]/.test(specFolder)) {\n270:     throw new Error(\n271:       `resolveArtifactRoot: specFolder contains forbidden shell metacharacter(s); refusing to proceed`,\n272:     );\n273:   }\n274: \n275:   const resolved = path.resolve(specFolder);\n276: \n277:   // Containment: refuse to hand back an artifact root outside the workspace's\n278:   // legitimate spec-folder roots (or the OS temp dir used by reducer unit\n279:   // tests — see getApprovedArtifactRoots()). Without this, a relative\n280:   // traversal (e.g. \"../../etc\") or an absolute path elsewhere on disk with\n281:   // no forbidden shell metacharacters would sail past the guard above and\n282:   // route workflow writes outside the intended packet.\n283:   if (!isWithinApprovedArtifactRoot(resolved)) {\n284:     throw new Error(\n285:       `resolveArtifactRoot: specFolder resolves outside the approved specs roots (.opencode/specs, specs) or the OS temp dir; refusing to proceed: ${resolved}`,\n286:     );\n287:   }\n288: \n289:   const rootDir = path.join(resolved, mode);\n290:   const artifactArchiveRoot = path.join(resolved, `${mode}_archive`);\n291:   const ancestorSpecFolder = findAncestorSpecFolder(resolved);\n292: \n293:   // ROOT spec: always flat\n294:   if (!ancestorSpecFolder) {\n295:     return {\n296:       rootDir,\n297:       subfolder: null,\n298:       artifactDir: rootDir,\n299:       artifactArchiveRoot,\n300:     };\n301:   }\n302: \n303:   // CHILD phase: prefer existing pt-NN packet for current target if any\n304:   const existingPacket = findExistingPacket(rootDir, resolved, mode);\n305:   if (existingPacket) {\n306:     return {\n307:       rootDir,\n308:       subfolder: existingPacket,\n309:       artifactDir: path.join(rootDir, existingPacket),\n310:       artifactArchiveRoot: path.join(artifactArchiveRoot, existingPacket),\n311:     };\n312:   }\n313: \n314:   // CHILD phase: check for flat artifact at rootDir\n315:   const targetSpecFolder = normalizeSpecFolderReference(resolved);\n316:   const flatConfigPath = path.join(rootDir, MODE_CONFIG_FILE[mode]);\n317:   const flatStateLogPath = path.join(rootDir, MODE_STATE_FILE[mode]);\n318:   const hasFlatArtifact = fs.existsSync(flatConfigPath) || fs.existsSync(flatStateLogPath);\n319: \n320:   if (hasFlatArtifact) {\n321:     const flatSpecFolder = readPacketSpecFolder(rootDir, mode);\n322:     if (flatSpecFolder === null || flatSpecFolder === targetSpecFolder) {\n323:       // Flat artifact matches current target (or its config is unreadable but rootDir is owned by this target's path) → reuse flat\n324:       return {\n325:         rootDir,\n326:         subfolder: null,\n327:         artifactDir: rootDir,\n328:         artifactArchiveRoot,\n329:       };\n330:     }\n331:     // Flat artifact is for a different target — fall through to allocate pt-NN\n332:   }\n333: \n334:   const ptFolders = listPacketDirectories(rootDir);\n335:   const hasPtFolders = ptFolders.length > 0;\n336: \n337:   // CHILD phase first run: empty rootDir → flat\n338:   if (!hasFlatArtifact && !hasPtFolders) {\n339:     return {\n340:       rootDir,\n341:       subfolder: null,\n342:       artifactDir: rootDir,\n343:       artifactArchiveRoot,\n344:     };\n345:   }\n346: \n347:   // CHILD phase: prior content exists (flat for different target, or pt-NN folders)\n348:   // and no matching packet for current target → allocate next pt-NN\n349:   const subfolder = allocateShortSubfolder(rootDir, path.basename(resolved));\n350:   return {\n351:     rootDir,\n352:     subfolder,\n353:     artifactDir: path.join(rootDir, subfolder),\n354:     artifactArchiveRoot: path.join(artifactArchiveRoot, subfolder),\n355:   };\n356: }\n357: \n358: module.exports = {\n359:   resolveArtifactRoot,\n360:   allocateShortSubfolder,\n361:   normalizeSpecFolderReference,\n362: };\n\n(End of file - total 362 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Review Research Paths                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\n\nconst MODE_CONFIG_FILE = {\n  research: 'deep-research-config.json',\n  review: 'deep-review-config.json',\n  alignment: 'deep-alignment-config.json',\n};\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/review-research-paths.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Review Research Paths                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\n\nconst MODE_CONFIG_FILE = {\n  research: 'deep-research-config.json',\n  review: 'deep-review-config.json',\n  alignment: 'deep-alignment-config.json',\n};\n\nconst MODE_STATE_FILE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n  alignment: 'deep-alignment-state.jsonl',\n};\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Allocate the next artifact subfolder name under an artifact root directory\n * using the {phaseSlug}-pt-{NN} naming convention.\n *\n * The phase slug is the FULL first-segment folder name under the spec tree\n * root (e.g. \"019-system-hardening\").  NN is a two-digit zero-padded counter:\n * 1 + the number of existing pt-folders whose slug prefix matches the requested\n * phase, so repeated calls produce sequential names without any stored counter.\n *\n * @param {string} rootDir   - Absolute path to the artifact root (research/ or review/)\n * @param {string} phaseSlug - Full phase folder name (e.g. \"019-system-hardening\")\n * @returns {string} Subfolder name, e.g. \"019-system-hardening-pt-03\"\n */\nfunction allocateShortSubfolder(rootDir, phaseSlug) {\n  let existingCount = 0;\n\n  if (fs.existsSync(rootDir)) {\n    const prefix = `${phaseSlug}-pt-`;\n    existingCount = fs.readdirSync(rootDir).filter(\n      (entry) => entry.startsWith(prefix),\n    ).length;\n  }\n\n  const nn = String(existingCount + 1).padStart(2, '0');\n  return `${phaseSlug}-pt-${nn}`;\n}\n\nfunction normalizeSpecFolderReference(specFolder) {\n  if (!specFolder) {\n    return null;\n  }\n\n  const normalized = String(specFolder)\n    .trim()\n    .replace(/\\\\/g, '/')\n    .replace(/\\/+$/g, '');\n\n  if (!normalized) {\n    return null;\n  }\n\n  const opencodeSpecsMarker = '/.opencode/specs/';\n  const specsMarker = '/specs/';\n  const opencodeIndex = normalized.lastIndexOf(opencodeSpecsMarker);\n  if (opencodeIndex !== -1) {\n    return normalized.slice(opencodeIndex + opencodeSpecsMarker.length);\n  }\n\n  const specsIndex = normalized.lastIndexOf(specsMarker);\n  if (specsIndex !== -1) {\n    return normalized.slice(specsIndex + specsMarker.length);\n  }\n\n  return normalized\n    .replace(/^\\.\\/+/, '')\n    .replace(/^\\.opencode\\/specs\\//, '')\n    .replace(/^specs\\//, '');\n}\n\nfunction findAncestorSpecFolder(specFolder) {\n  let current = path.resolve(specFolder);\n\n  while (true) {\n    const parent = path.dirname(current);\n\n    if (parent === current || path.basename(parent) === 'specs') {\n      return null;\n    }\n\n    if (fs.existsSync(path.join(parent, 'spec.md'))) {\n      return parent;\n    }\n\n    current = parent;\n  }\n}\n\nfunction readPacketSpecFolder(packetDir, mode) {\n  const configPath = path.join(packetDir, MODE_CONFIG_FILE[mode]);\n  if (fs.existsSync(configPath)) {\n    try {\n      const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));\n      return normalizeSpecFolderReference(config.specFolder);\n    } catch (_error) {\n      // Fall through to state log probing.\n    }\n  }\n\n  const stateLogPath = path.join(packetDir, MODE_STATE_FILE[mode]);\n  if (!fs.existsSync(stateLogPath)) {\n    return null;\n  }\n\n  try {\n    const lines = fs.readFileSync(stateLogPath, 'utf8').split(/\\r?\\n/);\n    for (const line of lines) {\n      if (!line.trim()) {\n        continue;\n      }\n      const parsed = JSON.parse(line);\n      return normalizeSpecFolderReference(parsed.specFolder);\n    }\n  } catch (_error) {\n    return null;\n  }\n\n  return null;\n}\n\nfunction listPacketDirectories(rootDir) {\n  if (!fs.existsSync(rootDir)) {\n    return [];\n  }\n\n  return fs.readdirSync(rootDir, { withFileTypes: true })\n    .filter((entry) => entry.isDirectory() && /-pt-\\d+$/.test(entry.name))\n    .map((entry) => entry.name)\n    .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }));\n}\n\nfunction findExistingPacket(rootDir, specFolder, mode) {\n  const targetSpecFolder = normalizeSpecFolderReference(specFolder);\n\n  if (!targetSpecFolder) {\n    return null;\n  }\n\n  const matches = [];\n  for (const packetName of listPacketDirectories(rootDir)) {\n    const packetDir = path.join(rootDir, packetName);\n    if (readPacketSpecFolder(packetDir, mode) === targetSpecFolder) {\n      matches.push(packetName);\n    }\n  }\n\n  return matches.at(-1) || null;\n}\n\n// SCRIPT_DIR: .opencode/skills/system-spec-kit/shared -> repo root is 4 levels\n// up. Mirrors the REPO_ROOT convention already used by\n// scripts/migrate-deep-loop-local-owner.cjs, so this stays a portable,\n// __dirname-relative anchor rather than a hardcoded absolute path.\nconst REPO_ROOT = path.resolve(__dirname, '../../../../');\n\n/**\n * Canonicalize a path via realpath when possible, falling back to the plain\n * resolved value when the path does not exist yet or cannot be canonicalized.\n * Needed because macOS aliases `os.tmpdir()` under `/var/...` while\n * `fs.realpathSync()` resolves it to `/private/var/...` — reducer unit tests\n * use both forms depending on whether they realpath their own fixture root.\n */\nfunction canonicalizeForContainment(target) {\n  try {\n    return fs.realpathSync(target);\n  } catch (_error) {\n    return path.resolve(target);\n  }\n}\n\n/** Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it. */\nfunction isWithinRoot(root, candidate) {\n  if (candidate === root) {\n    return true;\n  }\n  const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n  return candidate.startsWith(prefix);\n}\n\n/**\n * Allowed roots for resolveArtifactRoot() writes: this repo's two spec-folder\n * roots (.opencode/specs, specs — the convention also used by\n * normalizeSpecFolderReference() above and by migrate-deep-loop-local-owner.cjs),\n * plus the OS temp dir. The temp dir is included because the reducer unit test\n * suites (both here and under system-deep-loop/runtime) deliberately build\n * isolated fixture trees under `os.tmpdir()` rather than the live repo tree —\n * matching the same os.tmpdir()-as-allowed-root convention already used by\n * shared/ipc/socket-server.ts's allowedSocketRoots().\n */\nfunction getApprovedArtifactRoots() {\n  const roots = new Set();\n  roots.add(path.join(REPO_ROOT, '.opencode', 'specs'));\n  roots.add(canonicalizeForContainment(path.join(REPO_ROOT, '.opencode', 'specs')));\n  roots.add(path.join(REPO_ROOT, 'specs'));\n  roots.add(canonicalizeForContainment(path.join(REPO_ROOT, 'specs')));\n  roots.add(path.resolve(os.tmpdir()));\n  roots.add(canonicalizeForContainment(os.tmpdir()));\n  return [...roots];\n}\n\nfunction isWithinApprovedArtifactRoot(resolvedSpecFolder) {\n  const candidate = canonicalizeForContainment(resolvedSpecFolder);\n  return getApprovedArtifactRoots().some((root) => isWithinRoot(root, candidate));\n}\n\n/**\n * Resolve the canonical artifact directory for review or research output.\n *\n * Conventions (post-028 contract fix):\n *   - Root specs ALWAYS use flat: {spec_folder}/{mode}/\n *   - Child phases use FLAT-FIRST:\n *       (a) First run with empty {mode}/ directory → flat (subfolder=null)\n *       (b) Continuation when flat artifact's config matches current target → reuse flat\n *       (c) Existing pt-NN packet matches current target → reuse pt-NN\n *       (d) Prior content exists for non-matching target → allocate pt-NN\n *\n * Subfolder naming convention (when pt-NN allocation kicks in): {phaseSlug}-pt-{NN}\n *   - phaseSlug: the FULL immediate child phase segment under the spec tree\n *     root (e.g. \"019-system-hardening\")\n *   - NN: sequential two-digit counter scoped to that phase within the\n *     artifact root directory; allocated by counting existing same-prefix\n *     entries at call time\n *\n * Example:\n *   - root spec run → {spec_folder}/research/\n *   - child phase first run → {spec_folder}/research/   (flat, no pt-NN wrapper)\n *   - child phase second run with prior content for different target → {spec_folder}/research/{phaseSlug}-pt-NN/\n *   - child phase same-target continuation → reuses prior flat or pt-NN\n *\n * @param {string} specFolder - Absolute or relative path to the target spec folder\n * @param {'review'|'research'|'context'|'alignment'} [mode='review'] - Which artifact type to resolve\n *\n * @returns {{\n *   rootDir: string,\n *   subfolder: string|null,\n *   artifactDir: string,\n *   artifactArchiveRoot: string\n * }} Resolved packet root plus canonical packet/archive directories\n */\nfunction resolveArtifactRoot(specFolder, mode = 'review') {\n  // Workflow write-authority: reject specFolder values that contain\n  // shell metacharacters or quote characters. The YAML workflow interpolates\n  // {spec_folder} into a `node -e` shell command; without this guard, a\n  // malicious specFolder containing single-quotes / semicolons / backticks /\n  // $ / | / & / < / > could break out of the shell-quoted argument and\n  // execute arbitrary code in the Node process or shell.\n  if (typeof specFolder !== 'string' || specFolder.length === 0) {\n    throw new Error(`resolveArtifactRoot: specFolder must be a non-empty string`);\n  }\n  if (/['\"`$;|&<>\\\\]/.test(specFolder)) {\n    throw new Error(\n      `resolveArtifactRoot: specFolder contains forbidden shell metacharacter(s); refusing to proceed`,\n    );\n  }\n\n  const resolved = path.resolve(specFolder);\n\n  // Containment: refuse to hand back an artifact root outside the workspace's\n  // legitimate spec-folder roots (or the OS temp dir used by reducer unit\n  // tests — see getApprovedArtifactRoots()). Without this, a relative\n  // traversal (e.g. \"../../etc\") or an absolute path elsewhere on disk with\n  // no forbidden shell metacharacters would sail past the guard above and\n  // route workflow writes outside the intended packet.\n  if (!isWithinApprovedArtifactRoot(resolved)) {\n    throw new Error(\n      `resolveArtifactRoot: specFolder resolves outside the approved specs roots (.opencode/specs, specs) or the OS temp dir; refusing to proceed: ${resolved}`,\n    );\n  }\n\n  const rootDir = path.join(resolved, mode);\n  const artifactArchiveRoot = path.join(resolved, `${mode}_archive`);\n  const ancestorSpecFolder = findAncestorSpecFolder(resolved);\n\n  // ROOT spec: always flat\n  if (!ancestorSpecFolder) {\n    return {\n      rootDir,\n      subfolder: null,\n      artifactDir: rootDir,\n      artifactArchiveRoot,\n    };\n  }\n\n  // CHILD phase: prefer existing pt-NN packet for current target if any\n  const existingPacket = findExistingPacket(rootDir, resolved, mode);\n  if (existingPacket) {\n    return {\n      rootDir,\n      subfolder: existingPacket,\n      artifactDir: path.join(rootDir, existingPacket),\n      artifactArchiveRoot: path.join(artifactArchiveRoot, existingPacket),\n    };\n  }\n\n  // CHILD phase: check for flat artifact at rootDir\n  const targetSpecFolder = normalizeSpecFolderReference(resolved);\n  const flatConfigPath = path.join(rootDir, MODE_CONFIG_FILE[mode]);\n  const flatStateLogPath = path.join(rootDir, MODE_STATE_FILE[mode]);\n  const hasFlatArtifact = fs.existsSync(flatConfigPath) || fs.existsSync(flatStateLogPath);\n\n  if (hasFlatArtifact) {\n    const flatSpecFolder = readPacketSpecFolder(rootDir, mode);\n    if (flatSpecFolder === null || flatSpecFolder === targetSpecFolder) {\n      // Flat artifact matches current target (or its config is unreadable but rootDir is owned by this target's path) → reuse flat\n      return {\n        rootDir,\n        subfolder: null,\n        artifactDir: rootDir,\n        artifactArchiveRoot,\n      };\n    }\n    // Flat artifact is for a different target — fall through to allocate pt-NN\n  }\n\n  const ptFolders = listPacketDirectories(rootDir);\n  const hasPtFolders = ptFolders.length > 0;\n\n  // CHILD phase first run: empty rootDir → flat\n  if (!hasFlatArtifact && !hasPtFolders) {\n    return {\n      rootDir,\n      subfolder: null,\n      artifactDir: rootDir,\n      artifactArchiveRoot,\n    };\n  }\n\n  // CHILD phase: prior content exists (flat for different target, or pt-NN folders)\n  // and no matching packet for current target → allocate next pt-NN\n  const subfolder = allocateShortSubfolder(rootDir, path.basename(resolved));\n  return {\n    rootDir,\n    subfolder,\n    artifactDir: path.join(rootDir, subfolder),\n    artifactArchiveRoot: path.join(artifactArchiveRoot, subfolder),\n  };\n}\n\nmodule.exports = {\n  resolveArtifactRoot,\n  allocateShortSubfolder,\n  normalizeSpecFolderReference,\n};","lineStart":1,"lineEnd":362,"totalLines":362,"truncated":false}},"title":".opencode/skills/system-spec-kit/shared/review-research-paths.cjs","time":{"start":1783915749994,"end":1783915750029}},"metadata":{"openai":{"itemId":"fc_0271813eead27663016a5464e4ca588191a16902c0da2a1cbd"}},"id":"prt_f59aa1dae0011lG951vwXmfZxn","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59aa0e22001rEGBQMeIUmreSR"}}
