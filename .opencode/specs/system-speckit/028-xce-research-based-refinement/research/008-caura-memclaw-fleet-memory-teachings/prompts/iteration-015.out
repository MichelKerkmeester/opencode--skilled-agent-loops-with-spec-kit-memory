{"type":"tool_use","timestamp":1780728863943,"sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","part":{"type":"tool","tool":"read","callID":"call_TERkpGL99CH6iHi8GykpjkAr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/clients/storage_client.py","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/clients/storage_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Async HTTP client for core-storage-api.\n2: \n3: The worker hits a small set of endpoints:\n4: * ``PATCH /api/v1/storage/memories/{memory_id}`` — write the embedding\n5:   (CAURA-594) or enrichment fields (CAURA-595) back once the provider\n6:   call succeeds.\n7: * ``GET /api/v1/storage/memories/embedding-by-content-hash`` — best-\n8:   effort cache lookup so an identical-content row that already has an\n9:   embedding short-circuits the embed provider call.\n10: \n11: Module-level singleton client (``get_storage_client()``) so connection\n12: pooling persists across pull-loop iterations. Closed via\n13: :func:`close_storage_client` from the FastAPI lifespan.\n14: \n15: CAURA-591 Y3 / CAURA-595 follow-up: every outbound request is signed\n16: with a Cloud Run ID token whose audience is the storage service URL.\n17: The identity_token helper transparently returns ``{}`` when no creds\n18: are available (local dev / OSS) so the unauthenticated docker-compose\n19: path continues to work; on Cloud Run the metadata server issues a\n20: real token and the writer's ``--no-allow-unauthenticated`` accepts it.\n21: \"\"\"\n22: \n23: from __future__ import annotations\n24: \n25: import logging\n26: from collections.abc import AsyncIterator, Awaitable, Callable\n27: from dataclasses import dataclass\n28: from typing import Any\n29: from uuid import UUID\n30: \n31: import httpx\n32: \n33: from common.constants import LIFECYCLE_STALE_ARCHIVE_WEIGHT\n34: from core_worker.clients.identity_token import evict as _evict_id_token\n35: from core_worker.clients.identity_token import fetch_auth_header\n36: \n37: logger = logging.getLogger(__name__)\n38: \n39: _client: httpx.AsyncClient | None = None\n40: # Audience for the writer ID token — set alongside the singleton in\n41: # ``get_storage_client()``. Mirrors core-api's ``self._base_url``: the\n42: # rstrip'd ``core_storage_api_url`` from settings, used both as the\n43: # httpx ``base_url`` and as the Cloud Run audience claim.\n44: _audience: str | None = None\n45: _PREFIX = \"/api/v1/storage\"\n46: \n47: \n48: def get_storage_client() -> httpx.AsyncClient:\n49:     \"\"\"Return the singleton :class:`httpx.AsyncClient` used by the consumer.\n50: \n51:     Settings are read from a freshly-built ``Settings()`` on first call\n52:     only — subsequent calls return the cached instance regardless of\n53:     any env changes. Tests that need a different config call\n54:     :func:`close_storage_client` between cases to force re-construction.\n55:     \"\"\"\n56:     global _client, _audience\n57:     if _client is None:\n58:         # Lazy import — avoids paying the pydantic-settings load cost\n59:         # on cold-start for the worker's healthz probe.\n60:         from core_worker.config import Settings\n61: \n62:         s = Settings()  # type: ignore[call-arg]\n63:         # ``rstrip(\"/\")`` so a trailing slash in the env var doesn't\n64:         # produce a different audience string than Cloud Run validates.\n65:         _audience = s.core_storage_api_url.rstrip(\"/\")\n66:         _client = httpx.AsyncClient(\n67:             base_url=_audience,\n68:             timeout=httpx.Timeout(s.storage_http_timeout_s),\n69:         )\n70:     return _client\n71: \n72: \n73: async def close_storage_client() -> None:\n74:     \"\"\"Close the singleton (idempotent). Called from app lifespan shutdown.\"\"\"\n75:     global _client, _audience\n76:     if _client is not None:\n77:         await _client.aclose()\n78:         _client = None\n79:         _audience = None\n80: \n81: \n82: async def _signed_call(\n83:     fn: Callable[..., Awaitable[httpx.Response]],\n84:     *args: Any,\n85:     **kwargs: Any,\n86: ) -> httpx.Response:\n87:     \"\"\"Issue ``fn(*args, **kwargs)`` with the Cloud Run ID-token\n88:     Authorization header attached, with one transparent retry on 401.\n89: \n90:     ``fn`` is a bound method on the caller's ``httpx.AsyncClient``\n91:     (``client.get``, ``client.patch``, etc.) — single integration point\n92:     so a future endpoint helper can't add a request without auth or\n93:     skip the eviction-on-401 path.\n94: \n95:     On 401: evict the cached token (so a mid-TTL credential rotation or\n96:     SA/binding fix self-heals instead of waiting out the 50 min cache),\n97:     fetch a fresh token, and retry the request once. Without this\n98:     retry, every in-flight task during a rotation burns one Pub/Sub\n99:     delivery attempt against the DLQ budget; the retry makes a rotation\n100:     invisible to callers. A second 401 (rotation didn't help, or the\n101:     SA was actually unbound) propagates to the caller's normal\n102:     error-handling path.\n103: \n104:     On the OSS / local-dev path (``_audience`` unset, or google.auth\n105:     unavailable) the merged auth header is empty and the call goes\n106:     out unauthenticated — matching the docker-compose ``allUsers``\n107:     writer. 403 is intentionally NOT a trigger for eviction: 403 means\n108:     the token was accepted but IAM rejected the caller, which the\n109:     cache cannot fix.\n110:     \"\"\"\n111:     headers = dict(kwargs.pop(\"headers\", None) or {})\n112:     if _audience is not None:\n113:         headers.update(await fetch_auth_header(_audience))\n114:     resp = await fn(*args, headers=headers, **kwargs)\n115:     if resp.status_code == 401 and _audience is not None:\n116:         _evict_id_token(_audience)\n117:         # Rebind to a NEW dict rather than ``.update()`` in place — the\n118:         # first call still holds a reference to the original headers\n119:         # mapping (httpx is already done with it, but a debug logger\n120:         # or test inspector that snapshots the call args would\n121:         # otherwise see the rotated token retro-fitted into the first\n122:         # call's record).\n123:         headers = {**headers, **await fetch_auth_header(_audience)}\n124:         resp = await fn(*args, headers=headers, **kwargs)\n125:     return resp\n126: \n127: \n128: async def find_embedding_by_content_hash(\n129:     client: httpx.AsyncClient,\n130:     *,\n131:     tenant_id: str,\n132:     content_hash: str,\n133: ) -> list[float] | None:\n134:     \"\"\"Look up a previously computed embedding for the same content.\n135: \n136:     Returns ``None`` when there's no cached row, the row exists but its\n137:     embedding is NULL (still pending), or the storage call fails for\n138:     any reason. Callers fall through to the embedding provider.\n139: \n140:     Storage contract (``GET /memories/embedding-by-content-hash``)\n141:     returns the bare ``list[float] | None`` — JSON ``null`` on miss,\n142:     not ``{\"embedding\": null}``. Treating the body as a dict and\n143:     calling ``.get(\"embedding\")`` on a JSON-null parse crashes with\n144:     ``AttributeError: 'NoneType' object has no attribute 'get'``,\n145:     which used to be masked by 403s before the CAURA-595 ID-token\n146:     PR landed and the cache lookup actually started succeeding.\n147:     \"\"\"\n148:     try:\n149:         resp = await _signed_call(\n150:             client.get,\n151:             f\"{_PREFIX}/memories/embedding-by-content-hash\",\n152:             params={\"tenant_id\": tenant_id, \"content_hash\": content_hash},\n153:         )\n154:         if resp.status_code != 200:\n155:             return None\n156:         # ``resp.json()`` raises on malformed bodies (a partial response\n157:         # from a stray proxy, an HTML error page sneaking through with\n158:         # a 200, etc.). The docstring promises \"fails for any reason →\n159:         # None\" so the worker falls through to a fresh provider call\n160:         # instead of nacking and forcing Pub/Sub redelivery — staying\n161:         # consistent with the ``HTTPError`` handling above.\n162:         return resp.json()\n163:     except (httpx.HTTPError, ValueError):\n164:         logger.exception(\"storage embedding-cache lookup failed; treating as miss\")\n165:         return None\n166: \n167: \n168: async def update_memory_embedding(\n169:     client: httpx.AsyncClient,\n170:     *,\n171:     memory_id: UUID,\n172:     tenant_id: str,\n173:     embedding: list[float],\n174: ) -> None:\n175:     \"\"\"PATCH the embedding onto the memory row.\n176: \n177:     Raises on transient (5xx / 429) responses so the consumer nacks\n178:     → Pub/Sub redelivers. Permanent 4xx errors (404, 422) are logged\n179:     and ack-dropped — retrying them just burns the\n180:     max-delivery-attempts budget against an event that will never\n181:     succeed (row deleted between event publish and processing, or a\n182:     schema mismatch the storage layer rejects either way).\n183: \n184:     ``tenant_id`` is included in the body so the storage layer can\n185:     guard against cross-tenant updates.\n186: \n187:     The hot-path writer set ``metadata.embedding_pending=true`` when\n188:     deferring the embed; clear it via ``metadata_patch`` on the same\n189:     PATCH so a read-after-success returns clean state instead of\n190:     confusingly claiming the row is still pending.\n191:     \"\"\"\n192:     resp = await _signed_call(\n193:         client.patch,\n194:         f\"{_PREFIX}/memories/{memory_id}\",\n195:         json={\n196:             \"tenant_id\": tenant_id,\n197:             \"embedding\": embedding,\n198:             \"metadata_patch\": {\"embedding_pending\": False},\n199:         },\n200:     )\n201:     if resp.status_code == 404:\n202:         # Row was deleted after the event was published — common-enough\n203:         # legitimate race that it shouldn't churn the DLQ.\n204:         logger.warning(\n205:             \"memory %s not found in storage; ack-dropping embed-request \"\n206:             \"(row deleted between publish and processing)\",\n207:             memory_id,\n208:         )\n209:         return\n210:     if resp.status_code == 422:\n211:         # Storage rejected the payload shape. Won't pass on a redelivery\n212:         # either — log loudly so the schema mismatch is visible and ack.\n213:         logger.warning(\n214:             \"storage rejected embedding PATCH for memory %s with 422; ack-dropping\",\n215:             memory_id,\n216:         )\n217:         return\n218:     # 5xx / 429 / network → raise → consumer nacks → Pub/Sub redelivers.\n219:     resp.raise_for_status()\n220: \n221: \n222: @dataclass(frozen=True)\n223: class NullEmbeddingRow:\n224:     \"\"\"Identifiers for one memory row that needs re-embedding.\n225: \n226:     Carries only the fields needed to address a follow-up\n227:     ``GET /memories/{id}`` fetch. Raw ``content`` / ``content_hash``\n228:     are NOT included — the listing endpoint deliberately returns\n229:     ids-only (defence-in-depth on the unauthenticated storage API),\n230:     and the worker fetches content per row before publishing.\n231:     \"\"\"\n232: \n233:     memory_id: UUID\n234:     tenant_id: str\n235: \n236: \n237: async def iter_memories_with_null_embedding(\n238:     client: httpx.AsyncClient,\n239:     *,\n240:     tenant_id: str,\n\n(Showing lines 1-240 of 502. Use offset=241 to continue.)\n</content>","metadata":{"preview":"\"\"\"Async HTTP client for core-storage-api.\n\nThe worker hits a small set of endpoints:\n* ``PATCH /api/v1/storage/memories/{memory_id}`` — write the embedding\n  (CAURA-594) or enrichment fields (CAURA-595) back once the provider\n  call succeeds.\n* ``GET /api/v1/storage/memories/embedding-by-content-hash`` — best-\n  effort cache lookup so an identical-content row that already has an\n  embedding short-circuits the embed provider call.\n\nModule-level singleton client (``get_storage_client()``) so connection\npooling persists across pull-loop iterations. Closed via\n:func:`close_storage_client` from the FastAPI lifespan.\n\nCAURA-591 Y3 / CAURA-595 follow-up: every outbound request is signed\nwith a Cloud Run ID token whose audience is the storage service URL.\nThe identity_token helper transparently returns ``{}`` when no creds\nare available (local dev / OSS) so the unauthenticated docker-compose\npath continues to work; on Cloud Run the metadata server issues a\nreal token and the writer's ``--no-allow-unauthenticated`` accepts it.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/clients/storage_client.py","text":"\"\"\"Async HTTP client for core-storage-api.\n\nThe worker hits a small set of endpoints:\n* ``PATCH /api/v1/storage/memories/{memory_id}`` — write the embedding\n  (CAURA-594) or enrichment fields (CAURA-595) back once the provider\n  call succeeds.\n* ``GET /api/v1/storage/memories/embedding-by-content-hash`` — best-\n  effort cache lookup so an identical-content row that already has an\n  embedding short-circuits the embed provider call.\n\nModule-level singleton client (``get_storage_client()``) so connection\npooling persists across pull-loop iterations. Closed via\n:func:`close_storage_client` from the FastAPI lifespan.\n\nCAURA-591 Y3 / CAURA-595 follow-up: every outbound request is signed\nwith a Cloud Run ID token whose audience is the storage service URL.\nThe identity_token helper transparently returns ``{}`` when no creds\nare available (local dev / OSS) so the unauthenticated docker-compose\npath continues to work; on Cloud Run the metadata server issues a\nreal token and the writer's ``--no-allow-unauthenticated`` accepts it.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections.abc import AsyncIterator, Awaitable, Callable\nfrom dataclasses import dataclass\nfrom typing import Any\nfrom uuid import UUID\n\nimport httpx\n\nfrom common.constants import LIFECYCLE_STALE_ARCHIVE_WEIGHT\nfrom core_worker.clients.identity_token import evict as _evict_id_token\nfrom core_worker.clients.identity_token import fetch_auth_header\n\nlogger = logging.getLogger(__name__)\n\n_client: httpx.AsyncClient | None = None\n# Audience for the writer ID token — set alongside the singleton in\n# ``get_storage_client()``. Mirrors core-api's ``self._base_url``: the\n# rstrip'd ``core_storage_api_url`` from settings, used both as the\n# httpx ``base_url`` and as the Cloud Run audience claim.\n_audience: str | None = None\n_PREFIX = \"/api/v1/storage\"\n\n\ndef get_storage_client() -> httpx.AsyncClient:\n    \"\"\"Return the singleton :class:`httpx.AsyncClient` used by the consumer.\n\n    Settings are read from a freshly-built ``Settings()`` on first call\n    only — subsequent calls return the cached instance regardless of\n    any env changes. Tests that need a different config call\n    :func:`close_storage_client` between cases to force re-construction.\n    \"\"\"\n    global _client, _audience\n    if _client is None:\n        # Lazy import — avoids paying the pydantic-settings load cost\n        # on cold-start for the worker's healthz probe.\n        from core_worker.config import Settings\n\n        s = Settings()  # type: ignore[call-arg]\n        # ``rstrip(\"/\")`` so a trailing slash in the env var doesn't\n        # produce a different audience string than Cloud Run validates.\n        _audience = s.core_storage_api_url.rstrip(\"/\")\n        _client = httpx.AsyncClient(\n            base_url=_audience,\n            timeout=httpx.Timeout(s.storage_http_timeout_s),\n        )\n    return _client\n\n\nasync def close_storage_client() -> None:\n    \"\"\"Close the singleton (idempotent). Called from app lifespan shutdown.\"\"\"\n    global _client, _audience\n    if _client is not None:\n        await _client.aclose()\n        _client = None\n        _audience = None\n\n\nasync def _signed_call(\n    fn: Callable[..., Awaitable[httpx.Response]],\n    *args: Any,\n    **kwargs: Any,\n) -> httpx.Response:\n    \"\"\"Issue ``fn(*args, **kwargs)`` with the Cloud Run ID-token\n    Authorization header attached, with one transparent retry on 401.\n\n    ``fn`` is a bound method on the caller's ``httpx.AsyncClient``\n    (``client.get``, ``client.patch``, etc.) — single integration point\n    so a future endpoint helper can't add a request without auth or\n    skip the eviction-on-401 path.\n\n    On 401: evict the cached token (so a mid-TTL credential rotation or\n    SA/binding fix self-heals instead of waiting out the 50 min cache),\n    fetch a fresh token, and retry the request once. Without this\n    retry, every in-flight task during a rotation burns one Pub/Sub\n    delivery attempt against the DLQ budget; the retry makes a rotation\n    invisible to callers. A second 401 (rotation didn't help, or the\n    SA was actually unbound) propagates to the caller's normal\n    error-handling path.\n\n    On the OSS / local-dev path (``_audience`` unset, or google.auth\n    unavailable) the merged auth header is empty and the call goes\n    out unauthenticated — matching the docker-compose ``allUsers``\n    writer. 403 is intentionally NOT a trigger for eviction: 403 means\n    the token was accepted but IAM rejected the caller, which the\n    cache cannot fix.\n    \"\"\"\n    headers = dict(kwargs.pop(\"headers\", None) or {})\n    if _audience is not None:\n        headers.update(await fetch_auth_header(_audience))\n    resp = await fn(*args, headers=headers, **kwargs)\n    if resp.status_code == 401 and _audience is not None:\n        _evict_id_token(_audience)\n        # Rebind to a NEW dict rather than ``.update()`` in place — the\n        # first call still holds a reference to the original headers\n        # mapping (httpx is already done with it, but a debug logger\n        # or test inspector that snapshots the call args would\n        # otherwise see the rotated token retro-fitted into the first\n        # call's record).\n        headers = {**headers, **await fetch_auth_header(_audience)}\n        resp = await fn(*args, headers=headers, **kwargs)\n    return resp\n\n\nasync def find_embedding_by_content_hash(\n    client: httpx.AsyncClient,\n    *,\n    tenant_id: str,\n    content_hash: str,\n) -> list[float] | None:\n    \"\"\"Look up a previously computed embedding for the same content.\n\n    Returns ``None`` when there's no cached row, the row exists but its\n    embedding is NULL (still pending), or the storage call fails for\n    any reason. Callers fall through to the embedding provider.\n\n    Storage contract (``GET /memories/embedding-by-content-hash``)\n    returns the bare ``list[float] | None`` — JSON ``null`` on miss,\n    not ``{\"embedding\": null}``. Treating the body as a dict and\n    calling ``.get(\"embedding\")`` on a JSON-null parse crashes with\n    ``AttributeError: 'NoneType' object has no attribute 'get'``,\n    which used to be masked by 403s before the CAURA-595 ID-token\n    PR landed and the cache lookup actually started succeeding.\n    \"\"\"\n    try:\n        resp = await _signed_call(\n            client.get,\n            f\"{_PREFIX}/memories/embedding-by-content-hash\",\n            params={\"tenant_id\": tenant_id, \"content_hash\": content_hash},\n        )\n        if resp.status_code != 200:\n            return None\n        # ``resp.json()`` raises on malformed bodies (a partial response\n        # from a stray proxy, an HTML error page sneaking through with\n        # a 200, etc.). The docstring promises \"fails for any reason →\n        # None\" so the worker falls through to a fresh provider call\n        # instead of nacking and forcing Pub/Sub redelivery — staying\n        # consistent with the ``HTTPError`` handling above.\n        return resp.json()\n    except (httpx.HTTPError, ValueError):\n        logger.exception(\"storage embedding-cache lookup failed; treating as miss\")\n        return None\n\n\nasync def update_memory_embedding(\n    client: httpx.AsyncClient,\n    *,\n    memory_id: UUID,\n    tenant_id: str,\n    embedding: list[float],\n) -> None:\n    \"\"\"PATCH the embedding onto the memory row.\n\n    Raises on transient (5xx / 429) responses so the consumer nacks\n    → Pub/Sub redelivers. Permanent 4xx errors (404, 422) are logged\n    and ack-dropped — retrying them just burns the\n    max-delivery-attempts budget against an event that will never\n    succeed (row deleted between event publish and processing, or a\n    schema mismatch the storage layer rejects either way).\n\n    ``tenant_id`` is included in the body so the storage layer can\n    guard against cross-tenant updates.\n\n    The hot-path writer set ``metadata.embedding_pending=true`` when\n    deferring the embed; clear it via ``metadata_patch`` on the same\n    PATCH so a read-after-success returns clean state instead of\n    confusingly claiming the row is still pending.\n    \"\"\"\n    resp = await _signed_call(\n        client.patch,\n        f\"{_PREFIX}/memories/{memory_id}\",\n        json={\n            \"tenant_id\": tenant_id,\n            \"embedding\": embedding,\n            \"metadata_patch\": {\"embedding_pending\": False},\n        },\n    )\n    if resp.status_code == 404:\n        # Row was deleted after the event was published — common-enough\n        # legitimate race that it shouldn't churn the DLQ.\n        logger.warning(\n            \"memory %s not found in storage; ack-dropping embed-request \"\n            \"(row deleted between publish and processing)\",\n            memory_id,\n        )\n        return\n    if resp.status_code == 422:\n        # Storage rejected the payload shape. Won't pass on a redelivery\n        # either — log loudly so the schema mismatch is visible and ack.\n        logger.warning(\n            \"storage rejected embedding PATCH for memory %s with 422; ack-dropping\",\n            memory_id,\n        )\n        return\n    # 5xx / 429 / network → raise → consumer nacks → Pub/Sub redelivers.\n    resp.raise_for_status()\n\n\n@dataclass(frozen=True)\nclass NullEmbeddingRow:\n    \"\"\"Identifiers for one memory row that needs re-embedding.\n\n    Carries only the fields needed to address a follow-up\n    ``GET /memories/{id}`` fetch. Raw ``content`` / ``content_hash``\n    are NOT included — the listing endpoint deliberately returns\n    ids-only (defence-in-depth on the unauthenticated storage API),\n    and the worker fetches content per row before publishing.\n    \"\"\"\n\n    memory_id: UUID\n    tenant_id: str\n\n\nasync def iter_memories_with_null_embedding(\n    client: httpx.AsyncClient,\n    *,\n    tenant_id: str,","lineStart":1,"lineEnd":240,"totalLines":502,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-worker/src/core_worker/clients/storage_client.py","time":{"start":1780728863937,"end":1780728863942}},"metadata":{"openai":{"itemId":"fc_02424c5326d602fa016a23c41fcfc88191be6bdbd854d5e139"}},"id":"prt_e9bb61cac001yAa7qVrS4yWKL8","sessionID":"ses_1644b0d23ffeusCdGYhGesQX9J","messageID":"msg_e9bb5efad001LEyz9285Z8aN47"}}
