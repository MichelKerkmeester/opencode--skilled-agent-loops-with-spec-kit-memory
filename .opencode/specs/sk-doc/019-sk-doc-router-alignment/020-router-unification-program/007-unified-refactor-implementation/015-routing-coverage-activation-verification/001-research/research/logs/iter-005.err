.opencode/specs/sk-doc/016-create-diff-mode/010-fluid-responsive-report/review/lineages/sol/logs/fanout-lineage.out:23:{"type":"tool_use","timestamp":1784210499960,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_8a3DdpIYueijRvsJFrqA5twL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":635,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n635:                dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n636:                p0_resolution_gate_pass = boolean\n637:                active_p0_count = number of active P0 findings\n638:                evidence_density_gate_pass = boolean\n639:                avg_evidence_per_finding = numeric evidence density\n640:                hotspot_saturation_gate_pass = boolean\n641:                claim_adjudication_gate_pass = boolean\n642:                claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n643:                fix_completeness_replay_gate_pass = boolean\n644:                security_sensitive_fix_scope = boolean\n645:                fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n646:                fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n647:                candidate_coverage_gate_pass = boolean\n648:                candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n649:                candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n650:                graphless_fallback_gate_pass = boolean\n651:                graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n652:                graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n653:                graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n654:                recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n655:           6. COMBINED STOP RULE:\n656:                a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n657:                b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n658:                     decision = \"BLOCKED\"\n659:                     stop_blocked = true\n660:                     stopReason = \"blockedStop\"\n661:                     # Blocked-stop closure: blockedBy must be string[] per the\n662:                     # published review blocked-stop contract. Extract the `.type`\n663:                     # field from each structured graph blocker; preserve the full\n664:                     # objects in graph_blocker_detail_json for operator inspection.\n665:                     blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n666:                     blocked_by_csv = graph_blockers_csv\n667:                     graph_blocker_detail_json = graph_blockers_json\n668:                     recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n669:                c) if STOP is legal AND graph_decision == \"CONTINUE\":\n670:                     decision = \"CONTINUE\"\n671:                     stop_blocked = false\n672:                     reason = \"graph_convergence_continue\"\n673:                d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n674:         outputs:\n675:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n676:           - reason: \"Human-readable stop reason\"\n677:           - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n678:           - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n679:           - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n680:           - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n681:           - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n682:           - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n683:           - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n684:           - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n685:           - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n686:           - active_p0_count: \"Active P0 finding count at stop-check time\"\n687:           - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n688:           - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n689:           - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n690:           - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n691:           - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n692:           - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n693:           - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n694:           - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n695:           - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n696:           - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n697:           - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n698:           - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n699:           - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n700:           - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n701:           - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n702:           - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n703:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n704:           - graph_signals_json: \"JSON object returned by graph convergence\"\n705:           - graph_blockers_json: \"JSON array of graph blockers\"\n706:           - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n707:           - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n708: \n709:       step_emit_blocked_stop:\n710:         action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n711:         if_blocked:\n712:           append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n713:           log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n714:         if_not_blocked:\n715:           proceed: true\n716: \n717:       step_handle_convergence:\n718:         action: \"Act on convergence decision\"\n719:         if_stop:\n720:           branch_on: \"convergence_mode == 'divergent' AND reason == 'all_dimensions_clean'\"\n721:           if_divergent_eligible:\n722:             eligibility_contract:\n723:               required_decision: \"STOP\"\n724:               eligible_reasons: [all_dimensions_clean]\n725:               excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n726:               fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot. The nine legal-stop gates have already run and remain unchanged.\"\n727:             steps:\n728:               step_prepare_divergent_pivot:\n729:                 action: \"Generate state-grounded read-only review candidates and prepare or resume the pivot transaction\"\n730:                 command: |\n731:                   node --experimental-strip-types --input-type=module <<'EOF'\n732:                   import {\n733:                     buildReviewPivotPreparationInput,\n734:                     renderReviewPivotSeatPrompt,\n735:                   } from './.opencode/skills/system-deep-loop/deep-review/scripts/divergent-review-pivot.ts';\n736:                   import {\n737:                     preparePivotTransaction,\n738:                   } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n739: \n740:                   const input = buildReviewPivotPreparationInput({\n741:                     artifactRoot: '{state_paths.packet_dir}',\n742:                     configPath: '{state_paths.config}',\n743:                     stateLogPath: '{state_paths.state_log}',\n744:                     strategyPath: '{state_paths.strategy}',\n745:                     registryPath: '{state_paths.findings_registry}',\n746:                     currentIteration: Number('{current_iteration}'),\n747:                     maxIterations: Number('{max_iterations}'),\n748:                     triggerReason: '{reason}',\n749:                   });\n750:                   const prepared = await preparePivotTransaction(input);\n751:                   const seatPrompts = prepared.status === 'pending'\n752:                     ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n753:                         seat.id,\n754:                         renderReviewPivotSeatPrompt(seat, prepared.dispatchContext),\n755:                       ]))\n756:                     : {};\n757:                   process.stdout.write(`${JSON.stringify({\n758:                     ...prepared,\n759:                     seatPrompts,\n760:                     boundaryRejections: input.boundaryRejections,\n761:                   })}\\n`);\n762:                   EOF\n763:                 working_directory: \"{repo_root}\"\n764:                 outputs:\n765:                   - pivot_prepare_json: \"The complete parsed JSON result\"\n766:                   - pivot_prepare_status: \"status from the prepare result\"\n767:                   - pivot_id: \"pivotId from the prepare result\"\n768:                   - pivot_paths_json: \"paths from the prepare result as JSON\"\n769:                   - pivot_resumed: \"resumed from the prepare result\"\n770:                   - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n771:                   - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n772:                   - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n773:                   - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n774:                   - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n775:                   - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n776:                   - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n777:                   - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n778:                 short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n779: \n780:               step_dispatch_pivot_seat_001:\n781:                 action: \"Natively dispatch the analytical read-only review direction-selection seat\"\n782:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n783:                 capture_timing: true\n784:                 if_native:\n785:                   dispatch:\n786:                     agent: deep-review\n787:                     model: opus\n788:                     context_source: \"pivot_seat_001_prompt\"\n789:                   wait_for_completion: true\n790:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n791:                 outputs:\n792:                   - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n793:                   - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n794:                   - pivot_seat_001_error_json: \"{name,message} when rejected\"\n795:                   - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n796:                   - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n797:                   - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n798: \n799:               step_record_pivot_seat_001:\n800:                 action: \"Durably record the seat-001 native dispatch outcome\"\n801:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n802:                 command: |\n803:                   node --experimental-strip-types --input-type=module <<'EOF'\n804:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n805:                   const status = '{pivot_seat_001_dispatch_status}';\n806:                   const outcome = status === 'fulfilled'\n807:                     ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n808:                     : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n809:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n810:                   EOF\n811:                 working_directory: \"{repo_root}\"\n812: \n813:               step_dispatch_pivot_seat_002:\n814:                 action: \"Natively dispatch the critical read-only review direction-selection seat\"\n815:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n816:                 capture_timing: true\n817:                 if_native:\n818:                   dispatch:\n819:                     agent: deep-review\n820:                     model: opus\n821:                     context_source: \"pivot_seat_002_prompt\"\n822:                   wait_for_completion: true\n823:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n824:                 outputs:\n825:                   - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n826:                   - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n827:                   - pivot_seat_002_error_json: \"{name,message} when rejected\"\n828:                   - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n829:                   - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n830:                   - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n831: \n832:               step_record_pivot_seat_002:\n833:                 action: \"Durably record the seat-002 native dispatch outcome\"\n834:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n835:                 command: |\n836:                   node --experimental-strip-types --input-type=module <<'EOF'\n837:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n838:                   const status = '{pivot_seat_002_dispatch_status}';\n839:                   const outcome = status === 'fulfilled'\n840:                     ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n841:                     : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n842:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n843:                   EOF\n844:                 working_directory: \"{repo_root}\"\n845: \n846:               step_dispatch_pivot_seat_003:\n847:                 action: \"Natively dispatch the pragmatic read-only review direction-selection seat\"\n848:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n849:                 capture_timing: true\n850:                 if_native:\n851:                   dispatch:\n852:                     agent: deep-review\n853:                     model: opus\n854:                     context_source: \"pivot_seat_003_prompt\"\n855:                   wait_for_completion: true\n856:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n857:                 outputs:\n858:                   - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n859:                   - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n860:                   - pivot_seat_003_error_json: \"{name,message} when rejected\"\n861:                   - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n862:                   - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n863:                   - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n864: \n865:               step_record_pivot_seat_003:\n866:                 action: \"Durably record the seat-003 native dispatch outcome\"\n867:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n868:                 command: |\n869:                   node --experimental-strip-types --input-type=module <<'EOF'\n870:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n871:                   const status = '{pivot_seat_003_dispatch_status}';\n872:                   const outcome = status === 'fulfilled'\n873:                     ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n874:                     : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n875:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n876:                   EOF\n877:                 working_directory: \"{repo_root}\"\n878: \n879:               step_finalize_divergent_pivot:\n880:                 action: \"Finalize the prepared pivot after all missing native seats are durable\"\n881:                 skip_when: \"pivot_prepare_status != 'pending'\"\n882:                 command: |\n883:                   node --experimental-strip-types --input-type=module <<'EOF'\n884:                   import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n885:                   process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n886:                   EOF\n887:                 working_directory: \"{repo_root}\"\n888:                 outputs:\n889:                   - pivot_finalize_json: \"The complete parsed final result\"\n890: \n891:               step_resolve_divergent_pivot_result:\n892:                 action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n893:                 branch_on: \"pivot_prepare_status\"\n894:                 if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n895:                 if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n896: \n897:               step_apply_divergent_pivot_result:\n898:                 action: \"Adopt a successful read-only review direction or fail closed to the existing synthesis path\"\n899:                 branch_on: \"pivot_result.status\"\n900:                 if_completed:\n901:                   set:\n902:                     next_dimension: \"{pivot_result.restoredFocus}\"\n903:                     pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n904:                     saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n905:                   command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n906:                   log: \"Divergent review pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n907:                   proceed_to: step_normalize_pause_events\n908:                 if_failed:\n909:                   log: \"Divergent review pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n910:                   skip_to: phase_synthesis\n911:             on_error:\n912:               log: \"Divergent review pivot integration error; failing closed to the existing synthesis path.\"\n913:               skip_to: phase_synthesis\n914:           if_existing_terminal_path:\n915:             log: \"Loop stopping. Reason: {reason}\"\n916:             skip_to: phase_synthesis\n917:         if_blocked:\n918:           log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n919:         if_stuck_recovery:\n920:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n921:           recovery_strategies:\n922:             - \"Change granularity: file-level → function-level → line-level review\"\n923:             - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n924:             - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n925:           pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n926:           set:\n927:             next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n928:             pending_stop_event: \"stuck_recovery\"\n929:             pending_stop_reason: \"stuckRecovery\"\n930:             pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n931:           reset: { stuck_count: 0 }\n932:         if_continue:\n933:           log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n934: \n935:       step_normalize_pause_events:\n936:         action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n937:         if_pending_pause_event:\n938:           append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n939:           message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n940:           reset:\n941:             pending_stop_event: null\n942:             pending_stop_reason: null\n943:             pending_stop_detail: null\n944:           halt: true\n945:         if_pending_stuck_recovery:\n946:           append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n947:           reset:\n948:             pending_stop_event: null\n949:             pending_stop_reason: null\n950:             pending_stop_detail: null\n951:         if_no_pending_event:\n952:           proceed: true\n953: \n954:       step_generate_state_summary:\n955:         action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n956:         generate: |\n957:           STATE SUMMARY (auto-generated):\n958:           Iteration: {current_iteration} of {max_iterations}\n959:           Dimension: {next_dimension}\n960:           Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n961:           Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n962:           Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n963:           {resource_map_prompt_line}\n964:           Coverage Age: {coverage_age}\n965:           Last 2 ratios: {ratio_prev} -> {ratio_latest}\n966:           Stuck count: {stuck_count}\n967:           Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n968: \n969:       step_marker_scan:\n970:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n971:         algorithm: |\n972:           if current_iteration > 1:\n973:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n974:             if file_exists(PREV_PROMPT_PATH):\n975:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n976:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n977:                 log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n978:                 halt with exit code 2\n979:         note: |\n980:           False-positive prevention: only matches when the first line is exactly one of the\n981:           three canonical markers. Markers appearing in comments or body text are ignored.\n982:           True-positive triggers only when a previous iteration's rendered prompt literally\n983:           starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n984: \n985:       step_dispatch_iteration:\n986:         action: \"Dispatch @deep-review agent for one review iteration\"\n987:         resolve_executor:\n988:           source: \"config.executor\"\n989:           loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n990:         pre_dispatch:\n991:           generate_summary: |\n992:             STATE SUMMARY (auto-generated):\n993:             Iteration: {current_iteration} of {max_iterations}\n994:             Dimension: {next_dimension}\n995:             Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n996:             Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n997:             Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n998:             {resource_map_prompt_line}\n999:             Coverage Age: {coverage_age}\n1000:             Last 2 ratios: {ratio_prev} -> {ratio_latest}\n1001:             Stuck count: {stuck_count}\n1002:             Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n1003:           render_prompt_pack:\n1004:             template_path: \".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n1005:             renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n1006:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n1007:             variables:\n1008:               state_summary: \"{state_summary}\"\n1009:               current_iteration: \"{current_iteration}\"\n1010:               max_iterations: \"{max_iterations}\"\n1011:               next_dimension: \"{next_dimension}\"\n1012:               review_target: \"{review_target}\"\n1013:               review_scope_files: \"{review_scope_files}\"\n1014:               p0_count: \"{p0_count}\"\n1015:               p1_count: \"{p1_count}\"\n1016:               p2_count: \"{p2_count}\"\n1017:               pivot_lineage: \"{pivot_lineage}\"\n1018:               saturated_directions: \"{saturated_directions}\"\n1019:               state_paths_config: \"{state_paths.config}\"\n1020:               state_paths_state_log: \"{state_paths.state_log}\"\n1021:               state_paths_findings_registry: \"{state_paths.findings_registry}\"\n1022:               state_paths_strategy: \"{state_paths.strategy}\"\n1023:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n1024:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n1025:         pre_dispatch_audit:\n1026:           skip_when: \"config.executor.kind == 'native'\"\n1027:           call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n1028:           args:\n1029:             stateLogPath: \"{state_paths.state_log}\"\n1030:             executor: \"{config.executor}\"\n1031:             iteration: \"{current_iteration}\"\n1032:         branch_on: \"config.executor.kind\"\n1033:         if_native:\n1034:           dispatch:\n1035:             agent: deep-review\n1036:             model: opus\n1037:             context_source: \"rendered_prompt_pack\"\n1038:           wait_for_completion: true\n1039:         if_cli_copilot:\n1040:           command: |\n1041:             node --experimental-strip-types --input-type=module <<'EOF'\n1042:             import { readFileSync, writeFileSync } from 'node:fs';\n1043:             import { createHash } from 'node:crypto';\n1044: \n1045:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1046:             import { buildCopilotPromptArg } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n1047: \n1048:             const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n1049:             const prompt = readFileSync(promptPath, 'utf8');\n1050: \n1051:             // Workflow-resolved spec folder is the only legal write authority.\n1052:             // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n1053:             // is the single source of truth for rejecting empty / unresolved\n1054:             // template / whitespace-only / string-coerced empty values. The\n1055:             // YAML hands the raw `{spec_folder}` directly; on rejection the\n1056:             // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n1057:             // enforcement, --allow-all-tools stripped).\n1058:             const specFolderRaw = '{spec_folder}';\n1059:             const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n1060: \n1061:             const baseArgs = [\n1062:               '-p',\n1063:               prompt,\n1064:               '--model',\n1065:               '{config.executor.model}',\n1066:               '--allow-all-tools',\n1067:               '--no-ask-user',\n1068:             ];\n1069: \n1070:             const built = buildCopilotPromptArg({\n1071:               promptPath,\n1072:               prompt,\n1073:               targetAuthority,\n1074:               baseArgv: baseArgs,\n1075:             });\n1076: \n1077:             // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n1078:             // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n1079:             // Write it to disk so the file Copilot reads via @path opens with\n1080:             // the authority block. Without this, recovered/bootstrap folder\n1081:             // mentions inside the file could still anchor the model.\n1082:             if (built.promptFileBody !== undefined) {\n1083:               writeFileSync(promptPath, built.promptFileBody, 'utf8');\n1084:             }\n1085: \n1086:             // Copilot is routed through the audited executor wrapper so it produces\n1087:             // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n1088:             // There is no cli-copilot kind in the executor schema, so it\n1089:             // dispatches as kind:'native' (full env passthrough, no recursion-guard\n1090:             // layer configured for copilot); the receipt still records the real\n1091:             // 'copilot' command + built.argv as facts.\n1092:             const dispatchFacts = {\n1093:               command: 'deep/review',\n1094:               mode: 'review',\n1095:               specFolder: '{spec_folder}',\n1096:               artifactDir: '{state_paths.packet_dir}',\n1097:               iteration: Number('{current_iteration}'),\n1098:               executorKind: '{config.executor.kind}',\n1099:               branchId: '{config.executor.kind}',\n1100:               sessionId: '{session_id}',\n1101:               generation: Number('{generation}'),\n1102:             };\n1103:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1104:             process.exit(\n1105:               runAuditedExecutorCommand({\n1106:                 command: 'copilot',\n1107:                 args: built.argv,\n1108:                 cwd: '{repo_root}',\n1109:                 timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1110:                 stateLogPath: '{state_paths.state_log}',\n1111:                 executor: {\n1112:                   kind: 'native',\n1113:                   model: '{config.executor.model}',\n1114:                   configDir: null,\n1115:                   reasoningEffort: null,\n1116:                   serviceTier: null,\n1117:                   sandboxMode: null,\n1118:                   timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1119:                   governor: null,\n1120:                 },\n1121:                 iteration: Number('{current_iteration}'),\n1122:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1123:                 dispatchId,\n1124:               }),\n1125:             );\n1126:             EOF\n1127:           working_directory: \"{repo_root}\"\n1128:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1129:           wait_for_completion: true\n1130:           notes:\n1131:             - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n1132:             - \"copilot has no stdin support; prompt is positional\"\n1133:             - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n1134:             - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n1135:             - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n1136:             - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n1137:             - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n1138:         if_cli_claude_code:\n1139:           command: |\n1140:             node --experimental-strip-types --input-type=module <<'EOF'\n1141:             import { readFileSync } from 'node:fs';\n1142:             import { createHash } from 'node:crypto';\n1143: \n1144:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1145: \n1146:             const configDir = '{optional_claude_config_dir}';\n1147:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1148:             const executor = {\n1149:               kind: 'cli-claude-code',\n1150:               model: '{config.executor.model}',\n1151:               configDir: configDir || null,\n1152:               reasoningEffort,\n1153:               serviceTier: null,\n1154:               sandboxMode: null,\n1155:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1156:               governor: null,\n1157:             };\n1158:             const args = [\n1159:               '-p',\n1160:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n1161:               '--model',\n1162:               executor.model,\n1163:               '--permission-mode',\n1164:               'acceptEdits',\n1165:               '--output-format',\n1166:               'text',\n1167:             ];\n1168:             if (executor.reasoningEffort) {\n1169:               args.push('--effort', executor.reasoningEffort);\n1170:             }\n1171: \n1172:             // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n1173:             // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n1174:             const parentEnv = { ...process.env };\n1175:             if (configDir) {\n1176:               parentEnv.CLAUDE_CONFIG_DIR = configDir;\n1177:             }\n1178: \n1179:             const dispatchFacts = {\n1180:               command: 'deep/review',\n1181:               mode: 'review',\n1182:               specFolder: '{spec_folder}',\n1183:               artifactDir: '{state_paths.packet_dir}',\n1184:               iteration: Number('{current_iteration}'),\n1185:               executorKind: '{config.executor.kind}',\n1186:               branchId: '{config.executor.kind}',\n1187:               sessionId: '{session_id}',\n1188:               generation: Number('{generation}'),\n1189:             };\n1190:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1191:             process.exit(\n1192:               runAuditedExecutorCommand({\n1193:                 command: 'claude',\n1194:                 args,\n1195:                 cwd: '{repo_root}',\n1196:                 timeoutSeconds: executor.timeoutSeconds,\n1197:                 stateLogPath: '{state_paths.state_log}',\n1198:                 executor,\n1199:                 iteration: Number('{current_iteration}'),\n1200:                 guardContext: { env: parentEnv },\n1201:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1202:                 dispatchId,\n1203:               }),\n1204:             );\n1205:             EOF\n1206:           working_directory: \"{repo_root}\"\n1207:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1208:           wait_for_completion: true\n1209:           render_hint:\n1210:             optional_claude_config_dir: |\n1211:               If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n1212:               Otherwise expand to empty string.\n1213:           notes:\n1214:             - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1215:             - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n1216:             - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n1217:             - \"claude-code supports --effort for reasoning depth\"\n1218:         if_cli_opencode:\n1219:           command: |\n1220:             node --experimental-strip-types --input-type=module <<'EOF'\n1221:             import { execFileSync } from 'node:child_process';\n1222:             import { appendFileSync, readFileSync, realpathSync } from 'node:fs';\n1223:             import { createHash } from 'node:crypto';\n1224:             import { isAbsolute, relative, resolve } from 'node:path';\n1225: \n1226:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1227: \n1228:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1229:             const executor = {\n1230:               kind: 'cli-opencode',\n1231:               model: '{config.executor.model}',\n1232:               configDir: null,\n1233:               reasoningEffort,\n1234:               serviceTier: null,\n1235:               sandboxMode: null,\n1236:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1237:               governor: null,\n1238:             };\n1239:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1240:             if (!promptBody.includes('BANNED OPERATIONS') || !promptBody.includes('ALLOWED WRITE PATHS')) {\n1241:               throw new Error('Unsafe cli-opencode dispatch: rendered prompt is missing required write-containment sections');\n1242:             }\n1243: \n1244:             const repoRoot = realpathSync('{repo_root}');\n1245:             const artifactDir = resolve(repoRoot, '{state_paths.packet_dir}');\n1246:             const artifactRelative = relative(repoRoot, artifactDir);\n1247:             if (artifactRelative === '' || artifactRelative.startsWith('..') || isAbsolute(artifactRelative)) {\n1248:               throw new Error('Unsafe cli-opencode dispatch: artifact directory must be a strict descendant of the worktree root');\n1249:             }\n1250: \n1251:             const git = (args, cwd = repoRoot, trim = true) => {\n1252:               const output = execFileSync('git', args, { cwd, encoding: 'utf8' });\n1253:               return trim ? output.trim() : output;\n1254:             };\n1255:             const resolveGitPath = (candidate) => realpathSync(isAbsolute(candidate) ? candidate : resolve(repoRoot, candidate));\n1256:             const gitDir = resolveGitPath(git(['rev-parse', '--git-dir']));\n1257:             const commonGitDir = resolveGitPath(git(['rev-parse', '--git-common-dir']));\n1258:             if (gitDir === commonGitDir) {\n1259:               throw new Error('Unsafe cli-opencode dispatch: --dir must point at an isolated linked worktree');\n1260:             }\n1261: \n1262:             const primaryBlock = git(['worktree', 'list', '--porcelain'])\n1263:               .split(/\\n\\n+/)\n1264:               .find((block) => /^branch refs\\/heads\\/(?:main|master)$/m.test(block));\n1265:             const primaryLine = primaryBlock?.split('\\n').find((line) => line.startsWith('worktree '));\n1266:             if (!primaryLine) {\n1267:               throw new Error('Unsafe cli-opencode dispatch: primary main/master worktree could not be resolved');\n1268:             }\n1269:             const primaryRoot = realpathSync(primaryLine.slice('worktree '.length));\n1270:             const primaryStatus = git(['status', '--porcelain=v1', '--untracked-files=all'], primaryRoot);\n1271:             if (primaryStatus) {\n1272:               throw new Error('Unsafe cli-opencode dispatch: primary worktree must be clean before unrestricted execution');\n1273:             }\n1274: \n1275:             const dirtyPaths = [\n1276:               ...git(['diff', '--name-only', '-z', 'HEAD', '--'], repoRoot, false).split('\\0'),\n1277:               ...git(['ls-files', '--others', '--exclude-standard', '-z'], repoRoot, false).split('\\0'),\n1278:             ].filter(Boolean);\n1279:             const outsideArtifactDir = dirtyPaths.filter((candidate) => {\n1280:               const candidateRelative = relative(artifactDir, resolve(repoRoot, candidate));\n1281:               return candidateRelative.startsWith('..') || isAbsolute(candidateRelative);\n1282:             });\n1283:             if (outsideArtifactDir.length > 0) {\n1284:               throw new Error(`Unsafe cli-opencode dispatch: worktree changes outside the artifact directory: ${outsideArtifactDir.join(', ')}`);\n1285:             }\n1286: \n1287:             const recoveryBaselineCommit = git(['rev-parse', '--verify', 'HEAD']);\n1288:             appendFileSync(\n1289:               '{state_paths.state_log}',\n1290:               `${JSON.stringify({ type: 'event', event: 'recovery_baseline', mode: 'review', iteration: Number('{current_iteration}'), recoveryBaselineCommit, worktree: repoRoot, timestamp: new Date().toISOString() })}\\n`,\n1291:               'utf8',\n1292:             );\n1293:             const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n1294:               + '\\n\\n'\n1295:               + promptBody;\n1296:             const args = [\n1297:               'run',\n1298:               '--model',\n1299:               executor.model,\n1300:               '--format',\n1301:               'json',\n1302:               '--dangerously-skip-permissions',\n1303:               '--pure',\n1304:               '--dir',\n1305:               '{repo_root}',\n1306:             ];\n1307:             if (executor.reasoningEffort) {\n1308:               args.push('--variant', executor.reasoningEffort);\n1309:             }\n1310:             args.push(message);\n1311: \n1312:             const dispatchFacts = {\n1313:               command: 'deep/review',\n1314:               mode: 'review',\n1315:               specFolder: '{spec_folder}',\n1316:               artifactDir: '{state_paths.packet_dir}',\n1317:               iteration: Number('{current_iteration}'),\n1318:               executorKind: '{config.executor.kind}',\n1319:               branchId: '{config.executor.kind}',\n1320:               sessionId: '{session_id}',\n1321:               generation: Number('{generation}'),\n1322:             };\n1323:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1324:             process.exit(\n1325:               runAuditedExecutorCommand({\n1326:                 command: 'opencode',\n1327:                 args,\n1328:                 cwd: '{repo_root}',\n1329:                 timeoutSeconds: executor.timeoutSeconds,\n1330:                 stateLogPath: '{state_paths.state_log}',\n1331:                 executor,\n1332:                 iteration: Number('{current_iteration}'),\n1333:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1334:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1335:                 input: '',\n1336:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1337:                 dispatchId,\n1338:               }),\n1339:             );\n1340:             EOF\n1341:           working_directory: \"{repo_root}\"\n1342:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1343:           wait_for_completion: true\n1344:           notes:\n1345:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1346:             - \"Fail closed before dispatch unless the rendered containment sections exist, --dir is an isolated linked worktree, the primary worktree is clean, and current-worktree changes are confined to artifact_dir; append the recovery-baseline commit to state_log\"\n1347:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n1348:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1349:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1350:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1351:             - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1352:         if_cli_codex:\n1353:           command: |\n1354:             node --experimental-strip-types --input-type=module <<'EOF'\n1355:             import { readFileSync } from 'node:fs';\n1356:             import { execFileSync } from 'node:child_process';\n1357: \n1358:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1359: \n1360:             // Fail closed: a requested codex executor must dispatch codex or abort,\n1361:             // never silently degrade to another executor. Undetected absence is what\n1362:             // got Codex deprecated before, so the branch exits non-zero when the\n1363:             // binary is missing instead of falling through to a native/other path.\n1364:             let codexAvailable = false;\n1365:             try {\n1366:               execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n1367:               codexAvailable = true;\n1368:             } catch {}\n1369:             if (!codexAvailable) {\n1370:               console.error('cli-codex executor unavailable: command -v codex failed');\n1371:               process.exit(1);\n1372:             }\n1373: \n1374:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1375:             const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n1376:             const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n1377:             const executor = {\n1378:               kind: 'cli-codex',\n1379:               model,\n1380:               configDir: null,\n1381:               reasoningEffort,\n1382:               serviceTier,\n1383:               sandboxMode: 'workspace-write',\n1384:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1385:               governor: null,\n1386:             };\n1387: \n1388:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1389: \n1390:             // codex reads the iteration prompt from stdin via the trailing '-'. A review\n1391:             // iteration must WRITE its own iteration file, delta and state record, so the\n1392:             // sandbox is workspace-write — read-only would block those required writes.\n1393:             // approval_policy=never keeps the run non-interactive.\n1394:             const args = ['exec'];\n1395:             if (model) {\n1396:               args.push('--model', model);\n1397:             }\n1398:             args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n1399:             if (serviceTier) {\n1400:               args.push('-c', 'service_tier=' + serviceTier);\n1401:             }\n1402:             args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n1403: \n1404:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1405:             process.exit(\n1406:               runAuditedExecutorCommand({\n1407:                 command: 'codex',\n1408:                 args,\n1409:                 cwd: '{repo_root}',\n1410:                 timeoutSeconds: executor.timeoutSeconds,\n1411:                 stateLogPath: '{state_paths.state_log}',\n1412:                 executor,\n1413:                 iteration: Number('{current_iteration}'),\n1414:                 input: promptBody,\n1415:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1416:                 dispatchId,\n1417:               }),\n1418:             );\n1419:             EOF\n1420:           working_directory: \"{repo_root}\"\n1421:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1422:           wait_for_completion: true\n1423:           notes:\n1424:             - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n1425:             - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n1426:             - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n\n(Output capped at 50 KB. Showing lines 635-1426. Use offset=1427 to continue.)\n</content>","metadata":{"preview":"               dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n               p0_resolution_gate_pass = boolean\n               active_p0_count = number of active P0 findings\n               evidence_density_gate_pass = boolean\n               avg_evidence_per_finding = numeric evidence density\n               hotspot_saturation_gate_pass = boolean\n               claim_adjudication_gate_pass = boolean\n               claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n               fix_completeness_replay_gate_pass = boolean\n               security_sensitive_fix_scope = boolean\n               fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"               dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n               p0_resolution_gate_pass = boolean\n               active_p0_count = number of active P0 findings\n               evidence_density_gate_pass = boolean\n               avg_evidence_per_finding = numeric evidence density\n               hotspot_saturation_gate_pass = boolean\n               claim_adjudication_gate_pass = boolean\n               claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n               fix_completeness_replay_gate_pass = boolean\n               security_sensitive_fix_scope = boolean\n               fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n          6. COMBINED STOP RULE:\n               a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n               b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n                    decision = \"BLOCKED\"\n                    stop_blocked = true\n                    stopReason = \"blockedStop\"\n                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n                    blocked_by_csv = graph_blockers_csv\n                    graph_blocker_detail_json = graph_blockers_json\n                    recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n               c) if STOP is legal AND graph_decision == \"CONTINUE\":\n                    decision = \"CONTINUE\"\n                    stop_blocked = false\n                    reason = \"graph_convergence_continue\"\n               d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n          - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n          - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n          - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n          - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n          - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n          - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n          - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n          - active_p0_count: \"Active P0 finding count at stop-check time\"\n          - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n          - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n          - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n          - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n          - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n          - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n          - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:\n        action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n        if_blocked:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          branch_on: \"convergence_mode == 'divergent' AND reason == 'all_dimensions_clean'\"\n          if_divergent_eligible:\n            eligibility_contract:\n              required_decision: \"STOP\"\n              eligible_reasons: [all_dimensions_clean]\n              excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n              fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot. The nine legal-stop gates have already run and remain unchanged.\"\n            steps:\n              step_prepare_divergent_pivot:\n                action: \"Generate state-grounded read-only review candidates and prepare or resume the pivot transaction\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import {\n                    buildReviewPivotPreparationInput,\n                    renderReviewPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-review/scripts/divergent-review-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildReviewPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.findings_registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),\n                    triggerReason: '{reason}',\n                  });\n                  const prepared = await preparePivotTransaction(input);\n                  const seatPrompts = prepared.status === 'pending'\n                    ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n                        seat.id,\n                        renderReviewPivotSeatPrompt(seat, prepared.dispatchContext),\n                      ]))\n                    : {};\n                  process.stdout.write(`${JSON.stringify({\n                    ...prepared,\n                    seatPrompts,\n                    boundaryRejections: input.boundaryRejections,\n                  })}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_prepare_json: \"The complete parsed JSON result\"\n                  - pivot_prepare_status: \"status from the prepare result\"\n                  - pivot_id: \"pivotId from the prepare result\"\n                  - pivot_paths_json: \"paths from the prepare result as JSON\"\n                  - pivot_resumed: \"resumed from the prepare result\"\n                  - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n                  - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n                  - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n                  - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n                  - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n                  - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n                  - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n                  - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n                short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n\n              step_dispatch_pivot_seat_001:\n                action: \"Natively dispatch the analytical read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_001_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n                outputs:\n                  - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_001_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_001:\n                action: \"Durably record the seat-001 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_001_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_002:\n                action: \"Natively dispatch the critical read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_002_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n                outputs:\n                  - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_002_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_002:\n                action: \"Durably record the seat-002 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_002_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_003:\n                action: \"Natively dispatch the pragmatic read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_003_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n                outputs:\n                  - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_003_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_003:\n                action: \"Durably record the seat-003 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_003_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_finalize_divergent_pivot:\n                action: \"Finalize the prepared pivot after all missing native seats are durable\"\n                skip_when: \"pivot_prepare_status != 'pending'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_finalize_json: \"The complete parsed final result\"\n\n              step_resolve_divergent_pivot_result:\n                action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n                branch_on: \"pivot_prepare_status\"\n                if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n                if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n\n              step_apply_divergent_pivot_result:\n                action: \"Adopt a successful read-only review direction or fail closed to the existing synthesis path\"\n                branch_on: \"pivot_result.status\"\n                if_completed:\n                  set:\n                    next_dimension: \"{pivot_result.restoredFocus}\"\n                    pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n                    saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n                  command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n                  log: \"Divergent review pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n                  proceed_to: step_normalize_pause_events\n                if_failed:\n                  log: \"Divergent review pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n                  skip_to: phase_synthesis\n            on_error:\n              log: \"Divergent review pivot integration error; failing closed to the existing synthesis path.\"\n              skip_to: phase_synthesis\n          if_existing_terminal_path:\n            log: \"Loop stopping. Reason: {reason}\"\n            skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:\n            next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n            pending_stop_event: \"stuck_recovery\"\n            pending_stop_reason: \"stuckRecovery\"\n            pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n\n      step_normalize_pause_events:\n        action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n        if_pending_pause_event:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n          halt: true\n        if_pending_stuck_recovery:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n        if_no_pending_event:\n          proceed: true\n\n      step_generate_state_summary:\n        action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n        generate: |\n          STATE SUMMARY (auto-generated):\n          Iteration: {current_iteration} of {max_iterations}\n          Dimension: {next_dimension}\n          Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n          Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n          Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n          {resource_map_prompt_line}\n          Coverage Age: {coverage_age}\n          Last 2 ratios: {ratio_prev} -> {ratio_latest}\n          Stuck count: {stuck_count}\n          Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch @deep-review agent for one review iteration\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Iteration: {current_iteration} of {max_iterations}\n            Dimension: {next_dimension}\n            Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n            Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n            Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n            {resource_map_prompt_line}\n            Coverage Age: {coverage_age}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest}\n            Stuck count: {stuck_count}\n            Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n          render_prompt_pack:\n            template_path: \".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_dimension: \"{next_dimension}\"\n              review_target: \"{review_target}\"\n              review_scope_files: \"{review_scope_files}\"\n              p0_count: \"{p0_count}\"\n              p1_count: \"{p1_count}\"\n              p2_count: \"{p2_count}\"\n              pivot_lineage: \"{pivot_lineage}\"\n              saturated_directions: \"{saturated_directions}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_findings_registry: \"{state_paths.findings_registry}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.kind\"\n        if_native:\n          dispatch:\n            agent: deep-review\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_copilot:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync, writeFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n            import { buildCopilotPromptArg } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n\n            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n            const prompt = readFileSync(promptPath, 'utf8');\n\n            // Workflow-resolved spec folder is the only legal write authority.\n            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n            // is the single source of truth for rejecting empty / unresolved\n            // template / whitespace-only / string-coerced empty values. The\n            // YAML hands the raw `{spec_folder}` directly; on rejection the\n            // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n            // enforcement, --allow-all-tools stripped).\n            const specFolderRaw = '{spec_folder}';\n            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n\n            const baseArgs = [\n              '-p',\n              prompt,\n              '--model',\n              '{config.executor.model}',\n              '--allow-all-tools',\n              '--no-ask-user',\n            ];\n\n            const built = buildCopilotPromptArg({\n              promptPath,\n              prompt,\n              targetAuthority,\n              baseArgv: baseArgs,\n            });\n\n            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n            // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n            // Write it to disk so the file Copilot reads via @path opens with\n            // the authority block. Without this, recovered/bootstrap folder\n            // mentions inside the file could still anchor the model.\n            if (built.promptFileBody !== undefined) {\n              writeFileSync(promptPath, built.promptFileBody, 'utf8');\n            }\n\n            // Copilot is routed through the audited executor wrapper so it produces\n            // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n            // There is no cli-copilot kind in the executor schema, so it\n            // dispatches as kind:'native' (full env passthrough, no recursion-guard\n            // layer configured for copilot); the receipt still records the real\n            // 'copilot' command + built.argv as facts.\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'copilot',\n                args: built.argv,\n                cwd: '{repo_root}',\n                timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                stateLogPath: '{state_paths.state_log}',\n                executor: {\n                  kind: 'native',\n                  model: '{config.executor.model}',\n                  configDir: null,\n                  reasoningEffort: null,\n                  serviceTier: null,\n                  sandboxMode: null,\n                  timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                  governor: null,\n                },\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n            - \"copilot has no stdin support; prompt is positional\"\n            - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n            - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n            - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n            - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n            - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const configDir = '{optional_claude_config_dir}';\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              configDir: configDir || null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              'acceptEdits',\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n            // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n            const parentEnv = { ...process.env };\n            if (configDir) {\n              parentEnv.CLAUDE_CONFIG_DIR = configDir;\n            }\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                guardContext: { env: parentEnv },\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_claude_config_dir: |\n              If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n              Otherwise expand to empty string.\n          notes:\n            - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n            - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { execFileSync } from 'node:child_process';\n            import { appendFileSync, readFileSync, realpathSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n            import { isAbsolute, relative, resolve } from 'node:path';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            if (!promptBody.includes('BANNED OPERATIONS') || !promptBody.includes('ALLOWED WRITE PATHS')) {\n              throw new Error('Unsafe cli-opencode dispatch: rendered prompt is missing required write-containment sections');\n            }\n\n            const repoRoot = realpathSync('{repo_root}');\n            const artifactDir = resolve(repoRoot, '{state_paths.packet_dir}');\n            const artifactRelative = relative(repoRoot, artifactDir);\n            if (artifactRelative === '' || artifactRelative.startsWith('..') || isAbsolute(artifactRelative)) {\n              throw new Error('Unsafe cli-opencode dispatch: artifact directory must be a strict descendant of the worktree root');\n            }\n\n            const git = (args, cwd = repoRoot, trim = true) => {\n              const output = execFileSync('git', args, { cwd, encoding: 'utf8' });\n              return trim ? output.trim() : output;\n            };\n            const resolveGitPath = (candidate) => realpathSync(isAbsolute(candidate) ? candidate : resolve(repoRoot, candidate));\n            const gitDir = resolveGitPath(git(['rev-parse', '--git-dir']));\n            const commonGitDir = resolveGitPath(git(['rev-parse', '--git-common-dir']));\n            if (gitDir === commonGitDir) {\n              throw new Error('Unsafe cli-opencode dispatch: --dir must point at an isolated linked worktree');\n            }\n\n            const primaryBlock = git(['worktree', 'list', '--porcelain'])\n              .split(/\\n\\n+/)\n              .find((block) => /^branch refs\\/heads\\/(?:main|master)$/m.test(block));\n            const primaryLine = primaryBlock?.split('\\n').find((line) => line.startsWith('worktree '));\n            if (!primaryLine) {\n              throw new Error('Unsafe cli-opencode dispatch: primary main/master worktree could not be resolved');\n            }\n            const primaryRoot = realpathSync(primaryLine.slice('worktree '.length));\n            const primaryStatus = git(['status', '--porcelain=v1', '--untracked-files=all'], primaryRoot);\n            if (primaryStatus) {\n              throw new Error('Unsafe cli-opencode dispatch: primary worktree must be clean before unrestricted execution');\n            }\n\n            const dirtyPaths = [\n              ...git(['diff', '--name-only', '-z', 'HEAD', '--'], repoRoot, false).split('\\0'),\n              ...git(['ls-files', '--others', '--exclude-standard', '-z'], repoRoot, false).split('\\0'),\n            ].filter(Boolean);\n            const outsideArtifactDir = dirtyPaths.filter((candidate) => {\n              const candidateRelative = relative(artifactDir, resolve(repoRoot, candidate));\n              return candidateRelative.startsWith('..') || isAbsolute(candidateRelative);\n            });\n            if (outsideArtifactDir.length > 0) {\n              throw new Error(`Unsafe cli-opencode dispatch: worktree changes outside the artifact directory: ${outsideArtifactDir.join(', ')}`);\n            }\n\n            const recoveryBaselineCommit = git(['rev-parse', '--verify', 'HEAD']);\n            appendFileSync(\n              '{state_paths.state_log}',\n              `${JSON.stringify({ type: 'event', event: 'recovery_baseline', mode: 'review', iteration: Number('{current_iteration}'), recoveryBaselineCommit, worktree: repoRoot, timestamp: new Date().toISOString() })}\\n`,\n              'utf8',\n            );\n            const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"Fail closed before dispatch unless the rendered containment sections exist, --dir is an isolated linked worktree, the primary worktree is clean, and current-worktree changes are confined to artifact_dir; append the recovery-baseline commit to state_log\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { execFileSync } from 'node:child_process';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            // Fail closed: a requested codex executor must dispatch codex or abort,\n            // never silently degrade to another executor. Undetected absence is what\n            // got Codex deprecated before, so the branch exits non-zero when the\n            // binary is missing instead of falling through to a native/other path.\n            let codexAvailable = false;\n            try {\n              execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n              codexAvailable = true;\n            } catch {}\n            if (!codexAvailable) {\n              console.error('cli-codex executor unavailable: command -v codex failed');\n              process.exit(1);\n            }\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n            const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n            const executor = {\n              kind: 'cli-codex',\n              model,\n              configDir: null,\n              reasoningEffort,\n              serviceTier,\n              sandboxMode: 'workspace-write',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n\n            // codex reads the iteration prompt from stdin via the trailing '-'. A review\n            // iteration must WRITE its own iteration file, delta and state record, so the\n            // sandbox is workspace-write — read-only would block those required writes.\n            // approval_policy=never keeps the run non-interactive.\n            const args = ['exec'];\n            if (model) {\n              args.push('--model', model);\n            }\n            args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n            if (serviceTier) {\n              args.push('-c', 'service_tier=' + serviceTier);\n            }\n            args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'codex',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                input: promptBody,\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n            - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n            - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"","lineStart":635,"lineEnd":1426,"totalLines":1427,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1784210499952,"end":1784210499958}},"metadata":{"openai":{"itemId":"fc_03c8c2a24a1024bf016a58e443cc1881959ce4e2b63ed88fbe"}},"id":"prt_f6b3ba938001BHq6VeNHpGSGzD","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b749c001MtDgHQsckMQNI0"}}
