   158	function applyHardGate(d1, d2) {
   159	  if (d2 && d2.hard_gate_failed === true) {
   160	    return { d1_capped: { ...d1, score: 0.0, hard_gate_capped: true }, hard_gate_failed: true };
   161	  }
   162	  return { d1_capped: d1, hard_gate_failed: false };
   163	}
