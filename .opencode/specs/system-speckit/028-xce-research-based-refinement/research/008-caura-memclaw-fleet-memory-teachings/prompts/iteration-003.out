types: list[str] = []\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/entity.py:\n  Line 53: class MemoryEntityLink(Base):\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/memory.py:\n  Line 13: class Memory(Base):\n\n  Line 62:     visibility: Mapped[str] = mapped_column(\n\n  Line 64:         server_default=text(\"'scope_team'\"),\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/constants.py:\n  Line 15: class MemoryType(str, Enum):\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/service.py:\n  Line 167:     raw[\"contains_pii\"] = bool(raw.get(\"contains_pii\", False))\n\n  Line 168:     raw[\"pii_types\"] = raw.get(\"pii_types\") or []\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/enrichment/_prompts.py:\n  Line 100: 9. \"contains_pii\": boolean (default false)\n\n  Line 105: 10. \"pii_types\": array of strings (optional, empty if no PII)\n\n  Line 148: {{\"memory_type\": \"...\", \"weight\": 0.0, \"title\": \"...\", \"summary\": \"...\", \"tags\": [\"...\"], \"status\": \"active\", \"ts_valid_start\": null, \"ts_valid_end\": null, \"contains_pii\": false, \"pii_types\": [], \"retrieval_hint\": \"\", \"atomic_facts\": null}}\n","metadata":{"matches":17,"truncated":false},"title":"class Memory|visibility|scope_agent|scope_team|scope_org|importance_score|pii","time":{"start":1780727706338,"end":1780727706365}},"metadata"