p_server/handlers/session-health.ts:\n  Line 56:   trustedAt: string;\n\n  Line 107:   trustedAt: string | null | undefined,\n\n  Line 112:     trustedAt: trustedAt ?? observedAt,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/session-bootstrap.ts:\n  Line 250:     message: 'Advisory only: when the next question is about callers, imports, dependencies, or outline, prefer `code_graph_query` before Grep or Glob.',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts:\n  Line 770:   // Validate the caller-supplied sessionId before using it for feedback\n\n  Line 774:   const trustedValidation = sessionManager.resolveTrustedSession(sessionId ?? null);\n\n  Line 775:   const trustedSessionId = trustedValidation.trusted ? trustedValidation.effectiveSessionId : undefined;\n\n  Line 783:       actor: trustedSessionId ?? 'memory_validate',\n\n  Line 836:       sessionId: trustedSessionId,\n","metadata":{"matches":84,"truncated":false},"title":"trusted|caller|callerContext|MCPCallerContext|requireTrusted|trusted","time":{"start":1781761523958,"end":1781761523971}},"metadata":{"openai":{"itemId":"fc_069440cacd32e8f5016a3385f3d678819185842067006a0b5d"}},"id":"prt_ed94340ec001N34tPTCo7FX3La","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed9431f98001CfEsGbs6IvZNvn"}}
