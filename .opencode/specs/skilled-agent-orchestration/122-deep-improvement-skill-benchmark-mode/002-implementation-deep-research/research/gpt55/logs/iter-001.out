   228	const WRITE_VERBS = /\b(add|build|change|configure|create|edit|fix|generate|implement|modify|patch|refactor|rename|replace|run|update|write)\b/;
   229	const MEMORY_PRESERVATION_SESSION_INTENT = /\b(preserve|remember|capture|keep|store)\b.*\b(next|future|later)\s+session\b|\b(next|future|later)\s+session\b.*\b(lose|lost|preserve|remember|capture|keep|store)\b/;
   230	
   231	function push(scores: Map<string, { score: number; evidence: string[] }>, skillId: string, amount: number, evidence: string): void {
   232	  const current = scores.get(skillId) ?? { score: 0, evidence: [] };
   233	  current.score += amount;
   234	  current.evidence.push(evidence);
   235	  scores.set(skillId, current);
   236	}
   237	
   238	export function scoreExplicitLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {
   239	  const lower = prompt.toLowerCase();
   240	  const tokens = tokenize(prompt, true);
   241	  const scores = new Map<string, { score: number; evidence: string[] }>();
   242	
   243	  for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {
   244	    if (!lower.includes(phrase)) continue;
   245	    for (const [skillId, amount] of boosts) {
   246	      push(scores, skillId, amount, `phrase:${phrase}`);
   247	    }
   248	  }
   249	
   250	  for (const token of tokens) {
   251	    for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {
   252	      push(scores, skillId, amount, `token:${token}`);
   253	    }
   254	  }
   255	
   256	  if (WRITE_VERBS.test(lower) && /\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\b/.test(lower)) {
   257	    push(scores, 'sk-doc', 0.7, 'write-doc-surface');
   258	  }
   259	  if (WRITE_VERBS.test(lower) && /\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\.py|mcp\.json|commonjs)\b/.test(lower)) {
   260	    push(scores, 'sk-code', 0.7, 'write-system-code-surface');
--- advisor regression harness snippets ---
     1	#!/usr/bin/env python3
     2	# ───────────────────────────────────────────────────────────────
     3	# COMPONENT: SKILL ADVISOR REGRESSION HARNESS
     4	# ───────────────────────────────────────────────────────────────
     5	
     6	"""Regression harness for skill_advisor routing quality.
     7	
     8	Usage: python3 skill_advisor_regression.py --dataset <jsonl-path> [--out report.json]
     9	Output: JSON report with routing metrics, gate checks, and pass/fail status.
    10	"""
    11	
    12	from __future__ import annotations
    13	
    14	# ───────────────────────────────────────────────────────────────
    15	# 1. IMPORTS
    16	# ───────────────────────────────────────────────────────────────
    17	
    18	import argparse
    19	import importlib.util
    20	import json
    21	import os
    22	import subprocess
    23	import sys
    24	from typing import Any, Dict, List
    25	
    26	
    27	# ───────────────────────────────────────────────────────────────
    28	# 2. CONFIGURATION
    29	# ───────────────────────────────────────────────────────────────
    30	
    31	SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
    32	ADVISOR_PATH = os.path.join(SCRIPT_DIR, "skill_advisor.py")
    33	
    34	
    35	# ───────────────────────────────────────────────────────────────
    36	# 3. DATA LOADING
    37	# ───────────────────────────────────────────────────────────────
    38	
    39	def load_advisor_module() -> Any:
    40	    """Load the advisor module from disk for regression checks.
    41	
    42	    Delegates to the canonical implementation in skill_advisor_bench to
    43	    avoid duplicating the same importlib loading logic in two harnesses.
    44	    """
    45	    if SCRIPT_DIR not in sys.path:
    46	        sys.path.insert(0, SCRIPT_DIR)
    47	    from skill_advisor_bench import load_advisor_module as _load
    48	    return _load()
    49	
    50	
    51	def load_jsonl(path: str) -> List[Dict[str, Any]]:
    52	    """Load a JSONL dataset and surface line-numbered parse failures.
    53	
    54	    Validates that each row is an object with a non-empty ``prompt``
    55	    field, matching the same contract enforced by the bench harness.
    56	    """
    57	    rows: List[Dict[str, Any]] = []
    58	    with open(path, "r", encoding="utf-8") as handle:
    59	        for line_number, raw in enumerate(handle, start=1):
    60	            stripped = raw.strip()
    61	            if not stripped:
    62	                continue
    63	            try:
    64	                row = json.loads(stripped)
    65	            except json.JSONDecodeError as exc:
    66	                raise ValueError(f"Invalid JSONL at line {line_number}: {exc}") from exc
    67	            if not isinstance(row, dict):
    68	                raise ValueError(f"JSONL line {line_number}: expected object, got {type(row).__name__}")
    69	            prompt = row.get("prompt", "").strip() if isinstance(row.get("prompt"), str) else ""
    70	            if not prompt:
    71	                raise ValueError(f"JSONL line {line_number}: missing or empty 'prompt' field")
    72	            rows.append(row)
    73	    return rows
    74	
    75	
    76	# ───────────────────────────────────────────────────────────────
    77	# 4. EVALUATION LOGIC
    78	# ───────────────────────────────────────────────────────────────
    79	
    80	def run_case_inprocess(advisor: Any, case: Dict[str, Any], threshold: float, uncertainty: float) -> List[Dict[str, Any]]:
    81	    """Evaluate a case through the imported Python module."""
    82	    confidence_only = bool(case.get("confidence_only", False))
    83	    return advisor.analyze_prompt(
    84	        prompt=case["prompt"],
    85	        confidence_threshold=threshold,
    86	        uncertainty_threshold=uncertainty,
    87	        confidence_only=confidence_only,
    88	        show_rejections=False,
    89	    )
    90	
    91	
    92	def run_case_subprocess(case: Dict[str, Any], threshold: float, uncertainty: float) -> List[Dict[str, Any]]:
    93	    """Evaluate a case through the CLI subprocess bridge."""
    94	    confidence_only = bool(case.get("confidence_only", False))
    95	    command = [
    96	        "python3",
    97	        ADVISOR_PATH,
    98	        "--force-local",
    99	        "--threshold",
   100	        str(threshold),
   101	        "--uncertainty",
   102	        str(uncertainty),
   103	    ]
   104	    if confidence_only:
   105	        command.append("--confidence-only")
   106	    command.extend(["--", case["prompt"]])
   107	    env = os.environ.copy()
   108	    env["SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC"] = "1"
   109	    completed = subprocess.run(
   110	        command,
   111	        check=True,
   112	        stdout=subprocess.PIPE,
   113	        stderr=subprocess.PIPE,
   114	        encoding="utf-8",
   115	        env=env,
   116	    )
   117	    parsed = json.loads(completed.stdout or "[]")
   118	    if not isinstance(parsed, list):
   119	        raise ValueError(f"subprocess advisor returned {type(parsed).__name__}, expected list")
   120	    return parsed
   121	
   122	
   123	def evaluate_case(
   124	    advisor: Any,
   125	    case: Dict[str, Any],
   126	    threshold: float,
   127	    uncertainty: float,
   128	    runner: str = "inprocess",
   129	) -> Dict[str, Any]:
   130	    """Run a single regression case and record its expectation checks."""
   131	    prompt = case["prompt"]
   132	    confidence_only = bool(case.get("confidence_only", False))
   133	    recommendations = (
   134	        run_case_subprocess(case, threshold, uncertainty)
   135	        if runner == "subprocess"
   136	        else run_case_inprocess(advisor, case, threshold, uncertainty)
   137	    )
   138	
   139	    top = recommendations[0] if recommendations else None
   140	    expected_top = case.get("expected_top_any", [])
   141	    expect_result = bool(case.get("expect_result", True))
   142	    expect_kind = case.get("expect_kind")
   143	
   144	    result_ok = bool(top) == expect_result
   145	    top_ok = True
   146	    kind_ok = True
   147	
   148	    if expect_result and top is not None and expected_top:
   149	        # Gold labels may use a renamed alias (e.g. sk-deep-research) of the
   150	        # live skill id (deep-research). Match alias-aware so the harness does
   151	        # not flag legitimate renames as failures.
   152	        actual_skill = top["skill"]
   153	        top_ok = any(advisor.skill_matches_alias(actual_skill, candidate) for candidate in expected_top)
   154	
   155	    if expect_result and top is not None and expect_kind:
   156	        kind_ok = top.get("kind") == expect_kind
   157	
   158	    passed = result_ok and top_ok and kind_ok
   159	
   160	    return {
   161	        "id": case.get("id", "unknown"),
   162	        "priority": case.get("priority", "P1"),
   163	        "prompt": prompt,
   164	        "runner": runner,
   165	        "confidence_only": confidence_only,
   166	        "expect_result": expect_result,
   167	        "expected_top_any": expected_top,
   168	        "expected_kind": expect_kind,
   169	        "top": top,
   170	        "passed": passed,
   171	        "checks": {
   172	            "result_ok": result_ok,
   173	            "top_ok": top_ok,
   174	            "kind_ok": kind_ok,
   175	        },
   176	        "allow_command_bridge": bool(case.get("allow_command_bridge", False)),
   177	        "non_slash": bool(case.get("non_slash", "/" not in prompt)),
   178	    }
   179	
   180	
   240	# 6. CLI ENTRY POINT
   241	# ───────────────────────────────────────────────────────────────
   242	
   243	def main() -> int:
   244	    """Execute the regression suite and emit a JSON report."""
   245	    parser = argparse.ArgumentParser(description="Run skill advisor regression suite.")
   246	    parser.add_argument("--dataset", required=True, help="Path to JSONL regression dataset.")
   247	    parser.add_argument("--out", default="", help="Optional path to write JSON report.")
   248	    parser.add_argument("--threshold", type=float, default=0.8, help="Confidence threshold for evaluations.")
   249	    parser.add_argument("--uncertainty", type=float, default=0.35, help="Uncertainty threshold for dual-threshold evaluations.")
   250	    parser.add_argument("--min-top1-accuracy", type=float, default=0.92, help="Minimum acceptable top-1 accuracy.")
   251	    parser.add_argument("--max-command-bridge-fp-rate", type=float, default=0.05, help="Maximum command bridge FP rate on non-slash prompts.")
   252	    parser.add_argument("--min-p0-pass-rate", type=float, default=1.0, help="Minimum P0 pass rate.")
   253	    parser.add_argument("--mode", choices=["both", "default", "confidence-only"], default="both", help="Which dataset cases to execute by mode.")
   254	    parser.add_argument("--runner", choices=["both", "inprocess", "subprocess"], default="both", help="Advisor execution path to exercise.")
   255	    args = parser.parse_args()
   256	
   257	    advisor = load_advisor_module()
   258	    dataset = load_jsonl(args.dataset)
   259	
   260	    filtered_dataset: List[Dict[str, Any]] = []
   261	    for case in dataset:
   262	        confidence_only = bool(case.get("confidence_only", False))
   263	        if args.mode == "default" and confidence_only:
   264	            continue
   265	        if args.mode == "confidence-only" and not confidence_only:
   266	            continue
   267	        filtered_dataset.append(case)
   268	
   269	    runners = ["inprocess", "subprocess"] if args.runner == "both" else [args.runner]
   270	    results: List[Dict[str, Any]] = []
   271	    for runner in runners:
   272	        results.extend(
   273	            evaluate_case(
   274	                advisor=advisor,
   275	                case=case,
   276	                threshold=args.threshold,
   277	                uncertainty=args.uncertainty,
   278	                runner=runner,
   279	            )
   280	            for case in filtered_dataset
   281	        )
   282	
   283	    metrics = compute_metrics(results)
   284	    gates = {
   285	        "top1_accuracy": metrics["top1_accuracy"] >= args.min_top1_accuracy,
   286	        "command_bridge_fp_rate": metrics["command_bridge_fp_rate"] <= args.max_command_bridge_fp_rate,
   287	        "p0_pass_rate": metrics["p0_pass_rate"] >= args.min_p0_pass_rate,
   288	        "all_cases_passed": metrics["failed_cases"] == 0,
   289	    }
   290	    overall_pass = all(gates.values())
   291	
   292	    report = {
   293	        "dataset": args.dataset,
   294	        "mode": args.mode,
   295	        "runner": args.runner,
   296	        "runners_exercised": runners,
   297	        "thresholds": {
   298	            "confidence": args.threshold,
   299	            "uncertainty": args.uncertainty,
   300	            "min_top1_accuracy": args.min_top1_accuracy,
   301	            "max_command_bridge_fp_rate": args.max_command_bridge_fp_rate,
   302	            "min_p0_pass_rate": args.min_p0_pass_rate,
   303	        },
   304	        "metrics": metrics,
   305	        "gates": gates,
   306	        "overall_pass": overall_pass,
   307	        "failures": [item for item in results if not item["passed"]],
   308	    }
   309	
   310	    if args.out:

