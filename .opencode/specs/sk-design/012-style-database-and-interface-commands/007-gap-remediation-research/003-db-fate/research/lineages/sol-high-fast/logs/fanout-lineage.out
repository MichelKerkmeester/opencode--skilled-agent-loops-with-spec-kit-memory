rd) ?? [];\n\n  Line 128:   const eligibilityMatches = JSON.stringify(legacy.eligibility) === JSON.stringify(\n\n  Line 129:     persistent.eligibility,\n\n  Line 131:   const cardsMatch = JSON.stringify(legacyCards) === JSON.stringify(persistentCards);\n\n  Line 133:     ok: legacy.ok === persistent.ok && eligibilityMatches && cardsMatch,\n\n  Line 136:     legacyCards,\n\n  Line 137:     persistentCards,\n\n  Line 138:     persistentGenerationHash: persistent.generationHash,\n\n  Line 139:     persistentRankingMode: persistent.rankingMode,\n\n  Line 145:  * Route query traffic without allowing normal persistent reads to walk the corpus.\n\n  Line 150:  * @returns {Promise<Object>} Existing response shape with optional shadow evidence.\n\n  Line 154:   if (mode === 'legacy') return runLegacy(request, options);\n\n  Line 155:   if (mode === 'persistent') return queryPersistentStyles(request, persistentOptions(options));\n\n  Line 156:   const legacy = await runLegacy(request, options);\n\n  Line 158:     const persistent = queryPersistentStyles(request, persistentOptions(options));\n\n  Line 159:     return { ...legacy, shadow: compareQueryResults(legacy, persistent) };\n\n  Line 162:       ...legacy,\n\n  Line 163:       shadow: { ok: false, error: error.code ?? 'internal-error', message: error.message },\n\n  Line 169:  * Hydrate DB-selected artifacts from authoritative flat files under all legacy guards.\n\n  Line 294: function compareHydrationResults(legacy, persistent) {\n\n  Line 295:   if (!legacy.ok || !persistent.ok) {\n\n  Line 297:       ok: legacy.ok === persistent.ok && legacy.error === persistent.error,\n\n  Line 298:       legacyError: legacy.error ?? null,\n\n  Line 299:       persistentError: persistent.error ?? null,\n\n  Line 302:   const legacyProjection = {\n\n  Line 303:     id: legacy.id,\n\n  Line 304:     mode: legacy.mode,\n\n  Line 305:     totalBytes: legacy.totalBytes,\n\n  Line 306:     artifacts: legacy.artifacts,\n\n  Line 308:   cons