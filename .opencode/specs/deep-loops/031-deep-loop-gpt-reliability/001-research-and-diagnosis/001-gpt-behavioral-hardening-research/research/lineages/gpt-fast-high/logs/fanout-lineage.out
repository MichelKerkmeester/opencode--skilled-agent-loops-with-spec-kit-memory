event.properties.part.sessionID === 'object') {\n\n  Line 364:       return normalizeSessionID(event.properties.part.sessionID);\n\n  Line 371: function shouldInvalidateEvent(eventType) {\n\n  Line 372:   return typeof eventType === 'string'\n\n  Line 373:     && (eventType.startsWith('session.') || eventType.startsWith('message.'));\n\n  Line 376: function invalidateTransportCache(sessionID, specFolder) {\n\n  Line 377:   if (sessionID) {\n\n  Line 378:     transportCache.delete(cacheKeyForSession(sessionID, specFolder));\n\n  Line 394:  * Create the Spec Kit OpenCode plugin and its transport-backed hook handlers.\n\n  Line 400: export default async function mkCodeGraphPlugin(ctx, rawOptions) {\n\n  Line 407:     event: async ({ event }) => {\n\n  Line 408:       if (!shouldInvalidateEvent(event?.type)) {\n\n  Line 411:       invalidateTransportCache(extractEventSessionID(event), options.specFolder);\n\n  Line 415:       mk_code_graph_status: tool({\n\n  Line 428:             `messages_transform_enabled=${MESSAGES_TRANSFORM_ENABLED}`,\n\n  Line 429:             `messages_transform_mode=${MESSAGES_TRANSFORM_MODE}`,\n\n  Line 442:     'experimental.chat.system.transform': async (input, output = { system: [] }) => {\n\n  Line 450:         sessionID: input.sessionID,\n\n  Line 470:     'experimental.chat.messages.transform': async (_input, output) => {\n\n  Line 475:       const anchor = output.messages.at(-1);\n\n  Line 486:         sessionID: anchor.info.sessionID,\n\n  Line 493:       if (!plan || plan.messagesTransform.length === 0) {\n\n  Line 497:       for (const block of plan.messagesTransform) {\n\n  Line 504:           sessionID: anchor.info.sessionID,\n\n  Line 505:           messageID: anchor.info.id,\n\n  Line 520:     'experimental.session.compacting': async (input, output = { context: [] }) => {\n\n  Line 528:         sessionID: input.sessionID,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/session-cleanup.js:\n