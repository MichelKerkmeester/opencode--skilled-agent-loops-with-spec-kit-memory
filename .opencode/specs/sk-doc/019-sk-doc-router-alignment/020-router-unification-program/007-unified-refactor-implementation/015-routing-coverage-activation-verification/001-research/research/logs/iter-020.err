   239	function bridgeStdioThroughSessionProxy(socketPath, options = {}) {
   240	  const proxyModule = loadSessionProxyModule();
   241	  if (!proxyModule || typeof proxyModule.createSessionProxy !== 'function') {
   242	    throw new Error('launcher-session-proxy.cjs is unavailable');
   243	  }
   244	  const createProxy = options.createProxy ?? proxyModule.createSessionProxy;
   245	  const sessionProxy = createProxy({
   246	    socketPath,
   247	    stdin: options.stdin ?? process.stdin,
   248	    stdout: options.stdout ?? process.stdout,
   249	    log,
   250	    classify: classifySkillAdvisorFrame,
   251	  });
   252	  return sessionProxy.start();
