 1 michelkerkmeester  staff   3605 May 30 20:29 score-candidate-cache.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   7279 May 30 20:29 score-candidate-security.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   5945 May 30 20:29 scorer.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   9994 May 30 23:31 skill-benchmark.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff  10729 May 30 20:29 trade-off-detector.vitest.ts\n","metadata":{"output":"total 376\ndrwxr-xr-x  24 michelkerkmeester  staff    768 May 30 23:31 .\ndrwxr-xr-x  11 michelkerkmeester  staff    352 May 30 22:45 ..\n-rw-r--r--@  1 michelkerkmeester  staff   3898 May 30 20:29 README.md\n-rw-r--r--@  1 michelkerkmeester  staff  12069 May 30 20:29 benchmark-stability.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   5203 May 30 20:29 bundle-gate-exec-gate.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   8475 May 30 20:29 candidate-lineage.vitest.ts\ndrwxr-xr-x   4 michelkerkmeester  staff    128 May 30 20:29 fixtures\n-rw-r--r--@  1 michelkerkmeester  staff   6956 May 30 20:29 grader-harness-hardening.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff  10381 May 30 20:29 improvement-journal.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff  10385 May 30 20:29 loop-host.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   5814 May 30 20:29 materialize-fixture-id.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   3509 May 30 20:29 mirror-sync-verify.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   9038 May 30 20:29 mutation-coverage.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   3105 May 30 20:29 optin-scorer.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   5805 May 30 20:29 promote-candidate-benchmark.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   1806 May 30 20:29 reduce-state-dashboard.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   5620 May 30 20:29 reduce-state-mode-mix.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff  14734 May 30 20:29 remediation.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   9555 May 30 20:29 run-benchmark-hardening.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   3605 May 30 20:29 score-candidate-cache.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   7279 May 30 20:29 score-candidate-security.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   5945 May 30 20:29 scorer.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff   9994 May 30 23:31 skill-benchmark.vitest.ts\n-rw-r--r--@  1 michelkerkmeester  staff  10729 May 30 20:29 trade-off-detector.vitest.ts\n","exit":0,"description":"Check Lane C test files","truncated":false},"title":"Check Lane C test files","time":{"start":1780205051645,"end":1780205051649}},"id":"prt_e7c7d5b3b001q2LMg6dXeQHrmu","sessionID":"ses_183832656ffeoAakJrM2UesW0p","messageID":"msg_e7c7d4a6e001IVYtFtrbmVeJkn"}}
