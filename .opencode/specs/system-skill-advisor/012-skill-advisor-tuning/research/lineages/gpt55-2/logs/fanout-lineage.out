       \"correct\": 25,\n44:         \"total\": 32,\n45:         \"accuracy\": 0.7813\n46:       },\n47:       \"delegation\": {\n48:         \"correct\": 11,\n49:         \"total\": 11,\n50:         \"accuracy\": 1\n51:       }\n52:     }\n53:   }\n54: }\n\n(End of file - total 54 lines)\n</content>","metadata":{"preview":"{\n  \"schemaVersion\": 1,\n  \"capturedAt\": \"2026-07-07\",\n  \"capturedAtSha\": \"e95946b7a3\",\n  \"corpusSha256\": \"sha256:922caffda4ff97dcbd66945441079d724779133d1ffd05ab3e3103a1d921a8e8\",\n  \"holdoutSha256\": \"sha256:90dbee17115f58a6115224d08ece49fd9795781c5fe3ac68b9d7c1060d3c8ecb\",\n  \"ambiguitySha256\": \"sha256:328715d69b7e778840878d3be02b18647a5a039684969cd122d963f380785fa5\",\n  \"env\": {\n    \"SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC\": \"1\",\n    \"MK_SKILL_ADVISOR_DB_DIR\": \"<empty-dir>\",\n    \"projectionSource\": \"filesystem\"\n  },\n  \"metrics\": {\n    \"full_corpus_top1\": {\n      \"correct\": 147,\n      \"total\": 193,\n      \"accuracy\": 0.7617\n    },\n    \"unknown_count\": {\n      \"value\": 10","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/scripts/routing-accuracy/scorer-eval-baseline.json","text":"{\n  \"schemaVersion\": 1,\n  \"capturedAt\": \"2026-07-07\",\n  \"capturedAtSha\": \"e95946b7a3\",\n  \"corpusSha256\": \"sha256:922caffda4ff97dcbd66945441079d724779133d1ffd05ab3e3103a1d921a8e8\",\n  \"holdoutSha256\": \"sha256:90dbee17115f58a6115224d08ece49fd9795781c5fe3ac68b9d7c1060d3c8ecb\",\n  \"ambiguitySha256\": \"sha256:328715d69b7e778840878d3be02b18647a5a039684969cd122d963f380785fa5\",\n  \"env\": {\n    \"SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC\": \"1\",\n    \"MK_SKILL_ADVISOR_DB_DIR\": \"<empty-dir>\",\n    \"projectionSource\": \"filesystem\"\n  },\n  \"metrics\": {\n    \"full_corpus_top1\": {\n      \"correct\": 147,\n      \"total\": 193,\n      \"accuracy\": 0.7617\