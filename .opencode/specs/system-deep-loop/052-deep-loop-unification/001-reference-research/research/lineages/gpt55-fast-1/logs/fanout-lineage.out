{"type":"tool_use","timestamp":1783487883754,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_38T86owEvoEeKYMqOAm6tbFA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","offset":221,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts</path>\n<type>file</type>\n<content>\n221:   cli?: Partial<ExecutorConfig>;\n222:   file?: Partial<ExecutorConfig>;\n223: }): ExecutorConfig {\n224:   const merged = {\n225:     ...(sources.file ?? {}),\n226:     ...(sources.cli ?? {}),\n227:   };\n228:   return parseExecutorConfig(merged);\n229: }\n230: \n231: // ───────────────────────────────────────────────────────────────────\n232: // 6. FAN-OUT CONFIG\n233: // ───────────────────────────────────────────────────────────────────\n234: //\n235: // Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n236: // the loop runs N executor \"lineages\" concurrently (capped), each running the\n237: // existing sequential loop in its own isolated sub-packet. The single-executor\n238: // path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n239: // default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n240: \n241: const LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n242: \n243: /**\n244:  * One fan-out lineage: a single executor config plus fan-out metadata.\n245:  *\n246:  * - `label`: directory-safe id for the lineage's isolated sub-packet.\n247:  * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n248:  * - `iterations`: per-lineage max-iterations override; null = packet default.\n249:  * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n250:  *   \"tidd-ec\") resolved against sk-prompt-models when a consumer renders the\n251:  *   lineage prompt. null = consumer default. Loop-type-agnostic and optional, so\n252:  *   research/review lineages that omit it are unaffected.\n253:  * - `assignment_model`: defaults to the existing flat pool; `wave` is accepted\n254:  *   only so the runtime guard can reject activation attempts explicitly.\n255:  * - `depends_on` / `touches`: reserved dependency and path-domain metadata for\n256:  *   a future guarded planner; flat-pool execution ignores them after logging.\n257:  */\n258: export const lineageExecutorSchema = executorConfigSchema.extend({\n259:   label: z.string().min(1).regex(LINEAGE_LABEL_PATTERN, {\n260:     message: \"label must match /^[a-z0-9][a-z0-9-]*$/ (lowercase, digits, hyphens; dir-safe)\",\n261:   }),\n262:   count: z.number().int().positive().default(1),\n263:   iterations: z.number().int().positive().nullable().default(null),\n264:   promptFramework: z.string().min(1).nullable().default(null),\n265:   assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n266:   depends_on: z.array(z.string().trim().min(1)).default([]),\n267:   touches: z.array(z.string().trim().min(1)).default([]),\n268: });\n269: \n270: export type LineageExecutor = z.infer<typeof lineageExecutorSchema>;\n271: \n272: export const fanoutConfigSchema = z.object({\n273:   executors: z.array(lineageExecutorSchema).min(1),\n274:   assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n275:   concurrency: z.number().int().positive().default(2),\n276:   maxRetries: z.number().int().nonnegative().default(5),\n277:   // Stall detection defaults ON: a lineage that stops emitting progress is aborted and\n278:   // requeued within the ceiling and fails loud, instead of hanging silently at 0% CPU\n279:   // until the hours-scale subprocess timeout. Set 0 to opt out.\n280:   lagCeilingMs: z.number().int().nonnegative().default(300000),\n281:   progressHeartbeatSeconds: z.number().nonnegative().default(60),\n282: });\n283: \n284: export type FanoutConfig = z.infer<typeof fanoutConfigSchema>;\n285: \n286: /**\n287:  * Parse and validate a raw fan-out configuration.\n288:  *\n289:  * Each entry's executor subset is routed through {@link parseExecutorConfig} so\n290:  * ALL existing kind/model/flag rules apply per lineage with zero duplication.\n291:  * Labels must be unique and base-label (count>1) expansion must not collide.\n292:  *\n293:  * @param raw - Raw input to parse (JSON-parsed object).\n294:  * @returns Validated FanoutConfig.\n295:  * @throws {@link ExecutorConfigError} If validation fails.\n296:  */\n297: export function parseFanoutConfig(raw: unknown): FanoutConfig {\n298:   const parsed = fanoutConfigSchema.safeParse(raw);\n299:   if (!parsed.success) {\n300:     throw new ExecutorConfigError({ issues: parsed.error.issues.map((issue) => ({ path: issue.path, message: issue.message })) });\n301:   }\n302: \n303:   const config = parsed.data;\n304: \n305:   // Reuse the canonical single-executor validator per entry (kind/model/flags).\n306:   config.executors.forEach((entry, index) => {\n307:     const {\n308:       label: _label,\n309:       count: _count,\n310:       iterations: _iterations,\n311:       promptFramework: _promptFramework,\n312:       assignment_model: _assignmentModel,\n313:       depends_on: _dependsOn,\n314:       touches: _touches,\n315:       ...executorSubset\n316:     } = entry;\n317:     try {\n318:       parseExecutorConfig(executorSubset);\n319:     } catch (err: unknown) {\n320:       if (err instanceof ExecutorConfigError) {\n321:         throw new ExecutorConfigError({\n322:           issues: err.issues.map((issue) => ({ path: ['executors', index, ...issue.path], message: issue.message })),\n323:         });\n324:       }\n325:       throw err;\n326:     }\n327:   });\n328: \n329:   // Labels must be unique among the declared lineages.\n330:   const seenLabels = new Set<string>();\n331:   config.executors.forEach((entry, index) => {\n332:     if (seenLabels.has(entry.label)) {\n333:       throw new ExecutorConfigError({\n334:         issues: [{ path: ['executors', index, 'label'], message: `duplicate lineage label '${entry.label}'` }],\n335:       });\n336:     }\n337:     seenLabels.add(entry.label);\n338:   });\n339: \n340:   // Expanded labels (count>1 → label-1, label-2, …) must not collide either.\n341:   const expandedLabels = new Set<string>();\n342:   for (const lineage of expandLineages(config)) {\n343:     if (expandedLabels.has(lineage.label)) {\n344:       throw new ExecutorConfigError({\n345:         issues: [{ path: ['executors'], message: `expanded lineage label '${lineage.label}' collides; rename base labels` }],\n346:       });\n347:     }\n348:     expandedLabels.add(lineage.label);\n349:   }\n350: \n351:   return config;\n352: }\n353: \n354: /**\n355:  * Expand a fan-out config into concrete per-replica lineages.\n356:  *\n357:  * A `count` of 1 keeps the base label; `count > 1` yields `${label}-1` …\n358:  * `${label}-N`. Each expanded lineage carries `count: 1` so downstream\n359:  * consumers see one runnable unit per element.\n360:  *\n361:  * @param config - Validated FanoutConfig.\n362:  * @returns Flat list of single-replica lineages (one runnable unit each).\n363:  */\n364: export function expandLineages(config: FanoutConfig): LineageExecutor[] {\n365:   const lineages: LineageExecutor[] = [];\n366:   for (const entry of config.executors) {\n367:     if (entry.count === 1) {\n368:       lineages.push({ ...entry, count: 1 });\n369:       continue;\n370:     }\n371:     for (let replica = 1; replica <= entry.count; replica += 1) {\n372:       lineages.push({ ...entry, label: `${entry.label}-${replica}`, count: 1 });\n373:     }\n374:   }\n375:   return lineages;\n376: }\n\n(End of file - total 376 lines)\n</content>","metadata":{"preview":"  cli?: Partial<ExecutorConfig>;\n  file?: Partial<ExecutorConfig>;\n}): ExecutorConfig {\n  const merged = {\n    ...(sources.file ?? {}),\n    ...(sources.cli ?? {}),\n  };\n  return parseExecutorConfig(merged);\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 6. FAN-OUT CONFIG\n// ───────────────────────────────────────────────────────────────────\n//\n// Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n// the loop runs N executor \"lineages\" concurrently (capped), each running the\n// existing sequential loop in its own isolated sub-packet. The single-executor\n// path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n// default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","text":"  cli?: Partial<ExecutorConfig>;\n  file?: Partial<ExecutorConfig>;\n}): ExecutorConfig {\n  const merged = {\n    ...(sources.file ?? {}),\n    ...(sources.cli ?? {}),\n  };\n  return parseExecutorConfig(merged);\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 6. FAN-OUT CONFIG\n// ───────────────────────────────────────────────────────────────────\n//\n// Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n// the loop runs N executor \"lineages\" concurrently (capped), each running the\n// existing sequential loop in its own isolated sub-packet. The single-executor\n// path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n// default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n\nconst LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n\n/**\n * One fan-out lineage: a single executor config plus fan-out metadata.\n *\n * - `label`: directory-safe id for the lineage's isolated sub-packet.\n * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n * - `iterations`: per-lineage max-iterations override; null = packet default.\n * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n *   \"tidd-ec\") resolved against sk-prompt-models when a consumer renders the\n *   lineage prompt. null = consumer default. Loop-type-agnostic and optional, so\n *   research/review lineages that omit it are unaffected.\n * - `assignment_model`: defaults to the existing flat pool; `wave` is accepted\n *   only so the runtime guard can reject activation attempts explicitly.\n * - `depends_on` / `touches`: reserved dependency and path-domain metadata for\n *   a future guarded planner; flat-pool execution ignores them after logging.\n */\nexport const lineageExecutorSchema = executorConfigSchema.extend({\n  label: z.string().min(1).regex(LINEAGE_LABEL_PATTERN, {\n    message: \"label must match /^[a-z0-9][a-z0-9-]*$/ (lowercase, digits, hyphens; dir-safe)\",\n  }),\n  count: z.number().int().positive().default(1),\n  iterations: z.number().int().positive().nullable().default(null),\n  promptFramework: z.string().min(1).nullable().default(null),\n  assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n  depends_on: z.array(z.string().trim().min(1)).default([]),\n  touches: z.array(z.string().trim().min(1)).default([]),\n});\n\nexport type LineageExecutor = z.infer<typeof lineageExecutorSchema>;\n\nexport const fanoutConfigSchema = z.object({\n  executors: z.array(lineageExecutorSchema).min(1),\n  assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n  concurrency: z.number().int().positive().default(2),\n  maxRetries: z.number().int().nonnegative().default(5),\n  // Stall detection defaults ON: a lineage that stops emitting progress is aborted and\n  // requeued within the ceiling and fails loud, instead of hanging silently at 0% CPU\n  // until the hours-scale subprocess timeout. Set 0 to opt out.\n  lagCeilingMs: z.number().int().nonnegative().default(300000),\n  progressHeartbeatSeconds: z.number().nonnegative().default(60),\n});\n\nexport type FanoutConfig = z.infer<typeof fanoutConfigSchema>;\n\n/**\n * Parse and validate a raw fan-out configuration.\n *\n * Each entry's executor subset is routed through {@link parseExecutorConfig} so\n * ALL existing kind/model/flag rules apply per lineage with zero duplication.\n * Labels must be unique and base-label (count>1) expansion must not collide.\n *\n * @param raw - Raw input to parse (JSON-parsed object).\n * @returns Validated FanoutConfig.\n * @throws {@link ExecutorConfigError} If validation fails.\n */\nexport function parseFanoutConfig(raw: unknown): FanoutConfig {\n  const parsed = fanoutConfigSchema.safeParse(raw);\n  if (!parsed.success) {\n    throw new ExecutorConfigError({ issues: parsed.error.issues.map((issue) => ({ path: issue.path, message: issue.message })) });\n  }\n\n  const config = parsed.data;\n\n  // Reuse the canonical single-executor validator per entry (kind/model/flags).\n  config.executors.forEach((entry, index) => {\n    const {\n      label: _label,\n      count: _count,\n      iterations: _iterations,\n      promptFramework: _promptFramework,\n      assignment_model: _assignmentModel,\n      depends_on: _dependsOn,\n      touches: _touches,\n      ...executorSubset\n    } = entry;\n    try {\n      parseExecutorConfig(executorSubset);\n    } catch (err: unknown) {\n      if (err instanceof ExecutorConfigError) {\n        throw new ExecutorConfigError({\n          issues: err.issues.map((issue) => ({ path: ['executors', index, ...issue.path], message: issue.message })),\n        });\n      }\n      throw err;\n    }\n  });\n\n  // Labels must be unique among the declared lineages.\n  const seenLabels = new Set<string>();\n  config.executors.forEach((entry, index) => {\n    if (seenLabels.has(entry.label)) {\n      throw new ExecutorConfigError({\n        issues: [{ path: ['executors', index, 'label'], message: `duplicate lineage label '${entry.label}'` }],\n      });\n    }\n    seenLabels.add(entry.label);\n  });\n\n  // Expanded labels (count>1 → label-1, label-2, …) must not collide either.\n  const expandedLabels = new Set<string>();\n  for (const lineage of expandLineages(config)) {\n    if (expandedLabels.has(lineage.label)) {\n      throw new ExecutorConfigError({\n        issues: [{ path: ['executors'], message: `expanded lineage label '${lineage.label}' collides; rename base labels` }],\n      });\n    }\n    expandedLabels.add(lineage.label);\n  }\n\n  return config;\n}\n\n/**\n * Expand a fan-out config into concrete per-replica lineages.\n *\n * A `count` of 1 keeps the base label; `count > 1` yields `${label}-1` …\n * `${label}-N`. Each expanded lineage carries `count: 1` so downstream\n * consumers see one runnable unit per element.\n *\n * @param config - Validated FanoutConfig.\n * @returns Flat list of single-replica lineages (one runnable unit each).\n */\nexport function expandLineages(config: FanoutConfig): LineageExecutor[] {\n  const lineages: LineageExecutor[] = [];\n  for (const entry of config.executors) {\n    if (entry.count === 1) {\n      lineages.push({ ...entry, count: 1 });\n      continue;\n    }\n    for (let replica = 1; replica <= entry.count; replica += 1) {\n      lineages.push({ ...entry, label: `${entry.label}-${replica}`, count: 1 });\n    }\n  }\n  return lineages;\n}","lineStart":221,"lineEnd":376,"totalLines":376,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","time":{"start":1783487883749,"end":1783487883753}},"metadata":{"openai":{"itemId":"fc_0710ee419ff88bbf016a4ddd8ba3f48191aee2901b977cfd26"}},"id":"prt_f402969e2001UXIn0fL5ok2BPh","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messageID":"msg_f402949d2001QM2GBozaaPj7Rr"}}
