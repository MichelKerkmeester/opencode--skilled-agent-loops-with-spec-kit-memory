t plus graph insights block.\n680:  * Used by SessionStart hook when graphReasoning is enabled.\n681:  */\n682: export async function getContextMergeWithGraph(project: string): Promise<{ globals: Memory[]; scoped: Memory[]; graphInsights?: string }> {\n683:   const base = getContextMerge(project);\n684: \n685:   const { readConfigSync } = await import(\"./config.js\");\n686:   if (!readConfigSync().ltm?.graphReasoning) return base;\n687: \n688:   const seeds = [...base.globals.slice(0, 2), ...base.scoped.slice(0, 1)].map(m => m.id);\n689:   if (seeds.length === 0) return base;\n690: \n691:   try {\n692:     const { traverseGraph, buildReasoningContext } = await import(\"./graph.js\");\n693:     const results = await Promise.allSettled(seeds.map(id => traverseGraph(id, 2, false)));\n694:     const lines: string[] = [];\n695:     for (const r of results) {\n696:       if (r.status === \"fulfilled\") {\n697:         const block = buildReasoningContext(r.value);\n698:         if (block) lines.push(block);\n699:       }\n700:     }\n701:     const graphInsights = lines.slice(0, 5).join(\"\\n\") || undefined;\n702:     return { ...base, graphInsights };\n703:   } catch (err) {\n704:     process.stderr.write(`[getContextMergeWithGraph] error: ${err}\\n`);\n705:     return base;\n706:   }\n707: }\n708: \n709: /** Write docs/memory-long-term-dump.md — auto-generated snapshot (never overwrites the architecture doc). */\n710: export function exportMarkdown(): void {\n711:   const db = getDb();\n712:   if (!existsSync(DOCS_DIR)) mkdirSync(DOCS_DIR, { recursive: true });\n713: \n714:   const rows = db.query<Memory, []>(\n715:     `SELECT * FROM memories ORDER BY importance DESC, category ASC, created_at DESC LIMIT 500`\n716:   ).all();\n717: \n718:   // Batch-fetch all tags in one query to avoid N+1\n719:   const tagsByMemory = getTagsBatch(db, rows.map(r => r.id));\n720: \n721:   const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n722:   const lines: string[] = [\n723:     `# Long-Term Memory — Generated Dump`,\n724:     ``,\n725:     `> Auto-generated by \\`memory/db.ts\\`. Last updated: ${timestamp}`,\n726:     `> This is a raw data export. For the architecture guide see \\`docs/memory-long-term.md\\`.`,\n727:     `> Edit via \\`/learn\\`, \\`/forget\\`, \\`/relate\\` commands — do not edit directly.`,\n728:     ``,\n729:   ];\n730: \n731:   const byCategory = new Map<string, Memory[]>();\n732:   for (const m of rows) {\n733:     if (!byCategory.has(m.category)) byCategory.set(m.category, []);\n734:     byCategory.get(m.category)!.push(m);\n735:   }\n736: \n737:   for (const [cat, mems] of byCategory) {\n738:     lines.push(`## ${cat.charAt(0).toUpperCase() + cat.slice(1)}`);\n739:     lines.push(\"\");\n740:     for (const m of mems) {\n741:       const tags = tagsByMemory.get(m.id) ?? [];\n742:       const tagStr = tags.length > 0 ? ` \\`[${tags.join(\", \")}]\\`` : \"\";\n743:       const scope = m.project_scope ? ` *(${m.project_scope})*` : \"\";\n744:       const imp = \"★\".repeat(m.importance) + \"☆\".repeat(5 - m.importance);\n\n(Showing lines 650-744 of 780. Use offset=745 to continue.)\n</content>","metadata":{"preview":"  return scored.slice(0, limit).map(s => s.mem);\n}\n\nexport function getContextMerge(project: string): { globals: Memory[]; scoped: Memory[] } {\n  const db = getDb();\n  const sortByDecay = (arr: Memory[]) =>\n    arr.map(m => ({ m, score: computeDecayScore(m) }))\n       .sort((a, b) => b.score - a.score)\n       .map(({ m }) => m);\n\n  const SLIM = `id, content, category, importance, confidence, source, project_scope, dedup_key,\n               created_at, last_confirmed_at, last_used_at, confirm_count, status,\n               first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n               workspace_id, agent_id`;\n  const globals = sortByDecay(db.query<Memory, []>(\n    `SELECT ${SLIM} FROM memories WHERE importance >= 4 AND project_scope IS NULL AND status = 'active'`\n  ).all());\n\n  const scoped = sortByDecay(db.query<Memory, [string]>(\n    `SELECT ${SLIM} FROM memories WHERE project_scope=? AND importance >= 3 AND status = 'active' LIMIT 15`","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","text":"  return scored.slice(0, limit).map(s => s.mem);\n}\n\nexport function getContextMerge(project: string): { globals: Memory[]; scoped: Memory[] } {\n  const db = getDb();\n  const sortByDecay = (arr: Memory[]) =>\n    arr.map(m => ({ m, score: computeDecayScore(m) }))\n       .sort((a, b) => b.score - a.score)\n       .map(({ m }) => m);\n\n  const SLIM = `id, content, category, importance, confidence, source, project_scope, dedup_key,\n               created_at, last_confirmed_at, last_used_at, confirm_count, status,\n               first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n               workspace_id, agent_id`;\n  const globals = sortByDecay(db.query<Memory, []>(\n    `SELECT ${SLIM} FROM memories WHERE importance >= 4 AND project_scope IS NULL AND status = 'active'`\n  ).all());\n\n  const scoped = sortByDecay(db.query<Memory, [string]>(\n    `SELECT ${SLIM} FROM memories WHERE project_scope=? AND importance >= 3 AND status = 'active' LIMIT 15`\n  ).all(project));\n\n  const allIds = [...globals, ...scoped].map(m => m.id);\n  updateLastUsed(allIds);\n\n  return { globals, scoped };\n}\n\n/**\n * Async variant: returns getContextMerge result plus graph insights block.\n * Used by SessionStart hook when graphReasoning is enabled.\n */\nexport async function getContextMergeWithGraph(project: string): Promise<{ globals: Memory[]; scoped: Memory[]; graphInsights?: string }> {\n  const base = getContextMerge(project);\n\n  const { readConfigSync } = await import(\"./config.js\");\n  if (!readConfigSync().ltm?.graphReasoning) return base;\n\n  const seeds = [...base.globals.slice(0, 2), ...base.scoped.slice(0, 1)].map(m => m.id);\n  if (seeds.length === 0) return base;\n\n  try {\n    const { traverseGraph, buildReasoningContext } = await import(\"./graph.js\");\n    const results = await Promise.allSettled(seeds.map(id => traverseGraph(id, 2, false)));\n    const lines: string[] = [];\n    for (const r of results) {\n      if (r.status === \"fulfilled\") {\n        const block = buildReasoningContext(r.value);\n        if (block) lines.push(block);\n      }\n    }\n    const graphInsights = lines.slice(0, 5).join(\"\\n\") || undefined;\n    return { ...base, graphInsights };\n  } catch (err) {\n    process.stderr.write(`[getContextMergeWithGraph] error: ${err}\\n`);\n    return base;\n  }\n}\n\n/** Write docs/memory-long-term-dump.md — auto-generated snapshot (never overwrites the architecture doc). */\nexport function exportMarkdown(): void {\n  const db = getDb();\n  if (!existsSync(DOCS_DIR)) mkdirSync(DOCS_DIR, { recursive: true });\n\n  const rows = db.query<Memory, []>(\n    `SELECT * FROM memories ORDER BY importance DESC, category ASC, created_at DESC LIMIT 500`\n  ).all();\n\n  // Batch-fetch all tags in one query to avoid N+1\n  const tagsByMemory = getTagsBatch(db, rows.map(r => r.id));\n\n  const timestamp = new Date().toISOString().replace(\"T\", \" \").replace(/\\..+/, \"\");\n  const lines: string[] = [\n    `# Long-Term Memory — Generated Dump`,\n    ``,\n    `> Auto-generated by \\`memory/db.ts\\`. Last updated: ${timestamp}`,\n    `> This is a raw data export. For the architecture guide see \\`docs/memory-long-term.md\\`.`,\n    `> Edit via \\`/learn\\`, \\`/forget\\`, \\`/relate\\` commands — do not edit directly.`,\n    ``,\n  ];\n\n  const byCategory = new Map<string, Memory[]>();\n  for (const m of rows) {\n    if (!byCategory.has(m.category)) byCategory.set(m.category, []);\n    byCategory.get(m.category)!.push(m);\n  }\n\n  for (const [cat, mems] of byCategory) {\n    lines.push(`## ${cat.charAt(0).toUpperCase() + cat.slice(1)}`);\n    lines.push(\"\");\n    for (const m of mems) {\n      const tags = tagsByMemory.get(m.id) ?? [];\n      const tagStr = tags.length > 0 ? ` \\`[${tags.join(\", \")}]\\`` : \"\";\n      const scope = m.project_scope ? ` *(${m.project_scope})*` : \"\";\n      const imp = \"★\".repeat(m.importance) + \"☆\".repeat(5 - m.importance);","lineStart":650,"lineEnd":744,"totalLines":780,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","time":{"start":1780928833472,"end":1780928833486}},"metadata":{"openai":{"itemId":"fc_0140bca80acf93f6016a26d14158188195a7be6331f092be83"}},"id":"prt_ea7a167bb001q2mUuQ8XB85Azx","sessionID":"ses_1586048c5ffertmP8HohyAZ8wd","messageID":"msg_ea7a14cad001INVm0c42UMuN79"}}
